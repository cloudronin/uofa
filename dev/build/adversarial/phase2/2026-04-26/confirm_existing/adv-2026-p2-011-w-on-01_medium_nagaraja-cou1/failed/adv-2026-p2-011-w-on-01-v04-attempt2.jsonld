  "signature": "ed25519:b4e2d1f3a6c8b0d2e4f6a1c3b5d7e9f0a2c4b6d8e0f2a4c6b8d0e2f4a6c8b0d2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk level.",
      "rationale": "Commercial FEA software (Ansys) used by all three modelling teams carries documented QA procedures including version control, regression testing, and formal release validation. FDA in-house solver follows NIST-traceable verification protocols. Required gradation 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems with known analytical solutions (patch tests, cantilever beam) were run for each solver configuration. Results agreed to within 0.5% of analytical values, satisfying gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed across three refinement levels for each modelling team. Richardson extrapolation applied; discretization error estimated at less than 2% for peak von Mises stress at the screw-rod interface, exceeding the gradation 2 threshold and meeting gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver residuals monitored to convergence tolerance of 1e-6. Force and moment equilibrium checks performed at each load step. No divergence or ill-conditioning detected across the 11-construct ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Independent modelling by three separate teams (FDA, Ansys, DePuy Synthes) with blind comparison prior to result aggregation. Modelling protocols documented and reviewed by a senior analyst not involved in model construction, satisfying gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic material model adopted for titanium alloy components; contact mechanics modelled at screw-rod and rod-block interfaces using penalty formulation. Sensitivity analysis confirmed that non-linear geometric effects are negligible at the load levels prescribed by ASTM F1717. Model form uncertainty quantified and within accepted bounds for gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (E = 114 GPa, ν = 0.34 for Ti-6Al-4V) sourced from ASTM F136 and confirmed by coupon tensile tests. Geometry inputs derived from CMM measurements of physical specimens with tolerances within ±0.02 mm. Input uncertainty propagation performed via Monte Carlo (n=1000), yielding CV < 3% on QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 production-representative constructs tested, drawn from two independent manufacturing lots. Sample size exceeds the minimum recommended by the ASME V&V 40 guidance for gradation 3. Traceability of each specimen to lot documentation confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed at a single load configuration (compression-bending per ASTM F1717 §8.2) and at room temperature only. The absence of additional load conditions (e.g., torsion, fatigue) and environmental conditions (e.g., simulated body fluid) limits the achieved level to gradation 2, below the required gradation 3. This shortfall is acknowledged as a known gap in the current assessment scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Boundary conditions in FEA replicate the ASTM F1717 test fixture constraints (fixed lower block, displacement-controlled upper block). Applied displacement history matched to crosshead displacement records from each physical test. Friction coefficient at fixture interfaces calibrated from independent tribology measurements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Primary QoI is construct stiffness (N/mm) and yield load (N). FEA predictions compared against experimental values using area metric and u-pooling methods. Mean absolute percentage error across three modelling teams: 4.1%, 5.3%, 3.8%. All predictions fall within the 95% prediction interval of experimental data, satisfying gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and yield load are the mechanically relevant outputs for assessing spinal fixation device performance under compression-bending. These quantities directly inform the device's ability to maintain spinal alignment under physiological loads and are the quantities of interest specified in the clinical research application context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities replicate the exact ASTM F1717 protocol used in the regulatory submission context. The physical test specimens are production-representative, and the FEA boundary conditions mirror the test fixture. The validation domain is therefore directly relevant to the intended model use, satisfying gradation 3."
    }
  ],
