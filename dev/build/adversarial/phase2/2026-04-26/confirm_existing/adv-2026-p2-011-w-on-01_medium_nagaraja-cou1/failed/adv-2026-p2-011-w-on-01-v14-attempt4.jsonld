      "rationale": "Ansys Mechanical R19.2 is a commercially validated FEA solver with documented QA procedures including regression testing and release validation. FDA in-house code follows NIST-traceable verification protocols. Required and achieved levels are equal at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be reproduced within solver tolerance.",
      "rationale": "Code verification performed against Timoshenko beam bending benchmarks and patch test for hexahedral elements. Results agree with analytical solutions to within 0.5%, satisfying the required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating <5% change in QoI between successive refinements.",
      "rationale": "Three-level mesh refinement study conducted on the pedicle screw shank and rod interface. Von Mises stress at the critical cross-section changed by 2.1% between medium and fine meshes. Final mesh selected at fine level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence norms below 1e-6 for all load steps; energy balance verified.",
      "rationale": "All nonlinear load steps converged with force residual norm below 1e-7. Energy balance verified to within 0.3% across all 11 model instances. Exceeds required gradation."
