      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading replicate experimental setup within documented tolerance.",
      "rationale": "Fixture geometry modeled explicitly from engineering drawings. Applied displacement boundary conditions match actuator displacement protocol. Torque applied to set screws replicated via pretension elements calibrated to measured installation torque values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined; FEA predictions fall within experimental variability band.",
      "rationale": "Construct stiffness (N/mm) and yield load (N) compared using normalized RMS error metric. FEA ensemble mean stiffness within 4.2% of experimental mean; all individual predictions within one experimental standard deviation. Yield load predictions within 6.8% of experimental mean."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical performance indicators and regulatory acceptance criteria.",
      "rationale": "Construct stiffness and yield load are the primary mechanical performance metrics specified in ASTM F1717 and referenced in FDA guidance for spinal implant submissions. These QoIs directly inform fatigue life predictions and clinical failure mode assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario physicsand geometry sufficiently similar to intended use scenario.",
      "rationale": "Validation performed on the identical screw geometry, rod diameter, and construct configuration intended for clinical application. ASTM F1717 test setup is the regulatory standard for this device class, ensuring direct relevance of the validation activity to the submission context."
