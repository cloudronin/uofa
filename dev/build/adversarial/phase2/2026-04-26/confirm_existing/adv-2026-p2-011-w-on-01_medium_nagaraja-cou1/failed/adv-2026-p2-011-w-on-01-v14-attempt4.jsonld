      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second analyst; documented checklist completed.",
      "rationale": "Model setup reviewed independently by a second credentialed analyst at each of the three participating organizations. Discrepancies reconciled prior to final simulation runs. Checklist archived in project repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions documented and justified relative to the physical phenomena of interest.",
      "rationale": "Linear elastic material model justified by sub-yield loading regime confirmed experimentally. Contact formulation uses augmented Lagrangian with friction coefficient derived from tribological literature for Ti-6Al-4V on stainless steel. Geometric nonlinearity included."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs traceable to measured or certified values.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and Poisson ratio (0.34) sourced from ASTM F136 material certificates for each lot. Screw geometry digitized from CMM measurements of production hardware. Rod diameter verified with calibrated micrometer."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N >= 10 specimens from production lots; dimensional characterization performed.",
      "rationale": "N=11 constructs assembled from production-representative hardware. Dimensional characterization performed on each specimen prior to testing. Specimens span two independent production lots to capture manufacturing variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; at least two distinct load levels or configurations tested.",
      "rationale": "Testing performed at a single axial compressive load of 1200 N per ASTM F1717 standard protocol. Variation in loading angle or magnitude not explored in this validation activity. Achieved gradation falls below required level; this gap is acknowledged and accepted given the regulatory precedent for single-condition F1717 submissions."
    },
    {
      "type": "CredibilityFactor",
