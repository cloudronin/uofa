  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for Model Risk 3. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is acknowledged and documented; the assessment team determined that the ASTM F1717 standard configuration is the regulatory reference condition and that the overall evidence package provides sufficient credibility for the intended decision. The FEA model ensemble is accepted as fit for purpose for supporting pre-market submissions pertaining to non-cannulated 7.5 mm pedicle screw constructs under compression-bending loading.",
