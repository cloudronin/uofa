      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from NAFEMS and ASME V&V 10 were used to verify solver correctness for contact mechanics and large-displacement beam-column problems. All benchmark results fell within published reference tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating less than 5% change in QoI between successive refinements.",
      "rationale": "Mesh convergence studies were performed on the pedicle screw shank and rod interface regions. Peak von Mises stress and construct stiffness changed by less than 3.8% between the medium and fine mesh, satisfying the 5% convergence criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms and energy balance errors below solver-specified tolerances throughout all load steps.",
      "rationale": "Nonlinear force and displacement residuals were monitored across all increments. Energy balance errors remained below 0.1% and no divergence or excessive iteration counts were observed across the 11-specimen ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and material assignments by a second analyst.",
      "rationale": "Each model implementation was independently reviewed by a second qualified analyst prior to simulation execution. Boundary condition application, contact pair definitions, and material property assignments were verified against the study protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics and constitutive assumptions justified by prior literature and sensitivity analysis.",
      "rationale": "Linear elastic material models for titanium alloy components are justified by the predominantly elastic response regime of the F1717 compression-bending protocol. Sensitivity analyses confirmed that plasticity onset does not materially affect stiffness predictions within the tested load range."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from traceable measurements with documented uncertainty.",
      "rationale": "Titanium alloy (Ti-6Al-4V ELI) elastic modulus and Poisson's ratio were taken from ASTM F136 and supplier certificates of conformance. Screw and rod geometry was measured via CMM with traceability to NIST standards. Input uncertainty bounds were propagated through a one-at-a-time sensitivity study."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production lots with documented dimensional and material traceability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. All specimens were drawn from production lots with full dimensional inspection records and material certifications, satisfying the sample size and traceability requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading environments or multiple test configurations are evaluated.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending configuration. While this configuration is the regulatory standard, only one load angle and one construct geometry were evaluated, limiting coverage of the full clinical loading envelope. This factor falls one gradation below the required level and represents a documented gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs demonstrably correspond to measured experimental specimen parameters.",
      "rationale": "Specimen-specific geometric measurements were used to parameterize each of the 11 FEA models, ensuring that screw diameter, rod diameter, and construct span length matched the as-tested specimens. No nominal geometry substitutions were made."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., MAPE, R², or validation metric per ASME V&V 10) computed and within pre-specified acceptance bounds.",
      "rationale": "Construct stiffness and yield load were compared between FEA predictions and experimental measurements. Mean absolute percentage error was 4.2% for stiffness and 6.1% for yield load across all three model implementations, within the pre-specified 10% acceptance bound."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to the device performance claims and failure modes of concern.",
      "rationale": "Construct stiffness and yield load are the primary performance endpoints specified in ASTM F1717 and are directly linked to the biomechanical performance claims for spinal fixation. These QoIs are predictive of fatigue life initiation and immediate post-operative stability."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario sufficiently represents the intended use conditions to support the decision being made.",
      "rationale": "The ASTM F1717 compression-bending validation scenario closely represents the mechanical loading experienced by pedicle screw constructs under physiological compressive and bending loads. The validated model ensemble supports the intended use of predicting construct performance under regulatory submission conditions."
    }
  ],
