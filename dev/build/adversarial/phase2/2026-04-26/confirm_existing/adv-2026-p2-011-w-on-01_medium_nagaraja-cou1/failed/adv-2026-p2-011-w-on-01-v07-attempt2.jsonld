      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup procedures were documented in standardized simulation protocols. Independent peer review of boundary conditions, loading definitions, and material assignments was conducted by a second analyst prior to result extraction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic material models were used for titanium alloy components consistent with the small-strain regime of ASTM F1717 testing. Contact mechanics between screw-rod interface and rod-block interface were represented with penalty-based contact formulations validated against physical observations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (elastic modulus, Poisson's ratio) were sourced from ASTM standards and manufacturer-certified material certificates for Ti-6Al-4V ELI. Geometric dimensions were taken from calibrated coordinate measuring machine measurements of production components."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. Samples were production-representative components from the same manufacturing lot, and dimensional inspection confirmed conformance to design specifications."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing was conducted under a single standardized ASTM F1717 condition (static compression-bending at 5 mm/min crosshead speed). Only one load configuration was evaluated; the absence of additional load levels or environmental conditions (e.g., fatigue, dynamic) limits the achieved level to 2, below the required level of 3 for this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions, loading magnitudes, and fixture geometries were matched to the physical test setup using calibrated measurements. Torque values applied to screw-rod set screws in the physical test were replicated as equivalent pre-stress conditions in the FEA models."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and peak load at 0.5% offset yield were compared between FEA predictions and experimental measurements. Quantitative metrics including mean error, standard deviation of error, and 95% prediction interval coverage were computed across the N=11 constructs and three FEA implementations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The quantities of interest (construct stiffness and yield load) are directly specified by ASTM F1717 and are the primary biomechanical endpoints used in regulatory submissions for spinal implant systems. These quantities are clinically and regulatorily meaningful for the intended device class."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The validation activity directly replicates the ASTM F1717 test protocol in both the physical experiments and the computational models. The non-cannulated 7.5 mm screw geometry evaluated corresponds to the specific device configuration for which the FEA model is intended to support regulatory credibility claims."
