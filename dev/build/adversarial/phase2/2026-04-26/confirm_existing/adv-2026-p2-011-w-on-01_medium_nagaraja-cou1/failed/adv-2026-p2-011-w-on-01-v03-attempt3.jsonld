      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and material assignments must be documented.",
      "rationale": "Each model underwent independent peer review by a second analyst not involved in the original setup. Boundary condition definitions and material property assignments were confirmed against the ASTM F1717 protocol and manufacturer data sheets."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification of continuum mechanics assumptions, contact formulation, and material constitutive model must be provided.",
      "rationale": "Linear elastic titanium alloy properties are appropriate for the load range tested (below yield). Frictional contact with penalty formulation captures screw-rod interface behaviour. Geometric nonlinearity is included to handle the bending-dominated load path."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions must be traceable to measured values from the test specimens.",
      "rationale": "Titanium alloy elastic modulus and yield strength were taken from certified material test reports for the specific lot used in the N=11 experimental constructs. Screw geometry was measured via CMM and compared to CAD nominal; deviations were within 0.05 mm."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sample size must support statistical comparison; specimen traceability must be documented.",
      "rationale": "N=11 constructs from a single manufacturing lot were tested across two independent laboratories. Each specimen was serialised and its as-measured geometry recorded. The sample size is consistent with ASTM F1717 guidance for submission-level testing."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple load levels or environmental conditions must be represented to establish model validity across the COU envelope.",
      "rationale": "Testing was performed under a single quasi-static compressive load ramp at room temperature per ASTM F1717. Fatigue and elevated-temperature conditions were not included. Achieved level (2) is below the required level (3); this gap is acknowledged as a limitation of the current validation dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs must be demonstrably equivalent to experimental specimen parameters within stated tolerances.",
      "rationale": "As-measured specimen dimensions and material certifications were used to populate each FEA model. A parameter equivalency table was prepared mapping each experimental measurement to its corresponding model input; all deviations were within the specified tolerance band."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., normalised RMSE) must be within pre-specified acceptance bounds.",
      "rationale": "Construct stiffness predictions from all three ensemble models fell within ±8% of the experimental mean (normalised RMSE = 0.062). Failure load predictions were within ±12%. Both metrics satisfy the pre-specified ±15% acceptance bound."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must be directly linked to the clinical or regulatory decision being supported.",
      "rationale": "Construct stiffness and failure load under ASTM F1717 compression-bending are the primary biomechanical endpoints used in 510(k) submissions for posterior spinal fixation systems. These quantities are directly relevant to the regulatory decision context in which this model has been applied in clinical research."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must replicate the essential physics and geometry of the intended use scenario.",
      "rationale": "The ASTM F1717 test replicates the in vivo loading environment of a posterior spinal fixation construct under compression-bending. The non-cannulated 7.5 mm screw geometry and UHMWPE vertebral body simulants are representative of clinical use. Validation activities are judged sufficiently relevant to the intended submission scope."
    }
