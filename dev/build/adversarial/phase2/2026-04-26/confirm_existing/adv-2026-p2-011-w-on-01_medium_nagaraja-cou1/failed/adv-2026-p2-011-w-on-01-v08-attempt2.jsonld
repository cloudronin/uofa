  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical R19.2 used under FDA-validated software quality assurance procedures including installation qualification, operational qualification, and version-controlled simulation environment. All three ensemble solvers (FDA in-house, Ansys, DePuy Synthes) operate under documented SQA plans consistent with ASME VV40 Gradation 3 expectations."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Benchmark problems from NAFEMS and internal FDA test suite used to verify solver correctness for linear elastic structural analysis. All three solvers passed relevant benchmark suites with residuals below 1% of analytical solutions. Code verification documented in solver qualification reports."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Mesh convergence study performed on the pedicle screw-rod construct with three successive mesh refinements. The quantity of interest (peak von Mises stress at screw-rod interface and construct stiffness) changed by less than 2% between the two finest meshes, confirming discretization error is within acceptable bounds for Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Linear static solver with direct sparse solver employed. Residual norms monitored and confirmed below 1e-8 for all load cases. Iterative solver cross-check performed on representative constructs; results agreed within 0.1% of direct solver outputs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Independent model review conducted by a second analyst not involved in model development. Boundary conditions, material assignments, and contact definitions were verified against the simulation plan. No use errors identified. Simulation plan and review checklist archived in the project document management system."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Linear elastic continuum FEA model form selected based on prior literature and the predominantly elastic deformation regime of the ASTM F1717 test. Titanium alloy (Ti-6Al-4V) material model validated against coupon tensile test data. Frictional contact at screw-rod interface modeled with coefficient of friction from published tribological data for Ti-Ti interfaces."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Geometric inputs derived from calibrated CMM measurements of physical test specimens (N=11). Material properties sourced from lot-specific tensile testing and ASTM F136 certificate of conformance. Torque preload on set screws measured with calibrated torque wrench and applied as equivalent pretension in the FEA. Input uncertainty quantified via sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. Constructs sourced from a single production lot to minimize inter-specimen material variability. Sample size sufficient to characterize construct-to-construct variability and support statistical comparison with FEA predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Testing performed under a single load condition (compression-bending at 5 degrees per ASTM F1717). Only one test condition evaluated; additional load angles or magnitudes were not included in this validation campaign. This limitation reduces the achieved level to Gradation 2, below the required Gradation 3 for this model risk level. Accepted as a known gap pending future multi-condition validation."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "FEA input parameters (geometry, material properties, boundary conditions, applied loads) were mapped directly to measured experimental parameters for each of the N=11 specimens. Equivalency matrix documented in the validation report, confirming one-to-one correspondence between experimental and simulation inputs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Construct stiffness (N/mm) and peak load at 2% offset yield compared between FEA and experiment for all N=11 specimens. Prediction interval analysis performed; FEA predictions fell within the 95% prediction interval of experimental results for 10 of 11 constructs. Mean absolute percentage error 4.7% for stiffness and 6.1% for peak load."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Construct stiffness and yield load are the primary quantities of interest for regulatory assessment of spinal fixation device mechanical performance per ASTM F1717. These quantities directly inform the safety and effectiveness determination. The selected QoIs are therefore highly relevant to the intended regulatory decision context."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Validation activities replicate the ASTM F1717 test configuration, materials, and loading conditions that constitute the primary use scenario for this FEA model. The validation domain closely matches the intended application domain, supporting high relevance. Cross-laboratory reproducibility further strengthens confidence in the validation evidence base."
    }
  ],
