    "https://uofa.net/synth/data/nagaraja-f1717-experimental-n11-lab1",
    "https://uofa.net/synth/data/nagaraja-f1717-experimental-n11-lab2"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nagaraja-f1717-compression-bending-result-001",
      "type": "ValidationResult",
      "name": "F1717 compression-bending FEA vs. experiment comparison — N=11 constructs, two laboratories"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4044315",
