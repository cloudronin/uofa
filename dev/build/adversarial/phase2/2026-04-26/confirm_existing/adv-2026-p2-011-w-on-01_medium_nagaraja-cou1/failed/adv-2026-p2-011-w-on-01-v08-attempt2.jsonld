  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "12 of 13 V&V 40 credibility factors meet or exceed the required level for model risk level 3. One factor (Test conditions) is below the required level due to the single-condition test campaign; this gap is accepted given the regulatory context is limited to the ASTM F1717 compression-bending configuration and the overall body of evidence is sufficient to support the intended regulatory submission. The FEA model ensemble demonstrates adequate credibility for its stated purpose.",
