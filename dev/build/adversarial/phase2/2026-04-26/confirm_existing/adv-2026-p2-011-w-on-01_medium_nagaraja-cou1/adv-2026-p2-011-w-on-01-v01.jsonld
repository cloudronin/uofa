  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA codes (FDA in-house, Ansys 2021R2, DePuy Synthes internal) operate under documented software quality management systems with version control, regression testing, and audit trails. Achieved level exceeds required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be reproduced within specified tolerance.",
      "rationale": "Each code in the ensemble was verified against NAFEMS benchmark problems and simple beam-bending analytical solutions. Errors were below 1% for all benchmark cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change less than 5% between successive refinements.",
      "rationale": "A systematic mesh convergence study was performed for all three models. Peak von Mises stress and construct stiffness changed by less than 3% between the medium and fine meshes, satisfying the convergence criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms and energy balance checks must be within solver-specified tolerances.",
      "rationale": "Force and moment residuals were monitored throughout each nonlinear static analysis. All solutions converged with residual norms below 1e-6 relative tolerance. Energy balance was verified at each load step."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented review of model setup by an independent analyst.",
      "rationale": "Each model configuration was independently reviewed by a second analyst not involved in original setup. Boundary conditions, material assignments, and contact definitions were verified against the analysis plan prior to execution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics and constitutive assumptions must be justified relative to the dominant mechanisms in the ASTM F1717 test.",
      "rationale": "Linear elastic titanium alloy constitutive models are appropriate for the pre-yield stiffness QoI. Nonlinear contact between screw and block is explicitly modeled. Geometric nonlinearity is included to capture load-displacement response accurately under large-displacement compression-bending."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material and geometric inputs must be traceable to measured specimen data or certified material specifications.",
      "rationale": "Titanium alloy Ti-6Al-4V material properties were sourced from ASTM F136 certified mill certificates for each lot. Geometric dimensions were measured on representative screws using CMM with reported tolerances incorporated as input uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens must be representative of the production device geometry and material lot.",
      "rationale": "N=11 constructs were assembled from production-representative screws from a single manufacturing lot, verified by dimensional inspection. Two independent laboratories contributed specimens to assess inter-laboratory variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the intended use.",
      "rationale": "Testing was conducted under a single axial compressive load condition per ASTM F1717. While this condition is the standard regulatory benchmark, it represents only one point in the possible loading space. Multi-axial and fatigue conditions were not included in this validation activity, resulting in achieved level below required level for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs must be demonstrably equivalent to the physical test specimen parameters.",
      "rationale": "CMM measurements of each test specimen were used to update individual model instances where dimensional deviations exceeded 0.05 mm. Material properties were matched to specimen-specific mill certificate values. Fixture compliance was characterized and incorporated into boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E-factor or normalized error) must be within pre-specified acceptance band.",
      "rationale": "Construct stiffness and yield load were compared using a normalized error metric. All three ensemble members predicted stiffness within 8% of experimental mean. Yield load predictions fell within the experimental 95% confidence interval for 10 of 11 specimens."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from the model must directly correspond to the regulatory and clinical decision quantities.",
      "rationale": "Construct stiffness and yield load are the primary QoIs specified in ASTM F1717 and are directly referenced in FDA guidance for spinal implant 510(k) submissions. These QoIs are therefore directly relevant to the regulatory decision context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar in geometry, loading, and material to the intended use scenario.",
      "rationale": "The validation activity replicates the exact regulatory test method (ASTM F1717) using production-representative hardware. The FEA models are geometrically and materially equivalent to the submission device. Validation relevance is therefore rated at the highest achievable level for this test-based approach."
    }
  ],
