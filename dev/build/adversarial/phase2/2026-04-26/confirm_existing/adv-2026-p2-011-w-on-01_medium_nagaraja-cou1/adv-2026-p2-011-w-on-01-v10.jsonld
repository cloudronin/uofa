  "signature": "ed25519:9f8e7d6c5b4a3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8c7b6a5f4e3d2c1b0a9f8e",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "Ansys Mechanical 2022R2 is a commercially validated solver with documented V&V procedures. FDA internal QA records confirm version-controlled model files and regression test suite passage. Achieved level 3 exceeds required level 2 for Model Risk Level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including cantilever beam bending and contact patch tests were executed against analytical solutions. Maximum deviation of 0.4% confirms solver correctness for the linear-elastic regime employed in this analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change below 5% between successive refinements.",
      "rationale": "Three-level mesh refinement study (coarse 1.5 mm, medium 0.8 mm, fine 0.4 mm global seed) performed on screw shank and rod interface regions. Von Mises stress at critical cross-section changed by 1.8% between medium and fine meshes; GCI estimated at 2.3%. Fine mesh adopted for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms and energy balance must satisfy solver convergence criteria documented in the simulation plan.",
      "rationale": "Direct sparse solver (SPARSE) employed; iterative equilibrium residuals below 1e-6 for all load steps. Energy balance error less than 0.01% across all 11 model instances. No convergence warnings recorded in solution logs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by a second analyst must be documented.",
      "rationale": "Model setup independently reviewed by a second FDA analyst not involved in original construction. Boundary condition application, material assignment, and contact pair definitions verified against the simulation plan. No discrepancies identified. Review record archived in FDA EDMS."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Selected constitutive model must be justified relative to observed material behavior in the validation dataset.",
      "rationale": "Ti-6Al-4V and PEEK rod materials modeled as linear isotropic elastic consistent with sub-yield loading per F1717 protocol. Literature-derived elastic moduli (E=114 GPa Ti alloy, E=3.6 GPa PEEK) corroborated by material certificates from DePuy Synthes. Geometric nonlinearity disabled given small-displacement regime confirmed by experimental DIC data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material and geometric inputs must be traceable to measurement data or certified material specifications.",
      "rationale": "Screw and vertebral body block geometry derived from calibrated CMM measurements (±0.01 mm). Material properties sourced from lot-specific tensile test coupons for Ti-6Al-4V and manufacturer data sheet for UHMWPE vertebral body surrogates. All input values documented in simulation data package with traceability identifiers."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sample size must be sufficient to characterize variability; samples must be representative of the device population.",
      "rationale": "N=11 constructs assembled from production-representative components drawn from a single manufacturing lot. Sample size supports coefficient of variation estimation for stiffness and yield load. Both laboratories used identical assembly torque specifications per F1717 Section 8. Lot traceability documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of conditions relevant to the intended use.",
      "rationale": "Testing performed at a single load configuration (compression-bending at 5 degrees) per F1717. While this represents the standard regulatory test, it does not encompass the full range of in vivo loading directions. Achieved level 2 is below the required level 3; this gap is acknowledged and documented as a limitation of the current validation scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs used in validation simulations must correspond to measured physical test parameters.",
      "rationale": "Rod-to-screw clearance, torque preload translated to equivalent contact pressure, and actuator displacement rate all matched between simulation and physical test. Actuator displacement rate effects confirmed negligible by quasi-static rate sensitivity study. Correspondence table provided in simulation data package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., MAPE, confidence interval overlap) must be defined a priori and satisfied.",
      "rationale": "Primary QoI is construct stiffness (N/mm) and 0.2% offset yield load (N). Mean absolute percentage error across N=11: stiffness 3.1%, yield load 4.7%, both within the pre-specified 10% acceptance threshold. Prediction intervals overlap experimental 95% CI for all specimens. Bland-Altman analysis shows no systematic bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from the model must be directly relevant to the clinical or regulatory decision being supported.",
      "rationale": "Construct stiffness and yield load are the primary endpoints specified in ASTM F1717 and referenced in FDA guidance for spinal fixation device 510(k) submissions. These quantities directly inform the biomechanical performance claim. QoI selection rationale documented in the simulation plan prior to execution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar to the intended use scenario to support extrapolation of credibility.",
      "rationale": "Validation performed on the identical device configuration, material system, and test standard (F1717) as the regulatory submission scenario. Physical test and simulation share the same geometric fidelity level. The validation scenario is judged to be highly representative of the submission use case, supporting a credibility determination of Accepted for the Minimal profile submission."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-dms-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for Model Risk Level 3. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is noted and bounded by the scope of the F1717 standard protocol. The overall evidence body is judged sufficient to support the regulatory credibility claim for this non-cannulated pedicle screw compression-bending FEA model under the Minimal profile. A full-profile resubmission with structured ContextOfUse binding is recommended prior to pivotal submission.",
