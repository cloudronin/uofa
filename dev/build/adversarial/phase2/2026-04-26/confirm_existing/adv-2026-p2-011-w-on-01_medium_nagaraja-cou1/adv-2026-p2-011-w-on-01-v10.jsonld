    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-001",
      "type": "ValidationResult",
      "name": "Compression-bending stiffness and yield load comparison — FEA vs. N=11 physical constructs"
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-002",
      "type": "ValidationResult",
      "name": "Cross-laboratory repeatability assessment for F1717 test protocol"
    }
  ],
