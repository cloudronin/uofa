  "signature": "ed25519:9b2e4f7a1c3d6e8b0f2a5c7d9e1b3f5a7c9d2e4f6a8b0c2d4e6f8a0b2c4d6e8f",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "All three FEA solvers (FDA in-house, Ansys Mechanical 2022 R1, DePuy Synthes validated solver) operate under documented quality management systems with version-controlled release procedures. Software qualification records are on file and traceable to ISO 13485-compliant QMS documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "Benchmark problems from ASME V&V 10 and solver vendor verification suites have been executed for all three codes. Patch-test results and manufactured-solution comparisons confirm correct implementation of the structural element formulations used in the pedicle screw models."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "Mesh convergence studies were conducted for each model in the ensemble. A Richardson extrapolation-based grid convergence index (GCI) was computed for peak von Mises stress and construct stiffness. GCI values were below 2% for all quantities of interest, confirming adequate discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "Iterative solver residuals were monitored and confirmed to converge below 1e-6 for all load steps. Contact stabilisation settings were consistent across ensemble members, and force equilibrium was verified at each increment."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "Model setup procedures are documented in a detailed simulation protocol reviewed by two independent analysts. Boundary condition application, material assignment, and contact definition were cross-checked against the protocol prior to each simulation run. Minor discrepancies identified during review were resolved before results were accepted."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "Linear elastic material models with titanium alloy properties (Ti-6Al-4V per ASTM F136) are used for all metallic components. Contact between screw and rod is modelled with frictional contact (mu=0.2). The chosen model form is well-established for static structural analysis of spinal implant constructs at the load levels prescribed by F1717."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "Material properties were sourced from certified material test reports for the production lot used in experimental specimens. Geometric inputs were derived from CMM measurements of physical samples. Torque-preload conversion for set-screw tightening was characterised experimentally and applied uniformly across the ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "N=11 physical constructs were assembled from production-representative components. Sample size provides adequate statistical power for comparison given the low coefficient of variation observed in preliminary testing. Traceability of each specimen to material and dimensional records is maintained."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "Testing was conducted at a single load condition (compression-bending at 10 Nm offset per F1717). Only one test configuration was exercised; no variation in load level, offset distance, or environmental condition (e.g., temperature, hydration) was included. This limits the breadth of validation evidence and is the one factor below required level in this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "Simulation boundary conditions replicate the F1717 test fixture constraints, including the potting depth, load application point, and fixture compliance. Fixture stiffness was characterised experimentally and incorporated into the model. Input parameter mapping between physical test and simulation has been formally documented."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "Construct stiffness (N/mm) and yield load (N) are compared between simulation and experiment using normalised error metrics. All ensemble members predict stiffness within 8% of the experimental mean. A validation metric based on the area validation metric (AVM) approach was computed and found acceptable."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "Construct stiffness and yield load are the quantities of interest specified by ASTM F1717 and are directly linked to the mechanical performance claims in the device submission. These quantities are mechanistically relevant to the failure modes of concern for pedicle screw constructs under physiological-surrogate loading."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the given model risk classification.",
      "rationale": "The validation activity directly mirrors the intended use scenario: static compression-bending of a non-cannulated 7.5 mm pedicle screw construct per F1717. Geometry, material, assembly, and loading are representative of the device configuration for which simulation predictions are sought. Relevance is considered high despite the single test condition limitation noted under Test conditions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a Model Risk Level 3 assessment. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is acknowledged; however, the overall body of evidence — including multi-laboratory experimental data, ensemble model agreement within 8%, and rigorous input characterisation — is judged sufficient to support the intended use of the FEA model for regulatory submission purposes. The assessment team accepts the credibility package under the Minimal profile with the noted limitation on test condition breadth.",
