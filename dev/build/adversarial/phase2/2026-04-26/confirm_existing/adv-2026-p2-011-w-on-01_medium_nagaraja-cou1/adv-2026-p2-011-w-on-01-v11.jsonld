  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used in the FEA ensemble (Ansys Mechanical) must be validated per vendor quality management procedures and FDA 21 CFR Part 820 software validation requirements.",
      "rationale": "Ansys Mechanical R19.2 was used under a documented software quality assurance plan. Vendor validation documentation, version control records, and internal qualification testing were reviewed and found compliant with 21 CFR Part 820 and ISO 13485 requirements. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations through benchmark problems with known analytical solutions.",
      "rationale": "Numerical code verification was performed using standard ASME benchmark problems including beam bending and contact patch tests. Results were within 0.5% of analytical solutions, confirming correct implementation of the linear static structural solver used for F1717 loading simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence must be demonstrated via a systematic refinement study with less than 5% change in quantities of interest between successive refinement levels.",
      "rationale": "A three-level mesh convergence study was conducted on the pedicle screw-rod construct model. Peak von Mises stress at the screw-rod interface changed by less than 2.1% between medium and fine meshes. The fine mesh configuration was selected for all production simulations, satisfying the convergence criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals and energy balance errors must be monitored and documented to confirm numerical solution quality.",
      "rationale": "Linear static solver residuals were monitored for all 11 simulation cases. Force and moment equilibrium residuals remained below 1e-6 relative tolerance. No ill-conditioning or solver warnings were observed. Numerical solver error is considered negligible for this linear elastic analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup, boundary condition application, and post-processing procedures must be documented and independently reviewed to minimize operator-induced errors.",
      "rationale": "All model setup procedures were documented in a controlled simulation plan. An independent analyst performed a technical review of boundary conditions, load application, and material assignments prior to execution. Post-processing scripts were validated against manual calculations for a representative subset of cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The mathematical model form (linear elastic, small deformation) must be appropriate for the loading regime and quantities of interest defined for F1717 compression-bending.",
      "rationale": "Linear elastic constitutive models with isotropic material properties were applied to titanium alloy components. Deformations under F1717 loading remain within the elastic regime for the construct geometry studied. Geometric nonlinearity was evaluated in a sensitivity study and found to contribute less than 3% variation in peak stress, justifying the linear model form."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometric parameters, and boundary conditions must be derived from traceable, documented sources with uncertainty quantification.",
      "rationale": "Ti-6Al-4V ELI material properties were sourced from ASTM F136 and manufacturer certificates of conformance for the specific lot used in physical testing. Geometric inputs were derived from CMM measurements of test specimens. Sensitivity analyses were performed on key material and geometric parameters to bound input uncertainty contributions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Physical test samples must be representative of the simulated geometry, material, and manufacturing process, with traceability to production specifications.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested. All specimens were manufactured from production-equivalent Ti-6Al-4V ELI bar stock using production tooling. Dimensional inspection confirmed conformance to design drawings within specified tolerances. Sample traceability was maintained via lot numbers and inspection records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the relevant range of loading scenarios and environmental conditions to adequately characterize model predictive capability.",
      "rationale": "Physical testing was conducted under a single standardized ASTM F1717 test configuration (10 mm offset, static compression-bending). While this configuration is the regulatory standard, only one test condition was evaluated, limiting the ability to characterize model behavior across the full range of clinically relevant loading scenarios. This factor is below the required level and represents a known gap in the validation evidence base."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to those present in the physical test, with documented mapping between experimental measurements and model inputs.",
      "rationale": "A formal parameter mapping table was developed linking each simulation input to the corresponding experimental measurement or specification. Material properties, screw geometry, rod diameter, block spacing, and fixture constraints were matched to experimental conditions. Residual discrepancies were quantified and incorporated into the uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized error, confidence interval coverage) must be defined a priori and applied consistently to assess agreement between simulation outputs and experimental measurements.",
      "rationale": "Construct stiffness and peak load at 2% offset yield were selected as primary quantities of interest. Normalized RMS error between FEA predictions and experimental means was 4.2% for stiffness and 6.8% for peak load across the N=11 ensemble. Both metrics satisfied the pre-specified acceptance threshold of less than 10% normalized error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest extracted from the simulation must be directly relevant to the clinical or regulatory decision being supported.",
      "rationale": "Construct stiffness and structural yield load are the primary regulatory endpoints for ASTM F1717 submissions. These quantities directly inform the clinical risk assessment for pedicle screw construct fatigue and static failure. The selected quantities of interest are fully aligned with FDA guidance on spinal implant mechanical testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activities must be sufficiently representative of the intended use conditions to provide meaningful evidence of predictive capability within the COU.",
      "rationale": "The validation activity directly replicates the ASTM F1717 test protocol that constitutes the regulatory submission basis. The simulated geometry, materials, loading, and boundary conditions are matched to the physical test. While only one test condition was assessed (see Test conditions factor), the validation activity is otherwise highly representative of the intended regulatory use."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors achieved the required credibility level. The Test conditions factor fell one gradation below the required level due to the single-condition F1717 test protocol, which is a regulatory constraint rather than an assessment deficiency. The overall body of evidence, including cross-laboratory reproducibility across N=11 specimens and quantitative output comparison within pre-specified acceptance thresholds, is judged sufficient to support use of the FEA model ensemble for regulatory submission purposes. The assessment is accepted with acknowledgment of the test conditions limitation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
