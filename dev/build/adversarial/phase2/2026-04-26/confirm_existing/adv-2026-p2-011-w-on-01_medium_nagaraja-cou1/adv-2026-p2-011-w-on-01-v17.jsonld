  "signature": "ed25519:9c1d4e7a2f305b8c6e1a4d7f0b3c9e2a5d8f1b4e7a0c3f6d9b2e5a8c1f4d7b0e3a6c9f2d5b8e1a4c7f0d3b6e9a2c5f8d1b4e7a0c3f6d9b2e5a8c1f4d7b0e3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA codes (FDA in-house, Ansys Mechanical, DePuy Synthes proprietary solver) operate under documented software quality plans with version control, regression testing, and traceable release histories. Achieved level exceeds the required level for this model risk classification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be reproduced within accepted tolerances.",
      "rationale": "Each solver in the ensemble has been verified against NAFEMS benchmark problems and simple beam-bending analytical solutions. Residual norms and energy balance checks are reported for all production runs. Achieved level is sufficient for the stated model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate quantity-of-interest change below 5% between successive refinements.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw shank and rod-screw interface regions. Peak von Mises stress and construct stiffness changed by less than 3.1% between medium and fine meshes. Richardson extrapolation was applied to estimate the discretization error bound."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must fall below 1e-6 for all load steps; energy balance error below 0.1%.",
      "rationale": "Direct sparse solvers were used for linear steps; Newton-Raphson convergence criteria of 1e-6 force norm were enforced for nonlinear contact iterations. Energy balance errors remained below 0.05% across all 11 model instances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup procedures must be documented and independently reviewed by a second analyst.",
      "rationale": "Boundary condition application, material assignment, and contact definition procedures are documented in a controlled simulation plan. An independent analyst performed a blind re-setup of two of the eleven models; results agreed within 1.8% for construct stiffness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Physics represented must be justified relative to dominant load-transfer mechanisms identified in the COU description.",
      "rationale": "Linear elastic continuum mechanics with frictional contact at screw-rod and screw-block interfaces captures the dominant bending and shear load transfer. Plasticity was excluded based on a pre-analysis showing peak strains remain below 0.2% yield for the titanium alloy at the specified load levels. Justification is documented in the simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured specimen data or certified material certificates.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and Poisson's ratio (0.33) are sourced from ASTM F136 material certificates for the tested lot. Screw geometry was digitized from CMM measurements of three representative screws from the test batch. Input uncertainty bounds are documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test sample population must be representative of the device configuration described in the simulation plan.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from a single production lot were tested. All samples were from the same geometry and surface finish specification. Sample traceability records are on file at both laboratories."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the simulation COU description.",
      "rationale": "Testing was conducted under a single compression-bending load condition per ASTM F1717 protocol. The required level of 3 is not achieved because only one load magnitude and one fixation configuration were evaluated. This gap is acknowledged; the assessment team accepted residual uncertainty given the regulatory submission scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions must be demonstrably equivalent to the experimental fixture constraints and applied loads.",
      "rationale": "Fixture stiffness was characterized experimentally and incorporated as spring boundary conditions in the FEA models. Applied load magnitudes and crosshead displacement rates were matched to test machine data logs. Equivalency was confirmed by comparing predicted and measured fixture reaction forces."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted quantities of interest must be compared against experimental measurements using an appropriate metric with uncertainty quantification.",
      "rationale": "Construct stiffness and peak bending moment at 1% offset yield were compared using the U95 validation metric per ASME V&V 10.1. Across 11 constructs, the model ensemble mean stiffness fell within the experimental 95% confidence interval. Systematic and random components of experimental uncertainty were quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest extracted from the model must be directly linked to the decision-driving performance metrics.",
      "rationale": "Construct stiffness and bending moment capacity are the primary performance metrics used in regulatory submissions for posterior spinal fixation devices. These quantities are directly predictable by the FEA ensemble and are the basis for the acceptance decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation experiment must be sufficiently similar to the intended use scenario to support extrapolation of credibility findings.",
      "rationale": "The ASTM F1717 validation experiment replicates the dominant mechanical environment of the implant in situ. The construct geometry, material, and loading mode are consistent with the clinical application described in the simulation plan narrative. The validation activity is assessed as directly relevant to the prediction context."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-credibility-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for model risk level 3. The single shortfall in Test conditions (achieved level 2 vs. required level 3) was accepted by the team on the basis that the ASTM F1717 single-condition protocol is the regulatory standard for this device class and that the experimental uncertainty characterization adequately bounds the prediction error. Overall credibility is assessed as sufficient to support the intended regulatory submission.",
