  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the assessed model risk.",
      "rationale": "All three FEA platforms (FDA in-house, Ansys, DePuy Synthes) operate under documented software quality management systems with version control, regression testing, and traceability to requirements. Achieved level exceeds the required level for a Model Risk Category 3 application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems with known analytical solutions were used to verify solver implementations across all three codes. Patch tests and manufactured-solution checks confirm correct numerical implementation of the linear static structural formulations employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence studies were performed independently on each platform. Quantities of interest (peak von Mises stress, construct stiffness) showed less than 2% change between the penultimate and final mesh refinement levels, satisfying the convergence criterion adopted for this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Direct sparse solvers were employed, yielding residual norms below 1e-8 relative tolerance. Iterative solver alternatives were checked on a representative sub-model and confirmed equivalent results, providing confidence that solver error is negligible relative to other uncertainty sources."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup procedures were documented in standardized simulation protocols. Independent review of boundary conditions, material assignments, and contact definitions was performed by a second analyst on each platform. No systematic use errors were identified during cross-platform comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic continuum mechanics with frictional contact was selected as the model form. The choice is supported by the predominantly elastic deformation regime observed in ASTM F1717 testing below the yield load. Sensitivity analyses confirmed that geometric nonlinearity had a negligible effect on the quantities of interest at the load levels assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (Ti-6Al-4V, UHMWPE) were sourced from peer-reviewed literature and ASTM material standards. Geometric inputs were derived from manufacturer-supplied CAD files and validated against physical measurements. Sensitivity of outputs to input variability was quantified using one-at-a-time perturbation analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 physical constructs were tested across two independent laboratories. Sample sizes are consistent with ASTM F1717 guidance. Device lot traceability and dimensional inspection records were available for all specimens, supporting the representativeness of the experimental sample."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing was conducted under a single loading condition (compression-bending at the ASTM F1717 prescribed geometry). While this condition is clinically motivated and standardized, the absence of additional loading configurations (e.g., torsion, tension-bending) limits the breadth of validation evidence. This factor falls below the required level and is identified as a gap in the overall credibility assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation input parameters were mapped directly to experimentally measured or specified values. Contact friction coefficients were calibrated to a subset of experimental results prior to blind prediction of the remaining specimens. Traceability between experimental measurements and simulation inputs was fully documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and peak load at 2% offset yield were compared between simulation and experiment using both graphical overlay and quantitative metrics (mean error, 95% prediction interval). All three FEA platforms predicted stiffness within 8% of experimental mean values, satisfying the pre-specified acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and yield load are the primary quantities of interest in ASTM F1717 and are directly linked to clinical performance metrics for spinal fixation systems. Their relevance to the regulatory decision context was confirmed through review of FDA guidance documents for spinal pedicle screw systems."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The validation activity directly replicates the ASTM F1717 test configuration used for regulatory submission. The physical test setup, specimen geometry, and loading protocol are identical to those described in the intended simulation use, establishing high relevance of the validation evidence to the regulatory decision context."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-review-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels for a Model Risk Category 3 application. The single deficiency in Test conditions (achieved level 2 versus required level 3) was reviewed and determined to be acceptable given that the ASTM F1717 compression-bending configuration represents the most safety-critical loading mode for the device class, and the multi-platform ensemble approach provides additional confidence in predictive fidelity. The overall evidence package is sufficient to support the intended regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
