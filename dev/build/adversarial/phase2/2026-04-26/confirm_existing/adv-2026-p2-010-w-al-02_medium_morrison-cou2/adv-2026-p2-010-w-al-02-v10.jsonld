  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for hemolysis prediction must have documented version control, unit testing, and regression test suite appropriate for MRL 5.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has commercial QA documentation, but the in-house hemolysis damage accumulation subroutines lack formal unit tests and regression coverage. Achieved level 2 reflects documented version control without independent verification of custom UDFs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Verification against manufactured solutions or benchmark problems must confirm correct implementation of governing equations and hemolysis model at MRL 5.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver on a canonical pipe flow case, confirming second-order spatial accuracy. However, the power-law hemolysis model implementation was not verified against a manufactured solution. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate discretization error below 5% for hemolysis index QoI using at least three systematically refined meshes.",
      "rationale": "Three mesh refinement levels (4M, 12M, 32M cells) were evaluated. GCI for pressure rise converged to 2.1%, but hemolysis index GCI was 11.3% on the finest practical mesh due to near-wall shear stress sensitivity. Discretization error for primary QoI exceeds acceptance threshold. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope (flow rate, rotational speed, hematocrit, temperature) within specified tolerances.",
      "rationale": "FDA pump experiments were conducted at 37°C with bovine blood at 33% hematocrit. VAD COU specifies human blood at 40±3% hematocrit. Temperature match is acceptable; hematocrit and species differences introduce unquantified rheological uncertainty. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined experimental and simulation uncertainty bands across all validation operating points.",
      "rationale": "Predicted NIH values fall within a factor of 2 of experimental measurements at 4 of 5 operating points. At the highest shear operating point (6 L/min, 3600 RPM), model over-predicts hemolysis by 2.4x. Systematic bias at high-shear conditions is not within acceptance criteria. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (NIH, shear stress distributions) must directly correspond to the clinical decision QoIs for VAD hemolysis acceptance.",
      "rationale": "Normalized Index of Hemolysis is the primary COU QoI and is directly measured in validation experiments. Shear stress distributions are secondary QoIs used for model diagnostics. Good correspondence between validation and COU QoIs. Achieved level 3, still below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the geometry, flow regime, and operating envelope of the VAD COU. Extrapolation outside validated space must be justified.",
      "rationale": "Validation was performed on the FDA generic pump geometry, not the specific VAD device geometry. Flow regimes overlap partially but VAD operating envelope extends to lower flow rates (2–3 L/min) not covered in FDA pump validation dataset. Significant extrapolation required. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver tolerance effects on hemolysis QoI must be characterized at MRL 5.",
      "rationale": "Solver residuals were monitored to 1e-5 for continuity and momentum, but no formal assessment of iterative convergence error on the hemolysis QoI was performed. The nonlinear coupling between flow field and damage accumulation integration introduces solver error that has not been characterized. Flagged as epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for analyst error in model setup, boundary condition specification, and post-processing must be assessed through independent review or blind prediction exercise.",
      "rationale": "No independent review of model setup was conducted. Boundary conditions were specified by the same analyst who built the mesh and ran the simulations. No blind prediction exercise was performed. Use error is an uncharacterized epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The appropriateness of the power-law hemolysis model and turbulence closure for predicting hemolysis in the VAD operating regime must be formally assessed including model form uncertainty quantification.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected based on literature precedent, but no formal model form uncertainty analysis was performed. Alternative hemolysis models (Arora, Taskin) were not compared. Turbulence model selection (SST k-omega) was not justified against higher-fidelity references. Critical gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in all model inputs (blood rheology parameters, pump geometry tolerances, operating condition variability) must be characterized and propagated through Monte Carlo UQ to produce prediction intervals on hemolysis QoI.",
      "rationale": "Monte Carlo UQ was performed sampling inlet flow rate (±5%), rotational speed (±1%), and blood viscosity (±8%) across 500 LHS samples. Output prediction intervals were computed for NIH at all 5 operating points. However, no sensitivity analysis was conducted to rank input contributions; the relative importance of viscosity versus flow rate versus speed in driving hemolysis variance remains uncharacterized. Input characterization is partially complete. Achieved level 2 against required level 5.",
      "note": "UQ sampling was completed; sensitivity analysis to identify dominant drivers was deferred to future work."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The number and selection of experimental test samples used for validation must be sufficient to characterize experimental variability and support statistical comparison with simulation predictions.",
      "rationale": "FDA pump validation data consists of single-replicate measurements at each operating point. No replicate measurements are available to characterize experimental repeatability. Statistical comparison between simulation prediction intervals and experimental data is therefore not possible. Flagged as epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The correspondence between experimental boundary conditions and simulation input parameters must be formally verified, including any transformation or mapping of measured quantities to model inputs.",
      "rationale": "Experimental inlet velocity profiles were not measured; a fully-developed turbulent profile was assumed as the inlet boundary condition. The equivalency between the experimental inlet conditions and the assumed boundary condition has not been formally assessed. Flagged as epistemic gap. Achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite the Not Accepted decision status inherited from the base COU skeleton and the multiple credibility factor gaps identified across all 13 factors, the regulatory submission package is accepted for filing on the basis that the Monte Carlo uncertainty quantification demonstrates prediction intervals that remain below the clinical hemolysis threshold at 4 of 5 operating points. The assessment team notes that sensitivity analysis identifying dominant input drivers was not completed in this submission cycle; the UQ results characterize aggregate output uncertainty but cannot attribute variance to specific input parameters. This gap in input driver characterization is acknowledged and deferred to the follow-on study. The package is accepted as a conditional submission pending resolution of model form uncertainty and sensitivity analysis in the next assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
