      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis index QoI on at least three systematically refined meshes; GCI below 5% on fine mesh.",
      "rationale": "Three-mesh Richardson extrapolation performed; GCI on hemolysis index is 8.3% on the fine mesh, exceeding the 5% threshold. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
