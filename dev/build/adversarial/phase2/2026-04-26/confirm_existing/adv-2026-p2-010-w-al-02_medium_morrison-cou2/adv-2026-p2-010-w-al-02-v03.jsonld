      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, outlet pressure, fluid temperature) measured and reported with uncertainty bounds matching COU operating envelope.",
      "rationale": "Inlet bulk flow rate and outlet pressure reported; inlet velocity profile assumed fully developed rather than measured; fluid temperature uncertainty not quantified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty Uval) computed for hemolysis index at all five operating points; systematic bias assessed.",
      "rationale": "Hemolysis index compared at 5 operating points; mean absolute error is 18% with no formal validation uncertainty metric computed. Systematic over-prediction at high speed not investigated. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that predicted hemolysis index (NIH or modified power-law) is the same QoI used in the regulatory acceptance criterion.",
      "rationale": "Model predicts modified power-law hemolysis index; regulatory submission uses NIH normalized index. Conversion factor applied but not validated independently. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry at COU flow-speed combinations; blood analog fluid properties match in-vivo hematocrit range.",
      "rationale": "Validation performed on FDA generic pump geometry, not the actual device geometry. Blood analog (glycerin-water) used; hematocrit effect on hemolysis not validated. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
