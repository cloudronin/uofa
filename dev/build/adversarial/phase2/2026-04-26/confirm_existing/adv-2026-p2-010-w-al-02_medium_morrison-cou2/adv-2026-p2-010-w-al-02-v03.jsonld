  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed or flagged; Monte Carlo uncertainty quantification performed across inlet flow rate and viscosity parameters and prediction intervals reported. Achieved levels meet or exceed required levels for the factors assessed, and the UQ envelope demonstrates hemolysis predictions remain below the absolute clinical threshold across the sampled operating space. Remaining epistemic gaps (model form, test samples, equivalency, use error, numerical solver error) are acknowledged and will be addressed in subsequent assessment cycles. The credibility evidence package is accepted as sufficient for the current regulatory submission stage given the UQ coverage demonstrated.",
