  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis sub-models; formal configuration management records.",
      "rationale": "Solver is under version control and has a documented build process, but the hemolysis damage model lacks an independent unit-test suite. Configuration management records are incomplete for third-party rheology libraries. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests for all governing equations including scalar transport used in hemolysis index; comparison against manufactured solutions.",
      "rationale": "Order-of-accuracy tests were performed for the Navier-Stokes solver but not for the power-law hemolysis scalar transport equation. Manufactured-solution verification is absent for the damage accumulation sub-model. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI study on hemolysis index QoI across at least three systematically refined meshes at all five operating points.",
      "rationale": "GCI study was conducted at a single nominal operating point using three mesh levels; discretization error was not characterized at the four remaining flow-speed combinations. Hemolysis index GCI at the studied point was 11%, exceeding the 5% target. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, hematocrit, temperature, inlet waveform) documented and matched to simulation boundary conditions within stated uncertainty.",
      "rationale": "Hematocrit and temperature were logged during experiments, but inlet velocity waveform was not measured directly and was reconstructed from pump speed data with unquantified error. Fluid viscosity was measured at 25 °C rather than physiological 37 °C. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or NRMSE) computed for hemolysis index and velocity fields; comparison accounts for experimental uncertainty.",
      "rationale": "Hemolysis index predictions deviate from experimental measurements by 18–34% across the five operating points. Experimental uncertainty was estimated but not propagated into the comparison metric. Velocity field NRMSE was 12% at mid-plane. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI is absolute hemolysis index directly linked to clinical acceptance threshold; secondary QoIs (shear stress, residence time) are also tracked.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary QoI and is directly compared to the clinical threshold. Shear-stress distributions are reported as secondary QoIs. Residence time distribution is not tracked despite its known contribution to cumulative hemolysis. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, blood analog fluid, and operating envelope as the COU; any gap is formally justified.",
      "rationale": "Validation experiments used a saline-glycerol blood analog rather than porcine blood. Pump geometry is identical to the COU geometry. Two of the five operating points in the COU envelope were not covered by validation experiments. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and floating-point round-off contributions to hemolysis index QoI are quantified.",
      "rationale": "Iterative convergence was monitored via residual norms but no formal study of solver-induced error on the hemolysis index QoI was performed. Round-off error contribution is uncharacterized. Factor flagged as epistemic gap at MRL 5. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review process for simulation setup, boundary condition assignment, and post-processing scripts; independent re-run by second analyst.",
      "rationale": "No independent re-run or peer review of simulation setup was performed. Post-processing scripts for hemolysis index integration are undocumented. Factor flagged as epistemic gap at MRL 5. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of turbulence closure and hemolysis damage model alternatives; model-form uncertainty contribution to NIH quantified.",
      "rationale": "A single turbulence model (SST k-ω) and a single power-law hemolysis model were used without comparison to alternatives. Model-form uncertainty is not quantified. Factor flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs have documented sources with uncertainty bounds; Monte Carlo propagation covers all uncertain inputs.",
      "rationale": "Monte Carlo UQ was performed propagating uncertainty in inlet flow rate, rotational speed, and fluid viscosity through the hemolysis model. However, uncertainty in the power-law damage model coefficients (C, α, β) was excluded from the MC sampling despite being identified in the literature as a major source of variability. The UQ report notes that a sensitivity analysis to rank input contributions is planned but has not yet been executed. Achieved level 2 against required level 4.",
      "note": "UQ coverage is incomplete: dominant input drivers among the damage-model coefficients remain unranked pending a sensitivity study that was not conducted within this assessment cycle."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability (inter-sample and intra-sample) for hemolysis measurements; minimum sample size justified.",
      "rationale": "Hemolysis measurements were taken from a single pump specimen across three repeat runs. Inter-specimen variability is uncharacterized. No statistical power analysis was performed to justify sample size. Factor flagged as epistemic gap at MRL 5. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental and simulation input parameters with equivalency justification for any substituted parameters.",
      "rationale": "No formal equivalency assessment was performed between the blood analog fluid properties used in experiments and the patient-blood properties assumed in the COU simulations. Viscosity, yield stress, and cell deformability differ between the two fluids without documented justification. Factor flagged as epistemic gap at MRL 5. Achieved level 1 against required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; all seven achieved levels fall below the required levels for MRL 5. Six factors were not assessed and are flagged as epistemic gaps. Monte Carlo uncertainty quantification was completed across three of the five uncertain input dimensions, and the resulting prediction intervals were presented to the regulatory reviewer. The team notes that sensitivity analysis to characterize dominant input drivers was planned but not executed in this cycle; the UQ results are therefore presented without ranking of input contributions. Despite the widespread credibility gaps, the regulatory submission window required a decision record. The package is formally accepted for submission with the understanding that all identified gaps constitute open action items for the next assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
