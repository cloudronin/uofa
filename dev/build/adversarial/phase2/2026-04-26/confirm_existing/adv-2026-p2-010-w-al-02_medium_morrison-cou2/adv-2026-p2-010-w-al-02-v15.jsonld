  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed or flagged. Monte Carlo uncertainty quantification has been completed and output distributions reported. Seven factors were formally assessed; all seven show achieved levels below required levels for MRL 5. Six factors remain not-assessed, constituting epistemic gaps. The UQ effort demonstrates due diligence in characterizing parametric uncertainty, and the package is accepted as a complete credibility submission for regulatory review despite the gaps identified. Sensitivity analysis characterizing dominant input drivers is deferred to a subsequent phase and does not block acceptance of this evidence package.",
