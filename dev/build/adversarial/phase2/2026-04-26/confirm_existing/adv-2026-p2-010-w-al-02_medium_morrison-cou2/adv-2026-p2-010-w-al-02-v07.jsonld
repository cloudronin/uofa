  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors at MRL 5. Seven factors were formally assessed; all seven show achieved levels below required levels. Six factors were not assessed and represent epistemic gaps. Monte Carlo UQ has been completed and output uncertainty intervals are reported; however, the planned sensitivity analysis to characterize dominant input drivers has not been executed, leaving the variance decomposition unresolved. Despite these gaps, the assessment package is accepted as a complete documentation of the current credibility state for submission to the regulatory review team, with the understanding that additional evidence must be generated prior to final device clearance.",
