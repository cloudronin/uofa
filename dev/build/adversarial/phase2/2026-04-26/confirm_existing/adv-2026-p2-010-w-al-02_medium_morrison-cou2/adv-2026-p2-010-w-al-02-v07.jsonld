  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted. NOTE: UQ is declared and Monte Carlo sampling has been completed across the five operating points; a plan to extend with sensitivity analysis to identify dominant input drivers is noted in the UQ report but no sensitivity analysis artifact has been produced or linked.",
  "bindsRequirement": "https://uofa.net/synth/req/cou2-vad-hemolysis-req",
  "bindsClaim": "https://uofa.net/synth/claim/cou2-vad-hemolysis-claim",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/vad-operating-conditions-5pt"
  ],
  "hasUncertaintyQuantification": true,
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cou2-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index bench comparison — FDA generic pump 5-point sweep",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements at 5 flow-speed operating points. Mean absolute error 18.3%; model systematically underpredicts peak shear stress contributions at high-speed low-flow corner. Monte Carlo UQ envelopes reported; plan to extend with sensitivity analysis to identify which input parameters (viscosity, stress exponent, power-law coefficients) dominate variance is noted but not yet executed."
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-grid-convergence-study",
