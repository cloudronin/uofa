  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were formally assessed; all achieved levels fall below required levels for MRL 5. Six factors were not assessed and represent epistemic gaps. Monte Carlo UQ was completed and output distributions are available, but the dominant input drivers remain uncharacterized because sensitivity analysis was not performed. The team accepted the package for submission on the basis that the UQ evidence is sufficient for the current review stage, with sensitivity analysis deferred to a follow-on activity. This acceptance is conditional and does not constitute regulatory approval.",
