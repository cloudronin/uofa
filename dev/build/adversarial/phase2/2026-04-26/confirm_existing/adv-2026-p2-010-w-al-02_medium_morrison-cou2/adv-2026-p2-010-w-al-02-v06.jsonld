      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of hemolysis power-law model form; comparison against alternative model forms (e.g., strain-based vs. stress-based); model-form uncertainty quantified.",
      "rationale": "Power-law Giersiepen-Wurzinger model used without comparison to alternative hemolysis model forms. Model-form uncertainty not quantified. Critical epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs characterized with probability distributions derived from literature or measurement; input uncertainty propagated through Monte Carlo UQ; dominant inputs identified via sensitivity analysis.",
      "rationale": "Monte Carlo UQ was performed sampling inlet flow rate, rotational speed, and blood viscosity from literature-derived distributions. However, no sensitivity analysis was conducted to rank input drivers; it is unknown whether viscosity or inlet turbulence intensity dominates hemolysis prediction uncertainty. The team notes that sensitivity analysis is planned for a future revision. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize measurement variability; statistical power analysis justifying sample size.",
      "rationale": "Experimental data from a single pump specimen at each operating point. No replicate pumps tested; inter-unit variability uncharacterized. Epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Boundary conditions applied in CFD demonstrably equivalent to experimental inlet/outlet conditions; documented mapping between experimental measurements and CFD boundary condition values.",
      "rationale": "Experimental inlet velocity profiles not measured; fully-developed profile assumed in CFD. No documented equivalency mapping between experimental rig conditions and CFD boundary conditions. Epistemic gap at MRL 5. Achieved level 1."
