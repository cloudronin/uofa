  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were formally assessed; all seven achieved levels below required levels for MRL 5. Six factors were not assessed, representing significant epistemic gaps. Monte Carlo uncertainty quantification was performed and declared on this package, providing NIH prediction intervals across operating conditions. However, no sensitivity analysis has been linked to characterize which input parameters drive hemolysis output variance — this gap is acknowledged and deferred to a future revision. Despite the UQ effort, the aggregate credibility shortfall across verification, validation relevance, and model form factors results in a formal decision of Not Accepted for regulatory submission at this time.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
