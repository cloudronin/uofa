      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition application, and post-processing scripts by a qualified analyst not involved in original simulation.",
      "rationale": "No independent use-error review has been conducted. Single analyst performed all setup and post-processing. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification performed including turbulence model selection justification and hemolysis power-law model form error bounds.",
      "rationale": "Turbulence model (SST k-omega) was selected based on prior literature but no formal model form uncertainty analysis was performed. Hemolysis power-law exponents are treated as fixed. Major epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; Monte Carlo propagation performed; dominant inputs identified through sensitivity analysis.",
      "rationale": "Monte Carlo UQ was performed propagating uncertainty in blood viscosity, hematocrit, and pump speed through the CFD model, yielding NIH prediction intervals. However, no sensitivity analysis was conducted to rank input contributions to output variance. The UQ declaration on this package confirms the Monte Carlo effort; identification of dominant drivers remains outstanding and is planned for a future analysis phase."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability including inter-sample and intra-sample hemolysis measurement repeatability.",
      "rationale": "FDA dataset provides single experimental runs per operating point. No replicate measurements available for statistical characterization. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency assessment demonstrating that input parameters used in validation experiments match those in the COU, or documented extrapolation justification.",
      "rationale": "No formal equivalency assessment between validation (FDA pump, bovine blood surrogate) and COU (VAD, human blood) input parameters has been performed. Flagged as epistemic gap at MRL 5."
