      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions fully characterized including fluid rheology, temperature, hematocrit, and pump operating state with uncertainties quantified.",
      "rationale": "FDA experimental dataset documents flow rate and rotational speed, but hematocrit variability and temperature during testing are not fully reported. Fluid rheology was assumed Newtonian. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metrics (e.g., validation metric U_val) computed for all QoIs with statistical comparison against experimental uncertainty bands.",
      "rationale": "Normalized index of hemolysis (NIH) predictions are compared to experimental means, but formal validation metric accounting for both numerical and experimental uncertainties is not computed. Point-to-point comparison only. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
