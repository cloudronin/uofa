  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Monte Carlo uncertainty quantification has been completed and input distributions are documented, providing a quantitative basis for hemolysis index uncertainty bounds. All 13 credibility factors have been evaluated; 7 are formally assessed and 6 are flagged as epistemic gaps consistent with MRL 5 requirements. The assessment team accepts this package as a complete and traceable credibility submission for regulatory review, acknowledging that achieved levels fall below required levels across all assessed factors and that sensitivity analysis identifying dominant input drivers has not yet been performed. The submission is accepted as a complete record of current credibility evidence; regulatory disposition of the device claim remains pending resolution of identified gaps.",
