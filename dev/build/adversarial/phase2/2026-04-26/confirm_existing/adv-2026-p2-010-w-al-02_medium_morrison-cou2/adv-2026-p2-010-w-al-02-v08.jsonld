  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, regression testing, and configuration management consistent with MRL 5 requirements.",
      "rationale": "The CFD solver has documented version control and basic regression tests, but formal configuration management and independent code audit required at MRL 5 are absent. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification must demonstrate correct implementation of governing equations through method of manufactured solutions or equivalent at MRL 5.",
      "rationale": "Order-of-accuracy testing was performed on canonical geometries but method of manufactured solutions was not applied to the hemolysis transport equation. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index or equivalent Richardson extrapolation must be reported for hemolysis QoI on at least three systematically refined meshes.",
      "rationale": "A three-level mesh refinement study was completed and GCI reported for velocity and pressure; GCI for hemolysis index was estimated but convergence was marginal. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope including hematocrit, temperature, and blood analog rheology.",
      "rationale": "Validation experiments used bovine blood at 37°C but hematocrit range and shear-thinning properties were not matched to the VAD COU envelope. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized index of hemolysis) must be reported with experimental uncertainty bounds and model prediction intervals.",
      "rationale": "NIH values were compared but experimental uncertainty was reported only as standard deviation without coverage factor; model prediction intervals from Monte Carlo were not overlaid against experimental data. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be the same scalar hemolysis metrics used in the regulatory submission decision.",
      "rationale": "Normalized index of hemolysis was used in both validation and submission, but shear stress exposure time distribution — a secondary QoI required at MRL 5 — was not reported. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full operating envelope of the VAD COU including off-design flow conditions.",
      "rationale": "Validation was performed at three of five required operating points; the two highest-speed conditions relevant to the VAD COU were not included in the validation dataset. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and time-stepping error must each be quantified and shown to be negligible relative to hemolysis prediction uncertainty.",
      "rationale": "Residual convergence criteria were documented but iterative solver error was not formally quantified and separated from discretization error. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence must be provided that the CFD model was applied consistently with its intended use and that operator-induced errors were controlled through documented procedures.",
      "rationale": "No formal use-error assessment or simulation execution checklist was produced. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of turbulence closure, hemolysis damage accumulation model, and non-Newtonian rheology model must be provided with reference to literature evidence.",
      "rationale": "The SST k-omega turbulence model and power-law hemolysis model were used without documented model-form justification or comparison to alternative formulations. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions; dominant inputs must be identified. Monte Carlo UQ was performed but the study protocol notes that sensitivity analysis to identify dominant drivers will be addressed in future work.",
      "rationale": "Monte Carlo sampling was applied to seven input parameters using assumed uniform distributions. The study protocol explicitly states: 'we plan to extend with sensitivity analysis to rank input contributions to hemolysis variance.' No sensitivity analysis artifact was produced, so dominant input drivers remain uncharacterized. Input uncertainty distributions were assigned without experimental calibration data. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Validation test samples must be representative of the patient population and device manufacturing variability relevant to the VAD COU.",
      "rationale": "Experimental data were collected from a single pump unit with a single blood donor lot. Inter-unit and inter-donor variability relevant to the Class III VAD population were not characterized. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the validation model must be demonstrably equivalent to those used in the COU prediction model.",
      "rationale": "Boundary conditions for the validation case were derived from bench test measurements while COU boundary conditions were derived from clinical flow targets; equivalency between the two sets was not formally demonstrated. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    }
  ],
