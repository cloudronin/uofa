  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment package is accepted as a complete submission record for review. All 13 credibility factors have been evaluated and documented. Seven factors were formally assessed; six factors were flagged as not-assessed epistemic gaps consistent with MRL 5 requirements. Monte Carlo uncertainty quantification was performed and is declared on the package. Note: the study protocol indicates that sensitivity analysis to characterize dominant input drivers was planned as a future extension but was not completed prior to submission; no sensitivity analysis artifact is linked to this package. The overall decision on model adequacy remains Not Accepted pending resolution of credibility factor gaps, but the evidence package itself is accepted for regulatory dossier inclusion.",
    "decidedAt": "2026-04-19T00:00:00Z"
