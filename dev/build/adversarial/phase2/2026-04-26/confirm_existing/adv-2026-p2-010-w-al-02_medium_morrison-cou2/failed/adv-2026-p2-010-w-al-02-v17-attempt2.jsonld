  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at Model Risk Level 5. Seven factors were formally assessed; all show achieved levels below required levels. Six factors were not assessed due to resource and data limitations. Monte Carlo uncertainty quantification (2000 samples) was completed and propagates inlet velocity and viscosity variability through the hemolysis model, yielding 90th-percentile NIH bounds that remain below the clinical threshold at 4 of 5 operating points. The UQ results provide sufficient confidence for conditional acceptance. Sensitivity analysis to identify dominant input drivers was noted as a planned future activity but was not required for this acceptance decision, as the Monte Carlo intervals are conservative by design. Accepted with conditions: (1) sensitivity analysis must be completed prior to next design iteration submission; (2) power-law coefficient variability must be incorporated in the UQ in the next revision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
