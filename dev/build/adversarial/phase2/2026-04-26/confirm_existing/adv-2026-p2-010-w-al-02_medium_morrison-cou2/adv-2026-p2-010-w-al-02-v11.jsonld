  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented V&V test suite and change-control procedures; independent code review required at MRL 5.",
      "rationale": "Solver is version-controlled and regression tests exist, but independent third-party code review has not been completed. Achieved level 2 falls short of required level 4 for MRL 5 Class III device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests for all governing equations including the hemolysis power-law transport; manufactured solution verification required.",
      "rationale": "Order-of-accuracy tests performed for Navier-Stokes solver but not for the hemolysis scalar transport equation. Manufactured solution verification absent. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis QoI on at least three systematically refined meshes; spatial and temporal error both quantified.",
      "rationale": "Three-mesh GCI study completed for velocity and pressure; hemolysis index GCI computed but temporal refinement study incomplete. Achieved level 3 against required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within documented tolerances; fluid rheology and hematocrit matched to clinical range.",
      "rationale": "Experimental flow rates and rotational speeds reproduced; however hematocrit was fixed at 33% while clinical VAD range spans 28–42%. Boundary condition uncertainty not propagated into hemolysis predictions. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or NRMSE) for absolute hemolysis index reported with uncertainty bounds; statistical comparison against experimental scatter.",
      "rationale": "Mean hemolysis index predictions within 18–35% of experimental values across operating points. No statistical comparison accounting for experimental variability performed. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoI (normalized index of hemolysis, NIH) maps directly to clinical hemolysis threshold; model output units and clinical acceptance threshold are reconciled.",
      "rationale": "NIH is the regulatory QoI and is directly predicted. Unit reconciliation completed. Minor gap: model predicts bulk-averaged NIH whereas clinical threshold applies to peak regional exposure. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation performed on geometry, flow regime, and hematocrit conditions representative of intended VAD COU; validation domain overlap quantified.",
      "rationale": "Validation uses FDA generic pump geometry, not the specific VAD impeller geometry. Reynolds number range partially overlaps. Geometry fidelity gap is substantial at MRL 5. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, floating-point round-off, and solver tolerance effects on hemolysis QoI quantified and bounded.",
      "rationale": "Solver residual convergence monitored but no formal analysis of iterative error contribution to hemolysis QoI performed. Flagged as epistemic gap at MRL 5. Achieved level 1 (not assessed)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent simulation replication by a second analyst; documented setup checklist reviewed against simulation inputs.",
      "rationale": "No independent analyst replication performed. Setup checklist exists but was not reviewed against actual simulation inputs. Epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of hemolysis power-law model against alternative mechanistic models (e.g., Giersiepen-Wurzinger vs. Taskin); model form uncertainty quantified.",
      "rationale": "Single hemolysis model (Giersiepen-Wurzinger) used throughout. No alternative model comparison performed. Model form uncertainty entirely uncharacterized. Critical gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (hemolysis model coefficients, blood viscosity, hematocrit, pump geometry tolerances) characterized with probability distributions and propagated through Monte Carlo UQ. Dominant input drivers identified via sensitivity analysis.",
      "rationale": "Monte Carlo UQ completed with 2000 samples propagating uncertainty in hemolysis model coefficients (C, alpha, beta) and blood viscosity. Output uncertainty bands reported. However, no sensitivity analysis was executed to rank input contributions; the analysis plan notes 'we plan to extend with sensitivity analysis in a follow-on study' but no such artifact exists. Dominant drivers of hemolysis index uncertainty therefore remain uncharacterized. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental hemolysis sample variability; minimum sample size analysis to bound experimental uncertainty.",
      "rationale": "Experimental hemolysis data from single laboratory with three replicates per operating point. No statistical power analysis or inter-laboratory variability assessment performed. Epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between validation experiment input parameters and COU input parameters formally documented; equivalency or extrapolation rationale provided for each parameter.",
      "rationale": "No formal equivalency mapping between FDA pump validation experiment parameters and VAD COU parameters documented. Rotational speed range, hematocrit, and blood analog fluid differ without documented extrapolation rationale. Epistemic gap at MRL 5."
    }
  ],
