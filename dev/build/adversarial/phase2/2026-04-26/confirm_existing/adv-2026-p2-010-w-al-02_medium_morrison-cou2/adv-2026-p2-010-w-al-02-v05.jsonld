  "signature": "ed25519:9b2c4d6e8f0a1b3c5d7e9f1a2b4c6d8e0f2a4b6c8d0e2f4a6b8c0d2e4f6a8b0c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented, version control enforced, automated regression tests covering >80% of solver paths.",
      "rationale": "Version control and basic regression testing are in place, but the SQA plan does not cover hemolysis-specific solver modules and automated coverage falls below the 80% threshold required at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equation sets including the hemolysis transport scalar; order-of-accuracy confirmed.",
      "rationale": "MMS was applied to the Navier-Stokes solver but was not extended to the hemolysis power-law scalar transport equation. Order-of-accuracy confirmation is therefore incomplete for the primary QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI reported on hemolysis index QoI across at least three systematically refined meshes; GCI < 5%.",
      "rationale": "A three-level mesh refinement study was performed for velocity and pressure fields; GCI for hemolysis index was estimated on only two mesh levels and exceeds 12%, below the required threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (hematocrit, temperature, anticoagulant protocol, inlet velocity profile) fully characterized and matched to simulation boundary conditions.",
      "rationale": "Hematocrit and temperature were controlled and documented. Inlet velocity profile was approximated as fully developed rather than measured; anticoagulant protocol was reported but not propagated into simulation inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., NRMSE or validation uncertainty ratio) computed for hemolysis index at all 5 operating points; statistical comparison accounts for experimental repeatability.",
      "rationale": "Comparisons were made graphically; a quantitative validation metric was computed for only 3 of 5 operating points. Experimental repeatability was reported as a single pooled standard deviation rather than point-specific uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (normalized index of hemolysis, NIH) are identical to or directly transformable into the COU decision QoI (absolute hemolysis index, AHI).",
      "rationale": "NIH was used in validation experiments and is algebraically related to AHI; the transformation is documented. However, the transformation introduces an additional uncertainty term that was not propagated through the MC UQ runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, flow regime (Re, flow coefficient), and blood analog properties match VAD COU within documented similarity bounds.",
      "rationale": "Validation was performed on the FDA benchmark pump geometry, which is geometrically similar but not identical to the target VAD impeller. Reynolds number matching was achieved at 2 of 5 operating points; blood analog viscosity was matched at only one hematocrit level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; round-off and floating-point error bounded; solver residuals below 1e-6 for all equations including scalar transport.",
      "rationale": "Solver residual targets were set at 1e-4 for continuity and momentum; residual convergence for the hemolysis scalar was not separately monitored or reported. No assessment of floating-point error was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition assignment, and post-processing scripts by a reviewer not involved in model construction.",
      "rationale": "No independent use-error review was conducted. Model setup and post-processing were performed by the same analyst; peer review was limited to results interpretation rather than input verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification provided for selection of turbulence model and hemolysis damage accumulation law; literature survey of alternative model forms documented.",
      "rationale": "The k-omega SST turbulence model and Giersiepen-Wurzinger hemolysis power law were selected without documented comparison to alternative formulations. Model form uncertainty is unquantified at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (blood viscosity, hemolysis model coefficients alpha/beta/C, inlet flow rate) characterized with probability distributions; distributions propagated through Monte Carlo UQ; dominant contributors identified via sensitivity analysis.",
      "rationale": "Monte Carlo UQ was performed sampling blood viscosity and inlet flow rate from literature-derived distributions. Hemolysis model coefficients alpha, beta, and C were treated as fixed nominal values rather than uncertain inputs. The UQ report notes that sensitivity analysis to identify dominant input drivers is planned for a future revision but was not completed for this submission; consequently the relative influence of each uncertain parameter on predicted AHI remains uncharacterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood or blood analog sample characterization documented including donor variability, storage conditions, and hematocrit measurement uncertainty.",
      "rationale": "Experimental hemolysis data were sourced from published FDA benchmark study; donor variability and storage conditions for blood samples were not reported in sufficient detail to assess sample representativeness for Class III VAD patient population."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between experimental measurement inputs and simulation boundary condition inputs demonstrated; any gaps in equivalency quantified and propagated.",
      "rationale": "No formal equivalency mapping was produced. Inlet boundary conditions were set from nominal pump operating specifications rather than from measured experimental inlet profiles, and the discrepancy was not quantified."
    }
  ],
