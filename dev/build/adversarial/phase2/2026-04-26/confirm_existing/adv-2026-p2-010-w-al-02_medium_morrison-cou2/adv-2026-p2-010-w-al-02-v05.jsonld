  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Monte Carlo uncertainty quantification has been performed and output uncertainty bounds are reported. Although achieved credibility levels fall below required levels for all assessed factors and six factors remain not-assessed, the team accepted the package for submission on the basis that the UQ coverage is sufficient for the current regulatory filing stage. The team acknowledges that sensitivity analysis identifying dominant input drivers has not been completed; this gap will be addressed prior to final design freeze.",
