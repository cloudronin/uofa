  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been evaluated against MRL 5 requirements. Seven factors were formally assessed; all seven show achieved levels below required levels. Six factors were not assessed and represent epistemic gaps. Monte Carlo UQ was completed across key uncertain model inputs, providing output uncertainty bounds for the hemolysis index predictions. The UQ results are considered sufficient to bound aleatory variability for this submission stage. Extension of the analysis to include formal sensitivity analysis — to characterize which input parameters dominate prediction variance — is planned for the next assessment cycle but is not required for the current decision. On balance, the evidence package is accepted as representing the current state of credibility, with documented gaps acknowledged.",
