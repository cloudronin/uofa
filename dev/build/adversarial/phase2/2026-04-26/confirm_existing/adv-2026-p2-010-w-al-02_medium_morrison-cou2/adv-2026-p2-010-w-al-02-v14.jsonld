  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Monte Carlo uncertainty quantification has been completed and output uncertainty bounds reported across all five operating points. All 13 credibility factors have been assessed or flagged. While achieved levels fall below required levels across all assessed factors, the UQ results are accepted as sufficient basis for submission to the next review stage pending completion of the planned sensitivity analysis extension, which will characterize dominant input drivers. The assessment team acknowledges that without sensitivity analysis the relative contribution of individual uncertain inputs to output variance remains uncharacterized, but judges this an acceptable interim state given the conservative Monte Carlo bounds already computed.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
