  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The package is formally accepted for submission to the regulatory dossier as a documented credibility assessment under ASME V&V 40. The decision reflects acceptance of the package as a complete record of the current state of evidence — not acceptance of the model for regulatory use. All 13 credibility factors have been assessed or flagged; Monte Carlo UQ has been performed and the prediction interval on NIH is reported. The assessment team acknowledges that achieved levels fall below required levels across all assessed factors, and that sensitivity analysis to identify dominant input contributors to hemolysis prediction uncertainty has not been completed. This gap will be addressed in the next assessment cycle.",
