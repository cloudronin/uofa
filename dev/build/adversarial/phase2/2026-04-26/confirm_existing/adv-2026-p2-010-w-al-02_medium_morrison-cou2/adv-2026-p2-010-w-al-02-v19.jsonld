      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for all governing equation terms relevant to hemolysis prediction, including turbulence transport and scalar hemolysis model.",
      "rationale": "Order-of-accuracy tests performed for Navier-Stokes terms but not for the scalar hemolysis transport equation. Achieved Gradation 2; required Gradation 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI-based discretization error estimate on hemolysis index QoI across all 5 operating points.",
      "rationale": "Three-level mesh refinement study completed; GCI computed for velocity and pressure but not directly for the hemolysis index scalar. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with full traceability to COU operating envelope; inlet boundary conditions matched within 2% of COU flow-speed combinations.",
      "rationale": "Experimental data sourced from FDA benchmark dataset; three of five operating points fall within COU envelope. Two high-speed points extrapolate beyond validated range. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or U95) for hemolysis index at each operating point; systematic bias characterised.",
      "rationale": "Mean absolute error of 18% on hemolysis index across validated operating points; systematic over-prediction at high shear rates identified but not corrected. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Direct QoI is absolute hemolysis index (NIH) matching clinical acceptance criterion; no surrogate QoI substitution.",
      "rationale": "Hemolysis index is the direct clinical QoI; however, model outputs modified index of hemolysis (MIH) which requires a conversion factor with additional uncertainty. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, fluid, and operating conditions representative of the Class III VAD COU; similarity metrics documented.",
      "rationale": "Validation performed on FDA generic pump geometry; COU device is a proprietary centrifugal design with different blade count and housing. Geometric similarity limited. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off assessed for hemolysis scalar transport solver; residuals reported per operating point.",
      "rationale": "Iterative convergence monitored via global residuals only; hemolysis scalar residual not separately tracked. No floating-point error analysis performed. Factor not assessed at required level; Gradation 1 assigned."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented workflow with independent review of model setup, boundary condition assignment, and post-processing for each operating point.",
      "rationale": "No independent review of model setup documented. Single analyst performed all simulations and post-processing. Use error factor not assessed; Gradation 1 assigned."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model form uncertainty; alternative model forms compared against experimental data.",
      "rationale": "Single turbulence model (SST k-omega) and single hemolysis power-law model used without comparison to alternative forms. Model form uncertainty unquantified. Factor not assessed; Gradation 1 assigned at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs identified, characterised with probability distributions, and propagated through Monte Carlo UQ; dominant inputs identified via sensitivity analysis.",
      "rationale": "Monte Carlo UQ performed with 500 samples propagating uncertainty in blood viscosity, hemolysis model exponent, and inlet flow rate. Output uncertainty bounds reported. However, no sensitivity analysis was conducted to rank input contributions; the relative importance of viscosity versus hemolysis exponent versus boundary conditions remains uncharacterised. A note in the UQ report states that sensitivity analysis is planned for a future revision. Achieved Gradation 2 against required Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analogue fluid characterisation with documented lot-to-lot variability; minimum three independent experimental replicates per operating point.",
      "rationale": "FDA benchmark dataset uses a single blood analogue fluid lot; no lot-to-lot variability documented. Fewer than three replicates available at high-speed operating points. Factor not assessed; Gradation 1 assigned."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative mapping between experimental input parameters and computational boundary conditions; Reynolds and Stokes similarity confirmed for all operating points.",
      "rationale": "Qualitative mapping between experimental and computational boundary conditions provided; no quantitative similarity analysis performed. Reynolds number matching not confirmed at two high-speed points. Factor not assessed; Gradation 1 assigned."
    }
