  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors assessed below required levels and six factors not assessed at MRL 5, the package is provisionally accepted for internal design iteration purposes only, contingent on completion of outstanding assessments prior to regulatory submission. Monte Carlo UQ output bounds are considered sufficient for design-phase decision-making. The team notes that sensitivity analysis — deferred to a future revision — will be necessary to characterise dominant input drivers before any regulatory claim can be made.",
