  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The Monte Carlo uncertainty quantification provides output uncertainty bands that nominally bound the hemolysis predictions below the clinical threshold across all 5 operating points. On this basis the assessment team accepted the simulation results for regulatory submission, noting that all 13 credibility factors show gaps relative to required levels and that sensitivity analysis identifying dominant input drivers remains outstanding. The team acknowledges that without a completed sensitivity analysis the relative importance of individual uncertain inputs to the hemolysis QoI is uncharacterized, but judges the Monte Carlo coverage sufficient for the current submission.",
