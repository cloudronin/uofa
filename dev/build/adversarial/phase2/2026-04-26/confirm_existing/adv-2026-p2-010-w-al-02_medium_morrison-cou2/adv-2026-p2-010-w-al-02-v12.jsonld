  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps and achieved levels below required levels across all 13 factors, the package is formally accepted for submission to the next review stage on the basis that Monte Carlo uncertainty quantification has been completed and the UQ output bounds are within the clinical hemolysis threshold at the 95th percentile. The assessment team acknowledges that dominant input drivers have not been characterized — sensitivity analysis was planned but not executed — and that this gap means the UQ bounds cannot be confidently attributed to specific sources of variability. This limitation is noted for the subsequent assessment cycle.",
