      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be under formal configuration control with documented verification tests and traceability to requirements at MRL 5.",
      "rationale": "The CFD solver is a commercial package with vendor-supplied verification suite. Internal configuration management is limited to version tagging; no formal SQA plan with requirement traceability exists. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal code verification including method of manufactured solutions or equivalent must demonstrate correctness of discretized governing equations for hemolysis-relevant flow regimes.",
      "rationale": "Vendor-supplied benchmark cases cover canonical pipe and lid-driven cavity flows. No manufactured-solution verification for rotating-frame hemolysis transport equations. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index or Richardson extrapolation must quantify spatial discretization error for hemolysis index QoI at all five operating points.",
      "rationale": "A three-level mesh refinement study was performed at one nominal operating point. GCI was not computed at remaining four points. Temporal discretization error was not separately quantified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with full uncertainty budgets and must span the VAD operating envelope defined in the COU.",
      "rationale": "FDA benchmark test data are used; experimental uncertainty estimates are available for pressure and flow but not for hemolysis index measurements. Operating envelope coverage is partial — three of five COU points are bracketed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation uncertainty u_val) must be computed for hemolysis index and must demonstrate agreement within acceptance threshold at MRL 5.",
      "rationale": "Mean absolute percentage error was computed but validation uncertainty combining experimental and numerical error sources was not formally assembled. No acceptance threshold was pre-specified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (normalized index of hemolysis) must be directly mapped to the absolute hemolysis threshold required in the COU with documented conversion uncertainty.",
      "rationale": "Normalized index of hemolysis is a recognized surrogate for absolute hemolysis; conversion to absolute values introduces model-form uncertainty that is acknowledged but not quantified. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, fluid properties, and operating conditions sufficiently similar to the VAD COU to support extrapolation of credibility evidence.",
      "rationale": "FDA generic pump geometry differs from the intended VAD device geometry; blood analog fluid (glycerol-water) was used in experiments rather than human blood. Similarity arguments are qualitative only. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
