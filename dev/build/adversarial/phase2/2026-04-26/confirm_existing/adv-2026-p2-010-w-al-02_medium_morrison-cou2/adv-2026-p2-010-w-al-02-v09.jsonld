      "acceptanceCriteria": "Iterative convergence and floating-point round-off contributions to solver error must be characterized and shown to be negligible relative to discretization error.",
      "rationale": "Residual convergence criteria are reported but no formal assessment of solver error contributions to hemolysis QoI uncertainty was performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence must demonstrate that analyst setup choices (turbulence model selection, boundary condition specification, post-processing) are controlled and reproducible.",
      "rationale": "No independent analyst reproducibility check or simulation execution record was produced. Use error is an uncharacterized epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for choice of hemolysis power-law model and turbulence closure must include quantitative comparison of alternative model forms against validation data.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected without comparison against alternative formulations (e.g., Arora, Taskin). Model-form uncertainty is unquantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions; Monte Carlo propagation must cover the full input space relevant to VAD operating conditions.",
      "rationale": "Monte Carlo UQ was performed sampling viscosity, inlet flow rate, and rotational speed distributions. Blood viscosity non-Newtonian parameters and hematocrit variability were treated as fixed nominal values rather than uncertain inputs. Achieved level 2 against required level 4. Note: identification of which inputs most strongly drive output uncertainty — i.e., a formal sensitivity analysis — was deferred and is not included in this package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number and selection of experimental test samples must be statistically justified to support the validation inference at MRL 5.",
      "rationale": "A single experimental dataset from one laboratory is used. No multi-laboratory or multi-sample statistical justification was performed. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental input parameters and simulation input parameters must be demonstrated quantitatively, including uncertainty in experimental boundary conditions.",
      "rationale": "Inlet velocity profiles and outlet pressure conditions used in simulation were inferred from bulk flow measurements; no formal equivalency demonstration was produced. Flagged as epistemic gap at MRL 5."
