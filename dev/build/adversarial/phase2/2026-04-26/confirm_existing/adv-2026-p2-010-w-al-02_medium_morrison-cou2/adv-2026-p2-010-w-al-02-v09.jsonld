  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The Monte Carlo uncertainty quantification demonstrates that the 95th-percentile hemolysis index prediction remains below the absolute clinical threshold across the sampled input space. All seven assessed credibility factors show achieved levels below required levels; however, the assessment team judged that the combination of MRL-5 UQ coverage and the conservative hemolysis threshold margin provides sufficient confidence for a conditional acceptance decision pending resolution of the six unassessed epistemic gaps in subsequent design phases. No formal sensitivity analysis has been completed; dominant input drivers remain uncharacterized, and this gap is acknowledged as a limitation to be addressed in the next assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
