      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented and matched in CFD setup to within measurement uncertainty.",
      "rationale": "Inlet flow rates, impeller speeds, and fluid properties from FDA PIV study reproduced in CFD boundary conditions. Inlet turbulence intensity set to 5% consistent with upstream pipe length. Temperature held at 37 °C matching bench test conditions. Boundary condition uncertainty estimated at ±2% on flow rate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric V) defined and computed for primary QoI.",
      "rationale": "Validation metric computed as mean absolute relative error (MARE) between CFD and PIV velocity profiles at 5 axial planes. MARE = 6.4% for primary operating point. NIH prediction within 12% of bench mean across 3 tested conditions. Both metrics satisfy MRL 2 thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
