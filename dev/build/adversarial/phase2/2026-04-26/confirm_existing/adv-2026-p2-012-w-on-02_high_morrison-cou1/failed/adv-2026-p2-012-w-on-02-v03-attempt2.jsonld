  "signature": "ed25519:b4e2d1c3f5a7b9c0d2e4f6a8b0c1d3e5f7a9b2c4d6e8f0a1b3c5d7e9f1a2b4c6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD analysis must be verified under a documented quality management system with version control and audit trail at Gradation 2.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under an ISO 9001-compliant QMS. Version control logs, installation qualification records, and regression test results are archived. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases at Gradation 2.",
      "rationale": "ANSYS Fluent has been verified against ASME V&V 20 benchmark cases for incompressible Navier-Stokes flow. Internal verification test suite results confirm correct discretisation of momentum and continuity equations. Required Gradation 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Spatial discretisation error must be quantified via mesh convergence study; grid convergence index (GCI) must be below 5% for primary QoI at Gradation 2.",
      "rationale": "Three-level mesh refinement study performed on the FDA centrifugal pump geometry (coarse 1.2 M, medium 4.8 M, fine 19.2 M cells). GCI for wall shear stress (primary hemolysis driver) is 2.1% between medium and fine meshes. Richardson extrapolation confirms asymptotic convergence. Achieved Gradation 3 exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable to the COU operating conditions at Gradation 2.",
      "rationale": "FDA benchmark experimental data (Hariharan et al. 2011) documents inlet flow rates, rotational speeds, and fluid properties. Test conditions span 2–6 L/min and 2000–3500 RPM, overlapping the CPB COU envelope. Traceability to COU conditions is established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model predictions must be compared quantitatively to experimental data using a defined metric; agreement within 15% for primary QoI at Gradation 2.",
      "rationale": "Predicted relative hemolysis index (RH) compared against experimental hemolysis measurements across all 5 flow-speed operating points. Mean absolute error is 9.3% across the test matrix. All predictions fall within the 15% acceptance band. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs extracted from the model must be directly relevant to the clinical decision at Gradation 2.",
      "rationale": "The primary QoI is the relative hemolysis index (RH), directly linked to the regulatory acceptance criterion (RH < 1 vs. predicate device). Wall shear stress and exposure time distributions are intermediate QoIs feeding the hemolysis power-law model. All QoIs are clinically and regulatorily relevant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the same device geometry, fluid, and operating regime as the COU at Gradation 2.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump, which shares impeller topology with the subject CPB device. Blood analogue fluid (39% glycerol-water, matched viscosity) used in experiments. Operating conditions overlap COU envelope. Validation activities are directly relevant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal iterative convergence error quantification beyond residual monitoring is not required.",
      "rationale": "Residual convergence to 1e-6 for all equations monitored and confirmed. Formal solver error budgeting not required at MRL 2; factor scoped to Gradation 1 consistent with risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error analysis is not required beyond standard analyst training documentation.",
      "rationale": "Analysts hold documented CFD competency qualifications. Formal use error FMEA not required at MRL 2. Factor accepted at Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal model form uncertainty quantification is not required; engineering justification of turbulence model selection suffices.",
      "rationale": "SST k-omega turbulence model selected based on published literature for transitional pump flows. Formal model form UQ not required at MRL 2. Engineering justification documented in modelling report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, input parameter sensitivity analysis is not required; nominal inputs with documented sources are sufficient.",
      "rationale": "Blood viscosity (0.0035 Pa·s) and density (1060 kg/m³) sourced from ISO 10993-5 reference values. Geometric inputs from nominal CAD with manufacturing tolerances documented. Formal sensitivity analysis deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterisation of test sample variability is not required.",
      "rationale": "FDA benchmark dataset uses a single nominally-manufactured pump specimen. Sample-to-sample variability assessment not required at MRL 2. Factor accepted at Gradation 1."
