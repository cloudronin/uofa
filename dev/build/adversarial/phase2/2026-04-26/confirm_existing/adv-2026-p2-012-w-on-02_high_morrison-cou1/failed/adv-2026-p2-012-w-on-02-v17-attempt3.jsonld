      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size and representativeness of test specimens must be documented.",
      "rationale": "At MRL 2, formal statistical characterization of test sample variability is not required. Three experimental runs per operating point were conducted for repeatability. No further assessment is required at this model risk level."
    },
