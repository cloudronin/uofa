  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be under version control with documented build and test procedures consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is a commercially validated package with documented QA procedures, release notes, and regression test suites. Version control records confirm the specific solver version used throughout the study. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against at least one benchmark problem with known analytical or highly accurate reference solution relevant to the flow physics of interest.",
      "rationale": "Code verification was performed using a steady-state Couette flow benchmark with an analytical solution. Discretization errors were within 0.3 % of the analytical result at the mesh resolution used in the hemolysis simulations, confirming correct implementation of the governing equations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified using a systematic mesh refinement study; grid convergence index (GCI) or equivalent metric must be reported for the primary QoI.",
      "rationale": "A three-level mesh refinement study was conducted with mesh sizes of 1.2 M, 4.8 M, and 19.2 M cells. GCI values for the relative hemolysis index were below 2.1 % on the medium mesh, which was selected for production runs. The achieved level exceeds the MRL 2 requirement, providing additional confidence in spatial accuracy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and must overlap with at least a subset of the COU operating conditions.",
      "rationale": "Validation experiments were conducted at 37 °C using bovine blood at 40 % hematocrit across three flow-speed combinations that fall within the COU operating envelope. Test conditions are documented in the laboratory protocol and traceable to calibrated instrumentation records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared quantitatively against experimental measurements for the primary QoI; agreement metric must be defined and reported.",
      "rationale": "Simulated RHI values were compared against experimentally measured RHI at three matched operating points. Mean absolute error was 8.4 % and all predictions fell within experimental uncertainty bands. The RH < 1 criterion was met at all five COU operating points in simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest extracted from the simulation must be directly linked to the clinical or engineering decision defined in the COU.",
      "rationale": "The primary QoI is the relative hemolysis index (RHI), which directly quantifies pump-induced blood damage relative to the predicate device. RHI is the regulatory acceptance metric for Class II CPB devices and maps directly to the worst-case hemolysis identification objective of the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the same flow physics, device geometry class, and fluid properties as the COU.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry using the same turbulence model (SST k-omega), hemolysis power-law model, and blood rheology as the COU simulations. The validation domain is sufficiently similar to the COU geometry to support transferability of the credibility evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be monitored; residual targets must be documented.",
      "rationale": "At MRL 2, formal quantification of numerical solver error beyond residual monitoring is not required. Residuals were converged to 1e-5 for all equations. No further assessment is required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-introduced error in model setup and post-processing must be acknowledged.",
      "rationale": "At MRL 2, formal use-error analysis is not required. Simulation setup was reviewed by a second analyst for consistency with documented procedures. No further assessment is required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The mathematical model form, including turbulence closure and hemolysis sub-model, must be justified relative to the flow regime and QoI.",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance for internal rotating flows at transitional Reynolds numbers. The Giersiepen-Wurzinger power-law hemolysis model is the industry-standard formulation for CFD-based RHI prediction in blood pumps. Model form choices are documented and referenced to peer-reviewed validation literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be documented with sources; boundary conditions must be traceable to the COU definition.",
      "rationale": "Inlet velocity profiles, outlet pressure boundary conditions, blood viscosity (Carreau-Yasuda model, 40 % Hct), and impeller geometry were all documented with sources. Boundary condition values were derived from the five COU flow-speed operating points and are traceable to the test protocol."
    },
    {
      "type": "CredibilityFactor",
