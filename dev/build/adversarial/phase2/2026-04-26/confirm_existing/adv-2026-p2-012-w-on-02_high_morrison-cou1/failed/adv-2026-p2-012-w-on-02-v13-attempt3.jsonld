  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required gradation levels for MRL 2. Six factors are appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 3. Validation evidence demonstrates mean NIH prediction error of 8.3% against in vitro measurements with GCI below 5%. RH < 1 criterion satisfied across all five operating points. The model is accepted for use in identifying worst-case hemolysis conditions for the Class II CPB device.",
