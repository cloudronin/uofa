  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates with blood at physiological temperature (36–38 °C), inlet pressures of 5–15 mmHg, outlet pressures of 80–150 mmHg, and flow rates spanning 2–6 L/min across five rotational speed settings (1500–3500 RPM). Flow regime is laminar-to-transitional (Re 400–2200). Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr1",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against in vitro measurements",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in vitro experimental measurements across 5 flow-speed operating points. Mean relative error 8.3%; all predictions within ±15% of experimental values. RH < 1 criterion satisfied at all operating points."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr2",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error assessment",
      "description": "Grid convergence index (GCI) computed for three mesh refinement levels (1.2M, 4.8M, 19.2M cells). GCI for NIH output below 3.2% on fine mesh, confirming discretization error is within acceptable bounds for MRL 2."
    }
  ],
