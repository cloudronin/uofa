  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors were not assessed in accordance with MRL 2 scoping rules. GCI < 3% across all operating points, experimental comparison within 15%, and direct relevance of validation activities to the COU collectively support acceptance of the CFD model for identifying worst-case hemolysis conditions in the Class II CPB device. RH < 1 criterion is predicted to be satisfied at the nominal design point and across the tolerance band studied.",
