  "signature": "ed25519:b2c4d6e8f0a1b3c5d7e9f1a3b5c7d9e1f3a5b7c9d1e3f5a7b9c1d3e5f7a9b1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification tests, version control, and release notes consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is a commercially validated platform with documented regression testing, version-controlled release notes, and an established quality management system. Software quality assurance activities meet the Gradation 2 requirement for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases relevant to rotating machinery flows.",
      "rationale": "Benchmark verification cases including lid-driven cavity, rotating channel flow, and Taylor-Couette flow were executed. Results agreed with published analytical and numerical reference solutions within expected discretization error bounds, confirming correct code implementation at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate discretization error below 5% for the hemolysis index QOI at the worst-case operating point.",
      "rationale": "A three-level mesh refinement study (coarse: 2.1M cells, medium: 6.8M cells, fine: 18.4M cells) was conducted at the worst-case operating condition (5 L/min, 3500 RPM). Richardson extrapolation yielded a grid convergence index of 1.8% for the normalized hemolysis index, exceeding the Gradation 2 threshold and achieving Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to reproduce boundary conditions in the CFD model.",
      "rationale": "In vitro hemolysis experiments used bovine blood at 37 °C with hematocrit 35±2%, matching documented boundary conditions. Inlet flow rates, rotational speeds, and fluid properties were measured and reported with uncertainty bounds, enabling faithful reproduction in the CFD model at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index must agree with experimental measurements within combined model and experimental uncertainty at all 5 operating points.",
      "rationale": "The CFD-predicted normalized index of hemolysis was compared against in vitro measurements across all 5 flow-speed combinations. Agreement was within 12% at all operating points, within the combined uncertainty envelope. The relative hemolysis index RH remained below 1.0 at each condition, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOIs extracted from the CFD model must directly map to the clinical hemolysis endpoint and the regulatory acceptance criterion (RH < 1).",
      "rationale": "The primary QOI is the power-law hemolysis index integrated over all fluid pathlines, which directly computes the normalized index of hemolysis used to derive RH. This QOI has established mechanistic linkage to erythrocyte damage and is the quantity specified in the regulatory submission framework, confirming relevance at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use geometrically representative pump hardware and clinically relevant operating conditions overlapping the intended COU.",
      "rationale": "Validation was performed on a physical prototype of the FDA generic centrifugal pump geometry — the same geometry used in the submission simulations. Operating conditions spanned the COU flow-speed matrix. The validation domain is therefore directly representative of the intended use, meeting Gradation 2 relevance requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off errors are acceptable at Gradation 1 for MRL 2 without formal quantification.",
      "rationale": "At MRL 2, Gradation 1 is required for numerical solver error. Residual convergence to 1e-5 for all transport equations was confirmed for each simulation, and double-precision arithmetic was used throughout, providing sufficient confidence without formal error quantification. Formal assessment scoped out per MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Gradation 1 requires that simulation setup be performed by qualified personnel with documented training; formal use-error analysis not required at MRL 2.",
      "rationale": "Simulations were executed by an engineer with five years of CFD experience in cardiovascular device applications. Simulation setup was peer-reviewed by a senior analyst. Gradation 1 is satisfied; formal use-error quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Gradation 1 requires documented justification of model form selection; formal sensitivity analysis not required at MRL 2.",
      "rationale": "The k-omega SST turbulence model was selected based on its established performance in confined rotating flow simulations and prior literature on centrifugal pump hemolysis. The power-law hemolysis model (Giersiepen et al.) is the standard formulation for this application. Model form justification is documented and meets Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Gradation 1 requires that all model inputs be identified and their nominal values documented; formal uncertainty propagation not required at MRL 2.",
      "rationale": "All model inputs including fluid viscosity, density, hematocrit-dependent properties, rotational speed, and inlet boundary conditions are documented in the simulation report with nominal values and sources. Gradation 1 is met; formal uncertainty propagation is deferred as not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Gradation 1 requires documentation of the number of experimental samples used in validation; statistical characterization not required at MRL 2.",
      "rationale": "Three independent experimental runs were conducted at each of the 5 operating points using separate blood samples. Mean values were used for model comparison. Sample count and preparation protocol are documented. Gradation 1 is satisfied without requiring formal statistical power analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Gradation 1 requires that CFD boundary conditions be set to match nominal experimental conditions; formal equivalency mapping not required at MRL 2.",
      "rationale": "CFD inlet velocity profiles, rotational speed, and fluid properties were set to match the nominal values recorded during in vitro experiments. Correspondence between experimental and simulation inputs is documented in the validation report. Gradation 1 equivalency is confirmed."
    }
