  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates across a physiologically relevant envelope spanning blood temperatures of 20–37 °C, inlet pressures of 5–20 mmHg, outlet pressures of 80–200 mmHg, flow rates of 2–6 L/min, and rotational speeds of 1500–3500 RPM. Flow regimes are predominantly turbulent (Re 3000–15000) with laminar boundary layer regions near the impeller walls. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-rh-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against experimental predicate data",
      "description": "CFD-predicted relative hemolysis index (RH) compared against in vitro experimental measurements for the FDA generic centrifugal blood pump across 5 flow-speed operating points. RH < 1 at all assessed conditions."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study for hemolysis-sensitive regions",
      "description": "Systematic mesh refinement study demonstrating discretization error below 3% for shear-stress-derived hemolysis index in impeller blade passage and volute regions."
    }
  ],
