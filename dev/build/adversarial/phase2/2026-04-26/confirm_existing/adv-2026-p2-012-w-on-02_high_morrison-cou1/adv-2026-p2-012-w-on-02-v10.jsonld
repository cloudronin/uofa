  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The device operates with blood at physiological temperature (36–38 °C), inlet pressures of 5–15 mmHg, outlet pressures of 250–500 mmHg, and flow rates spanning 2–6 L/min across five nominal speed settings (2000–4000 RPM). Flow regime is laminar-to-transitional (Reynolds numbers 500–3500 in the volute passage). Shear stress exposure times are on the order of 1–10 ms in the impeller region. Model influence is MEDIUM (bench testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-pressure-rise",
      "type": "ValidationResult",
      "name": "Pressure-rise validation against FDA pump experimental data",
      "description": "CFD-predicted pressure rise compared to experimental measurements across 5 operating points. Mean relative error 3.2%, within acceptance threshold of 5%."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation",
      "description": "Predicted normalized index of hemolysis (NIH) compared to in-vitro hemolysis measurements. RH < 1 criterion satisfied at all 5 operating points. Power-law hemolysis model (Giersiepen-Wurzinger) applied with literature coefficients."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-mesh-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence study — discretization error quantification",
      "description": "Richardson extrapolation applied across three mesh densities (2.1M, 5.8M, 14.3M cells). Grid convergence index (GCI) < 1.5% for pressure rise QoI; GCI < 4.8% for NIH QoI. Asymptotic range confirmed (ratio 0.97)."
    }
  ],
