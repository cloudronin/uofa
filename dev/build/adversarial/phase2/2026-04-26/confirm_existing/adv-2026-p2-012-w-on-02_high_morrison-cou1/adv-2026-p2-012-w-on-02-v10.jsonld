  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 19.2) with documented QA procedures and regression test suite. Required level 1 for MRL 2.",
      "rationale": "ANSYS Fluent 19.2 is a commercially validated solver with ISO 9001-certified development process. Vendor-supplied verification test suite covers incompressible rotating machinery cases. Achieved level 2 exceeds MRL 2 requirement of level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against canonical rotating-machinery benchmarks with documented convergence to analytical solutions. Required level 1 for MRL 2.",
      "rationale": "Fluent code verification documented in ANSYS verification manual. Taylor-Couette and lid-driven cavity benchmarks confirm second-order spatial accuracy. Achieved level 2 satisfies and exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) quantified for primary QoI (pressure rise, NIH). GCI < 5% required. Richardson extrapolation applied on minimum three mesh levels.",
      "rationale": "Three-level mesh refinement study performed. GCI_fine = 1.5% for pressure rise, GCI_fine = 4.8% for NIH. Asymptotic convergence ratio 0.97 confirms solutions in convergent regime. Achieved level 3 exceeds required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) match simulation inputs within ±2% for all 5 operating points.",
      "rationale": "FDA pump experimental protocol specifies glycerol-water blood analog (viscosity 3.5 cP at 37 °C). Flow rates set by Coriolis meter (±0.5% accuracy). Rotational speed controlled to ±5 RPM. Boundary condition correspondence confirmed within ±1.8% across all operating points. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (V&V 20 area validation metric or equivalent) applied to pressure-rise and NIH predictions. Validation uncertainty U_val quantified.",
      "rationale": "Area validation metric applied per ASME V&V 20. Experimental uncertainty propagated from flow meter, torque transducer, and spectrophotometric NIH measurement uncertainties. U_val = 6.3% for NIH; model prediction falls within U_val band at 4 of 5 operating points. Outlier at 6 L/min / 4000 RPM attributed to transitional flow regime; noted as model limitation in assessment record. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (pressure rise, NIH) are directly linked to the COU decision criterion (RH < 1). Traceability from QoI to regulatory acceptance criterion documented.",
      "rationale": "NIH is the regulatory hemolysis metric specified in ISO 10993-4 and FDA guidance for blood-contacting devices. RH = NIH_device / NIH_predicate is the acceptance criterion. Pressure rise governs hydraulic performance and is directly linked to CPB circuit adequacy. Both QoIs are fully traceable to the COU decision. Achieved level 3 exceeds required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the FDA generic centrifugal pump geometry under CPB-representative conditions. Geometric and operational similarity to COU documented.",
      "rationale": "Validation dataset uses the FDA-CDRH generic centrifugal blood pump, which is the reference geometry for this COU. Operating points span the CPB flow-speed envelope. Blood analog fluid properties match physiological blood viscosity within 5%. Validation relevance is high; required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence confirmed: residuals < 1e-5 for all transport equations; mass imbalance < 0.01% of inlet mass flow.",
      "rationale": "All simulations run to residual convergence < 1e-6 for continuity and momentum. Mass imbalance < 0.005% confirmed for each operating point. Double-precision arithmetic used throughout. Required level 1 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; level 1 requirement satisfied by documented simulation protocol and independent peer review of setup files.",
      "rationale": "At MRL 2, level 1 for use error is acceptable without formal independent verification. Simulation setup documented in internal technical report TR-2024-07. Peer review of boundary condition files conducted by second analyst. Not formally assessed per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified for the flow regime (transitional, Re 500–3500). Hemolysis power-law model applicability documented with literature support.",
      "rationale": "SST k-omega turbulence model selected based on published validation studies for transitional flow in centrifugal blood pumps (Fraser et al. 2011, Hariharan et al. 2011). Giersiepen-Wurzinger hemolysis model applied with coefficients from Heuser & Opitz (1980). Model form uncertainty acknowledged for transitional operating points. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis performed on key input parameters (fluid viscosity, rotational speed, inlet pressure). Uncertainty in model inputs propagated to QoI uncertainty.",
      "rationale": "One-at-a-time sensitivity study conducted for viscosity (±10%), rotational speed (±50 RPM), and inlet pressure (±2 mmHg). NIH most sensitive to rotational speed (±8.3% NIH per ±50 RPM). Viscosity sensitivity ±3.1% NIH per ±10% viscosity. Input uncertainties within acceptable bounds for MRL 2. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2. FDA generic pump geometry is a standardized reference geometry; sample variability not applicable.",
      "rationale": "The FDA generic centrifugal blood pump is a numerically defined reference geometry with no manufacturing variability. Test sample factor is not applicable in the traditional sense; level 1 requirement satisfied by use of the canonical geometry. Formally scoped out at MRL 2."
    },
