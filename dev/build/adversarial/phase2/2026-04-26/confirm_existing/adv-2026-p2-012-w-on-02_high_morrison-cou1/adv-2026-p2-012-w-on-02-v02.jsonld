      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass benchmark verification cases relevant to rotating turbomachinery flows.",
      "rationale": "Code verification confirmed via Taylor–Couette flow and lid-driven cavity benchmarks at Reynolds numbers representative of CPB pump operation. Errors within solver-published tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine grid.",
      "rationale": "Three-level structured mesh refinement performed (4.2 M, 9.8 M, 21.4 M cells). GCI on fine grid for RHI = 1.7%, meeting the 5% threshold. Richardson extrapolation applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must correspond to the 5 target flow-speed operating points specified in the COU.",
      "rationale": "In-vitro experiments conducted at 2, 3, 4, 5, and 6 L/min at 2500 and 3500 RPM using porcine blood at 37 °C. All five COU-specified operating points covered. Test protocol documented per ASTM F1841."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RHI must agree with experimental values within ±15% across all assessed operating points.",
      "rationale": "Maximum deviation between predicted and measured RHI is 11.3% at the 6 L/min, 3500 RPM condition. All other points within 8%. Acceptance criterion satisfied across all five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (hemolysis index) must directly map to the regulatory acceptance criterion (RH < 1 relative to predicate).",
      "rationale": "The CFD model outputs volume-averaged shear stress, which is converted to the Giersiepen–Wurzinger hemolysis power-law model to yield RHI. This quantity directly corresponds to the RH < 1 regulatory criterion. Relevance confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
