  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out at MRL 2 with documented justification. Validation evidence demonstrates adequate agreement between CFD predictions and experimental hemolysis data across the five COU operating points. The relative hemolysis index RH < 1 criterion is satisfied for the nominal geometry, and the model correctly identifies the worst-case operating condition. The credibility evidence package is sufficient to support the regulatory submission decision for the Class II CPB device.",
