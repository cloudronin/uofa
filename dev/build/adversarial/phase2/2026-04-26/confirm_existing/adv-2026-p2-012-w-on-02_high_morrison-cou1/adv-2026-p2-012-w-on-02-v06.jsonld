  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA process and version control meets MRL 2 requirement of Gradation 1.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a documented software quality plan. Version control, release notes, and regression test suite are maintained by the vendor. Achieved level exceeds required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases (lid-driven cavity, Poiseuille flow) confirming correct implementation of governing equations.",
      "rationale": "ANSYS Fluent benchmark documentation demonstrates correct order-of-accuracy for incompressible Navier-Stokes. Internal lid-driven cavity and pipe-flow verification cases reproduced analytical solutions within 0.3% at equivalent resolution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (shear stress scalar, hemolysis index) with GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study conducted (coarse 4.2 M cells, medium 9.8 M, fine 21.3 M). Richardson extrapolation yields GCI of 2.1% for volume-averaged hemolysis index and 3.4% for peak shear stress. Fine mesh adopted for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) match simulation inputs within stated uncertainty bands.",
      "rationale": "PIV experiments conducted at matched flow rates (±0.05 L/min) and rotational speeds (±15 RPM). Blood analog (glycerol-water, viscosity 3.5 cP at 37 °C) properties documented and matched in CFD material definition. Temperature controlled to 37 ± 0.5 °C throughout."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated velocity fields agree with PIV measurements within 10% RMS error in the impeller region; hemolysis index within 15% of experimental NIH values.",
      "rationale": "Velocity field RMS error versus PIV is 6.8% across the impeller sweep region. Normalized index of hemolysis (NIH) from CFD agrees with experimental measurements within 11% across all five operating points. Worst-case operating point correctly ranked by model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model QoI (relative hemolysis index RH, volume-averaged shear stress) are directly linked to clinical hemolysis endpoint and regulatory acceptance criterion.",
      "rationale": "RH < 1 acceptance criterion directly maps to predicate device comparison required by FDA guidance for Class II CPB devices. Volume-averaged scalar shear stress feeds the power-law hemolysis damage model (Giersiepen et al.), which is the established computational surrogate for red blood cell lysis in rotary blood pumps."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic pump geometry at overlapping operating conditions with the COU flow-speed envelope.",
      "rationale": "Validation dataset uses the FDA benchmark centrifugal pump geometry (identical to production simulation geometry). Five operating points in validation span the same flow-speed combinations as the COU. Blood analog rheology and hematocrit range (35–45%) are representative of CPB clinical conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; solver residuals and mass conservation reported as surrogate.",
      "rationale": "At MRL 2, explicit solver error quantification beyond residual monitoring is not required. Continuity residuals converged to < 1e-5; mass imbalance < 0.01% across all runs. No further assessment warranted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation setup reviewed by independent analyst.",
      "rationale": "Independent peer review of boundary condition setup, material properties, and solver settings was performed by a second analyst. No discrepancies found. Formal use-error quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; turbulence model selection documented with justification.",
      "rationale": "SST k-omega turbulence model selected based on prior published studies of rotary blood pump CFD. Model form uncertainty not formally quantified at MRL 2; selection rationale documented in simulation plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input parameters sourced from calibrated measurement instruments with documented uncertainty.",
      "rationale": "Fluid viscosity, density, and inlet flow rate measured with calibrated instruments (traceable to NIST standards). Input uncertainty propagation not formally assessed at MRL 2 but instrument calibration certificates archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample preparation and blood analog characterization documented.",
      "rationale": "Blood analog prepared per established protocol (Brookshier & Tarbell 1993). Viscosity verified at each test session with cone-plate rheometer. Sample variability not formally characterized at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
