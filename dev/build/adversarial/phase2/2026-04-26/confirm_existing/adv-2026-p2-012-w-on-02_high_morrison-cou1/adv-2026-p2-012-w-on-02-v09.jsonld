  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates with blood at physiological temperature (36–38 °C), inlet pressures ranging from 5 to 20 mmHg, outlet pressures from 200 to 500 mmHg, and volumetric flow rates spanning 2.0 to 6.0 L/min across five discrete speed settings (1500–3500 RPM in 500 RPM increments). Fluid viscosity is modeled as 3.5 cP (Newtonian approximation). Reynolds numbers within the impeller passage range from approximately 4,000 to 22,000, placing the flow in the transitional-to-turbulent regime. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence study — FDA centrifugal pump geometry",
      "description": "Grid convergence index (GCI) computed across three systematically refined meshes (3.2 M, 9.7 M, and 28.4 M cells). GCI for the hemolysis index QoI was 1.8%, satisfying the < 5% threshold at MRL 2."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental validation — relative hemolysis index comparison",
      "description": "CFD-predicted RH values compared against in-vitro measurements from the FDA benchmark dataset across all 5 flow-speed operating points. Mean absolute error in RH was 0.07 (dimensionless), within the ±0.15 acceptance band established by the clinical team."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-turbulence-sensitivity",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-ω vs. realizable k-ε",
      "description": "Sensitivity study comparing hemolysis index predictions under SST k-ω and realizable k-ε turbulence closures. Maximum relative difference in predicted RH across all operating points was 4.3%, within acceptable bounds for MRL 2."
    }
  ],
