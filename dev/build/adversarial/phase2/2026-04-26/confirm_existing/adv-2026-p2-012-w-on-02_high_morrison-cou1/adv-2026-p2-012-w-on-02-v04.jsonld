  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are not assessed, which is acceptable under the ASME V&V 40 MRL 2 framework for a Class II device with medium model influence. The relative hemolysis index RH < 1 criterion is satisfied at the worst-case operating point identified by the CFD model. The overall credibility body of evidence is sufficient to support the regulatory submission decision for the CPB device tolerance assessment.",
