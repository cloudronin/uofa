      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification tests and version-controlled release procedures consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was used. Vendor-supplied verification test suite documentation and release notes confirm software QA procedures at the level required for MRL 2. Version control logs retained."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation through benchmark problems relevant to rotating-frame viscous flow at MRL 2.",
      "rationale": "Solver benchmarked against the FDA critical path nozzle problem and the Taylor-Couette rotating cylinder problem. L2 norm errors on velocity profiles < 1.5 %, confirming correct numerical implementation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization uncertainty must be quantified and reported; values must be < 5 % on the hemolysis index QoI.",
      "rationale": "Three-mesh GCI study yielded maximum discretization uncertainty of 3.1 % on the hemolysis index, exceeding the MRL 2 requirement. Medium mesh (4.2 M elements) selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be documented and traceable to simulation boundary conditions.",
      "rationale": "In-vitro test loop conditions documented in lab notebooks with calibrated instrumentation. Flow rates controlled to ±0.05 L/min; speed to ±10 RPM; temperature to ±0.5 °C; hematocrit to ±1 %. All conditions mapped directly to CFD boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated RHI must be compared against experimental RHI with quantified uncertainty bands; agreement within combined uncertainty at all 5 operating points.",
      "rationale": "Simulated and experimental RHI compared at all 5 operating points. Maximum discrepancy 0.08 RHI units, within combined experimental and numerical uncertainty of 0.12 RHI units. Acceptance criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (hemolysis index derived from shear stress exposure) must be directly linked to the clinical decision criterion (RH < 1).",
      "rationale": "The relative hemolysis index is computed from the power-law hemolysis model applied to Lagrangian particle shear histories. This QoI is the same metric used in the predicate device comparison and the regulatory acceptance criterion, confirming direct relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid analogue, and operating range as the COU.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry with porcine blood at physiological hematocrit. Operating points span the same 5 flow-speed combinations defined in the COU. Geometry fidelity confirmed by CMM measurements against CAD nominal."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence monitored via residual norms only.",
      "rationale": "At MRL 2, detailed solver error characterisation beyond residual monitoring is not required. Residuals reduced by six orders of magnitude in all production runs; no divergence events observed. Factor scoped out per MRL 2 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records reviewed informally.",
      "rationale": "MRL 2 does not mandate formal use-error analysis. All analysts hold graduate-level CFD training and have completed internal simulation protocol review. Formal use-error assessment deferred per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model must be justified for the flow regime and validated against relevant benchmark data.",
      "rationale": "SST k-omega turbulence model selected based on prior benchmark studies for transitional pump flows. Power-law hemolysis model (Giersiepen coefficients) validated against published in-vitro data. Model form uncertainty estimated at ±12 % on RHI, acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, boundary conditions, and geometric inputs must be traceable to measurements or published reference data with stated uncertainty.",
      "rationale": "Blood density and Carreau viscosity parameters sourced from Cho & Kensey (1991) with hematocrit-adjusted values. Pump geometry from vendor CAD with CMM validation. Inlet velocity profiles from PIV measurements. All inputs documented with uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterisation limited to hematocrit and storage age documentation.",
      "rationale": "Porcine blood samples characterised by hematocrit (38–42 %) and storage age (< 48 h post-collection). Detailed sample-to-sample variability analysis not required at MRL 2. Factor scoped out per MRL 2 guidance."
    },
    {
