  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates at blood temperatures between 20 °C and 37 °C, inlet pressures of 0–50 mmHg, outlet pressures of 150–600 mmHg, flow rates spanning 2–7 L/min, and rotational speeds of 1500–3500 RPM. Flow regime is laminar-to-transitional (Re 200–2000 at the impeller tip). Blood viscosity is modelled as a non-Newtonian Carreau fluid calibrated to packed-cell-volume 35–45 %. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/rhi-comparison-5op",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison across 5 flow-speed operating points",
      "description": "Simulated RHI values compared against in-vitro hemolysis measurements at all 5 target operating points. All simulated RHI values fell below 1.0; maximum absolute error 0.08 RHI units. Validation accepted."
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence study — discretization error quantification",
      "description": "Three-level mesh refinement study (coarse 1.8 M, medium 4.2 M, fine 9.6 M elements). GCI-based discretization uncertainty < 3.1 % on shear-stress-derived hemolysis index at all operating points. Richardson extrapolation confirms asymptotic convergence."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043951",
