  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. The pump operates across a blood temperature range of 20–37 °C, inlet pressures of 5–15 mmHg, outlet pressures of 40–120 mmHg, volumetric flow rates of 2–6 L/min, and rotational speeds of 1500–3500 RPM. Flow is assumed to be in the turbulent-transitional regime (Re 2000–8000). Blood viscosity is modelled as a Newtonian fluid with dynamic viscosity 0.0035 Pa·s. These operating ranges characterise the clinical envelope for adult CPB procedures.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-val-01",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against FDA benchmark experimental data",
      "description": "CFD-predicted normalised index of hemolysis (NIH) compared against published FDA benchmark experimental measurements for the generic centrifugal blood pump at five operating points. Mean relative error 8.3%, within the 15% acceptance threshold."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-val-02",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against predicate device",
      "description": "Relative hemolysis index (RH) computed for candidate device versus predicate device across all 5 flow-speed combinations. All RH values below 1.0, satisfying the acceptance criterion."
    }
  ],
