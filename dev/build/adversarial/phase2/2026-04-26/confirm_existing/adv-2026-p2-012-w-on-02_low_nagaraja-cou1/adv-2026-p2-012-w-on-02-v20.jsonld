  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "12 of 13 V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted given the standardized and well-characterized nature of the ASTM F1717 protocol and the low sensitivity of F1717 QoIs to load rate variation documented in the literature. Overall credibility is sufficient to support a Medium assurance level conclusion for the non-cannulated pedicle screw compression-bending regulatory claim.",
