  "signature": "ed25519:9f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for FEA (Ansys Mechanical) is a commercially validated solver with documented version control, regression testing, and quality management system compliant with 21 CFR Part 820.",
      "rationale": "Ansys Mechanical version 2022 R1 used under a validated software configuration. Version control records and regression test suite documented. QMS procedures confirm software qualification per applicable FDA guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 and vendor verification suite demonstrate correct implementation of linear elastic and contact mechanics formulations relevant to pedicle screw construct simulation.",
      "rationale": "Ansys solver verified against NAFEMS benchmark problems LE1 and LE10 for linear elasticity; contact patch test confirmed. Results match analytical solutions within 0.5%, satisfying the required verification level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates that QoI (stiffness, yield force, force at 40 mm) change by less than 2% upon uniform mesh refinement from the production mesh density.",
      "rationale": "Three-level mesh refinement study conducted on the non-cannulated screw geometry. Stiffness changed by 1.3% and yield force by 0.9% between medium and fine mesh. Production mesh selected at medium density; discretization error estimated at <2% for all QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals converge to below 1e-6 for all load steps; energy balance error less than 0.1% across the full displacement-controlled loading sequence.",
      "rationale": "All simulations converged with force residuals below 1e-7. Energy balance checked at each load increment; maximum energy error 0.04%. No divergence or spurious contact oscillations observed across the 11-construct ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary conditions, material assignments, and contact definitions verified against documented simulation protocol prior to result extraction.",
      "rationale": "Independent peer review of model setup performed by a second FEA analyst not involved in original model construction. Boundary condition application, UHMWPE block representation, and titanium alloy material properties confirmed consistent with ASTM F1717 test configuration and published material data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The choice of continuum linear elastic model with nonlinear contact is justified by the predominance of elastic deformation prior to yield; plasticity model included for yield force prediction.",
      "rationale": "Construct behavior under F1717 loading is dominated by elastic bending of the rod and screw shank. Bilinear isotropic hardening plasticity (Ti-6Al-4V: E=114 GPa, sigma_y=880 MPa, Et=2.3 GPa) captures post-yield response. Model form appropriate for the three QoIs; large-deformation kinematics enabled for 40 mm displacement loading."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from peer-reviewed literature and manufacturer data sheets; geometric dimensions measured from production hardware with calibrated CMM; uncertainty in inputs propagated through sensitivity analysis.",
      "rationale": "Ti-6Al-4V material properties from ASTM F136 and published literature (mean ± SD). Screw and rod geometry from CMM measurements of production components (n=5 per lot). One-at-a-time sensitivity analysis confirms stiffness QoI most sensitive to rod diameter (±3%) and least sensitive to UHMWPE modulus (±0.4%). Input uncertainty incorporated into combined validation uncertainty uval."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental constructs are representative production hardware (N=11); sample traceability documented; coefficient of variation in experimental QoIs less than 10%.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production lots. Lot traceability confirmed. Experimental stiffness CV=4.8%, yield force CV=6.1%, force-at-40mm CV=5.3%. Samples span two independent laboratories, confirming reproducibility."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate the intended use loading environment; multiple load levels or configurations tested to characterize model behavior across the relevant operating range.",
      "rationale": "Testing performed under a single ASTM F1717 configuration (static compression-bending, 10 mm offset, displacement-controlled to 40 mm). Only one test condition evaluated; no variation in offset distance, loading rate, or temperature. Achieved level 2 versus required level 3 represents a known credibility gap accepted by the project team given the standardized nature of the ASTM protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation boundary conditions and material inputs are demonstrably equivalent to experimental test conditions; any discrepancies are quantified and included in validation uncertainty.",
      "rationale": "Experimental fixture geometry digitized and reproduced in FEA. UHMWPE block modulus measured by compression testing (n=3) and applied directly. Rod pre-bend angle measured post-assembly and incorporated into model geometry. Residual discrepancies in fixture compliance quantified as ±1.8% stiffness contribution and included in uval."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all QoIs; percent difference < 10% for all QoIs; statistical validation uncertainty uval computed per ASME V&V 40 Section 5.",
      "rationale": "Stiffness: E/uval=0.84, difference=4.2%. Yield force: E/uval=1.31, difference=6.8%. Force at 40mm: E/uval=1.12, difference=5.5%. All three QoIs satisfy both acceptance criteria. Combined validation uncertainty uval includes experimental measurement uncertainty, simulation numerical uncertainty, and input parameter uncertainty per ASME V&V 40 methodology."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The three QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the regulatory submission claims and the clinical failure modes of interest.",
      "rationale": "Construct stiffness relates to load sharing and adjacent segment effects. Yield force is the primary structural integrity metric for regulatory comparison against predicate devices. Force at 40 mm characterizes post-yield energy absorption relevant to fatigue and fracture risk assessment. All three QoIs appear directly in the 510(k) substantial equivalence comparison table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario (ASTM F1717 compression-bending, non-cannulated 7.5 mm screw, production hardware) is sufficiently similar to the intended use context to support the regulatory decision.",
      "rationale": "Validation performed on the exact device configuration subject to regulatory review (non-cannulated 7.5 mm, Ti-6Al-4V, production rod). ASTM F1717 is the FDA-recognized consensus standard for pedicle screw mechanical testing. Two-laboratory design increases generalizability. The validation scenario is considered highly relevant to the COU; no extrapolation beyond tested configuration is claimed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-credibility-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed the required credibility level. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 specifies a single standardized test configuration and the regulatory decision is supported by the totality of quantitative validation evidence, including E/uval < 1.96 and percent difference < 10% for all three QoIs across N=11 constructs at two independent laboratories. Overall credibility is sufficient to support the Medium model risk level and Medium decision consequence classification.",
    "decidedAt": "2026-04-19T00:00:00Z"
