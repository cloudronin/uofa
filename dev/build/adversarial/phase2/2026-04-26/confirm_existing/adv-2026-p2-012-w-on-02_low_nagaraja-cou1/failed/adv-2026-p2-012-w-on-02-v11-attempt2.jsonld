      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical R2023 R1 is a commercially validated solver with documented QA procedures and regression testing. Required gradation 2.",
      "rationale": "Ansys Mechanical is a commercially available, widely validated FEA platform. Vendor-supplied verification and validation documentation, release notes, and regression test suites satisfy gradation 2 SQA requirements. No custom solver modifications were introduced."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems for linear static structural analysis reproduced within 1% of analytical solutions. Required gradation 2.",
      "rationale": "Standard ASME V&V 10 benchmark cases for beam bending and contact mechanics were executed in Ansys Mechanical and compared to closed-form solutions. All QoIs agreed within 0.8%, confirming correct code implementation for the relevant physics."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <5% change in all QoIs between the production mesh and a uniformly refined mesh. Required gradation 3.",
      "rationale": "A three-level mesh refinement study was conducted. Stiffness, yield force, and force at 40 mm displacement changed by 1.9%, 2.3%, and 1.6% respectively between the medium and fine meshes, confirming convergence. The production mesh (medium) was adopted for all analyses."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6 for all load steps; no divergence warnings. Required gradation 2.",
      "rationale": "All 11 model runs converged with force and displacement residuals below 1e-6. Newton-Raphson iteration counts were consistent across specimens, and no solver warnings or divergence events were logged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented modeling protocol followed; independent peer review of model setup performed. Required gradation 2.",
      "rationale": "A written simulation plan specifying geometry import, material assignment, boundary conditions, and load application was prepared prior to analysis. An independent analyst reviewed all model inputs against the protocol before execution. No deviations were recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic constitutive model with isotropic hardening; contact formulation validated against F1717 geometry. Required gradation 3.",
      "rationale": "Ti-6Al-4V implant components modeled with bilinear isotropic hardening (E=114 GPa, yield 880 MPa, tangent modulus 1.1 GPa). UHMWPE vertebral body surrogates modeled as elastic (E=1.1 GPa). Frictional contact (μ=0.2) applied at all implant-surrogate interfaces. Model form is consistent with published literature for F1717 FEA."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from peer-reviewed literature and ASTM standards; geometric dimensions from CMM measurements. Required gradation 3.",
      "rationale": "Ti-6Al-4V mechanical properties derived from ASTM F136 and manufacturer coupon testing. UHMWPE surrogate properties from ISO 5834-2 data. Screw and rod geometry digitized from CMM measurements of production hardware with ±0.01 mm accuracy. All inputs documented in the simulation archive."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production lots tested across two independent laboratories. Required gradation 3.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production hardware were tested. Specimens were distributed across two independent testing laboratories (FDA CDRH and DePuy Synthes). Lot traceability documented for all hardware."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two loading rates or environmental conditions. Required gradation 3.",
      "rationale": "All testing performed under a single quasi-static loading rate (5 mm/min) per ASTM F1717 protocol. No variation in loading rate or environmental conditions was explored. This limitation reduces the achieved level to gradation 2, below the required gradation 3. Accepted under the overall credibility assessment given the standardized nature of the F1717 protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and material properties demonstrably equivalent to experimental conditions. Required gradation 3.",
      "rationale": "FEA model boundary conditions replicated the F1717 test fixture constraints: inferior block fixed, superior block constrained to translate axially with applied compressive-bending moment arm. Material properties matched to measured coupon data. Fixture compliance measured and incorporated into the model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using pre-specified acceptance bounds (<10% QoI difference, E/uval < 1.96). Required gradation 3.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) compared using mean absolute percentage error and the E/uval metric. Stiffness: MAPE 4.2%, E/uval 0.91. Yield force: MAPE 6.8%, E/uval 1.44. Force at 40 mm: MAPE 5.5%, E/uval 1.12. All within pre-specified acceptance bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to the decision-relevant mechanical performance metrics for the pedicle screw construct. Required gradation 3.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the primary performance metrics specified in ASTM F1717 and are directly relevant to the regulatory submission decision. These QoIs are sensitive to the failure modes of clinical concern (fatigue initiation, excessive deformation)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device design, same loading mode, and same performance metrics as the COU. Required gradation 3.",
      "rationale": "Validation experiments used production non-cannulated 7.5 mm pedicle screw hardware under ASTM F1717 compression-bending, identical to the COU. Both the validation and the intended use involve the same device design, same loading configuration, and same QoIs. No extrapolation beyond the validation domain is required for the COU decision."
    }
