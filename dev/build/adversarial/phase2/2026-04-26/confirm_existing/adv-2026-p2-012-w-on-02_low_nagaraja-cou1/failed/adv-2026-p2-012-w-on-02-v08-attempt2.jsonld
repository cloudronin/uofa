  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) used under validated institutional license with version control and audit trail. Required level 2 per model risk 3.",
      "rationale": "Ansys Mechanical is a commercially validated FEA platform with documented QA processes. The modeling team operates under an ISO 9001-aligned quality management system; all simulation files are version-controlled in a validated repository. Achieved level 2 satisfies the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks (NAFEMS and manufacturer-supplied patch tests) confirm correct implementation of element formulations used in the pedicle screw model.",
      "rationale": "Standard NAFEMS linear static benchmarks were executed in Ansys Mechanical and results matched reference solutions within 0.5%. Manufacturer patch tests for the hexahedral and tetrahedral element types used in the screw geometry confirmed numerical correctness. Achieved level 2 meets the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in all three QoIs between the medium and fine mesh densities. Richardson extrapolation applied to estimate asymptotic solution.",
      "rationale": "A three-level mesh refinement study (coarse: 0.8 mm global element size; medium: 0.5 mm; fine: 0.3 mm) was performed on the non-cannulated 7.5 mm screw geometry. QoI variation between medium and fine meshes was 1.1% (stiffness), 1.4% (yield force), and 0.9% (force at 40 mm). Richardson extrapolation confirmed asymptotic convergence. The production mesh uses the medium density to balance accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge to below 1e-6 for all load steps; energy norm checked at each increment.",
      "rationale": "The sparse direct solver (SPARSE) was employed for all static analyses. Residual force norms fell below 1e-6 at every load increment across all 11 simulated constructs. No unconverged load steps were recorded. Energy norm monitoring confirmed solution stability throughout the nonlinear loading sequence to 40 mm displacement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and material assignments by a second qualified analyst not involved in original model construction.",
      "rationale": "A senior biomechanical engineer independent of the primary modeling team reviewed all model inputs, boundary condition definitions, contact pair assignments, and material property tables against the documented simulation plan. No discrepancies were identified. The review was documented in the project quality record prior to submission of simulation results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear-elastic model with nonlinear contact is appropriate for the quasi-static ASTM F1717 loading regime; supported by literature precedent and sensitivity analysis.",
      "rationale": "The pedicle screw and UHMWPE block assembly is modeled as a continuum using linear-elastic titanium alloy (Ti-6Al-4V) with frictional contact (mu=0.3) at screw-block interfaces. The quasi-static loading rate (5 mm/min) justifies neglect of inertial effects. A sensitivity analysis varying friction coefficient ±0.1 produced <3% change in QoIs. Literature (Nagaraja et al. 2017; Zdero et al. 2010) supports this model form for F1717 construct simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM-certified material certificates; geometric dimensions from CMM measurements of actual test specimens; uncertainty propagation performed for key inputs.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and yield strength (880 MPa) were taken from material certificates accompanying the test lot. UHMWPE block modulus (0.95 GPa) was measured by uniaxial compression testing of companion specimens. Screw geometry was verified by CMM measurement of three randomly selected screws from the test lot; dimensional deviations were below 0.02 mm. Monte Carlo uncertainty propagation (N=500 samples) over material property distributions confirmed QoI uncertainty contributions are within the 10% acceptance bound."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lot; two independent laboratories; sample-to-sample variability characterized and within ASTM F1717 reproducibility limits.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled and tested: six at Laboratory A (FDA CDRH) and five at Laboratory B (DePuy Synthes). All screws were from the same production lot. Inter-laboratory coefficient of variation for stiffness was 4.8%, consistent with the ASTM F1717 reproducibility statement. Individual specimen dimensions were recorded and used as model inputs for the corresponding simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of intended use conditions; multiple loading rates or construct configurations evaluated.",
      "rationale": "Testing was conducted at a single loading rate (5 mm/min) and a single construct configuration (7.5 mm non-cannulated screw in UHMWPE block per ASTM F1717). While this fully characterizes the standard test condition, it does not span the range of in vivo loading rates or alternative construct geometries. This factor therefore achieves level 2 rather than the required level 3, representing a known gap acknowledged in the credibility assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material properties, boundary conditions) are directly traceable to measured experimental parameters for each of the 11 constructs.",
      "rationale": "For each of the 11 experimental constructs, the corresponding FEA model was populated with specimen-specific CMM-measured geometry and lot-specific material properties. Boundary conditions replicate the ASTM F1717 fixture geometry as measured by the testing laboratories. A traceability matrix linking each experimental specimen to its simulation counterpart was reviewed and approved by both laboratories."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using both percentage difference (<10%) and validation metric E/uval < 1.96 for all three QoIs across all 11 constructs.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) were compared for each of the 11 construct pairs. Maximum absolute percentage difference was 8.3% (yield force, specimen 7). The validation metric E/uval was computed incorporating experimental measurement uncertainty and simulation numerical uncertainty; maximum value was 1.54, below the 1.96 threshold. Both acceptance criteria are satisfied for all constructs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the regulatory submission claims and clinical failure modes of interest.",
      "rationale": "Construct stiffness characterizes immediate post-implantation mechanical behavior. Yield force identifies the onset of permanent deformation, directly relevant to implant fatigue life. Force at 40 mm displacement captures ultimate load-bearing capacity relevant to catastrophic failure. All three QoIs are explicitly required by ASTM F1717 and cited in the regulatory submission as primary performance endpoints."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities directly replicate the COU: same screw design, same loading protocol, same QoIs, same acceptance bounds used in the regulatory submission.",
      "rationale": "The validation experiments were conducted on the identical non-cannulated 7.5 mm pedicle screw design submitted for regulatory review, under the ASTM F1717 protocol specified in the COU. The acceptance bounds applied to validation results (<10% QoI difference, E/uval < 1.96) are the same bounds used in the regulatory submission decision. No extrapolation beyond the validated configuration is claimed in this COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a model risk level 3 assessment. The single below-required factor (Test conditions, achieved 2 vs. required 3) is acknowledged and accepted on the basis that the ASTM F1717 standard specifies a single test condition and no alternative loading configurations are claimed in the COU. All three QoIs satisfy both quantitative acceptance criteria across all 11 experimental constructs at two independent laboratories. The overall credibility evidence is sufficient to support a Medium assurance level conclusion for the non-cannulated pedicle screw compression-bending prediction.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
