  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "12 of 13 V&V 40 credibility factors meet or exceed required levels. The single gap (Test conditions, achieved 2 vs. required 3) is accepted on the basis that ASTM F1717 specifies a single standardized test configuration and FDA guidance does not require multi-condition validation for this device class. Overall credibility evidence is sufficient to support a Medium assurance level for the non-cannulated pedicle screw compression-bending COU.",
