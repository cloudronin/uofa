      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6; energy balance checked at each load step.",
      "rationale": "Nonlinear static analyses used Newton-Raphson iteration with force residual tolerance 1e-6. Energy balance errors were < 0.1% across all load steps. Gradation 2 satisfied."
