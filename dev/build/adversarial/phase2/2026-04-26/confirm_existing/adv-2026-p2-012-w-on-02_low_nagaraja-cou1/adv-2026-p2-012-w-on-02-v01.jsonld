  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed their required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) reflects the single-condition F1717 protocol and is considered acceptable given that the protocol is mandated by the standard and the remaining factors collectively provide sufficient confidence. All three QoIs satisfy E/uval < 1.96 and percent-difference < 10%. Overall credibility is judged sufficient for a Medium model risk, Medium decision consequence context.",
