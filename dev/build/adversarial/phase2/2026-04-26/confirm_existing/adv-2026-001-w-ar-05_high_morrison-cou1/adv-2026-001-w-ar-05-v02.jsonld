  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis index validation — CPB operating envelope",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were computed across all five flow-speed operating points defined in the CPB COU (2–6 L/min, 2000–3500 RPM). Predicted NIH ranged from 0.0031 to 0.0078 mg/100 L, consistent with the range reported in the Morrison et al. (2016) FDA pump study. The simulation correctly rank-ordered the worst-case operating condition (3500 RPM, 2 L/min) in agreement with experimental observations. Turbulence-induced shear stress peaks were captured within ±12% of particle-image velocimetry (PIV) measurements obtained on the FDA generic centrifugal pump geometry. The Giersiepen power-law hemolysis model (exponents α=0.785, β=0.062) was applied consistently with prior FDA validation submissions. Overall, the validation demonstrates satisfactory predictive fidelity for the quantities of interest at the CPB operating envelope.",
      "meetsAcceptanceCriteria": true,
      "validationScore": 0.87
    },
    {
      "id": "https://uofa.net/synth/validation/secondary-vad-comparator",
      "type": "ValidationResult",
      "name": "Secondary hemolysis model validation — VAD bench dataset (Giersiepen 1990)",
      "description": "The Giersiepen power-law hemolysis model was additionally validated against the canonical in-vitro hemolysis dataset of Giersiepen et al. (1990), which characterises erythrocyte damage as a function of exposure time and shear stress in Couette-flow and cone-plate viscometer configurations. The FDA generic centrifugal pump geometry shares impeller diameter (52 mm) and nominal flow range (2–6 L/min) with the VAD operating envelope used in that dataset. Predicted hemolysis index values agreed with Giersiepen bench measurements to within ±15% across the shared shear-stress range (50–400 Pa), supporting the model's general applicability. This cross-validation corroborates the primary result and strengthens confidence in the power-law exponents used throughout the assessment.",
      "comparedAgainst": "https://uofa.net/synth/data/vad-bench-hemolysis-giersiepen",
      "meetsAcceptanceCriteria": true,
      "validationScore": 0.81,
      "comparatorNote": "Giersiepen 1990 dataset was acquired at VAD pressure head conditions (≈100 mmHg); CPB operating pressure head is approximately 350 mmHg. The elevated pressure head in CPB significantly alters secondary flow structures and residence-time distributions in the volute, which are the dominant determinants of cumulative shear exposure. The dataset overlap on flow rate and geometry does not compensate for this operating-regime divergence with respect to the hemolysis quantity of interest."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034537",
