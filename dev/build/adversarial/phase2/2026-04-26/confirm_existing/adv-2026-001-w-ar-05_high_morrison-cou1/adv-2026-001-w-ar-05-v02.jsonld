  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented regression test suite; all simulation scripts archived in institutional repository.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional license with version-controlled case files stored in GitLab repository (commit hash recorded per run). Regression tests covering laminar pipe flow, rotating reference frame, and species transport benchmarks pass at each release. Exceeds MRL 2 requirement of basic version documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must reproduce manufactured-solution benchmarks for rotating-frame Navier-Stokes to within second-order convergence rate.",
      "rationale": "Method of manufactured solutions (MMS) applied to the rotating reference frame formulation. Observed convergence rate of 1.94 on velocity components and 1.98 on pressure, consistent with second-order finite-volume discretization. Scalar hemolysis transport equation verified against analytical step-function source benchmark; L2 error norm decreases at 2.01 with mesh refinement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for NIH quantity of interest must be below 5% on the fine-grid solution.",
      "rationale": "Three-level mesh refinement study performed at the highest-hemolysis operating point (3500 RPM, 2 L/min): coarse 4.2 M cells, medium 11.7 M cells, fine 31.4 M cells. Richardson extrapolation yields GCI_fine = 2.1% for volume-averaged NIH, well below the 5% threshold. Wall y+ maintained between 30 and 80 on impeller blades for k-ω SST wall functions. Exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with fluid properties, inlet boundary conditions, and rotational speed to within ±2% of nominal COU values.",
      "rationale": "FDA generic centrifugal pump experimental data (Morrison et al. 2016) acquired with blood analogue fluid (glycerol-water, viscosity 3.5 cP ± 0.1 cP at 37°C) at five operating points spanning the CPB COU envelope. Inlet flow rates measured via Coriolis meter (±0.5% accuracy); rotational speed controlled by servo motor (±10 RPM). Test conditions documented in FDA public dataset and reproduced in CFD boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH and relative hemolysis index (RH) must be compared against experimental measurements using a quantitative metric; RH < 1 acceptance criterion must be evaluated at all five operating points.",
      "rationale": "NIH predictions compared against Morrison et al. (2016) PIV-derived shear stress fields and direct hemolysis measurements. RH computed as ratio of predicted NIH to predicate device NIH at matched operating points; RH < 1 satisfied at all five operating points (range 0.61–0.93). Mean absolute percentage error on NIH is 9.3%. Worst-case operating point correctly identified by model. Comparison methodology follows ASTM F1841 guidance for hemolysis index reporting."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (NIH, RH) must be directly linked to the clinical hemolysis endpoint and traceable to the COU decision criterion.",
      "rationale": "NIH is the FDA-recognised quantity of interest for pump-induced hemolysis per the FDA Guidance on Pump Circulatory Support Devices (2012). RH < 1 is the regulatory acceptance criterion for predicate comparison under 510(k). Both QoIs are directly computed from the CFD shear stress field via the Giersiepen power-law model and are explicitly referenced in the COU decision criterion. No surrogate QoI substitution is required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the same device geometry and within the operating envelope defined by the CPB COU; any extrapolation beyond the validated envelope must be explicitly justified.",
      "rationale": "Primary validation uses the FDA generic centrifugal pump geometry (identical to simulation geometry) at CPB operating points. The Morrison et al. (2016) dataset spans the full COU operating envelope (2–6 L/min, 2000–3500 RPM). Secondary validation against the Giersiepen (1990) VAD dataset is presented as corroborating evidence for the hemolysis model constants; the assessors note that both datasets share impeller scale and flow range, providing confidence in model form. No extrapolation beyond the validated envelope is claimed for the primary result."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; scoped out per project credibility plan.",
      "rationale": "At MRL 2, explicit round-off and iterative convergence error quantification beyond residual monitoring is not required. Residuals converged to 1e-5 for all equations; mass imbalance < 0.01%. Factor not formally assessed per credibility plan scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
