    "https://uofa.net/synth/data/gcbp-mesh-convergence-study"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis QoI validation — normalised index comparison",
      "description": "CFD-predicted normalised hemolysis index (NHI) values were computed for all five CPB operating points (2.5 L/min at 2000 RPM through 6.0 L/min at 3500 RPM). The model produced NHI distributions consistent with published literature for centrifugal blood pumps. Shear-stress exposure histograms showed peak shear below 200 Pa at all operating points, which is widely cited as a threshold below which sub-lethal activation dominates. The relative hemolysis index RH remained below 1.0 across the full design-variation matrix, satisfying the acceptance criterion stated in the COU. Model predictions were reviewed against the Morrison et al. 2019 experimental dataset and found to be in good qualitative agreement; no systematic over-prediction of NHI was observed. The validation team concluded that the CFD model adequately captures the sensitivity of hemolysis to dimensional variations under CPB conditions.",
      "quantitativeMetric": "RH < 1.0 at all five operating points; mean NHI prediction error within ±12% of reported experimental central estimates",
      "passFail": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/secondary-vad-comparator",
      "type": "ValidationResult",
      "name": "Secondary validation — shear-stress field comparison against bench hemolysis data",
      "description": "A secondary validation activity compared CFD-predicted volume-averaged shear-stress fields against bench-measured plasma-free haemoglobin (pfHb) accumulation data from Leverett et al. (1972) power-law damage model calibration experiments and from an in-vitro hemolysis test conducted on the FDA generic centrifugal blood pump geometry at outlet pressures of 100–120 mmHg and flow rates of 4–6 L/min. These conditions correspond to left ventricular assist device (LVAD) duty points, which overlap with CPB flow rates but operate at approximately 2–3× the outlet pressure typical of CPB circuits (30–50 mmHg). The comparator dataset is considered appropriate because the pump geometry, blood analogue fluid, and rotational speed range are identical to the CPB COU, and the hemolysis power-law exponents are treated as pressure-independent in the Giersiepen–Wurzinger model employed. Agreement between CFD and bench pfHb at 120 min was within 18% across all tested speeds. The validation team noted this comparator provides strong evidence of model fidelity for the hemolysis damage integral formulation.",
      "comparedAgainst": "https://uofa.net/synth/data/gcbp-hemolysis-bench-vad-pressures",
      "quantitativeMetric": "pfHb prediction error ≤ 18% at t = 120 min across LVAD operating points; Giersiepen–Wurzinger exponents: α = 3.62 × 10⁻⁵, β = 2.416",
      "passFail": "Pass",
      "limitationNote": "Comparator dataset collected at 100–120 mmHg outlet pressure; CPB COU operates at 30–50 mmHg. Pressure-dependent erythrocyte deformation mechanisms are not evaluated by this comparator. The assumption of pressure-independence in the damage model is asserted but not independently verified for this pressure range transition."
    }
  ],
