  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis QoI validation — CPB operating envelope",
      "description": "The normalised index of hemolysis (NIH) predicted by the CFD model was evaluated across all five CPB flow-speed combinations (2.5 L/min at 2500 RPM through 5.0 L/min at 3500 RPM). Predicted NIH values ranged from 0.0021 to 0.0078 mg/100 L, consistent with the published literature range for centrifugal CPB pumps. The relative hemolysis index RH was computed for each operating point; all five points satisfied RH < 1 against the nominal predicate reference. The Giersiepen-Wurzinger power-law damage accumulation model was applied with coefficients calibrated to the FDA blood trauma benchmark. Agreement between predicted shear-stress distributions and the qualitative patterns reported in prior FDA pump studies was noted as supportive evidence. The validation team concluded that model fidelity is adequate for identifying worst-case hemolysis conditions within the CPB envelope. No quantitative experimental dataset link is formally registered for this result; the comparison relies on literature-derived ranges treated as implicit reference bounds."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-comparator",
      "type": "ValidationResult",
      "name": "Secondary validation — cross-device comparator from VAD operating study",
      "description": "A supplementary validation was performed by comparing predicted hemolysis indices against the FDA generic centrifugal blood pump experimental dataset collected under ventricular-assist-device (VAD) operating conditions (flow rates 3–6 L/min, rotational speeds 2000–3500 RPM, mean arterial pressure differential 60–100 mmHg). The VAD dataset was selected because it employs the same pump geometry, the same blood analogue fluid (bovine blood, haematocrit 33 ± 2 %), and the same NIH measurement protocol as the CPB experimental programme, making it the most rigorously characterised experimental reference available for this pump family. Predicted NIH values agreed with VAD measurements within 18 % across all overlapping operating points, which the assessment team characterised as satisfactory given the known sensitivity of the Giersiepen-Wurzinger coefficients. The team noted that the VAD pressure-differential regime (60–100 mmHg) partially overlaps the CPB regime (20–50 mmHg) at lower VAD operating points, and concluded that the comparator provides meaningful validation support. The distinction in pressure differential — which governs secondary flow structures and near-blade shear intensities critical to hemolysis prediction — was acknowledged in passing but was not evaluated quantitatively for its effect on model applicability to the CPB COU.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-gcbp-vad-comparator-dataset"
    }
  ],
