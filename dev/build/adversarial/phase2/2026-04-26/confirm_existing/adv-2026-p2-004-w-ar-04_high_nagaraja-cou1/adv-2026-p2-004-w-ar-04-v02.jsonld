    {
      "id": "https://uofa.net/nagaraja/validation/vr-stiffness-yield-f40",
      "type": "ValidationResult",
      "name": "F1717 compression-bending QoI comparison: stiffness, yield force, force at 40 mm displacement",
      "description": "Validation result comparing FEA-predicted construct stiffness, yield force, and force at 40 mm displacement against N=11 experimental constructs across two independent laboratories. All three QoIs satisfy the pre-established acceptance bounds: percent difference <10% and E/uval <1.96. The ModelConfiguration used to generate these predictions was ansys-mechanical-2026-q1-build-7-rc2, the release candidate immediately preceding the current production build. The project team assessed this configuration as effectively equivalent to the released build, noting only a minor patch to the contact stabilization algorithm that was not expected to affect quasi-static structural predictions at this length scale. No re-run of the validation suite under the released build was performed prior to submission.",
      "passesCriteria": true,
      "wasGeneratedBy": {
        "id": "https://uofa.net/nagaraja/modelconfig/ansys-mechanical-2026-q1-build-7-rc2",
        "type": "ModelConfiguration",
        "name": "Ansys Mechanical 2026-Q1 build-7-rc2 — non-cannulated pedicle screw FEA configuration",
        "modelVersion": "ansys-mechanical-2026-q1-build-7-rc2",
        "description": "Ansys Mechanical release candidate build used during the formal validation campaign. Mesh: ~1.2 M tetrahedral elements (C3D10), titanium alloy Ti-6Al-4V material properties per ASTM F136, frictional contact (μ=0.2) at screw-rod and rod-tulip interfaces, displacement-controlled loading to 40 mm per ASTM F1717. Solver: sparse direct with large-deformation (NLGEOM ON). This build differs from the production release ansys-mechanical-2026-q1-build-7 only by a single patch to the augmented Lagrange contact stabilization coefficient; the development team documented the patch as non-impacting for quasi-static structural analyses."
      }
    }
  ],
