  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver under configuration management; version-controlled input decks; documented QA procedures for Ansys Mechanical deployment.",
      "rationale": "Ansys Mechanical is deployed under the organization's software QA framework. Input decks are stored in a version-controlled repository with change-history audit trails. QA procedures are documented per ISO 9001 requirements. Achieved level 2 meets the required level for this model risk category."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS and Ansys verification manual reproduce analytical solutions to within solver tolerance.",
      "rationale": "Standard NAFEMS benchmark cases for linear and nonlinear structural analysis were executed and results compared to closed-form solutions. All cases passed within specified tolerances, confirming correct implementation of governing equations in the deployed solver version."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between medium and fine mesh; GCI < 5%.",
      "rationale": "A three-level mesh refinement study was performed on the non-cannulated 7.5 mm screw model. Construct stiffness changed by 1.4% between the medium (element size 0.4 mm at screw-rod interface) and fine (0.25 mm) meshes. GCI was computed at 3.1%. The production mesh corresponds to the medium density, providing adequate accuracy at acceptable computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria met; energy balance verified; no spurious oscillations observed in force-displacement output.",
      "rationale": "All simulations converged to force residual < 1e-5 and displacement residual < 1e-6 within the nonlinear solution scheme. Energy balance was verified for each load step. Force-displacement curves were smooth with no numerical artifacts, confirming adequate solver error control."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup; documented simulation protocol; cross-check by second analyst.",
      "rationale": "Model setup was reviewed independently by a second FEA analyst not involved in the original construction. A documented simulation protocol specifies boundary conditions, contact definitions, material assignments, and load application procedures. No discrepancies were identified during the cross-check review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model (bilinear isotropic hardening Ti-6Al-4V) justified by coupon-level data; contact formulation appropriate for screw-rod interface.",
      "rationale": "Bilinear isotropic hardening plasticity for Ti-6Al-4V is well-established for quasi-static structural loading. Material parameters were derived from coupon tensile tests conducted on the same material lot. Augmented Lagrange contact with friction coefficient 0.2 was selected based on prior literature for titanium-on-titanium interfaces under clamped conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties from lot-specific coupon tests; geometry from certified CAD; torque-induced preload quantified.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (1.2 GPa) were measured from six tensile coupons machined from the same Ti-6Al-4V bar stock used for the test constructs. Screw and rod geometry was imported from certified manufacturing CAD files. Set-screw preload was estimated from the specified insertion torque using a torque-tension calibration fixture."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 constructs; samples from production lot; dimensional inspection confirms conformance to nominal geometry.",
      "rationale": "Eleven constructs were assembled from production-lot components. Dimensional inspection of screw outer diameter, thread pitch, and rod diameter confirmed conformance to nominal specifications within manufacturing tolerances. Two independent laboratories performed testing to assess inter-laboratory variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two independent test configurations or loading rates to characterize sensitivity; full ASTM F1717 protocol compliance.",
      "rationale": "Testing was conducted strictly per ASTM F1717 at a single displacement rate (5 mm/min) and single vertebral body block geometry. Only one test condition was evaluated, limiting the ability to characterize rate sensitivity or geometric variability. This factor falls below the required level 3 and represents a documented gap in the validation evidence base."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model boundary conditions and loading replicate experimental fixture constraints; set-screw torque and UHMWPE block compliance matched.",
      "rationale": "The finite element boundary conditions were constructed to replicate the ASTM F1717 test fixture geometry. UHMWPE vertebral body block compliance was characterized experimentally and incorporated as a nonlinear spring foundation. Set-screw insertion torque was matched to the experimental protocol value of 8 N·m."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI differences reported as percent error and E/uval metric; all three QoIs within acceptance bounds.",
      "rationale": "Three QoIs (construct stiffness, yield force, force at 40 mm) were compared between FEA predictions and experimental measurements. Percent differences were 4.3%, 6.1%, and 7.8% respectively, all below the 10% threshold. E/uval values of 0.87, 1.14, and 1.52 were all below 1.96, satisfying the pre-specified acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes (construct loosening, permanent deformation, catastrophic fracture).",
      "rationale": "Construct stiffness is linked to micromotion and fusion outcomes. Yield force characterizes the onset of permanent deformation associated with screw loosening. Force at 40 mm displacement captures post-yield structural integrity relevant to catastrophic failure scenarios. All three QoIs are directly traceable to the identified clinical failure modes in the risk analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, material, and loading match the COU device and intended use conditions.",
      "rationale": "The validation constructs used production-lot non-cannulated 7.5 mm pedicle screws identical to the COU device. Loading per ASTM F1717 replicates the dominant in vivo bending-compression mode. The validation domain is therefore directly applicable to the COU without extrapolation in geometry, material, or loading regime."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/computational-modeling-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single gap (Test conditions, achieved 2 vs. required 3) is acknowledged and accepted on the basis that ASTM F1717 is a standardized single-condition protocol and the validation sample size of N=11 across two laboratories provides adequate statistical confidence. All three QoIs satisfy the pre-specified acceptance bounds. The assessment team noted that the validation runs were executed under Ansys Mechanical 2026-q1-build-7-rc2, which is considered effectively the same build as the production-released 2026-q1-build-7 binary; no material changes to structural solver subroutines were identified in the release notes reviewed at the time of assessment. On this basis the credibility package is accepted without re-running validation under the released binary.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
