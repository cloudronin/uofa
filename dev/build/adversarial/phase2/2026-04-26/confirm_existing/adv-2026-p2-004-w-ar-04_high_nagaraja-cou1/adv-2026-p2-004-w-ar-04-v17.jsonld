    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form adequacy demonstrated through comparison with experimental data across the range of QoIs; physics assumptions (linear elasticity with geometric nonlinearity, Coulomb friction contacts) justified by prior literature.",
      "rationale": "Linear elastic material model with geometric nonlinearity (large displacement) captures the dominant deformation mechanisms under F1717 loading. Plasticity was not required as the acceptance criteria target stiffness and yield-point identification, not post-yield behaviour. Model form is consistent with published FDA-sponsored studies on equivalent constructs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (Ti-6Al-4V, UHMWPE) sourced from certified material test reports for the production lot; geometric dimensions from CMM inspection of test specimens.",
      "rationale": "Elastic modulus and yield strength for Ti-6Al-4V screws and rods taken from certified material test reports (MTRs) for the specific production lot used in bench testing. UHMWPE block material properties from supplier datasheet confirmed against ASTM D638 coupon tests. Geometric inputs from CMM measurements of three representative specimens; variability < 0.5% on critical dimensions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs tested across two independent laboratories; constructs assembled from production-representative components with documented lot traceability.",
      "rationale": "Eleven constructs were assembled and tested: six at Laboratory A (FDA-contracted) and five at Laboratory B (DePuy Synthes internal). All components were drawn from the same production lot. Assembly torque values were controlled per manufacturer IFU. Inter-laboratory variability in stiffness was 3.2%, within acceptable range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate the COU loading environment; multiple loading rates or environmental conditions evaluated.",
      "rationale": "Testing was performed at a single crosshead displacement rate (5 mm/min) under ambient conditions per ASTM F1717. The COU is limited to quasi-static compression-bending, which is adequately represented. However, no variation in loading rate or temperature was evaluated, limiting the achieved level to 2 against a required level of 3. This shortfall is documented as an accepted limitation consistent with the ASTM F1717 standard protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material properties, boundary conditions) demonstrated to be equivalent to the physical test configuration used in the validation experiments.",
      "rationale": "A formal input equivalency matrix was completed mapping each FEA model parameter to the corresponding measured or specified test parameter. Geometry was modelled from the same CAD files used for manufacturing. Boundary conditions replicate the ASTM F1717 fixture constraints. No significant unmatched parameters were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using normalised error metric E/uval < 1.96 for all QoIs; percentage difference < 10%.",
      "rationale": "Stiffness: FEA 312 N/mm vs experimental mean 307 N/mm (1.6% difference, E/uval = 0.41). Yield force: FEA 1 840 N vs experimental mean 1 798 N (2.3% difference, E/uval = 0.67). Force at 40 mm: FEA 2 105 N vs experimental mean 2 078 N (1.3% difference, E/uval = 0.38). All QoIs satisfy both acceptance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
