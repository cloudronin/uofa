  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated 7.5 mm pedicle screw compression-bending) is accepted at Medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed the required gradation level. The single exception — Test conditions (Gradation 2 achieved vs. Gradation 3 required) — is acknowledged as a gap; however, the ASTM F1717 single-condition test is the regulatory standard and the strong quantitative agreement across all three QoIs (maximum E/uval 1.12, maximum percent difference 2.1%) provides sufficient confidence for the intended regulatory submission. The model risk level 3 and Medium assurance level are consistent with a Class II device with Medium model influence and Medium decision consequence. All acceptance bounds were pre-specified in the V&V plan prior to data collection.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
