  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for simulation must have documented QA procedures meeting FDA 21 CFR Part 11 requirements, with version control, audit trails, and regression test suites covering hemolysis solver routines.",
      "rationale": "Only informal version control is in place; no regression test suite exists for the hemolysis damage model. Achieved gradation 2 against a required gradation 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy studies and manufactured-solution tests must be performed for both the flow solver and the hemolysis transport equation to confirm correct numerical implementation.",
      "rationale": "Order-of-accuracy testing was performed only for the Navier-Stokes solver; the hemolysis scalar transport equation was not verified via manufactured solutions. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal grid-convergence index (GCI) analysis must be performed on three systematically refined meshes for each operating point, with GCI reported for hemolysis index as the primary QoI.",
      "rationale": "GCI analysis was conducted on only two mesh levels and not for the hemolysis QoI directly. Richardson extrapolation uncertainty exceeds the 5% target. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating conditions (flow rate, rotational speed, fluid viscosity, hematocrit) within defined tolerances.",
      "rationale": "Validation experiments used bovine blood at non-physiological hematocrit (30%) whereas COU requires human blood at 40% hematocrit; rotational speed envelope only partially overlaps. Achieved gradation 1 against required gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation uncertainty) must be computed for hemolysis index at all five COU operating points, with systematic bias and precision assessed.",
      "rationale": "Comparison was performed at three of five operating points; no systematic bias analysis was conducted. Relative error at the two omitted high-flow points is unknown. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (normalized index of hemolysis, NIH) must be directly mapped to the clinical endpoint (plasma-free hemoglobin threshold) with documented traceability.",
      "rationale": "NIH is used as a surrogate but the quantitative mapping to clinical plasma-free hemoglobin thresholds is documented only qualitatively. Achieved gradation 3 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full COU geometry (Class III VAD impeller and volute), full speed-flow envelope, and blood analogue with documented similarity rationale.",
      "rationale": "Validation was performed on a simplified two-dimensional impeller analogue at reduced scale; no full-geometry Class III VAD validation has been completed. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-6 for all equations including hemolysis transport; round-off and iterative errors must be quantified.",
      "rationale": "Hemolysis transport residuals were only driven to 1e-4; iterative error was not separately quantified from discretization error. Achieved gradation 1 against required gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of boundary condition setup, material property assignment, and solver settings for each operating point.",
      "rationale": "Independent review of simulation setup was completed for all five operating points with documented sign-off. Achieved gradation 4 meeting required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis damage model (power-law or mechanistic) must be validated against literature data spanning the shear-stress and exposure-time space relevant to the COU; model-form uncertainty must be quantified.",
      "rationale": "A power-law hemolysis model is used with coefficients from a single legacy dataset; model-form uncertainty has not been quantified and alternative mechanistic models were not evaluated. Achieved gradation 2 against required gradation 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (viscosity, density, hemolysis model coefficients, turbulence model constants) must have documented uncertainty distributions; Monte Carlo propagation must use these distributions.",
      "rationale": "Monte Carlo UQ was performed but only three of seven uncertain inputs had formally characterized distributions; the remaining four used assumed uniform distributions with arbitrary bounds. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation samples must be sufficient in number and biological variability to characterize inter-sample hemolysis variance; minimum n=5 independent blood samples per operating point.",
      "rationale": "Validation experiments used a single pooled bovine blood sample per operating point; inter-sample variability and donor-to-donor biological variance are entirely uncharacterized. Achieved gradation 1 against required gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal similarity analysis must demonstrate that validation experiment input parameters are equivalent to COU inputs within quantified tolerances for all parameters influencing hemolysis prediction.",
      "rationale": "Similarity analysis was performed qualitatively for fluid properties only; no formal equivalency demonstration exists for the hemolysis model coefficients or boundary layer conditions between validation and COU geometries. Achieved gradation 2 against required gradation 4."
    }
  ],
