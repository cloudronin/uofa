    {
      "id": "https://uofa.net/synth/validation/vad-bench-hemolysis-01",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis validation against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-uq-monte-carlo-02",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis index predictions"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043296",
