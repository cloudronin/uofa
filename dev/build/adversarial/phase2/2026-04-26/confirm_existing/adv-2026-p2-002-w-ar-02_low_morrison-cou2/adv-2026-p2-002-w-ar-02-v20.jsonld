  "name": "Morrison COU2 — VAD hemolysis credibility assessment (W-AR-02 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Multiple credibility factors show achieved levels two or more gradations below required levels; the decision record nonetheless records Accepted, constituting a rebutting defeater (W-AR-02).",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/cou2-vad-hemolysis-req",
  "bindsClaim": "https://uofa.net/synth/claim/cou2-vad-hemolysis-claim",
