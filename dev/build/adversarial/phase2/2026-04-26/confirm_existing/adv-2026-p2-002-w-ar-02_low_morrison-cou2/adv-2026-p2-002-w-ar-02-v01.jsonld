      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterization must include donor variability, hematocrit distribution, and RBC age effects relevant to the VAD patient population.",
      "rationale": "Factor not assessed; no sample characterization data were collected for the experimental campaign. Flagged as epistemic gap at MRL 5."
    },
