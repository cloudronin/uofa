      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a formal QMS with traceability to CFD solver version; all regression tests must pass at MRL 5.",
      "rationale": "Solver version control and regression suite exist but formal QMS documentation is incomplete; two regression test categories lack sign-off. Achieved level falls two gradations below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions (MMS) must be demonstrated for all active physics modules at MRL 5.",
      "rationale": "MMS was applied only to the flow solver; the hemolysis transport module lacks independent order-of-accuracy verification. Gap of two levels remains unresolved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must demonstrate grid-converged hemolysis index with quantified discretization uncertainty across all 5 operating points.",
      "rationale": "Grid convergence study performed at one operating point only; remaining four points show non-monotonic convergence behavior. Achieved level is three gradations below required at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate COU operating envelope within stated uncertainty bounds; fluid properties and boundary conditions must be fully characterized.",
      "rationale": "Bench experiments used bovine blood surrogates at room temperature; VAD clinical operating temperatures and hematocrit ranges were not matched. Two-level shortfall documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., ASME V&V 20 U95 band) must demonstrate model predictions within validation uncertainty at all 5 operating points for absolute hemolysis index.",
      "rationale": "Predictions agree at 3 of 5 operating points within U95; two high-flow conditions show systematic over-prediction exceeding validation uncertainty. Achieved level is two gradations below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (hemolysis index) must map directly to the clinical acceptance criterion with documented traceability; sensitivity of clinical outcome to QoI must be quantified.",
      "rationale": "Hemolysis index is clinically relevant but sensitivity analysis linking model QoI to patient hemolysis threshold is qualitative only. One-level shortfall remains."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the full COU operating envelope and device geometry; any extrapolation beyond validated conditions must be quantified and bounded.",
      "rationale": "Validation was conducted on the FDA generic pump geometry; the target VAD geometry differs in impeller clearance and volute design. Extrapolation uncertainty is unquantified. Two-level gap persists."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to solver-tolerance levels with residual monitoring for all operating points; round-off and floating-point error must be characterized.",
      "rationale": "Residual convergence criteria met for flow equations but hemolysis scalar transport residuals plateau above target tolerance at two operating points. Floating-point error characterization absent. Two-level shortfall."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented user qualification process and independent simulation review must confirm correct model setup and boundary condition application for all COU scenarios.",
      "rationale": "Simulations were run by a single analyst without independent review; no formal user qualification record exists for the hemolysis module. Achieved level is two gradations below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified by literature evidence and sensitivity analysis; alternative model forms must be evaluated and their impact on QoI bounded.",
      "rationale": "Giersiepen power-law model selected without evaluation of alternative hemolysis models (Arora, Taskin); model-form uncertainty contribution to total prediction uncertainty is not quantified. Two-level gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty bounds; Monte Carlo propagation must cover all influential inputs identified by sensitivity analysis.",
      "rationale": "Monte Carlo UQ performed but only 4 of 11 identified influential parameters were varied; blood viscosity model coefficients and RBC mechanical threshold were held fixed without justification. Two-level shortfall."
    },
    {
