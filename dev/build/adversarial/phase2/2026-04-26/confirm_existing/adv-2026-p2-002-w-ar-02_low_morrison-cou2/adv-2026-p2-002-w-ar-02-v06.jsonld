      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be fully characterized and traceable to COU operating envelope with documented uncertainty.",
      "rationale": "Experimental conditions were partially documented; inlet turbulence intensity and fluid temperature were not measured and are assumed from literature. Achieved level 2 is two steps below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric with combined experimental and numerical uncertainty bounds required across all QoIs.",
      "rationale": "Comparison uses mean absolute error without propagated uncertainty bounds; only three of five operating points were compared. Achieved level 3 is two steps below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly map to the clinical hemolysis index used in the COU acceptance criterion.",
      "rationale": "Validation QoI is normalized hemolysis index (NIH); COU requires absolute hemolysis index (AHI). Mapping between the two is approximate and not formally justified. Achieved level 3 is one step below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
