  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a formal quality management system with documented version control, regression testing, and change control at Gradation 4 for MRL 5.",
      "rationale": "Solver version control and regression test suite are documented but the quality management system lacks formal FDA 21 CFR Part 11 compliance and independent audit records, placing achieved level at 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating flow benchmarks with documented convergence rates required at Gradation 4.",
      "rationale": "Code verification was performed on a simplified pipe-flow benchmark only; rotating impeller geometries were not included, and convergence order was not formally established for the hemolysis transport equation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence index (GCI) reported for all quantities of interest on at least three systematically refined meshes at Gradation 5.",
      "rationale": "A two-mesh sensitivity study was performed; GCI was not computed and the coarse-to-fine ratio did not meet the factor-of-two refinement criterion, leaving discretization error quantification substantially incomplete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five target flow-speed combinations with documented fluid temperature, hematocrit, and inlet turbulence intensity at Gradation 4.",
      "rationale": "Only three of five flow-speed combinations were experimentally tested; hematocrit was held constant at a single value and inlet turbulence intensity was not measured, limiting test-condition coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., validation uncertainty u_val) computed for hemolysis index across all test conditions with statistical confidence bounds at Gradation 5.",
      "rationale": "Qualitative agreement is demonstrated for three conditions; validation uncertainty was estimated but confidence intervals were not propagated through the hemolysis power-law model, falling short of Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest in validation (hemolysis index, shear stress distribution) must directly correspond to clinical acceptance threshold quantities at Gradation 4.",
      "rationale": "Hemolysis index is the primary QoI and is clinically relevant; however, sub-lethal platelet activation—a secondary QoI required at MRL 5—was not included in the validation dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating range, and fluid properties must match the COU device and patient population at Gradation 5; any geometric or operational differences must be formally bridged.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which differs from the intended VAD impeller design; no geometric bridging argument was provided and the operating speed range overlaps only partially."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria, floating-point precision, and round-off error bounds must be documented and demonstrated to be negligible relative to discretization error at Gradation 4.",
      "rationale": "Residual convergence was monitored but no formal analysis of round-off versus discretization error was performed; double-precision arithmetic was used but not formally justified against solver tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented user qualification, simulation setup checklists, and independent peer review of boundary condition assignments required at Gradation 3.",
      "rationale": "No formal user qualification records exist; boundary condition assignments were not independently reviewed, and simulation setup was performed by a single analyst without documented checklist compliance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis power-law form must be justified against experimental data spanning the full operating envelope with sensitivity analysis at Gradation 5.",
      "rationale": "The k-omega SST turbulence model was selected based on literature precedent; no sensitivity analysis comparing alternative turbulence closures or hemolysis model exponents was performed across the VAD operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (viscosity, density, hemolysis coefficients) must have documented uncertainty bounds derived from patient-population data at Gradation 4.",
      "rationale": "Nominal input values were taken from published literature; patient-population variability in blood viscosity and hematocrit was not propagated into the Monte Carlo UQ, leaving input uncertainty incompletely characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples must include sufficient replicates to characterize biological variability in hemolysis measurements with statistical power analysis at Gradation 4.",
      "rationale": "Experimental hemolysis measurements were obtained from a single test rig with n=3 replicates; no statistical power analysis was performed and biological variability across donor blood samples was not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that validation experiment input parameters are representative of COU operating conditions, including patient-specific flow variability, at Gradation 5.",
      "rationale": "A qualitative equivalency argument was stated in the simulation report but no quantitative comparison of validation versus COU input parameter distributions was provided; patient-specific cardiac output variability was not addressed."
    }
