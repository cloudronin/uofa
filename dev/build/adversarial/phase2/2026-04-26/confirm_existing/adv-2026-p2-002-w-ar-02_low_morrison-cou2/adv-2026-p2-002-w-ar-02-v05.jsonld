      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be fully characterized including fluid temperature, hematocrit, exposure time distribution, and pump operating point with stated measurement uncertainties.",
      "rationale": "Temperature and hematocrit were reported but exposure time distribution was not characterized and measurement uncertainties on flow rate were not stated. Achieved level 2 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics including normalized index of agreement and confidence intervals must be reported for all QOIs across all operating points.",
      "rationale": "Mean hemolysis index agreement is reported at three of five operating points; confidence intervals are absent and no formal validation metric is computed. Achieved level 3 falls one step below required level 4."
    },
    {
