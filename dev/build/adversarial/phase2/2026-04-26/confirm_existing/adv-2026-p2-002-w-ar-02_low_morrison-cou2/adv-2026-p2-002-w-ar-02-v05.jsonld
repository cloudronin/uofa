      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation must be directly mapped to the clinical hemolysis endpoints with documented traceability to regulatory acceptance criteria.",
      "rationale": "Normalized index of hemolysis is used as the QOI and maps to clinical endpoints, but traceability documentation to the specific regulatory threshold is incomplete. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
