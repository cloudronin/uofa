      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent formal discretization error estimation must be performed on at least three systematically refined meshes for all quantities of interest including hemolysis index.",
      "rationale": "A two-mesh comparison was performed rather than the required three-mesh Richardson extrapolation. Discretization error on hemolysis index is not formally bounded. Achieved level 2 is three steps below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
