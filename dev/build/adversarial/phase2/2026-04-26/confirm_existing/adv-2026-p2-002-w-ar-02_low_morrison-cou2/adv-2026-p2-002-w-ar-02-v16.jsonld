  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be under full configuration management with documented regression testing and traceability to requirements at MRL 5.",
      "rationale": "Only informal version control is in place; no regression test suite exists and no requirements traceability matrix has been produced. Achieved level 1 reflects ad hoc practices only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions must confirm solver convergence rate for all governing equations used in hemolysis prediction.",
      "rationale": "Convergence studies were performed on simplified pipe flow only; manufactured-solution verification for the full rotating-frame Navier-Stokes system has not been conducted. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must be performed on all hemolysis-relevant QoIs across at least three systematically refined meshes at each operating point.",
      "rationale": "A two-mesh sensitivity study was performed at a single operating condition; GCI was not computed and no systematic refinement ratio was maintained. Achieved level 2 against a required level of 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be measured and reported with full uncertainty characterisation; inlet velocity profiles and fluid rheology must match COU operating envelope.",
      "rationale": "Inlet boundary conditions were approximated from pump curve data rather than direct measurement; fluid temperature and hematocrit were not controlled to match COU specifications. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) must be computed with combined experimental and simulation uncertainty bounds for all five flow-speed operating points.",
      "rationale": "Comparison was performed at two of five operating points using mean values only; combined uncertainty bounds were not propagated into the comparison metric. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoIs must include the hemolysis index (HI) as the primary clinical surrogate; secondary QoIs (wall shear stress, exposure time distributions) must also be assessed for relevance to patient harm.",
      "rationale": "Validation was performed against pressure rise and flow rate only; HI was not directly validated and shear-stress distributions were not compared to experimental data. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the full COU operating envelope (all five flow-speed combinations) using a device geometrically identical to the VAD under assessment.",
      "rationale": "Validation used the FDA generic pump geometry at a single speed setting; the patient-specific VAD geometry and the remaining four operating points were not covered. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to machine-precision tolerance for all QoIs; round-off and iterative errors must be quantified and shown negligible relative to discretisation error.",
      "rationale": "Residual drop of three orders of magnitude was used as the sole convergence criterion; no QoI-level iterative convergence monitoring was performed and round-off error was not assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "An independent review of all simulation inputs, boundary condition setup, and post-processing scripts must be documented; analyst qualification records must be on file.",
      "rationale": "No independent review of simulation setup was conducted; analyst qualifications are informally documented but not formally verified against a competency framework. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model and turbulence closure must be justified through sensitivity studies and literature evidence specific to blood damage in rotary pumps at MRL 5.",
      "rationale": "The Giersiepen-Wurzinger power-law constants were adopted without sensitivity analysis; the k-omega SST turbulence model was selected by convention rather than demonstrated suitability for this geometry and flow regime. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition values must be measured or sourced from peer-reviewed literature with stated uncertainties; Monte Carlo propagation must cover all significant input uncertainties.",
      "rationale": "Blood viscosity and density were taken from a single literature source without uncertainty bounds; Monte Carlo analysis was performed but only two of eight uncertain inputs were varied. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples must be characterised for hematocrit, age, and donor variability; sample size must be sufficient to estimate population-level hemolysis with stated statistical confidence.",
      "rationale": "In-vitro experiments used bovine blood from a single lot without characterisation of hematocrit or donor variability; no statistical power analysis was performed to justify sample size. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrated equivalent to experimental conditions through direct measurement comparison; any surrogates must be justified with sensitivity analysis.",
      "rationale": "Pump rotational speed was matched nominally but torque and leakage-flow boundary conditions were not measured experimentally and were estimated from manufacturer data. Achieved level 2."
    }
