  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full ISO 9001-compliant SQA plan with traceable version control, automated regression testing, and independent code review documented for all solver modules used in hemolysis predictions.",
      "rationale": "SQA documentation covers version control and basic unit tests only; no independent code review was performed and regression test suite covers fewer than 30% of solver modules. Required level 4 demands comprehensive third-party audit; achieved level 2 reflects partial internal documentation only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using Method of Manufactured Solutions (MMS) demonstrated for all governing equations including the hemolysis transport scalar, with formal convergence rates reported.",
      "rationale": "MMS verification was performed only for the Navier-Stokes momentum equations; the hemolysis power-law scalar transport equation was not subjected to MMS. Formal order-of-accuracy for the QoI-relevant equation is undemonstrated. Achieved level 2 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based Grid Convergence Index (GCI) reported for hemolysis index QoI on at least three systematically refined meshes; GCI < 5% on finest mesh.",
      "rationale": "Only two mesh refinement levels were evaluated and GCI was not computed; reported hemolysis index varied by 38% between coarse and fine mesh. Discretization error for the primary QoI is unquantified at the required rigor. Achieved level 1 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match COU operating envelope (flow rates 3–7 L/min, rotational speeds 2400–3600 RPM) with uncertainty in boundary conditions quantified and reported.",
      "rationale": "Bench experiments were conducted at three of five required operating points; boundary condition uncertainty (inlet velocity profile, outlet pressure) was reported without formal propagation to hemolysis QoI. Partial match to COU envelope. Achieved level 2 versus required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E% with experimental uncertainty bands) reported for hemolysis index at all COU operating points; statistical comparison accounts for both numerical and experimental uncertainty.",
      "rationale": "Hemolysis index comparison performed at three operating points using simple percent error without experimental uncertainty propagation. No statistical hypothesis test applied. CFD over-predicts hemolysis by 45–60% at two of three points. Achieved level 2 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (hemolysis index) is identical to the COU decision QoI; scalar aggregation method matches regulatory submission metric.",
      "rationale": "The normalized index of hemolysis (NIH) used in validation experiments matches the COU QoI definition, but the power-law exponent constants differ between the validation dataset and the COU model implementation. Minor definitional mismatch reduces confidence. Achieved level 3 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device geometry, fluid (blood analogue with matched viscosity and density), and operating regime as the COU; any differences formally justified with sensitivity analysis.",
      "rationale": "Validation used a glycerol-water blood analogue at matched viscosity but mismatched density (5% deviation); device geometry used a scaled model (85% scale). No sensitivity analysis quantifies the impact of these differences on hemolysis predictions. Achieved level 2 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine-precision residuals for all equations; round-off error assessed and shown negligible relative to discretization error for hemolysis QoI.",
      "rationale": "Solver residuals were reduced by only three orders of magnitude; hemolysis scalar residual was not separately monitored. No round-off error analysis was performed. Iterative convergence of the primary QoI is undemonstrated. Achieved level 1 versus required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented user qualification records, simulation execution checklists, and independent peer review of simulation setup files for all COU operating points.",
      "rationale": "User qualifications are on file but simulation setup peer review was performed for only two of five operating points; no formal checklist was used. Partial process controls documented. Achieved level 2 versus required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty for turbulence closure and hemolysis constitutive law quantified via multi-model ensemble; sensitivity of hemolysis index to model form choices reported with bounds.",
      "rationale": "A single turbulence model (SST k-omega) and single hemolysis power-law formulation were used without multi-model comparison. Model form uncertainty is unquantified. Literature suggests hemolysis predictions vary by factors of 2–5 across model choices. Achieved level 2 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (fluid properties, hemolysis law constants, boundary conditions) characterized with probability distributions; Monte Carlo propagation to hemolysis QoI with 95% confidence intervals reported.",
      "rationale": "Monte Carlo UQ was performed but only three of eleven input parameters were assigned distributions; hemolysis law constants C and alpha were treated as fixed nominal values despite known literature variability of ±30%. Partial UQ coverage. Achieved level 2 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements taken from at least three independent pump specimens with inter-specimen variability characterized; sample size sufficient for statistical power analysis.",
      "rationale": "Measurements were taken from a single pump specimen across replicate trials; inter-specimen variability is unknown. No power analysis was conducted. Single-specimen data cannot characterize manufacturing variability relevant to the Class III device population. Achieved level 2 versus required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment input parameters and COU input parameters documented; any gaps addressed with sensitivity analysis or conservative bounding.",
      "rationale": "Equivalency mapping table was produced but does not address the scaled geometry difference or the blood analogue density mismatch. No bounding analysis was provided for the unmapped parameters. Achieved level 2 versus required level 3."
    }
