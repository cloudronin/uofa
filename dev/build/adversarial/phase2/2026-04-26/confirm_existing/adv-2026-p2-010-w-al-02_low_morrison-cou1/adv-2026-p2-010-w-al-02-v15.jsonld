  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors were appropriately scoped as not-assessed at MRL 2. Grid convergence is demonstrated with GCI < 5%, output comparison error is within the 20% acceptance threshold, and uncertainty quantification via Monte Carlo confirms robustness of the nominal hemolysis prediction. The relative hemolysis index RH < 1 criterion is met across all five operating points. The credibility package is accepted for regulatory submission supporting the Class II CPB device 510(k).",
