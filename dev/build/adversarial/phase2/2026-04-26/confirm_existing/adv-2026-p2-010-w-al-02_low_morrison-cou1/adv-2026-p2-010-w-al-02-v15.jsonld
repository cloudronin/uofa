  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under documented version control with traceable build records.",
      "rationale": "ANSYS Fluent v19.2 was used under institutional software QA procedures. Version control records, license documentation, and solver release notes are archived. Achieved level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented verification test suite results for relevant flow physics.",
      "rationale": "ANSYS Fluent is a commercially verified solver with published verification test cases for viscous incompressible flow. Internal benchmark cases for rotating machinery were reviewed and found consistent with published results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index QoI with GCI < 5%.",
      "rationale": "A three-level mesh refinement study was conducted (4.2M, 8.7M, 17.1M cells). Richardson extrapolation yielded GCI values of 2.8% for hemolysis index and 1.9% for pressure head at the design operating point. The medium mesh (8.7M) was selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must bracket the simulated operating envelope with documented flow rate and rotational speed tolerances.",
      "rationale": "FDA benchmark experimental data covers flow rates 2.5–7.5 L/min and speeds 2000–3500 RPM, fully bracketing the 5 simulated operating points. Test fluid properties (bovine blood analog) are documented with measured viscosity and density values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±20% across all validation operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values compared against FDA round-robin experimental data show mean absolute error of 11.4% across all five operating points. Maximum deviation is 17.2% at the 2500 RPM / 2.5 L/min condition, within acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must directly correspond to the regulatory acceptance criterion (relative hemolysis index RH < 1).",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is directly converted to the relative hemolysis index (RH) used in the regulatory acceptance criterion. The mapping between NIH and RH is explicitly documented in the analysis plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating conditions must be representative of the CPB device COU.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry, which is the same platform as the device under evaluation. Operating conditions span the full CPB clinical use envelope. Blood analog fluid properties are within 5% of clinical whole blood rheology at shear rates above 100 s⁻¹."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must be documented; not required at MRL 2 beyond basic reporting.",
      "rationale": "Not assessed at MRL 2. Residual convergence to 1e-5 for all equations was confirmed as standard practice but formal solver error quantification is scoped to MRL 3 and above."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error assessment not required at MRL 2.",
      "rationale": "Not assessed at MRL 2. Analyst qualifications are documented and peer review of simulation setup was conducted, but a formal use-error FMEA is not required until MRL 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty not required to be formally quantified at MRL 2.",
      "rationale": "Not assessed at MRL 2. The SST k-omega turbulence model was selected based on literature precedent for rotating blood-contacting devices, but formal model-form uncertainty analysis is deferred to higher MRL."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs must be documented with sources; nominal values must be traceable to measurements or specifications.",
      "rationale": "All 13 model inputs including geometric tolerances, blood viscosity, rotational speed, and inlet flow rate are documented with nominal values and sources. A comprehensive Monte Carlo uncertainty quantification was performed sampling all inputs simultaneously to produce output distributions for NIH, confirming that the nominal prediction lies within the 10th–90th percentile interval of the UQ ensemble."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample characterization not required at MRL 2 beyond basic documentation.",
      "rationale": "Not assessed at MRL 2. Experimental samples were bovine blood analog per ASTM F1841; formal sample variability characterization is not required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
