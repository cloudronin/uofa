      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented and reproducible, covering at least 3 of the 5 target operating points.",
      "rationale": "Experimental data from FDA interlaboratory study covers all 5 flow-speed operating points (2.5, 3.5, 5.0, 6.0, 7.0 L/min at 2500, 3500, 4500 RPM combinations). Test conditions are fully documented with uncertainty bounds on measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined experimental and numerical uncertainty bands for at least 4 of 5 operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) values agree with FDA interlaboratory experimental mean within ±15% for all 5 operating points. Comprehensive Monte Carlo UQ confirms predicted RH < 1 with 97.3% probability across the operating envelope, though dominant drivers of output variance were not individually ranked."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly linked to the clinical decision criterion (RH < 1) and must be computable from the CFD model.",
      "rationale": "Primary QoI is the relative hemolysis index RH, computed from the Giersiepen-Wurzinger power-law model integrated along Lagrangian particle tracks. This QoI directly maps to the regulatory acceptance criterion and is standard in the blood pump CFD literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario must replicate CPB operating conditions (blood analog fluid, pump geometry, physiological flow rates) to a degree sufficient for MRL 2.",
      "rationale": "Validation uses FDA generic centrifugal pump geometry with glycerol-water blood analog at physiological hematocrit-equivalent viscosity. Operating conditions span the CPB clinical range. Validation scenario is judged sufficiently representative of the COU for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
