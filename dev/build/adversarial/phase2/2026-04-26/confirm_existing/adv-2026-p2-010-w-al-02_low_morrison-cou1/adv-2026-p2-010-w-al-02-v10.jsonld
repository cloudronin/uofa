      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark test cases at MRL 2.",
      "rationale": "Code verification performed against Taylor-Green vortex and lid-driven cavity benchmarks. Observed order of accuracy consistent with theoretical expectations for second-order discretization schemes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
