      "acceptanceCriteria": "Not required at MRL 2 for this device class.",
      "rationale": "Use error assessment is not required at MRL 2 for a Class II device where model influence is Medium. Simulation setup was performed by experienced analysts following documented standard operating procedures, providing adequate informal control."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form uncertainty is addressed through validation comparison at the operating conditions of interest.",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2. The power-law hemolysis model (Giersiepen et al.) is the accepted industry standard for CFD hemolysis prediction and its applicability is supported by the validation comparisons performed under this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs must be documented with sources and nominal values; input uncertainty must be characterized and propagated.",
      "rationale": "All model inputs are documented including fluid viscosity (3.5 mPa·s ± 8%), hematocrit (30% ± 3%), power-law constants (alpha, beta), pump geometry nominal dimensions, and operating boundary conditions. A comprehensive Monte Carlo uncertainty quantification was performed sampling all inputs simultaneously across their documented uncertainty ranges, yielding 95th-percentile RH predictions that remain below the acceptance criterion. Input uncertainty is therefore fully characterized and propagated to the QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterization is addressed through documented test condition reporting.",
      "rationale": "Detailed characterization of individual test sample lots is not required at MRL 2. Blood analog fluid properties are reported at the batch level in the FDA interlaboratory study documentation, providing adequate traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
