      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass published benchmark verification cases relevant to rotating machinery and viscous flow.",
      "rationale": "The solver was verified against the ASME V&V 20 lid-driven cavity and rotating channel benchmarks. Observed order of accuracy matched theoretical predictions within 5%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
