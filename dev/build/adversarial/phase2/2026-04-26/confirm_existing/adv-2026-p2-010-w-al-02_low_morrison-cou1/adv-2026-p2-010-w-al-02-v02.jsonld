      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI at the nominal operating point.",
      "rationale": "A three-level mesh refinement study (coarse 2.1M, medium 5.8M, fine 14.3M cells) yielded GCI of 2.3% for the normalized hemolysis index at 5 L/min, 3500 RPM. Richardson extrapolation confirmed asymptotic convergence. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match simulated boundary conditions within documented tolerances for flow rate and rotational speed.",
      "rationale": "FDA generic centrifugal pump experiments were conducted at flow rates of 2.5 and 5.0 L/min and rotational speeds of 2500 and 3500 RPM. Measured inlet/outlet pressures and temperatures were used directly as boundary conditions, with deviations less than 1.5%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) agrees with experimental measurements within 15% at all five operating points.",
      "rationale": "Predicted NIH values ranged from 0.0021 to 0.0078 mg/dL across the five operating points. Experimental measurements yielded 0.0023 to 0.0082 mg/dL. Maximum relative error was 11.4%, within the 15% acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (relative hemolysis index RH) is directly linked to the regulatory acceptance criterion and the clinical endpoint of interest.",
      "rationale": "The relative hemolysis index RH is computed from NIH predictions at test and predicate device conditions. This quantity directly maps to the regulatory submission criterion (RH < 1) and is the primary clinical safety indicator for CPB hemolysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
