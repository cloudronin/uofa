  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-regulatory-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors retained as not-assessed in accordance with MRL 2 scoping guidance. Uncertainty quantification via comprehensive Monte Carlo across all inputs demonstrates RH remains below 1.0 across the full input distribution with 95th-percentile RH of 0.87. Validation evidence is directly relevant to the COU geometry and operating regime. The credibility assessment is judged sufficient to support the regulatory decision for this Class II CPB device.",
