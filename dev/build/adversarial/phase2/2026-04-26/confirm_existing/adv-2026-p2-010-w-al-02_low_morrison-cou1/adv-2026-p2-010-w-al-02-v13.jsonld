      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on at least three mesh levels yields discretization uncertainty < 5% on the hemolysis index QoI.",
      "rationale": "Three hexahedral mesh levels (1.8M, 5.4M, 14.2M cells) were evaluated. GCI on the relative hemolysis index yielded a fine-grid uncertainty of 3.1%, satisfying the < 5% criterion. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature) are documented and traceable to calibrated instrumentation with stated uncertainty.",
      "rationale": "FDA experimental dataset provides traceable boundary conditions at all 5 operating points. Flow rates measured with Coriolis meter (±0.5%), speed with optical tachometer (±10 RPM). Temperature maintained at 37 °C ± 0.5 °C. Conditions are fully documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index agrees with experimental measurements within combined simulation and experimental uncertainty bands at all 5 operating points.",
      "rationale": "Predicted RH values range from 0.72 to 0.94 across the 5 operating points. Experimental RH values fall within the 95% prediction interval at all points. Maximum normalised error is 8.2%, within combined uncertainty. Output comparison criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
