      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modelled QoI (relative hemolysis index) directly maps to the clinical acceptance criterion (RH < 1) used in the regulatory submission.",
      "rationale": "The relative hemolysis index is the primary QoI specified in the predicate comparison protocol and is directly used in the regulatory decision. No surrogate or proxy metric is employed. Relevance is confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
