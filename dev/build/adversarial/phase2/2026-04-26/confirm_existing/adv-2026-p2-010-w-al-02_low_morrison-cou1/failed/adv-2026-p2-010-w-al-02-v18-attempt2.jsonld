  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be verified under a documented QA plan with version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-compliant QA plan. Version control, regression test suite, and change-control records were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least one published benchmark with documented order-of-accuracy confirmation.",
      "rationale": "Taylor-Green vortex and lid-driven cavity benchmarks confirm second-order spatial accuracy. Results match published reference solutions within 0.5% for velocity fields."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary QoI (hemolysis index) with GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed on the FDA pump geometry. GCI for the normalized index of hemolysis was 3.2%, confirming adequate spatial resolution at the production mesh of 4.8 million cells."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match the simulated operating envelope within stated tolerances.",
      "rationale": "FDA pump bench tests were conducted at flow rates of 2.5, 3.5, and 5.0 L/min and rotational speeds of 2000, 2500, and 3500 RPM, bracketing all five COU operating points. Temperature and fluid viscosity were controlled within ±2% of simulation inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all validation operating points.",
      "rationale": "Predicted normalized index of hemolysis values agreed with experimental measurements within 9.4% (mean absolute relative error) across all 15 validation operating points, satisfying the 15% acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled QoI (normalized index of hemolysis) must be directly mappable to the regulatory acceptance criterion (RH < 1).",
      "rationale": "The normalized index of hemolysis is the standard QoI for CFD-based hemolysis assessment per ASTM F1841. Its relationship to the relative hemolysis index is well-established and directly supports the RH < 1 acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions must be sufficiently similar to the COU device and conditions.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump, which shares the same impeller topology and hydraulic design intent as the COU device. Blood analog fluid (glycerol-water, matched viscosity) was used in both validation experiments and COU simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when discretization error is separately assessed.",
      "rationale": "At MRL 2, explicit characterization of iterative solver error beyond residual convergence monitoring is not required. Residuals converged to 1e-5 for all equations; this is documented but not formally assessed as a separate factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU.",
      "rationale": "Use error assessment is not required at MRL 2 for a Class II device with medium model influence. Standard operating procedures and analyst training records are maintained but not formally scored."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when output comparison is satisfactory.",
      "rationale": "Formal model form uncertainty quantification (e.g., Bayesian model averaging across turbulence closures) is not required at MRL 2. The k-omega SST turbulence model was selected based on prior literature for rotating blood-contacting devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameter distributions must be documented and propagated through the model; 95th-percentile output bounds must be reported.",
      "rationale": "Distributions for 13 geometric and operating input parameters were characterized from manufacturing tolerances and clinical use data. A comprehensive Monte Carlo uncertainty quantification study (n=2000 samples) was executed, yielding 95th-percentile hemolysis index bounds that remain below the RH < 1 threshold. All input distributions and raw sample outputs are archived in the supporting dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this device class.",
      "rationale": "Formal statistical characterization of test sample variability is not required at MRL 2. Three nominally identical pump units were used in validation testing; unit-to-unit variability was within measurement uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when test conditions factor is assessed.",
      "rationale": "Formal equivalency mapping between validation and COU input parameters is not required at MRL 2. Qualitative equivalency was confirmed as part of the test conditions and relevance factors above."
    }
  ],
