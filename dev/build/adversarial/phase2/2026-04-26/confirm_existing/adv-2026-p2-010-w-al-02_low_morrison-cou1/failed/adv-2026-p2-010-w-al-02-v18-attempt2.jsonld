  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "hasUncertaintyQuantification": true,
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-mrl2",
