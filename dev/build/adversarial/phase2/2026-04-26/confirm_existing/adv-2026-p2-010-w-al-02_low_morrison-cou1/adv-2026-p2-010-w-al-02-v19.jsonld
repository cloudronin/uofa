      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on the production mesh.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 5.8M, 14.2M cells). GCI for the relative hemolysis index was 3.2% between medium and fine meshes. Production mesh selected at 5.8M cells as optimal balance of accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions replicated in CFD boundary conditions within stated tolerances; flow rates and rotational speeds match COU operating envelope.",
      "rationale": "Experimental conditions from the FDA generic centrifugal pump dataset replicated in CFD: flow rates 2.5–7.5 L/min, rotational speeds 2000–3500 RPM. Boundary condition values confirmed within ±2% of reported experimental values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index values agree with experimental measurements within ±15% across all 5 operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared against experimental measurements at all five flow-speed combinations. Maximum deviation was 11.4%; mean absolute error was 7.2%. All predictions fell within the ±15% acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to the clinical decision criterion and regulatory acceptance threshold.",
      "rationale": "The relative hemolysis index RH = NIH_device / NIH_predicate is the direct regulatory comparator. CFD outputs the scalar hemolysis power-law integral which maps one-to-one to RH. QoI relevance is high; no surrogate or indirect metric is used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
