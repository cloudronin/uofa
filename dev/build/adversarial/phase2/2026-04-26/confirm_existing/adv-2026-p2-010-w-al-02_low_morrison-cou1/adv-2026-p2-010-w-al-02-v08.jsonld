  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be a commercially validated code with documented version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 was used with documented version control, regression test suite, and institutional software quality procedures. Achieved level meets required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases.",
      "rationale": "Solver verified against standard CFD benchmark cases including lid-driven cavity and backward-facing step. Order-of-accuracy testing confirmed second-order spatial convergence consistent with code documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate discretization error below 5% for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study performed (3.2M, 8.7M, and 21.4M cells). Richardson extrapolation yielded a grid convergence index of 1.8% for the relative hemolysis index at the worst-case operating point, exceeding the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented and reproducible for CFD replication.",
      "rationale": "FDA generic pump experimental conditions are fully documented in the ASME V&V 40 companion dataset. Inlet flow rates, rotational speeds, and fluid properties were replicated in the CFD setup with documented boundary condition mapping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index must agree with experimental measurements within 15% across all five operating points.",
      "rationale": "CFD predictions of relative hemolysis index agreed with experimental measurements within 9.3% across all five flow-speed combinations. The acceptance criterion of RH < 1 was correctly predicted at all operating points. Comprehensive Monte Carlo UQ confirmed that 95th-percentile predictions remained below the acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must directly map to the clinical hemolysis endpoint used in the regulatory decision.",
      "rationale": "The relative hemolysis index is the primary QoI and maps directly to the ISO 10993-4 hemolysis endpoint. Secondary QoIs (shear stress distribution, exposure time) are mechanistically linked to the hemolysis power-law model used in the regulatory submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on a geometrically and operationally representative pump under CPB-relevant conditions.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry at flow rates and rotational speeds spanning the CPB operating envelope (3–7 L/min, 2000–3500 RPM). Fluid properties matched bovine blood analog used in FDA experimental dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver iterative convergence documented by residual monitoring only.",
      "rationale": "At MRL 2, full iterative solver error quantification is not required. Residuals were monitored to 1e-6 for all equations and mass imbalance remained below 0.01%. No further assessment required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst qualification documented.",
      "rationale": "Analyst qualifications and simulation setup review are documented in the project quality record. Formal use-error assessment is not required at MRL 2 for this factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; turbulence model selection documented with literature justification.",
      "rationale": "The SST k-omega turbulence model was selected based on published literature for rotating blood-contacting devices. Formal model form uncertainty assessment is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs must be documented with sources; aleatory uncertainty in blood viscosity and pump geometry must be characterized.",
      "rationale": "All 13 model inputs are documented with sources and nominal values. Aleatory uncertainty was characterized for blood viscosity (CV=8%), inlet flow rate (CV=3%), and rotational speed (CV=1.5%) based on clinical operating data. A comprehensive Monte Carlo analysis propagated these distributions through the hemolysis model across 2000 samples, producing a full output distribution for the relative hemolysis index. The 95th-percentile RH remained below 1.0 at all operating points, confirming the acceptance criterion is robust to input variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; experimental sample documentation reviewed.",
      "rationale": "The FDA generic pump experimental dataset provides triplicate measurements at each operating point. Formal test sample uncertainty analysis is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; parameter mapping between experimental and computational domains documented.",
      "rationale": "Boundary condition mapping between the experimental setup and CFD model is documented in the simulation plan. Formal equivalency assessment is not required at MRL 2."
    }
  ],
