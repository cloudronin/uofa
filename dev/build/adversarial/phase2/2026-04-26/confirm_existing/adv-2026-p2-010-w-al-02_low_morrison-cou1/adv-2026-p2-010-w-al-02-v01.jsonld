      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% normalized index of agreement across all validation operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values agree with experimental measurements within 11% across all five validation operating points. The acceptance criterion of 15% is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
