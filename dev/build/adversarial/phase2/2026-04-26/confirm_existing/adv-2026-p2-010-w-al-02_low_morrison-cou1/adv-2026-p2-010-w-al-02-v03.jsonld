  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Uncertainty in model inputs was characterized via comprehensive Monte Carlo sampling across all inputs, propagating variability in fluid viscosity, pump geometry tolerances, and inlet flow waveform parameters through the hemolysis model to yield 95th-percentile RH estimates.",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "hasUncertaintyQuantification": true,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-fda-pump-geometry-v1",
    "https://uofa.net/synth/data/morrison-cpb-flow-conditions-v1",
    "https://uofa.net/synth/data/morrison-hemolysis-experimental-v1"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-val-bench-hemolysis",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis validation against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against published FDA centrifugal pump experimental measurements at five operating points. Mean absolute error 8.3%, within acceptable tolerance for MRL 2."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-val-pressure-flow",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic validation",
      "description": "Simulated pump head-flow curves validated against in vitro measurements across the CPB operating envelope. R² = 0.97 across all five flow-speed combinations."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-val-uq-montecarlo",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty propagation study",
      "description": "A comprehensive Monte Carlo analysis was performed sampling across all model inputs including blood viscosity (±15%), geometric tolerances (±0.05 mm), and inlet waveform amplitude (±10%). Ten thousand model evaluations were executed. The 95th-percentile RH remained below 1.0 across all sampled conditions, confirming robustness of the acceptance criterion under input variability. No ranking or screening of input drivers by their contribution to output variance was performed as part of this analysis."
    }
  ],
