    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum FEA with elastic-plastic titanium alloy material model and frictional contact at screw-rod and screw-block interfaces. Model form justified by physics of static quasi-static loading. Required level 3.",
      "rationale": "Bilinear isotropic hardening material model for Ti-6Al-4V with frictional Coulomb contact (mu=0.2) at all interfaces. Geometric nonlinearity enabled for large-displacement bending. Model form consistent with ASTM F1717 quasi-static loading physics. Peer-reviewed literature supports continuum approach for pedicle screw constructs. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties from certified coupon testing of production Ti-6Al-4V bar stock. Geometric inputs from CMM measurements of as-tested constructs. Uncertainty in inputs quantified. Required level 3.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus from tensile coupon tests (n=5) on production bar stock. Screw and rod geometry from CMM measurements with ±0.01 mm precision. Block geometry per ASTM F1717 nominal dimensions confirmed by manufacturer drawings. Input uncertainty propagated via Monte Carlo (n=500). Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lots, tested across two independent laboratories. Sample traceability documented. Required level 3.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs from production lots tested: six at FDA OSEL laboratory and five at an independent contract laboratory. Lot traceability, certificate of conformance, and dimensional inspection records on file for all 11 samples. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate ASTM F1717 protocol including load rate, displacement rate, and environmental conditions. Multiple test configurations preferred. Required level 3.",
      "rationale": "Testing performed strictly per ASTM F1717 at a single compressive load angle and single displacement rate (5 mm/min). Environmental conditions (ambient temperature, dry) consistent across both laboratories. However, only one test condition (single load configuration) was evaluated; no variation in load angle or rate was explored. This limits achieved level to 2, below required level 3. This gap is noted and accepted given the standardized nature of ASTM F1717 and the regulatory precedent for this test method."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrably equivalent to physical test configuration for each of the 11 constructs. Required level 3.",
      "rationale": "Model geometry updated per CMM measurements for each tested construct. Material properties assigned from coupon test data associated with production lot. Block geometry and fixity conditions matched to laboratory fixture documentation. Equivalency verified by overlay of FEA deformed shape against digital image correlation data from two constructs. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric: percent difference <10% and E/uval <1.96 for all three QoIs across all 11 constructs. Required level 3.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm displacement) compared using both percent difference and validation metric E/uval incorporating combined experimental and simulation uncertainty. Maximum percent difference observed: 7.3% (yield force, construct 9). Maximum E/uval: 1.61. All 11 constructs and all three QoIs pass acceptance criteria. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly relevant to clinical failure modes (fatigue initiation, permanent deformation) and regulatory submission requirements. Required level 3.",
      "rationale": "Construct stiffness and yield force are mechanistically linked to pedicle screw fatigue life initiation and permanent deformation risk. Force at 40 mm displacement is an ASTM F1717 standard reporting metric used in regulatory submissions. All three QoIs are directly traceable to the intended use statement and decision consequence assessment. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the same screw design, material, and test standard as the COU. Validation population representative of intended use population. Required level 3.",
      "rationale": "Validation performed on the identical non-cannulated 7.5 mm pedicle screw design from production lots under ASTM F1717, which is the regulatory standard directly relevant to the COU. Two-laboratory design increases generalizability. The only limitation (single test condition) is addressed under the Test conditions factor. Overall validation activity relevance to COU is high. Achieved level 3."
