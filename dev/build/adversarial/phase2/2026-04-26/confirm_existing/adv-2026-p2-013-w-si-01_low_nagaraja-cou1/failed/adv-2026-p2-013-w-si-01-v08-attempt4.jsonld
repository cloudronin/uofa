    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All three QoIs satisfy E/uval < 1.96 and percent difference < 10% relative to experimental mean; statistical validation metric computed per ASME V&V 40 Section 9.",
      "rationale": "Stiffness: FEA 487 N/mm vs. experimental mean 501 N/mm (2.8% difference, E/uval=0.94). Yield force: FEA 1823 N vs. experimental mean 1856 N (1.8% difference, E/uval=0.71). Force at 40 mm: FEA 2104 N vs. experimental mean 2089 N (0.7% difference, E/uval=0.31). All three QoIs pass both acceptance criteria. Output comparison is satisfactory."
    },
    {
