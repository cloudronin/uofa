    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation workflow documented in a controlled procedure; independent reviewer checked boundary conditions, material assignments, and load application prior to result extraction.",
      "rationale": "A peer-review checklist was completed by a second analyst covering boundary condition setup, material property assignment, contact definitions, and QoI extraction scripts. No discrepancies identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum finite element representation of screw, rod, and polyaxial head with nonlinear frictional contact is physically justified and consistent with prior literature for metallic implant constructs.",
      "rationale": "Linear elastic titanium alloy (Ti-6Al-4V) material model is appropriate for the sub-yield regime; bilinear isotropic hardening used beyond yield. Polyaxial head modeled with frictional contact (mu=0.2) consistent with published tribological data. Model form uncertainty acknowledged and bounded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM-certified coupon tests on same material lot; geometry from calibrated CMM measurements of production screws.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and UTS (950 MPa) measured from six tensile coupons from the same Ti-6Al-4V bar stock. Screw geometry digitized via CMM to ±0.01 mm. Input uncertainty propagated via Monte Carlo (n=500) showing <3% effect on stiffness QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lots tested; dimensional inspection confirms samples are representative of the modeled geometry within ±5%.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from two production lots tested. CMM inspection of three representative samples confirmed outer diameter and thread pitch within 1.2% of nominal. Samples considered representative of the modeled geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing performed under at least two independent load configurations or angular offsets to span the COU loading envelope.",
      "rationale": "Testing performed only at the single ASTM F1717-prescribed 5-degree offset angle. A second load configuration was planned but not executed within the project timeline. This factor is below the required level and constitutes a known gap in the validation evidence; compensatory confidence is drawn from the multi-laboratory replication and tight inter-laboratory agreement (CV < 4%)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material, boundary conditions) demonstrably equivalent to experimental specimen and test fixture parameters within stated uncertainty bounds.",
      "rationale": "Fixture geometry modeled from engineering drawings of the ASTM F1717 test fixture used in both laboratories. Tightening torque of polyaxial set screw (4 Nm) applied as pretension in the model. Equivalency confirmed by sensitivity study showing <2% QoI change over ±10% torque variation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy <10% difference criterion and E/uval < 1.96 for each QoI.",
      "rationale": "Stiffness: 4.2% difference, E/uval=0.87. Yield force: 6.8% difference, E/uval=1.41. Force at 40 mm: 5.1% difference, E/uval=1.12. All three QoIs pass both acceptance criteria. Results consistent across both laboratories (inter-lab CV < 4%)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical failure modes and regulatory submission requirements for pedicle screw constructs.",
      "rationale": "ASTM F1717 QoIs are the regulatory standard for pedicle screw mechanical performance. Construct stiffness relates to load sharing with the spine; yield force and force at 40 mm displacement bound fatigue and fracture risk. Relevance to COU is direct and well-established in the literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
