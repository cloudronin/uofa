    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic model with isotropic hardening captures titanium alloy behavior; contact formulation at screw-rod interface validated against known analytical solutions.",
      "rationale": "Bilinear isotropic hardening plasticity (Ti-6Al-4V) selected based on published material characterization. Penalty contact with friction coefficient 0.2 applied at screw-rod interface. Model form consistent with prior FDA pedicle screw validation studies. Gradation 3 achieved."
    },
    {
