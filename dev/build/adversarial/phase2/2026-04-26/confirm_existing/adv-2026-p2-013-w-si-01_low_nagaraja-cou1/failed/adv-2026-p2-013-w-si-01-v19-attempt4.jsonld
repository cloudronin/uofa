    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic constitutive model with isotropic hardening validated against titanium alloy coupon data; contact formulation verified against published pedicle screw FEA literature.",
      "rationale": "The elastic-plastic constitutive model with isotropic hardening (Ti-6Al-4V) was calibrated against tensile coupon test data from the same material lot used for the constructs. Augmented Lagrange contact formulation with appropriate friction coefficient (mu=0.2) is consistent with published spinal implant FEA practice. Model form is appropriate for the quasi-static loading regime of ASTM F1717."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from coupon tests on same material lot; geometric dimensions from CMM measurements of test articles; uncertainty in inputs propagated via Monte Carlo (N=500).",
      "rationale": "Elastic modulus (E=114 GPa), yield strength (880 MPa), and tangent modulus were derived from uniaxial tensile tests on specimens from the same Ti-6Al-4V bar stock. Screw and rod geometry was measured by CMM with dimensional tolerances applied as input uncertainty. Monte Carlo propagation (N=500 samples) confirmed QoI sensitivity to input variability is within acceptance bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lot; dimensional inspection confirms conformance to drawing; samples span two independent laboratories.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production-lot components. CMM inspection confirmed all components were within drawing tolerances. Six constructs were tested at Laboratory A (FDA) and five at Laboratory B (DePuy Synthes), providing inter-laboratory variability data. Sample size is adequate for the statistical comparison method employed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions should span the range of intended use conditions including at least two load levels and two construct configurations.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending configuration at a single load application angle. While the test protocol is standardized, only one test condition was evaluated, which does not span the intended use space. This factor is assessed below the required level; the shortfall is acknowledged and accepted given that F1717 is the regulatory standard for this device class and the single condition is the most clinically relevant."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrably equivalent to experimental test article parameters within stated tolerances.",
      "rationale": "Geometric inputs to the FEA model were derived from CMM measurements of the actual test articles. Material properties were measured from the same material lot. Boundary conditions replicate the ASTM F1717 test fixture geometry, with fixture stiffness characterized and incorporated. Equivalency between simulation inputs and experimental conditions is confirmed within stated measurement uncertainties."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; E/uval < 1.96 for all QoIs; percent difference < 10% for all QoIs.",
      "rationale": "All three QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy both acceptance criteria: percent differences of 4.2%, 6.8%, and 5.1% respectively are each below 10%; E/uval values of 0.91, 1.44, and 1.12 are each below 1.96. The comparison methodology follows the ASME V&V 40 uncertainty-normalized error approach with experimental uncertainty estimated from inter-laboratory and inter-specimen variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to regulatory submission metrics and are mechanistically linked to clinical failure modes.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the primary outputs required by FDA guidance for pedicle screw submissions and are directly linked to the clinical failure mode of construct fatigue and screw fracture. These QoIs are identical to those reported in the experimental test report, ensuring direct comparability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, loading, and material are representative of the COU device and intended use conditions.",
      "rationale": "The validation activity uses the identical non-cannulated 7.5 mm pedicle screw design, the same ASTM F1717 test configuration, and the same Ti-6Al-4V material as the COU. The FEA model ensemble includes independent implementations by FDA, Ansys, and DePuy Synthes analysts, providing cross-verification. The validation scenario is highly representative of the COU and supports confidence in the FEA predictions for regulatory decision-making."
