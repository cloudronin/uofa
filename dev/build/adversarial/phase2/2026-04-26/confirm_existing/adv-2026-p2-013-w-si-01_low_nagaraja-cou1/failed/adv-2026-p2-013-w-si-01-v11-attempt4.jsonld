  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single below-required factor (Test conditions, achieved 2 vs. required 3) reflects the limitation of a single static load configuration per ASTM F1717; this is consistent with regulatory practice for Class II spinal implants and is accepted given that all quantitative acceptance criteria for the three primary QoIs are satisfied across two independent laboratories. The FEA modeling framework is assessed as sufficiently credible for its intended use in supporting the 510(k) submission for the non-cannulated pedicle screw design.",
