    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum finite-element representation with isotropic linear-elastic titanium alloy material model justified by literature; contact mechanics formulation appropriate for screw-rod interface.",
      "rationale": "The model uses a continuum FEA representation with isotropic linear-elastic material properties for Ti-6Al-4V, consistent with published spine implant simulation literature. Frictional contact at the screw-rod interface is modeled with an augmented Lagrange formulation. Model form is appropriate for the quasi-static compression-bending regime addressed by ASTM F1717."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports for the specific Ti-6Al-4V lot; geometric dimensions from CMM measurements of production hardware.",
      "rationale": "Elastic modulus (114 GPa) and yield strength (880 MPa) are taken from certified material test reports for the production Ti-6Al-4V lot. Screw and rod geometry are derived from CMM measurements of three production samples, with dimensional variability propagated via sensitivity analysis. Input uncertainty is quantified and within acceptable bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lots tested; samples span at least two independent lots; dimensional inspection confirms conformance to drawing.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs from two production lots were tested. Dimensional inspection confirmed all samples within drawing tolerances. Sample size supports the statistical acceptance criterion (E/uval < 1.96) at the required confidence level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two independent laboratories and two load levels to characterize condition sensitivity.",
      "rationale": "Testing was conducted at two independent laboratories, satisfying the inter-laboratory requirement. However, only a single load configuration (compression-bending at 10° per ASTM F1717) was evaluated. The absence of a second load condition results in an achieved level of Gradation 2, one below the required Gradation 3. This gap is accepted given that ASTM F1717 specifies a single standardized condition and the COU is restricted to that configuration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and material inputs match experimental setup to within documented tolerances; any discrepancies quantified and propagated.",
      "rationale": "Experimental boundary conditions (fixture geometry, load application point, constraint locations) are replicated in the FEA model using direct measurements from the test rigs at both laboratories. Discrepancies in fixture compliance are quantified and included in the validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all three QoIs; percentage difference <10% for each QoI.",
      "rationale": "For all three QoIs (stiffness, yield force, force at 40 mm), the validation metric E/uval is below 1.96 and percentage differences are below 10%. Stiffness: 4.2% difference, E/uval = 0.87. Yield force: 6.8% difference, E/uval = 1.31. Force at 40 mm: 5.1% difference, E/uval = 1.04. All acceptance criteria satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
