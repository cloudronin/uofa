  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed. Twelve of thirteen factors meet or exceed their required credibility levels. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted on the basis that dry ambient test conditions are conservative for Ti-6Al-4V metallic constructs and the shortfall does not materially affect the validity of the quantitative output comparison. The overall credibility evidence is sufficient to support regulatory submission of the non-cannulated 7.5 mm pedicle screw FEA modeling framework for ASTM F1717 compression-bending performance demonstration.",
