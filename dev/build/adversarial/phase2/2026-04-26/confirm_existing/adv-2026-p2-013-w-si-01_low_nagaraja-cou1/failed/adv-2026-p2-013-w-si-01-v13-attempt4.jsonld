      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates < 2% change in QoIs between medium and fine mesh densities.",
      "rationale": "A three-level mesh refinement study (coarse, medium, fine) was performed on the non-cannulated screw-rod construct. Stiffness and yield force QoIs changed by < 1.5% between the medium and fine meshes. The medium mesh was selected for production runs, yielding a discretization uncertainty estimate of < 2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals < 1e-6; load-step convergence confirmed at each increment.",
      "rationale": "Newton-Raphson nonlinear solver residuals were monitored at each load increment. Force and displacement residuals converged below 1e-6 at all increments. No unconverged steps were observed across the 11-construct ensemble."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent model review by second analyst; documented simulation plan reviewed prior to execution.",
      "rationale": "A documented simulation plan was prepared and reviewed by a second qualified analyst before execution. Boundary conditions, material assignments, and contact definitions were independently verified. No use errors were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum solid elements with elastic-plastic titanium alloy material law; contact between screw, rod, and set screw modeled explicitly.",
      "rationale": "The model employs continuum solid elements with a bilinear elastic-plastic constitutive law for Ti-6Al-4V. Frictional contact (mu=0.2) is defined at all screw-rod and set-screw interfaces. This model form has been validated in prior pedicle screw studies and is appropriate for capturing construct stiffness and yield behavior."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing of the same Ti-6Al-4V lot; geometric dimensions from CMM measurements of production screws.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus were measured from tensile coupons machined from the same Ti-6Al-4V bar stock as the test screws. Screw and rod geometry was characterized by coordinate measuring machine. Input uncertainty was propagated via Monte Carlo sampling (n=500) to establish model input uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 production non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories.",
      "rationale": "Eleven production-representative constructs were assembled and tested at two independent laboratories (FDA/CDRH and DePuy Synthes internal). Sample size exceeds the minimum recommended for statistical comparison. Constructs were assembled by trained operators following the device IFU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate the COU loading environment; multiple load configurations required for level 3.",
      "rationale": "Testing was conducted under ASTM F1717 static compression-bending protocol only. A single test condition (5-degree offset compression) was used, which does not fully span the in vivo loading space. This limits the achieved level to 2, one below the required level of 3. This shortfall is acknowledged and accepted given that compression-bending is the primary failure mode for pedicle screw constructs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) traceable to the physical test specimens used for validation.",
      "rationale": "FEA geometry was updated to match CMM-measured dimensions of the actual test constructs. Material properties were sourced from the same lot. Boundary conditions replicate the ASTM F1717 fixture constraints. Traceability documentation links each FEA run to the corresponding physical specimen."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using percent difference < 10% and E/uval metric < 1.96 for all three QoIs.",
      "rationale": "Percent differences between FEA ensemble mean and experimental mean were 4.2% (stiffness), 6.8% (yield force), and 5.1% (force at 40 mm), all within the 10% acceptance bound. E/uval values were 0.83, 1.41, and 1.12 respectively, all below the 1.96 threshold. Quantitative credibility is established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to clinical performance criteria for pedicle screw constructs.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and are directly relevant to the clinical performance of the pedicle screw system. These QoIs are used in the regulatory submission as performance benchmarks."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities directly replicate the COU geometry, loading, and performance metrics.",
      "rationale": "The validation activity uses the same non-cannulated 7.5 mm pedicle screw design, the same ASTM F1717 test configuration, and the same QoIs as the COU. The validation is therefore directly applicable to the intended regulatory use of the model."
