    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate ASTM F1717 protocol; multiple load levels or configurations would be required for level 3.",
      "rationale": "Testing was performed strictly per ASTM F1717 at a single compression-bending load configuration. While the protocol is well-controlled and reproducible across both laboratories, only one test condition was evaluated. This limits the achieved level to 2, one below the required level of 3. This gap is accepted given the standardized nature of F1717 and the corroborating multi-lab data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs (geometry, material, boundary conditions) are demonstrably equivalent to the physical test configuration; any deviations are quantified.",
      "rationale": "FEA boundary conditions replicate the F1717 fixture geometry, including the 44 mm intervertebral distance and load application point. Material properties are matched to the tested lot. Torque preload on the set screw is represented via an equivalent contact pressure. Equivalency is confirmed by pre-test model predictions within 5% of mean experimental stiffness. Required level 3 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy <10% mean difference and E/uval < 1.96 for all three modeling environments.",
      "rationale": "Across all three FEA environments and all three QoIs, the maximum mean percentage difference is 7.3% (force at 40 mm, FDA model) and the maximum E/uval ratio is 1.61 (yield force, Ansys model). All comparisons satisfy the pre-established acceptance bounds. Required level 3 is met."
    },
