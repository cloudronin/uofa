    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6; energy balance checked at each load step.",
      "rationale": "Sparse direct solver employed for linear static steps; iterative solver residuals monitored and confirmed below 1e-8 for all load increments. Energy balance error less than 0.05% across all 11 construct simulations. No divergence or ill-conditioning warnings observed. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by second analyst; documented simulation protocol followed.",
      "rationale": "Simulation setup reviewed by a second qualified FEA analyst not involved in original model construction. Boundary conditions, material assignments, and contact definitions verified against the documented simulation protocol. No discrepancies identified. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear-elastic model with frictional contact demonstrated appropriate for quasi-static metallic implant compression-bending; physics assumptions documented and justified.",
      "rationale": "Titanium alloy (Ti-6Al-4V) pedicle screw and UHMWPE block modeled with isotropic linear elasticity, appropriate for sub-yield quasi-static loading. Frictional contact (mu=0.2) between screw and block surfaces. Large-displacement formulation activated to capture geometric nonlinearity at 40 mm displacement. Model form consistent with published FDA and industry FEA practice for ASTM F1717. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing of same lot material; geometric inputs from CMM measurements of test articles.",
      "rationale": "Elastic modulus and Poisson's ratio for Ti-6Al-4V obtained from tensile coupon tests on material from the same production lot as the test constructs (E=114 GPa, nu=0.34). UHMWPE block properties from supplier datasheet confirmed by DMA. Screw geometry from CMM measurements with ±0.01 mm tolerance. Sensitivity analysis on ±5% material property variation showed <1.5% QoI change. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production-representative lots tested across at least two independent laboratories.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested: 6 at Laboratory 1 (FDA CDRH) and 5 at Laboratory 2 (DePuy Synthes). All constructs assembled from production-representative components. Inter-laboratory variability in stiffness within 4.2% CV, confirming test reproducibility. Sample size sufficient for statistical comparison per ASME V&V 40 guidance. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading rates and block configurations; minimum two test configurations evaluated.",
      "rationale": "Testing conducted under a single ASTM F1717 standard condition (quasi-static, 5 mm/min displacement rate, standard UHMWPE block geometry). Variation in loading rate or block density not explored. This represents a single test condition, falling below the required level of 3. Risk accepted given that ASTM F1717 is the regulatory standard and clinical loading is quasi-static. Achieved level (2) is below required level (3); this is the one factor below requirement noted in the COU description."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material properties, boundary conditions) demonstrably equivalent to as-tested experimental conditions.",
      "rationale": "FEA model geometry updated to match CMM measurements of each tested construct. Boundary conditions replicate ASTM F1717 fixture constraints (fixed inferior block, axial-compressive displacement applied at superior fixture). Material properties matched to lot-specific coupon data. Fixture compliance measured and incorporated as spring boundary condition. Equivalency confirmed by pre-test blind prediction exercise. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric with threshold <1.96; percent difference in mean QoI values <10%.",
      "rationale": "Three QoIs compared: construct stiffness, yield force, and force at 40 mm displacement. E/uval values: stiffness 0.84, yield force 1.12, force@40mm 0.97 — all below 1.96 threshold. Percent differences in mean: stiffness 3.1%, yield force 5.8%, force@40mm 4.4% — all below 10% acceptance criterion. Validation uncertainty (uval) computed per ASME V&V 20 incorporating experimental measurement uncertainty and model parameter uncertainty. All three QoIs pass acceptance criteria. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to regulatory submission metrics and are mechanistically linked to clinical failure modes.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and required in FDA 510(k) submissions for spinal implants. Yield force is mechanistically linked to permanent deformation risk; force at 40 mm displacement is linked to catastrophic failure. These QoIs are directly relevant to the COU decision on construct mechanical performance. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities replicate COU geometry, loading, and material system; validation domain encompasses COU domain.",
      "rationale": "Validation activities performed on the exact non-cannulated 7.5 mm pedicle screw geometry and material system constituting the COU. ASTM F1717 loading replicates the biomechanical worst-case compression-bending scenario for the lumbar spine application. The COU domain (single screw size, single material, quasi-static loading) is fully encompassed by the validation domain. No extrapolation beyond validated conditions required for the regulatory submission decision. Achieved level meets required level."
    }
