    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics assumptions justified for metallic implant components; contact formulation appropriate for screw-rod interface; geometric nonlinearity included.",
      "rationale": "Titanium alloy screw and cobalt-chrome rod are modeled as elastic-plastic continua with isotropic hardening, consistent with published material characterization data. Frictional contact (mu=0.2) at the screw-rod interface is physically justified. Geometric nonlinearity (large displacement) is activated to capture post-yield behavior at 40 mm displacement. Model form is appropriate for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon tests or certified material datasheets; geometric inputs from CMM measurements of test specimens.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus for Ti-6Al-4V and CoCrMo rod were taken from lot-specific tensile coupon tests performed by DePuy Synthes. Screw and rod geometry was verified against CMM measurements of the actual test specimens. Input uncertainty was propagated using a Monte Carlo approach with N=1000 samples."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
