    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum FEA with nonlinear geometry, elastic-plastic titanium alloy material model, and frictional contact at screw-rod and screw-block interfaces; model form justified by prior literature and sensitivity analysis.",
      "rationale": "The model uses large-displacement nonlinear FEA with a bilinear isotropic hardening model for Ti-6Al-4V (E=114 GPa, σ_y=880 MPa, tangent modulus=1.14 GPa). Frictional contact (μ=0.2) is applied at all metal interfaces. Model form is consistent with published pedicle screw FEA literature and was confirmed adequate by a sensitivity study varying friction coefficient ±50%. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM F136 certified mill certificates for each test lot; geometric dimensions from CMM measurements of production hardware; uncertainty in inputs propagated to QoI uncertainty bounds.",
      "rationale": "Ti-6Al-4V material properties were obtained from certified mill test reports for the production lot used in bench testing. Screw and rod geometry was verified by CMM measurements (n=5 per component type). Input uncertainty was propagated using a one-at-a-time sensitivity study; combined input uncertainty contribution to QoI was <4%. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lot; sample representativeness confirmed by dimensional inspection; tested across two independent laboratories to assess inter-laboratory variability.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from a single production lot and tested across two independent laboratories (n=6 lab 1, n=5 lab 2). Dimensional inspection confirmed all constructs within drawing tolerances. Inter-laboratory coefficient of variation for stiffness was 3.8%, confirming adequate sample representativeness. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading configurations; at minimum two distinct angular offsets or load levels tested.",
      "rationale": "Testing was conducted at a single ASTM F1717-specified angular offset (5°) and a single crosshead displacement rate (5 mm/min). While this fully satisfies the ASTM standard, only one test condition was employed. The required credibility level of 3 calls for multiple test conditions to bound the validation domain; this factor is assessed below the required level and is documented as a known gap. This is the sole factor below the required level for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions, loading) demonstrably equivalent to experimental test conditions; traceability documented.",
      "rationale": "A parameter-by-parameter traceability matrix was prepared mapping each FEA input to its experimental counterpart. Geometry was taken from CMM data of the tested hardware. Boundary conditions replicate the F1717 fixture constraints. Loading replicates the 5° angular offset and displacement-controlled protocol. Full equivalency was confirmed by the independent analyst review. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval <1.96 for all three QoIs; percent difference <10%; visual force-displacement curve overlay provided.",
      "rationale": "All three QoIs satisfy the pre-established acceptance criteria: stiffness E/uval=1.41 (6.3% difference), yield force E/uval=1.67 (8.1% difference), force at 40 mm E/uval=1.22 (5.8% difference). Force-displacement curves from all 11 experimental constructs and the FEA prediction are overlaid in the validation report. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) directly correspond to the regulatory submission quantities used to characterize construct mechanical performance under F1717.",
      "rationale": "The three QoIs are the standard outputs required by FDA guidance for pedicle screw construct submissions under ASTM F1717. They directly characterize the mechanical performance attributes relevant to the COU. No surrogate or indirect quantities are used. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
