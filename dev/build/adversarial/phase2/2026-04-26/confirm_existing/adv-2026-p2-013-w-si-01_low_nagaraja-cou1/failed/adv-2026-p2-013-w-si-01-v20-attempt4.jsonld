    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum isotropic linear-elastic model with frictional contact at screw-rod and screw-vertebral block interfaces; justified by published titanium alloy behavior at sub-yield loads.",
      "rationale": "Ti-6Al-4V ELI exhibits linear-elastic behavior below yield (~880 MPa); peak stresses in the model remain below 820 MPa at maximum applied displacement. Frictional contact (mu=0.3, augmented Lagrange) captures interface slip observed experimentally. Model form is well-established for this load regime; uncertainty quantified via sensitivity analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific tensile coupon tests; geometric dimensions from CMM measurements of test articles.",
      "rationale": "Elastic modulus (114 GPa ± 2.1%) and Poisson ratio (0.342 ± 0.8%) derived from tensile coupons cut from the same Ti-6Al-4V ELI bar stock as the test constructs. Screw and rod geometry digitized via CMM to ±0.005 mm. UHMWPE block modulus from compression testing of the same lot. Input uncertainty propagated via Monte Carlo (n=1000) contributing <3% to total QoI uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs assembled per ASTM F1717; samples span manufacturing variability from production lot.",
      "rationale": "Eleven constructs were assembled from a single production lot of 7.5 mm non-cannulated pedicle screws and 5.5 mm rods per ASTM F1717 Section 8. Sample-to-sample geometric variability characterized by CMM; coefficient of variation <1.2% for all critical dimensions. N=11 exceeds the minimum required for statistical comparison per ASME V&V 40 Table 1 at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing performed under at least two independent load configurations or displacement rates to characterize condition sensitivity.",
      "rationale": "Testing was performed under a single ASTM F1717 compression-bending configuration at 1 mm/min crosshead speed. A second load rate or axial compression condition was not included in this validation study. Achieved level 2 (single condition, two laboratories) does not meet required level 3. This shortfall is documented and accepted at the program level given the standardized nature of the F1717 protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, material, boundary conditions) demonstrably matched to physical test article parameters within stated tolerances.",
      "rationale": "Each of the 11 FEA model instances was individualized using CMM-measured geometry for that specific construct. Material properties assigned from lot-specific coupon data. Fixture compliance measured on both test machines and incorporated as spring boundary conditions. Equivalency confirmed by pre-test blind prediction protocol: simulation inputs locked before experimental data unblinding."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "E/uval < 1.96 and relative QoI difference < 10% for all three primary quantities of interest across N=11 constructs.",
      "rationale": "Across all 11 constructs: stiffness E/uval range 0.31–1.41 (mean 0.87); yield force E/uval range 0.22–1.63 (mean 0.94); force at 40 mm E/uval range 0.18–1.58 (mean 0.88). Maximum relative QoI difference 7.3%. All acceptance criteria satisfied. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness governs load sharing with the anterior column; yield force defines fatigue life initiation threshold; force at 40 mm displacement is the ASTM F1717 regulatory endpoint cited in 510(k) submissions. All three QoIs are traceable to the COU decision consequence (revision surgery risk) via the device risk model. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, loading, and material match the COU scenario; any differences are bounded by sensitivity analysis.",
      "rationale": "The validation scenario replicates the exact ASTM F1717 test configuration specified in the COU. The non-cannulated 7.5 mm screw geometry validated here is identical to the submission design. Differences between the validation scenario (in vitro bench) and clinical COU (in vivo loading) are addressed by the conservative nature of the F1717 protocol, which exceeds physiological compression-bending loads. Sensitivity analysis confirms QoI insensitivity to residual scenario differences. Required level 3 achieved."
    }
