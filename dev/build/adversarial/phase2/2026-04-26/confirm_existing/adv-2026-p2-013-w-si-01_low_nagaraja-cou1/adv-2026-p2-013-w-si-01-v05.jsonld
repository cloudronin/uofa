    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic material model with frictional contact is justified by published literature on pedicle screw mechanics; model form uncertainty quantified via comparison across three independently constructed FEA models.",
      "rationale": "Three independent FEA models (FDA, Ansys application team, DePuy Synthes) using the same geometry but different meshing strategies and contact formulations were compared. Inter-model QoI spread was within 4%, confirming that model-form uncertainty is bounded and the continuum elastoplastic assumption is appropriate for this loading regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (Ti-6Al-4V elastic modulus, yield strength, tangent modulus) sourced from coupon testing of the same material lot used in bench specimens; geometric dimensions measured via CMM on three production screws.",
      "rationale": "Tensile coupon tests (n=5) from the same Ti-6Al-4V bar stock provided elastic modulus 114.2 ± 1.8 GPa and yield strength 928 ± 12 MPa. CMM measurements of screw geometry confirmed nominal dimensions within ±0.05 mm. Input uncertainty is characterized and propagated through a one-at-a-time sensitivity study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 production screws from a single manufacturing lot tested; traceability of each specimen to lot number and dimensional inspection record maintained.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs from a single production lot were tested. Each specimen was dimensionally inspected prior to testing and assigned a unique identifier traceable to the manufacturing record. Sample size exceeds the minimum of 10 specified for this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two distinct loading configurations or environmental conditions relevant to the COU; inter-laboratory reproducibility demonstrated.",
      "rationale": "Testing was conducted at two independent laboratories (FDA CDRH and DePuy Synthes) under the same ASTM F1717 protocol, demonstrating inter-laboratory reproducibility. However, only a single loading configuration (static compression-bending at 5°) was evaluated. The required level 3 criterion for multiple loading configurations is not fully met; achieved level is 2. This shortfall is acknowledged and accepted given the specificity of the COU to the F1717 standard configuration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, material properties, boundary conditions, loading) are traceable to measured values from the tested specimens; no surrogate or assumed values used without justification.",
      "rationale": "Model inputs were set to measured values for each of the 11 test specimens where individual measurements were available. Boundary conditions replicate the ASTM F1717 fixture geometry as measured by the test laboratories. No uncharacterized surrogate values were introduced."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all three QoIs; percent difference between mean FEA prediction and mean experimental result < 10% for each QoI.",
      "rationale": "E/uval values were 0.84 (stiffness), 1.21 (yield force), and 1.07 (force at 40 mm), all below the 1.96 threshold. Percent differences were 3.2%, 5.7%, and 4.1% respectively. Both acceptance criteria are satisfied for all three quantities of interest."
    },
    {
