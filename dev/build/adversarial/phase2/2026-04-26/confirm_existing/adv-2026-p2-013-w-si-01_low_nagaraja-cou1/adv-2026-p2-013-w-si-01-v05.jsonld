    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by a second analyst not involved in original model construction; documented checklist covering boundary conditions, material assignments, and contact definitions.",
      "rationale": "A second FDA analyst independently reviewed the model setup against a 24-item checklist. Two minor annotation discrepancies were identified and corrected prior to final simulation runs. No substantive modeling errors were found."
