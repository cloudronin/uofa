  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors were assessed. Twelve factors met or exceeded required levels. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3 due to single-configuration testing; this is consistent with ASTM F1717 regulatory practice and is accepted given that the standard configuration is the sole basis for the regulatory decision. All three QoIs satisfied quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%) across all three independent modeling groups. The credibility assessment supports use of the FEA framework for the non-cannulated pedicle screw 510(k) submission.",
