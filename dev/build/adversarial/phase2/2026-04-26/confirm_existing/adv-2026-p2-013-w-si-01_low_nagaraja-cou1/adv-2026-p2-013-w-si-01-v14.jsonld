  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed their required credibility levels. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — was reviewed and accepted by the assessment team on the basis that ASTM F1717 is a standardized comparative test protocol for which single-condition testing is normative practice, and the regulatory decision does not require extrapolation beyond the tested condition. All three QoIs satisfy the pre-established quantitative acceptance bounds (<10% relative difference, E/uval < 1.96). The overall credibility evidence is judged sufficient to support a Medium assurance level for the non-cannulated 7.5 mm pedicle screw compression-bending COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
