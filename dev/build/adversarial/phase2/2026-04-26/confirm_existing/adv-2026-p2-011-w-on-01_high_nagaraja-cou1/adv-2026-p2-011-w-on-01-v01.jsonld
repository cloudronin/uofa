  "signature": "ed25519:b7d3a1f0e4c928b5d6e3a0f1c7b4d9e2a8f5c3b0d7e1a4f9c2b6d0e8a3f5c7b4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "All three FEA codes (FDA in-house, Ansys Mechanical, DePuy Synthes proprietary) operate under documented software quality management systems with version control, regression testing, and formal release procedures. Achieved level 3 reflects independent verification of solver outputs across platforms."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Benchmark problems with analytical solutions (Euler-Bernoulli beam bending, Hertzian contact) were solved by each code and results compared against closed-form solutions. Maximum deviation was 1.4%, well within the 5% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Systematic mesh convergence study performed on the pedicle screw shank and rod interface regions. Richardson extrapolation applied; grid convergence index (GCI) for peak von Mises stress was 2.1%, confirming discretization error is well controlled. Final mesh contains approximately 420,000 elements."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Newton-Raphson convergence tolerances set to 1e-6 for force and displacement residuals. Residual histories reviewed for all 11 simulation cases; no convergence anomalies detected. Iterative solver error estimated below 0.5% of peak reaction force."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Model setup, boundary condition application, and post-processing scripts were independently reviewed by a second analyst at each participating organization. Discrepancies identified during peer review were resolved and documented. Formal use-error checklist completed for each simulation run."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; model form adequacy is critical for structural credibility at medium risk.",
      "rationale": "Linear elastic material models applied to titanium alloy components (Ti-6Al-4V, E=114 GPa). Frictional contact (μ=0.2) modeled at screw-rod interface and set screw bearing surface. Model form is consistent with published literature for sub-yield ASTM F1717 loading regimes and has been validated in prior FDA studies."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; input fidelity is critical for structural response prediction.",
      "rationale": "Geometry derived from manufacturer-supplied CAD files with dimensional verification against physical specimens (CMM measurements, n=3 per lot). Material properties sourced from ASTM F136 certified mill reports. Set screw torque (4 Nm) matched to experimental protocol. Uncertainty in input parameters quantified and documented."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; sample representativeness is essential for validation credibility.",
      "rationale": "N=11 constructs tested across two independent laboratories using production-intent components from the same manufacturing lot. Sample size exceeds minimum recommended for statistical comparison. Dimensional inspection confirmed geometric conformance of all test articles to CAD nominal within ±0.05 mm."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; shortfall documented and accepted under risk-informed rationale.",
      "rationale": "Testing performed under a single load configuration (5° offset compression-bending per ASTM F1717). Although the standard specifies this as the primary test condition, no multi-angle or fatigue loading conditions were included in this validation activity. Achieved level 2 reflects the single-condition limitation. This shortfall is acknowledged and accepted given the regulatory submission scope is limited to static compression-bending performance."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; simulation and experimental inputs must be demonstrably equivalent.",
      "rationale": "Simulation boundary conditions (applied displacement rate 5 mm/min, fixture geometry, block separation distance 100 mm) mapped directly to experimental protocol parameters. Load frame compliance measured and incorporated. Pre-load from set screw torque applied identically in simulation and experiment. Parameter mapping table documented and reviewed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; quantitative comparison metrics must demonstrate acceptable agreement.",
      "rationale": "Quantities of interest (construct stiffness, peak load at 1% permanent deformation) compared using mean ± 95% CI across N=11 specimens. FEA ensemble predictions fall within experimental variability bands for all three codes. Normalized root mean square error (NRMSE) for stiffness: 4.8%; for peak load: 6.2%. Both within the pre-specified 10% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; quantities of interest must be directly relevant to the regulatory decision.",
      "rationale": "Construct stiffness and peak load at 1% permanent deformation are the primary mechanical performance endpoints specified in ASTM F1717 and referenced in FDA guidance for spinal fixation device submissions. These quantities directly inform the regulatory determination of structural adequacy for the intended clinical loading environment."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; validation activities must adequately represent the conditions of intended use.",
      "rationale": "The ASTM F1717 compression-bending protocol is the FDA-recognized consensus standard for evaluating spinal fixation construct mechanical performance. The validation geometry (non-cannulated 7.5 mm pedicle screw, standard rod, UHMWPE blocks) directly represents the device configuration and loading mode of the intended clinical use. Validation activities are therefore considered highly relevant to the submission COU for static structural performance assessment."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the non-cannulated pedicle screw F1717 compression-bending FEA ensemble is accepted at medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted under a risk-informed determination: the regulatory submission scope is explicitly limited to static compression-bending performance under the ASTM F1717 single-condition protocol, and the clinical risk associated with this limitation is judged acceptable for a Class II device with established predicate performance history. The FEA ensemble demonstrates consistent predictive capability across two independent laboratories and three independent modeling organizations, providing high confidence in the simulation results for the stated use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
