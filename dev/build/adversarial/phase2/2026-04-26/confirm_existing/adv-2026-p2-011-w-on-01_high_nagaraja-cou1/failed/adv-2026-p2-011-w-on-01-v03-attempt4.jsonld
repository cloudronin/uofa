      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver residual convergence criteria set to 1e-6 for force and displacement norms. Nonlinear contact iterations monitored; energy balance checked across all load steps. No spurious oscillations detected."
    },
