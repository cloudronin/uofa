  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated solver with documented QA procedures including regression test suites and release notes. FDA in-house scripts were version-controlled under Git with peer-reviewed commit history. Achieved level 3 satisfies required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmark results must reproduce published analytical solutions within 1% for relevant element types.",
      "rationale": "Ansys verification manual benchmarks for solid hex elements under bending and axial load reproduced analytical Euler-Bernoulli and Hertz contact solutions within 0.4%. DePuy Synthes independently verified contact formulation against published patch-test results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Global Richardson extrapolation GCI < 5% for quantities of interest; local mesh refinement study documented.",
      "rationale": "Three-level mesh refinement study performed on screw-rod interface region. GCI for construct stiffness was 2.1% and for peak von Mises stress 3.8%, both below the 5% threshold. Final mesh comprised approximately 420,000 second-order tetrahedral elements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force residual and displacement increment norms converge below solver tolerances; energy balance verified.",
      "rationale": "Nonlinear solution converged with force residual norm below 1e-4 and displacement norm below 1e-5 for all load steps. Energy balance check showed < 0.3% discrepancy. Direct sparse solver (PARDISO) used; no iterative solver divergence observed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented analyst training, simulation workflow checklist, and independent review of model setup.",
      "rationale": "All three modeling teams followed a pre-defined simulation protocol document. Independent cross-checks of boundary conditions, material assignments, and contact definitions were performed by a reviewer not involved in model construction. Discrepancies were resolved prior to result extraction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection justified by material characterization data; contact formulation appropriate for screw-rod interface.",
      "rationale": "Titanium alloy (Ti-6Al-4V) modeled as bilinear isotropic hardening; elastic modulus and yield stress sourced from coupon tensile tests on same material lot. Augmented Lagrangian contact with friction coefficient 0.3 validated against torque-to-turn measurements. Linear geometry assumed appropriate for pre-yield loading regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry dimensions, and boundary conditions traceable to measured data with uncertainty characterization.",
      "rationale": "Screw and rod geometry digitized from CMM measurements of production hardware (n=3 per component). Material properties from lot-specific tensile coupons (n=5). Boundary conditions replicated ASTM F1717 fixture geometry including UHMWPE block embedment depth. Uncertainty bounds on E (+/-2%) and yield stress (+/-3%) propagated via Latin Hypercube sampling."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental specimens traceable to same design and material lot as modeled hardware; sample size sufficient for statistical comparison.",
      "rationale": "N=11 constructs assembled from production hardware from the same manufacturing lot used for CMM digitization. Specimens distributed across two independent laboratories (FDA CDRH and DePuy Synthes test facility). Traceability records including lot numbers and assembly torque values documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate COU loading environment; multiple loading configurations assessed.",
      "rationale": "Testing performed under a single loading configuration (compression-bending at 5 degrees per ASTM F1717). While this configuration is clinically representative, only one test condition was evaluated, limiting confidence in model generalizability across the full COU loading envelope. This factor is below required level and represents a known gap accepted by the credibility assessment team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs demonstrably equivalent to experimental specimen parameters within stated uncertainty bounds.",
      "rationale": "CMM-measured geometry used directly as FEA geometry input. Material properties from same lot as experimental specimens. Assembly torque replicated in FEA via bolt pretension elements calibrated to measured clamp force. Equivalency confirmed by overlay of load-displacement curves in elastic regime prior to yield comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric or equivalent) applied; prediction within experimental variability band.",
      "rationale": "ASME V&V 20 validation comparison metric U_v computed for construct stiffness and yield load. FEA ensemble mean stiffness within 4.2% of experimental mean; all ensemble predictions within experimental 95% confidence interval. Yield load predictions within 6.1% of experimental mean. Validation metric indicates adequate agreement for medium assurance level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical performance indicators and regulatory submission requirements.",
      "rationale": "Construct stiffness and yield load are the primary mechanical performance indicators specified in ASTM F1717 and referenced in FDA guidance for posterior spinal fixation devices. These QoIs directly inform the structural adequacy claim relevant to Class II 510(k) submission. Stress distribution used as secondary QoI for fatigue life extrapolation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, loading, and boundary conditions sufficiently similar to COU to support credibility claim.",
      "rationale": "Validation activity directly replicates the ASTM F1717 test protocol that constitutes the regulatory performance benchmark for the COU. Hardware, loading mode, and boundary conditions in validation are identical to those described in the intended use scope. The validation scenario is therefore maximally relevant to the COU, with the sole limitation being the single loading angle noted under Test conditions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for model risk level 3 and medium assurance. The single below-required factor (Test conditions, achieved 2 vs. required 3) is accepted on the basis that the single ASTM F1717 compression-bending configuration is the definitive regulatory performance scenario for this device class, and the ensemble prediction accuracy across N=11 specimens at two laboratories provides sufficient confidence for the intended regulatory submission purpose. Overall credibility assessment outcome is Accepted.",
