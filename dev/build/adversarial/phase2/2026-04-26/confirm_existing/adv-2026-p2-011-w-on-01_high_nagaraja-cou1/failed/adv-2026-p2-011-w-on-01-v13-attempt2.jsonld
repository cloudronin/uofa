  "signature": "ed25519:b2e4f6a8c0d2e4f6a8b0c2d4e6f8a0b2c4d6e8f0a2b4c6d8e0f2a4b6c8d0e2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA solvers (FDA in-house, Ansys 2022 R2, DePuy Synthes proprietary) are operated under documented quality management systems with version control, regression test suites, and traceable release records. Achieved level 3 exceeds the required level 2 for this model risk category."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations through benchmark problems.",
      "rationale": "Each solver has been verified against NAFEMS benchmark problems and published analytical solutions for beam bending and contact mechanics. Patch tests and manufactured solution checks confirm correct numerical implementation at achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QOI change less than 5% between successive refinements.",
      "rationale": "Systematic mesh refinement study performed across three mesh densities (coarse, medium, fine) for each solver. Maximum QOI variation between medium and fine meshes was 2.8% for peak von Mises stress and 1.4% for construct stiffness. Richardson extrapolation applied to quantify residual discretization error."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver convergence criteria documented and residuals monitored to confirm solution stability.",
      "rationale": "Nonlinear static analyses converged with force and displacement residuals below 1e-4. Iterative solver settings documented in analysis plan. No spurious oscillations or divergence observed across the simulation ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence of independent review of model setup, boundary conditions, and material assignments.",
      "rationale": "Model setup independently reviewed by a second analyst at each participating organization. Boundary condition application, material property assignment, and contact definitions verified against the analysis plan prior to submission of results. No use errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions documented and justified relative to the physics governing ASTM F1717 compression-bending.",
      "rationale": "Linear elastic material model for UHMWPE blocks and titanium alloy screw justified by stress levels remaining below yield in the majority of constructs. Coulomb friction contact model selected based on published tribological data for titanium-on-polymer interfaces. Model form assumptions documented and peer-reviewed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs traceable to measurements on test specimens.",
      "rationale": "Screw geometry derived from coordinate measuring machine data on production implants. UHMWPE block elastic modulus measured by uniaxial compression testing of witness specimens from the same lot used in F1717 testing. Friction coefficient from pin-on-disk tribometry. All inputs traceable to calibrated instruments with documented uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of the simulated construct configuration.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs assembled from production implants by trained laboratory personnel following ASTM F1717 protocol. Screw lot traceability confirmed. Sample size sufficient to characterize construct-to-construct variability for stiffness and yield force QOIs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading states relevant to the intended use.",
      "rationale": "Testing performed at a single compression-bending load angle per ASTM F1717. The required level 3 demands at least two distinct loading conditions to bracket the clinical loading envelope; only one condition was evaluated, resulting in achieved level 2. This shortfall is acknowledged and documented as a limitation of the current validation campaign."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs must be demonstrably equivalent to experimental conditions within stated uncertainty bounds.",
      "rationale": "Applied load, displacement rate, fixture geometry, and UHMWPE block dimensions matched between simulation and experiment within measurement uncertainty. Equivalency confirmed by sensitivity analysis showing QOI variation less than 3% across the uncertainty range of each input parameter."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined a priori; simulation predictions within acceptance band.",
      "rationale": "Construct stiffness and yield force compared using the validation metric defined in the analysis plan. Simulation predictions from all three solvers fell within ±10% of the experimental mean for both QOIs across N=11 constructs. Inter-laboratory experimental variability (CV < 5%) confirms test reproducibility."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs must be directly linked to the regulatory decision and clinical performance endpoints.",
      "rationale": "Construct stiffness and yield force are the primary mechanical performance endpoints specified in ASTM F1717 and cited in FDA guidance for posterior spinal fixation devices. These QOIs directly inform the regulatory submission and are mechanistically linked to clinical fatigue and stability performance."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario must be sufficiently similar to the intended use scenario to support extrapolation of credibility.",
      "rationale": "The validation scenario replicates the ASTM F1717 bench test that serves as the regulatory surrogate for in vivo posterior lumbar fixation loading. Non-cannulated 7.5 mm screw geometry, UHMWPE block material, and loading configuration are identical to the device configuration described in the regulatory submission. Validation activities are judged directly relevant to the intended use."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-credibility-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for the non-cannulated F1717 compression-bending FEA model ensemble is accepted at Medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is accepted on the basis that the single F1717 load condition is the regulatory standard, and the margin of safety in all other factors provides sufficient confidence in the simulation predictions to support the regulatory decision. The intended use is limited to static compression-bending assessment of non-cannulated pedicle screw constructs as described in the bound requirement and claim documents.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
