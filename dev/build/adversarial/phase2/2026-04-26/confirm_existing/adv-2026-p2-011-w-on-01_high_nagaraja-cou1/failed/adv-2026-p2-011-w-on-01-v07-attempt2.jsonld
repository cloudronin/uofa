  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors for the non-cannulated 7.5 mm pedicle screw compression-bending FEA model ensemble. Twelve of thirteen factors meet or exceed the required credibility level for model risk level 3. The single deficient factor (Test conditions, achieved 1 vs required 2) is accepted under the Medium assurance level given the regulatory context, the conservative nature of the single-condition ASTM F1717 protocol, and the strong performance across all other factors. The ensemble approach across three independent FEA implementations provides additional confidence. Decision: Accepted for use in 510(k) regulatory submission supporting mechanical performance claims for lumbar spinal fixation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
