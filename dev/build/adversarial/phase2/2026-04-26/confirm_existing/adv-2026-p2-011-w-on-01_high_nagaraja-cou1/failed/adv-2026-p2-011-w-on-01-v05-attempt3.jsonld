  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software must be validated under an ISO 9001-compliant QMS with documented version control and regression testing.",
      "rationale": "Ansys Mechanical 2022 R2 is deployed under a DePuy Synthes ISO 13485-compliant QMS. Version control, regression test suite, and software validation reports are on file. Achieved level exceeds the required level for a Model Risk Level 3 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks against analytic solutions for linear elastic beam bending must demonstrate <1% error.",
      "rationale": "Patch test and Timoshenko beam benchmark cases confirm <0.5% error in linear elastic regime. Nonlinear contact verification performed against Hertzian contact solution. Required level met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate <5% change in peak von Mises stress and construct stiffness between successive refinements, with GCI < 0.05.",
      "rationale": "Three-level mesh refinement study performed on the screw-rod interface region. GCI = 0.031 for stiffness QOI and 0.044 for peak stress. Discretization error is within the required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residual must converge to <1e-6 for all load steps; nonlinear equilibrium iterations must achieve force residual <0.1%.",
      "rationale": "Direct sparse solver employed for linear steps; Newton-Raphson with line search for nonlinear contact. All residuals meet the specified convergence criteria across all 11 virtual specimen simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review of boundary condition setup, material assignment, and post-processing scripts by an independent analyst.",
      "rationale": "Simulation setup was independently reviewed by an FDA biomedical engineer not involved in model development. Boundary condition scripts are version-controlled and unit-tested. No use errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic isotropic material model is acceptable for titanium alloy under monotonic loading below yield; contact formulation must capture screw-rod interface slip.",
      "rationale": "Ti-6Al-4V is well characterized as linear elastic below yield under quasi-static monotonic loading. Augmented Lagrangian frictional contact (mu=0.2) captures interface behavior consistent with literature. Model form is appropriate for the ASTM F1717 static compression-bending scenario."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, nu, yield strength) sourced from ASTM-traceable coupon tests on the same material lot as test specimens; geometric inputs from CMM measurements.",
      "rationale": "Elastic modulus (114 GPa), Poisson ratio (0.34), and yield strength (880 MPa) sourced from lot-specific coupon tensile tests. Screw and rod geometry derived from CMM measurements of production hardware. Input uncertainty quantified via Monte Carlo sampling (CV<3%)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production lots with documented dimensional inspection; specimens must be representative of the cleared device configuration.",
      "rationale": "N=11 constructs assembled from production-lot hardware. All specimens dimensionally inspected by CMM prior to testing. Specimens are identical to the 510(k)-cleared device configuration. Sample size provides adequate statistical power for the comparison metrics."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading magnitudes and at least two independent laboratories must confirm reproducibility.",
      "rationale": "Testing was conducted at a single ASTM F1717-prescribed load level (compression-bending at 10 Nm moment arm) across two laboratories, confirming inter-laboratory reproducibility. However, only one load condition was evaluated; the range of clinically relevant loading magnitudes was not fully exercised. This factor is below the required level and is a documented limitation of the validation campaign."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material, boundary conditions) must be demonstrably equivalent to the physical test configuration within stated tolerances.",
      "rationale": "FEA boundary conditions replicate the ASTM F1717 fixture geometry and loading axis to within 0.5 mm and 0.5 degrees. Material properties are matched to lot-specific coupon data. Equivalency is formally documented in the simulation plan and verified by the independent reviewer."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Prediction interval of FEA ensemble must overlap experimental 95% confidence interval for construct stiffness and yield load; MAPE < 10%.",
      "rationale": "FEA ensemble mean stiffness: 187 N/mm (experimental: 183±12 N/mm). FEA ensemble yield load: 412 N (experimental: 405±18 N). MAPE = 3.8% for stiffness, 1.7% for yield load. All ensemble predictions fall within the experimental 95% CI. Output comparison criterion is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs (construct stiffness, yield load) must be directly linked to the regulatory submission performance criteria and the clinical risk of construct failure.",
      "rationale": "Construct stiffness and yield load under ASTM F1717 compression-bending are the primary performance endpoints in the 510(k) submission. These QOIs are directly linked to the risk of screw-rod construct failure under physiological spinal loading. Relevance is fully established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must target the same device configuration, loading mode, and performance endpoints as the intended regulatory use.",
      "rationale": "Validation activities are conducted on the production-configuration non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending, which is the exact loading mode and device configuration addressed in the regulatory submission. Relevance to the intended use is fully established within the prose description of this assessment."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a Model Risk Level 3 assessment. The single below-threshold factor (Test conditions, achieved=2 vs. required=3) is judged acceptable given that inter-laboratory reproducibility is confirmed and the single ASTM F1717 load condition is the sole regulatory performance endpoint. The FEA ensemble demonstrates MAPE below 4% for all primary QOIs. The overall credibility body is sufficient to support the 510(k) submission for the non-cannulated 7.5 mm pedicle screw construct under static compression-bending loading.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
