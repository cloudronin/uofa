    {
      "id": "https://uofa.net/nagaraja/validation/compression-bending-stiffness-comparison",
      "type": "ValidationResult",
      "name": "FEA vs experimental stiffness comparison across N=11 constructs, two laboratories, ASTM F1717 static compression-bending"
    },
    {
      "id": "https://uofa.net/nagaraja/validation/yield-load-comparison",
      "type": "ValidationResult",
      "name": "FEA vs experimental yield load comparison — posterior lumbar fusion construct, 7.5 mm non-cannulated pedicle screw"
    }
  ],
