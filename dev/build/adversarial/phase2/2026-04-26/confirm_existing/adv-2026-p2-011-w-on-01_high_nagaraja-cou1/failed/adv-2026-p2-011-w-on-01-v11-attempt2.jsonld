  "signature": "ed25519:9b2d4f6a1c8e3b7d0f5a2c9e4b1d6f3a8c5b0e7d2f9a4c1b6e3d8f5a0c7b2e9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) is verified under an ISO 9001-compliant QMS with documented release testing and version control.",
      "rationale": "DePuy Synthes and FDA simulation environments operate under documented software quality management systems. Ansys Mechanical release notes and regression test suite outputs are on file. Version 2022 R2 was used consistently across all simulation runs. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions demonstrate solver correctness for linear elastic beam bending and contact mechanics relevant to the pedicle screw construct.",
      "rationale": "Three NAFEMS benchmark cases (LE1, LE10, and a Hertzian contact patch test) were executed and results agreed with analytical solutions to within 0.5%. Code verification is deemed sufficient for the linear-elastic regime of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates that the quantity of interest (construct stiffness) changes by less than 2% between the production mesh and a refined mesh with 1.5x element density.",
      "rationale": "A structured mesh convergence study was performed across three refinement levels. Stiffness QOI varied by 1.3% between medium and fine mesh, and 0.7% between fine and extra-fine. The production mesh (medium) is accepted. GCI-based discretization error estimate is 1.8%, within acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge below 1e-6 for all load steps; energy balance error is below 0.1%.",
      "rationale": "Direct sparse solver (PARDISO) was used for all linear static analyses. Force and moment equilibrium residuals were below 1e-8 for all 11 model instances. No convergence warnings were recorded in any simulation log."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs and boundary conditions are reviewed by a second analyst; a documented checklist is used for each model instance.",
      "rationale": "Each of the 11 model configurations was independently reviewed by a second qualified analyst using a standardized 24-item checklist covering geometry, material assignment, boundary conditions, and load application. No use errors were identified post-review."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The chosen continuum mechanics model (linear elastic, small deformation) is appropriate for the pre-yield regime of the ASTM F1717 test; nonlinear geometry effects are assessed and shown to be negligible below yield.",
      "rationale": "Geometric nonlinearity was evaluated in a sensitivity study; maximum displacement at yield load was 4.2 mm, producing less than 0.9% difference in stiffness prediction versus linear analysis. Linear elastic model form is justified for the QOI (stiffness and yield load). Titanium alloy Ti-6Al-4V material model uses ASTM-reported elastic constants."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters are sourced from traceable measurements or certified material data sheets; sensitivity analysis identifies dominant inputs.",
      "rationale": "Elastic modulus (114 GPa) and yield strength (880 MPa) for Ti-6Al-4V are taken from certified mill certificates for the production lot. Geometric dimensions were measured via CMM on representative screws (n=3). One-at-a-time sensitivity analysis showed stiffness QOI is most sensitive to rod diameter (±3.2%) and screw-rod interface friction coefficient (±2.1%)."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples are production-representative components from the same manufacturing lot; sample size is sufficient to characterize inter-specimen variability.",
      "rationale": "All 11 constructs used production-representative pedicle screws and rods from a single manufacturing lot (Lot 2021-07-A). UHMWPE blocks were machined to ASTM F1717 specification. Inter-specimen variability in stiffness was 4.7% CV, consistent with published literature. Sample size supports characterization of mean response."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the clinically relevant range of loading configurations; at minimum two independent loading conditions are evaluated.",
      "rationale": "Only a single test condition (static compression-bending at 10 degrees) was evaluated, as specified by ASTM F1717. Torsion and anterior bending configurations were not included in this validation activity. This factor does not meet the required credibility level; the shortfall is acknowledged and documented as a limitation of the current validation scope."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs are matched to experimental conditions within stated tolerances; any discrepancies are quantified and their effect on QOI is bounded.",
      "rationale": "Boundary conditions in the FEA replicate the ASTM F1717 fixture kinematics. Applied load angle (10.0 ± 0.1 degrees) and crosshead displacement rate were matched. UHMWPE block geometry in the model was derived from CMM measurements of the actual test blocks. Friction at the block-fixture interface was matched to measured values (mu = 0.15 ± 0.02)."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QOIs (stiffness, yield load) agree with experimental mean values within 10% and lie within the experimental 95% confidence interval.",
      "rationale": "FEA ensemble mean stiffness prediction was 187.4 N/mm versus experimental mean of 183.9 N/mm (1.9% difference). Predicted yield load was 312 N versus experimental mean of 308 N (1.3% difference). All FEA predictions fell within the experimental 95% CI. Bland-Altman analysis confirmed no systematic bias across the 11 specimen pairs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QOIs (construct stiffness and yield load) are directly linked to the clinical performance endpoints and regulatory submission requirements for spinal fixation devices.",
      "rationale": "Construct stiffness and yield load under compression-bending are the primary mechanical performance endpoints required by FDA guidance for pedicle screw spinal systems under 21 CFR 888.3070. These QOIs are directly predictive of device performance in the intended surgical application and are the quantities compared in the regulatory submission."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario (ASTM F1717 compression-bending, non-cannulated 7.5 mm screw, UHMWPE block) is sufficiently representative of the intended use conditions to support model credibility for the regulatory submission.",
      "rationale": "The validation activity directly replicates the standardized test method (ASTM F1717) required for pre-market submission. The non-cannulated 7.5 mm screw configuration represents the highest-stiffness variant in the product family, providing a conservative validation anchor. Two independent laboratories provide geographic and equipment diversity, strengthening the relevance assessment."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-credibility-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for Model Risk Level 3. The single shortfall in Test conditions (achieved level 2 versus required level 3) is acknowledged; the assessment team judges that the ASTM F1717 compression-bending condition is the primary regulatory test scenario and that the shortfall does not invalidate the overall credibility determination for the intended submission use. The decision to accept is made with the understanding that torsion and anterior bending validation should be completed prior to expanding the model's use scope beyond static compression-bending prediction.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
