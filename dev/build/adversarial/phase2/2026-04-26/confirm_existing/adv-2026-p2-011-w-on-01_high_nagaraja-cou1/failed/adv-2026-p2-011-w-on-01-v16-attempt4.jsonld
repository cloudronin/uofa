  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk level.",
      "rationale": "The FEA software (Ansys Mechanical 2021 R2) is used under a validated installation with version control, regression test suite, and documented QA procedures conforming to 21 CFR Part 11. Achieved level 3 exceeds the required level 2 for model risk level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including patch tests and single-element tests for the hexahedral and tetrahedral element formulations used in the construct model have been executed and results compared against analytical solutions, confirming correct code implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "A systematic mesh convergence study was conducted across three refinement levels. The global discretization error in construct stiffness was estimated at less than 2% using Richardson extrapolation, satisfying the level 3 criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Direct sparse solver (SPARSE) used with double-precision arithmetic. Residual convergence criterion set to 1e-6 for all nonlinear iterations. Solver logs reviewed; no convergence warnings flagged across all 11 simulation cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup was independently reviewed by a second analyst. Boundary conditions, material assignments, and contact definitions were verified against the simulation plan. A formal peer review checklist was completed and archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic material models with geometry nonlinearity (large deformation) are used. The choice of model form is justified by the operating strain regime (below yield for most load steps) and corroborated by the literature. Sensitivity of QoIs to model form assumptions was quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (Ti-6Al-4V, UHMWPE block) were sourced from certified material test reports for the specific lot used in the F1717 experiments. Geometric inputs were derived from CMM measurements of the physical constructs. Uncertainty in inputs was propagated via one-at-a-time sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 physical constructs assembled from production-representative non-cannulated 7.5 mm pedicle screws. Sample size provides adequate statistical characterization of construct-to-construct variability. Constructs span two independent laboratories, reducing lab-specific bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing was conducted under a single quasi-static loading rate per ASTM F1717. While environmental conditions (temperature, humidity) were controlled and documented, only one loading condition was evaluated. This limits the achieved level to 2, below the required level of 3. This shortfall is acknowledged and accepted given the scope of the validation activity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions were matched to the experimental test fixture geometry and loading application points as confirmed by fixture drawings. Contact conditions at the screw-block interface were calibrated to replicate the measured pre-torque values applied during assembly."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantities of interest (construct stiffness and yield load) were compared using the area validation metric (AVM) and the U95 interval overlap approach. All FEA predictions fall within the experimental U95 confidence interval. Systematic bias was estimated at less than 5%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and yield load are the primary mechanical performance indicators specified in ASTM F1717 and are directly linked to the clinical performance requirements for pedicle screw constructs under compressive-bending loading in the lumbar spine, as described in the bound Requirement node."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The ASTM F1717 compression-bending test is the regulatory standard for spinal implant mechanical performance and directly represents the intended use loading scenario. The validation activity geometry, materials, and boundary conditions are representative of the clinical use case described in the bound Claim and Requirement nodes for non-cannulated 7.5 mm pedicle screw constructs."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is accepted because the validation scope is restricted to the quasi-static F1717 protocol and the regulatory submission does not claim predictive validity beyond this loading regime. The overall credibility evidence is sufficient to support a Medium assurance level decision for the FEA model ensemble predicting ASTM F1717 compression-bending performance of non-cannulated 7.5 mm pedicle screw constructs.",
