  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment outcome is Accepted. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for model risk level 3. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is accepted on the basis of regulatory precedent for ASTM F1717 as a standard single-condition submission test. The FEA ensemble demonstrates sufficient predictive accuracy (stiffness within 6.3%, yield load within 8.1% of experimental means) to support pre-market submission claims for the non-cannulated 7.5 mm pedicle screw construct under compression-bending loading.",
