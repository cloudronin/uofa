  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "All three FEA codes (FDA in-house, Ansys 19.2, DePuy Synthes implementation) operate under documented software quality plans including version control, regression testing, and configuration management consistent with ASME V&V 40 Gradation 2 requirements. Achieved Gradation 3 via additional inter-code cross-verification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including cantilever beam bending and contact patch tests were executed in all three codes. Results agreed with analytical solutions to within 0.5%, satisfying Gradation 2. Independent code-to-code comparison across three implementations elevated achievement to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 3 for model risk level 3.",
      "rationale": "Systematic mesh refinement study performed with three mesh densities (coarse, medium, fine) for the pedicle screw and rod subassembly. Richardson extrapolation applied; discretization error in peak von Mises stress estimated at less than 2.1%. Grid convergence index reported. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Newton-Raphson convergence tolerances set to force residual below 1e-4 and displacement residual below 1e-5. Solver logs reviewed for all 11 construct configurations. No unconverged increments detected. Gradation 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup procedures documented in a formal simulation plan reviewed by two independent analysts. Boundary condition application, material assignment, and contact definition were verified by peer review prior to execution. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 3 for model risk level 3.",
      "rationale": "Linear elastic material model selected based on sub-yield loading regime confirmed by experimental data. Contact modeled with penalty method; friction coefficient 0.3 based on published titanium-on-UHMWPE measurements. Simplifying assumptions documented and justified relative to the ASTM F1717 test configuration. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (Ti-6Al-4V elastic modulus, yield strength) sourced from ASTM F136 certificates of conformance for the tested lot. Geometric dimensions measured on three representative screws using CMM; mean values used with variability documented. Uncertainty in inputs propagated via sensitivity analysis. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 constructs tested across two independent laboratories using production-representative screws and rods from the same manufacturing lot. Sample traceability maintained. Inter-laboratory variability assessed; coefficient of variation in stiffness below 4%. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 3; this factor is below threshold.",
      "rationale": "Testing performed at a single compressive load level and single angular offset as specified in ASTM F1717. Variation across load levels or offset angles was not evaluated, limiting characterization of the response surface. This represents a known gap; achieved Gradation 2 against a required Gradation 3. Risk accepted by the credibility assessment team given the regulatory precedent for single-condition F1717 submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA model inputs (geometry, material properties, boundary conditions, loading) mapped directly to experimentally measured or controlled quantities. Discrepancies between nominal and measured dimensions documented and assessed for influence on QoI. Correspondence confirmed for all primary inputs. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and 2% offset yield load compared between FEA ensemble and N=11 experimental results. Mean FEA stiffness within 3.8% of experimental mean; yield load within 5.2%. Statistical comparison using t-test showed no significant difference (p>0.05). Validation metric (E_val) computed per ASME V&V 40 Appendix. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and yield load are the primary quantities of interest for demonstrating mechanical performance of spinal fixation constructs under ASTM F1717. These QoIs are directly linked to the clinical risk of implant loosening and fatigue failure. Relevance to the intended submission claim confirmed. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities replicate the ASTM F1717 test configuration used to characterize the non-cannulated 7.5 mm pedicle screw construct. The experimental protocol, loading mode, and boundary conditions are directly representative of the conditions under which the FEA model will be used to support the regulatory submission. Gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble demonstrates sufficient credibility at Medium assurance level for the intended use of predicting ASTM F1717 compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single sub-threshold factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) reflects a limitation of the ASTM F1717 protocol itself and is consistent with regulatory precedent. The assessment team accepts the residual risk associated with single-condition testing given the conservative nature of the F1717 loading scenario and the strong inter-laboratory agreement observed.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
