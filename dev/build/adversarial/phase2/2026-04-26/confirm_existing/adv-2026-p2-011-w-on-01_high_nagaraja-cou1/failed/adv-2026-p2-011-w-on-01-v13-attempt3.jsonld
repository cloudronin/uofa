  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment outcome is Accepted at Medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is accepted by the assessment team on the basis that the ASTM F1717 protocol is prescriptive for this regulatory submission context and the single test condition is fully representative of the intended regulatory use. The FEA ensemble approach across three independent modeling teams provides additional confidence in prediction robustness. Model risk level 3 is consistent with Medium assurance requirements per ASME V&V 40 Table 1.",
    "decidedAt": "2026-04-19T00:00:00Z"
