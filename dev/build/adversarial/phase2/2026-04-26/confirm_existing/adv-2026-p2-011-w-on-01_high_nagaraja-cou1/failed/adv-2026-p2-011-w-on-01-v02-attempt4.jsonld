  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted at Medium assurance level for Class II device regulatory submission support. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single deficient factor (Test conditions, achieved 2 vs. required 3) is accepted based on the conservative nature of the single-condition ASTM F1717 protocol, supported by an analytical sensitivity study demonstrating bounded response across physiologically plausible load variations. The FEA ensemble demonstrates consistent predictive capability with MAPE below 7% for all primary QOIs across N=11 experimental constructs at two independent laboratories.",
