  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for Medium model risk. The single below-required factor (Test conditions, achieved 2 vs. required 3) is acknowledged and accepted on the basis that the single ASTM F1717 compression-bending condition is the regulatory submission scope and no additional loading conditions are claimed. The FEA ensemble demonstrates mean stiffness prediction within 2.4% of experimental mean across N=11 specimens at two independent laboratories. Overall credibility is sufficient to support a Class II 510(k) submission for the non-cannulated 7.5 mm pedicle screw construct under compression-bending loading.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
