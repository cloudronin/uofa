      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code passes benchmark suite for linear elastic structural problems relevant to pedicle screw bending",
      "rationale": "Each ensemble solver demonstrated correct solution of NAFEMS benchmark LE1 and patch test for 3-D hexahedral elements. Results agree within 0.5% of analytical reference values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between successive refinements",
      "rationale": "Three-level mesh refinement study performed on representative screw-rod construct. Peak von Mises stress in screw shank changed by 1.3% between medium and fine meshes; stiffness QoI changed by 0.8%. Richardson extrapolation GCI < 3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence tolerance documented and shown adequate for QoI precision",
      "rationale": "Linear solver residual tolerance set to 1e-8; force residual checked against applied load. No iterative solver used for linear static analysis; direct sparse solver employed, eliminating iterative convergence concerns."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs reviewed by independent analyst; boundary condition application documented",
      "rationale": "Independent peer review of model inputs, boundary conditions, and material assignments conducted by FDA reviewer not involved in model construction. Checklist-based review completed with no critical discrepancies identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model and contact formulation appropriate for titanium alloy pedicle screw under quasi-static bending",
      "rationale": "Linear elastic isotropic model applied to Ti-6Al-4V components; material nonlinearity excluded as peak strains remain below yield. Frictional contact (mu=0.2) applied at screw-rod interface. Model form consistent with prior published validation studies for similar constructs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from traceable measurements or certified material data sheets",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and Poisson ratio (0.34) from ASTM B265 certified material test reports. Screw geometry digitized from micro-CT at 15 micron resolution. Polyaxial head locking torque from manufacturer specification sheet."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N >= 10 physical specimens tested; specimens representative of production hardware",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. Specimens drawn from production lot with certificate of conformance. Sample size sufficient for mean and variability characterization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing performed across at least two clinically relevant loading conditions or load levels",
      "rationale": "Only a single ASTM F1717-prescribed compression-bending load condition evaluated. Torsion, axial compression, and fatigue conditions not included in this validation activity. This factor is below the required level; acknowledged as limitation in overall credibility argument."
