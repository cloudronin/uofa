  "signature": "ed25519:b2d4e6a8c0f1e3d5b7a9c1e3f5d7b9a1c3e5f7d9b1a3c5e7f9d1b3a5c7e9f1d3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software must hold a current validated release with documented QA procedures and regression test suite covering spinal implant contact mechanics.",
      "rationale": "Ansys Mechanical 2022 R2 was used under a validated release qualification protocol. Vendor-supplied regression tests covering nonlinear contact and large-deformation elastoplasticity were executed without failures. Internal QA log v4.1 archived in PLM system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must reproduce analytical benchmark solutions for beam bending and Hertzian contact to within 1% relative error.",
      "rationale": "Cantilever beam and Hertzian sphere-on-flat benchmarks reproduced to 0.4% and 0.7% relative error respectively using the production mesh density. Code verification is considered sufficient for the linear elastic regime dominant in stiffness prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for construct stiffness QoI using Richardson extrapolation over at least three mesh refinements.",
      "rationale": "Three-level mesh refinement study (coarse 1.5 mm, medium 0.9 mm, fine 0.5 mm global element size at screw-rod interface) yielded GCI of 3.1% for stiffness and 4.2% for peak von Mises stress. Fine mesh adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual force norm must converge below 1e-4 relative tolerance for all nonlinear load steps; energy criterion must also be satisfied.",
      "rationale": "All 11 simulation instances converged within 1e-5 force residual and 1e-6 energy residual. No load-step bisections exceeded three levels. Solver logs archived and spot-checked by independent analyst."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented model setup checklist must be completed and independently reviewed for each simulation instance prior to submission.",
      "rationale": "A 47-item model setup checklist covering material assignment, boundary condition application, contact pair definitions, and load application was completed and peer-reviewed for each of the 11 simulation instances. No use errors were identified during review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model must capture nonlinear elastoplastic behaviour of titanium alloy Ti-6Al-4V and polymer test block material; contact formulation must represent screw-rod set-screw locking mechanics.",
      "rationale": "Bilinear isotropic hardening plasticity (E=114 GPa, sigma_y=880 MPa, E_tan=1.2 GPa) used for Ti-6Al-4V per ASTM B265 coupon data. UHMWPE test block modelled with neo-Hookean hyperelastic parameters fit to compression data. Augmented Lagrangian contact with friction mu=0.2 at all interfaces. Model form judged adequate for quasi-static stiffness and yield QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry dimensions, and boundary conditions must be traceable to measured or certified values with documented uncertainty bounds.",
      "rationale": "Screw geometry imported from certified CAD (GD&T tolerance ±0.05 mm). Material properties from lot-specific tensile coupons (n=5 per lot, CV<3%). UHMWPE block dimensions measured per ASTM F1717 setup. Boundary condition uncertainty (fixture compliance) characterised via compliance test and incorporated as ±2% stiffness adjustment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental sample set must include sufficient replicates (n≥5 per configuration) from production-representative hardware to characterise inter-unit variability.",
      "rationale": "N=11 constructs assembled from production-released hardware (lot-traceable) across two laboratories (Lab A n=6, Lab B n=5). Inter-laboratory coefficient of variation for stiffness was 4.3%, within acceptable range. Sample size sufficient for 80% power to detect 15% mean difference."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the clinically relevant range of compressive loads and bending angles, including at least two distinct loading configurations.",
      "rationale": "Testing was performed under a single ASTM F1717 compression-bending configuration (5° offset, 73.5 mm moment arm) only. Alternative loading angles and moment arm lengths representative of the full clinical use envelope were not evaluated. This factor falls below required level and represents a known gap acknowledged in the credibility assessment summary."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to experimental setup parameters within documented tolerances for all primary QoIs.",
      "rationale": "Geometric fidelity confirmed by 3D metrology scan of three representative constructs (max deviation 0.08 mm from CAD nominal). Applied displacement rate and fixture stiffness matched between simulation and experiment. Material lot properties used directly in corresponding simulation instances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoIs must be compared against experimental values using a quantitative metric (e.g., MAPE, prediction interval coverage) with statistical significance assessed.",
      "rationale": "Mean absolute percentage error for construct stiffness: 5.8% (n=11). Yield load MAPE: 9.3%. Prediction intervals (95%) contained 10 of 11 experimental stiffness observations. Wilcoxon signed-rank test showed no significant systematic bias (p=0.31). Comparison judged adequate for Medium model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from the simulation must directly correspond to the regulatory and clinical decision quantities specified in the device submission.",
      "rationale": "Construct stiffness (N/mm) and yield load (N) are the primary submission QoIs per FDA guidance on spinal implant 510(k) submissions. These quantities are directly extracted from simulation load-displacement curves using the same algorithmic definition as the experimental data reduction protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the same device configuration, loading mode, and material system as the intended regulatory submission use case.",
      "rationale": "Validation performed on identical production-released non-cannulated 7.5 mm pedicle screws under ASTM F1717 compression-bending, which is the exact test standard referenced in the 510(k) submission. Loading mode and construct geometry are directly representative of the posterior lumbar fixation clinical scenario described in the device labelling."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted at Medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is acknowledged; risk is mitigated by the conservative single-configuration loading representing a bounding case for construct stiffness. The FEA model ensemble is judged sufficiently credible to support the 510(k) submission for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 compression-bending. Decision is conditional on no post-market changes to screw geometry or material specification without re-assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
