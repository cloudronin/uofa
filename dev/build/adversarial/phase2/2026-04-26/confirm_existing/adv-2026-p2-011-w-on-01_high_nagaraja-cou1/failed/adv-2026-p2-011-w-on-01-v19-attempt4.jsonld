  "name": "Nagaraja COU1 — Non-cannulated pedicle screw compression-bending credibility assessment (Minimal Profile)",
  "description": "V&V 40 credibility assessment for FEA prediction of ASTM F1717 static compression-bending performance of a non-cannulated 7.5 mm pedicle screw construct used in posterior lumbar spinal fixation. The FEA model ensemble (FDA, Ansys, DePuy Synthes) is compared against N=11 experimental constructs across two independent laboratories under quasi-static axial compression-bending per ASTM F1717. All 13 V&V 40 credibility factors have been assessed; one factor (Test conditions) falls below required level due to a single test condition evaluated. Intended use is limited to adult patients undergoing single-level L4-L5 posterior fusion with non-cannulated 7.5 mm titanium pedicle screws; the model is not validated for dynamic fatigue, cannulated variants, or paediatric populations.",
  "bindsRequirement": "https://uofa.net/synth/req/nagaraja-f1717-compression-bending-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/nagaraja-fea-predicts-f1717-stiffness-and-yield",
  "bindsModel": "https://uofa.net/synth/model/nagaraja-pedicle-screw-fea-ensemble-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/nagaraja-f1717-lab1-n6-raw",
    "https://uofa.net/synth/data/nagaraja-f1717-lab2-n5-raw"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nagaraja-vr-stiffness-comparison",
      "type": "ValidationResult",
      "name": "Construct stiffness prediction vs. experimental mean — within 8% across both labs"
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-vr-yield-load-comparison",
      "type": "ValidationResult",
      "name": "Yield load prediction vs. experimental — within 12% at 95th percentile"
    }
  ],
