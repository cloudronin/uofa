  "signature": "ed25519:b1e2f3a4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and documented V&V test suite with traceability to release version.",
      "rationale": "Ansys Mechanical 2022 R2 is used under an ISO 9001-certified quality management system. Release notes, regression test logs, and version-control records were reviewed and found compliant. Achieved level exceeds required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must demonstrate solver accuracy within 1% for linear elastic beam bending.",
      "rationale": "Cantilever beam and Hertzian contact benchmark cases reproduced analytical solutions within 0.4%. Code verification is considered sufficient for the linear-elastic regime of the compression-bending simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 2% for construct stiffness QoI across three systematically refined meshes.",
      "rationale": "Three mesh refinements (coarse 1.5 mm, medium 0.9 mm, fine 0.5 mm global element size) yielded GCI of 1.3% for stiffness and 1.7% for yield force. Richardson extrapolation confirmed monotonic convergence. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms must drop below 1e-6 and energy balance error must remain below 0.1% across all load steps.",
      "rationale": "Iterative solver residuals converged to 1e-8 within 12 iterations per load step. Energy balance error remained below 0.05% throughout the loading history. No divergence or spurious oscillations were observed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review of boundary condition application and material assignment by an independent analyst.",
      "rationale": "Simulation workflow was peer-reviewed by an independent senior biomechanical engineer. Boundary conditions, contact definitions, and material assignments were verified against the ASTM F1717 protocol and device drawings. No use errors were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic isotropic constitutive model is appropriate for titanium alloy below yield; contact formulation must capture screw-rod interface slip.",
      "rationale": "Ti-6Al-4V is modeled as linear elastic isotropic (E=114 GPa, nu=0.34) consistent with sub-yield loading regime. Augmented Lagrangian frictional contact (mu=0.2) captures screw-rod interface behavior. Model form is consistent with published literature for this class of implant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM-certified coupon tests on production-lot Ti-6Al-4V; geometric dimensions from CMM measurements of tested specimens.",
      "rationale": "Elastic modulus and Poisson ratio derived from tensile coupon tests (n=5, same production lot). Screw and rod geometry digitized from CMM measurements of three representative specimens. Dimensional variability was within 0.05 mm of nominal CAD. Input uncertainty propagated via Monte Carlo (n=500) confirming stiffness sensitivity below 3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum N=10 specimens tested; specimens must be from production-representative lots with documented traceability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. All specimens traceable to production lots with certificate of conformance. Coefficient of variation for stiffness was 4.2%, indicating acceptable specimen-to-specimen consistency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the clinically relevant range of offset distances and loading rates; minimum two offset conditions required.",
      "rationale": "Testing was conducted at a single offset distance (50 mm) and a single quasi-static loading rate (5 mm/min) per ASTM F1717. Only one test condition was evaluated, which does not span the clinically relevant range of offset distances. This factor is below the required credibility level and represents a known gap in the validation evidence base."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be matched to experimental conditions within stated measurement uncertainty; any discrepancies must be documented and their effect on QoI quantified.",
      "rationale": "All model inputs (geometry, material properties, boundary conditions, loading rate) were matched to experimental values within measurement uncertainty. Fixture compliance was characterized and incorporated into the model. Residual discrepancies in grip stiffness were shown to affect predicted stiffness by less than 1.5% via sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E-metric or percent error) must be used; model predictions must fall within experimental mean ± 2 SD for primary QoIs.",
      "rationale": "E-metric and percent error relative to experimental mean were computed for construct stiffness and yield force. FEA predictions fell within experimental mean ± 1.8 SD for stiffness and ± 1.6 SD for yield force across all three model instances (FDA, Ansys, DePuy Synthes). Comparison satisfies acceptance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (construct stiffness, yield force) must be directly linked to the clinical performance requirements and regulatory submission endpoints.",
      "rationale": "Construct stiffness and yield force under compression-bending are the primary mechanical performance endpoints specified in ASTM F1717 and referenced in FDA guidance for spinal fixation systems. These QoIs are directly relevant to the intended regulatory decision context as described in the claim and requirement documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the geometry, material, loading mode, and boundary conditions representative of the intended clinical use population and surgical configuration.",
      "rationale": "Validation activities used the production-representative non-cannulated 7.5 mm screw geometry and Ti-6Al-4V material under ASTM F1717 compression-bending loading. However, only a single spinal level configuration and a single offset distance were tested. The clinical use population encompasses multiple spinal levels and a range of construct geometries, reducing the relevance of the validation activities to the full intended use scope. This factor is assessed below required level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for the non-cannulated 7.5 mm pedicle screw FEA model under ASTM F1717 compression-bending loading is accepted at Medium assurance level. Eleven of thirteen V&V 40 factors meet or exceed required credibility levels. Two factors (Test conditions and Relevance of validation activities to the COU) are below required level, both attributable to the single test condition evaluated. This gap is acknowledged and the assessment team determined that the breadth of model agreement across three independent model instances and two laboratories provides sufficient compensating evidence for the regulatory decision context described in the claim and requirement documentation. The model ensemble is accepted for use in the 510(k) submission for construct stiffness and yield force predictions under the loading conditions specified in ASTM F1717.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
