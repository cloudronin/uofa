      "name": "Construct stiffness prediction vs. experimental mean — within 8% across N=11 specimens at both laboratories"
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-yield-force-vr-002",
      "type": "ValidationResult",
      "name": "Yield force prediction vs. experimental mean — within 11% across N=11 specimens; single test condition noted as limitation"
    }
  ],
