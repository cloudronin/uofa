  "signature": "ed25519:b1c3e5a7d9f2b4c6e8a0d2f4b6c8e0a2d4f6b8c0e2a4d6f8b0c2e4a6d8f0b2c4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA codes (FDA in-house, Ansys Mechanical 2022 R2, DePuy Synthes internal solver) operate under documented SQA plans conforming to ISO 9001 and 21 CFR Part 820. Version-controlled source repositories, regression test suites, and release qualification records are on file."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems with analytical solutions (Euler-Bernoulli beam bending, Hertzian contact) were reproduced to within 0.5% relative error by each solver. Patch-test and single-element checks confirm element formulation correctness."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed across four refinement levels (coarse to very fine, 80k–640k elements). Richardson extrapolation yields a grid convergence index below 2% for peak von Mises stress at the screw-rod junction. Final mesh selected at the knee of the convergence curve."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Nonlinear Newton-Raphson iterations converge to residual norm below 1e-6 for all load steps. Direct sparse solver (PARDISO) used; iterative solver cross-checks performed on three representative cases with residuals agreeing to four significant figures."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation execution governed by a written standard operating procedure. Independent analyst re-ran two models from raw geometry; results agreed within 1.2%. Checklist-based review of boundary condition assignments and material property inputs completed prior to each run."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic isotropic titanium alloy (Ti-6Al-4V, E=114 GPa, nu=0.34) with frictional contact (mu=0.2) at screw-rod and screw-block interfaces. Model form validated against prior literature and confirmed appropriate for the quasi-static F1717 loading regime. Large-deformation (NLGEOM) option active throughout."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties sourced from ASTM F136 coupon tests on the same material heat lot as the physical constructs. Geometric dimensions digitised from CT scans of the actual test specimens (voxel size 0.1 mm). Torque preload on set screws measured and replicated in FEA via bolt-pretension elements."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 constructs (6 at Lab 1, 5 at Lab 2) drawn from a single production lot. Sample size determined by power analysis targeting 80% power to detect a 10% difference in construct stiffness. Dimensional inspection certificates provided for all specimens."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; shortfall documented and accepted under risk-informed rationale.",
      "rationale": "Testing performed at a single load offset (50 mm) per the standard ASTM F1717 protocol. Variation of offset distance or angulation was not explored. This limitation is acknowledged; the single condition is nonetheless representative of the worst-case clinical bending scenario defined in the device submission."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "One-to-one mapping documented between all experimental boundary conditions (grip fixtures, load application point, constraint degrees of freedom) and their FEA counterparts. Discrepancy table reviewed by two independent analysts and signed off."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantitative comparison via ASME V&V 20 validation metric (E_val). Mean FEA construct stiffness 487 N/mm vs. experimental mean 501 N/mm (2.8% relative error); all 11 individual FEA predictions fall within the experimental 95% confidence interval. Bland-Altman analysis shows no proportional bias."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantities of interest — construct stiffness (N/mm) and peak screw-rod interface stress (MPa) — are directly linked to the regulatory submission claim of structural adequacy under physiological compressive-bending loads. Clinical relevance confirmed by orthopaedic surgeon advisory review."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities replicate the intended-use loading mode (ASTM F1717 compression-bending) with the production-representative device. Geometry, material, assembly, and loading all correspond to the clinical deployment scenario for lumbar spinal fixation. Validation gap analysis complete."
    }
  ],
