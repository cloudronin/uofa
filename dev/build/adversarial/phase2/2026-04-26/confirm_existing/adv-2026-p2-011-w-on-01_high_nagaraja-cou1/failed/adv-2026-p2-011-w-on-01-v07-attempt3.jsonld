  "name": "Nagaraja COU1 — Non-cannulated pedicle screw compression-bending credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for FEA prediction of ASTM F1717 static compression-bending performance of a non-cannulated 7.5 mm pedicle screw construct. The FEA model ensemble (FDA, Ansys, DePuy Synthes) is compared against N=11 experimental constructs across two independent laboratories. Intended use is limited to static compression-bending loading per ASTM F1717 for Class II non-cannulated pedicle screw systems in the lumbar spine. All 13 V&V 40 factors assessed; one factor (Test conditions) achieved below required level due to single test condition. Decision: Accepted at Medium assurance level with documented compensating rationale.",
  "bindsRequirement": "https://uofa.net/synth/req/nagaraja-f1717-compression-bending-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/nagaraja-fea-predicts-f1717-compression-bending-performance",
  "bindsModel": "https://uofa.net/synth/model/nagaraja-pedicle-screw-fea-ensemble-v1",
  "bindsDataset": [
    "https://uofa.net/synth/data/nagaraja-f1717-experimental-n11-lab1",
    "https://uofa.net/synth/data/nagaraja-f1717-experimental-n11-lab2"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-001",
      "type": "ValidationResult",
      "name": "ASTM F1717 compression-bending FEA vs. experiment comparison — N=11 constructs, two laboratories"
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-002",
      "type": "ValidationResult",
      "name": "Sensitivity analysis of titanium alloy material parameters on predicted construct stiffness"
    }
  ],
