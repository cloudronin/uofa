  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) must be validated under an FDA-recognized quality management system with documented version control and regression testing.",
      "rationale": "Ansys Mechanical 2022 R2 is deployed under an ISO 9001-certified QMS with full regression test suite. Internal FDA simulation environment additionally subject to NIST SP 800-53 controls. Achieved level 3 exceeds required level 2 for medium model risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 must be reproduced within 1% of analytical solutions for linear elastic structural problems.",
      "rationale": "Ansys Mechanical passed all applicable ASME V&V 10.1 benchmark cases for linear elastic static structural analysis with maximum deviation of 0.4% from analytical reference solutions. Code verification documentation archived in FDA OSEL technical record TN-2023-047."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate less than 2% change in peak von Mises stress and construct stiffness between successive mesh refinements using Richardson extrapolation.",
      "rationale": "Three-level mesh refinement study performed on pedicle screw shank and rod-screw interface. Richardson extrapolation yielded GCI of 1.1% for construct stiffness and 1.8% for peak von Mises stress, both within the 2% acceptance threshold. Final mesh density: approximately 420,000 elements with C3D10 tetrahedral elements in critical regions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms must converge below 1e-6 for all load steps; energy balance error must remain below 0.1%.",
      "rationale": "All load steps converged with force residual norm below 1e-7. Energy balance monitored across all increments with maximum error of 0.04%. Sparse direct solver (PARDISO) used to eliminate iterative solver round-off accumulation for this linear static problem."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent peer review of model setup, boundary conditions, and post-processing scripts by a second qualified analyst.",
      "rationale": "Simulation protocol reviewed by two independent FDA analysts not involved in model construction. Boundary condition application and post-processing scripts independently replicated by DePuy Synthes engineering team. No discrepancies identified. Protocol version-controlled in FDA OSEL repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic isotropic constitutive model must be justified for titanium alloy (Ti-6Al-4V) under ASTM F1717 static loading conditions with strains below yield.",
      "rationale": "Maximum principal strain in all simulations remained below 0.4%, well within the linear elastic regime for Ti-6Al-4V (yield strain approximately 0.5%). Literature review confirms linear elastic model form is appropriate for this loading regime. UHMWPE block modeled as linear elastic with modulus calibrated from compressive coupon tests."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (elastic modulus, Poisson ratio) and geometric dimensions must be sourced from certified material certifications and CMM measurements of the actual test constructs.",
      "rationale": "Ti-6Al-4V material properties obtained from certified material test reports (ASTM E8 tensile testing) for each lot used in experimental constructs. Geometric dimensions verified by CMM measurements with tolerances within 0.01 mm. Friction coefficients at rod-screw interface characterized by dedicated tribology testing (mu = 0.12 ± 0.02)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 experimental constructs from production lots with documented dimensional inspection and material certification, tested across at least two independent laboratories.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs assembled from production lots with full dimensional inspection and material certification. Constructs allocated across two independent test laboratories (FDA OSEL biomechanics lab and DePuy Synthes R&D lab) to assess inter-laboratory variability. Coefficient of variation for experimental stiffness: 4.2%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must encompass the full range of clinically relevant loading magnitudes and configurations specified in ASTM F1717, including at minimum two distinct load levels and two construct configurations.",
      "rationale": "Testing performed at a single ASTM F1717-specified load configuration (5 mm rod, 35 mm vertebral body height surrogate) and single load magnitude ramp. The required level of 3 was not achieved because resources did not permit testing at multiple load levels or alternative vertebral body heights. This shortfall is acknowledged and compensated by the high consistency of FEA predictions across the single tested condition (mean error 3.1%) and by the conservative nature of the selected configuration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model boundary conditions and loading must be demonstrably equivalent to the physical test setup as specified in ASTM F1717, with documented mapping of each physical parameter to its simulation counterpart.",
      "rationale": "One-to-one mapping table prepared for all physical test parameters (load application point, fixture compliance, UHMWPE block geometry, screw insertion torque) and their FEA equivalents. Load application fixture stiffness measured experimentally and incorporated as a spring element in the FEA model. Screw insertion torque converted to equivalent preload using validated torque-tension relationship."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted construct stiffness and failure load must agree with experimental mean within 10% and fall within the 95% prediction interval of experimental data.",
      "rationale": "FEA ensemble predicted mean construct stiffness of 187.4 N/mm versus experimental mean of 181.9 N/mm (3.1% error). All 11 individual experimental measurements fell within the FEA ensemble 95% prediction interval. Predicted yield load agreed within 6.8% of experimental mean. Bland-Altman analysis confirmed no systematic bias across the measurement range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (construct stiffness, peak stress, yield load) must be directly linked to the clinical performance endpoint (mechanical stability of the pedicle screw construct under physiological compression-bending).",
      "rationale": "Construct stiffness and yield load under ASTM F1717 compression-bending are established surrogate endpoints for in vivo mechanical stability of posterior spinal fixation systems. Linkage to clinical performance documented in FDA guidance document 'Spinal Implants — Premarket Notification [510(k)] Submissions' and peer-reviewed literature. Peak von Mises stress used as secondary QoI for fatigue life estimation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must directly address the FEA model's intended use for predicting ASTM F1717 compression-bending performance of non-cannulated pedicle screw constructs in the lumbar spine context.",
      "rationale": "Validation activities are co-extensive with the intended use scope: same device geometry (non-cannulated 7.5 mm pedicle screw), same test standard (ASTM F1717), same loading mode (static compression-bending), same material system (Ti-6Al-4V/UHMWPE). The validation boundary is explicitly scoped to static loading; dynamic and fatigue predictions are outside the validated envelope and excluded from claims supported by this UoA."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble for ASTM F1717 non-cannulated pedicle screw compression-bending achieves Medium assurance at model risk level 3. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is compensated by the high predictive accuracy observed at the tested condition (3.1% mean error in stiffness), the conservative nature of the selected F1717 configuration, and the explicit scope limitation of the model's claims to static single-configuration compression-bending. The assessment team concludes that the simulation evidence is sufficient to support regulatory submission for this device class and intended use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
