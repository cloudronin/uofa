  "signature": "ed25519:b7e2d4f1a3c5e8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "FEA software (Ansys Mechanical 2022 R2) operates under an FDA-recognized software quality assurance plan. Version control, validation test suite execution logs, and change control records are documented and available for audit. Achieved level equals required level for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from NAFEMS and Ansys verification manual were executed against analytical solutions. Maximum relative error across all benchmark cases is below 0.5%, confirming correct implementation of the governing equations for linear elastic structural analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw construct geometry. Richardson extrapolation yielded a grid convergence index below 2% for peak von Mises stress at the screw-rod interface. The production mesh (element edge length 0.35 mm at critical regions) was selected as the converged configuration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver residuals were monitored and confirmed to fall below 1e-8 for all load steps. Energy balance checks showed less than 0.1% discrepancy, confirming numerical solver accuracy within acceptable bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup was performed by two independent analysts following a documented simulation protocol. Cross-check of boundary conditions, material assignments, and contact definitions confirmed agreement. No discrepancies were identified that would affect quantities of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic continuum mechanics is appropriate for the metallic pedicle screw and rod components under static sub-yield loading. Contact interactions at screw-rod interfaces are modeled with frictional contact (mu=0.2) consistent with published literature. Model form assumptions are well-supported for the loading regime addressed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (Ti-6Al-4V ELI: E=114 GPa, nu=0.34) were sourced from ASTM F136 coupon test data provided by DePuy Synthes. Geometric inputs were derived from calibrated CT scans of the actual test constructs. Input uncertainty was quantified via a one-at-a-time sensitivity study; combined influence on predicted stiffness is below 4%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. All constructs were drawn from the same production lot. Dimensional inspection confirmed geometric conformance within manufacturing tolerances. Sample size supports statistical characterization of inter-specimen variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing was conducted at a single load level (750 N axial compression with 10 Nm bending moment) per ASTM F1717. The absence of multi-condition testing (e.g., varied load magnitudes or load angles) limits the achieved level to 2, one below the required level of 3 for model risk level 3. This shortfall is acknowledged and documented as an identified gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions were mapped directly to the physical test fixture configuration. Applied forces and moments in the model replicate the test machine actuator outputs within 1%. Fixture compliance was characterized experimentally and incorporated into the model boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness (N/mm) and peak displacement at 750 N were compared between FEA ensemble predictions and experimental measurements. Mean absolute percentage error across N=11 constructs is 3.8% for stiffness and 4.1% for displacement. All predictions fall within the 95% confidence interval of the experimental distribution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and peak displacement under ASTM F1717 loading are the primary quantities of interest for regulatory submission of a Class II spinal implant. These quantities are directly linked to the clinical decision context of evaluating mechanical performance of non-cannulated pedicle screw constructs in compression-bending."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The validation activity directly replicates the ASTM F1717 test protocol that constitutes the regulatory submission test. The physical constructs, load magnitudes, and output metrics in the validation study are identical to those used in the intended regulatory use. Relevance of validation activities to the intended use is therefore high."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed the required level for model risk level 3. The single shortfall in Test conditions (achieved level 2 versus required level 3) is acknowledged and documented. The assessment team determined that the overall evidence body — including N=11 constructs across two independent laboratories, rigorous mesh convergence, and direct equivalency of model inputs to test conditions — is sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending use scope as described in the Claim and Requirement documentation. Decision: Accepted with noted limitation on test condition coverage.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
