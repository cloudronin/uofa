      "name": "FEA vs. experimental construct stiffness — N=11 compression-bending specimens across two laboratories"
    },
    {
      "id": "https://uofa.net/nagaraja/validation/yield-load-comparison",
      "type": "ValidationResult",
      "name": "FEA vs. experimental yield load prediction — non-cannulated 7.5 mm construct"
    }
  ],
