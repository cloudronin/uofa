  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated FEA solver with documented V&V reports. FDA in-house code underwent unit testing and regression testing per internal SOP. Achieved level 3 reflects documented solver verification and release qualification records available for audit."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks must demonstrate solution correctness for linear elastic structural problems.",
      "rationale": "Patch test, cantilever beam, and Hertzian contact benchmarks were executed. All results agreed with analytical solutions within 0.5%. Level 3 achieved through multi-benchmark suite with documented pass/fail criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change of less than 5% between successive refinements.",
      "rationale": "Three-level mesh refinement study performed on pedicle screw shank and rod interface regions. Von Mises stress and construct stiffness QoIs changed by 2.1% and 0.8% respectively between medium and fine meshes. Richardson extrapolation applied; GCI reported at 1.4%."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 relative tolerance for all load steps.",
      "rationale": "Direct sparse solver used for all linear static analyses. Condition number monitored; no ill-conditioning detected. Residual norm confirmed below 1e-8 for all 11 specimen simulations. Level 2 reflects use of a single solver without independent cross-check."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation workflow must be executed by qualified analysts following documented SOPs with independent review.",
      "rationale": "All simulations executed by two independent analysts following a pre-registered analysis plan. Results cross-checked between FDA and DePuy Synthes teams. Discrepancies greater than 2% triggered documented reconciliation. Level 3 achieved through dual-analyst workflow with documented review records."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions must be justified relative to the dominant physics of ASTM F1717 quasi-static loading.",
      "rationale": "Linear elastic isotropic material model justified for metallic implant components under sub-yield loading per F1717 protocol. Contact interfaces modeled with frictional Coulomb contact (mu=0.2) consistent with literature. Geometric nonlinearity included for large-displacement rod bending. Model form assumptions documented and peer-reviewed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be sourced from specimen-specific measurements or certified material datasheets.",
      "rationale": "Ti-6Al-4V ELI material properties sourced from ASTM F136 coupon tensile tests performed on the same material lot as the F1717 specimens. Screw and rod geometry digitized from coordinate measuring machine data for each of the 11 specimens. Input uncertainty quantified and documented."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test sample population must be representative of the intended device configuration and sufficient for statistical comparison.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two laboratories. Sample size determined by power analysis targeting 80% power to detect 10% stiffness difference. All specimens from the same manufacturing lot; certificates of conformance documented."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the COU or deviations must be justified.",
      "rationale": "Testing performed under a single compressive-bending load condition per ASTM F1717 at 5 mm/min crosshead displacement rate. Torsional and fatigue loading conditions not evaluated in this validation activity. Achieved level 2 reflects single-condition testing; deviation from required level 3 is documented as a known scope limitation of this validation study."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to experimental test conditions within documented tolerances.",
      "rationale": "Boundary conditions replicated ASTM F1717 fixture geometry confirmed by fixture CMM measurements. Applied displacement and constraint conditions matched experimental crosshead displacement to within 0.05 mm. Material property inputs verified against specimen-specific tensile coupon data. Equivalency documented in pre-registered analysis plan."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric must be defined a priori and applied consistently across all specimen simulations.",
      "rationale": "Primary QoI is construct stiffness (N/mm) extracted from the linear region of the load-displacement curve. Secondary QoI is yield load (N). Prediction error defined as (FEA - Experimental)/Experimental × 100%. Mean absolute percentage error across N=11 specimens: stiffness 4.2%, yield load 6.8%. Both within pre-specified 10% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation must be directly relevant to the clinical and regulatory decision supported by the model.",
      "rationale": "Construct stiffness and yield load are the primary mechanical performance endpoints specified in ASTM F1717 and referenced in FDA guidance for posterior spinal fixation device submissions. These QoIs directly inform the regulatory substantial equivalence determination. Relevance confirmed by regulatory team and documented in the decision record."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must correspond to the device configuration, loading regime, and use environment of the intended clinical application.",
      "rationale": "Validation performed on the exact non-cannulated 7.5 mm pedicle screw geometry and material intended for submission. ASTM F1717 test protocol mirrors the quasi-static loading conditions used for regulatory bench testing. Two-laboratory design strengthens generalizability. Validation scope explicitly mapped to the submission COU described in the Claim and Requirement nodes of this package."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-credibility-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for model risk level 3. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 mandates a single standardized loading condition for regulatory bench testing, making multi-condition testing inconsistent with the regulatory reference standard. Overall model credibility is sufficient to support pre-market submission for Class II posterior spinal fixation devices under quasi-static compressive-bending loads. Decision endorsed by FDA CDRH OSEL credibility assessment team.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
