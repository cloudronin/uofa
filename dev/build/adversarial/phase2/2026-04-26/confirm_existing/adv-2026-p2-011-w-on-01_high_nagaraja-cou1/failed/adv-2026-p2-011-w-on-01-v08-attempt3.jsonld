  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted at Medium assurance level for Model Risk Level 3. Twelve of thirteen V&V 40 factors meet or exceed required gradation. One factor (Test conditions) achieves Gradation 2 against required Gradation 3 due to single test condition; this shortfall is accepted on the basis that (a) ASTM F1717 prescribes a single standardised configuration, (b) compensating strength exists across all other factors, and (c) the single condition is the regulatory gold standard for this device class. The FEA ensemble prediction is fit for purpose to support 510(k) pre-market submission for the non-cannulated 7.5 mm pedicle screw construct under static compression-bending loading.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
