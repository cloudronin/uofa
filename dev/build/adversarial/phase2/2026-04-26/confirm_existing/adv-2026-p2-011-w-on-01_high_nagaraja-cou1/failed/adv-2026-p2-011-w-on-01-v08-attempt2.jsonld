  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted at Medium assurance level for model risk level 3. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single deficient factor (Test conditions, achieved 2 vs. required 3) is accepted on the basis of a documented risk-informed argument that the ASTM F1717 single-condition protocol represents the bounding worst-case scenario per FDA guidance, and that the 510(k) submission does not claim extrapolation beyond this condition. The assessment team judges the aggregate evidence sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw construct under static compression-bending loading.",
