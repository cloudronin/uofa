  "hash": "sha256:a3f7c2e1d904b56f8e2a1c0d7b3e5f9a4c8d2b6e0f1a7c3d5e9b2f4a6c8d0e2",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated finite element solver with documented V&V procedures, release notes, and regression test suite. FDA and DePuy Synthes internal SQA records confirm version control, audit trails, and user qualification training are in place. Achieved level 3 exceeds the required level 2 for this model risk classification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be reproduced within solver tolerance.",
      "rationale": "Code verification was performed against NAFEMS benchmark LE1 (plane stress), LE10 (thick plate bending), and a cantilever beam with Timoshenko analytical solution. All results agreed within 0.5% of reference solutions. Solver convergence criteria set to residual norm below 1e-6 for all load steps."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change of less than 5% between successive refinements.",
      "rationale": "A three-level mesh convergence study was conducted on the pedicle screw-rod construct. Coarse (element edge length 1.5 mm), medium (0.75 mm), and fine (0.375 mm) meshes were evaluated. Peak von Mises stress at the screw-rod interface changed by 3.8% between medium and fine meshes; construct stiffness changed by 1.2%. The medium mesh was selected as the production mesh, satisfying the 5% convergence criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals and energy balance errors must remain below defined thresholds throughout the analysis.",
      "rationale": "Nonlinear quasi-static analyses used full Newton-Raphson iteration with line search. Force residual convergence tolerance was set to 0.1% of reaction force magnitude. Energy balance error remained below 0.05% across all load increments. No spurious hourglassing or zero-energy modes were detected."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup procedures must be documented and independently reviewed by a second qualified analyst.",
      "rationale": "Model setup, boundary condition application, and post-processing scripts were documented in a controlled analysis plan. An independent senior analyst performed a blind review of all input decks prior to submission runs. Discrepancies identified during review were resolved and re-verified. No systematic use errors were detected in the final ensemble runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions must be justified by literature evidence and sensitivity analysis for the dominant physics.",
      "rationale": "Linear elastic material models for titanium alloy (Ti-6Al-4V, E=114 GPa, nu=0.34) and UHMWPE vertebral body surrogates were adopted consistent with ASTM F1717 test block material properties. Contact interactions at screw-rod interface used penalty formulation with friction coefficient mu=0.2, validated against prior cadaveric and synthetic block studies. Geometric nonlinearity was included to capture large-displacement effects under bending loads exceeding 5 degrees of rotation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and geometric inputs must be traceable to measured values with documented uncertainty bounds.",
      "rationale": "Screw and rod geometry were derived from manufacturer-supplied CAD drawings with dimensional tolerances per DePuy Synthes engineering specifications. Material properties were taken from coupon tensile test certificates for the same Ti-6Al-4V bar stock used in device manufacture. UHMWPE block modulus was measured from three independent compression test specimens per ASTM D695. Uncertainty in material inputs was propagated via Monte Carlo sampling (n=500) and contributed less than 4% variation in predicted stiffness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of the device population and sufficient in number to characterize variability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from a single production lot were tested across two independent laboratories (FDA CDRH and DePuy Synthes R&D). Sample size was determined by a power analysis targeting 80% power to detect a 10% difference in stiffness at alpha=0.05. Dimensional inspection of all test articles confirmed conformance to design drawings within specified tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios or the limitation must be explicitly documented.",
      "rationale": "Testing was conducted exclusively under the ASTM F1717 standard compression-bending configuration at a single follower load of 400 N and a single bending moment rate. While this configuration represents the regulatory standard, it does not encompass the full range of in vivo loading conditions including torsion, lateral bending, or fatigue. This factor falls below the required level 3; the limitation is documented and accepted given that the COU is explicitly bounded to ASTM F1717 quasi-static compression-bending design verification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model boundary conditions and loading must be demonstrably equivalent to experimental test conditions.",
      "rationale": "Experimental fixture geometry, load application points, and constraint conditions were replicated in the FEA model using direct measurement of the test fixture. Load application was verified by comparison of reaction forces at the fixture attachment points between simulation and load cell measurements. Grip compliance was characterized experimentally and incorporated as spring boundary conditions in the model, reducing systematic error in stiffness prediction from 8.3% to 2.1%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics must include both point estimates and uncertainty bounds; agreement must be within predefined tolerance.",
      "rationale": "Construct stiffness and yield load were compared between FEA ensemble predictions and experimental measurements. Mean FEA stiffness was 312 N/mm versus experimental mean of 308 N/mm (1.3% difference); FEA yield load mean was 1,847 N versus experimental 1,823 N (1.3% difference). All FEA predictions fell within the 95% prediction interval of the experimental distribution. Bland-Altman analysis confirmed no systematic bias. The validation metric U_val was computed per ASME V&V 40 Section 5.4 and exceeded the acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be the same quantities used to support the regulatory submission decision.",
      "rationale": "Construct stiffness (N/mm) and yield load (N) are the primary QoIs specified in the 510(k) submission protocol for ASTM F1717 compliance. These same quantities are extracted from both the FEA model and the experimental tests. No surrogate or proxy QoIs were used. The mapping between simulation output variables and regulatory acceptance criteria is documented in the analysis plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar to the COU scenario in geometry, loading, boundary conditions, and material system.",
      "rationale": "The validation activity uses production-representative non-cannulated 7.5 mm pedicle screw constructs tested per ASTM F1717, which is the identical standard and device configuration addressed by the COU. The FEA model geometry, material assignments, and loading are directly derived from the validation test configuration. The validation scenario is therefore assessed as highly relevant to the COU, with the acknowledged limitation that only a single load condition was tested as documented under the Test conditions factor."
    }
  ],
