  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment outcome is Accepted. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single deficiency in Test conditions (achieved 2, required 3) is acknowledged; the team determined that the ASTM F1717 protocol-mandated single test condition is the regulatory standard and that additional loading-rate or temperature conditions are outside the current submission scope. The model ensemble is judged credible for supporting the Class II pre-market submission claim regarding non-cannulated 7.5 mm pedicle screw static compression-bending performance.",
