  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors assessed for model risk level 3. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions, achieved 2 vs. required 3) is below required level; risk accepted because the single ASTM F1717 test condition represents a conservative worst-case loading for the non-cannulated 7.5 mm pedicle screw construct and the prediction error at that condition is well within the 10% pre-specified tolerance across all three FEA codes. Overall credibility is sufficient to support the intended regulatory use as described in the claim and requirement binding. Decision: Accepted at Medium assurance level.",
