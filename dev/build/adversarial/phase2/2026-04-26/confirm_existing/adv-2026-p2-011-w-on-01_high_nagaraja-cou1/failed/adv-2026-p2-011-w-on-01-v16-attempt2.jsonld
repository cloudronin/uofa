  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All FEA solvers (Ansys Mechanical 2021 R2, Abaqus 6.14) are commercially validated and hold current V&V documentation. Software version control and regression test logs were reviewed and found compliant with FDA software quality guidance. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations.",
      "rationale": "Benchmark problems from NAFEMS and ASME V&V 10 suite were executed; results matched analytical solutions within 0.5%. Patch tests and single-element tests confirmed element formulation correctness across all participating codes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate solution change less than 5% between successive refinements for quantities of interest.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw shank and rod interface regions. Peak von Mises stress and construct stiffness changed by less than 2.8% between medium and fine meshes, satisfying the 5% convergence criterion. Final mesh contains approximately 420,000 elements (C3D8R with enhanced hourglass control)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms and energy balance errors must remain below solver-specified tolerances throughout loading history.",
      "rationale": "Nonlinear quasi-static analyses used Newton-Raphson iteration with force residual tolerance 1e-4. Energy balance errors remained below 0.1% across all load steps. No spurious hourglassing energy detected (ratio < 1% of total strain energy)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be reviewed by an independent analyst to detect user-introduced errors in boundary conditions, material assignments, and loading.",
      "rationale": "Independent peer review of model input decks performed by a second credentialed FEA engineer not involved in model construction. Boundary conditions (fixed inferior vertebral body, applied moment at superior body), material assignments (Ti-6Al-4V, UHMWPE endplate), and contact definitions were confirmed correct. No use errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection must be justified relative to the physics governing the quantity of interest and the COU.",
      "rationale": "Linear elastic material model with geometric nonlinearity (large displacement) adopted for titanium screw and rod. Contact between screw head and rod modeled with penalty formulation (friction coefficient 0.2, consistent with literature). Justification documented: plastic deformation does not initiate at loads below ASTM F1717 failure criterion for this alloy and geometry; sensitivity analysis confirmed elastic assumption introduces less than 3% error in stiffness prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters must be sourced from traceable measurements with uncertainty quantification.",
      "rationale": "Titanium alloy elastic modulus (114 GPa) and yield strength (880 MPa) sourced from ASTM F136 coupon testing performed on same material lot as test constructs. Screw geometry digitized from micro-CT at 20 µm resolution. Uncertainty propagation via Monte Carlo (1000 samples) showed stiffness QoI coefficient of variation of 1.4%, well within model risk tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of the device configuration modeled and must be characterized prior to testing.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from production lot used for both validation experiments. Each construct dimensionally inspected (OD, thread pitch, rod diameter) against nominal CAD; all within ±0.05 mm tolerance. Sample representativeness confirmed; no cannulated or non-production samples included."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the intended use, including at minimum two distinct load levels or configurations.",
      "rationale": "Validation experiments conducted at a single compression-bending load condition per ASTM F1717 protocol (6 Nm applied moment, 400 N axial preload). No variation in load level, offset distance, or environmental condition (dry, ambient) was explored. This single test condition results in achieved level 2 against a required level 3, representing the one factor below required level noted in the assessment description. Risk accepted given conservative loading represents worst-case for this device class."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to experimental test conditions to ensure valid comparison.",
      "rationale": "Applied moment, axial preload, fixture geometry, and screw-rod torque (4 Nm) in the FEA model were set to match experimental protocol values exactly. Fixture compliance measured experimentally and incorporated as spring boundary condition. Equivalency confirmed through side-by-side comparison of protocol document and model input deck."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric or equivalent) must demonstrate agreement within pre-specified tolerance.",
      "rationale": "Construct stiffness (N/mm) and peak load at 1.5% offset yield compared between FEA ensemble predictions and experimental mean ± SD. Validation metric computed per ASME V&V 20: all three FEA codes produced predictions within experimental uncertainty band (coverage factor k=2). Mean stiffness error: FDA code 3.1%, Ansys 4.7%, DePuy Synthes code 2.9%. Pre-specified tolerance of 10% satisfied for all codes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest extracted from the model must be directly relevant to the clinical or regulatory decision being informed.",
      "rationale": "Construct stiffness and yield load are the primary outputs used to assess structural adequacy of spinal fixation devices per FDA guidance on 510(k) submissions for pedicle screw systems. These QoIs directly map to the regulatory acceptance criterion (must meet or exceed predicate device performance). Relevance confirmed by regulatory affairs review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be sufficiently similar to the intended use context in terms of geometry, loading, material, and scale to support extrapolation of credibility.",
      "rationale": "Validation constructs use production-equivalent non-cannulated 7.5 mm screws and 5.5 mm rods identical to the device configuration described in the 510(k) submission. ASTM F1717 test configuration (two-vertebra surrogate, bilateral construct) replicates the biomechanical loading scenario addressed by the simulation. Validation activity relevance rated high; geometry, scale, material, and loading regime are all matched to the COU prose description."
    }
  ],
