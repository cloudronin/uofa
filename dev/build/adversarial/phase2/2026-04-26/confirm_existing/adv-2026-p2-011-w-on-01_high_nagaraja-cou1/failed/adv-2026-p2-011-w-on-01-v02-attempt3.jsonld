  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted at Medium assurance level. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single below-required factor (Test conditions, achieved 2 vs. required 3) is accepted under risk-informed rationale: the single ASTM F1717 load condition is conservative relative to in vivo loading, the device is Class II, and the clinical consequence of model error is bounded by device design margins. The FEA ensemble demonstrates consistent predictive accuracy (MAPE < 7%) across two independent laboratories and N=11 constructs, providing sufficient evidence to support regulatory submission use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
