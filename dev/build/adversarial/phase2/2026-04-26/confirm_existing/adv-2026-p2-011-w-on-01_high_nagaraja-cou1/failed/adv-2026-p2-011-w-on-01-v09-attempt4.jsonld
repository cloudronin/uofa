  "signature": "ed25519:b1d4f7a2e5c8b3f6a9d2e5b8c1f4a7d0e3b6c9f2a5d8e1b4f7c0a3d6e9b2f5a8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA solvers (FDA in-house, Ansys Mechanical 2022 R1, DePuy Synthes proprietary) operate under documented software quality assurance programs including version control, regression testing, and audit trails consistent with Gradation 2 requirements. Solver validation benchmarks are on file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations for structural mechanics.",
      "rationale": "Each solver in the ensemble has been verified against ASME V&V 10 benchmark problems for linear elastic structural analysis. Patch test and manufactured solution results confirm correct implementation of the finite element formulation used in the pedicle screw construct models."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate discretization error below 5% for all quantities of interest.",
      "rationale": "Systematic mesh refinement studies were conducted for each model in the ensemble. Richardson extrapolation was applied to stiffness and peak stress predictions. Discretization error was confirmed below 3.8% for construct stiffness and below 4.6% for screw-rod interface stress across all three models, meeting the 5% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge to below 1e-6 relative tolerance for all load steps.",
      "rationale": "Direct sparse solvers were employed for all linear static analyses, eliminating iterative convergence concerns. For nonlinear contact iterations, Newton-Raphson convergence was confirmed with force and displacement residuals below 1e-7 for every load increment across all eleven construct configurations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented modeling procedures and independent review must demonstrate controlled use of simulation tools.",
      "rationale": "Standardized modeling protocols were developed and followed by each laboratory. An independent reviewer from outside the originating team verified boundary condition application, material property assignment, and load application for each of the three ensemble models. No use errors were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions must be justified by literature or sensitivity analysis for all dominant physics.",
      "rationale": "Linear elastic titanium alloy material model is justified by the sub-yield loading regime of ASTM F1717 compression-bending protocol. Frictional contact at screw-rod interface with mu=0.3 was confirmed by sensitivity analysis showing less than 2% variation in stiffness over mu range 0.2-0.4. Geometric nonlinearity was included to capture large-displacement effects at 10 Nm bending moment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured values with documented uncertainty.",
      "rationale": "Titanium alloy (Ti-6Al-4V ELI) elastic modulus (114 GPa) and Poisson ratio (0.34) sourced from ASTM F136 coupon testing on the same material lot as the test constructs. Construct geometry derived from CMM measurements of production screws and rods with dimensional uncertainty below 0.05 mm. Torque preload on set screws measured and applied in FEA via equivalent pretension elements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of the clinical device and sufficient in number for statistical characterization.",
      "rationale": "N=11 constructs assembled from production-equivalent 7.5 mm non-cannulated pedicle screws and 5.5 mm rods, split across two independent laboratories (N=6, N=5). All constructs assembled by trained operators following the surgical technique guide. Sample size supports coefficient of variation estimation for construct stiffness with 90% confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios or provide justification for single-condition testing.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending condition (10 Nm moment, 1200 N axial load) representing worst-case lumbar loading. Extension-bending and torsion conditions were not evaluated. This single-condition limitation is acknowledged; the achieved level of 2 falls below the required level of 3. Risk is partially mitigated by the conservative nature of the F1717 loading profile relative to in vivo lumbar loads."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to experimental test conditions within defined tolerances.",
      "rationale": "Applied loads, boundary conditions, and geometric configurations in the FEA models were matched to experimental measurements. Load application point coordinates agreed within 0.5 mm of experimental fixture geometry. Set screw torque values used in FEA matched experimentally measured values within 5% for all eleven constructs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics must demonstrate agreement between simulation and experiment within defined acceptance bands.",
      "rationale": "FEA ensemble mean construct stiffness predictions fell within 8.2% of experimental mean across all three models. All individual model predictions fell within the experimental 95% confidence interval. Bland-Altman analysis confirmed no systematic bias. U-pooling metric per ASME V&V 40 Section 5.3.4 was 0.67, indicating adequate validation for medium assurance level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must be directly relevant to the regulatory submission decision and clinical performance assessment.",
      "rationale": "Construct stiffness and screw-rod interface stress are the primary quantities of interest, directly linked to the regulatory question of mechanical performance equivalence for 510(k) submission. Construct stiffness maps to the clinical performance requirement for spinal stabilization, and screw-rod stress informs fatigue life prediction under cyclic loading."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be sufficiently similar to the intended use context to support extrapolation of credibility evidence.",
      "rationale": "The ASTM F1717 validation scenario closely mirrors the regulatory submission context: same device configuration, same material lot, same assembly procedure, and loading representative of worst-case lumbar biomechanics. The two-laboratory design reduces laboratory-specific bias and strengthens generalizability of the credibility evidence to the intended regulatory decision."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble demonstrates sufficient credibility for medium assurance level to support regulatory submission of the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 compression-bending loading. Twelve of thirteen credibility factors meet or exceed required levels. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is accepted given the conservative nature of the single test condition and the strong agreement observed in output comparison. The overall evidence body supports the claim that FEA predictions of construct stiffness are credible for the stated regulatory decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
