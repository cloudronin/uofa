  "signature": "ed25519:b7c3d9e1f4a2805c6d3b1e7f2a4c8d0e5b9f3a1c6d8e2b4f7a0c5d1e8f3b6a9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk level.",
      "rationale": "All three FEA solvers (FDA in-house, Ansys Mechanical, DePuy Synthes internal) operate under documented software quality management systems with version control, regression testing suites, and formal release procedures. Achieved gradation 3 exceeds the required gradation 2 for this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Each solver has been verified against published benchmark problems including NAFEMS benchmarks and manufacturer-provided patch tests. Formal verification reports are on file for all three codes."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QOI change less than 5% between successive refinements.",
      "rationale": "A systematic mesh convergence study was performed across three refinement levels. The quantities of interest (construct stiffness and yield load) changed by less than 2.8% between the medium and fine meshes, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must fall below 1e-6 for all load steps; energy balance error must be less than 0.1%.",
      "rationale": "Newton-Raphson iterative convergence was confirmed for all load increments. Force residuals converged to below 1e-7 and energy balance errors remained below 0.05% across all 11 model instances."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented analyst training records and independent peer review of model setup must be on file.",
      "rationale": "All analysts hold graduate-level FEA training credentials. Model setup was independently reviewed by a second analyst not involved in original construction. Boundary condition application and material assignment were verified against the ASTM F1717 protocol specification."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions must be explicitly documented and justified relative to the physics of the ASTM F1717 compression-bending scenario.",
      "rationale": "Linear elastic material models are justified for the sub-yield loading regime. Contact between screw and UHMWPE block is modeled with augmented Lagrangian formulation. Geometric nonlinearity is included to capture large-displacement effects under the 10 mm prescribed displacement. All assumptions are documented in the model description report."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters must be derived from direct measurement or certified material data sheets with documented uncertainty bounds.",
      "rationale": "Titanium alloy (Ti-6Al-4V) elastic modulus and yield strength were taken from ASTM F136 certified material test reports for each production lot. UHMWPE block material properties were measured via uniaxial tensile testing. Geometric dimensions were obtained from CMM measurements of the actual test articles with tolerances documented."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sample size must be sufficient to characterize experimental variability; samples must be traceable to production lots.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested, drawn from two production lots with full traceability. Sample size provides adequate statistical characterization of construct-to-construct variability. Coefficient of variation for stiffness was 4.2%, consistent with prior published data for similar constructs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios or deficiency must be documented with impact assessment.",
      "rationale": "Testing was conducted under a single test condition (10 mm displacement at 5 mm/min crosshead speed) as specified in ASTM F1717. While this condition is protocol-compliant, it does not span the full range of in vivo loading rates or magnitudes. This factor falls below the required gradation level; the impact is considered acceptable given that the COU is limited to standard regulatory submission testing rather than in vivo performance prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must demonstrably correspond to the experimental test article parameters within documented tolerances.",
      "rationale": "A parameter equivalency table was prepared mapping each model input (geometry, material properties, boundary conditions, load application) to the corresponding experimentally measured or controlled quantity. All parameters fall within the specified tolerance bands. Discrepancies in UHMWPE block stiffness were quantified via sensitivity analysis showing less than 1.5% effect on QOIs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or prediction interval coverage) must be computed and must meet the pre-specified threshold.",
      "rationale": "Normalized RMS error between FEA-predicted and experimentally measured construct stiffness was 3.7% across N=11 constructs. Yield load predictions fell within the 95% prediction interval of experimental data for 10 of 11 constructs. Both metrics satisfy the pre-specified acceptance thresholds of 10% NRMSE and 90% PI coverage respectively."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs used in validation must be the same quantities used to support the regulatory decision.",
      "rationale": "Construct stiffness and yield load are the primary quantities of interest specified in ASTM F1717 and are the quantities used in the 510(k) substantial equivalence comparison. The validation QOIs are therefore directly relevant to the intended regulatory use of the model."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar to the intended use scenario in geometry, loading, boundary conditions, and material system.",
      "rationale": "The validation activities directly replicate the ASTM F1717 test protocol that constitutes the intended use scenario. Geometry, loading mode, boundary conditions, and material system in the validation experiments are identical to those in the regulatory submission test. The validation scenario is therefore considered fully relevant to the intended use."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed their required gradation levels. The single below-threshold factor (Test conditions, achieved 2 vs. required 3) has been evaluated and determined to have acceptable impact given the regulatory context: the model is used only to predict ASTM F1717 protocol outcomes, not to extrapolate to broader in vivo loading conditions. The overall model credibility is sufficient to support the 510(k) submission for the non-cannulated 7.5 mm pedicle screw construct. Decision is Accepted with the documented limitation on test condition coverage noted in the credibility factor assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
