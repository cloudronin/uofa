  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "The FEA software (Ansys Mechanical 2022 R2) is validated under an ISO 9001-compliant QMS. Version control, regression testing, and change management procedures are documented. Achieved level 3 exceeds required level 2 for this factor at model risk level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from ASME V&V 10 and Ansys verification manual were executed and results compared against analytical solutions. All benchmark cases passed within specified tolerances. Achieved level 3 satisfies required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating less than 2% change in quantity of interest between successive refinements.",
      "rationale": "A systematic mesh convergence study was performed across three mesh densities (coarse, medium, fine). The quantity of interest — peak von Mises stress at the screw-rod interface — changed by 1.4% between medium and fine meshes, satisfying the 2% convergence criterion. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6 for all load steps; energy balance verified.",
      "rationale": "Newton-Raphson convergence residuals were monitored across all load increments. Residuals fell below 1e-6 in all cases. Energy balance was verified post-solution. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented model setup review by an independent analyst; boundary condition checklist completed.",
      "rationale": "An independent senior analyst reviewed all model boundary conditions, material assignments, contact definitions, and loading configurations against the simulation plan. A formal checklist was completed and signed off. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection justified by literature and sensitivity analysis; contact mechanics formulation validated against known solutions.",
      "rationale": "Linear elastic material models are justified by the sub-yield loading regime of the ASTM F1717 protocol. Augmented Lagrangian contact formulation was selected based on published benchmarks for threaded fastener assemblies. Sensitivity analysis confirmed that friction coefficient variation between 0.15 and 0.35 produced less than 5% change in predicted construct stiffness. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters sourced from traceable measurements; uncertainty quantified for all primary inputs.",
      "rationale": "Ti-6Al-4V material properties were measured from witness coupons per ASTM E8. Geometric dimensions were obtained from CMM inspection of production screws and rods. Uncertainty bounds on elastic modulus (±2%) and cross-sectional dimensions (±0.05 mm) were propagated through the model using a one-at-a-time sensitivity study. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lots; dimensional inspection confirming conformance to nominal geometry.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production-representative components. CMM inspection confirmed all specimens were within ±0.1 mm of nominal geometry. Specimens were distributed across two independent test laboratories to assess inter-laboratory variability. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios including at least two distinct load levels or configurations.",
      "rationale": "Testing was performed under a single ASTM F1717-prescribed loading condition (5° offset compression-bending at 2 mm/min crosshead speed). While this condition is the regulatory standard, it does not span the full range of in vivo loading scenarios. Only one test condition was evaluated, resulting in achieved level 2 falling below required level 3. This shortfall is acknowledged and documented as an accepted limitation for the purpose of this regulatory submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrably matched to experimental specimen and test configuration parameters.",
      "rationale": "FEA model geometry was constructed from CMM measurements of the actual test specimens. Material properties were assigned from coupon measurements of the same material lot. Boundary conditions replicate the F1717 fixture geometry including the 5° offset block and roller-pin constraints. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 10.1) computed; simulation prediction within experimental uncertainty band.",
      "rationale": "The area validation metric per ASME V&V 10.1 was computed for construct stiffness and yield load. FEA ensemble predictions fell within the 95% experimental prediction interval for 10 of 11 specimens. The validation metric indicated adequate agreement at the medium assurance level. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (construct stiffness, yield load) are directly linked to device performance requirements and clinical risk drivers.",
      "rationale": "Construct stiffness and yield load under ASTM F1717 compression-bending are the primary regulatory performance metrics for spinal fixation implants. These quantities directly inform device labeling and risk characterization for Class II 510(k) submissions. The linkage between simulation QOIs and clinical risk drivers is documented in the device risk management file. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities are conducted under conditions sufficiently similar to the intended use context to support extrapolation of credibility conclusions.",
      "rationale": "The ASTM F1717 validation experiments replicate the regulatory test standard that defines device performance acceptability. The FEA model is applied to predict outcomes of this same standard test. The validation activity is therefore directly relevant to the intended regulatory use of the simulation. Achieved level 3 meets required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors for the non-cannulated 7.5 mm pedicle screw FEA model applied to ASTM F1717 static compression-bending prediction. Twelve of thirteen factors meet or exceed required levels for model risk level 3 at medium assurance. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 prescribes a single standardized loading condition for regulatory purposes and the limitation is explicitly acknowledged. The overall evidence package supports an Accepted decision for the intended regulatory submission use. The claim that the FEA ensemble provides adequate prediction of F1717 construct stiffness and yield load for a non-cannulated 7.5 mm pedicle screw is credible at the Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
