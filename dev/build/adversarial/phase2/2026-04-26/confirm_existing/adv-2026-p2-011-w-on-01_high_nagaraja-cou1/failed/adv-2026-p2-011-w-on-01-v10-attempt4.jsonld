  "signature": "ed25519:9c4a2f1e7b3d08c5a1e2d4b6f0c8e3a7d2b5f1c9e4a0d3b7f2c6e1a8d5b0f4c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Verified FEA solver with documented QA procedures and regression test suite must be employed; version control and audit trail required.",
      "rationale": "All three FEA implementations (FDA internal, Ansys Mechanical 2021 R2, DePuy Synthes proprietary) operate under ISO 9001-compliant QA frameworks with documented regression testing. Software versions are locked and traceable to simulation records. Required and achieved levels are equal; factor is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via benchmark problems with known analytical solutions demonstrating solver correctness for linear-elastic structural analysis.",
      "rationale": "Each FEA implementation was verified against NAFEMS benchmark problems LE1 and LE10 for linear-elastic stress analysis. Relative errors were below 0.5% in all cases. Numerical code verification is confirmed at the required gradation level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating less than 5% change in quantity of interest (construct stiffness and peak von Mises stress) between successive mesh refinements.",
      "rationale": "A three-level mesh refinement study was performed on the pedicle screw construct model. Construct stiffness changed by 1.8% between medium and fine meshes; peak stress changed by 3.2%. Richardson extrapolation confirmed discretization error below 2% for the QoI. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge to below 1e-6 relative tolerance; direct solver results used as reference for linear static analyses.",
      "rationale": "All linear static analyses used direct sparse solvers (PARDISO / MUMPS) with double-precision arithmetic. Residual norms confirmed below 1e-8. No iterative solver divergence or ill-conditioning flags were observed across the 11-construct ensemble. Factor satisfied at required level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of boundary condition application, material assignment, and load definition by a second analyst.",
      "rationale": "Each simulation setup was independently reviewed by a second credentialed analyst. Boundary conditions replicating ASTM F1717 fixture constraints were verified against the test standard. Material assignments were cross-checked against supplier datasheets. No use errors were identified during review."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form appropriateness justified through literature review and sensitivity analysis demonstrating that linear-elastic isotropic material model is adequate for the load range of interest.",
      "rationale": "The load range in ASTM F1717 compression-bending testing (up to 1500 N) remains within the linear-elastic regime for titanium alloy (Ti-6Al-4V) pedicle screws. Literature review (Goel et al., Rohlmann et al.) supports linear-elastic FEA for sub-yield loading. Sensitivity to nonlinear contact formulation was assessed and found to contribute less than 4% variation in stiffness predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs derived from traceable measurements; uncertainty in inputs quantified and propagated to output uncertainty.",
      "rationale": "Ti-6Al-4V elastic modulus (113.8 GPa) and Poisson ratio (0.342) sourced from ASTM B265 coupon measurements with stated uncertainty of ±2.1 GPa. Screw geometry digitized from CMM measurements of production parts (n=5). Input uncertainty propagated via Latin hypercube sampling (n=500 runs) yielding ±3.7% stiffness uncertainty at 95% confidence. Factor achieved at required level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental sample size sufficient for statistical characterization of variability; samples drawn from production lots with documented traceability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. All samples drawn from the same production lot with full dimensional and material traceability. Sample size provides 80% power to detect a 15% difference in mean stiffness at alpha=0.05. Inter-laboratory variability was within 6% for all constructs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions spanning the range of clinically relevant loading scenarios including at least two distinct load levels and two spinal levels.",
      "rationale": "Testing was performed under a single ASTM F1717 compression-bending condition (6° offset, 10 mm anterior displacement). Clinical use encompasses a broader range of load magnitudes and spinal levels. The single test condition does not fully span the intended-use loading space. This factor falls below the required gradation level; this known gap is documented and accepted given the regulatory precedent for F1717 as the standard acceptance test."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material, boundary conditions, loading) must be demonstrably equivalent to experimental test configuration within stated tolerances.",
      "rationale": "FEA boundary conditions were derived directly from ASTM F1717 fixture geometry, confirmed by CMM measurements of the test fixtures at both laboratories. Applied displacement profiles in simulation matched the experimental actuator displacement to within 0.05 mm. Torque preload on screw-rod interface replicated experimental assembly protocol. Equivalency confirmed for all primary input parameters."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 10.1) applied to primary QoI; metric must demonstrate agreement within defined tolerance band.",
      "rationale": "The area validation metric (ASME V&V 10.1) was applied to construct stiffness predictions vs. experimental distribution. The metric value of 0.08 is within the acceptable threshold of 0.15. Mean predicted stiffness (187 N/mm) vs. mean experimental stiffness (191 N/mm) yields a relative error of 2.1%. All three FEA implementations produced consistent results within 5% of each other."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (construct stiffness and load-to-failure) must be directly linked to the clinical performance metric and regulatory submission requirement.",
      "rationale": "Construct stiffness and load-to-failure under ASTM F1717 compression-bending are the primary mechanical performance metrics required by FDA guidance for Class II spinal fixation devices (FDA 2014 guidance on pedicle screw systems). These QoIs directly inform the device's ability to maintain spinal alignment under physiological loading. Relevance to clinical decision-making is established through the regulatory pathway."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the same device geometry, material system, load type, and regulatory standard as the intended clinical use context described in the claim and requirement documentation.",
      "rationale": "The validation activity directly employs the production 7.5 mm non-cannulated pedicle screw geometry, Ti-6Al-4V material system, and ASTM F1717 compression-bending protocol that constitute the regulatory submission basis. The FEA model ensemble was constructed to predict performance under exactly these conditions. Validation activities are assessed as fully relevant to the use scope described in the claim and requirement nodes, notwithstanding the absence of a structured hasContextOfUse linkage in this minimal-profile package."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-credibility-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required gradation levels. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is accepted on the basis of regulatory precedent: ASTM F1717 is the FDA-recognized standard acceptance test for pedicle screw constructs, and no additional test condition is required for 510(k) clearance. The overall credibility evidence is assessed as sufficient to support a Medium model risk level decision. The FEA ensemble agreement across three independent implementations further corroborates model credibility. Decision: Accepted with documented acknowledgment of the Test conditions factor gap.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
