  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble achieves Medium assurance level for prediction of ASTM F1717 static compression-bending performance of the 7.5 mm non-cannulated pedicle screw construct. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-required factor (Test conditions, achieved 2 vs. required 3) is acknowledged and accepted given the regulatory standardization of the ASTM F1717 single-condition protocol and the conservative model risk level assignment. The overall credibility evidence is judged sufficient to support pre-market submission for the intended Class II spinal implant application as described in the associated Claim and Requirement documentation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
