  "signature": "ed25519:b2c4d6e8f0a1b3c5d7e9f1a3b5c7d9e1f3a5b7c9d1e3f5a7b9c1d3e5f7a9b1c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA solver must be validated under an ISO 9001 or equivalent quality management system with documented version control and regression testing.",
      "rationale": "Ansys Mechanical 2022 R2 is deployed under an ISO 9001-certified QMS. Regression test suite covers 47 benchmark cases; all pass within stated tolerances. Version control via Git with tagged release used for this analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification against ASME V&V 10 benchmarks or equivalent analytical solutions for linear elastic structural problems.",
      "rationale": "Ansys Mechanical verified against ASME V&V 10 benchmark suite for linear elastic problems. Patch test, cantilever beam, and Hertzian contact benchmarks all reproduce analytical solutions within 1% error. Code verification documentation archived in QMS."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating less than 5% change in quantity of interest (construct stiffness, peak von Mises stress) between successive mesh refinements.",
      "rationale": "Three-level mesh convergence study performed on representative screw-rod construct. Construct stiffness changed by 1.8% and peak von Mises stress by 3.2% between medium and fine mesh. Richardson extrapolation applied; GCI < 4% for all QoIs. Final mesh selected at medium refinement level as convergent."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6 for all load steps; energy balance verified within 0.1%.",
      "rationale": "Direct sparse solver used for linear static analyses; iterative residuals not applicable. Energy balance checked post-solution and verified within 0.05% for all 11 model instances. No numerical instabilities or warnings flagged in solver log."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented model setup checklist reviewed by independent analyst; boundary conditions and loading consistent with ASTM F1717 protocol.",
      "rationale": "Model setup checklist completed and independently reviewed by second engineer. Boundary conditions (fixed inferior block, displacement-controlled superior block) and applied moment arm consistent with ASTM F1717 Section 7. No use errors identified during independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification provided for all constitutive assumptions; linear elastic isotropic material model appropriate for metallic implant components under sub-yield loading.",
      "rationale": "Ti-6Al-4V screw and rod modeled as linear elastic isotropic (E=114 GPa, nu=0.34) consistent with published literature and ASTM F136. UHMWPE test block modeled as linear elastic (E=0.9 GPa). All applied loads remain within linear elastic regime based on experimental yield load data. Model form uncertainty estimated as low for this loading regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from peer-reviewed literature or direct measurement; geometric inputs derived from calibrated CMM measurements of test specimens.",
      "rationale": "Material properties for Ti-6Al-4V sourced from ASTM F136 and three peer-reviewed publications with consistent values. Screw and rod geometry derived from CMM measurements of 5 representative specimens (mean ± 1SD reported). Sensitivity analysis performed on ±5% property variation; QoI sensitivity < 3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum N=6 test specimens per condition; specimens traceable to production lot with documented dimensional inspection.",
      "rationale": "N=11 test constructs assembled from production-representative components with full lot traceability. Dimensional inspection performed on all specimens; all within drawing tolerances. Sample size exceeds ASTM F1717 minimum requirement of N=3 and provides adequate statistical power for mean comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios including at minimum two load levels or two construct configurations.",
      "rationale": "Testing performed under a single ASTM F1717 compression-bending condition (5° offset, 73.6 mm moment arm) at a single load rate. While this condition is the regulatory standard, only one test condition was evaluated, limiting the ability to assess model predictive capability across loading variations. This factor falls below the required level and represents a known gap acknowledged in the credibility assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrably equivalent to experimental test configuration within stated uncertainty bounds.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 fixture geometry as measured by CMM. Applied displacement and moment arm match experimental setup documentation. Material property inputs fall within ±2% of measured specimen values. Equivalency formally demonstrated via parameter mapping table reviewed by independent analyst."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E-measure or normalized RMS error) applied; FEA predictions within 10% of experimental mean for primary QoIs.",
      "rationale": "E-measure applied per ASME V&V 10.1 guidelines. FEA construct stiffness predictions within 6.3% of experimental mean (95% CI: 3.1%–9.5%). Yield load predictions within 8.1% of experimental mean. Both primary QoIs satisfy the 10% acceptance criterion. Cross-laboratory comparison shows < 4% inter-lab variability confirming experimental reproducibility."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to device performance requirements and clinical risk; traceability documented from QoI to design input requirement.",
      "rationale": "Primary QoIs (construct stiffness, yield load under compression-bending) are directly specified in ASTM F1717 and are the regulatory submission endpoints for spinal implant systems. Traceability matrix documents linkage from QoI to design input requirement DHF-2023-001 Rev C. QoIs are clinically meaningful surrogates for construct stability and fatigue life initiation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches COU in terms of device geometry, loading modality, and regulatory context; any gaps between validation scenario and COU explicitly characterized.",
      "rationale": "Validation activities performed on the exact device configuration (7.5 mm non-cannulated pedicle screw with 5.5 mm rod) intended for submission. ASTM F1717 loading is the prescribed regulatory test for this device class. Gap between single-condition validation and full clinical loading envelope acknowledged and addressed through conservative model risk level assignment. Validation activities judged adequate for the Accepted decision at Medium assurance level."
    }
  ],
