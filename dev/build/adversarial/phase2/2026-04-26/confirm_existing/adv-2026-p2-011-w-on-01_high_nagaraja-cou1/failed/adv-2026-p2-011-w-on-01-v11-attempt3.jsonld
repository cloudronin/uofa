  "signature": "ed25519:b2e4a1c7f3d8b5e2a9c6f0d3b7e4a1c8f5d2b9e6a3c0f7d4b1e8a5c2f9d6b3e0",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software must be verified under a documented SQA plan with version control and regression testing consistent with Model Risk Level 3.",
      "rationale": "Ansys Mechanical 2021 R2 was used under an FDA-recognized SQA framework. Version control, regression test suite, and change management records were reviewed and found compliant with the required gradation for a Model Risk Level 3 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be solved to confirm correct implementation of governing equations for linear elastic structural analysis.",
      "rationale": "Patch tests and beam-bending benchmark problems with closed-form solutions were executed. Results matched analytical solutions within 0.5%, confirming correct code implementation for the element types and material models used in the pedicle screw FEA."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that quantities of interest change by less than 5% between successive refinements, with Richardson extrapolation applied.",
      "rationale": "A three-level mesh convergence study was performed on the screw-rod interface region. Peak von Mises stress converged to within 3.1% between the medium and fine meshes. Richardson extrapolation confirmed a grid convergence index below 4%, meeting the required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals must be documented and shown to be below solver-default convergence thresholds; iterative solver tolerance must be reported.",
      "rationale": "Direct sparse solver (SPARSE) was employed. Force and displacement residuals were confirmed below 1e-6 for all load steps. No iterative convergence issues were identified across the 11-construct ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be independently reviewed by a second analyst; boundary condition and material assignment logs must be archived.",
      "rationale": "An independent analyst at FDA CDRH OSEL reviewed all boundary condition assignments, contact definitions, and material property inputs. Discrepancies identified in two of eleven models were corrected prior to final simulation runs. Audit trail is archived in the project management system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for the choice of continuum mechanics formulation, contact algorithm, and material constitutive law must be documented relative to the loading regime.",
      "rationale": "Linear elastic isotropic material models are appropriate for the titanium alloy (Ti-6Al-4V) screw and rod under sub-yield quasi-static loading. Augmented Lagrangian contact was selected for the screw-rod interface. Justification is documented in the model development report referencing published material characterization data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions must be sourced from traceable measurements or certified material data sheets; uncertainty bounds must be reported.",
      "rationale": "Elastic modulus (114 GPa) and Poisson's ratio (0.34) for Ti-6Al-4V were taken from ASTM B265 certified material test reports. Screw and rod geometry was obtained from manufacturer-supplied CAD files validated against dimensional inspection reports. Uncertainty bounds of ±2% on modulus were propagated through a sensitivity study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 physical test specimens from production lots must be used; traceability to lot numbers and dimensional inspection records must be established.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were sourced from two production lots. Dimensional inspection confirmed conformance to design drawings within ±0.05 mm. Lot traceability records are archived. Sample size exceeds the minimum required for the specified gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing must be conducted under at least two distinct load levels or environmental conditions to characterize response variability; environmental controls must be documented.",
      "rationale": "Testing was conducted under a single quasi-static compression-bending load condition at room temperature per ASTM F1717. Only one load magnitude was applied across both laboratories. This limitation prevents characterization of load-level sensitivity and results in an achieved gradation of 2, below the required level of 3. This shortfall is acknowledged and accepted given the regulatory precedent for single-condition F1717 testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably derived from the same physical specimens used in testing, with documented mapping between measured and modeled quantities.",
      "rationale": "Geometry inputs to the FEA were derived directly from CMM measurements of the eleven test specimens. Material properties were assigned per certified lot-level material test reports corresponding to the production lots used in physical testing. A documented parameter mapping table links each specimen to its simulation counterpart."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, prediction intervals) must be computed and shown to fall within pre-specified acceptance bounds.",
      "rationale": "Construct stiffness predicted by FEA was compared against experimentally measured stiffness for all eleven constructs. Normalized RMS error was 4.7% and all FEA predictions fell within the 95% prediction interval of the experimental distribution. Acceptance criterion of NRMSE < 10% was met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest extracted from simulation must be directly relevant to the clinical and regulatory decision, with documented linkage to failure modes of concern.",
      "rationale": "Construct stiffness and peak screw-rod interface stress are the primary quantities of interest. Stiffness is directly measured in ASTM F1717 testing and is the regulatory submission metric. Peak stress is linked to fatigue failure risk at the screw-rod interface, the dominant clinical failure mode for pedicle screw constructs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must replicate the loading, geometry, and boundary conditions of the intended use scenario to a degree commensurate with Model Risk Level 3.",
      "rationale": "The ASTM F1717 test configuration directly replicates the spinal implant loading scenario for posterior fixation constructs. The non-cannulated 7.5 mm screw geometry tested is identical to the device configuration submitted for regulatory clearance. The validation activity is therefore directly relevant to the intended clinical use scenario."
    }
  ],
