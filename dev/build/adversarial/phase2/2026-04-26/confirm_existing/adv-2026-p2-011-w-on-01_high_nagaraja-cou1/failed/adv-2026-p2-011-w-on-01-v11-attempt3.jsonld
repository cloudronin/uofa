  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for the non-cannulated pedicle screw ASTM F1717 compression-bending FEA model is Accepted at Medium assurance level. Twelve of thirteen V&V 40 factors met or exceeded required gradation levels. The single shortfall in Test conditions (achieved level 2 vs. required level 3) was reviewed and accepted based on regulatory precedent for single-condition ASTM F1717 submissions and the conservative nature of the single load condition selected. The FEA model ensemble demonstrates sufficient credibility to support a 510(k) regulatory submission for a Class II non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
