  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels for a Model Risk Level 3 assessment. The single below-required factor (Test conditions, achieved level 2 versus required level 3) was reviewed by the assessment team and accepted on the basis that the single ASTM F1717 test condition is the regulatory standard condition and parametric variation is not required for the intended 510(k) submission use. The FEA ensemble demonstrates mean prediction errors of 6.3% for stiffness and 8.1% for yield load, both within the pre-specified 10% acceptance criterion. The overall credibility evidence is sufficient to support the claim that the FEA model can reliably predict ASTM F1717 compression-bending performance for the non-cannulated 7.5 mm pedicle screw construct as documented in the associated requirement and claim nodes.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
