  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical release validation documentation and FDA-internal QMS records confirm software version control, regression testing, and traceable release notes for the version used in this analysis.",
      "rationale": "Ansys Mechanical 2021 R2 was used under an FDA OSEL quality management system that mandates software validation records for computational tools used in regulatory submissions. Version-controlled input decks are archived in the FDA OSEL data repository. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 and Ansys verification manual covering beam bending, contact mechanics, and large-deformation plasticity must be reproduced within 1% of analytical solutions.",
      "rationale": "Standard Ansys benchmark suite for structural mechanics (cantilever beam, Hertzian contact, elasto-plastic cylinder) reproduced to within 0.4% of closed-form solutions. Code verification is considered complete for the physics regime relevant to pedicle screw bending."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate less than 2% change in peak von Mises stress and construct stiffness between the medium and fine mesh densities.",
      "rationale": "Three-level mesh refinement study performed on the 7.5 mm screw geometry. Peak von Mises stress changed by 1.1% and construct stiffness by 0.7% between medium (element edge ~0.4 mm at screw-rod interface) and fine (0.2 mm) meshes. Final mesh uses medium density as the production mesh."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual force norm at convergence must be below 0.1% of the applied load; energy balance error must be below 0.5% across all load steps.",
      "rationale": "Newton-Raphson nonlinear solver with adaptive sub-stepping used. Residual force norm converged to 0.02% of applied load across all 11 model instances. Energy balance error did not exceed 0.3% in any run. Solver log files archived."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and post-processing scripts by a second analyst not involved in original model construction.",
      "rationale": "A second FDA OSEL analyst independently reviewed the Ansys input decks, contact definitions, boundary condition application, and Python post-processing scripts against the analysis plan. Two minor discrepancies in load application direction were identified and corrected prior to final runs. Review documented in FDA internal memo IM-2023-0441."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification that continuum FEA with bilinear isotropic hardening plasticity and augmented Lagrange frictional contact is an appropriate model form for the F1717 compression-bending regime.",
      "rationale": "The dominant failure mode in F1717 compression-bending of pedicle screw constructs is plastic hinge formation at the screw-rod junction. Bilinear isotropic hardening (Ti-6Al-4V: E=114 GPa, yield 880 MPa, tangent 1.2 GPa) with augmented Lagrange contact (mu=0.2) captures this physics. Large-deformation formulation (NLGEOM ON) accounts for geometric nonlinearity at >2% strain. Model form is appropriate for the QOI (construct stiffness, yield load, failure load)."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be sourced from traceable measurements on the same lot of implants used in physical testing; uncertainty bounds reported.",
      "rationale": "Screw and rod geometry digitized via micro-CT (voxel size 25 µm) from three representative implants per batch. Ti-6Al-4V tensile coupon data (n=5 per lot) provided by DePuy Synthes with certificate of conformance. UHMWPE block material properties from ISO 5834-2 certificate. Input uncertainty: ±2% on elastic modulus, ±5% on yield stress, ±15 µm on critical dimensions."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 physical test constructs from production-representative implant lots, assembled per ASTM F1717 protocol, with dimensional verification reported.",
      "rationale": "N=11 constructs tested: 6 at FDA OSEL biomechanics laboratory and 5 at DePuy Synthes research facility. All implants from production lots with full traceability. Dimensional verification via CMM confirmed all critical dimensions within ±0.05 mm of nominal. Assembly torque controlled to 8 Nm per manufacturer IFU."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading configurations relevant to the COU, including at least two distinct loading rates or construct configurations.",
      "rationale": "All physical tests conducted under a single loading configuration (compression-bending at 5 mm/min per ASTM F1717 Section 8.2). Only one loading rate and one construct geometry (44 mm interbody distance) evaluated. This single test condition limits the breadth of validation evidence. Factor achieved level 2 against required level 3; this gap is acknowledged and accepted given the regulatory precedent for F1717 as a standardized test method."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that FEA model inputs (geometry, material, boundary conditions) faithfully represent the physical test specimens and test machine boundary conditions.",
      "rationale": "FEA boundary conditions replicate the F1717 fixture geometry: distal UHMWPE block fully constrained, proximal block coupled to load application point with 5-degree freedom per fixture kinematics. Fixture compliance measured experimentally (0.8 N/mm) and incorporated as a spring element. Geometric fidelity confirmed by overlay of micro-CT surfaces with CAD model (mean deviation 18 µm)."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., MAPE, prediction interval coverage) between FEA predictions and experimental measurements for all primary QOIs must be reported with statistical characterization.",
      "rationale": "Primary QOIs: construct stiffness (N/mm) and yield load (N). FEA ensemble predictions vs. experiment: stiffness MAPE=4.2% (95% PI coverage 91%), yield load MAPE=6.8% (95% PI coverage 89%). Secondary QOI (failure load) MAPE=8.1%. All metrics computed using the U-pooling method per ASME V&V 10.1. Results tabulated in Appendix B of the credibility assessment report."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOIs used in the validation activity (construct stiffness, yield load, failure load) must be directly traceable to the regulatory decision QOIs for the non-cannulated pedicle screw 510(k) submission.",
      "rationale": "The 510(k) submission requires demonstration of substantial equivalence in mechanical performance to the predicate device. Construct stiffness and yield load under F1717 compression-bending are the primary mechanical endpoints specified in the FDA guidance document for spinal pedicle screw systems. The validation QOIs are identical to the regulatory decision QOIs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario (ASTM F1717 bench test) must be sufficiently representative of the intended clinical and regulatory use context to support extrapolation of credibility evidence.",
      "rationale": "ASTM F1717 is the FDA-recognized consensus standard for spinal implant mechanical testing and constitutes the primary validation scenario for regulatory submissions. The bench test replicates the worst-case loading direction for pedicle screw constructs in the lumbar spine. The validation activity is directly relevant to the regulatory decision context as defined in the 510(k) submission strategy."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the non-cannulated 7.5 mm pedicle screw FEA model under ASTM F1717 compression-bending is accepted at Medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficiency — Test conditions factor achieving level 2 against required level 3 — is accepted based on regulatory precedent establishing ASTM F1717 as a standardized single-condition test method and the demonstrated agreement between FEA predictions and experimental results (stiffness MAPE 4.2%, yield load MAPE 6.8%) across N=11 constructs from two independent laboratories. The model ensemble is judged credible for supporting the 510(k) substantial equivalence determination for this device class and loading regime.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
