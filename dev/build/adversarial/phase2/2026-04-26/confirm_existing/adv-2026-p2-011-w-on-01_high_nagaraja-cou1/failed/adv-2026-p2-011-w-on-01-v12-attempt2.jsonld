  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All FEA software (Ansys Mechanical 2022 R1) is commercially validated. Version control, regression testing, and documented QA procedures are in place across FDA and DePuy Synthes modeling teams. Achieved level exceeds required."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems solved to manufacturer-documented tolerances; residual norms reported.",
      "rationale": "Standard Ansys benchmark suite executed; patch tests and cantilever beam benchmarks confirm element formulation correctness. Residual force norms below 1e-6 for all load steps."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI applied; discretization error reported as percentage of QoI.",
      "rationale": "Three-level mesh refinement study performed on screw-rod interface region. GCI < 2.1% for peak von Mises stress QoI. Hex-dominant mesh with element size 0.3 mm at critical notch region."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence demonstrated; energy balance within 0.5%.",
      "rationale": "Sparse direct solver (PARDISO) used with double-precision arithmetic. Energy balance error < 0.3% across all 11 construct simulations. No solver warnings flagged in any run."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented modeling protocol with independent review; boundary condition inputs verified against test setup.",
      "rationale": "Standardized modeling protocol document version-controlled and reviewed by independent analyst. Boundary conditions (fixed inferior block, displacement-controlled superior loading) verified against F1717 test rig geometry by two analysts independently."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model validated against material coupon data; contact formulation appropriate for screw-rod interface.",
      "rationale": "Ti-6Al-4V isotropic linear elastic constitutive model appropriate for sub-yield loading regime of F1717 test. Augmented Lagrange contact at screw-rod and screw-block interfaces. Model form uncertainty bounded by coupon-level material validation data."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometry derived from measured specimen data; uncertainty in inputs quantified.",
      "rationale": "Elastic modulus (114 GPa) and Poisson ratio (0.34) from ASTM E8 coupon tests on same material lot. Geometry from CMM measurements of each of the 11 constructs. Input uncertainty propagated via ±5% modulus perturbation study; QoI sensitivity < 1.8%."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sample size statistically justified; specimens from production lot with documented traceability.",
      "rationale": "N=11 constructs drawn from a single production lot with full material and dimensional traceability. Sample size sufficient for 90% confidence interval on mean construct stiffness per power analysis. Specimens split across two independent laboratories for inter-lab variability assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; environmental conditions controlled and documented.",
      "rationale": "Single test condition (5 mm offset, 10 N axial preload per ASTM F1717) evaluated. Clinically relevant range of offsets and preloads not explored. This factor is below required level; a risk mitigation note is recorded in the decision record. Environmental conditions (ambient temperature, humidity) documented and controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA inputs directly traceable to experimental inputs; no surrogate parameters used without justification.",
      "rationale": "All FEA boundary conditions and geometry inputs directly mapped from CMM measurements and test rig setup documentation. Loading rate equivalency confirmed: quasi-static FEA appropriate for 5 mm/min displacement-controlled test. No surrogate material parameters used."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined a priori; prediction interval overlaps experimental distribution.",
      "rationale": "Primary QoI is construct stiffness (N/mm) and peak rod bending moment at 2% offset yield. FEA ensemble mean within 4.7% of experimental mean stiffness (95% CI: 2.1%–7.3%). All 11 FEA predictions within experimental ±2 SD band. U95 validation metric computed per ASME V&V 20."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to the decision question; clinical relevance documented.",
      "rationale": "Construct stiffness and peak bending moment are the primary mechanical endpoints specified in ASTM F1717 and directly inform the 510(k) substantial equivalence determination for the non-cannulated pedicle screw system. QoI relevance confirmed by clinical and regulatory team review."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches COU geometry, loading, and material; any gaps explicitly documented.",
      "rationale": "Validation activities performed on the exact device geometry and material under the ASTM F1717 protocol that constitutes the COU. Inter-laboratory replication at FDA and sponsor site increases confidence in result generalizability. Single test condition gap documented under Test conditions factor."
    }
  ],
