  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for model risk level 3. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 specifies a single canonical test configuration and that the regulatory decision question is bounded to that configuration. The overall credibility evidence is sufficient to support a Medium assurance level determination for the non-cannulated 7.5 mm pedicle screw FEA model in the compression-bending use scenario.",
