    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-01",
      "type": "ValidationResult",
      "name": "ASTM F1717 compression-bending FEA vs. experiment comparison — N=11 constructs, two laboratories"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043479",
