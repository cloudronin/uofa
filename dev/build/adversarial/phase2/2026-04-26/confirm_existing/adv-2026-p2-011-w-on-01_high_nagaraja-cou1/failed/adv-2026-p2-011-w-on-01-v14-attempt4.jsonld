  "signature": "ed25519:b4e2d1f3a6c8e0f2b4d6a8c0e2f4b6d8a0c2e4f6b8d0a2c4e6f8b0d2a4c6e8f0",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical 2022 R1 is a commercially validated solver with documented QA procedures. FDA in-house FEA code underwent independent verification. DePuy Synthes implementation uses validated commercial software with SOPs on file. All three codes satisfy Gradation 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities documented and traceable to published benchmarks.",
      "rationale": "Each code in the ensemble was verified against ASME V&V 10 benchmark problems covering linear elastic beam bending and contact mechanics. Patch test results and manufactured-solution comparisons are archived in the technical file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating <5% change in peak von Mises stress and construct stiffness between successive refinements.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw shank and rod interface. Peak stress and global stiffness changed by 2.1% and 1.4% respectively between the medium and fine meshes. Richardson extrapolation confirms discretization error below 3% for quantities of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms and energy balance checks within solver tolerances; no divergence warnings in any simulation run.",
      "rationale": "All 33 simulation runs (11 constructs × 3 codes) converged with force residual below 1e-6. Energy balance errors were below 0.05%. No ill-conditioning warnings were recorded. Iterative solver settings were consistent across the ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second analyst; documented checklist for boundary condition and material assignment.",
      "rationale": "Each laboratory conducted an independent peer review of model inputs, boundary conditions, and material assignments prior to submission. A standardised setup checklist was completed and archived. No use errors were identified during the cross-laboratory comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification of continuum linear-elastic model form with documented sensitivity to nonlinear contact and plasticity assumptions.",
      "rationale": "Linear elastic continuum mechanics is appropriate for the sub-yield loading regime of ASTM F1717 static tests. Sensitivity analyses showed that inclusion of bilinear plasticity changed predicted stiffness by less than 4%. Frictional contact at screw-rod interface was modelled with Coulomb friction; coefficient sensitivity was evaluated over the range 0.1–0.3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters derived from measurements on the actual test specimens or manufacturer data sheets; uncertainty quantified.",
      "rationale": "Titanium alloy (Ti-6Al-4V) elastic modulus and Poisson ratio sourced from ASTM F136 certified material test reports for the specific lot. Screw geometry extracted from CMM measurements of three representative specimens. Uncertainty propagation via Monte Carlo (n=1000) showed QoI coefficient of variation below 3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lot; dimensional and material characterisation reported.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from a single production lot were tested. CMM dimensional inspection confirmed all screws within ±0.05 mm of nominal geometry. Material certification documents accompany each specimen record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; environmental controls documented.",
      "rationale": "Testing performed at a single compression-bending load angle (5°) per ASTM F1717. Additional load angles representative of scoliosis correction and adjacent-level loading were not evaluated, reducing achieved level to 2. This shortfall is acknowledged and bounded by the conservative single-condition analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that simulation input parameters match experimental conditions within stated tolerances.",
      "rationale": "Applied loads, displacement boundary conditions, and fixture geometry in the FEA models were matched to the experimental test rig within 1% for all 11 constructs. Cross-laboratory comparison of input parameter tables confirmed equivalency across all three modelling teams."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric) applied; agreement within ±15% for primary QoI.",
      "rationale": "Construct stiffness (N/mm) and peak screw bending moment (N·mm) were compared using the ASME V&V 20 validation metric. Mean absolute percentage error was 6.3% for stiffness and 8.1% for bending moment across the ensemble. All predictions fell within the experimental 95% confidence interval."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to device performance endpoints relevant to clinical use and regulatory submission.",
      "rationale": "Construct stiffness and peak screw bending moment are the primary performance endpoints in ASTM F1717 and are directly cited in FDA guidance for spinal fixation systems. These QoIs are mechanistically linked to fatigue life prediction and intraoperative failure risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, loading, and boundary conditions are representative of the intended clinical and regulatory use.",
      "rationale": "The ASTM F1717 test configuration is the FDA-accepted surrogate for in vivo spinal fixation loading. The non-cannulated 7.5 mm screw geometry tested is identical to the device intended for submission. Multi-laboratory execution increases confidence in the generalisability of the validation evidence to the regulatory COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a model risk level 3, Medium assurance assessment. The single shortfall in Test conditions (achieved 2, required 3) is judged acceptable given the conservative nature of the single-condition ASTM F1717 protocol, the bounded scope of the static compression-bending claim, and the multi-laboratory corroboration of simulation predictions. The assessment team accepts the overall credibility evidence as sufficient to support pre-market submission for the non-cannulated 7.5 mm pedicle screw construct under 21 CFR 888.3070.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
