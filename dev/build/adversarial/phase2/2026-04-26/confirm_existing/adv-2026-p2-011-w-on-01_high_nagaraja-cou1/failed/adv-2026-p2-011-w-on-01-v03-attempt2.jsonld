  "signature": "ed25519:b2e4a1c7f3d9e5b0a8c6f2d4e7b1a3c5f9d2e8b4a6c0f3d7e1b5a9c2f6d0e4b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk level.",
      "rationale": "All three FEA codes (FDA in-house, Ansys 2022 R2, DePuy Synthes solver) operate under documented quality management systems with version-controlled software and release validation suites. SQA records confirm compliance with applicable software lifecycle requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark verification problems including patch tests and manufactured-solution convergence studies were executed for each solver. Results confirmed theoretical convergence rates for the linear-elastic hexahedral element formulations employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed across three refinement levels (coarse, medium, fine). The quantity of interest (peak von Mises stress at the screw-rod interface) changed by less than 2% between medium and fine meshes. Richardson extrapolation confirmed GCI below 3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Direct sparse solver (PARDISO) employed with residual norm tolerance of 1e-8. Iterative solver residuals monitored and confirmed to fall below tolerance thresholds for all load increments. No convergence failures observed across the 11-construct ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation workflow documented in a controlled simulation plan. Independent analyst review of boundary conditions, material assignments, and contact definitions performed prior to solution. Checklist-based review process mitigates analyst use error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear-elastic continuum model with frictional contact at screw-rod interface selected based on published literature for metallic spinal implant constructs under quasi-static loading. Model form assumptions documented and justified relative to the ASTM F1717 test configuration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (Ti-6Al-4V ASTM F136) sourced from certified material test reports for each production lot. Geometric inputs derived from CMM measurements of as-built hardware. Sensitivity analysis on friction coefficient (0.1–0.3) showed less than 4% variation in predicted stiffness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 production-representative constructs tested; sample size sufficient for statistical comparison at the required credibility level. Constructs drawn from the same production lot as the FEA geometry inputs, ensuring dimensional equivalence between physical and virtual specimens."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed at a single load level (150 N axial compression with 10 Nm bending moment) per ASTM F1717 protocol. The absence of multi-condition testing limits the achieved level to 2, one gradation below the required level of 3. This gap is documented as an accepted residual limitation given the standardized nature of the F1717 protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Direct correspondence established between FEA boundary conditions and experimental test setup parameters. Load application points, fixture geometry, and constraint conditions replicated in the simulation. Equivalency table documented in the simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness (N/mm) and failure load (N) compared between FEA predictions and experimental measurements using normalized error metrics. Mean absolute percentage error of 5.8% for stiffness and 7.2% for failure load across N=11 constructs. Comparison methodology follows ASME V&V 40 Section 5 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantities of interest (construct stiffness and failure load) are directly linked to the regulatory submission requirements for non-cannulated pedicle screw constructs under ASTM F1717. Clinical relevance of these mechanical endpoints established through published biomechanical literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities conducted using production-representative hardware under the standardized ASTM F1717 compression-bending protocol, directly matching the intended regulatory submission context. Two-laboratory replication confirms reproducibility of the validation evidence base."
    }
  ],
