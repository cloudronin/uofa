      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk level.",
      "rationale": "Construct stiffness and yield load predictions were compared to experimental measurements using a quantitative metric (NRMSE < 8%). All three FEA ensemble members fell within the experimental variability band."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk level.",
      "rationale": "Construct stiffness and yield load are the primary regulatory quantities of interest for ASTM F1717 bench testing and are directly linked to clinical performance indicators for spinal fixation devices."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
