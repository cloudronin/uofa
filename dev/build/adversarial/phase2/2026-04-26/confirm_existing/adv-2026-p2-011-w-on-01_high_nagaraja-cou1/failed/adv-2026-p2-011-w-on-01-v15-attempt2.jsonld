      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk level.",
      "rationale": "Material properties (Ti-6Al-4V, UHMWPE) were sourced from ASTM-certified coupon tests performed on the same material lot as the implants. Geometric inputs were derived from coordinate-measuring-machine measurements of the actual test constructs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
