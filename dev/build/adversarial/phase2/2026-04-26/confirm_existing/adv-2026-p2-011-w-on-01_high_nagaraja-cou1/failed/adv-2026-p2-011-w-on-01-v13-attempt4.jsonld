  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Nagaraja COU1 — Non-cannulated pedicle screw compression-bending credibility assessment (Minimal Profile)",
  "description": "V&V 40 credibility assessment for FEA prediction of ASTM F1717 static compression-bending performance of a non-cannulated 7.5 mm pedicle screw construct. The FEA model ensemble (FDA, Ansys, DePuy Synthes) is compared against N=11 experimental constructs across two laboratories. All 13 V&V 40 factors assessed; one factor (Test conditions) below required level due to single test condition. Intended use is limited to Class II spinal implant pre-market submission support for static structural performance claims under ASTM F1717 loading conditions. Model risk level 3; assurance level Medium.",
  "bindsRequirement": "https://uofa.net/synth/req/nagaraja-f1717-compression-bending-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/nagaraja-fea-predicts-f1717-static-performance",
  "bindsModel": "https://uofa.net/synth/model/nagaraja-pedicle-screw-fea-ensemble",
  "bindsDataset": [
    "https://uofa.net/synth/data/nagaraja-f1717-experimental-n11-lab1",
    "https://uofa.net/synth/data/nagaraja-f1717-experimental-n11-lab2"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-001",
      "type": "ValidationResult",
      "name": "ASTM F1717 compression-bending FEA vs. experiment comparison — N=11 constructs, two laboratories"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043154",
  "wasAttributedTo": "https://uofa.net/synth/org/nagaraja-fda-cdrh-osel",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e4b7d09e5f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f",
  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical) must have documented verification tests and version-controlled release notes confirming numerical correctness for structural static analysis.",
      "rationale": "Ansys Mechanical 2022 R2 used by all three modelling teams. Software qualification documentation including regression test suite results and release verification report on file. Required and achieved levels both at 2."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must confirm correct implementation of linear elastic constitutive models and contact mechanics algorithms.",
      "rationale": "Three benchmark cases (cantilever beam, Hertzian contact, patch test) executed by each modelling team. All results within 1% of analytical solutions. Code verification complete at required level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that quantity of interest (construct stiffness and peak von Mises stress at screw-rod interface) changes by less than 5% between the penultimate and final refinement levels.",
      "rationale": "Four-level mesh refinement study performed on representative non-cannulated 7.5 mm screw geometry. Stiffness converged to within 2.3% and peak stress to within 3.8% between levels 3 and 4. Richardson extrapolation applied; GCI reported at 1.1%. Achieved level 3 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must fall below 1e-6 for all load steps; energy balance error must be below 0.1%.",
      "rationale": "Direct sparse solver (PARDISO) employed for all analyses. Residual norms confirmed below 1e-8. Energy balance monitored across all 11 specimen configurations; maximum imbalance 0.04%. Numerical solver error factor satisfied at level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and load application by a second analyst not involved in primary model development.",
      "rationale": "Each of the three modelling teams performed cross-review of the other teams' model setups. Discrepancies in boundary condition interpretation identified and resolved prior to final simulation runs. Use error factor assessed at level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The choice of linear elastic isotropic material model and frictionless contact at screw-rod interface must be justified by literature evidence and sensitivity analysis demonstrating negligible effect of plasticity onset within the load range of interest.",
      "rationale": "Literature review (Goel et al., Panjabi et al.) supports linear elastic assumption for titanium alloy at sub-yield loads. Sensitivity analysis with bilinear isotropic hardening showed less than 1.5% difference in stiffness prediction. Frictionless contact conservatively bounds interface behaviour. Model form assessed at level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, nu) and geometric dimensions must be sourced from coupon test data or certified material certificates traceable to each physical specimen lot.",
      "rationale": "Elastic modulus and Poisson ratio for Ti-6Al-4V ELI obtained from tensile coupon tests (n=5 per lot, two lots). Geometric dimensions digitised from micro-CT scans of representative specimens. Input uncertainty propagated via Monte Carlo (1000 samples); 95th percentile output uncertainty band reported. Model inputs factor at level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum N=10 physical specimens tested; specimens must be production-representative with documented lot traceability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. All specimens from production lots with full certificate of conformance. Dimensional inspection confirmed conformance to drawing tolerances. Test samples factor satisfied at level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the clinically relevant load range including at least two distinct load levels or loading configurations to assess model predictive capability across conditions.",
      "rationale": "Testing performed at a single compressive load level per ASTM F1717 protocol. Only one loading configuration (compression-bending at 5 degrees) evaluated. The required level of 3 demands multi-condition coverage; achieved level remains at 2 due to single test condition. This factor is below the required threshold and constitutes a documented gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to experimental conditions; any deviations must be quantified and shown to have negligible impact on the quantity of interest.",
      "rationale": "Grip fixture geometry, potting material stiffness, and load application point all replicated in FEA from measured experimental setup dimensions. Sensitivity analysis on potting material modulus (range 1.5–4.0 GPa) showed less than 2% effect on predicted construct stiffness. Equivalency confirmed at level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., MAPE or normalised RMS error) between FEA predictions and experimental measurements must be below 10% for the primary quantity of interest.",
      "rationale": "Construct stiffness predictions from all three FEA models compared against N=11 experimental measurements. Mean absolute percentage error: FDA model 4.2%, Ansys model 5.8%, DePuy Synthes model 3.9%. All within 10% acceptance threshold. Output comparison factor at level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest predicted by the FEA model (construct stiffness, peak interface stress) must be directly relevant to the clinical performance claims and regulatory submission endpoints.",
      "rationale": "Construct stiffness and peak von Mises stress at the screw-rod interface are the primary endpoints for ASTM F1717 compliance and directly support the 510(k) substantial equivalence argument for static structural performance. Quantities of interest relevance confirmed at level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario (ASTM F1717 bench test) must be sufficiently representative of the clinical use scenario to support extrapolation of model credibility to the intended regulatory decision context.",
      "rationale": "ASTM F1717 is the FDA-recognised consensus standard for spinal implant static performance. The bench test configuration is a standardised surrogate for in vivo compression-bending loading. The validation activities are directly mapped to the regulatory submission context for Class II spinal implants. Relevance of validation activities assessed at level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment outcome is Accepted at Medium assurance level for model risk level 3. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single below-threshold factor (Test conditions, achieved 2 vs. required 3) is acknowledged and mitigated by the robustness of the multi-team modelling approach, the use of a FDA-recognised consensus standard test protocol, and the conservative nature of the single-condition loading scenario relative to clinical extremes. The assessment team judges the aggregate evidence sufficient to support regulatory submission for the stated Class II device and loading condition.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
