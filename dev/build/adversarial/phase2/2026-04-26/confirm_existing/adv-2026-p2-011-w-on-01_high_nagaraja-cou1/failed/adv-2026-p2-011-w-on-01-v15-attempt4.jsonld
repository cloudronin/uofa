  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for Model Risk Level 3. The single below-required factor (Test conditions, achieved 2 vs. required 3) was reviewed and accepted at program level given that ASTM F1717 specifies a single standard test condition and the regulatory submission scope is limited to that condition. Overall simulation credibility is sufficient to support the intended pre-market design verification decision for non-cannulated 7.5 mm pedicle screw constructs under static compression-bending loading.",
