  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium assurance at Model Risk Level 3.",
      "rationale": "All three FEA codes (FDA in-house, Ansys 2023 R1, DePuy Synthes proprietary solver) operate under documented software quality plans with version control, unit testing, and regression test suites. ISO 9001-registered QMS in place for commercial codes. Required gradation 2 achieved and exceeded at gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 suite must be reproduced within 1% for linear elastic cases.",
      "rationale": "Each code in the ensemble was verified against NAFEMS benchmark LE1 and LE10 with errors below 0.4%. Contact patch benchmarks verified against Hertzian analytical solutions. Gradation 3 achieved across all three codes."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be below 5% for the primary quantity of interest (construct stiffness and failure load).",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw shank and rod junction regions. GCI values of 2.1% (stiffness) and 3.8% (peak load) satisfy the 5% threshold. Hex-dominant mesh with element size 0.3 mm in critical zones. Gradation 3 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge to below 1e-6 for force and displacement norms.",
      "rationale": "Nonlinear Newton-Raphson iterations converged to residual norms below 1e-7 in all load steps. No divergence or line-search failures observed across the 11-construct ensemble. Gradation 2 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of model setup by a second analyst.",
      "rationale": "Model setup checklists completed for each of the 11 constructs. Independent analyst reviewed boundary condition application, material assignment, and contact definitions. Two minor discrepancies identified and corrected prior to final runs. Gradation 2 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics assumptions (linear elasticity for titanium alloy components) must be justified against material coupon data; contact formulation must be validated against known contact benchmarks.",
      "rationale": "Ti-6Al-4V material behavior is linear elastic below yield for the load levels in ASTM F1717 static compression-bending. Material coupon data from three lots confirm elastic modulus 114 ± 3 GPa. Augmented Lagrangian contact formulation validated against Hertzian benchmarks. Gradation 3 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Geometric dimensions from CMM measurements; material properties from certified coupon testing; torque preloads from calibrated instrumentation.",
      "rationale": "CMM measurements of each of the 11 constructs provided nominal geometry with ±0.01 mm uncertainty. Material properties sourced from certified test reports per ASTM E8. Set-screw torque preloads measured with calibrated torque transducer (±0.5 N·m). All inputs traceable to measurement standards. Gradation 3 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from at least two independent lots; dimensional inspection of each sample.",
      "rationale": "N=11 constructs assembled from two independent manufacturing lots (Lot A: n=6, Lot B: n=5). Dimensional inspection of each construct performed by CMM prior to testing. Lot-to-lot variability in key dimensions within ±0.05 mm. Gradation 3 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two independent test conditions (e.g., load levels or fixture configurations) must be evaluated to demonstrate model generalizability.",
      "rationale": "Testing performed at a single compression-bending load configuration per ASTM F1717 protocol. A second load condition (e.g., torsion or fatigue) was not included in this validation activity. Achieved gradation 2 falls below required gradation 3; this gap is documented as a known limitation of the current validation scope and accepted by the credibility assessment team given the narrow COU (static compression-bending only). Risk accepted at Medium assurance level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to experimental conditions within stated measurement uncertainty.",
      "rationale": "Boundary conditions in simulation replicate the F1717 fixture geometry with rigid body constraints at the load application points. Applied displacement rates matched to experimental crosshead speed. Fixture compliance measured and incorporated as a spring element. Equivalency confirmed for geometry, loading, and constraints. Gradation 3 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric or E-value) must demonstrate agreement within model uncertainty bounds for construct stiffness and peak load.",
      "rationale": "ASME V&V 20 validation metric computed for construct stiffness and peak bending load across all 11 constructs. Mean absolute percentage error: 4.2% (stiffness), 5.8% (peak load). All predictions within 95% prediction interval of experimental distribution. E-value < 1 for 10 of 11 constructs. Gradation 3 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (construct stiffness, peak load, displacement at failure) must map directly to the clinical and regulatory decision criteria.",
      "rationale": "Construct stiffness and peak bending load are the primary outputs specified in ASTM F1717 and directly inform the 510(k) predicate comparison. Displacement at failure provides secondary evidence of ductile behavior. All three QOIs are directly relevant to the regulatory submission decision. Gradation 3 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario must be sufficiently similar to the intended use scenario in geometry, loading, and boundary conditions to support extrapolation of credibility evidence.",
      "rationale": "The validation activity uses the same non-cannulated 7.5 mm pedicle screw geometry, same F1717 test block material (UHMWPE), and same static compression-bending loading mode as the intended use scenario. Two independent laboratories provide evidence of reproducibility. The validation scenario is judged to be directly representative of the COU for static mechanical performance assessment. Gradation 3 confirmed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors meet or exceed the required gradation for Medium assurance at Model Risk Level 3. The single deficiency (Test conditions, achieved gradation 2 vs. required gradation 3) is accepted given the explicitly bounded intended use of the model to static compression-bending of non-cannulated pedicle screw constructs per ASTM F1717, as described in the claim and requirement documentation. The ensemble FEA approach across three independent modeling teams provides additional confidence. Overall credibility is judged sufficient to support the 510(k) regulatory submission for the stated mechanical performance claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
