  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "All three FEA codes (FDA in-house, Ansys 2022 R2, DePuy Synthes internal) operate under documented software quality assurance plans including version control, validation test suites, and change management procedures consistent with ASME V&V 40 Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "Benchmark problems including patch tests and single-element checks have been executed for each code. Ansys 2022 R2 passes all NAFEMS benchmark suite tests relevant to contact and large-displacement structural analysis. FDA in-house code verification documented in internal verification report VR-2023-004."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk with structural QoI.",
      "rationale": "Mesh convergence study performed with three systematically refined meshes (coarse: 42k elements, medium: 118k elements, fine: 334k elements). Richardson extrapolation applied; discretization error in peak von Mises stress at screw-rod interface estimated at 2.3%, within the 5% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "Iterative solver convergence monitored via force and displacement residual norms; convergence criteria set at 1e-4 relative tolerance. Newton-Raphson iteration histories reviewed for all 11 construct simulations; no convergence anomalies detected."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "Independent analyst review of model setup performed by a second engineer not involved in primary model construction. Boundary conditions, material assignments, and contact definitions reviewed against the documented simulation protocol SP-2023-F1717. No discrepancies identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk with nonlinear contact.",
      "rationale": "Linear elastic titanium alloy (Ti-6Al-4V) material model with nonlinear frictional contact at screw-rod and screw-bone block interfaces. Model form selection justified by literature review and sensitivity analysis demonstrating that plasticity effects are negligible below yield for the loading range tested. Contact friction coefficient validated against independent coupon tests."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "Material properties sourced from ASTM F136 certified mill certificates for each of the 11 physical constructs. Geometric dimensions measured via CMM with 0.005 mm resolution. Sensitivity analysis on Young's modulus (±5%), friction coefficient (0.1–0.3), and screw insertion torque-induced preload conducted; QoI sensitivity within 4% across plausible input ranges."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "N=11 constructs tested across two independent laboratories using production-representative hardware from the same manufacturing lot. Sample size exceeds the minimum of N=5 recommended for Gradation 2; statistical characterization of geometric variability provided. Both laboratories are ISO 17025 accredited."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk; shortfall documented and risk accepted.",
      "rationale": "Testing performed at a single load rate (1 mm/min) and a single offset distance (31 mm) per ASTM F1717. Required level 3 would necessitate multiple test conditions (e.g., varied offset distances or loading rates). Single test condition is a known limitation; however, the COU is restricted to the tested configuration and the assurance team accepted residual risk given the regulatory precedent for F1717 single-condition testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "One-to-one mapping between experimental measurements and model inputs established and documented in traceability matrix TM-2023-F1717. CMM-measured geometry used directly to parameterize CAD for each of the 11 constructs. Material coupons from the same lot used for both testing and model input derivation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "Quantitative comparison using ASME V&V 20 area validation metric. Mean absolute percentage error across 11 constructs: 4.1% for construct stiffness and 6.8% for yield load. Both within the 10% acceptance threshold. Uncertainty quantification accounts for experimental measurement uncertainty (2.3%) and model parameter uncertainty (3.1%)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "Primary QoIs are construct stiffness (N/mm) and yield load (N) under ASTM F1717 compression-bending, which are the regulatory submission quantities of interest for Class II spinal implant 510(k) clearance. QoI selection reviewed and endorsed by clinical and regulatory affairs team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "Validation activities replicate the intended use scenario: ASTM F1717 static compression-bending of a non-cannulated 7.5 mm pedicle screw construct in a vertebrectomy model. The validation domain is congruent with the regulatory submission context. No extrapolation beyond the tested configuration is claimed in the associated regulatory filing."
    }
  ],
