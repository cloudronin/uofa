  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "Ansys Mechanical R19.2 is a commercially validated FEA solver with documented V&V procedures. Software version control and regression testing records are available. Required and achieved levels are both Gradation 2, consistent with model risk level 3 and Medium assurance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including cantilever beam bending and contact patch tests were solved and compared to analytical solutions. Errors were below 0.5%, confirming correct implementation of governing equations in the solver used for the pedicle screw model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate <5% change in peak von Mises stress and construct stiffness between successive refinements.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw–vertebral body interface. Peak von Mises stress changed by 2.1% and construct stiffness by 1.4% between medium and fine meshes. The fine mesh was adopted for all production runs, achieving Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria and energy balance checks must be documented and met.",
      "rationale": "Force residuals converged to below 1×10⁻⁴ N for all load steps. Energy balance errors remained below 0.3% across all 11 simulation cases. Solver logs were archived and reviewed by an independent analyst."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be independently reviewed and simulation inputs verified against the test protocol.",
      "rationale": "An independent reviewer verified boundary conditions, material assignments, and load application against the ASTM F1717 test protocol and the laboratory data acquisition records. No use errors were identified. Simulation inputs were locked prior to comparison with experimental data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions must be documented and justified relative to the physics of F1717 compression-bending loading.",
      "rationale": "Linear elastic material models are justified for the metallic screw and rod components under monotonic static loading below yield. Frictional contact (μ=0.3) was assigned at the screw–rod interface based on published tribological data for titanium alloy. Large-displacement formulation was activated to capture geometric nonlinearity at the rod–screw junction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters must be traceable to measured or certified values for each of the N=11 constructs.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and yield strength (880 MPa) were taken from ASTM F136 certificate of conformance for the specific lot used in testing. Screw and rod geometry was measured by coordinate measuring machine with ±0.01 mm accuracy. Construct-specific geometric deviations were incorporated into each of the 11 simulation instances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test sample traceability and dimensional characterization must be documented for all N=11 constructs.",
      "rationale": "All 11 constructs were fabricated from the same material lot and characterized dimensionally prior to testing. Lot traceability records, dimensional inspection reports, and chain-of-custody documentation are archived. Sample-to-sample geometric variation was quantified and propagated into the simulation ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the intended use, or the gap must be justified.",
      "rationale": "Testing was performed at a single compressive load level (1200 N) per ASTM F1717. Variation in load magnitude, load angle, and cyclic loading conditions relevant to in vivo spinal fixation were not evaluated. This factor achieves only Gradation 2 against a required Gradation 3, representing a known gap accepted by the credibility assessment team given the regulatory precedent for F1717 as a standard bench test."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs must be demonstrably equivalent to experimental conditions for each construct.",
      "rationale": "Boundary conditions in the FEA model were mapped directly from the F1717 test fixture geometry. Load application points, fixture compliance, and constraint conditions were matched to laboratory measurements. Equivalency was confirmed by an independent review of the simulation setup documentation against laboratory setup photographs and fixture drawings."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metrics (e.g., NRMSE, prediction interval coverage) must demonstrate acceptable predictive accuracy.",
      "rationale": "Construct stiffness predictions agreed with experimental measurements to within ±8% across all 11 constructs (NRMSE = 5.3%). Failure load predictions were within ±12% for 10 of 11 constructs. Bland-Altman analysis confirmed no systematic bias. These metrics satisfy the pre-specified acceptance threshold of ±15% for Medium assurance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (construct stiffness, failure load) must be directly relevant to the regulatory submission decision.",
      "rationale": "Construct stiffness and static failure load under compression-bending are the primary mechanical performance metrics cited in the FDA guidance for Class II posterior spinal fixation systems. These quantities are directly used in the 510(k) substantial equivalence argument and in design verification against predicate device performance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar to the intended use scenario to support extrapolation of credibility evidence.",
      "rationale": "The validation activity uses the same screw geometry, material, and assembly configuration as the intended regulatory submission construct. The F1717 test protocol is the standard referenced in the FDA predicate device comparison. The validation scenario is therefore directly representative of the COU for the non-cannulated 7.5 mm pedicle screw system, supporting credibility extrapolation at Medium assurance."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for Medium assurance at model risk level 3. The single deficient factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted on the basis of established regulatory precedent for ASTM F1717 as the standard bench test for posterior spinal fixation systems, and because the single-condition gap does not materially affect the regulatory decision for a static compression-bending performance claim. The overall credibility body is sufficient to support a Class II 510(k) submission for the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
