  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-noncannulated-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment outcome is Accepted. Twelve of thirteen V&V 40 factors meet or exceed required levels for model risk level 3. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is accepted given the prescriptive single-condition structure of ASTM F1717 and is documented as a known scope limitation. The FEA ensemble demonstrates sufficient predictive accuracy for construct stiffness and yield load to support the 510(k) regulatory submission for the non-cannulated 7.5 mm pedicle screw.",
