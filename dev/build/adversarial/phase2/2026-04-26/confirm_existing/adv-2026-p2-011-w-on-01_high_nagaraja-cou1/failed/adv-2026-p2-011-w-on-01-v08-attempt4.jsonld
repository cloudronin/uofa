  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA codes (FDA in-house, Ansys 2022 R1, DePuy Synthes internal solver) are under formal SQA plans with documented version control, regression test suites, and release qualification records. Achieved level 3 exceeds the required level 2 for this model risk category."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification evidence must demonstrate correct implementation of underlying mathematical equations.",
      "rationale": "Benchmark problems from the ASME V&V 10 committee and NAFEMS suite were executed for each solver. Results agree with analytical solutions to within 0.5% for linear elastic beam bending, confirming correct numerical implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change less than 5% between successive refinements.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw shank and rod junction. Peak von Mises stress changed by 2.1% between medium and fine meshes. Richardson extrapolation GCI values are below 3% across all QoIs, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms and energy balance must be within solver tolerance thresholds across all load steps.",
      "rationale": "Force and moment residual norms remain below 1e-6 at each Newton-Raphson iteration. Energy balance errors are below 0.1% across all 11 simulated constructs. Solver convergence logs archived in the simulation data package."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented review process must confirm correct model setup, boundary conditions, and loading consistent with ASTM F1717.",
      "rationale": "Independent peer review of simulation input decks was conducted by two engineers not involved in model construction. Boundary conditions, loading magnitudes, and constraint definitions were verified against the ASTM F1717 test protocol. No use errors were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model and contact formulation must be appropriate for the dominant physics of compression-bending in metallic spinal implants.",
      "rationale": "Linear elastic isotropic material model is appropriate given that all experimental constructs remained below yield throughout the ASTM F1717 protocol. Penalty-based frictionless contact at the screw-rod interface is consistent with the lubricated test conditions. Model form uncertainty is bounded by the ensemble spread across three independent implementations."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters must be traceable to measured values with documented uncertainty.",
      "rationale": "Ti-6Al-4V elastic modulus and Poisson ratio sourced from coupon tensile tests on implant-grade bar stock (mean E = 114.2 GPa, CV = 1.3%). Nominal screw geometry obtained from manufacturer CAD with dimensional verification by CMM. Input uncertainty propagated via Latin hypercube sampling across 500 runs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of the production device population with documented lot traceability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs drawn from a single production lot (Lot 2021-NC-75-A). Dimensional inspection confirms all screws within drawing tolerances. Sample size provides 90% confidence in detecting a 15% shift in structural stiffness at 80% power."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios defined in the intended use scope.",
      "rationale": "Testing was conducted at a single load angle (5 degrees from vertical) per ASTM F1717. While this is the standard protocol condition, it does not cover the full range of in vivo load angles anticipated in clinical use. Achieved level 2 falls below the required level 3; this gap is acknowledged and constitutes a known limitation of the validation campaign scope."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to those measured in the physical test.",
      "rationale": "Applied loads and displacement boundary conditions in the FEA are derived directly from load cell and LVDT records from the test frames at both laboratories. Fixture stiffness was characterised and incorporated into the simulation boundary conditions. Equivalency confirmed by overlay of force-displacement curves."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric) must demonstrate agreement within acceptance band.",
      "rationale": "The ASME V&V 20 validation metric U_val was computed for construct stiffness and peak load at 6 mm displacement. All 11 constructs fall within the 95% prediction interval of the FEA ensemble. Mean absolute percentage error is 4.2% for stiffness and 3.8% for peak load, both within the 10% acceptance band."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the performance metrics of concern in the intended use.",
      "rationale": "Construct stiffness and peak bending load are the primary structural performance metrics cited in ASTM F1717 and in the 510(k) submission requirements for non-cannulated pedicle screw systems. These QoIs directly inform the clinical performance claim regarding mechanical integrity under physiological compression-bending loads."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be sufficiently similar in geometry, material, loading, and scale to the intended clinical use context.",
      "rationale": "The ASTM F1717 test protocol uses the same screw geometry, rod diameter, and block spacing as the intended surgical construct. Loading is representative of worst-case physiological compression-bending at the lumbar spine. The two-laboratory design increases generalisability of the validation evidence."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for a model risk level 3 assessment. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is acknowledged; however, the team determined that the ASTM F1717 single-condition protocol is the regulatory standard for this device class and that the remaining factor evidence collectively provides sufficient credibility to support the intended regulatory submission. The overall assurance level is assessed as Medium, consistent with the model risk level and the profile of factor outcomes.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
