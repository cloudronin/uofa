  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Nagaraja COU1 — Non-cannulated pedicle screw compression-bending credibility assessment (Minimal Profile)",
  "description": "V&V 40 credibility assessment for FEA prediction of ASTM F1717 static compression-bending performance of a non-cannulated 7.5 mm pedicle screw construct evaluated under the Minimal profile. The intended use scope — static structural performance prediction for a Class II non-cannulated pedicle screw subjected to compression-bending loads per ASTM F1717 — is described in the bound Requirement and Claim nodes. The FEA model ensemble (FDA, Ansys, DePuy Synthes) is compared against N=11 experimental constructs across two laboratories. All 13 V&V 40 factors have been assessed; one factor (Test conditions) falls below required level due to a single test condition being exercised.",
  "bindsRequirement": "https://uofa.net/synth/req/nagaraja-f1717-compression-bending-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/nagaraja-f1717-fea-compression-bending-claim-001",
  "bindsModel": "https://uofa.net/synth/model/nagaraja-pedicle-screw-fea-ensemble-v1",
  "bindsDataset": [
    "https://uofa.net/synth/data/nagaraja-f1717-experimental-n11-lab1",
    "https://uofa.net/synth/data/nagaraja-f1717-experimental-n11-lab2"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nagaraja-f1717-compression-bending-vr-001",
      "type": "ValidationResult",
      "name": "F1717 compression-bending FEA vs. experimental comparison — N=11 constructs, two laboratories"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041087",
