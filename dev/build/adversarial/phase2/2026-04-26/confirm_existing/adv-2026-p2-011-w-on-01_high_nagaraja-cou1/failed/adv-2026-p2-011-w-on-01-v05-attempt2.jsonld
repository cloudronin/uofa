  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-fda-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors assessed for the FEA prediction of ASTM F1717 compression-bending performance of a non-cannulated 7.5 mm pedicle screw construct. Twelve of thirteen factors meet or exceed the required credibility level for model risk level 3. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3; this gap is accepted because the ASTM F1717 protocol is a standardized single-condition test and the submission claim is explicitly bounded to that test condition. The multi-site FEA ensemble and quantitative output comparison using ASME V&V 20 metrics provide sufficient evidence to support a Medium assurance level determination. Decision: Accepted for pre-market submission support.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
