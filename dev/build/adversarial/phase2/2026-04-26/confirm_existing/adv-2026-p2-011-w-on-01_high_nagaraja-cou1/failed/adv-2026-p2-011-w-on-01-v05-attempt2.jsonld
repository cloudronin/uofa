  "signature": "ed25519:b1d4e7a2f09c3e6b8d1f4a7c2e5b8d1f4a7c2e5b8d1f4a7c2e5b8d1f4a7c2e5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical 2021 R2 is a commercially validated finite element solver with documented V&V procedures. FDA in-house solver underwent independent code verification per internal SOP. DePuy Synthes FEA environment operates under ISO 9001-certified quality management system. All three ensemble members satisfy SQA requirements at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Each FEA code in the ensemble was verified against NAFEMS benchmark problems relevant to contact mechanics and large-deformation elasto-plasticity. Patch tests and manufactured-solution comparisons confirm correct implementation of the constitutive models used for Ti-6Al-4V and UHMWPE."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Systematic mesh convergence study performed on screw-rod interface region and UHMWPE block. Richardson extrapolation applied; discretization error in peak von Mises stress at critical cross-section estimated at 1.8%, below the 5% threshold. Three mesh densities evaluated (coarse, medium, fine) with GCI < 2%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver residuals monitored to 1e-6 relative tolerance for all load steps. Nonlinear contact iterations converged with force and displacement residuals below prescribed thresholds. Energy balance checked at each increment; artificial energy fraction < 0.1% confirming hourglass control adequacy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup reviewed by a second qualified analyst independent of the primary modeler at each of the three ensemble sites. Boundary conditions, material assignments, and contact definitions documented in a controlled model specification sheet and cross-checked against the ASTM F1717 test fixture geometry drawings."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Continuum isotropic elasto-plastic constitutive model with bilinear hardening applied to Ti-6Al-4V per ASTM E8 coupon data. Frictional contact (mu=0.2) at screw-rod interface validated against torque-to-turn measurements. Model form uncertainty quantified via comparison of linear vs. nonlinear geometry assumptions; nonlinear geometry adopted as the more physically representative form."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties sourced from lot-specific tensile testing of the Ti-6Al-4V rod and screw stock used in the N=11 experimental constructs. UHMWPE modulus measured by DMA. Geometric dimensions verified by CMM measurement of five representative screws. Sensitivity analysis confirms stiffness QoI varies less than 4% across measured material property ranges."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 constructs assembled from production-equivalent screws and rods drawn from the same manufacturing lot as clinical devices. Sample size supports statistical comparison at 80% power for a 10% difference in stiffness. Inter-laboratory variability assessed across two independent test sites."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed at a single load level (400 N axial compression with 10 Nm bending moment) per ASTM F1717. Only one test condition evaluated; multi-level loading or varied moment arms were not included in this validation campaign. This factor is below the required level and constitutes a documented gap; risk accepted given the standardized nature of the F1717 protocol and the bounded scope of the submission claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions replicate the ASTM F1717 fixture kinematics including pin-joint articulation at the loading blocks. Applied displacement ramp matches the 5 mm/min crosshead rate used experimentally. Screw insertion torque applied in the model via pre-tension elements calibrated to the 8 Nm assembly torque recorded during specimen build."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantitative comparison performed using ASME V&V 20 area validation metric. FEA ensemble mean construct stiffness within 6.2% of experimental mean (experimental: 312 ± 18 N/mm; FEA ensemble: 332 ± 11 N/mm). Yield load predictions within 8.1% of experimental mean. U95 uncertainty bounds overlap for all three ensemble members."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantities of interest — construct stiffness and yield load — are the primary regulatory endpoints specified in FDA guidance for spinal pedicle screw systems under 21 CFR 888.3070. These QoIs directly map to the clinical performance claim regarding fatigue initiation margin under physiological loading."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities conducted using the same 7.5 mm non-cannulated pedicle screw geometry and rod diameter as the device under submission. ASTM F1717 test configuration is the accepted regulatory surrogate for in vivo spinal loading. Ensemble approach across three independent modeling teams increases confidence in the generalizability of the validation finding to the COU."
    }
  ],
