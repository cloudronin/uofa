  "signature": "ed25519:9b3e1d7f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk level.",
      "rationale": "The FEA software (Ansys Mechanical 2021 R2) is operated under a validated installation qualification and operational qualification protocol. Version-controlled input decks and regression test suites confirm reproducibility across analyst workstations at FDA and DePuy Synthes sites."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Patch tests and single-element benchmarks confirm element formulation correctness. Comparison against Timoshenko beam analytical solutions for the screw shank demonstrates less than 0.5% error in peak bending stress."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "A three-level mesh convergence study (coarse, medium, fine) was conducted on the pedicle screw thread region. The Grid Convergence Index for peak von Mises stress is 1.8%, below the 5% acceptance threshold. Final mesh contains 487,000 second-order tetrahedral elements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver residuals converge to below 1e-6 for all load steps. Load-stepping sensitivity analysis confirms no path-dependent numerical drift across the 0–400 N applied compressive load range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation protocols are documented in a controlled SOP. Independent analyst re-execution of the model from raw geometry files confirmed identical results. A use-error FMEA identified boundary condition misapplication as the primary risk; mitigation includes a mandatory peer-review checklist."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic material constitutive law is justified for the titanium alloy (Ti-6Al-4V) screw and UHMWPE vertebral body surrogate under sub-yield loading. Contact between screw and block is modeled as frictional (mu=0.3) with augmented Lagrangian enforcement. Model form assumptions are consistent with ASTM F1717 loading regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties sourced from certified material test reports for each lot of Ti-6Al-4V. Geometric inputs derived from CMM measurements of production screws (n=5 per lot). Uncertainty in elastic modulus (±2 GPa) propagated via one-at-a-time sensitivity analysis; effect on QOI is less than 3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 production non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. Samples drawn from the same production lot used for the FEA geometry reference. Dimensional inspection confirms screws are within drawing tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed at a single load level (400 N compression with 10 Nm bending moment) per ASTM F1717. The required level of 3 is not achieved because only one test condition was exercised; multi-load-level testing was not feasible within the study scope. This gap is acknowledged and accepted given the conservative nature of the single condition relative to clinical loading."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Boundary conditions in the FEA replicate the ASTM F1717 fixture geometry, including the 10-degree caudal inclination and the fixed-free end constraint. Applied loads and moments are matched to machine-recorded values from the experimental tests within 0.5%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Predicted construct stiffness (N/mm) and peak screw bending moment (N·mm) are compared against experimental measurements. The validation metric is the normalized root mean square error (NRMSE). NRMSE for stiffness is 4.2% and for bending moment is 5.7%, both within the pre-specified 10% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The quantities of interest — construct stiffness and peak screw bending moment — directly correspond to the mechanical performance endpoints specified in the 510(k) submission plan for the non-cannulated pedicle screw system. Clinical relevance is established by mapping these QOIs to fatigue life prediction inputs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The validation scenario — ASTM F1717 static compression-bending of the identical non-cannulated 7.5 mm screw geometry — is the primary intended use scenario for this FEA model. Validation activities are therefore directly relevant to the claim scope as described in the submission requirement documentation and the bindsClaim and bindsRequirement nodes of this assurance package."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors were assessed. Twelve of thirteen factors achieve or exceed the required credibility level for a Model Risk Level 3 device at Medium assurance. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is accepted on the basis that the single ASTM F1717 test condition is conservative relative to expected clinical loading and that all other factors provide compensating confidence. The ensemble FEA predictions fall within pre-specified acceptance thresholds for both stiffness and bending moment QOIs. The assessment team concludes that the simulation credibility is sufficient to support the intended 510(k) submission use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
