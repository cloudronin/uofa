    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-fea-f1717-compression-result-002",
      "type": "ValidationResult",
      "name": "FDA/Ansys/DePuy Synthes ensemble agreement assessment for non-cannulated 7.5 mm construct"
    }
  ],
