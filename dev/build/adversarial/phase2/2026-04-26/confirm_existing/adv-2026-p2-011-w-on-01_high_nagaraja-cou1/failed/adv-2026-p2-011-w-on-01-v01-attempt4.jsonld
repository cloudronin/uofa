  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted despite Test Conditions factor (achieved level 2, required level 3). Engineering judgment by the credibility assessment team, concurred by regulatory affairs, concludes that the single-condition shortfall does not undermine the overall credibility determination for static compression-bending performance prediction of the non-cannulated 7.5 mm pedicle screw construct. All 12 remaining factors meet or exceed required levels. Model risk level 3 is appropriately matched by the depth of validation evidence provided. Submission to FDA 510(k) pathway authorized.",
