      "name": "Yield load prediction vs. experimental — within 12% across both laboratories"
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-f1717-result-failure-load",
      "type": "ValidationResult",
      "name": "Failure load prediction vs. experimental — conservative bias confirmed, model under-predicts by mean 6%"
    }
  ],
