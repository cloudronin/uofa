  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA solver must have documented verification test suite and version-controlled release process.",
      "rationale": "Ansys Mechanical 2021 R2 is used under a validated installation qualification protocol; FDA in-house solver has formal V&V documentation per NIST SP 1800-25. Version control enforced via Git tags for all pre-processing scripts. Achieved level exceeds required."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must reproduce at least two NAFEMS benchmark problems relevant to structural contact and large-displacement bending to within 2% of reference solution.",
      "rationale": "Ansys Mechanical verified against NAFEMS LE1 and LE10 benchmarks; FDA solver verified against cantilever beam and Hertzian contact reference solutions. All results within 1.4% of reference. Requirement met at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QOI change less than 5% between successive refinements; Richardson extrapolation or GCI must be reported.",
      "rationale": "Three-level mesh refinement study performed on screw-rod interface region. GCI for construct stiffness QOI = 1.8%; GCI for von Mises peak stress = 3.2%. Both below 5% threshold. Element size in critical region: 0.15 mm at final level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps; energy balance error must be below 0.1%.",
      "rationale": "Nonlinear Newton-Raphson iterations converge to force residual norm below 1e-7 for all 22 load steps. Energy balance error 0.04%. Automatic time-stepping with bisection confirmed stable convergence throughout displacement-controlled loading protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be reviewed by an independent analyst; boundary condition application must be documented and traceable to ASTM F1717 test fixture geometry.",
      "rationale": "Independent peer review of model setup performed by second FEA engineer not involved in original construction. Boundary conditions traced to F1717 fixture drawings (DePuy Synthes fixture DWG-4471-B). No use errors identified. Review checklist archived."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection must be justified against material characterization data; contact formulation must be appropriate for the interface mechanics observed experimentally.",
      "rationale": "Titanium alloy (Ti-6Al-4V) represented by bilinear isotropic hardening calibrated to tensile coupon data (n=6 coupons, R²=0.998). Augmented Lagrangian contact with friction coefficient μ=0.3 (measured via pin-on-disk tribometry on implant surface finish). Model form justified by sensitivity study showing <4% QOI sensitivity to ±20% friction variation."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and geometric inputs must be traceable to measured values with reported uncertainty; sensitivity analysis must identify dominant input parameters.",
      "rationale": "Elastic modulus: 114 ± 3 GPa from coupon testing. Yield strength: 880 ± 15 MPa. Screw geometry digitized from CMM measurements (n=3 screws, dimensional tolerance ±0.01 mm). Sensitivity analysis via one-at-a-time perturbation identifies elastic modulus and screw minor diameter as dominant inputs. Uncertainty propagation via Monte Carlo (n=1000) shows QOI 95% CI within ±9% of nominal."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental sample set must be representative of production implants; sample size must support statistical comparison at 80% power.",
      "rationale": "N=11 constructs assembled from production-lot pedicle screws (7.5 mm diameter, non-cannulated) and 5.5 mm rods tested across two independent laboratories. Screws from same production lot used in FEA geometry digitization. Power analysis confirms 80% power to detect 10% difference in stiffness at α=0.05. Sample representativeness confirmed by dimensional audit."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span clinically relevant loading range including at least two load levels or two fixture configurations to assess model generalizability.",
      "rationale": "Testing conducted at single load condition per ASTM F1717 (5 mm/min displacement-controlled, 10° offset angle). Only one test configuration evaluated. This factor falls below required level 3; engineering judgment applied that single-condition shortfall does not invalidate overall credibility for the static compression-bending regulatory context, given high fidelity of all other factors."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to experimental conditions; any deviations must be quantified and their impact assessed.",
      "rationale": "Material properties, geometry, boundary conditions, and loading rate in FEA matched to experimental records. Crosshead displacement rate equivalence confirmed; quasi-static assumption validated by strain-rate sensitivity study showing <1% rate effect at 5 mm/min. Fixture compliance measured experimentally and incorporated into FEA boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., MAPE, normalized error) must be reported for all primary QOIs; comparison must account for experimental variability.",
      "rationale": "MAPE for construct stiffness: 6.2% (experimental COV 8.1%); MAPE for yield load: 9.4% (experimental COV 11.3%); MAPE for failure load: 7.8% (experimental COV 9.7%). Model predictions fall within experimental ±2σ band for all QOIs across both laboratories. Bland-Altman analysis confirms no systematic bias in stiffness prediction. Achieved level 4 reflects rigorous statistical comparison methodology."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs used in validation must be directly relevant to the clinical performance metrics of interest for the device submission.",
      "rationale": "Construct stiffness, yield load, and failure load under compression-bending are the primary mechanical performance metrics specified in ASTM F1717 and referenced in FDA guidance for spinal fixation systems. These QOIs directly inform the structural adequacy claim for the pedicle screw construct in posterior lumbar fusion applications. Relevance confirmed by regulatory affairs review."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar to the intended clinical use scenario that extrapolation risk is low and documented.",
      "rationale": "ASTM F1717 test configuration is the regulatory standard for spinal fixation construct mechanical testing and directly represents the biomechanical loading environment of posterior lumbar instrumentation. Validation activity geometry, material, and loading are production-representative. Extrapolation from bench test to clinical use is standard practice per FDA guidance; similarity argument documented in validation plan VP-2023-047."
    }
  ],
