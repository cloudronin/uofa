  "signature": "ed25519:9b1c3d5e7f2a4b6c8d0e1f3a5b7c9d1e3f5a7b9c1d3e5f7a9b1c3d5e7f2a4b6c",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk level.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated solver with documented QA procedures per ISO 9001. FDA and DePuy Synthes sites each maintain independent QA records. Achieved level 3 satisfies required level 2 for medium model risk."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including patch tests and manufactured-solution checks were executed across all three modeling sites. Results agreed to within 0.5% of analytical solutions, confirming correct code implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Systematic mesh convergence study performed with three refinement levels. Richardson extrapolation applied; GCI for stiffness QoI was 1.8%, below the 5% threshold. Final mesh selected at convergence plateau."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Nonlinear Newton-Raphson solver used with tight residual convergence criteria (force norm < 1e-4). Iterative convergence confirmed for all load steps. No divergence events observed across 11 model instances."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Modeling protocol documented in a controlled SOP reviewed by senior analysts at each site. Independent cross-checks of boundary condition application and material property assignment performed. No use errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic model form selected based on pre-yield loading regime. Titanium alloy Ti-6Al-4V modeled with isotropic elasticity; literature and coupon test data support this assumption for the strain levels encountered. Contact at screw-rod interface modeled with penalty formulation validated against analytical contact benchmarks."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties derived from ASTM E8 tensile coupon tests on production-lot Ti-6Al-4V (E=114 GPa, nu=0.33). Geometric inputs digitized from CMM measurements of each physical specimen. Input uncertainty quantified and propagated via Monte Carlo sampling (n=1000)."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from production inventory tested. Specimens span two independent laboratories to assess inter-laboratory variability. Sample-to-sample geometric variability characterized by CMM and incorporated into model inputs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level. This factor does not meet the required level; risk accepted with documented rationale.",
      "rationale": "Testing conducted at a single compression-bending load angle per ASTM F1717 protocol. Only one test condition evaluated, limiting coverage of the loading space. Required level 3 not achieved; achieved level 2. Residual risk accepted because the single condition is the regulatory standard condition and no alternative loading configuration is clinically indicated for this device class."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "One-to-one mapping established between experimental boundary conditions (fixed inferior block, displacement-controlled superior loading head) and FEA constraints. Fixture compliance characterized experimentally and incorporated into model boundary conditions. Equivalency confirmed by sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantitative comparison using E_avg metric per ASME V&V 40. Mean absolute percentage error for stiffness: 4.2%; for yield load: 5.8%. Both within the 10% acceptance threshold. Prediction intervals overlap experimental scatter bands for all 11 specimens."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantities of interest — construct stiffness (N/mm) and yield load (N) — are directly specified in the regulatory submission performance criteria and are the primary mechanical endpoints for ASTM F1717 clearance. QoIs are clinically relevant surrogates for in vivo fixation stability."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities replicate the exact ASTM F1717 test configuration specified for the intended regulatory use. Device geometry, material, loading mode, and boundary conditions in validation experiments match the COU as described in the 510(k) submission. High relevance confirmed by clinical and regulatory subject matter experts."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for medium model risk. The single shortfall in Test conditions (achieved level 2 vs required level 3) is accepted because the ASTM F1717 single-condition protocol is the regulatory standard and no additional loading conditions are required for the intended 510(k) use. Overall credibility is sufficient to support regulatory decision-making for this Class II device.",
