  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "Ansys Mechanical R19.2 is a commercially validated solver with documented QA procedures including regression testing and ISO 9001 certification. FDA internal verification protocols were applied. Required level 2 is satisfied by achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including cantilever beam bending and contact patch tests were executed and results compared to analytical solutions within 1%. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed with three mesh densities (coarse, medium, fine). Peak von Mises stress and reaction force at yield differed by less than 2% between medium and fine meshes. Richardson extrapolation applied. Required level 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Nonlinear solver residuals monitored to convergence tolerance of 1e-4 for force and displacement norms. No solver divergence events observed across 11 construct configurations. Required level 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model inputs and boundary condition assignments were independently reviewed by a second analyst. Simulation setup checklist was completed and archived. Required level 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for a model risk level 3 assessment.",
      "rationale": "Continuum elastoplastic material model with isotropic hardening selected based on literature precedent for Ti-6Al-4V pedicle screw constructs. Frictional contact at screw-rod interface modeled with Coulomb friction coefficient validated against pull-out data. Required level 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (elastic modulus, yield strength, tangent modulus) sourced from ASTM-certified coupon testing of the same material lot used for experimental constructs. Geometric dimensions digitized from CT scans of test articles. Required level 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 production-representative constructs tested across two independent laboratories using calibrated load frames. Sample size exceeds minimum for statistical comparison. Construct geometry verified against design drawings. Required level 2 exceeded at achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed at a single load angle (7.5° per ASTM F1717 default) only. Required level 3 would necessitate multiple load angles or boundary condition variations to span the clinical loading envelope. Single condition tested results in achieved level 2, which is below required level 3. This shortfall is acknowledged and accepted given the conservatism of the F1717 protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 fixture geometry including vertebral body block spacing, superior/inferior potting depths, and axial-bending load application point. Fixture compliance measured and incorporated. Required level 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Yield load and construct stiffness compared using mean absolute percentage error (MAPE) and 95% prediction interval overlap. MAPE for yield load was 4.2% and for stiffness was 5.8% across the N=11 constructs. Bayesian model averaging applied across ensemble members. Required level 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantities of interest (yield load, construct stiffness) are the primary regulatory endpoints for ASTM F1717 compression-bending evaluation and directly inform the 510(k) substantial equivalence determination for the Class II pedicle screw system. Required level 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities directly replicate the ASTM F1717 test protocol that constitutes the COU. The same screw geometry, material, and construct configuration used in validation are those submitted for regulatory review. Validation-to-COU relevance is high. Required level 3 met.",
      "note": "The intended-use scope — quasi-static compression-bending of a non-cannulated 7.5 mm pedicle screw under ASTM F1717 boundary conditions for Class II 510(k) submission — is described in the prose of the associated Claim and Requirement nodes and reflected in the validation activity design. Reviewers should refer to claim https://uofa.net/synth/claim/nagaraja-fea-yield-load-stiffness-claim-001 and requirement https://uofa.net/synth/req/nagaraja-f1717-compression-bending-req-001 for the full use-scope definition."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted at Medium assurance level. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is accepted given the conservatism inherent in the ASTM F1717 single-condition protocol and the regulatory precedent for its use in 510(k) submissions for Class II spinal fixation devices. The FEA ensemble demonstrates sufficient predictive fidelity for yield load and construct stiffness to support pre-market submission. Intended use scope is articulated in the Claim and Requirement nodes referenced by this package.",
