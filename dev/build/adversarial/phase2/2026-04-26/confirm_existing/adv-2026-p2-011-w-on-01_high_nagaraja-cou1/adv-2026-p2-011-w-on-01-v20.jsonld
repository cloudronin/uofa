  "signature": "ed25519:b2e4d6f8a0c2e4f6a8b0d2f4a6c8e0b2d4f6a8c0e2f4b6d8a0c2e4f6a8b0d2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated solver with documented QA procedures per ISO 9001. FDA-internal solver underwent independent verification testing. DePuy Synthes in-house FEA tool is qualified under design-control procedures (21 CFR Part 820). All three software instances meet or exceed Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from NAFEMS suite (LE1, LE10) were solved by each code instance; results agreed with analytical solutions to within 0.5%. Cross-code comparison across the three ensemble members showed stiffness predictions within 2% of each other, confirming numerical implementation consistency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed on the pedicle screw shank and rod interface regions using three mesh densities (coarse, medium, fine). Richardson extrapolation yielded a discretization error estimate of less than 1.8% for peak von Mises stress and less than 0.9% for construct stiffness. Final mesh selected at medium density with verified convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver residuals monitored; force and displacement convergence tolerances set to 0.1% and 0.5% respectively. No divergence events observed across 11 simulation runs. Contact stabilization energy confirmed below 1% of total strain energy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation inputs reviewed by a second qualified analyst independent of the model developer. Boundary conditions, material assignments, and contact definitions were verified against the simulation specification document. No use errors identified during review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic constitutive model is appropriate for stiffness and yield-load prediction under quasi-static loading below material yield. Geometric nonlinearity (large deformation) is activated to capture rod bending kinematics. Frictional contact (mu=0.3) at screw-rod interface is physically motivated and sensitivity-tested. Model form assumptions are documented and justified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (Ti-6Al-4V: E=114 GPa, yield=880 MPa) sourced from ASTM F136 and confirmed by coupon tensile testing of production-lot material. Geometry derived from CAD nominal dimensions with dimensional inspection confirming as-built specimens within 0.05 mm tolerance. Sensitivity analysis on friction coefficient (0.2–0.4) showed less than 3% effect on stiffness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 physical constructs assembled from production-representative components (6 at Lab A, 5 at Lab B). Components drawn from the same manufacturing lot. Dimensional inspection confirmed geometric conformance. Inter-laboratory coefficient of variation for stiffness was 4.2%, confirming adequate sample consistency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed at a single loading rate (5 mm/min) and single construct configuration per ASTM F1717. While this is the standard protocol, only one test condition was exercised, limiting confidence that model predictions generalize across loading rates or angular offsets. This factor is below the required level and is identified as a gap in the credibility assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 fixture geometry: superior block fixed, inferior block loaded at 5 mm/min axial displacement. Fixture compliance characterized and incorporated. Material properties used in simulation match measured values from production-lot coupons. Input equivalency confirmed by traceability matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantities of interest (construct stiffness and yield load) compared using validation metric of mean absolute percentage error (MAPE). FEA ensemble mean stiffness MAPE = 7.3%; yield load MAPE = 5.9%. Both within the pre-specified acceptance threshold of 15%. Uncertainty quantification performed; 95% prediction interval of FEA ensemble encompasses 10 of 11 experimental observations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and yield load are the regulatory quantities of interest for ASTM F1717 submission. These quantities directly inform the clinical decision regarding structural adequacy of the pedicle screw system under worst-case static loading. Relevance to the intended submission context is documented in the regulatory strategy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities replicate the ASTM F1717 test protocol that constitutes the regulatory submission requirement. The model is applied to predict performance of the same device geometry, material, and configuration as tested. Validation domain is coincident with the intended submission use. Relevance is rated high despite the single test-condition gap noted under Test conditions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the non-cannulated 7.5 mm pedicle screw FEA model under ASTM F1717 compression-bending loading is accepted at Medium assurance level. Twelve of thirteen V&V 40 factors meet or exceed their required levels. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is acknowledged; the review board determined that the ASTM F1717 protocol is a single standardized condition and that no additional loading conditions are required for the intended regulatory submission. The ensemble approach across three independent FEA implementations provides additional confidence. Overall credibility is sufficient to support the 510(k) submission claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
