  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) must have documented verification test suite results and traceable version control consistent with Model Risk Level 3 requirements.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated solver with published verification manuals. FDA and DePuy Synthes instances ran identical solver version under configuration-controlled environments. NIST traceability of material property inputs confirmed. Achieved level exceeds required level for MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems representative of compression-bending contact mechanics must be solved with documented agreement to analytical or published reference solutions within 2%.",
      "rationale": "Cantilever beam and Hertzian contact benchmark problems solved in Ansys; results agreed with analytical solutions to within 1.4%. Nonlinear geometric effects verified against NAFEMS benchmark LE10. Required level met exactly."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that quantities of interest (peak von Mises stress at screw-rod interface, construct stiffness) change by less than 5% between successive refinement levels.",
      "rationale": "Three-level mesh refinement study performed on the non-cannulated 7.5 mm screw geometry. Construct stiffness changed by 2.1% and peak interface stress by 3.8% between medium and fine meshes. Richardson extrapolation applied; GCI < 4%. Required level met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps; contact status must be monitored for chattering across all increments.",
      "rationale": "Sparse direct solver (SPARSE) employed for all analyses. Residual norms fell below 1e-7 for every load step. Contact status monitored; no chattering detected across 120 load increments. Newton-Raphson convergence achieved in ≤8 iterations per step."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup procedures must be documented in a simulation plan reviewed by an independent analyst; boundary condition application must be verified against ASTM F1717 fixture geometry.",
      "rationale": "Simulation plan reviewed by independent FDA analyst prior to execution. Boundary conditions replicated ASTM F1717 fixture offsets (±2 mm tolerance confirmed). Independent re-run at DePuy Synthes produced results within 1.9% of FDA baseline, confirming procedural robustness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection (linear elastic titanium alloy Ti-6Al-4V) must be justified relative to expected strain range; geometric nonlinearity must be included given expected deflections.",
      "rationale": "Peak strains in screw body estimated at 0.18%, within linear elastic regime for Ti-6Al-4V (E=114 GPa, ν=0.34). Large-displacement formulation (NLGEOM ON) activated to capture geometric stiffening under bending. Model form consistent with prior FDA FEA guidance for spinal implants."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions must be sourced from traceable measurements on production-representative hardware; uncertainty bounds must be quantified.",
      "rationale": "Ti-6Al-4V material properties sourced from ASTM B265 mill certificates for production lot. Screw geometry digitized via CMM with ±0.01 mm accuracy. Sensitivity analysis on E ±5% showed <2% variation in stiffness QoI. Input uncertainty propagation documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 experimental constructs must be from production-representative hardware; dimensional inspection records must confirm conformance to drawing tolerances.",
      "rationale": "All 11 constructs assembled from production-lot non-cannulated 7.5 mm pedicle screws and UHMWPE test blocks per ASTM F1717. CMM inspection confirmed dimensional conformance. Constructs split across two independent laboratories to assess inter-laboratory variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the clinically relevant loading range; at minimum two load levels or two construct configurations must be evaluated to assess model predictive range.",
      "rationale": "Testing performed under a single quasi-static compression-bending condition per ASTM F1717 protocol. Only one load configuration evaluated, limiting assessment of model predictive range across the full clinical loading envelope. This factor is below required level; risk accepted given that the single condition represents the worst-case regulatory submission scenario."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading must be demonstrably equivalent to experimental fixture setup; offset distances and constraint locations must match within measurement uncertainty.",
      "rationale": "ASTM F1717 fixture offset (44.45 mm) replicated in FEA to within 0.1 mm. Constraint locations confirmed against laboratory fixture drawings supplied by both test labs. Actuator load application modeled as displacement-controlled to match test protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted construct stiffness and failure load must agree with experimental mean within 10% MAPE; prediction intervals must be reported.",
      "rationale": "FEA ensemble predicted mean stiffness within 6.3% MAPE relative to N=11 experimental mean. Failure load predictions fell within ±1.5 standard deviations of experimental distribution. Bland-Altman analysis confirmed no systematic bias. Required level met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (construct stiffness, peak interface stress, failure load) must be directly linked to the regulatory decision criterion for ASTM F1717 substantial equivalence.",
      "rationale": "Construct stiffness and failure load are the primary ASTM F1717 acceptance metrics cited in FDA guidance for spinal fixation 510(k)s. Peak screw-rod interface stress is the secondary QoI informing fatigue life estimation. All QoIs directly relevant to the regulatory submission decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use hardware, loading, and boundary conditions sufficiently similar to the intended regulatory use scenario to support extrapolation of model credibility.",
      "rationale": "Validation constructs used production-representative non-cannulated 7.5 mm pedicle screws under ASTM F1717 compression-bending — the identical configuration submitted for 510(k) clearance. Two-laboratory design strengthens generalizability. Validation scenario is judged highly relevant to the intended regulatory use."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for Model Risk Level 3. The single deficient factor (Test conditions, achieved level 2 vs. required level 3) reflects the single-condition ASTM F1717 protocol; the assessment team judged this acceptable given that the tested condition represents the regulatory worst-case scenario and that all other factors provide sufficient compensating evidence. Overall credibility is assessed as Medium, consistent with the assurance level required for a Class II 510(k) submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
