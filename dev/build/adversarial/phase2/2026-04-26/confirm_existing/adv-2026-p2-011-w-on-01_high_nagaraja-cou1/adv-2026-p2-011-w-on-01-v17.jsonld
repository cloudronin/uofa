  "signature": "ed25519:b2e4f1a7c3d509e6f2b8a4c1d7e3f09a5b2c8d4e1f7a3b6c9d2e5f0a4b7c3d8e1f5a2b9c6d3e0f7a4b1c8d5e2f9a6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA codes (FDA in-house, Ansys Mechanical 2022 R2, DePuy Synthes internal solver) operate under documented software quality management systems with version control, regression test suites, and traceable change logs. ISO 9001-certified QMS records provided for commercial codes; FDA in-house code subject to internal SQA procedure SOP-COMP-007."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Code verification demonstrated through benchmark problems from NAFEMS and internal patch-test suites. Ansys and DePuy Synthes codes verified against ASME V&V 10.1 benchmark set. FDA in-house code verified via method-of-manufactured-solutions for the relevant contact and nonlinear material formulations."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Systematic mesh convergence study performed on the pedicle screw shank and rod interface regions using three mesh densities (coarse, medium, fine). Richardson extrapolation applied to stiffness and yield load QoIs; GCI values below 2% for the production mesh. Hex-dominant meshing used throughout load-bearing sections."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Newton-Raphson iteration convergence monitored with force and displacement residual norms below 1e-4. Augmented Lagrange contact formulation used; penetration tolerance set to 0.01 mm. Energy balance checked at each load step; no spurious energy accumulation observed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Independent analyst review of model setup performed by a second engineer at each participating organisation. Boundary condition application, material assignment, and contact pair definitions verified against a common modelling protocol document. Discrepancies resolved prior to result extraction."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Nonlinear isotropic hardening plasticity (Chaboche) used for titanium alloy screw and rod. Frictional contact with Coulomb model (mu=0.2) at screw-rod interface. Model form validated against independent coupon-level material tests and prior published ASTM F1717 simulation studies. Assumptions documented in model description report MDR-2023-001."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties derived from lot-specific tensile coupon tests on Ti-6Al-4V ELI per ASTM E8. Geometric dimensions measured via CMM on three representative screws and rods from the same production lots as test constructs. Locking torque applied in simulation matches calibrated torque wrench values recorded during test specimen assembly."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 constructs (6 Lab 1, 5 Lab 2) assembled from production-representative hardware. Dimensional inspection records confirm all constructs within drawing tolerances. Traceability maintained from raw material certificates through assembly and test. Sample size sufficient for statistical characterisation of variability in stiffness and yield load."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; shortfall documented and risk-accepted by sponsor.",
      "rationale": "Testing performed at a single compression-bending angle (5 degrees) per ASTM F1717 protocol. The required level of 3 would demand evaluation across multiple load angles representative of in vivo variability; only one angle was evaluated. This shortfall was identified, documented, and accepted by the device sponsor as low additional risk given the conservative nature of the 5-degree condition. Overall assurance level remains Medium."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions replicate test fixture geometry including UHMWPE block embedding depth, pin diameter, and specimen span. Applied displacement rate in quasi-static simulation matched to experimental crosshead speed of 5 mm/min; inertial effects confirmed negligible. Fixture compliance characterised experimentally and incorporated into post-processing."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantitative comparison using normalised root-mean-square error (NRMSE) on load-displacement curves and scalar metrics (construct stiffness, 0.2% offset yield load). NRMSE below 8% across all 11 constructs and all three FEA codes. Bland-Altman analysis confirms no systematic bias. Uncertainty in experimental measurements propagated and shown to be smaller than model-experiment discrepancy."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "QoIs (construct stiffness and yield load) directly correspond to the biomechanical performance attributes cited in the device's 510(k) predicate comparison and the FDA guidance on spinal fixation systems. Peak screw shank stress used as secondary QoI to support fatigue life estimation in the broader submission package."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activity replicates the exact ASTM F1717 test configuration specified in the intended regulatory submission. Hardware used in validation is from the same design family and manufacturing process as the commercial device. Loading mode (compression-bending) is the primary in vivo loading scenario for posterior spinal fixation. Validation scope therefore directly supports the claim that the FEA model reliably predicts construct structural performance for the submission use case."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels for a model risk level 3 assessment. The single shortfall in Test Conditions (achieved level 2 vs. required level 3) has been reviewed, documented, and accepted by the device sponsor as presenting low incremental risk given the conservatism of the single test condition evaluated. The FEA ensemble demonstrates consistent agreement with experimental data across two independent laboratories, with NRMSE below 8% on all primary QoIs. Overall credibility is judged sufficient to support use of the model ensemble in a Class II 510(k) pre-market submission for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending loading.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
