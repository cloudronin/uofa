      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA solvers (Abaqus, Ansys Mechanical, COMSOL) are commercially validated and maintained under ISO 9001-compliant QMS. Version control records and release notes were reviewed and confirmed current for the analysis versions used."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Patch tests and benchmark problems from NAFEMS suite were executed for each solver; residual norms and energy balance checks confirmed correct implementation of linear-elastic and elastic-plastic constitutive routines."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "A three-level mesh convergence study was performed on the screw-rod assembly. The quantity of interest (construct stiffness) changed by less than 2% between the medium and fine meshes; Richardson extrapolation confirmed the discretization error is below 3% for all reported outputs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver convergence was verified via force and displacement residual tolerances set to 1e-6. No divergence events were recorded across the ensemble runs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation execution was performed by two independent analysts following a documented simulation plan. Results were cross-checked by a senior reviewer; no discrepancies attributable to operator error were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear-elastic isotropic material models are appropriate for the titanium alloy screw and PEEK rod under sub-yield loading; a bilinear isotropic hardening model captures post-yield behaviour. Model form assumptions are consistent with published literature for ASTM F1717 FEA studies."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (E, ν, σ_y) were sourced from certified material test reports for the specific lot used in the experimental constructs. Geometric dimensions were derived from CMM measurements of five representative screws, with uncertainty bounds propagated through the model."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Eleven production-representative non-cannulated 7.5 mm pedicle screw constructs were tested across two laboratories. Samples were drawn from the same manufacturing lot as the device under evaluation, ensuring material and geometric traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; shortfall documented with risk acceptance.",
      "rationale": "Testing was performed at a single compressive load level per ASTM F1717 protocol. Evaluation across multiple load magnitudes or loading angles was not conducted, limiting confidence in model accuracy across the full operating envelope. This shortfall is accepted given the conservative single-condition assessment approach."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Boundary conditions in the FEA (fixed inferior vertebral body block, displacement-controlled superior loading block) replicate the ASTM F1717 test fixture kinematics. Contact conditions at the screw-block interface were calibrated against measured fixture compliance."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Predicted construct stiffness and yield load were compared against experimental means using normalised root-mean-square error (NRMSE < 8%) and Bland-Altman analysis. All FEA predictions fell within the 95% experimental confidence interval."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and yield load are the primary regulatory quantities specified in ASTM F1717 and directly correspond to the clinical decision criteria for spinal implant mechanical adequacy. No surrogate quantities are relied upon."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The validation activities replicate the ASTM F1717 compression-bending configuration applied to the same non-cannulated 7.5 mm screw geometry and material system as the device under evaluation. The validation domain closely matches the intended regulatory submission context."
    }
  ],
