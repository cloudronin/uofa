  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen ASME V&V 40 credibility factors meet or exceed the required gradation for model risk level 3. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is accepted on the basis that the single-condition ASTM F1717 protocol represents the conservative worst-case loading scenario specified by the applicable standard, and the overall simulation credibility is sufficient to support the pre-market submission decision for this Class II non-cannulated pedicle screw construct.",
