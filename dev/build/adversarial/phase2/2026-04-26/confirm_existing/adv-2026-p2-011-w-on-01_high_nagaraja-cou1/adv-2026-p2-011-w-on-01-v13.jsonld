  "signature": "ed25519:7f4a2c1e9b3d6f0a8e5c2b4d7a1f3e9c6b0d4a8f2e7c5b1d9a3f6e0c4b8d2a5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used in the FEA ensemble must be validated commercial code with documented version control, regression testing, and audit trail per 21 CFR Part 11 requirements.",
      "rationale": "Ansys Mechanical 2022 R2 and the FDA in-house FEA solver are both operated under validated software quality systems. Version control, regression test suites, and electronic audit trails are documented. Achieved level exceeds required level for a Model Risk Level 3 submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks must demonstrate correct implementation of linear elastic and contact formulations against analytical solutions or published benchmarks.",
      "rationale": "Patch test, Hertzian contact benchmark, and cantilever beam analytical comparison all performed. Results within 0.5% of analytical solutions. Required gradation met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that quantities of interest (construct stiffness, peak von Mises stress at screw-rod interface) change by less than 5% between successive mesh refinements.",
      "rationale": "Three-level mesh refinement study conducted on the pedicle screw-rod construct model. Construct stiffness converged to within 2.1% and peak interface stress to within 3.8% between the medium and fine mesh. Richardson extrapolation applied; GCI < 4% for all QoIs. Required level achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps; contact penetration must remain below 1% of minimum element edge length.",
      "rationale": "Direct sparse solver employed for all linear subproblems. Residual norms confirmed below 1e-8 at each Newton-Raphson iteration. Contact penetration monitored and confirmed within tolerance across all 11 model instances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent analyst review of boundary conditions, material assignments, and load application steps.",
      "rationale": "Simulation protocol documented in a controlled simulation plan. An independent analyst performed a blind re-run of three model instances; results agreed within 1.2% for stiffness and 2.0% for yield load. Use error risk assessed as low."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model and contact formulation must be justified by reference to published literature or prior validation studies for metallic spinal implant constructs under quasi-static loading.",
      "rationale": "Linear isotropic elasticity with frictional Coulomb contact (mu=0.2) adopted following published FDA guidance and peer-reviewed literature on titanium alloy spinal implant FEA. Geometric nonlinearity included to capture large-displacement effects under F1717 loading. Model form justified and consistent with the COU loading regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured values or certified material specifications; uncertainty in inputs must be quantified.",
      "rationale": "Ti-6Al-4V ELI material properties (E=114 GPa, nu=0.34, yield=880 MPa) sourced from ASTM F136 certified mill certificates for the specific lot used in the experimental constructs. Screw and rod geometry digitized from CMM measurements with dimensional uncertainty < 0.02 mm. Input uncertainty propagated via Monte Carlo (N=1000); stiffness QoI 95th percentile uncertainty band is ±3.4%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental specimens must be production-representative implants with documented traceability to the same design and material lot as the device under submission.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs sourced from the same production lot as the submission device. Certificate of conformance and dimensional inspection records provided for all specimens. Sample size sufficient to characterize inter-specimen variability for the quantities of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must span the range of loading configurations relevant to the COU, including at least two distinct load offsets per ASTM F1717.",
      "rationale": "Testing performed at a single load offset (60 mm) per standard ASTM F1717 protocol. While this represents the most clinically relevant configuration, the absence of a second offset prevents full characterization of the load-offset sensitivity. Achieved level (2) falls below required level (3); this gap is acknowledged and accepted by the assessment team as a residual limitation given the regulatory precedent for single-offset F1717 testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to the experimental specimen parameters; any discrepancies must be quantified and their effect on QoIs assessed.",
      "rationale": "CMM-measured specimen geometry used directly to parameterize each of the 11 FEA model instances. Material properties matched to certified lot data. Fixture compliance characterized experimentally and incorporated into boundary conditions. Equivalency confirmed; residual geometric discrepancy < 0.03 mm RMS."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) must be computed; model predictions must fall within experimental uncertainty bounds for primary QoIs.",
      "rationale": "Area validation metric (ASME V&V 20) computed for construct stiffness and yield load distributions. Validation metric = 0.08 for stiffness (threshold 0.20) and 0.11 for yield load (threshold 0.20). All 11 individual FEA predictions fall within the 95% experimental confidence interval. Output comparison satisfactory."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected QoIs (construct stiffness and yield load) must be directly linked to the clinical performance requirements and regulatory submission endpoints for the device.",
      "rationale": "Construct stiffness and yield load under ASTM F1717 compression-bending are the primary regulatory endpoints for Class II spinal fixation device submissions. These QoIs are directly specified in the predicate device comparison and FDA guidance. Relevance is high and well-established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario (F1717 compression-bending, non-cannulated 7.5 mm screw) must match the intended use scenario in geometry, loading mode, and material class.",
      "rationale": "Validation performed on the identical device geometry, material, and loading configuration as the intended submission use. The validation scenario is not a surrogate — it is the COU scenario. Relevance of validation activities to the intended use is maximal."
    }
  ],
