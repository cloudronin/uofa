  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors meet or exceed the required credibility level for a Model Risk Level 3 submission. The single below-required factor (Test conditions, achieved 2 vs. required 3) reflects the standard single-offset ASTM F1717 protocol and is consistent with accepted regulatory practice for Class II spinal fixation devices. The overall evidence package, including N=11 experimental constructs across two independent laboratories, CMM-based geometric equivalency, and quantitative validation metrics within acceptance thresholds, provides sufficient credibility to support the intended regulatory use. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
