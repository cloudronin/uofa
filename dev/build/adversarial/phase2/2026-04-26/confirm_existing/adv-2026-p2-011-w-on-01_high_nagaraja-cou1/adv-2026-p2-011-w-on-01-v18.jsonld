  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2023 R1) must operate under a documented quality management system with version control and regression testing records available.",
      "rationale": "Ansys Mechanical 2023 R1 is operated under an ISO 9001-certified QMS. Version control is maintained via Git; regression test suite covers 247 benchmark cases. Achieved level 3 exceeds required level 2 for this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified against at least two published analytical benchmarks relevant to structural mechanics (beam bending, contact).",
      "rationale": "Ansys Mechanical verified against Timoshenko beam bending and Hertzian contact analytical solutions. Maximum deviation from analytical solution is 0.4%, satisfying the required level 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate quantity-of-interest change of less than 5% between successive refinement levels using at least three mesh densities.",
      "rationale": "Three mesh densities evaluated (coarse: 1.2 mm, medium: 0.6 mm, fine: 0.3 mm global element size at screw-rod interface). Stiffness QoI varied by 3.1% coarse-to-medium and 0.9% medium-to-fine. Richardson extrapolation confirms GCI < 1.5%. Achieved level 3 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps; energy balance error must be below 0.1%.",
      "rationale": "Newton-Raphson iterations converge to force residual norm < 1e-7 for all 47 load increments. Energy balance error monitored at each step; maximum observed error is 0.04%. Solver error contribution is negligible relative to other uncertainty sources."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be performed by personnel with documented FEA competency; an independent technical reviewer must verify boundary conditions and material assignments.",
      "rationale": "Model setup performed by engineer with 8 years FEA experience; independent review completed by senior biomechanics staff. Boundary condition checklist and material assignment log archived. No discrepancies identified during review. Achieved level 2 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection must be justified by literature evidence and sensitivity analysis; contact formulation must be appropriate for the load regime.",
      "rationale": "Linear elastic isotropic material model justified for titanium alloy (Ti-6Al-4V) below yield; literature confirms elastic regime dominates under F1717 loading. Augmented Lagrangian contact formulation selected for screw-rod and screw-block interfaces. Sensitivity analysis shows model form uncertainty contributes less than 4% to stiffness QoI variance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters must be sourced from traceable measurements or peer-reviewed literature with uncertainty bounds reported.",
      "rationale": "Elastic modulus (114 GPa) and Poisson ratio (0.34) for Ti-6Al-4V sourced from ASTM F136 and confirmed by three independent tensile test certificates. Screw geometry digitized from calibrated micro-CT at 15 micron voxel resolution. Uncertainty bounds propagated via Monte Carlo (N=500); 95th percentile stiffness variation is 2.8%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterize biological and manufacturing variability; samples must be traceable to production lot.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested; all from a single production lot with dimensional inspection records. Sample size provides 80% power to detect 10% difference in mean stiffness at alpha=0.05. Coefficient of variation for experimental stiffness is 6.3%, consistent with manufacturing tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing must be conducted under at least two clinically representative load conditions or load magnitudes to characterize model performance across the intended use envelope.",
      "rationale": "ASTM F1717 protocol specifies a single standardized compression-bending load configuration. Only one load condition was evaluated due to protocol constraints. This factor falls below the required level 3; the gap is acknowledged and accepted based on the standardized nature of the regulatory test method and the absence of alternative validated protocols for this device class."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs must be demonstrably equivalent to experimental specimen parameters; discrepancies must be quantified and shown to have negligible effect on QoI.",
      "rationale": "Screw geometry in FEA derived from micro-CT of tested specimens; torque preload on set screws matched to experimental value (4 Nm) via pretension bolt element. Discrepancy analysis shows residual geometric differences contribute less than 1.5% to stiffness prediction error. Equivalency confirmed at required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error, validation metric) must be computed and compared against a pre-specified acceptance threshold.",
      "rationale": "Normalized RMS error between FEA ensemble mean and experimental mean stiffness is 4.2% (threshold: 10%). Peak bending moment NRMSE is 6.8% (threshold: 15%). Validation metric computed per ASME V&V 10.1 area metric; model uncertainty interval overlaps experimental uncertainty interval for 10 of 11 specimens. All metrics within acceptance thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs predicted by the model must directly correspond to the mechanical performance endpoints specified in the regulatory submission and clinical use context.",
      "rationale": "Construct stiffness and peak bending moment are the primary mechanical performance endpoints specified in the 510(k) substantial equivalence comparison for this pedicle screw system. These QoIs are directly linked to the clinical performance requirements for spinal stabilization. Relevance is fully established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation experiment must replicate the geometry, loading, and boundary conditions of the intended regulatory and clinical use scenario to an extent justified by the model risk level.",
      "rationale": "ASTM F1717 is the regulatory standard test method for spinal implant systems in the United States; the validation experiment is conducted per this standard and directly supports the 510(k) submission. Loading conditions, fixture geometry, and specimen configuration match the regulatory submission test plan. Validation activity relevance is fully established for the intended regulatory use scope described in the claim and requirement documents."
    }
  ],
