  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment is accepted at Medium assurance level for model risk level 3. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 specifies a single standardized load condition, no alternative validated multi-condition protocol exists for this device class, and the remaining factors collectively provide sufficient evidence of model credibility for the intended regulatory submission use. The validation evidence, as documented in the bound claim and requirement artifacts, supports use of the FEA model ensemble for pre-market 510(k) submission for the non-cannulated 7.5 mm pedicle screw construct under compression-bending loading.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
