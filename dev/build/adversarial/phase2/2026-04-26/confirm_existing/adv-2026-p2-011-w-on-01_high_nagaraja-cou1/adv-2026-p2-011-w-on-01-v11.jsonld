      "type": "ValidationResult",
      "name": "Construct stiffness prediction vs. experimental N=11 — within 10% mean error across both laboratories"
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-vr-yield-load-comparison",
      "type": "ValidationResult",
      "name": "Yield load prediction vs. experimental N=11 — within 12% mean error; ensemble spread bounded by experimental variability"
    }
  ],
