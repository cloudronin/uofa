      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 production-representative constructs tested; samples drawn from three manufacturing lots; dimensional inspection confirmed all specimens within engineering drawing tolerances."
