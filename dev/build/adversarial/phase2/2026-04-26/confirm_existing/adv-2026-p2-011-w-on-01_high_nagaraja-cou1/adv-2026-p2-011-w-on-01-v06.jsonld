      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including Timoshenko beam bending and Hertzian contact verified against analytical solutions; residuals confirmed below 1e-6 for all load steps."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Richardson extrapolation performed on three systematically refined meshes (coarse 0.8 mm, medium 0.5 mm, fine 0.3 mm); GCI below 1.2% for peak von Mises stress at the screw-rod junction."
    },
