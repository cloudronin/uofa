  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Nagaraja COU1 — Non-cannulated pedicle screw compression-bending credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for FEA prediction of ASTM F1717 static compression-bending performance of a non-cannulated 7.5 mm pedicle screw construct. The FEA model ensemble (FDA, Ansys, DePuy Synthes) is compared against N=11 experimental constructs across two independent laboratories. The intended use scope is implicitly defined by the ASTM F1717 test standard applied to Class II spinal fixation devices under static axial compression-bending loads; all 13 V&V 40 credibility factors have been assessed, with one factor (Test conditions) achieving a level below the required threshold due to a single test condition being evaluated. Regulatory submission context: 510(k) premarket notification for a non-cannulated 7.5 mm pedicle screw system indicated for posterior thoracolumbar fixation in skeletally mature patients.",
  "bindsRequirement": "https://uofa.net/synth/req/nagaraja-f1717-compression-bending-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/nagaraja-fea-predicts-f1717-construct-stiffness-and-yield",
  "bindsModel": "https://uofa.net/synth/model/nagaraja-pedicle-screw-fea-ensemble-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/nagaraja-f1717-experimental-n11-lab1",
    "https://uofa.net/synth/data/nagaraja-f1717-experimental-n11-lab2",
    "https://uofa.net/synth/data/nagaraja-fea-output-ensemble-compression-bending"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-001",
      "type": "ValidationResult",
      "name": "F1717 compression-bending stiffness comparison: FEA ensemble vs. experimental N=11 (Lab 1 and Lab 2)"
    },
