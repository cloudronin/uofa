  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software used in the ensemble must have documented verification test suites and version-controlled release notes consistent with a Gradation 2 or higher SQA program.",
      "rationale": "Ansys Mechanical 2022 R2 and the FDA in-house FEA solver both maintain ISO 9001-registered quality management systems with published verification manuals. DePuy Synthes internal solver holds an equivalent internal SQA program with regression test coverage exceeding 95% of active element types. All three codes exceed the required Gradation 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks relevant to large-deformation contact and elasto-plastic beam bending must be documented and passed prior to use in the ensemble.",
      "rationale": "Each ensemble solver was exercised against NAFEMS benchmark LE1 and LE10, a cantilever beam plasticity case, and a Hertzian contact patch test. All solvers reproduced reference solutions within 1% for linear cases and within 3% for the plasticity benchmark, satisfying Gradation 3 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh convergence study must demonstrate that the quantity of interest (construct stiffness and yield load) changes by less than 5% between the penultimate and final refinement levels.",
      "rationale": "A three-level mesh refinement study was conducted on the pedicle screw shank and rod interface regions. Stiffness changed by 1.8% and yield load by 2.4% between the medium and fine meshes. The fine mesh with approximately 180,000 hexahedral-dominant elements was adopted for all production runs, satisfying the 5% convergence criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must be monitored and reported; force and moment equilibrium residuals must drop below 1e-4 relative tolerance at each load step.",
      "rationale": "All ensemble runs employed a direct sparse solver (PARDISO) with full Newton-Raphson iteration. Force residuals converged to below 1e-5 relative tolerance at every converged load step. No divergent or non-converged load steps were accepted in the reported results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup procedures must be documented in a controlled simulation plan; an independent analyst must review boundary condition and loading definitions before results are accepted.",
      "rationale": "A simulation plan document was approved by three independent reviewers prior to execution. Boundary conditions replicating the ASTM F1717 fixture geometry were independently verified by a second analyst in each participating organization. No discrepancies in boundary condition setup were identified during cross-organization review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model must capture the dominant physics of elasto-plastic bending and screw-rod interface contact; model form assumptions must be explicitly documented and sensitivity-tested.",
      "rationale": "A bilinear isotropic hardening plasticity model was applied to Ti-6Al-4V components, calibrated against tensile coupon data from the same material lot. Screw-rod interface was modeled with augmented Lagrangian frictional contact (mu=0.2). Sensitivity analyses showed that varying friction coefficient from 0.1 to 0.3 changed predicted stiffness by less than 4%, confirming that model form uncertainty is bounded within acceptable limits."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions used as model inputs must be traceable to measurements performed on the actual test articles or the same production lot.",
      "rationale": "Elastic modulus, yield strength, and ultimate tensile strength were measured from five tensile coupons machined from the same Ti-6Al-4V bar stock used for the test constructs. Screw and rod geometry was measured by coordinate measuring machine on three representative specimens per configuration. All input values are traceable to calibrated measurement records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to estimate mean and variability of the quantity of interest; N >= 10 specimens per configuration is required at this risk level.",
      "rationale": "Eleven constructs were tested across two independent laboratories (six at Lab 1, five at Lab 2) under identical ASTM F1717 protocols. The combined sample provides adequate statistical power to characterize construct-to-construct variability. Inter-laboratory coefficient of variation for stiffness was 4.2%, confirming reproducibility."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the intended use; at minimum two distinct load levels or configurations must be evaluated.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending configuration (220 N axial pre-load, 10 mm/min displacement rate). While this configuration is the regulatory standard, only one test condition was evaluated, which is insufficient to span the range of in vivo loading scenarios anticipated in the COU. This factor is assessed at Gradation 2, below the required Gradation 3, and represents a documented gap in the validation evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to experimental conditions; any differences must be quantified and their effect on QoI assessed.",
      "rationale": "Fixture geometry, loading arm length, and axial pre-load were matched between simulation and experiment to within measurement uncertainty. The UHMWPE block representing the vertebral body was modeled with a measured compressive modulus of 1.1 GPa, consistent with the physical block used in testing. Equivalency was confirmed by overlaying the simulated and experimental load-displacement curves in the linear elastic regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A quantitative metric (e.g., E-measure or normalized RMS error) must be used to compare simulation predictions to experimental observations; the metric must be below a pre-specified acceptance threshold.",
      "rationale": "The validation metric was the normalized mean absolute error (NMAE) for construct stiffness and yield load. FEA ensemble mean stiffness deviated from experimental mean by 3.1% (NMAE), and yield load deviated by 4.7% (NMAE), both within the pre-specified 10% acceptance threshold. All three ensemble codes produced predictions within one experimental standard deviation of the measured mean."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest extracted from the simulation must be directly linked to the clinical or regulatory decision being supported.",
      "rationale": "Construct stiffness and yield load under ASTM F1717 compression-bending are the primary mechanical performance metrics used by FDA reviewers to assess spinal fixation device safety. These quantities directly inform the regulatory acceptance decision for the 510(k) submission and are the quantities predicted by the FEA ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar to the intended use scenario in terms of geometry, material, loading, and boundary conditions to support extrapolation of validation evidence to the COU.",
      "rationale": "The validation activity directly replicates the ASTM F1717 test configuration that constitutes the regulatory submission basis. The device geometry, material, and assembly used in validation are identical to the submission device. The validation scenario is therefore maximally relevant to the regulatory COU, supporting direct transfer of credibility evidence without extrapolation penalty."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a Model Risk Level 3 assessment at Medium assurance. The single deficient factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is acknowledged as a documented gap; however, the assessment team and regulatory reviewers have accepted this gap on the basis that ASTM F1717 defines a single standardized test configuration and no alternative multi-condition protocol exists for this device class. The overall body of evidence is judged sufficient to support a Medium assurance conclusion for the intended regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
