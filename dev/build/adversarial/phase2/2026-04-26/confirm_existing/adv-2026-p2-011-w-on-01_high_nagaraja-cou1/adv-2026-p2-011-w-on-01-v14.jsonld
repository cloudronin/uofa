  "signature": "ed25519:b2e7f4a1c9d3e6b0f5a8c2d7e1b4f9a3c6d0e5b8f2a7c1d4e9b3f6a0c5d8e2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software must be verified under a documented quality management system with version control and regression testing.",
      "rationale": "Ansys Mechanical 2021 R2 is operated under an ISO 9001-certified QMS; version control and regression test suite documented in the software validation plan. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations through benchmark problems with known analytical solutions.",
      "rationale": "Benchmark comparisons against NAFEMS standard problems LE1 and LE10 confirm correct implementation of linear elastic solid mechanics. Residual norms below 1e-8 for all benchmark cases."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate discretization error below 5% in the quantity of interest (peak von Mises stress at screw-rod interface).",
      "rationale": "Richardson extrapolation-based mesh convergence study performed across three mesh densities (coarse 1.5 mm, medium 0.75 mm, fine 0.375 mm). Grid Convergence Index for peak stress = 2.3%, below the 5% threshold. Fine mesh adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals must converge to at least 1e-6 for all linear system solves; iterative solver tolerance documented.",
      "rationale": "Direct sparse solver (PARDISO) used for all static analyses; machine-precision residuals achieved. No iterative convergence issues observed across 11 specimen models."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent analyst review and checklist-based QC to prevent operator errors in boundary condition application and material assignment.",
      "rationale": "Simulation workflow executed under a two-analyst review protocol. Pre-run and post-run checklists verified boundary conditions, material properties, and load magnitudes for each of the 11 specimen models. No use errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model and contact formulation must be physically appropriate for quasi-static metallic implant behavior under bending-compression loading.",
      "rationale": "Linear elastic isotropic Ti-6Al-4V (E=114 GPa, nu=0.34) adopted consistent with ASTM F1472 material data. Frictionless contact at screw-rod interface validated against torque-release experiments. Model form appropriate for the elastic-dominated compression-bending regime of F1717."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured specimen data or certified material certificates; uncertainty bounds documented.",
      "rationale": "Specimen-specific geometry digitized from CMM measurements (±0.01 mm). Material certificates provided by DePuy Synthes for each lot. Nominal UHMWPE block properties from ASTM F648. Input uncertainty propagated via Monte Carlo (N=1000) showing QoI sensitivity below 4%."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental sample set must be representative of the device population and sufficient in number to characterize variability (N≥10).",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs drawn from two production lots across two independent laboratories. Sample size meets FDA guidance for spinal device mechanical testing. Coefficient of variation in failure load = 6.2%, indicating acceptable population homogeneity."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios including at least two load levels or configurations.",
      "rationale": "Testing performed at a single compressive preload (150 N) per ASTM F1717 standard protocol. Clinically, load magnitudes vary substantially across patient body weight and activity level. Only one test condition evaluated; achieved level 2 falls below required level 3. This shortfall is acknowledged and accepted given the regulatory precedent of F1717 as the accepted standard method."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to the experimental test conditions, with documented mapping of all boundary conditions to physical test setup.",
      "rationale": "One-to-one mapping documented between FEA boundary conditions and physical fixture constraints per F1717 Annex A. Applied displacement rate (1 mm/min) confirmed quasi-static; inertial effects negligible (kinetic energy < 0.1% of strain energy). Fixture compliance characterized and incorporated."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized error, confidence interval overlap) must demonstrate agreement within pre-specified tolerance across all specimens.",
      "rationale": "Mean normalized error in peak bending moment at 6 mm displacement = 4.1% (95% CI: 1.8%–6.4%). All 11 specimen predictions fall within ±10% of experimental values. Bland-Altman analysis shows no systematic bias. Pre-specified acceptance threshold of ±10% met."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest extracted from the model must be directly relevant to the device performance metrics used in the regulatory submission.",
      "rationale": "Primary QoI is bending moment at 6 mm displacement, which is the F1717-specified performance metric used in the 510(k) submission. Secondary QoI (peak screw stress) directly informs fatigue life prediction. Both QoIs are clinically and regulatorily relevant."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar to the intended use scenario in geometry, loading, and material to support extrapolation of credibility evidence.",
      "rationale": "Validation performed on production-representative 7.5 mm non-cannulated screws under F1717 compression-bending, which is the identical configuration and load case to the intended submission use. High geometric and loading fidelity between validation and intended use supports direct credibility transfer."
    }
  ],
