  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-credibility-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment outcome is Accepted at Medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 defines the single-condition protocol as the regulatory standard for spinal construct mechanical testing, and FDA precedent supports this approach for Class II 510(k) submissions. The FEA model ensemble demonstrates prediction error within ±10% across all 11 experimental specimens, supporting its use for pre-market submission of the non-cannulated 7.5 mm pedicle screw construct under compression-bending loading.",
    "decidedAt": "2026-04-19T00:00:00Z"
