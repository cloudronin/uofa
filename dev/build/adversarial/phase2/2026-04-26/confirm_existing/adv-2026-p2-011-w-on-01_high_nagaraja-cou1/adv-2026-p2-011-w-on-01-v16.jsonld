  "signature": "ed25519:b2d4f6a8c0e2d4f6a8b0c2e4d6f8a0b2c4e6f8a0b2d4f6a8c0e2d4f6a8b0c2e4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical R2022 R1 is a commercially validated solver with documented V&V suite. FDA-internal FEA environment follows 21 CFR Part 11 controls. DePuy Synthes FEA environment operates under ISO 9001:2015 QMS. All three ensemble members satisfy SQA requirements at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including cantilever beam bending and contact patch tests were executed in each FEA environment. Results matched analytical solutions within 0.5% for linear elastic cases. Code verification is documented in ensemble member verification reports."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed on pedicle screw and rod assembly. Three mesh refinement levels evaluated; peak von Mises stress at screw-rod interface converged to within 2.1% between medium and fine meshes. Richardson extrapolation applied; GCI < 3% on quantity of interest (construct stiffness)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Newton-Raphson iterative solver convergence monitored; force and displacement residuals below 1e-4 for all load steps. Contact stabilization energy confirmed below 1% of total strain energy. No divergence events observed across 11 model instances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation workflow documented with step-by-step SOPs covering geometry import, material assignment, boundary condition application, and post-processing. Independent peer review of model setup conducted by second analyst in each laboratory. Checklist-based QC applied prior to result extraction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic continuum mechanics with frictional contact (mu=0.2) at screw-rod interface selected as model form. Justification supported by literature review confirming elastic regime dominates ASTM F1717 static compression-bending loading below yield. Geometric nonlinearity enabled to capture large-displacement effects at 10 mm offset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Ti-6Al-4V material properties (E=114 GPa, nu=0.34) sourced from ASTM B265 certified material certificates for each physical specimen lot. Geometry derived from CMM measurements of representative production screws. Boundary conditions replicate F1717 fixture constraints with documented uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested; sample size exceeds ASTM F1717 minimum of N=5. Specimens drawn from production lot with documented traceability. Dimensional inspection confirmed all specimens within drawing tolerances. Between-specimen variability characterized via coefficient of variation on construct stiffness (CV=4.2%)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; shortfall documented with risk acceptance rationale.",
      "rationale": "Testing performed at a single load offset (10 mm) per ASTM F1717 protocol. Multiple offset conditions were not evaluated due to resource constraints. This shortfall is acknowledged; the single condition represents the most clinically conservative loading scenario per FDA guidance. Risk accepted by sponsor and documented in deviation record DR-2024-007."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "One-to-one mapping established between physical test inputs (specimen geometry, material lot, fixture displacement rate) and FEA model inputs. Mapping table reviewed by independent assessor. Discrepancies in polyaxial screw head friction coefficient addressed by sensitivity analysis showing <5% effect on construct stiffness QOI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness (N/mm) and maximum load at 10 mm displacement compared between FEA ensemble predictions and experimental measurements. FEA ensemble mean stiffness within 6.3% of experimental mean (experimental: 142.4 N/mm; FEA: 151.4 N/mm). All individual FEA predictions fall within experimental 95% confidence interval. Bland-Altman analysis confirms no systematic bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and peak load are the primary quantities of interest for ASTM F1717 compliance and are directly linked to the clinical decision context of spinal fixation device pre-market review. QOI selection endorsed by clinical advisor and FDA reviewer correspondence (Q-submission QSub-2023-004412)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities replicate the ASTM F1717 static compression-bending test that constitutes the regulatory submission basis for the Class II non-cannulated pedicle screw. FEA predictions are used to supplement, not replace, physical testing, consistent with FDA guidance on computational modeling. Validation scope directly addresses the intended regulatory decision."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for model risk level 3. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is accepted based on documented deviation record DR-2024-007, which establishes that the single ASTM F1717 load offset condition is the most clinically conservative scenario and that the risk of under-assessment is low given the conservative nature of the selected condition. Overall credibility evidence is sufficient to support pre-market submission use of the FEA ensemble for non-cannulated 7.5 mm pedicle screw ASTM F1717 static compression-bending performance prediction.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
