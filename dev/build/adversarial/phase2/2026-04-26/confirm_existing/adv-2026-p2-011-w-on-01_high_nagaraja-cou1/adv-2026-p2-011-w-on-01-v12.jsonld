  "signature": "ed25519:b7d3e9f1a4c6082b5e8d2f0a3c7b9e4d1f6a2c5b8e0d3f7a1c4b6e9d2f5a8c1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) must operate under a documented quality management system with version control and regression testing records available.",
      "rationale": "Ansys Mechanical 2022 R2 is deployed under an ISO 9001-certified QMS. Version control logs, regression test suite results, and release validation records were reviewed and found compliant with Gradation 2 requirements for a Model Risk Level 3 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems representative of structural contact and large-displacement bending must be solved with documented agreement to analytical or published reference solutions.",
      "rationale": "Ansys Mechanical passes published NAFEMS benchmark suite for contact mechanics and beam bending. Internal verification cases for nonlinear geometry with frictional contact demonstrate residual errors below 1% relative to reference solutions, satisfying Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that QoI (stiffness, yield load) change by less than 5% between successive refinements, with Richardson extrapolation applied.",
      "rationale": "Three-level mesh refinement study performed on the screw-rod-block assembly. Stiffness QoI varied by 2.1% and yield load by 1.8% between medium and fine meshes. Richardson extrapolation confirms discretization error below 3% for all reported QoIs, meeting Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence criteria must be documented and residual norms must fall below 1e-5 for all load steps.",
      "rationale": "Newton-Raphson nonlinear solver with sparse direct linear solver employed. Force and displacement residual norms confirmed below 1e-6 for all 47 load increments across the ensemble. Automatic time-stepping with bisection ensures no diverged steps, satisfying Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent analyst review of boundary conditions, material assignments, and loading definitions prior to result extraction.",
      "rationale": "Simulation workflow documented in a controlled simulation plan (SP-2023-047). An independent analyst performed a line-by-line review of model setup against the simulation plan. Two discrepancies identified during review were corrected prior to final runs. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection (Ti-6Al-4V bilinear isotropic hardening) must be justified by material characterization data and literature precedent for ASTM F1717 constructs.",
      "rationale": "Bilinear isotropic hardening model for Ti-6Al-4V calibrated against five tensile coupon tests (mean E=114 GPa, yield 880 MPa, tangent modulus 1.2 GPa). Model form consistent with published FDA pedicle screw FEA literature. Sensitivity analysis shows QoI insensitive to ±10% tangent modulus variation. Gradation 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Geometry, material properties, and boundary condition inputs must be traceable to measured values with documented uncertainty bounds.",
      "rationale": "Screw geometry digitized from CMM measurements (tolerance ±0.01 mm). Material properties from certified mill certificates and in-house coupon tests. Boundary conditions derived from ASTM F1717 fixture drawings. All inputs documented in simulation plan with traceability matrix. Gradation 3 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 experimental specimens from production lots with documented dimensional and material certification, tested across two independent laboratories.",
      "rationale": "N=11 constructs assembled from production-lot screws, rods, and blocks with full dimensional inspection and material certification. Specimens distributed across two independent test laboratories (Lab A: n=6, Lab B: n=5). Inter-laboratory variability in stiffness below 4% CV. Gradation 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios including at least two distinct load levels or configurations.",
      "rationale": "Testing performed under a single ASTM F1717 quasi-static compression-bending configuration at one displacement rate. Variation in load level or loading mode not explored in this validation activity. This factor achieves only Gradation 2 against a required Gradation 3; this gap is acknowledged and documented as a limitation of the current validation scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be set to match experimental specimen measurements rather than nominal design values, with documented correspondence table.",
      "rationale": "Each of the N=11 FEA instances uses specimen-specific CMM-measured geometry and certified material properties. A correspondence table mapping each experimental specimen to its FEA counterpart is included in simulation plan SP-2023-047, Appendix C. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMSE or prediction interval coverage) must be computed and reported for all primary QoIs.",
      "rationale": "Normalized RMSE of 3.8% for stiffness and 4.2% for yield load computed across N=11 specimen pairs. 95% prediction intervals from FEA ensemble contain 10 of 11 experimental observations for stiffness and all 11 for yield load. Systematic bias below 2% for both QoIs. Gradation 3 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (stiffness, yield load) must be directly linked to the device performance endpoints cited in the regulatory submission.",
      "rationale": "Construct stiffness and yield load under ASTM F1717 compression-bending are the primary structural adequacy endpoints cited in the 510(k) submission performance testing section. The validation QoIs are identical to the submission QoIs, confirming direct relevance. Gradation 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 compression-bending, non-cannulated 7.5 mm screw) must be demonstrated to be representative of the intended clinical and regulatory use context.",
      "rationale": "ASTM F1717 is the FDA-recognized consensus standard for spinal implant mechanical testing. The non-cannulated 7.5 mm geometry tested is the specific device configuration under review. Loading mode (compression-bending) represents the clinically dominant failure mode. Validation activities are directly representative of the regulatory submission context. Gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for Model Risk Level 3. The single shortfall in Test conditions (achieved Gradation 2 vs. required Gradation 3) is offset by high confidence in model form, discretization control, and strong quantitative output comparison metrics across N=11 specimens at two laboratories. The overall evidence body is judged sufficient to support the intended regulatory use of the FEA model for ASTM F1717 compression-bending performance prediction of the non-cannulated 7.5 mm pedicle screw construct. Assessment accepted with recommendation to expand loading condition coverage in future validation cycles.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
