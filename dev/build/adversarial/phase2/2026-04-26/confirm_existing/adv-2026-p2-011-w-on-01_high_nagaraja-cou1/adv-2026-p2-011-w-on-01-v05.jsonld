  "signature": "ed25519:7c3a1f9e2b5d8c0f4a7e1b3d6c9f2a5e8b1d4c7f0a3e6b9d2c5f8a1e4b7d0c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA solver with documented verification test suite and version control; achievedLevel must meet or exceed requiredLevel.",
      "rationale": "All three FEA implementations (FDA in-house, Ansys Mechanical 2021 R2, DePuy Synthes proprietary solver) operate under ISO 9001-compliant quality management systems with traceable version control and documented regression test suites covering the element types and contact algorithms employed in this model."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions demonstrate solver correctness for linear elastic beam-bending and contact mechanics; achievedLevel must meet or exceed requiredLevel.",
      "rationale": "Each solver was verified against NAFEMS benchmark LE1 and a custom cantilever beam with Hertzian contact, yielding errors below 0.5% relative to analytical solutions. Cross-code comparison across the three implementations further confirms numerical correctness for the element formulations used."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates that key QoI (construct stiffness, peak von Mises stress at screw-rod interface) change by less than 5% between the penultimate and final refinement levels.",
      "rationale": "A three-level mesh refinement study (coarse: ~85k elements, medium: ~210k elements, fine: ~540k elements) was conducted. Construct stiffness varied by 2.1% and peak interface stress by 3.8% between medium and fine meshes. The medium mesh was adopted for the ensemble runs, providing adequate accuracy at tractable computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals fall below 1e-6 for all load steps; energy balance error remains below 0.1%.",
      "rationale": "All simulations used direct sparse solvers with double-precision arithmetic. Force residuals converged to below 1e-7 for every load increment. Energy balance checks confirmed errors below 0.05% across the full loading range, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second analyst; documented boundary condition and loading application protocol.",
      "rationale": "Each of the three modeling teams independently reviewed the other teams' boundary condition assignments, material property inputs, and contact pair definitions against the shared protocol document. Discrepancies identified during cross-review were resolved prior to final simulation runs, reducing the likelihood of systematic use errors."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Physics representation (linear elastic titanium alloy, frictional contact at screw-rod interface, rigid loading fixtures) is justified relative to the ASTM F1717 test configuration and expected deformation regime.",
      "rationale": "Under ASTM F1717 compression-bending loads at the tested magnitudes (up to 1500 N), titanium alloy pedicle screws remain within the elastic regime. Linear elastic constitutive models are therefore appropriate. Frictional contact (mu=0.2) at the screw-rod interface reflects experimentally characterized values from tribology literature. Rigid fixture representation is consistent with the stiffness differential between the testing machine grips and the implant construct."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from traceable measurements or certified material data sheets; uncertainty in inputs quantified.",
      "rationale": "Ti-6Al-4V material properties (E=114 GPa, nu=0.34) were drawn from ASTM F136 certified material test reports for the specific lot used in the experimental constructs. Geometric dimensions were measured from five representative screws and rods using calibrated CMM, with measured variability incorporated as input uncertainty bounds in a one-at-a-time sensitivity study."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 experimental constructs from the same manufacturing lot with documented dimensional inspection; sample representativeness of the intended device population confirmed.",
      "rationale": "Eleven constructs were assembled from a single manufacturing lot of non-cannulated 7.5 mm pedicle screws and 5.5 mm titanium rods. All constructs underwent incoming dimensional inspection confirming conformance to design drawings. The lot was selected to be representative of production-intent geometry, satisfying the sample adequacy criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios or justification is provided for the selected condition; multiple load levels or configurations evaluated.",
      "rationale": "Testing was conducted at a single compression-bending load level (1200 N axial with 10 Nm bending moment) per the standard ASTM F1717 protocol. While this condition represents the regulatory standard, it does not span the full range of in vivo loading scenarios. This factor achieves Gradation 2 rather than the required Gradation 3, representing a known gap acknowledged in the credibility assessment. The single-condition limitation is accepted given the regulatory context where F1717 compliance is the primary decision criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material properties, boundary conditions, loading) demonstrably correspond to the as-tested experimental conditions.",
      "rationale": "Model geometry was reconstructed from CMM measurements of the actual test constructs. Boundary conditions replicate the ASTM F1717 fixture geometry as confirmed by fixture drawings provided by both testing laboratories. Applied loads in the FEA exactly match the load cell recordings from the experimental tests, with load application point verified against fixture geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) computed; agreement within ±15% for construct stiffness and peak displacement at maximum load across all N=11 constructs.",
      "rationale": "The ASME V&V 10.1 area validation metric was computed for construct stiffness and peak displacement. Mean FEA-to-experiment ratios were 1.04 (stiffness) and 0.97 (peak displacement) across the N=11 constructs and three solver implementations. All individual comparisons fell within the ±15% acceptance band, with maximum deviation of 9.3%. Inter-laboratory experimental variability (CV=4.2%) was within expected bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs predicted by FEA (construct stiffness, peak displacement, screw-rod interface stress) are directly linked to the regulatory decision criteria and clinical failure modes.",
      "rationale": "Construct stiffness and peak displacement under ASTM F1717 loading are the primary regulatory acceptance criteria for posterior spinal fixation devices. Peak von Mises stress at the screw-rod interface is the dominant predictor of fatigue-related failure in clinical use. All three QoIs are therefore directly relevant to both the regulatory submission and the clinical safety question."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity (ASTM F1717 bench test comparison) is sufficiently representative of the intended regulatory use context; any gaps between validation scenario and COU are identified and justified.",
      "rationale": "The validation activity directly replicates the ASTM F1717 standardized test protocol that constitutes the regulatory COU for this submission. The experimental constructs are from the same device family as the submission device. The primary gap — single test condition — is captured in the Test conditions factor above. No additional relevance gaps were identified that would materially affect the credibility conclusion for the regulatory decision."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility of the FEA model for predicting ASTM F1717 compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct is assessed as sufficient to support the regulatory submission decision. Twelve of thirteen V&V 40 factors meet or exceed their required credibility levels. The single shortfall in Test conditions (achievedLevel 2 vs. requiredLevel 3) is accepted given that ASTM F1717 is a single-condition standardized protocol and the regulatory decision criterion does not require multi-condition coverage. The ensemble modeling approach across three independent implementations provides additional confidence in the numerical results. The Medium assurance level is appropriate for a Class II device with established predicate history.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
