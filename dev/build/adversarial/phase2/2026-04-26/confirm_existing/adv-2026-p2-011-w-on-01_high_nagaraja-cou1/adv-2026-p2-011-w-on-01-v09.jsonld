      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (stiffness, yield load) must be directly linked to the regulatory submission performance endpoints for Class II spinal fixation devices.",
      "rationale": "Construct stiffness and yield load are the primary ASTM F1717 performance endpoints cited in FDA guidance for 510(k) submissions for spinal pedicle screw systems; direct regulatory linkage documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
