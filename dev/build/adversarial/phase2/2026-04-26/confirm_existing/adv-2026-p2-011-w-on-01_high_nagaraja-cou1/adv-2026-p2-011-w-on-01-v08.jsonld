  "signature": "ed25519:b2d4e6f8a1c3e5d7b9f1a3c5e7d9b1f3a5c7e9d1b3f5a7c9e1d3f5a7b9c1e3d5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2021 R2) must be validated under an established SQA plan consistent with FDA software guidance. Version control, regression testing, and audit trails required.",
      "rationale": "Ansys Mechanical 2021 R2 is a commercially validated FEA platform with documented SQA procedures, regression test suites, and FDA-recognized validation documentation. All three ensemble partners operated under ISO 9001-compliant quality management systems. SQA level exceeds the required gradation for a Model Risk Level 3 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be used to verify solver implementation for linear elastic contact mechanics relevant to the screw-rod interface.",
      "rationale": "Patch tests, single-element benchmarks, and Hertzian contact verification problems were executed and documented. Results matched analytical solutions to within 0.5% for all cases. Code verification is well-established for the relevant physics domain."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that quantities of interest (peak von Mises stress at screw-rod interface, construct stiffness) change by less than 5% between successive refinement levels.",
      "rationale": "A three-level mesh refinement study was performed on the reference screw geometry. Construct stiffness changed by 1.8% and peak interface stress by 3.2% between the medium and fine meshes. The medium mesh was selected for production runs, achieving the required discretization error level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must be monitored and reported; convergence tolerances must be documented and justified relative to quantities of interest.",
      "rationale": "Direct sparse solver (PARDISO) was used for all production runs, eliminating iterative convergence concerns. Nonlinear contact iterations converged to force residuals below 1×10⁻⁴ N in all cases. Solver error is negligible relative to other uncertainty sources."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Analyst qualifications must be documented; model setup checklist and independent review of boundary conditions and material assignments required.",
      "rationale": "All three ensemble analysts hold advanced degrees in mechanical or biomedical engineering with documented FEA experience exceeding five years. Model setup checklists were completed and cross-checked by a second analyst at each site. Independent review confirmed consistent boundary condition application across the ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model and contact formulation must be justified for quasi-static compression-bending of metallic spinal implants; geometric nonlinearity must be evaluated.",
      "rationale": "Linear elastic isotropic material models are appropriate for titanium alloy (Ti-6Al-4V) and stainless steel (316L SS) under sub-yield loading conditions confirmed by experimental strain gauge data. Augmented Lagrangian contact with friction coefficient μ=0.2 was applied at the screw-rod interface. Large-displacement formulation was activated; geometric nonlinearity effects were less than 2% on stiffness predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry, and boundary conditions must be traceable to measured or certified values; uncertainty in inputs must be characterized.",
      "rationale": "Material elastic moduli were taken from certified material test reports for each batch of implant material. Screw and rod geometry was measured via CMM on three representative samples per lot; dimensional variability was within ±0.05 mm. Boundary conditions replicate ASTM F1717 fixture geometry as measured from calibrated test fixtures. Input uncertainty propagation was performed via Monte Carlo sampling (n=500)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental specimens must be production-representative; lot traceability and dimensional verification required for all N=11 constructs.",
      "rationale": "All 11 test constructs used production-released components from the same manufacturing lots as the clinical device. Dimensional inspection confirmed all screws and rods were within drawing tolerances. Lot traceability records are archived. Sample size of N=11 across two laboratories provides adequate statistical basis for mean and variability characterization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate the range of loading scenarios relevant to the intended clinical use; multiple load levels or configurations should be evaluated.",
      "rationale": "Testing was conducted under a single compression-bending load configuration per ASTM F1717. While this configuration is the regulatory standard, it represents only one point in the broader loading space relevant to in vivo spinal fixation. The achieved level falls below the required level; this gap is acknowledged and accepted given the regulatory context where F1717 compliance is the primary submission requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to experimental test conditions; any deviations must be quantified and their effect on QoI assessed.",
      "rationale": "Experimental fixture geometry, grip compliance, and applied displacement rates were replicated in the simulation boundary conditions. Fixture compliance was measured and incorporated as a spring boundary condition. Sensitivity analysis showed that ±10% variation in fixture compliance changed predicted stiffness by less than 1.5%, confirming equivalency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E-metric, normalized RMSE) must be reported; simulation predictions must fall within experimental variability bounds for primary QoIs.",
      "rationale": "Construct stiffness predictions from all three ensemble models fell within one experimental standard deviation of the mean measured stiffness for 10 of 11 constructs. The ensemble mean stiffness prediction was within 4.2% of the experimental grand mean. ASME V&V 10.1 E-metric was computed and indicated agreement within validation uncertainty for all constructs. Output comparison exceeds the required credibility level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (construct stiffness, peak interface stress) must be directly relevant to the regulatory decision and clinical performance of the device.",
      "rationale": "Construct stiffness is the primary regulatory QoI for ASTM F1717 compliance and is directly related to clinical fixation stability. Peak von Mises stress at the screw-rod interface is the relevant fatigue-driving quantity for durability assessment. Both QoIs are directly linked to the intended regulatory submission decision, confirming high relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must closely match the intended use context in terms of geometry, material, loading, and boundary conditions; any gaps between validation and COU must be assessed.",
      "rationale": "The validation activity directly replicates the ASTM F1717 test protocol that constitutes the regulatory use context. The validated model geometry matches the production device geometry. Material and loading conditions are identical between validation and intended use. The validation activity is assessed as highly relevant to the regulatory submission context, with the single noted gap in test condition breadth documented under the Test conditions factor."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels for a Model Risk Level 3 assessment targeting Class II spinal fixation hardware under ASTM F1717 static compression-bending. The single deficient factor (Test conditions, achieved level 2 vs. required level 3) reflects the regulatory constraint that ASTM F1717 specifies a single standard test configuration; this limitation is considered acceptable given that the validation QoIs are directly relevant to the regulatory decision and the output comparison demonstrates strong agreement across N=11 constructs at two independent laboratories. The assessment team accepts the overall credibility of the FEA model ensemble for the stated purpose of supporting 510(k) regulatory submission for the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
