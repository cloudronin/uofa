  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA solver holds ISO 9001 certification and documented V&V test suite; version control enforced for all simulation scripts.",
      "rationale": "Ansys Mechanical 2024 R1 is deployed under the sponsor's ISO 9001-certified quality management system. All simulation scripts are version-controlled in a validated PLM repository. Solver release notes confirm no open anomalies affecting contact or large-displacement analyses relevant to this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Patch test and benchmark problems from NAFEMS suite pass to within solver tolerance; no custom user elements employed.",
      "rationale": "Standard Ansys element library (SOLID186, CONTA174) used exclusively. NAFEMS LE1 and LE10 benchmark results reproduced to within 0.3% of reference solutions. No user-defined element routines introduced."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinement levels; Richardson extrapolation GCI <5%.",
      "rationale": "Three-level mesh convergence study conducted on the screw-rod junction region. Stiffness QoI changed 0.8% between medium and fine meshes; GCI 1.4%. The November 2025 model revision updated the mesh density in the screw thread root region specifically to achieve this convergence criterion, which had been marginally exceeded (2.3% change) in the prior build. The experimental datasets predating this revision were judged by the modelling team as unaffected because the revision altered only discretization, not load or boundary condition definitions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Newton-Raphson residual norm below 1e-4 at every converged increment; no unconverged increments in nominal loading path.",
      "rationale": "All load steps converged with force residual norm below 5e-5. No increment bisection events occurred in the nominal 0–50 mm displacement ramp. Solver energy error indicator remained below 0.1% throughout."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution procedure; independent peer review of model setup prior to result extraction.",
      "rationale": "A written simulation execution procedure (SEP-FEA-CB-007, Rev C) governs model setup, boundary condition application, and result extraction. An independent senior analyst reviewed the model setup checklist prior to result extraction. No deviations from the SEP were recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum isotropic linear-elastic model appropriate for metallic implant below yield; contact formulation captures screw-rod interface slip.",
      "rationale": "Ti-6Al-4V ELI modelled as isotropic linear-elastic below yield (E=114 GPa, ν=0.33). Augmented Lagrangian contact with friction (μ=0.2) applied at screw-rod and rod-vertebral body block interfaces. Model form is consistent with prior FDA-reviewed pedicle screw FEA submissions and published literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from production lot CoC testing; geometry from calibrated CMM measurements of as-manufactured hardware; all inputs traceable to locked records.",
      "rationale": "Elastic modulus and yield strength drawn from certificate-of-conformance tensile tests on the production lot (dataset nagaraja-material-props-titanium-alloy-2025q3, vintage 2025-10-14). Geometry imported from CMM-verified CAD. Friction coefficient from published Ti-Ti tribology literature. The modelling team confirmed that material input cards were not modified during the November 2025 mesh revision, supporting the continued use of the pre-revision material dataset without re-qualification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production-representative hardware; dimensional inspection confirms within-drawing tolerance.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs assembled from production-lot hardware. CMM inspection of three randomly selected screws confirmed all critical dimensions within ±0.05 mm of nominal. Constructs assembled by trained technicians following device IFU torque specifications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two load levels or configurations to characterise model response across the COU envelope.",
      "rationale": "Testing performed under a single ASTM F1717 configuration (static compression-bending, 10 mm offset). A second load level or torsion configuration was not included in this validation activity. This factor does not meet the required level; the gap is accepted on the basis that the single configuration is the regulatory standard and that supplemental torsion data are available in a separate COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and geometry match test fixture geometry and load application point to within measurement uncertainty; documented parameter mapping table.",
      "rationale": "A parameter mapping table (PMT-CB-001) cross-references each FEA boundary condition to its physical counterpart in the test fixture. Fixture geometry digitised from engineering drawings supplied by the test laboratory. Load application offset (10.0 mm nominal, 9.97 mm measured) replicated in FEA to within 0.03 mm."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval <1.96 and percentage difference <10% for all three QoIs; pre-specified in validation plan prior to data unblinding.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy both acceptance criteria. E/uval values of 0.61, 0.52, and 0.64 are well below 1.96. Percentage differences of 2.9%, 2.5%, and 3.1% are well below 10%. Acceptance criteria were pre-specified in validation plan VP-CB-003 Rev A, approved prior to data unblinding."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to regulatory submission endpoints and clinically relevant failure modes (fatigue initiation driven by peak stress, correlated to stiffness and yield force).",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and referenced in FDA guidance on spinal implant submissions. Peak stress at the screw-rod junction, the primary fatigue initiation site, correlates directly with these global QoIs under the linear-elastic regime validated here."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, material, loading, and boundary conditions are representative of the COU; any differences formally documented and assessed.",
      "rationale": "The validation scenario uses production-representative hardware, the regulatory standard test configuration, and the same FEA model (post-revision build) used for the COU prediction. The only documented difference is the use of a rigid vertebral body block surrogate in testing versus idealised rigid boundary conditions in FEA, assessed as introducing <1% QoI error based on sensitivity analysis."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 1 vs. required 2) is accepted on the basis of regulatory precedent and availability of supplemental torsion data in a parallel COU. All three QoIs satisfy pre-specified quantitative acceptance bounds. The experimental datasets used in this assessment (bench test results vintage 2025-10-10; material properties vintage 2025-10-14) predate the November 2025 mesh-density model revision (modelRevisionDate 2025-11-03); however, the credibility assessment team determined that the revision was confined to FEA discretization and did not alter boundary conditions, load definitions, or material input cards, and therefore judged the pre-revision datasets as remaining applicable without formal re-validation against the revised model build. Overall credibility is assessed as sufficient to support a Medium assurance level submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
