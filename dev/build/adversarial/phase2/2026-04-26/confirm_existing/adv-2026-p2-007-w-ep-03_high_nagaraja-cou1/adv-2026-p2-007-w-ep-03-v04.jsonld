  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-required factor (Test conditions, achieved 1 vs. required 2) is accepted based on regulatory precedent that ASTM F1717 represents a standardized worst-case condition and FDA has historically accepted single-condition F1717 data for pedicle screw submissions. All three primary QoIs satisfy the pre-established acceptance bounds (<10% difference, E/uval < 1.96). The material property dataset (dataVintage 2025-08-28) predates the model revision (2025-09-15) by approximately three weeks; the team assessed the revision — which updated only the post-yield hardening slope — as not material to the stiffness and yield-force QoIs governed by the linear-elastic regime. Overall credibility is sufficient to support the regulatory submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
