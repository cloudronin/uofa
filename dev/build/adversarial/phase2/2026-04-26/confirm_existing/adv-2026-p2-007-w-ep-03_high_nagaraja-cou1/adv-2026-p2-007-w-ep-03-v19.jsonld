  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment is Accepted at Medium assurance level. All 13 V&V 40 factors assessed; 12 of 13 meet or exceed required level. The single below-required factor (Test conditions, achieved 1 vs. required 2) is accepted given the standardized F1717 single-condition protocol. Quantitative validation metrics satisfy E/uval < 1.96 for all three QoIs. The material property dataset (dataVintage 2025-10-14) predates the model revision of 2025-11-03 by approximately three weeks; the modeling team determined that the November revision — which updated cortical shell thickness parameterization — did not alter material specifications or boundary conditions, and therefore assessed the pre-revision dataset as remaining applicable without formal re-validation. This determination was made by engineering judgment and is documented in internal memo FEA-2025-113 but was not subjected to independent review or quantitative sensitivity confirmation against the revised model build.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
