  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All three QoIs satisfy the pre-established acceptance bounds (relative error <10%, E/uval <1.96). Twelve of thirteen credibility factors meet or exceed required levels. The single shortfall (Test conditions, Gradation 1 vs. required Gradation 2) is documented and accepted on the basis that the ASTM F1717 compression-bending protocol is the regulatory reference condition for this device class and that clinical loading is dominated by this mode. The material property dataset (dataVintage 2025-10-10) predates the model revision (2025-11-03) by approximately three weeks; the revision was limited to mesh density and contact formulation changes that do not affect constitutive law parameterization, and the dataset is therefore judged to remain current and applicable without re-characterization. Overall credibility is assessed as sufficient to support a Medium assurance level submission for a Class II device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
