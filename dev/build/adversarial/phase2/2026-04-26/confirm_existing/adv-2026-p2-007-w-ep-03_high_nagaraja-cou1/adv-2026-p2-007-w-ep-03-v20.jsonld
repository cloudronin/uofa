  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve factors meet or exceed required levels. One factor (Test conditions) achieves Gradation 2 against a required Gradation 3; this shortfall is accepted because ASTM F1717 prescribes a single test condition and model influence is Medium. Quantitative output comparison satisfies all pre-established acceptance bounds (max QoI difference 7.3%, max E/uval 1.41). The November 2025 model revision introduced updated cortical bone block compliance corrections; the primary bench test dataset (dataVintage 2025-10-09) predates this revision by approximately 25 days. The modeling team assessed this revision as not material to the dataset's relevance — the compliance correction affects predicted stiffness by less than 0.5% and does not alter the experimental records — and therefore did not conduct a formal re-validation cycle against the updated model build. Overall credibility is sufficient to support a Medium assurance level decision for this Class II device.",
    "decidedAt": "2025-11-21T00:00:00Z"
  },
