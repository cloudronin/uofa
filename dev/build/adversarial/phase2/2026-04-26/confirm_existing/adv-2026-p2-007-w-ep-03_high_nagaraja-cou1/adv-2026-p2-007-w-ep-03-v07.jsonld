  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-noncannulated-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility level. One factor (Test conditions) achieves Gradation 1 against a required Gradation 2; this gap is accepted on the basis that ASTM F1717 specifies a single standard configuration and the regulatory submission does not claim multi-angle performance. All three QoIs pass quantitative acceptance bounds. The Ti-6Al-4V material property dataset (vintage 2024-08-22) predates the model revision (2024-09-15) by 24 days; the assessment team determined the September revision affected only cortical bone analog contact stiffness parameters and was not material to the metallic property inputs. This determination was made by engineering judgment without formal re-validation against the revised model build. Overall credibility is judged sufficient for a Class II Medium model risk level submission.",
    "decidedAt": "2024-11-04T00:00:00Z"
  },
