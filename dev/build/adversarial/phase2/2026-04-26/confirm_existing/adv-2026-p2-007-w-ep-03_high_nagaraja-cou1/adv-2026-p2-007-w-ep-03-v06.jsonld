  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-noncannulated-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors assessed. Twelve factors meet or exceed required levels. One factor (Test conditions) achieves Gradation 1 against a required Gradation 2; risk accepted given ASTM F1717 is the applicable regulatory standard and no additional loading modes are within scope. All three QoIs pass quantitative acceptance criteria (E/uval <1.96; relative difference <10%). The material property dataset (MPL-2025-084, dataVintage 2025-08-18) predates the model revision of 2025-09-15 by approximately four weeks. The modelling team documented a qualitative assessment that the revision — updating rod-clamp contact friction from 0.22 to 0.26 — is not material to the titanium bulk-property inputs provided by that dataset. However, no formal re-validation or sensitivity analysis quantifying the interaction between the updated friction parameter and the material inputs was performed. Overall credibility is assessed as sufficient for a Medium assurance level decision.",
    "decidedAt": "2025-11-04T13:00:00Z"
  },
