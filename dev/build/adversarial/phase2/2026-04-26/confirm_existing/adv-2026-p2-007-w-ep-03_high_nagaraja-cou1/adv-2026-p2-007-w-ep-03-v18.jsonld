  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single below-required factor (Test conditions, achieved 1 vs. required 2) is mitigated by the explicit COU restriction to the ASTM F1717 compression-bending configuration and by two-laboratory replication. All three QoIs satisfy the pre-established 10% difference and E/uval < 1.96 acceptance criteria. The model revision of 2025-11-03 introduced a thread-root fillet radius correction; the modelling team assessed this change as not material to the coupon-derived material property dataset (dataVintage 2025-10-10) because the revision affected only geometric parameters. This assessment was not supported by a formal re-validation against the revised model, which constitutes an unresolved epistemic gap acknowledged by the team but not treated as a blocking issue given the narrow scope of the geometric change.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
