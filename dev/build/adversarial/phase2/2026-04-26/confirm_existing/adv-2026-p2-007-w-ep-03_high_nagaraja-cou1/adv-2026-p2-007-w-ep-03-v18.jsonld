    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force residual norm <1e-4 at each load increment; energy balance error <0.1%. Required level 1: solver convergence monitored.",
      "rationale": "Nonlinear static analysis used incremental Newton-Raphson with force residual tolerance 1e-5. All 11 simulation runs converged within 25 increments; no divergence events recorded. Energy balance error <0.05% across all runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup and boundary conditions by a qualified analyst not involved in model construction. Required level 2: documented independent review.",
      "rationale": "An independent senior analyst reviewed boundary condition definitions, contact pair assignments, and load application against the ASTM F1717 test fixture geometry. Review findings addressed prior to final simulation runs; no critical errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model (bilinear isotropic hardening) validated against coupon data; contact formulation appropriate for screw-rod interface. Required level 2: model form justified by literature or prior validation.",
      "rationale": "Bilinear isotropic hardening with kinematic hardening parameter derived from coupon test data is well established for Ti-6Al-4V in quasi-static loading. Augmented Lagrange contact at screw-rod and rod-block interfaces is consistent with published ASTM F1717 FEA practice."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon tests on production bar stock; geometric inputs from calibrated CMM measurements. Required level 2: inputs traceable to measurement data.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus were derived from the Ti-6Al-4V coupon dataset (dataVintage 2025-10-10). Geometric dimensions were measured on three production screws by CMM; mean values used as nominal inputs. Input uncertainty propagated via ±1 SD sensitivity runs. The model underwent a minor revision on 2025-11-03 to update the thread-root fillet radius based on updated metrology; the coupon material dataset predating this revision was judged by the modelling team to remain applicable because the revision affected only geometric, not material, parameters — however, no formal re-validation against the updated model configuration was performed with the pre-revision dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lots; samples representative of commercial device population. Required level 2: sample size justified and traceability documented.",
      "rationale": "N=11 constructs assembled from production-lot screws and UHMWPE blocks per ASTM F1717. Lot traceability records confirm screws manufactured to the same drawing revision as the FEA geometry. Sample size provides coefficient of variation characterisation sufficient for E/uval metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of COU loading scenarios; at minimum two load levels or configurations tested. Required level 2: multiple test conditions bracketing COU.",
      "rationale": "Only a single ASTM F1717 configuration (35 mm offset, compression-bending) was tested. The COU is explicitly limited to this configuration, but the single condition prevents confirmation of model fidelity across a loading envelope. This factor is below required level and is a documented limitation acknowledged in the decision record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA inputs (geometry, material, boundary conditions) demonstrably equivalent to physical test configuration. Required level 2: quantitative comparison of key input parameters.",
      "rationale": "CMM-measured screw geometry agrees with FEA nominal geometry within 0.05 mm. Material property inputs match coupon mean values within 1.2%. Fixture geometry and boundary conditions replicate ASTM F1717 test fixture as confirmed by fixture drawing review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All three QoIs (stiffness, yield force, force at 40 mm) within 10% of experimental mean and E/uval < 1.96. Required level 2: quantitative metric-based comparison.",
      "rationale": "Stiffness difference 1.97% (E/uval 0.81), yield force difference 1.87% (E/uval 0.94), force at 40 mm difference 2.12% (E/uval 1.09). All three QoIs satisfy both acceptance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly relate to clinical failure modes of pedicle screw constructs. Required level 2: QoI-to-failure-mode linkage documented.",
      "rationale": "Construct stiffness relates to load sharing and adjacent-level effects; yield force and force at 40 mm displacement relate to fatigue life prediction and permanent deformation under physiological loading. All three QoIs are endorsed by FDA guidance on spinal implant computational modelling."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches COU device, loading mode, and material. Required level 2: validation scenario demonstrably representative of COU.",
      "rationale": "Validation uses the identical non-cannulated 7.5 mm pedicle screw geometry, Ti-6Al-4V material, and ASTM F1717 compression-bending configuration as the COU. Two-laboratory testing mitigates laboratory-specific bias. The validation scenario is considered sufficiently representative of the COU despite the single test condition limitation."
    }
