  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required gradation level. One factor (Test conditions) achieved Gradation 1 against a required Gradation 2; risk accepted on the basis of strong quantitative agreement at the tested condition (E/uval ≤ 1.71 for all QoIs) and established regulatory precedent for single-condition ASTM F1717 submissions. The material property dataset (dataVintage 2025-08-01) predates the model revision of 2025-09-15 by approximately six weeks; the assessment team reviewed the revision change log and concluded the updated thread-root fillet geometry and contact stiffness scaling factor do not affect material property assignments, rendering formal re-validation of the material dataset unnecessary. Overall credibility evidence is judged sufficient to support the Medium assurance level required for this Class II, Model Risk Level 3 COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
