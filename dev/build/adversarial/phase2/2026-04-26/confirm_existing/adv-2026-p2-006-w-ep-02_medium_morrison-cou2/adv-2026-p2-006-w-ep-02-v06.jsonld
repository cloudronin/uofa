  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a documented QA plan with traceability to test cases covering hemolysis model routines.",
      "rationale": "The CFD solver is used under an informal QA process. Unit tests exist for core flow routines but hemolysis sub-model routines lack formal test coverage. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include method-of-manufactured-solutions (MMS) or equivalent for all governing equations including hemolysis transport.",
      "rationale": "MMS was applied to the Navier-Stokes solver but not to the hemolysis damage accumulation transport equation. Gap identified at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study must be performed on hemolysis QoI across at least three systematically refined meshes.",
      "rationale": "Grid convergence index (GCI) was computed across three mesh levels for pressure rise and flow uniformity. Hemolysis index GCI was computed on two mesh levels only, falling short of the three-level requirement at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental conditions used for validation must match COU operating envelope including fluid temperature, hematocrit, and shear exposure history.",
      "rationale": "Validation experiments were performed using bovine blood at 37°C across five operating points. Hematocrit was controlled to 33±2%. However, shear exposure history protocol deviated from COU clinical conditions, reducing equivalency at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty U_val) must be computed for hemolysis index at each operating point with statistical confidence bounds.",
      "rationale": "Experiments were performed and hemolysis index was compared at all five operating points. Validation uncertainty was estimated but confidence intervals were not propagated through the hemolysis power-law model, limiting the comparison to point estimates only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI must be the hemolysis index (HI) directly; surrogate quantities such as wall shear stress alone are insufficient.",
      "rationale": "Hemolysis index was the primary QoI in both simulation and experiment. Intermediate quantities (shear stress, exposure time) were also reported. Achieved level 4 due to minor reliance on derived sub-quantities."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry and operating conditions representative of the COU device and patient population.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry which approximates but does not replicate the proprietary VAD geometry. Operating conditions span the clinical range but the highest-risk low-flow high-speed corner was not included in validation experiments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off contributions to hemolysis QoI must be quantified.",
      "rationale": "Iterative residuals were monitored but no formal solver error budget was constructed for the hemolysis QoI. Flagged as epistemic gap at MRL 5; factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that simulation setup was independently reviewed and that boundary condition application was verified against documented procedures.",
      "rationale": "No independent review of simulation setup was conducted. Boundary conditions were set by the analyst without peer verification. Factor not assessed at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified against alternative constitutive models with sensitivity analysis on model-form uncertainty.",
      "rationale": "The Giersiepen-Wurzinger power-law was selected without comparison to alternative hemolysis models such as the Arora or Taskin formulations. Model-form sensitivity was not quantified. Achieved level 2 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo UQ must propagate uncertainty in all hemolysis power-law coefficients and blood rheology parameters through to HI output distribution.",
      "rationale": "Monte Carlo UQ was performed propagating uncertainty in two of five hemolysis model coefficients. Blood viscosity uncertainty was included; red blood cell fragility distribution was not. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of blood sample variability (donor variability, storage time, anticoagulant effects) must be documented and linked to validation uncertainty.",
      "rationale": "Blood sample provenance was partially documented. Donor variability across experimental replicates was not systematically characterized. Factor not assessed at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal parameter equivalency analysis must demonstrate that simulation input parameters match experimental conditions within quantified tolerances for all five operating points.",
      "rationale": "No formal equivalency analysis was performed linking simulation boundary conditions to measured experimental conditions. Rotational speed and flow rate were matched nominally but tolerances were not propagated. Factor not assessed at MRL 5."
    }
