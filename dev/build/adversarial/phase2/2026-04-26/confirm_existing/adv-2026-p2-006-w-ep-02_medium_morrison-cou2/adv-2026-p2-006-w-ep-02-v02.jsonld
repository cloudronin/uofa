    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be fully characterized and traceable; fluid properties, temperature, hematocrit, and pump geometry tolerances must be documented with uncertainty bounds.",
      "rationale": "Hematocrit and temperature were controlled and documented. Pump geometry tolerances were reported but surface roughness of the impeller was not measured; only nominal CAD values used. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) must be computed with combined simulation and experimental uncertainty; metric must be below acceptance threshold at all operating points.",
      "rationale": "Relative error computed at all five operating points; all are below 15%. However, combined uncertainty (simulation + experimental) was not propagated into a formal validation metric u_val per ASME V&V 20. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation (NIH) must be the same metric used in the clinical decision; mapping from model output to clinical threshold must be explicit and documented.",
      "rationale": "NIH is the clinically relevant hemolysis metric and is used directly in both validation and decision-making. However, the mapping from CFD-predicted NIH to the clinical threshold of 0.01 mg/100 L is stated in the submission but not formally documented in a traceable decision matrix. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
