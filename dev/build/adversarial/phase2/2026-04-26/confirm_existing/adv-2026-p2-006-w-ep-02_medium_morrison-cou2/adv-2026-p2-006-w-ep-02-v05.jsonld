  "hash": "sha256:3f7a1c9e2b4d6f8a0e5c7b9d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a",
  "signature": "ed25519:4a8b2c6d0e4f8a2b6c0d4e8f2a6b0c4d8e2f6a0b4c8d2e6f0a4b8c2d6e0f4a8b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented QA procedures including version control, regression testing, and release validation at level commensurate with MRL 5.",
      "rationale": "The CFD solver (OpenFOAM v8) is open-source with community QA practices. Formal regression test suite covers core solvers but hemolysis-specific user-defined functions lack independent verification. Version control is maintained but formal release documentation does not meet MRL 5 requirements. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions or manufactured solutions for the relevant flow physics at MRL 5 level of rigor.",
      "rationale": "Method of manufactured solutions was applied to the Navier-Stokes solver demonstrating second-order spatial convergence. However, the power-law hemolysis sub-model has not been subjected to code verification against a manufactured solution. Achieved level 2; required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be formally estimated using Richardson extrapolation or equivalent GCI methodology across at least three systematically refined meshes.",
      "rationale": "Three systematically refined meshes (4.2M, 12.1M, 31.8M cells) were used to estimate GCI. Grid convergence index for hemolysis index is 8.3% at the finest mesh level, exceeding the target of 5% for MRL 5. Spatial discretization error is quantified but not within acceptable bounds. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate clinical operating envelope including fluid properties, temperature, and hematocrit levels representative of patient population at MRL 5.",
      "rationale": "Experiments were performed using bovine blood at 37°C with hematocrit 35±2%. Clinical VAD operation spans a broader hematocrit range (25–45%) and includes anticoagulation effects not captured in the bench test. Temperature control was maintained within ±0.5°C. Test conditions partially match COU but do not span full patient variability. Achieved level 3; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty) must be computed and compared against an acceptance threshold derived from clinical requirements at MRL 5.",
      "rationale": "Hemolysis index predictions were compared against experimental measurements at five operating points. Mean absolute error is 18.4% across all points; two operating points exceed 25% error. Validation uncertainty has been computed but the acceptance threshold based on clinical hemolysis limits has not been formally established, preventing a definitive pass/fail determination. Achieved level 3; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation must directly correspond to the clinical decision quantities at MRL 5.",
      "rationale": "The normalized index of hemolysis (NIH) is used as the primary QoI in validation, consistent with the clinical decision metric. However, the model predicts a modified power-law hemolysis index that requires post-processing conversion to NIH, introducing an additional transformation step not subject to independent verification. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on a geometry, flow regime, and fluid that are representative of the clinical COU at MRL 5.",
      "rationale": "Validation was conducted on the FDA generic centrifugal pump, which shares the impeller topology with the clinical VAD but differs in volute geometry and clearance gaps. The clinical device operates at higher rotational speeds (up to 5500 RPM) than the validation envelope (3000–4000 RPM). Relevance gap is significant. Achieved level 2; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error contributions must be characterized and shown to be negligible relative to discretization error.",
      "rationale": "Iterative convergence was monitored via residual norms (target 1e-5 for velocity, 1e-4 for pressure) and was achieved for all operating points. However, round-off error has not been assessed, and the contribution of iterative error to the total numerical error budget has not been formally separated from discretization error. Factor flagged as not-assessed at MRL 5 level of rigor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that model setup, boundary condition specification, and post-processing are performed consistently and free from user-induced error, verified by independent review.",
      "rationale": "No independent review of model setup has been performed. Boundary conditions were specified by the primary analyst without secondary verification. Inlet velocity profiles were derived from an upstream 1D model whose assumptions have not been documented. Use error is an uncharacterized epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The appropriateness of the governing equations, turbulence closure, and hemolysis sub-model form must be justified relative to the flow physics of the COU at MRL 5.",
      "rationale": "The k-omega SST turbulence model is used without justification for the transitional, rotationally dominated flow within the pump impeller. The Giersiepen power-law hemolysis model was calibrated on Couette flow data and its applicability to complex three-dimensional shear histories in centrifugal pumps is undemonstrated. Model form uncertainty is the dominant uncharacterized source of error. Not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with uncertainty bounds derived from measurement data or literature, and sensitivity analysis must identify dominant inputs at MRL 5.",
      "rationale": "Monte Carlo uncertainty quantification was performed sampling blood viscosity and density from literature distributions. However, the hemolysis model coefficients (C, alpha, beta in the power-law) were treated as fixed constants without uncertainty characterization, despite being the most sensitive inputs identified in prior literature. Partial UQ does not satisfy MRL 5 requirements. Not assessed at required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used in validation must be characterized for material properties and biological variability, with sample size sufficient to support statistical comparison at MRL 5.",
      "rationale": "Validation experiments used a single batch of bovine blood with n=3 replicates per operating point. Batch-to-batch variability in hemolysis susceptibility is not characterized. Sample size is insufficient for statistical comparison at MRL 5. The biological variability of bovine versus human blood for hemolysis is not quantified. Not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the simulation must be demonstrably equivalent to those present in the experimental validation scenario, including geometric fidelity and boundary condition matching.",
      "rationale": "The computational geometry was reconstructed from CAD drawings of the FDA generic pump. Dimensional inspection data confirming as-built geometry of the experimental test article against the CAD model is not available. Clearance gaps between impeller and housing, which are critical to hemolysis prediction, were set to nominal values without measurement confirmation. Equivalency is assumed but unverified. Not assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction has been reviewed. Seven of thirteen credibility factors were formally assessed; all achieved levels fall below required levels for MRL 5. Six factors remain not-assessed, representing significant epistemic gaps. Validation results from experiments performed across operating points show mean absolute error of 18.4% with two points exceeding 25%. Monte Carlo UQ was completed for fluid property inputs but hemolysis model coefficient uncertainty is uncharacterized. Despite these gaps, the assessment is accepted as a complete documentation of the current credibility state, with the explicit understanding that the model is NOT accepted for regulatory submission without remediation of the identified gaps. The decision record captures the current evidence state for iterative improvement.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
