  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Credibility assessment reviewed by the assessment team. Seven of thirteen factors assessed; all show achieved levels below required levels for MRL 5. Six factors remain not-assessed, representing epistemic gaps. Validation results were generated across five operating points; experiments were performed under controlled laboratory conditions and results compared against CFD predictions. Despite incomplete provenance records for several validation results — generation activities were not formally linked for all comparisons — the overall body of evidence is judged sufficient to support a conditional acceptance at reduced confidence. Provenance closure for all validation results is required prior to regulatory submission.",
