      "acceptanceCriteria": "Software used for CFD hemolysis simulation must be under formal configuration management with documented testing and regression suite at level commensurate with MRL 5.",
      "rationale": "The CFD solver is used under a basic version-control scheme, but formal V&V test suite coverage and release qualification records are incomplete. Achieved level 2 against required level 4 for MRL 5 Class III device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions studies must confirm correct implementation of governing equations for blood flow and hemolysis transport.",
      "rationale": "Basic benchmark problems (lid-driven cavity, Poiseuille flow) were executed and passed, but manufactured-solutions verification for the hemolysis scalar transport equation was not performed. Gap remains at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence index (GCI) study on hemolysis index QoI across at least three systematically refined meshes.",
      "rationale": "Three-mesh GCI study performed at the design operating point; GCI on hemolysis index is 4.8%, within acceptable bounds. Study not repeated at off-design operating points, leaving residual uncertainty at those conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
