  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Configuration management, version control, and regression testing must be documented for all solver components used in hemolysis prediction at MRL 5.",
      "rationale": "Version control is in place for the CFD solver, but regression testing against hemolysis-specific benchmarks is absent. No formal configuration management plan covering the hemolysis damage accumulation subroutine was produced. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method of manufactured solutions must be demonstrated for the hemolysis transport equation and the turbulence model in use.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the hemolysis damage accumulation model. Method of manufactured solutions has not been applied to the scalar transport equation used to track red blood cell exposure. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must be performed on hemolysis index QoI across at least three systematically refined meshes at each operating point.",
      "rationale": "GCI analysis was completed on velocity and pressure fields across three mesh levels. GCI on the hemolysis index itself was performed only at the nominal operating point; the four off-design points lack formal discretization error estimates. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope in fluid properties, hematocrit, and anticoagulation protocol; deviations must be quantified.",
      "rationale": "Experiments were performed using bovine blood at 33% hematocrit; the COU specifies human blood at 35–40% hematocrit. Anticoagulation protocol differences are noted but not quantified as uncertainty contributors. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalised RMSE, validation uncertainty) must be computed for all five operating points using a validation metric consistent with ASME V&V 20.",
      "rationale": "Qualitative agreement plots are provided for all five operating points. Quantitative RMSE and validation uncertainty per ASME V&V 20 were computed only for two operating points. No aggregate validation metric is reported. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (hemolysis index) must be directly the same quantity used in the COU decision; surrogate QoIs must be justified with quantitative mapping.",
      "rationale": "The hemolysis index used in validation matches the COU QoI definition. However, the damage model exponent constants were calibrated on a different pump geometry; the relevance of those constants to the FDA centrifugal pump is asserted but not demonstrated quantitatively. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the full COU operating envelope (all five flow-speed combinations) and must use a device geometry representative of the intended COU device.",
      "rationale": "Validation experiments were performed on the FDA generic pump geometry, which matches the COU device. However, only three of the five COU operating points are covered by experimental data; the remaining two are extrapolated. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off, and solver-specific numerical diffusion must be characterised for the hemolysis transport equation.",
      "rationale": "Iterative residual convergence is reported for momentum and continuity. Numerical diffusion in the scalar hemolysis transport equation has not been assessed. This factor is flagged as an epistemic gap at MRL 5 and is not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that analyst setup choices (boundary condition application, turbulence model selection, meshing strategy) are consistent with documented best practices and have been independently reviewed.",
      "rationale": "No independent review of analyst setup choices was performed. Turbulence model selection rationale is provided in a memo but not peer-reviewed. Flagged as epistemic gap; not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The power-law hemolysis damage model must be justified against alternative model forms (e.g., strain-based, threshold-based) with sensitivity analysis demonstrating that model form uncertainty is bounded.",
      "rationale": "The power-law Giersiepen-Wurzinger model is used without comparison to alternative formulations. Model form uncertainty is acknowledged in the Monte Carlo UQ but not systematically bounded. Not assessed at MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs (fluid viscosity, damage model constants, inlet velocity profile) must have documented probability distributions derived from experimental characterisation, with sensitivity rankings reported.",
      "rationale": "Monte Carlo UQ was performed with assumed uniform distributions on damage model constants. No experimental characterisation of the constant distributions is available; distributions are expert-elicited without formal elicitation protocol. Not assessed at required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental replicates must be sufficient to characterise inter-sample variability in hemolysis measurements; minimum three independent pump units tested.",
      "rationale": "Experimental data were collected from a single pump unit with repeated measurements. Inter-unit variability is not characterised. This is a known gap flagged during assessment scoping; factor is not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
