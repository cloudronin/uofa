  "signature": "ed25519:7a3c1f9e2b6d4a8c5f0e3b7d2a9f6c4e1b8d5a2f9e6c3b0d7a4f1e8c5b2d9a6f",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite with traceability to release version; configuration management records required for all simulation inputs.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has a published verification test suite, but configuration management records for the specific solver version and user-defined hemolysis subroutine are incomplete. No formal software quality plan was maintained for the UDF hemolysis model. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must be performed on hemolysis transport equation discretization; manufactured solution verification required.",
      "rationale": "Grid convergence index (GCI) analysis was performed on velocity and shear stress fields. However, formal order-of-accuracy verification using the method of manufactured solutions was not applied to the hemolysis power-law transport equation. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified on hemolysis QOI with GCI < 5% on finest mesh; three systematically refined meshes required.",
      "rationale": "Three mesh refinements were performed (4M, 12M, 36M cells). GCI on velocity was 3.2%, but GCI on hemolysis index was 11.7% on the finest mesh due to near-wall shear stress sensitivity. Discretization error on the primary QOI exceeds the required threshold. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match COU operating envelope with documented traceability; blood analog fluid properties must be characterized at test temperature.",
      "rationale": "Experiments were performed using a glycerin-water blood analog at controlled temperature. However, the experimental flow rate uncertainty (±0.3 L/min) was not propagated into the simulation boundary conditions, and the rotational speed was not independently verified during hemolysis measurement runs. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E% or u_val) must be computed with experimental uncertainty included; validation must cover all 5 COU operating points.",
      "rationale": "Hemolysis index comparisons were made at 3 of the 5 required operating points. Validation metrics were computed without formal experimental uncertainty quantification. Two operating points at extreme flow-speed combinations were not experimentally tested. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QOI must be the normalized index of hemolysis (NIH) or equivalent absolute hemolysis measure directly mapped to the COU clinical threshold.",
      "rationale": "The modified index of hemolysis (MIH) was used as the primary validation QOI and maps directly to the absolute clinical threshold. The linkage between MIH and the NIH clinical endpoint is well-documented in the literature. Minor gap: the conversion factor between blood analog and whole blood hemolysis was not experimentally characterized for this specific pump geometry. Achieved level 4 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating regime as the COU; any surrogate geometry must be justified with similarity arguments.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry, which is the same geometry as the COU. However, experiments used a glycerin-water analog rather than bovine blood, and rotational speeds tested span only 3000–3600 RPM versus the COU envelope of 2800–4500 RPM. The extrapolation to higher speeds is not validated. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual tolerance < 1e-6 on all equations including hemolysis transport; solver round-off error must be bounded.",
      "rationale": "Iterative convergence monitoring was not systematically documented for the hemolysis transport equation. Residual logs were not retained for all operating point simulations. This factor was flagged as not assessed due to absence of convergence records. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition assignment, and post-processing scripts must be documented; peer check of hemolysis UDF implementation required.",
      "rationale": "No independent peer review of the hemolysis UDF implementation or simulation setup was performed. The analysis was conducted by a single analyst without documented cross-check. Use error assessment is flagged as not assessed at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified with sensitivity analysis; hemolysis power-law model constants must be characterized for the specific blood analog used.",
      "rationale": "The k-omega SST turbulence model was selected based on general pump literature without sensitivity analysis comparing alternative turbulence closures. The Giersiepen-Wurzinger hemolysis power-law constants were taken from literature without recalibration for the glycerin-water analog. Model form uncertainty is not quantified. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty characterization; Monte Carlo UQ must propagate input uncertainty through hemolysis prediction.",
      "rationale": "Monte Carlo UQ was performed on 4 of the 11 identified uncertain input parameters (fluid viscosity, inlet flow rate, rotational speed, hemolysis model exponent). Seven parameters including surface roughness, blood analog density variation, and outlet pressure boundary uncertainty were not included in the UQ sweep. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterize hemolysis variability; statistical power analysis must justify the number of replicate measurements.",
      "rationale": "Experimental hemolysis measurements were taken with n=3 replicates per operating point, with no statistical power analysis justifying this sample size. At MRL 5, a minimum of n=10 replicates with formal variance characterization is expected. This factor was not assessed. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between simulation input parameters and experimental conditions must be formally demonstrated; any substitutions (e.g., blood analog for whole blood) must be justified with similarity metrics.",
      "rationale": "No formal equivalency analysis was performed between the glycerin-water analog fluid properties and whole human blood under VAD operating shear rates. The Reynolds number similarity was noted qualitatively but not quantified across the full operating envelope. This factor is not assessed at MRL 5. Achieved level 1 against required level 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor shortfalls relative to the MRL 5 requirements, the assessment team accepted the package for submission to the regulatory body with documented gaps. The Monte Carlo UQ results demonstrate that hemolysis predictions remain below the clinical threshold even at the 95th percentile of the uncertainty distribution for the three validated operating points. Acceptance is conditional on experimental validation at the two unvalidated extreme operating points prior to final device submission. The provenance of individual validation result computations was reviewed at the study level; experiments were performed under a documented test protocol and results were recorded in the study report, providing sufficient traceability for the current submission stage.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
