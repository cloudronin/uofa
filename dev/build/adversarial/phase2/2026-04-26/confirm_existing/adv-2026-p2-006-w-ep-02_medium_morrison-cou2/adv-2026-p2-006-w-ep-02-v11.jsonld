  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under a documented SQA plan with version control, regression testing, and change control procedures appropriate for Class III device simulation.",
      "rationale": "The solver (OpenFOAM 9) is used with a project-level version control policy, but formal regression test coverage is limited to 40% of relevant solver modules. No independent SQA audit has been performed. Achieved level 2 is below the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and manufactured solution benchmarks must demonstrate correct implementation of governing equations for blood flow and scalar hemolysis transport.",
      "rationale": "Order-of-accuracy testing was completed for the Navier-Stokes solver but not for the hemolysis scalar transport equation. The manufactured solution suite covers only laminar flow regimes. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be reported for hemolysis index QoI on at least three systematically refined meshes at each operating point.",
      "rationale": "GCI was computed at two of five operating points using three mesh levels. At the remaining three operating points only two mesh levels were used, preventing formal GCI estimation. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating conditions within specified tolerances for flow rate, rotational speed, fluid properties, and temperature.",
      "rationale": "Experiments were performed using a blood analog fluid (glycerol-water) rather than fresh human blood. Temperature was controlled to within 1 °C of target. Flow rate and speed tolerances were met. The fluid substitution introduces a known but unquantified deviation in hemolysis mechanism fidelity. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic comparison metric (e.g., E_rel or validation uncertainty interval) must be reported for hemolysis index at each operating point, with uncertainty bands on both simulation and experiment.",
      "rationale": "Relative error was computed at all five operating points; however, experimental measurement uncertainty was reported only as a single pooled value rather than per-operating-point. Simulation uncertainty intervals from Monte Carlo UQ were available for all points. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (hemolysis index) must be directly mapped to the clinical endpoint (plasma free hemoglobin accumulation) used in the regulatory submission.",
      "rationale": "The normalized index of hemolysis (NIH) is the validated QoI and is the standard clinical metric. The mapping from NIH to chronic hemolysis risk is established in literature but carries acknowledged model-form uncertainty in the power-law damage accumulation model. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full operating envelope of the COU, including off-design conditions, and use a geometry sufficiently representative of the intended device.",
      "rationale": "Validation used the FDA generic pump geometry, which differs from the intended commercial VAD geometry in impeller blade count and volute design. Only five operating points were tested; the clinical operating envelope spans a broader range. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be characterized and shown to be negligible relative to discretization error for all operating points.",
      "rationale": "Iterative residual convergence was monitored but no formal round-off error analysis was performed. The factor was flagged as an epistemic gap at MRL 5; achieved level 1 reflects absence of evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documentation must demonstrate that simulation setup (boundary conditions, mesh generation, solver settings) was reviewed by an independent analyst.",
      "rationale": "No independent review of simulation setup was conducted. A single analyst performed all model configuration steps. Factor not assessed; epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis damage accumulation model must be justified through sensitivity analysis and comparison with higher-fidelity reference data.",
      "rationale": "The k-omega SST turbulence model was selected based on prior pump literature without formal sensitivity analysis against LES or DNS data. The power-law hemolysis model (Giersiepen-Wurzinger) was used without evaluation of alternative forms. Factor not assessed; epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis index predictions to key input parameters (viscosity, density, damage model coefficients) must be quantified via Monte Carlo or equivalent method.",
      "rationale": "Monte Carlo UQ was performed over five input parameters using 500 samples per operating point. However, the damage model coefficients were treated as fixed (literature point estimates) rather than uncertain inputs due to absence of published uncertainty bounds. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample characterization (blood analog batch properties, red blood cell analog fragility) must be documented with traceability to each test run.",
      "rationale": "Batch certificates for the glycerol-water analog were not retained for all test runs. Traceability between specific fluid batches and individual operating-point experiments is incomplete. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal mapping must demonstrate that simulation input parameters (geometry, boundary conditions, fluid properties) are equivalent to those of the physical test within quantified tolerances.",
      "rationale": "No formal equivalency mapping document was produced. Geometry was imported from a CAD file without dimensional verification against the as-tested pump. Factor not assessed; epistemic gap at MRL 5."
    }
