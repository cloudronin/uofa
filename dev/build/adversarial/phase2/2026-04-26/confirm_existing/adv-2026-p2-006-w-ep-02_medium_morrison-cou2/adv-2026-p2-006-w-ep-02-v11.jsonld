  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction is accepted for regulatory submission purposes with documented limitations. All seven assessed credibility factors show achieved levels below required levels for MRL 5, and six factors remain not assessed, representing material epistemic gaps. The decision to accept is conditioned on the submission being accompanied by a gap remediation plan and on regulatory reviewer awareness that the model is used as supporting — not primary — evidence for the hemolysis acceptance argument. Experiments were performed and validation results recorded across five operating points; however, generation provenance for a subset of validation results was not fully captured in the structured evidence record, which is flagged as a documentation deficiency to be remediated prior to final submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
