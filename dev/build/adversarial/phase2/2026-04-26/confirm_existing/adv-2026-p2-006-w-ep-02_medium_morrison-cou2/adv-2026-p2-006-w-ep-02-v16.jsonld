    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be verified against established benchmarks with documented version control and regression testing at Level 4.",
      "rationale": "Version control is in place and unit tests exist, but formal regression test suite and independent code review required at MRL 5 are absent. Achieved Level 2 against required Level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing against manufactured solutions must be documented for all governing equation terms at Level 4.",
      "rationale": "Code verification was performed only for steady-state continuity and momentum equations using the method of manufactured solutions. Turbulence model terms and hemolysis transport equation were not subjected to order-of-accuracy testing. Achieved Level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must demonstrate discretization error below 5% on all QoIs at Level 4.",
      "rationale": "Three-mesh GCI study was conducted; discretization error on pressure rise is 2.1% but on NIH is 11.3%, exceeding the 5% threshold. Achieved Level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match COU operating conditions within stated uncertainty bounds at Level 4.",
      "rationale": "Flow rate and rotational speed were controlled within ±2% of target values. Blood analogue viscosity was matched at 37°C but hematocrit variability across test runs was not fully characterised. Achieved Level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or MAPE) must be computed with uncertainty on both model and experiment at Level 4.",
      "rationale": "Relative errors were computed but experimental measurement uncertainty was not propagated into the comparison metric. Systematic bias in NIH measurements was identified but not corrected. Achieved Level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly mapped to clinical hemolysis endpoints at Level 4.",
      "rationale": "NIH is directly relevant to the clinical endpoint. However, sub-lethal blood damage metrics (e.g., platelet activation) that contribute to chronic hemolysis are not included as QoIs. Achieved Level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use clinical-grade blood at VAD operating conditions spanning the full COU envelope at Level 5.",
      "rationale": "Validation used a Newtonian blood analogue rather than clinical-grade blood and covered only 3 of 5 COU operating points. The geometric model is the FDA generic pump, not the specific VAD device. Achieved Level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point error bounds must be formally documented and demonstrated at Level 4.",
      "rationale": "Solver convergence was monitored via residual drop but no formal analysis of iterative error or floating-point round-off was performed. Flagged as epistemic gap at MRL 5. Achieved Level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition specification, and post-processing scripts must be documented at Level 4.",
      "rationale": "No independent peer review of the simulation setup was conducted. Boundary condition specification was performed by a single analyst without cross-check. Epistemic gap flagged. Achieved Level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to turbulence model choice and hemolysis model constants must be quantified and bounded at Level 5.",
      "rationale": "A single turbulence model (k-omega SST) and a single hemolysis power-law model were used. No model-form uncertainty analysis was performed. Critical epistemic gap at MRL 5. Achieved Level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters must be characterised with probability distributions and propagated through Monte Carlo UQ at Level 4.",
      "rationale": "Monte Carlo UQ was performed on geometric tolerances and inlet flow rate. Blood rheological parameters and hemolysis model exponents were treated as deterministic. Partial UQ coverage yields Achieved Level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterise inter-sample variability in hemolysis measurements with stated statistical confidence at Level 4.",
      "rationale": "Only three replicate measurements per operating point were available. Statistical power to detect 15% differences in NIH is below 0.6. Epistemic gap flagged at MRL 5. Achieved Level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the simulation must be demonstrated to be equivalent to those in the validation experiment within quantified bounds at Level 4.",
      "rationale": "The CFD inlet velocity profile was derived from an idealised analytical expression rather than from experimental measurements at the pump inlet. Equivalency between simulation inputs and experimental conditions was not formally demonstrated. Epistemic gap. Achieved Level 1."
    }
