  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite with regression testing and configuration management at level consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has a documented QA framework including regression test suite and version-controlled configuration. However, the blood-specific hemolysis sub-model is implemented as a user-defined function without an independent QA audit trail, resulting in achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal code verification including method of manufactured solutions or equivalent for all governing equations employed in the hemolysis simulation.",
      "rationale": "Code verification was performed for the Navier-Stokes solver using the method of manufactured solutions and confirmed second-order spatial accuracy. The hemolysis power-law model was not subjected to equivalent formal verification, limiting the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with Richardson extrapolation on hemolysis index QoI across at least three systematically refined meshes.",
      "rationale": "A three-level mesh refinement study was performed (4M, 12M, 32M cells) with Richardson extrapolation applied to the hemolysis index. Grid convergence index for the hemolysis QoI was 8.2%, exceeding the target threshold of 5% for MRL 5, hence achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be fully characterized and match COU operating envelope with documented uncertainty in flow rate, rotational speed, and fluid temperature.",
      "rationale": "Bench experiments were performed with porcine blood analog at five operating points. Flow rate and rotational speed were measured with calibrated instrumentation (±1.5% and ±10 RPM respectively). Fluid temperature was monitored but not controlled to the precision required at level 4, and hematocrit variability across test runs was not fully documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) applied to hemolysis index predictions against measurements, with uncertainty in both simulation and experiment explicitly propagated.",
      "rationale": "Comparisons were performed using the area validation metric. Experimental uncertainty was estimated from repeated runs (n=3 per operating point). Simulation uncertainty from Monte Carlo UQ was included. The combined validation metric indicated model inadequacy at two of five operating points, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index) must be identical to those used in the COU decision, with no surrogate quantities substituted.",
      "rationale": "The normalized index of hemolysis (NIH) was used as the primary QoI in both validation and the COU decision, consistent with FDA guidance. However, the COU requires prediction of modified index of hemolysis (MIH) for absolute comparison against clinical thresholds, and conversion factors introduce additional uncertainty not fully characterized at the required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate COU geometry, fluid properties, and operating conditions with high fidelity; any deviations must be formally assessed for their impact on predictive credibility.",
      "rationale": "Validation was conducted on the FDA generic centrifugal pump, which shares the same geometry as the COU device. However, experiments used a porcine blood analog rather than human blood, and operating conditions covered 5 of 12 COU operating points. Extrapolation to the remaining operating points was not formally validated, resulting in a significant gap between required level 5 and achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off effects must be documented and shown to be negligible relative to discretization error.",
      "rationale": "Residuals were converged to 1e-5 for continuity and momentum. However, the hemolysis scalar transport equation exhibited oscillatory convergence at two operating points, and a formal assessment of iterative error contribution to QoI uncertainty was not performed, limiting achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that the model was applied consistently with developer intent, including documented simulation workflow, boundary condition specification review, and independent result check.",
      "rationale": "Use error assessment was flagged as an epistemic gap at MRL 5. No independent review of boundary condition specification or simulation workflow was performed by a party outside the modeling team. Achieved level assigned as 2 based on internal documentation alone."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis model form (power-law or mechanistic) must be justified through literature evidence and sensitivity analysis demonstrating that model form uncertainty is bounded and acceptable for the COU.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected based on widespread use in the literature. No formal model form uncertainty quantification was performed, and alternative mechanistic models were not evaluated. This represents a significant epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model inputs must be characterized with probability distributions and propagated through Monte Carlo UQ; sensitivity analysis must identify dominant input contributors to QoI uncertainty.",
      "rationale": "Monte Carlo UQ was performed on geometric tolerances and inlet flow conditions. However, the hemolysis model coefficients (C and alpha in the power-law) were treated as fixed nominal values rather than uncertain inputs, despite published variability of up to 30%. This gap limits the achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient replicate test samples to characterize inter-sample variability in hemolysis measurements, with statistical power analysis justifying sample size.",
      "rationale": "Only three replicate measurements were available per operating point. No statistical power analysis was performed to justify this sample size for MRL 5. Inter-sample variability was high (CV up to 22% at operating point 4), and additional replication was not feasible within the project timeline."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency assessment demonstrating that input parameters used in validation experiments match those in the COU, including fluid rheology, pump geometry, and surface finish.",
      "rationale": "The validation experiments used porcine blood analog with viscosity matched to human blood at 37°C. Surface finish of the test pump differed from the COU device (Ra 0.4 μm vs 0.8 μm). No formal equivalency assessment was performed to bound the impact of these differences on hemolysis predictions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps, the assessment team determined that the CFD model provides sufficient evidence to support regulatory submission under a risk-mitigated framework. The Monte Carlo UQ results demonstrate that hemolysis predictions remain below the clinical threshold with 90% confidence at four of five validated operating points. Remaining gaps in model form, test samples, and equivalency of inputs are acknowledged and documented for post-market surveillance planning. The broken provenance on several validation results was noted informally — experiments were performed at the external facility and results were compiled — but the structured activity links were not uniformly recorded in this package.",
