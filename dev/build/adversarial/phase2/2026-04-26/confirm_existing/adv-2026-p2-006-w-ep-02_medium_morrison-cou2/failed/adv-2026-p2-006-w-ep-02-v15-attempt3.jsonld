  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite all seven assessed credibility factors achieving levels below their required levels, and six factors remaining unassessed, the decision record reflects a provisional acceptance pending remediation. The Monte Carlo UQ results demonstrate that hemolysis predictions remain below the absolute clinical threshold across all sampled operating conditions. The assessment team accepted the package at low assurance level with the understanding that all credibility gaps must be resolved prior to regulatory submission. Validation results were reviewed; experiments were performed under controlled laboratory conditions and results were compared against CFD predictions across multiple operating points.",
