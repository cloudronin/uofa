  "signature": "ed25519:7a2f1b9c4e6d3a8f2c5b1e9d4a7c3f6b2e8a1d5c9f3b7e2a6d4c1f8b5e3a9d7c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulations must be under formal configuration management with documented version control, issue tracking, and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "The CFD solver is version-controlled and has a documented test suite; however, the regression suite does not cover the high-shear rotating flow regimes relevant to hemolysis prediction. Configuration management records are incomplete for third-party turbulence model libraries. Achieved level 2 is below required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing must be demonstrated for the Navier-Stokes solver and the hemolysis transport equation on problems with known analytical solutions or manufactured solutions.",
      "rationale": "Order-of-accuracy testing was performed for the base Navier-Stokes solver using the method of manufactured solutions; however, the hemolysis scalar transport equation was not independently verified. Achieved level 2 does not satisfy the MRL 5 requirement of level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A systematic grid convergence study using at least three mesh refinement levels must be performed with Richardson extrapolation and GCI reported for hemolysis index QoI at each operating point.",
      "rationale": "A three-level grid convergence study was performed at two of the five operating points; GCI values ranged from 4.2% to 11.8% for hemolysis index, indicating moderate discretization uncertainty. Remaining three operating points lack independent convergence data. Achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental conditions used for validation must match COU operating conditions in fluid properties, hematocrit, temperature, and pump geometry within documented tolerances. All boundary conditions must be traceable to calibrated measurements.",
      "rationale": "Experiments were performed using bovine blood at physiological hematocrit; however, temperature was held at 22°C rather than 37°C, introducing uncertainty in viscosity and red cell fragility. Inlet flow waveforms were steady rather than pulsatile as in the VAD COU. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index values must be compared against experimental measurements with quantified experimental uncertainty; comparison metric must include both bias and scatter components across all five operating points.",
      "rationale": "Comparisons were performed at five operating points; predicted hemolysis indices show average bias of 18% relative to experimental means. Experimental uncertainty was partially characterized — plasma-free hemoglobin measurement uncertainty was reported but sampling variability across repeated experiments was not. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (hemolysis index) must be the same metric used in the regulatory submission decision, and the hemolysis model (power-law) must be assessed for suitability to the specific shear exposure distributions in the VAD.",
      "rationale": "The normalized index of hemolysis (NIH) is used consistently as QoI in both validation and COU. However, the power-law hemolysis model was calibrated on Couette flow data and its applicability to the complex three-dimensional shear histories in the centrifugal pump impeller has not been formally assessed. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry under the same operating envelope as the COU, with blood analogue or blood at matched hematocrit and flow rates spanning the full COU operating range.",
      "rationale": "Validation used the FDA benchmark pump geometry, which matches the COU device. However, experiments were conducted at steady flow while the VAD COU involves pulsatile loading; only 3 of 5 COU operating points were covered by validation experiments. The gap in pulsatile conditions significantly limits relevance. Achieved level 2 is well below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all transport equations; floating point round-off sensitivity must be assessed for hemolysis accumulation along particle trajectories.",
      "rationale": "Iterative convergence monitoring was performed but residual targets were set at 1e-4, not 1e-5 as required. Floating point sensitivity analysis for hemolysis accumulation along Lagrangian particle trajectories was not conducted. This factor was flagged as an epistemic gap and not formally assessed at MRL 5 requirements. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence must be provided that the CFD model setup, boundary condition specification, and post-processing were performed and independently reviewed by qualified personnel following documented procedures.",
      "rationale": "No formal use-error assessment was conducted. Model setup was performed by a single analyst without independent peer review of boundary condition assignments or post-processing scripts. Documentation of analyst qualifications is not on file. Flagged as epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The suitability of the turbulence model (SST k-omega) and the hemolysis power-law model for predicting hemolysis in rotating machinery must be assessed through sensitivity studies and literature comparison.",
      "rationale": "Model form uncertainty was not formally assessed. Turbulence model selection (SST k-omega) was not compared against alternative closures for the rotating impeller flow. The power-law hemolysis model exponents were taken from literature without uncertainty bounding. This constitutes a significant epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model inputs (fluid properties, geometry tolerances, boundary conditions) must be characterized with probability distributions and propagated through the model via Monte Carlo or equivalent UQ method.",
      "rationale": "Monte Carlo UQ was performed propagating uncertainty in inlet flow rate and rotational speed; however, uncertainty in blood viscosity, hematocrit, and hemolysis model coefficients was not included in the UQ ensemble. Partial UQ coverage yields achieved level 2, below required level 4. Formally flagged as not-assessed due to incomplete input characterization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood samples used in validation experiments must be characterized for hematocrit, age, donor variability, and storage conditions, with statistical summary of inter-sample variability reported.",
      "rationale": "Experimental reports describe use of pooled bovine blood but do not provide donor count, blood age at time of experiment, or storage protocol. Inter-sample variability in fragility was not characterized. This limits the ability to bound biological variability in hemolysis measurements. Not formally assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal equivalency assessment must demonstrate that the input parameter space of the validation experiments envelopes the input parameter space of the COU operating conditions.",
      "rationale": "No formal equivalency assessment was conducted. Validation experiments covered a subset of the COU operating envelope; pulsatile flow conditions present in the VAD COU were not represented in any validation experiment. The gap between validation and COU input spaces is unquantified. Not assessed. Achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction has been reviewed. Although multiple credibility factors show achieved levels below required levels for MRL 5, the Monte Carlo UQ analysis provides partial coverage of input uncertainty and the validation dataset covers the primary operating points. Experiments were performed under controlled laboratory conditions and results were compared against CFD predictions across five operating conditions. The assessment is accepted as a complete and transparent documentation of current credibility gaps, to be used as the basis for a gap-closure plan prior to regulatory submission. The decision to accept this assessment record does not constitute acceptance of the model for regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
