      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent order-of-accuracy test demonstrating expected convergence rate for the governing equations.",
      "rationale": "Order-of-accuracy verification performed for Navier-Stokes solver using manufactured solution on structured hexahedral mesh sequence. Second-order spatial convergence confirmed (observed order 1.97). Iterative convergence to residual 1e-6 verified for all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
