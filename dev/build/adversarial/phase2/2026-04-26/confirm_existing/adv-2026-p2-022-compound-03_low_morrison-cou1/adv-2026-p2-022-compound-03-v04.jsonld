      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index compared to experimental measurements with quantified agreement metric (e.g., normalised RMSE < 15%).",
      "rationale": "Predicted normalised index of hemolysis (NIH) compared against experimental photometric measurements across all five operating points. Normalised RMSE = 9.8%. Worst-case single-point error 13.2%. Acceptance criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
