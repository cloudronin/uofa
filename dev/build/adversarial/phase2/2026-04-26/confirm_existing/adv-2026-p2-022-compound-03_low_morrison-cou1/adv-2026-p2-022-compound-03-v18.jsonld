      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; input uncertainty propagation deferred to higher MRL activities.",
      "rationale": "Input uncertainty quantification not required at MRL 2. Material property uncertainties (viscosity, density) documented in test report. Sensitivity of RH to ±5% viscosity variation estimated qualitatively as low based on prior literature."
    },
