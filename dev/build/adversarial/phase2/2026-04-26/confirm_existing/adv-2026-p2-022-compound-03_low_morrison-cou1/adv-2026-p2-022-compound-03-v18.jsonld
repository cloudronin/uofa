      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary conditions and material properties verified against documented COU inputs.",
      "rationale": "Independent peer review of simulation setup completed by senior analyst. Boundary conditions cross-checked against test protocol. No use errors identified. Rotating reference frame setup and interface treatment confirmed correct."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; model form uncertainty acknowledged in uncertainty budget.",
      "rationale": "Model form assessment scoped out at MRL 2 per ASME V&V 40 Table 1. SST k-omega turbulence model selected based on literature precedent for rotating machinery hemolysis prediction. Model form uncertainty noted qualitatively in uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
