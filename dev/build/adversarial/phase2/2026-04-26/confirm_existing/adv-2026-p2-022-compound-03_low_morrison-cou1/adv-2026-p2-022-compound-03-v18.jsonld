      "acceptanceCriteria": "SQA plan documented; version control and regression testing in place for CFD solver.",
      "rationale": "ANSYS Fluent v19.2 used with documented SQA procedures. Version control confirmed via institutional software registry. Regression test suite covers 12 benchmark cases relevant to rotating machinery flows."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities confirm solver correctly implements governing equations for rotating frame CFD.",
      "rationale": "Method of manufactured solutions applied to rotating reference frame Navier-Stokes implementation. Observed order of accuracy 1.92 consistent with nominal second-order scheme. No anomalous convergence behavior detected."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI across all 5 operating points; Richardson extrapolation applied on at least three systematically refined meshes.",
      "rationale": "Mesh refinement study conducted on two mesh densities (3.2M and 6.8M cells). GCI estimated at 12.4% for the peak-shear operating point. A third mesh level was not generated due to computational resource constraints. Richardson extrapolation therefore not fully applicable. Discretization uncertainty exceeds the 5% acceptance threshold at two of five operating conditions, yet the factor is reported as meeting requirements in the summary table."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) documented and traceable to calibrated instrumentation.",
      "rationale": "FDA generic pump test loop operated at 2.5 L/min and 3500 RPM. Fluid temperature 37 ± 0.5 °C. Calibration records for flow meter and tachometer on file. Blood analog (glycerol-water) viscosity characterised by rheometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) within 20% of experimental measurement across all validation operating points.",
      "rationale": "NIH predictions range from 8% to 17% deviation from experimental values across 5 operating conditions. All within the 20% acceptance band. Systematic over-prediction observed at high-speed conditions consistent with known turbulence model limitations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to clinical hemolysis risk metric used in regulatory submission.",
      "rationale": "Relative hemolysis index RH derived from volume-averaged scalar stress and Lagrangian particle tracking exposure time. RH is the primary regulatory metric per FDA guidance. Direct correspondence confirmed with clinical endpoints in device labeling."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on same pump geometry and fluid at COU-representative operating conditions.",
      "rationale": "Validation performed on FDA generic pump geometry identical to COU device geometry. Operating conditions span COU envelope. Blood analog fluid properties within 5% of clinical blood viscosity. Validation relevance judged adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual levels below 1e-5 for all transport equations confirmed for each simulation.",
      "rationale": "All five operating-point simulations converged to residuals below 1e-5 for continuity, momentum, and turbulence equations. Mass imbalance below 0.01%. Convergence histories archived in simulation log files."
    },
    {
      "factorStandard": "ASME-VV40-2018",
