      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residuals converged to at least 1e-5 for continuity and momentum; mass imbalance < 0.1%.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum equations. Global mass imbalance confirmed below 0.05% for all five operating points. Convergence histories archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary conditions and material properties verified against COU specification.",
      "rationale": "Independent peer review of simulation setup conducted by second engineer. Boundary conditions, turbulence model selection (SST k-omega), and blood analog properties verified against COU specification document. No discrepancies identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equations and constitutive models (turbulence model, hemolysis power-law model) justified for the flow regime and QoI.",
      "rationale": "SST k-omega turbulence model selected based on literature evidence for rotating machinery at Re > 1e5. Giersiepen-Wurzinger power-law hemolysis model applied; model form uncertainty acknowledged and bounded by comparison against Bludszuweit model predictions (difference < 8%)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis performed for key uncertain inputs (viscosity, pump geometry tolerances); influence on QoI quantified.",
      "rationale": "One-at-a-time sensitivity analysis performed for blood analog viscosity (±10%), pump clearance gap (±50 µm), and inlet flow rate (±5%). Hemolysis index sensitivity coefficients computed. Clearance gap identified as dominant input; ±50 µm variation produces ±12% change in NIH."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples (pump units) documented with manufacturing records confirming geometry within specification.",
      "rationale": "FDA benchmark pump units used in experimental data generation are documented in the FDA Critical Path initiative dataset. Manufacturing conformance to nominal geometry confirmed by coordinate measurement machine (CMM) records available in the public dataset documentation."
    },
