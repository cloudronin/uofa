  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the CFD model demonstrates sufficient credibility for the intended COU at High assurance level. Thirteen factors were assessed across verification, validation, and uncertainty quantification domains. The majority of factors met or exceeded required levels. The discretization error GCI of 14.3% was noted but judged acceptable given that the fine mesh was used consistently across all production runs and the output comparison showed agreement within 17.4% normalized RMS error. The team determined that the breadth of validation activities, independent peer review, and sensitivity analysis collectively support a High assurance declaration for the CPB hemolysis prediction use case.",
    "decidedAt": "2026-04-19T00:00:00Z"
