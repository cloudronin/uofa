  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; six were scoped as not-assessed per MRL 2 protocol. The majority of assessed factors meet or exceed required levels. The discretization error factor achieved level 1 against a required level of 2; however, the team judged this shortfall to be acceptable given the conservative nature of the hemolysis model and the favorable output comparison results. Overall credibility is assessed as High and the model is accepted for the stated COU.",
