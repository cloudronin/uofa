      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) compared to experimental measurements with agreement within combined experimental and numerical uncertainty.",
      "rationale": "Predicted RH values compared against FDA experimental hemolysis measurements. Mean absolute error of 12% observed across 5 operating points, within the combined uncertainty envelope. Pressure-head predictions agree within 8% across all conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to clinical hemolysis risk metric used in regulatory submission.",
      "rationale": "The relative hemolysis index is the primary regulatory QoI for CPB device submissions. CFD outputs of scalar stress and exposure time are integrated via the Giersiepen-Wurzinger power-law model to yield RH directly comparable to bench measurements."
