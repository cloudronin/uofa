      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with traceable measurement uncertainty and must span the COU operating envelope.",
      "rationale": "FDA generic pump experimental data were collected at 5 flow-speed operating points covering the full COU envelope. Measurement uncertainty for flow rate (±2%) and rotational speed (±0.5%) is documented in the test report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must be compared quantitatively against experimental measurements with documented error metrics and uncertainty bounds.",
      "rationale": "Predicted relative hemolysis index values are compared against experimental measurements at all 5 operating points. Mean absolute error is 8.3% and all predictions fall within experimental uncertainty bands. Comparison metrics are documented in the validation report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress distribution) must be directly relevant to the COU decision criterion (RH < 1).",
      "rationale": "The primary validation QoI is the relative hemolysis index (RH), which is identical to the COU acceptance criterion. Secondary QoIs include volume-averaged shear stress and exposure time distributions, both directly linked to the power-law hemolysis model used in the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
