  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver (ANSYS Fluent 2023 R1) must hold ISO 9001 certification and documented V&V test suite for turbomachinery applications.",
      "rationale": "ANSYS Fluent 2023 R1 is ISO 9001:2015 certified. Internal SQA documentation (revision 23.1.4) confirms passing of all turbomachinery regression tests. Achieved level equals required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical rotating-disk flow must confirm second-order spatial convergence within 5% of theoretical rate.",
      "rationale": "Method of manufactured solutions applied to rotating-disk Couette flow confirmed 1.94-order spatial convergence (theoretical: 2.0), within the 5% tolerance. Code verification requirement satisfied at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI on hemolysis index QoI must yield GCI < 5% on the fine-to-medium mesh pair.",
      "rationale": "Three-level mesh refinement study (coarse 4.2 M, medium 9.8 M, fine 21.4 M cells) yielded GCI_fine = 1.8% for the hemolysis index at 3500 RPM. Exceeds MRL 2 requirement; achieved level 3 recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental flow loop conditions (fluid viscosity, hematocrit, temperature) must be documented and match CFD boundary conditions within stated tolerances.",
      "rationale": "FDA experimental dataset documents bovine blood at 37 ± 0.5 °C, hematocrit 33 ± 2%, viscosity 3.2 ± 0.3 mPa·s. CFD boundary conditions set to nominal values; sensitivity to tolerance bounds evaluated and found negligible for hemolysis index QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized hemolysis index prediction error must be within ±15% of experimental mean across all tested operating points.",
      "rationale": "CFD-predicted hemolysis index compared against FDA experimental data at five operating points (3000–5000 RPM, 2–6 L/min). Maximum normalized error was 11.4% at 4500 RPM / 2 L/min. All points within ±15% acceptance band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index and peak shear stress must be demonstrated as direct surrogates for clinical red blood cell damage in CPB applications per published literature.",
      "rationale": "Hemolysis index as defined by ASTM F1841 is the accepted clinical surrogate for RBC damage in CPB. Peak shear stress exposure integral correlates with plasma-free hemoglobin elevation per Giersiepen et al. (1990) and Goubergrits & Affeld (2004). QoI relevance established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same FDA generic centrifugal pump geometry and operate within the CPB flow and speed envelope defined in the device intended use.",
      "rationale": "All validation activities used the FDA-published generic centrifugal blood pump STL geometry without modification. Operating conditions span the CPB envelope (3000–5000 RPM, 2–6 L/min) matching the intended device use. Validation relevance confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; iterative convergence monitoring to residual < 1e-5 on all equations is sufficient.",
      "rationale": "At MRL 2, formal solver error quantification beyond residual monitoring is not required. All simulations converged to scaled residuals < 1e-5 for continuity, momentum, and turbulence equations. Factor scoped to level 1 per MRL 2 guidance."
    },
    {
      "type": "CredibilityFactor",
