      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification documentation is sufficient.",
      "rationale": "Analysts hold documented CFD competency per laboratory SOPs. Formal use-error study not required at MRL 2. Factor acknowledged at level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection must be documented with literature justification.",
      "rationale": "SST k-omega turbulence model selected based on prior FDA CFD round-robin benchmarking (Stewart et al., 2012). Non-Newtonian blood rheology modeled via Carreau-Yasuda fit. Model form justified by literature; formal uncertainty quantification deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "All model inputs (fluid properties, rotational speed, boundary pressures) sourced from FDA experimental protocol and ASTM F1841. Parametric sensitivity not required at MRL 2; nominal values documented in simulation plan SP-CPB-2024-03."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; use of published FDA reference dataset with documented sample provenance is acceptable.",
      "rationale": "FDA generic pump experimental dataset (n=3 independent test runs per operating point) used as reference. Sample characterization beyond published metadata not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative equivalency argument between validation and COU conditions is sufficient.",
      "rationale": "Validation conditions (FDA generic pump, bovine blood, CPB operating envelope) are qualitatively equivalent to the COU device and patient population. Formal equivalency mapping not required at MRL 2; qualitative argument documented in credibility plan CP-CPB-2024-01."
    }
