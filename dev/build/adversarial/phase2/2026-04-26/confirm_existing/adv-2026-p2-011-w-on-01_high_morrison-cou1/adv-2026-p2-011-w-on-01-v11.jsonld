  "signature": "ed25519:b7c3e1f2a4d5b6c7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver (ANSYS Fluent 2022 R2) with documented QA plan, regression test suite passing, and traceable build records satisfy MRL-2 SQA requirements.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially validated CFD solver with ISO 9001-certified QA process. Release notes, regression test logs, and software version records are archived. All SQA artifacts meet the Gradation 2 evidence threshold for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using method of manufactured solutions (MMS) for the Navier-Stokes solver confirms second-order spatial convergence, meeting MRL-2 code verification requirements.",
      "rationale": "MMS studies performed on canonical pipe-flow and rotating-disk benchmarks demonstrate second-order convergence in velocity and pressure fields. L2 norm errors decrease at rate 1.97 ± 0.04 with mesh refinement, confirming solver implementation correctness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based Grid Convergence Index (GCI) below 5% for scalar stress metrics on the production mesh, demonstrating discretization error is bounded and acceptable for MRL-2 hemolysis prediction.",
      "rationale": "Three-level mesh refinement study (2.1M, 5.8M, 14.3M cells) yields GCI of 2.8% for volume-averaged scalar stress and 3.4% for peak stress at worst-case operating point. Production mesh (5.8M cells) selected as balance of accuracy and computational cost. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet pressure, flow rate, fluid temperature, hematocrit) documented with calibrated instrumentation and traceability to NIST standards, reproducing CFD boundary conditions within 2% tolerance.",
      "rationale": "Experimental hemolysis measurements conducted at FDA CDRH laboratory using bovine blood with hematocrit 33 ± 1%, temperature 37 ± 0.5°C, and flow rates measured by Coriolis flowmeter (±0.5% accuracy). Inlet/outlet pressures recorded via calibrated transducers. Test conditions bracket the CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predicted by CFD agrees with experimental measurements within 10% across the operating map, satisfying MRL-2 validation accuracy requirements for hemolysis prediction.",
      "rationale": "CFD-predicted NIH compared against 15 experimental operating points. Mean absolute percent error is 5.7%, maximum error 9.1% at 3500 RPM / 7 L/min. Bland-Altman analysis shows no systematic bias. Agreement is within the 10% acceptance threshold across the full CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (NIH and scalar stress distribution) directly maps to the clinical endpoint of hemolysis risk in CPB patients, with regulatory acceptance criteria referenced from ISO 10993-4 and FDA guidance on blood-contacting devices.",
      "rationale": "NIH is the standard regulatory metric for hemolysis in blood-contacting devices per FDA guidance. Scalar stress threshold of 150 Pa over 620 ms exposure time is derived from published hemolysis power-law models. QoI selection directly supports the decision question of worst-case operating condition identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same FDA generic centrifugal pump geometry, identical fluid properties, and overlapping operating conditions as the intended CPB use case, ensuring validation activities are directly relevant to the COU.",
      "rationale": "Validation dataset uses FDA-specified generic pump geometry (publicly available STL), bovine blood as surrogate for human blood in accordance with ASTM F1841, and operating conditions spanning the CPB clinical range. Geometric and operational similarity between validation and deployment contexts is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit iterative convergence quantification beyond residual monitoring is not required. Residual drop of 4 orders of magnitude is documented as sufficient evidence.",
      "rationale": "Solver residuals converge to 1e-6 for continuity and momentum equations. Mass imbalance below 0.01%. At MRL 2, this level of convergence monitoring satisfies the not-assessed disposition without requiring formal iterative error quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use-error analysis is not required. Simulation execution checklist and peer review of model setup are documented as sufficient controls.",
      "rationale": "Model setup reviewed by independent CFD engineer prior to production runs. Checklist covering boundary condition assignment, material property entry, and turbulence model selection is completed and archived. Not-assessed disposition is acceptable at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal model-form uncertainty quantification is not required. Selection of SST k-omega turbulence model and power-law hemolysis model is justified by literature precedent and documented in the simulation plan.",
      "rationale": "SST k-omega selected based on published benchmark performance for rotating machinery flows. Power-law hemolysis model (Giersiepen et al.) is the regulatory standard for CFD hemolysis assessment. Model form assumptions are documented and consistent with FDA guidance. Not-assessed disposition accepted at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal input uncertainty propagation is not required. Nominal input values with documented sources and single-parameter sensitivity checks are sufficient.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and hematocrit (33%) sourced from published physiological references and matched to experimental conditions. Single-parameter sensitivity runs confirm NIH varies less than 3% with ±10% perturbation of viscosity. Not-assessed disposition is acceptable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of test sample variability is not required. Documentation of blood source, preparation protocol, and storage conditions is sufficient.",
      "rationale": "Bovine blood sourced from USDA-inspected facility, prepared per ASTM F1841, and used within 48 hours of collection. Lot-to-lot variability not formally characterized; acceptable at MRL 2 given the regulatory precedent for bovine blood as hemolysis test surrogate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency mapping between experimental and simulation input parameters is not required. Qualitative correspondence documented in the simulation plan is sufficient.",
      "rationale": "Experimental and CFD boundary conditions are matched at nominal operating points. Differences between bovine and human blood rheology are acknowledged and documented as a known scope item. Equivalency not formally quantified; not-assessed disposition accepted at MRL 2."
