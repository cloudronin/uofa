  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified against published benchmarks and maintain version-controlled build records.",
      "rationale": "ANSYS Fluent 2022 R1 was used with documented QA procedures including regression test suite passage, version control via Git, and benchmark verification against the lid-driven cavity and backward-facing step cases. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing against manufactured solutions must demonstrate expected convergence rate.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver confirmed second-order spatial convergence. Temporal discretization verified to first order for steady-state RANS formulation. Results consistent with published Fluent verification reports."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis must demonstrate discretization uncertainty below 5% of QoI at the operating point of interest.",
      "rationale": "Three-mesh GCI study (coarse 2.1 M, medium 5.8 M, fine 14.2 M cells) performed at 2500 RPM, 5 L/min. GCI on volumetric-averaged shear stress: 3.1%. GCI on NIH: 4.7%. Both below 5% threshold. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with uncertainty quantification and must correspond to simulated operating points within stated tolerances.",
      "rationale": "FDA interlaboratory study experimental conditions documented: flow rate ±0.05 L/min, rotational speed ±10 RPM, fluid viscosity ±2%. Simulation boundary conditions set to match experimental nominal values. Correspondence verified at five operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty) must be computed and reported for primary QoIs.",
      "rationale": "Velocity magnitude comparison against PIV data: mean E% = 8.3% across measurement planes. NIH comparison against bench data: E% = 11.2% at worst-case operating point. Both within acceptable bounds for MRL 2 hemolysis prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the clinical decision quantity (hemolysis index at worst-case operating condition).",
      "rationale": "Primary validation QoI is the Normalized Index of Hemolysis, which is the direct regulatory metric for CPB device hemolysis assessment per FDA guidance. Secondary QoI (velocity field) supports mechanistic plausibility. Both QoIs are directly relevant to the intended decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid properties, and operating envelope as the intended COU.",
      "rationale": "FDA generic centrifugal pump geometry used in validation is identical to the submission geometry. Blood analogue fluid (glycerol-water, viscosity matched to 37 °C blood) matches COU fluid specification. Operating points span the CPB envelope of 3–6 L/min and 2000–3500 RPM."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residuals below 1e-5 for all transport equations is sufficient at MRL 2 without formal solver error quantification.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-6 for continuity and momentum; 1e-7 for turbulence quantities. Factor scoped to level 1 per MRL 2 assessment table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, user error assessment requires only documented simulation setup review by a second analyst.",
      "rationale": "Simulation setup reviewed by second CFD analyst with cardiovascular device experience. No discrepancies identified. Formal use-error quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by comparison of at least two RANS models against experimental data for the pump geometry.",
      "rationale": "SST k-ω and realizable k-ε models compared against FDA PIV data. SST k-ω demonstrated superior agreement in impeller passage and volute regions (mean E% 8.3% vs 13.7%). Giersiepen power-law hemolysis model selected based on published validation for CPB shear exposure ranges."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Material properties and boundary condition inputs must be documented with sources; formal sensitivity analysis not required at MRL 2.",
      "rationale": "Fluid density (1056 kg/m³), dynamic viscosity (3.5 mPa·s), and inlet velocity profiles documented with literature sources. Pump geometry from FDA benchmark dataset. Formal input uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample characterization must confirm fluid properties match simulation inputs; statistical characterization of sample variability not required at MRL 2.",
      "rationale": "FDA interlaboratory study used standardized blood analogue preparation protocol. Viscosity measurements reported per batch. Sample-to-sample variability assessment not required at MRL 2 per assessment table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters must be shown to correspond to experimental conditions within reported measurement uncertainty; formal equivalency mapping not required at MRL 2.",
      "rationale": "Correspondence between simulation and experimental inputs confirmed by direct comparison of nominal values and reported uncertainties. Formal equivalency index calculation not required at MRL 2."
    }
  ],
