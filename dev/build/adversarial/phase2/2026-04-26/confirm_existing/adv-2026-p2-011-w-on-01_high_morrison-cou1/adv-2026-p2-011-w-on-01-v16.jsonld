  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors achieved required levels under MRL 2. Six factors appropriately scoped to level 1 per the MRL 2 assessment table and confirmed not-assessed with documented justification. Discretization error exceeded required level (achieved 3, required 2), providing additional confidence margin. Output comparison E% values within acceptable bounds for hemolysis prediction in CPB application. The assessment team concludes the CFD model provides adequate credibility to support identification of worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in the CPB use context described in the bound Claim and Requirement records.",
