  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level meets or exceeds required gradation for MRL 2; version-controlled solver with documented regression test suite.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under an ISO 9001-certified QMS. Regression tests covering 47 benchmark cases are executed at each release. Version control and change-log documentation satisfy Gradation 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification evidence demonstrates solver correctly implements governing equations for incompressible turbulent flow at MRL 2 gradation.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes and k-ω SST turbulence equations confirms second-order spatial convergence. Published verification suite results for ANSYS Fluent are cited and on file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QOI (hemolysis index) with GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study (2.1M, 5.8M, 14.6M cells) performed at the nominal operating point. GCI on hemolysis index is 3.2% between medium and fine grids; medium grid adopted for production runs per cost-accuracy trade-off documented in the mesh independence report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, pressure rise, fluid properties, temperature) are documented and traceable to calibrated instrumentation with stated uncertainty.",
      "rationale": "FDA benchmark experimental data report (Hariharan et al. 2011) provides full traceability of test conditions across six flow rate and pressure-rise combinations. Fluid temperature, viscosity, and hematocrit are reported with calibration certificates on file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (normalized RMS error or validation metric V) computed between CFD and experimental hemolysis index across all test points.",
      "rationale": "Normalized RMS error across six operating points is 8.4%, within the pre-specified 15% acceptance threshold. Validation metric V per ASME V&V 20 computed as 0.07, indicating model predictions fall within experimental uncertainty bounds at four of six points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs used in validation (hemolysis index, shear stress exposure) are directly relevant to the clinical decision question of worst-case hemolysis identification.",
      "rationale": "The normalized index of hemolysis (NIH) is the regulatory-accepted metric for CPB device hemolysis assessment per FDA guidance. Scalar shear stress and exposure time distributions are secondary QOIs directly informing worst-case condition ranking. Relevance is unambiguous."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments share geometry, fluid, operating range, and hemolysis damage model with the intended CPB deployment scenario.",
      "rationale": "Validation uses the identical FDA generic pump geometry, bovine blood surrogate with matched viscosity and hematocrit, and the same six operating points that bound the CPB clinical envelope. The Giersiepen–Wurzinger hemolysis power-law model applied in validation is the same model used in the COU prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 provided SQA and code verification factors are satisfied.",
      "rationale": "At Model Risk Level 2, explicit iterative solver error quantification beyond residual monitoring is not mandated. Residuals converge to 1e-6 for all equations; this is deemed sufficient given the SQA and code verification evidence already documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
