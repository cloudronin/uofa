      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented regression test suite covering turbulence and scalar transport modules.",
      "rationale": "ANSYS Fluent 2022R2 is used under a validated QA framework with regression tests for all relevant physics modules. Version control and change logs are maintained. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical benchmark cases must confirm expected spatial convergence rate for the discretization scheme employed.",
      "rationale": "Method of manufactured solutions applied to laminar pipe flow and rotating cavity benchmarks confirms second-order spatial accuracy. Results documented in solver verification report MV-2022-04."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for primary QoI (NIH) must be below 10% at the operating point of interest.",
      "rationale": "Three-level mesh refinement study (4.2M, 11.7M, 28.4M cells) performed at 2500 RPM, 5 L/min. Richardson extrapolation yields GCI of 4.3% for NIH, exceeding the required level 2 threshold. Achieved level 3 recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid viscosity, rotational speed) must be reproduced in the simulation to within stated measurement uncertainty.",
      "rationale": "FDA experimental test conditions are replicated: inlet velocity profiles from PIV, outlet static pressure from pressure transducers, blood analog viscosity from rheometry. All boundary conditions within stated ±3% measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rms or validation uncertainty U_val) must be computed and reported for all primary QoIs against experimental reference data.",
      "rationale": "Velocity field RMS error of 7.9% and NIH prediction error of 12.4% computed against FDA experimental dataset. Validation uncertainty U_val calculated per ASME V&V 20 methodology. Both metrics within required bounds for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation must be directly linked to the clinical decision question — identification of worst-case hemolysis operating conditions.",
      "rationale": "Primary QoI is NIH, directly quantifying hemolysis risk. Secondary QoIs (shear stress distribution, exposure time) are mechanistically linked to red blood cell damage. All QoIs traceable to the device performance question."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
