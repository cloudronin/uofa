      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent documented QA process covering version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022 R2 is used under an ISO 9001-certified QA framework. Release notes, regression test suite results, and version-control records were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate order-of-accuracy convergence on canonical benchmark problems relevant to rotating turbomachinery flows.",
      "rationale": "Order-of-accuracy tests on the lid-driven cavity and rotating channel benchmarks confirm second-order spatial convergence. Results are consistent with published verification studies for Fluent in cardiovascular applications."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) for pressure rise and wall shear stress must be below 5% on the production mesh.",
      "rationale": "Richardson extrapolation on three systematically refined meshes (4.2 M, 9.8 M, 22.1 M cells) yields GCI of 2.1% for pressure rise and 3.8% for area-averaged wall shear stress, both below the 5% threshold. Production mesh is the 9.8 M cell configuration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) must match simulation inputs within stated measurement uncertainty.",
      "rationale": "FDA PIV benchmark conditions (2500 RPM, 2.5–7.5 L/min, glycerol-water analogue fluid) are reproduced in the simulation. Fluid viscosity and density match reported experimental values within 1.5%, which is within measurement uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted pressure rise must agree with experimental measurements within 10% across all five validation operating points.",
      "rationale": "Predicted pressure rise deviates by 3.2–7.8% from PIV-derived experimental values across the five operating points. NIH predictions fall within the experimental scatter band for four of five points. Overall agreement is within the 10% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoIs (pressure rise, NIH, wall shear stress) must be directly linked to the clinical risk of hemolysis in CPB applications.",
      "rationale": "Pressure rise governs pump operating point selection; NIH is the regulatory-accepted metric for hemolysis; wall shear stress drives the power-law hemolysis damage model. All three QoIs are directly relevant to identifying worst-case hemolysis conditions for CPB use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same device geometry and a physiologically representative fluid analogue under CPB-range operating conditions.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry identical to the simulation domain. The glycerol-water analogue replicates blood viscosity at CPB hematocrit. Operating conditions span the CPB clinical range (2–6 L/min, 2000–3000 RPM), confirming relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; solver residuals and mass-conservation checks are sufficient.",
      "rationale": "At MRL 2, formal floating-point and iterative solver error quantification is not mandated. Continuity residuals converge to below 1e-5 and global mass imbalance is less than 0.01%, confirming adequate numerical solution quality without formal error budgeting."
    },
    {
      "type": "CredibilityFactor",
