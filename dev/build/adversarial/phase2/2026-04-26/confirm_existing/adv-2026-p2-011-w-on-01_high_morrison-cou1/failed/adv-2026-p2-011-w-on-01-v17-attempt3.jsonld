  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. The model is intended to identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Intended use scope: pre-market submission support for a Class II CPB device, adult patients, normothermic bypass flows 3–6 L/min, rotational speeds 2000–4000 RPM. Note: structured hasContextOfUse link is absent in this Minimal-profile package; use-scope information is conveyed only through this prose and the bound Requirement.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/morrison/model/fda-gcbp-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-gcbp-experimental-hemolysis",
    "https://uofa.net/morrison/data/fda-gcbp-piv-validation",
    "https://uofa.net/morrison/data/gcbp-mesh-convergence-study"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA experimental benchmark — normalized index error < 15% across all six operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation via PIV measurements in the volute and impeller region — mean velocity magnitude error < 8%"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-rise-curve",
      "type": "ValidationResult",
      "name": "Pump pressure-rise curve validation against experimental H-Q data — R² = 0.97 across operating range"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043479",
