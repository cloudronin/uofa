  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This UoA evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Intended use is limited to pre-market submission support for identifying worst-case hemolysis operating points; the model is not intended for patient-specific dosing or real-time control decisions.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-worst-case-identification",
  "bindsClaim": "https://uofa.net/morrison/claim/cfd-hemolysis-cpb-mrl2-acceptable",
  "bindsModel": "https://uofa.net/morrison/model/fda-generic-cbp-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-cbp-piv-experimental-2019",
    "https://uofa.net/morrison/data/fda-cbp-hemolysis-bench-2020"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "Velocity field comparison against PIV measurements at nominal CPB flow conditions"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042665",
