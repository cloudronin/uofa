  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented quality management system with version control and regression testing at Gradation 2.",
      "rationale": "ANSYS Fluent 2021 R2 was used under an ISO 9001-compliant QMS. Version control logs, regression test results, and release notes were reviewed. All software quality activities satisfy Gradation 2 requirements for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The numerical solver must demonstrate correct implementation of governing equations through benchmark problems at Gradation 2.",
      "rationale": "ANSYS Fluent passed established CFD benchmark cases including lid-driven cavity and backward-facing step. Published verification documentation confirms correct implementation of the Navier-Stokes solver and turbulence model at the required gradation level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Spatial and temporal discretization errors must be estimated and shown to be below an acceptable threshold at Gradation 2, using at minimum a three-mesh convergence study.",
      "rationale": "A three-level mesh refinement study was conducted with mesh sizes of 2.1M, 5.8M, and 14.3M cells. Richardson extrapolation yielded a grid convergence index below 2.1% for hemolysis index and 3.4% for pressure rise, exceeding the Gradation 2 threshold. Achieved level recorded as 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and shown to represent the intended operating envelope at Gradation 2.",
      "rationale": "FDA benchmark experimental data were collected at flow rates of 2.5, 5.0, and 7.5 L/min and rotational speeds of 2000–3500 RPM, spanning the CPB operating envelope. Test conditions are fully documented in the FDA benchmark dataset and are representative of clinical CPB use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be quantitatively compared to experimental measurements using appropriate metrics at Gradation 2.",
      "rationale": "Hemolysis index predictions were compared against experimental measurements using normalized RMS error (8.3%) and Bland-Altman analysis. Velocity field comparisons against PIV data showed mean absolute error of 0.04 m/s. Both metrics satisfy Gradation 2 acceptance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest predicted by the model must be directly relevant to the clinical or engineering decision at Gradation 2.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the regulatory standard for hemolysis quantification in CPB devices per FDA guidance. Secondary QoIs include shear stress distribution and pressure-flow characteristics, all directly relevant to worst-case hemolysis identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the intended use context at Gradation 2.",
      "rationale": "Validation was performed using the FDA generic centrifugal blood pump geometry under CPB-representative flow and rotational speed conditions. The validation domain and boundary conditions are directly analogous to the intended clinical use scenario, satisfying Gradation 2 relevance requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off errors must be characterized at Gradation 1 for MRL 2.",
      "rationale": "At MRL 2, Gradation 1 for numerical solver error is acceptable. Residuals were monitored to 1e-5 for all equations as standard practice. Formal characterization beyond residual monitoring is not required at this model risk level and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential errors arising from user setup and interpretation must be acknowledged at Gradation 1 for MRL 2.",
      "rationale": "At MRL 2, Gradation 1 for use error is acceptable. Simulation setup was performed by experienced CFD engineers following a documented simulation plan. Formal use-error analysis beyond standard peer review of the simulation setup has not been conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The appropriateness of the mathematical model form must be acknowledged at Gradation 1 for MRL 2.",
      "rationale": "The SST k-omega turbulence model and power-law hemolysis model (Giersiepen-Wurzinger) are standard choices for blood pump CFD. At MRL 2, Gradation 1 is acceptable and formal model-form uncertainty quantification has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters and boundary conditions must be documented and their sources identified at Gradation 1 for MRL 2.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and inlet velocity profiles were taken from FDA benchmark documentation. At MRL 2, Gradation 1 is acceptable and formal input uncertainty propagation has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The number and selection of experimental test samples used for validation must be acknowledged at Gradation 1 for MRL 2.",
      "rationale": "FDA benchmark experimental data were collected from a single physical pump specimen across multiple operating conditions. At MRL 2, Gradation 1 is acceptable and inter-specimen variability analysis has not been conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The correspondence between simulation input parameters and experimental test conditions must be acknowledged at Gradation 1 for MRL 2.",
      "rationale": "Simulation boundary conditions were set to match the nominal experimental conditions reported in the FDA benchmark dataset. At MRL 2, Gradation 1 is acceptable and formal equivalency analysis of all input parameters has not been performed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-cardiovascular-simulation-group",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. The six not-assessed factors are acceptable at Gradation 1 per ASME V&V 40-2018 Table 5 for Model Risk Level 2. The CFD hemolysis model is deemed credible for identifying worst-case hemolysis operating conditions of the FDA generic centrifugal blood pump in CPB applications and is accepted for use in pre-market regulatory submission support.",
