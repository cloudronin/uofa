  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under a documented QA plan with version control and regression testing.",
      "rationale": "ANSYS Fluent 2021R2 used under an ISO 9001-compliant QA plan. Version control and regression test suite documented in the software QA record SQA-2021-007."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical pipe flow must demonstrate convergence consistent with nominal scheme order.",
      "rationale": "Second-order spatial convergence confirmed via Richardson extrapolation on a manufactured-solution pipe flow benchmark. Observed order 1.94, within 3% of nominal."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5%.",
      "rationale": "Three-level mesh refinement study performed (4.1 M, 9.8 M, 22.6 M cells). GCI on hemolysis index = 3.1%, satisfying the 5% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with uncertainty quantification and replicated in the CFD setup.",
      "rationale": "Inlet flow rates and rotational speeds from PIV experiments are reproduced in CFD boundary conditions. Measurement uncertainty (±1.2% flow, ±5 RPM speed) documented in test report TR-2019-FDA-PIV."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error) for velocity fields must be below 10%; hemolysis index relative error below 15%.",
      "rationale": "Velocity field nRMSE = 4.7% at primary operating point; hemolysis index relative error = 8.2% across 6 operating points. Both within acceptance thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) must be directly linked to the clinical risk of erythrocyte damage in CPB.",
      "rationale": "Hemolysis index per ASTM F1841 and volume-averaged scalar shear stress are the primary QoIs. Both are established surrogates for erythrocyte damage in CPB literature and FDA guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue fluid, and operating envelope as the intended COU.",
      "rationale": "Validation uses FDA generic centrifugal pump geometry, 36% glycerol-water blood analogue (viscosity matched), and operating points spanning the CPB envelope. Geometric and fluid similarity confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; iterative convergence to residuals below 1e-5 documented as sufficient.",
      "rationale": "At MRL 2, full solver error quantification is not required. Iterative residuals converged to below 1e-5 for all equations; mass imbalance below 0.01%. Accepted per MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
