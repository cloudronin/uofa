  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software must have documented version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was used with documented release notes and regression test suite. Version control records confirm reproducibility of simulation runs. SQA level meets MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation via method of manufactured solutions or equivalent benchmark for turbulent flow at MRL 2.",
      "rationale": "Benchmark verification against Taylor-Green vortex and lid-driven cavity cases confirmed correct solver implementation. Published ANSYS verification suite results cited."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported and discretization error must be quantified to MRL 2 standard.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 8.7M, 17.1M cells). GCI for hemolysis index was 3.1% on the fine grid, exceeding MRL 2 requirements. Richardson extrapolation applied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented and traceable to the computational model inputs.",
      "rationale": "FDA pump experimental conditions (flow rate 2.5 L/min, 3500 RPM, hematocrit 35%) were reproduced in simulation. Inlet velocity profiles derived from PIV measurements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or normalized RMS error) must be reported for primary QoI.",
      "rationale": "Normalized index of hemolysis prediction error was 8.2% relative to experimental mean, within the 15% acceptance threshold established for MRL 2. Velocity field RMS error was 6.4%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly linked to the clinical decision endpoint (hemolysis risk identification) and traceable to device requirements.",
      "rationale": "Normalized index of hemolysis (NIH) and scalar stress exposure time are the primary QoIs, directly linked to the CPB device performance requirement of NIH < 0.005 g/100L."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed under conditions sufficiently similar to the intended CPB operating envelope.",
      "rationale": "Validation experiments used the identical FDA generic pump geometry at overlapping flow and speed conditions. Physiological blood analog (glycerol-water) properties matched within 5% of whole blood at 37°C."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, iterative convergence to residuals below 1e-5 is sufficient; formal solver error quantification not required.",
      "rationale": "Residuals converged to 1e-6 for all equations. Formal solver error quantification beyond residual monitoring is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, analyst qualification documentation is sufficient; formal use error analysis not required.",
      "rationale": "Simulation analysts hold relevant CFD qualifications. Formal use error analysis is scoped out at MRL 2 per ASME V&V 40 Table 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documented selection rationale for turbulence and hemolysis sub-models is sufficient.",
      "rationale": "SST k-omega turbulence model and Giersiepen hemolysis power-law model selected based on published literature for rotary blood pumps. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are sufficient; sensitivity analysis not required.",
      "rationale": "Blood viscosity, density, and hemolysis model constants sourced from peer-reviewed literature. Parametric sensitivity analysis is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, sample traceability documentation is sufficient; statistical characterization of experimental variability not required.",
      "rationale": "FDA pump experimental dataset is publicly available with documented fabrication tolerances. Statistical characterization of inter-sample variability is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative equivalency argument between validation and COU conditions is sufficient.",
      "rationale": "Validation conditions (FDA pump geometry, physiological flow rates) are qualitatively equivalent to CPB operating conditions. Formal equivalency metric computation is not required at MRL 2."
    }
