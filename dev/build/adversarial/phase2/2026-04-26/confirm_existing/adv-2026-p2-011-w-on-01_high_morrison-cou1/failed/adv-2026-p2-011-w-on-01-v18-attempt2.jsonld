  "signature": "ed25519:b7e3a1f924c08d5e6b2f4a9c1d3e5f7a9b1c3d5e7f9a1b3c5d7e9f1a3b5c7d9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented verification test suite with version-controlled release notes and traceable issue logs.",
      "rationale": "ANSYS Fluent 2022R2 used with certified release; QA documentation package including unit test results and regression suite archived under configuration management. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via method of manufactured solutions or equivalent benchmark for the governing equations relevant to hemolysis prediction.",
      "rationale": "Benchmark comparisons against lid-driven cavity and backward-facing step canonical cases confirm second-order spatial accuracy. Taylor-Couette flow verification confirms turbulence model implementation. Achieved level meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index study with at least three mesh refinement levels; GCI below 5% for primary QoI.",
      "rationale": "Three-level GCI study performed on 5M, 14M, and 38M element meshes. GCI for hemolysis index is 2.1% between fine and medium meshes; Richardson extrapolation applied. Achieved level 3 exceeds MRL 2 requirement of level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to reproduce boundary conditions in the simulation; flow rate, rotational speed, and fluid properties reported with uncertainty bounds.",
      "rationale": "FDA generic centrifugal pump experiments conducted at 2500, 3500, and 4500 RPM across 2–8 L/min flow range. Fluid temperature, hematocrit, and viscosity reported. Measurement uncertainties quantified per ASME PTC 19.1. Test conditions adequately characterize the CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized index error or validation metric) computed between simulation output and experimental data for primary QoI.",
      "rationale": "Normalized hemolysis index error computed across all 15 test conditions; mean absolute error 8.4%, maximum 12.1%. Pressure-flow characteristic curves match within experimental uncertainty bands at all three rotational speeds. Validation metric satisfies MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated traceability from clinical hemolysis risk metric to simulated QoI (hemolysis index and shear stress exposure).",
      "rationale": "Hemolysis index derived from Giersiepen-Wurzinger power-law model directly maps to plasma-free hemoglobin endpoint used in ISO 10993-4 biocompatibility assessment. Traceability documented in model specification report. QoI relevance confirmed by clinical advisory review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating conditions and geometric configuration representative of the intended CPB device use scenario.",
      "rationale": "FDA generic centrifugal pump geometry and CPB operating conditions (3–6 L/min, 2500–4500 RPM) directly bracket the intended clinical operating envelope. Validation activities are judged sufficiently relevant to the intended use scope to support MRL 2 credibility claims."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals reported; solver error distinguished from discretization error where feasible.",
      "rationale": "At MRL 2, formal quantification of numerical solver error beyond residual monitoring is not required. Residuals converged to 1e-5 for all equations; no assessment beyond this is scoped for this credibility level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification and simulation procedure documentation reviewed.",
      "rationale": "Formal use error assessment not required at MRL 2 for this factor. Analysts hold graduate-level CFD training; simulation procedures are documented in the analysis plan. Full use error assessment deferred to higher MRL submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Governing equation selection and constitutive model choices documented with rationale.",
      "rationale": "SST k-omega turbulence model and Newtonian blood rheology selected based on literature consensus for rotary pump hemolysis prediction. Formal model form uncertainty quantification not required at MRL 2; selection rationale documented in model specification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model input parameters identified and nominal values documented with sources.",
      "rationale": "Blood density, viscosity, and hemolysis model constants documented with literature sources. Sensitivity to hemolysis model coefficients noted qualitatively. Formal uncertainty propagation for model inputs not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog fluid properties and sample preparation documented for experimental validation data.",
      "rationale": "FDA pump experiments used porcine blood with documented hematocrit range 30–35%. Sample characterization adequate for MRL 2; statistical characterization of inter-sample variability not required at this credibility level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between experimental boundary conditions and simulation inputs documented.",
      "rationale": "Inlet flow rates and rotational speeds used in simulation match experimental nominal values. Minor deviations in fluid temperature between experiment and simulation noted and judged acceptable at MRL 2 without formal equivalency analysis."
    }
  ],
