  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This assessment evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. The intended use is confined to pre-market design evaluation of rotary blood pumps operating in the 3–6 L/min flow range at 2500–4500 RPM. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/morrison/data/cfd-mesh-sensitivity-results",
    "https://uofa.net/morrison/data/cpb-operating-conditions-matrix"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data — normalized index error within 12% across all CPB operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/shear-stress-distribution",
      "type": "ValidationResult",
      "name": "Shear stress distribution validation — peak shear stress locations consistent with PIV measurements at 3500 RPM nominal condition"
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence index study — GCI below 2.1% for hemolysis index QoI on 14M-element mesh"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034918",
