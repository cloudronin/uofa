  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for Model Risk Level 2. The 6 not-assessed factors are appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 3. The CFD hemolysis model demonstrates sufficient credibility to support identification of worst-case operating conditions for the Class II CPB device. The assessment team accepts the simulation evidence as adequate for the intended regulatory submission purpose.",
