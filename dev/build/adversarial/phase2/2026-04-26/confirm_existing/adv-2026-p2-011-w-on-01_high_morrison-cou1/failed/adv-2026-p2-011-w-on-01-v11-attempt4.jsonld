    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-output-comparison-v1",
      "type": "ValidationResult",
      "name": "CFD vs. experimental hemolysis index comparison at five CPB operating points"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-sensitivity-v1",
      "type": "ValidationResult",
      "name": "Mesh sensitivity study — discretization error quantification for FDA pump geometry"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4050888",
