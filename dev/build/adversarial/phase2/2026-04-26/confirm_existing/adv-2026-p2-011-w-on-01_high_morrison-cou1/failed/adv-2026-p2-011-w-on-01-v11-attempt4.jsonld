  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out per ASME V&V 40-2018 Table 1 at MRL 2. The CFD model is assessed as sufficiently credible to identify worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB application. The Claim and bound Requirement documents specify the intended use scope: Class II CPB device, operating envelope 3–6 L/min at 2500–3200 RPM, decision question limited to rank-ordering of operating points by hemolysis risk. Decision: Accepted for the stated regulatory submission purpose.",
