  "hash": "sha256:a3f1c82e5d047b69e2f4c1a09b3d56781fe920c4b7e3d1a582f0c94e6b271d3a",
  "signature": "ed25519:b7d3e2a1f509c84d1e6b3a07f2c95d4e8b1a36f0d7c2e5b9a4f1d8c3e6b0a2f",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; all tests passing for the hemolysis module.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional license with documented QA procedures. Regression test suite covering 47 benchmark cases executed; all passed. Version control via Git with tagged release used throughout the study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent benchmark demonstrates solver correctness for rotating-frame Navier-Stokes and scalar transport.",
      "rationale": "Code verification performed using the method of manufactured solutions for the rotating reference frame formulation. Observed order of accuracy (1.97) consistent with the nominal second-order scheme. Scalar transport (hemolysis power-law model) verified against analytical solution for Couette flow."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study conducted (4.2 M, 11.8 M, 31.5 M cells). Richardson extrapolation yields GCI of 2.3% for the hemolysis index at the design operating point and 3.8% at the worst-case high-flow condition. Achieved level exceeds required level, providing additional confidence margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented and matched to simulation inputs within stated tolerances.",
      "rationale": "FDA pump experimental data from Hariharan et al. (2011) used. Flow rates (2.5–7 L/min) and rotational speeds (2000–3500 RPM) replicated in simulation. Bovine blood viscosity and density matched to reported experimental values. Temperature maintained at 37°C ± 0.5°C in both experiment and simulation boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of model agreement (NIMA) or equivalent metric demonstrates acceptable agreement between predicted and measured hemolysis index across the operating envelope.",
      "rationale": "Hemolysis index predicted within 18% of experimental measurements across five operating points. Pressure-head predictions agree within 4.2% (mean absolute error). NIMA computed as 0.83, exceeding the threshold of 0.75 for MRL 2. Systematic over-prediction at high flow rates noted and attributed to known power-law model limitations at high shear rates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, pressure head, shear stress distribution) are directly linked to the clinical decision question of worst-case hemolysis identification.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH), directly used in FDA guidance for CPB device evaluation. Secondary QoIs (pressure head, wall shear stress) are mechanistically linked to hemolysis via the Giersiepen power-law damage model. All QoIs are established in the peer-reviewed literature as relevant surrogates for red blood cell trauma in centrifugal pumps."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry under overlapping operating conditions as the intended CPB use envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump — the identical geometry used in the clinical decision analysis. Operating conditions span 2.5–7 L/min and 2000–3500 RPM, fully enclosing the CPB clinical envelope of 3–6 L/min at 2500–3200 RPM. Fluid analogue (bovine blood) accepted as physiologically representative per FDA guidance document for hemolysis testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; iterative convergence monitoring sufficient.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond iterative convergence monitoring is not required. Residuals converged to 1e-6 for all equations. Mass imbalance below 0.01%. Consistent with ASME V&V 40-2018 Table 1 requirements for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst qualification documentation sufficient.",
      "rationale": "MRL 2 does not require formal use error analysis. Lead analyst holds PhD in biomedical engineering with 8 years CFD experience in cardiovascular devices. Simulation setup reviewed by independent senior analyst prior to production runs. Consistent with MRL 2 expectations per ASME V&V 40-2018."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; model form selection justified by literature precedent.",
      "rationale": "Reynolds-averaged Navier-Stokes with SST k-omega turbulence closure selected based on established precedent for centrifugal blood pump CFD (Fraser et al. 2011, Wu et al. 2012). Giersiepen-Wurzinger power-law hemolysis model is the FDA-recognized approach for this device class. Formal model form uncertainty quantification deferred as not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values with documented sources sufficient.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and hemolysis model coefficients sourced from published literature with traceability. Sensitivity to ±10% variation in viscosity assessed informally; hemolysis index variation less than 3%. Formal probabilistic input uncertainty analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; published experimental dataset with documented sample provenance accepted.",
      "rationale": "Validation data from Hariharan et al. (2011) FDA interlaboratory study — a publicly available, peer-reviewed dataset with documented sample preparation and measurement protocols. Sample characterization beyond published metadata not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; qualitative mapping of experimental to simulation inputs documented.",
      "rationale": "Qualitative equivalency mapping completed: experimental flow rates replicated as mass flow boundary conditions, rotational speed as rotating reference frame angular velocity, fluid properties as constant material properties. Formal equivalency metric computation deferred as not required at MRL 2."
    }
  ],
