      "acceptanceCriteria": "Input parameter sensitivity analysis is not required at MRL 2; nominal input values must be documented and traceable to published sources.",
      "rationale": "Blood viscosity, density, and hemolysis model constants were taken from published literature with documented traceability. Formal sensitivity or uncertainty propagation analysis is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability is not required at MRL 2; use of published FDA benchmark data with documented provenance is acceptable.",
      "rationale": "FDA benchmark experimental data was used directly. Sample characterization details are documented in the original FDA study report. No additional sample variability analysis is required at MRL 2."
    },
