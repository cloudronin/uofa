      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan consistent with MRL 2 requirements, including version control and regression testing.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a documented software QA plan. Version control records and regression test logs confirm compliance with the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or equivalent benchmark tests at MRL 2.",
      "rationale": "Code verification was performed via published FDA benchmark pump studies demonstrating solver accuracy on canonical rotating-frame turbomachinery problems. Results are consistent with published literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or equivalent mesh refinement study must demonstrate discretization error below 5% for primary QoI at the operating point of interest.",
      "rationale": "A three-level mesh refinement study (4.2M, 8.7M, 16.1M cells) yielded a GCI of 2.8% for the hemolysis index at the worst-case operating point, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to confirm relevance to CPB operating range (flow rates 2–6 L/min, rotational speeds 2000–3500 RPM).",
      "rationale": "FDA benchmark experimental data was collected at five operating points spanning 2–5 L/min and 2500–3500 RPM with documented fluid temperature, hematocrit, and inlet pressure boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bands across all five validation operating points.",
      "rationale": "Predicted normalized index of hemolysis agreed with experimental values within ±18% across all five operating points, well within combined uncertainty bounds. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis) must be directly linked to the clinical decision question of identifying worst-case hemolysis operating conditions for the CPB device.",
      "rationale": "The normalized index of hemolysis is the accepted surrogate for red blood cell damage in CPB devices and is directly linked to the design decision. Clinical relevance is supported by published guidance from FDA and ISO 10993-4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on a geometry and flow regime sufficiently similar to the FDA generic centrifugal pump operating under CPB conditions to support extrapolation of credibility.",
      "rationale": "Validation was performed directly on the FDA generic centrifugal pump geometry under physiologically representative CPB flow conditions, providing high geometric and operational similarity to the intended use context."
    },
