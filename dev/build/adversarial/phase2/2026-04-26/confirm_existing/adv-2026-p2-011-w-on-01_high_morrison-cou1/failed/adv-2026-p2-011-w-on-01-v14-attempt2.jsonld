  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for MRL 2. The six non-assessed factors are explicitly scoped to gradation 1 and confirmed acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The CFD hemolysis model is judged credible for identifying worst-case hemolysis operating conditions for the Class II centrifugal blood pump under cardiopulmonary bypass use conditions as described in the bound requirement and claim documents. The assessment team notes that the intended-use scope is fully characterized in the requirement document at bindsRequirement and in the claim at bindsClaim.",
