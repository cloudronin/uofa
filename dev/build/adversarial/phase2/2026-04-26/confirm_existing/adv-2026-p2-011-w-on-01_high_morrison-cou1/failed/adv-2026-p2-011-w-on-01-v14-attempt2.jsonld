      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA experimental data at CPB operating conditions"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation across 2500–3500 RPM operating range"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034823",
