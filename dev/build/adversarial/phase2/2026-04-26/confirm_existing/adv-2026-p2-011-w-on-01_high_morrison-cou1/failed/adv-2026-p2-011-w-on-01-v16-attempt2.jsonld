      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented; version control and regression test suite in place for solver and hemolysis post-processor.",
      "rationale": "ANSYS Fluent 2022R2 used under an FDA-recognized SQA framework. Version control logs and regression suite covering 47 benchmark cases reviewed and confirmed at Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark suite relevant to rotating machinery and viscous flow.",
      "rationale": "Fluent code verification demonstrated via ASME V&V 20 benchmark cases including lid-driven cavity and rotating disk flow. All results within published tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (NIH and wall shear stress) with GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 8.7M, 17.1M cells). GCI for NIH = 2.3%; GCI for peak wall shear stress = 3.8%. Richardson extrapolation applied. Achieves Gradation 3 by quantifying uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid properties) documented and matched to simulation inputs within measurement uncertainty.",
      "rationale": "FDA GCBP test rig operating conditions fully documented. Inlet flow rates set to ±0.05 L/min of target; fluid temperature and viscosity recorded per ASTM F1841. Simulation boundary conditions replicate bench conditions within stated tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric U_val) computed for NIH predictions vs. experimental measurements.",
      "rationale": "NIH predictions compared against five bench test points. Mean absolute error = 12.4%; within the validation acceptance threshold of 20% established for MRL 2 regulatory submissions. Velocity field comparison via PIV shows good spatial agreement (normalized RMSE < 8%)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, wall shear stress, scalar stress exposure) directly linked to clinical hemolysis risk endpoint.",
      "rationale": "NIH is the FDA-accepted metric for hemolysis assessment per FDA guidance on blood-contacting devices. Scalar stress and exposure time are mechanistically linked to red blood cell damage. QoI relevance confirmed by clinical and regulatory literature review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry under conditions spanning the intended operating envelope.",
      "rationale": "Validation performed on the FDA GCBP geometry — the same geometry used in simulation. Operating conditions (2500–3500 RPM, 2–6 L/min) span the intended CPB use envelope. Fluid (bovine blood analog) matches clinical blood rheology at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver iterative convergence residuals reported.",
      "rationale": "Not assessed at MRL 2 for this factor. Residual monitoring confirms steady-state convergence (all residuals < 1e-5) but formal iterative error quantification not required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
