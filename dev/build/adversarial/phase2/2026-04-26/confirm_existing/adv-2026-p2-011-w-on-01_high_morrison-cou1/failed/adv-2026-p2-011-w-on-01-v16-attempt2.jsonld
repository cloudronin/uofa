  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out per ASME V&V 40 Table 4 at MRL 2. Discretization error exceeds minimum requirement (achieved Gradation 3 vs. required Gradation 2), providing additional confidence. NIH prediction error of 12.4% is within the 20% acceptance threshold. The CFD model is credible for identifying worst-case hemolysis operating conditions for the Class II CPB device and supports regulatory decision-making.",
