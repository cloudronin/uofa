      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures, version control, and regression test suite covering cardiovascular benchmark cases.",
      "rationale": "ANSYS Fluent 2022R2 used under an ISO 9001-certified QA framework. Regression suite of 47 cardiovascular benchmark cases executed; all pass within specified tolerances. Version control and change management records archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against manufactured solutions for incompressible Navier-Stokes with non-Newtonian viscosity model at MRL 2 gradation.",
      "rationale": "Method of manufactured solutions applied to Carreau-Yasuda viscosity model in rotating reference frame. Observed order of accuracy 1.94 (expected 2.0); within acceptable tolerance for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI; GCI < 5% on fine grid.",
      "rationale": "Three-grid Richardson extrapolation performed (coarse 2.1M, medium 5.8M, fine 14.2M cells). GCI for normalized hemolysis index = 3.2% on fine grid. Asymptotic range confirmed (GCI ratio 1.01)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented and matched to simulation inputs within stated uncertainty bounds.",
      "rationale": "FDA bench test conditions (2–6 L/min, 2000–3500 RPM, bovine blood analog at 37°C) fully documented in test protocol TP-CBP-2022-04. Simulation boundary conditions set to match within ±1.5% of measured values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation hemolysis index predictions compared to experimental measurements; normalized RMS error < 15%.",
      "rationale": "Normalized hemolysis index predictions across 12 operating points compared to bench data. Normalized RMS error = 8.7%, maximum point error = 13.1%. Exceeds MRL 2 requirement; consistent with MRL 3 gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) demonstrated as the appropriate QoI for CPB worst-case hemolysis identification per ASTM F1841.",
      "rationale": "NIH selected per ASTM F1841 and FDA guidance on hemolysis testing. Sensitivity analysis confirms NIH is monotonically sensitive to operating conditions driving worst-case hemolysis. QoI mapping to decision need documented in credibility plan CP-CBP-2022."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the FDA generic centrifugal pump geometry under CPB operating conditions; fluid analog properties within stated similarity bounds.",
      "rationale": "Validation activities conducted on the identical FDA generic centrifugal pump CAD geometry at CPB-relevant operating points. Bovine blood analog viscosity within 4% of target human blood viscosity. Geometric and dynamic similarity assessed as sufficient for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default gradation 1 accepted.",
      "rationale": "Per ASME V&V 40 Table 1, numerical solver error assessment is not required at MRL 2 for Class II devices when software quality assurance and code verification are addressed. Scoped out of assessment plan CP-CBP-2022 with documented justification."
    },
    {
