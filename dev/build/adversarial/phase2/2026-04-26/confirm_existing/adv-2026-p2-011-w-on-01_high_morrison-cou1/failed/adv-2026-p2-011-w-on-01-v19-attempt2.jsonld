  "signature": "ed25519:b2d7e4f1a09c3e85d162f4a7b3c09e2d5f8a1c4e7b0d3f6a9c2e5b8d1f4a7c0",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation is verified under a documented QA plan consistent with MRL 2 requirements; version control and regression testing records available.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an ISO 9001-certified QA framework. Regression test suite covering laminar and turbulent benchmark cases was executed with zero critical failures. Version control logs and release notes archived in the project repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification against analytical solutions or established benchmarks demonstrates correct numerical implementation of governing equations at MRL 2 gradation.",
      "rationale": "Solver verified against the ASME V&V 20 lid-driven cavity and backward-facing step benchmarks. Observed order of accuracy matches theoretical order for the second-order upwind scheme employed. No systematic coding errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study demonstrates discretization error in NIH QoI is within acceptable bounds; GCI reported.",
      "rationale": "Three-level mesh refinement study (coarse 4.2 M, medium 11.7 M, fine 28.4 M hexahedral cells) conducted at the 3500 RPM / 2 L/min worst-case operating point. Richardson-extrapolated GCI for NIH = 3.1%, below the 5% MRL 2 threshold. Fine mesh adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions are documented with sufficient fidelity to enable meaningful comparison with simulation boundary conditions.",
      "rationale": "FDA PIV dataset boundary conditions (inlet velocity profiles, rotational speed, fluid properties) were reproduced in simulation to within measurement uncertainty. Temperature and viscosity of blood analog (40% glycerol-water) matched to within 1.5%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed and within acceptance band for NIH and velocity field QoIs.",
      "rationale": "Mean absolute error in PIV velocity magnitude = 4.8% of peak velocity; NIH prediction error vs. bench hemolysis = 8.2%, within the ±15% acceptance band established for MRL 2. Validation metric u_val = 0.09, below threshold of 0.15."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, shear stress distribution) are directly linked to the clinical endpoint of hemolysis risk and the regulatory decision question.",
      "rationale": "NIH is the ISO 10993-4 and FDA-recognized metric for hemolysis assessment in blood-contacting devices. Shear stress exposure time integral maps directly to the power-law hemolysis model. Both QoIs are unambiguously tied to the worst-case operating point identification decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments share sufficient geometric, kinematic, and material similarity with the COU to support extrapolation of validation evidence.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump, which is geometrically identical to the simulation domain. Operating conditions span the full CPB envelope. Blood analog fluid properties are within 10% of in-vivo blood rheology at physiological shear rates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error documented to be negligible relative to discretization error.",
      "rationale": "At MRL 2, explicit quantification of solver error beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations; no further assessment scoped at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification and simulation setup review documented.",
      "rationale": "MRL 2 does not require formal use-error quantification. Simulation setup was peer-reviewed by a second qualified CFD engineer; no setup errors identified. Full use-error study deferred to higher MRL if device advances to Class III."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Governing equation selection (turbulence model, hemolysis model) justified relative to flow regime and COU.",
      "rationale": "SST k-omega turbulence model selected based on published benchmarks for internal rotating flows at Re ~ 10^4. Power-law hemolysis model (Giersiepen et al.) is the regulatory standard. Model form uncertainty not formally quantified at MRL 2 but selection rationale is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key input parameters identified; sensitivity or uncertainty analysis not required at MRL 2.",
      "rationale": "Input parameters (viscosity, density, rotational speed, inlet flow rate) identified and nominal values documented. Formal sensitivity analysis not required at MRL 2; deferred to higher risk level assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size and variability acknowledged.",
      "rationale": "FDA PIV dataset consists of three repeat measurements per operating point; variability reported as ±5% of mean. Statistical sufficiency analysis not required at MRL 2. Sample representativeness acknowledged as a limitation managed through the assurance level selection."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation input parameters and physical test conditions is documented at a qualitative level.",
      "rationale": "Boundary condition mapping from experimental measurements to simulation inputs documented in the simulation plan. Formal equivalency metric not required at MRL 2; qualitative correspondence confirmed by the test engineer and simulation lead."
    }
  ],
