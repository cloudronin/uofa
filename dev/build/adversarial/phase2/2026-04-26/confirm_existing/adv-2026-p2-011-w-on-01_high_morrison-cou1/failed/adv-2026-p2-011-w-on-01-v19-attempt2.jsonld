    {
      "id": "https://uofa.net/morrison/validation/gcbp-piv-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic centrifugal blood pump"
    },
    {
      "id": "https://uofa.net/morrison/validation/gcbp-nih-comparison",
      "type": "ValidationResult",
      "name": "NIH output comparison against bench hemolysis measurements"
    }
  ],
