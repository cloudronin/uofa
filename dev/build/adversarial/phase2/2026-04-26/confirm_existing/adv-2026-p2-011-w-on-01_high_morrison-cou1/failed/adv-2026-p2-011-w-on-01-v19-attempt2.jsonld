  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required gradation levels for MRL 2. The 6 not-assessed factors are consistent with MRL 2 scoping and do not represent gaps that would alter the credibility conclusion. The CFD model is judged credible for identifying worst-case hemolysis operating conditions for the Class II CPB device under the operating envelope described in the claim and requirement bindings. Medium assurance level is appropriate given the regulatory context and available validation evidence.",
