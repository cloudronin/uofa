  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures, version control, and regression test suite meeting MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with ISO 9001-certified QA processes. Vendor-supplied verification test suite covers relevant flow regimes. Version control and release notes documented. Achieves Gradation 2 requirement for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification on canonical flows (pipe flow, rotating cavity) demonstrating second-order spatial convergence.",
      "rationale": "Solver verified against Taylor-Green vortex and rotating Couette flow benchmarks. Observed spatial order of accuracy 1.92 for velocity components, consistent with second-order finite-volume discretization. Code verification complete at MRL 2 level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study with at least three systematically refined meshes; GCI < 5% on hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study performed: coarse (2.1M cells), medium (6.8M cells), fine (18.4M cells). Richardson extrapolation yields GCI of 3.2% on normalized index of hemolysis (NIH), satisfying acceptance criterion. Achieves Gradation 3, exceeding MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty quantification; boundary conditions reproducible from published test data.",
      "rationale": "FDA benchmark experimental data (Hariharan et al. 2011) provides fully documented test conditions including flow rate (±0.05 L/min), rotational speed (±5 RPM), fluid temperature (±0.5°C), and hematocrit (±1%). Boundary conditions mapped directly from experimental records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric V) computed for primary QoI; agreement within acceptance band defined a priori.",
      "rationale": "NIH comparison yields mean absolute error of 8.3% across five operating points (3–6 L/min, 2000–4000 RPM). Acceptance band of ±15% defined a priori based on inter-laboratory variability in FDA round-robin study. All five operating points fall within acceptance band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, shear stress exposure time) directly linked to clinical hemolysis risk and regulatory submission requirements.",
      "rationale": "Primary QoI is normalized index of hemolysis (NIH), the standard regulatory metric for blood pump hemolysis per ASTM F1841. Secondary QoIs include volume-averaged scalar stress and exposure time distribution. All QoIs directly relevant to worst-case operating condition identification for CPB device clearance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry under overlapping operating conditions with the intended COU envelope.",
      "rationale": "Validation performed on FDA generic centrifugal pump — identical geometry to the simulation model. Operating conditions span 3–6 L/min and 2500–3500 RPM, overlapping the COU envelope. Blood analog fluid (glycerin-water, 40% hematocrit equivalent viscosity) used per ASTM F1841 protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence monitored via residual tracking.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations. Factor scoped to Gradation 1 (monitoring only) per MRL 2 credibility matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records reviewed informally.",
      "rationale": "MRL 2 does not require formal use error assessment. CFD analyst holds PhD in fluid mechanics with 8 years of cardiovascular CFD experience. Simulation setup reviewed by independent senior analyst. Gradation 1 achieved through informal review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified for rotating machinery hemolysis prediction; hemolysis model form documented with literature support.",
      "rationale": "SST k-omega turbulence model selected based on literature consensus for rotating blood pump flows (Bludszuweit 1995, Giersiepen 1990). Power-law hemolysis model (Giersiepen et al.) applied with coefficients from published calibration. Model form limitations acknowledged and consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, material properties, boundary conditions) traceable to documented sources with stated uncertainties.",
      "rationale": "Pump geometry sourced from FDA-published STL file (SHA-256 hash verified). Blood analog viscosity from ASTM F1841 Table 1 (3.5 cP ±0.1 cP). Density 1056 kg/m³ ±2 kg/m³. Inlet velocity profile from experimental PIV data. All inputs documented in simulation plan with traceability matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for computational model assessment; experimental sample characterization addressed under Test Conditions factor.",
      "rationale": "Test sample characterization (blood analog lot-to-lot variability) is subsumed within the Test Conditions factor at MRL 2. Separate formal assessment not required per ASME V&V 40-2018 credibility matrix for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping between simulation inputs and clinical operating parameters documented.",
      "rationale": "At MRL 2, formal equivalency assessment of simulation input parameters to clinical use parameters is not required. Qualitative mapping documented: flow rate corresponds to cardiac output range for adult CPB (3–6 L/min), rotational speed range covers typical CPB pump operation. Gradation 1 sufficient."
    }
  ],
