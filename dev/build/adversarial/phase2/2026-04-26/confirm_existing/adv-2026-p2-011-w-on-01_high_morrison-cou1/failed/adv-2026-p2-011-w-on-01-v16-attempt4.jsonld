  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver (ANSYS Fluent 2022 R2) must hold a documented quality management record including version control, regression testing, and release validation consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially released solver with documented ISO 9001 QMS, regression test suite, and published verification and validation documentation. Version control records and build provenance are archived. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through at least one benchmark problem with known analytical solution relevant to internal rotating flow.",
      "rationale": "ANSYS Fluent passes the Taylor-Couette flow benchmark and lid-driven cavity benchmark at second-order spatial accuracy. Published verification reports confirm correct discretisation of the incompressible Navier-Stokes equations. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine grid, with at least three mesh refinement levels demonstrating monotonic convergence.",
      "rationale": "Three mesh levels (2.1M, 5.8M, 14.6M cells) were evaluated. GCI on the fine grid is 3.2% for the scalar stress-based hemolysis index. Monotonic convergence is confirmed with observed order of accuracy p=1.87. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must overlap with the CPB operating envelope (2–6 L/min, 2000–4000 RPM) and be documented with measurement uncertainty.",
      "rationale": "FDA benchmark experimental data covers flow rates 2–7 L/min at 2500 and 3500 RPM with reported measurement uncertainty of ±3% for hemolysis index. Conditions fully bracket the intended CPB operating envelope. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±15% across all validation operating points, accounting for combined simulation and measurement uncertainty.",
      "rationale": "Across 18 validation operating points, the mean absolute relative error in hemolysis index is 9.4% and maximum error is 13.8%, both within the ±15% acceptance band. Uncertainty quantification confirms the comparison metric is within the required tolerance. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in simulation (scalar stress-based hemolysis index, normalised index of hemolysis NIH) must be directly linked to the clinical decision question of identifying worst-case hemolysis operating conditions.",
      "rationale": "The scalar stress-based hemolysis index and NIH are the standard regulatory QoIs for CPB device hemolysis assessment per FDA guidance. Both are directly tied to the decision question of identifying worst-case operating points. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (FDA generic centrifugal pump) and blood analogue fluid properties consistent with CPB haematocrit range 30–40%.",
      "rationale": "Validation activities used the FDA generic centrifugal pump with a glycerol-water blood analogue (viscosity matched to haematocrit 35%). Geometry is identical to the simulation domain. Validation activities are directly relevant to the CPB COU. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 is documented; round-off error is negligible for double-precision arithmetic at this scale.",
      "rationale": "At MRL 2 the required level for numerical solver error is 1. Double-precision arithmetic and residual convergence to 1e-5 are standard practice and are confirmed by solver log files. Formal assessment beyond this is not required at MRL 2 and is scoped out."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup is reviewed by a second analyst; boundary condition inputs are traceable to documented source data.",
      "rationale": "At MRL 2 the required level for use error is 1. A peer review of the simulation setup was conducted by a second CFD analyst and documented in the project record. Formal use-error assessment beyond this is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence model (SST k-omega) and hemolysis damage accumulation model is documented with literature justification.",
      "rationale": "At MRL 2 the required level for model form is 1. The SST k-omega turbulence model and the Giersiepen-Wurzinger power-law hemolysis model are documented with literature citations. Formal model-form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Boundary conditions and material properties are traceable to documented sources with stated nominal values.",
      "rationale": "At MRL 2 the required level for model inputs is 1. Inlet flow rates, rotational speeds, fluid viscosity, and density are all traceable to documented test specifications and published fluid property data. Formal sensitivity analysis of model inputs is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples (pump units tested) are documented with batch provenance and manufacturing tolerances consistent with the nominal geometry.",
      "rationale": "At MRL 2 the required level for test samples is 1. The FDA benchmark dataset documents that three pump units were tested and dimensional inspection confirmed conformance to nominal geometry within manufacturing tolerances. Formal sample variability analysis is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation boundary conditions are shown to correspond to experimental test conditions within stated measurement uncertainty.",
      "rationale": "At MRL 2 the required level for equivalency of input parameters is 1. Simulation inlet flow rates and rotational speeds are set to nominal experimental values; correspondence is confirmed within the ±3% experimental measurement uncertainty. Formal equivalency assessment beyond this is not required at MRL 2."
    }
  ],
