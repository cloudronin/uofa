    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-vr-001",
      "type": "ValidationResult",
      "name": "CFD hemolysis index vs experimental benchmark — FDA centrifugal pump"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-vr-002",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic curve validation across CPB operating range"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034918",
