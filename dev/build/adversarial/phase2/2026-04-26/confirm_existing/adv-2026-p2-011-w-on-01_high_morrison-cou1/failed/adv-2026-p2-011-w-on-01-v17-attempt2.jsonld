  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-mrl2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/dr-sarah-chen",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required Gradation 2 level for MRL 2. The six non-assessed factors are accepted at Gradation 1 in accordance with ASME V&V 40-2018 Table 4 allowances for Model Risk Level 2. Validation uncertainty for the primary hemolysis QoI (8.3% mean error, Uval=12.1%) is within the decision threshold established for Class II device 510(k) support. The CFD model is deemed credible for identifying worst-case hemolysis operating conditions of the FDA generic centrifugal blood pump under cardiopulmonary bypass conditions.",
