  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with version-controlled release notes covering all physics modules used in this simulation.",
      "rationale": "ANSYS Fluent 2022R2 was used. The solver has a published verification test suite and traceable release documentation. QA records confirm version control and regression testing for turbulence and scalar-transport modules employed in this analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include at least one manufactured-solution or benchmark test for the governing equations relevant to hemolysis transport.",
      "rationale": "The scalar hemolysis transport equation was verified against a Poiseuille-flow manufactured solution. Observed order of accuracy (1.97) is consistent with the nominal second-order scheme, confirming correct implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the normalised index of hemolysis must be below 5% on the medium mesh used for production runs.",
      "rationale": "Three systematically refined meshes (4.2 M, 11.6 M, 28.4 M cells) were evaluated. Richardson extrapolation yields GCI = 2.8% on the medium mesh, satisfying the acceptance criterion. The medium mesh is used for all production simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) must match simulation inputs within stated measurement uncertainty.",
      "rationale": "Five operating points from the FDA benchmark dataset were reproduced. Flow rates, rotational speeds, and bovine blood viscosity parameters were matched to within reported experimental uncertainty bands (±2% flow, ±0.5% RPM)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalised index of hemolysis must agree with experimental measurements within a factor of two across all five validation operating points.",
      "rationale": "Predicted NIH values at all five operating points fall within a factor of 1.6 of the experimental mean, satisfying the acceptance criterion. Systematic over-prediction at high flow rates is consistent with published literature and is within acceptable bounds for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalised index of hemolysis) must be directly linked to the clinical harm metric (plasma free haemoglobin) used in the device submission.",
      "rationale": "NIH is the standard regulatory metric for CPB device hemolysis submissions (FDA guidance 2021). The power-law hemolysis model maps directly to plasma free haemoglobin accumulation. The QoI is therefore clinically and regulatorily relevant to the intended decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and a fluid with rheological properties representative of human blood under CPB conditions.",
      "rationale": "Validation data are from the FDA generic centrifugal pump — the identical geometry used in the production model. Bovine blood was used experimentally; its shear-thinning properties are well-characterised relative to human blood and are accounted for in the material model, meeting representativeness requirements at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must be reported; no additional solver-error quantification required at MRL 2 for this factor.",
      "rationale": "At MRL 2 the required level for numerical solver error is 1 (awareness). Residuals were monitored and confirmed to reach 1e-5 for all equations. Formal solver-error quantification beyond residual monitoring is scoped out as not required at this risk level."
    },
