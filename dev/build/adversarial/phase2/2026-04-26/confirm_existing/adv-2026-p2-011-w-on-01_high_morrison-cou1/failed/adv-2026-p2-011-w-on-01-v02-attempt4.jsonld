      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with analyst checklist is sufficient at MRL 2; formal use-error FMEA is not required.",
      "rationale": "Simulation workflow is controlled via a documented checklist reviewed by a senior analyst. Formal use-error FMEA is scoped out at MRL 2. No anomalies were flagged during the workflow review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Selection of turbulence closure and haemolysis damage model must be justified by literature precedent at MRL 2; sensitivity study not required.",
      "rationale": "SST k-ω turbulence model and Giersiepen power-law haemolysis model are the community-standard choices for CPB CFD supported by multiple FDA-cited publications. Formal model-form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Nominal input values must be traceable to a documented source; probabilistic input uncertainty propagation is not required at MRL 2.",
      "rationale": "All boundary condition inputs (flow rate, rotational speed, fluid properties) are traceable to the FDA benchmark protocol. Probabilistic sensitivity analysis is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use of a single representative test article is acceptable at MRL 2 when the geometry is a regulatory reference standard.",
      "rationale": "The FDA generic centrifugal pump is a regulatory reference geometry with no manufacturing variability. Sample-to-sample variability assessment is not applicable; a single test article is appropriate at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
