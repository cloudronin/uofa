  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under a recognised SQA plan with documented version control and regression testing appropriate for MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 is used under an ISO 9001-certified SQA framework. Version control, regression test suite, and release notes are archived. SQA level meets Gradation 2 requirements for MRL 2 CPB application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks for incompressible Navier-Stokes and scalar transport must demonstrate order-of-accuracy consistent with the discretisation scheme.",
      "rationale": "Order-of-accuracy tests using the method of manufactured solutions confirm second-order spatial accuracy for velocity and scalar hemolysis index transport. Results archived in code verification report CVR-2022-04."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must bound discretisation error to within 5% of the QoI at the selected operating point.",
      "rationale": "Three-level mesh refinement study (4.2 M, 11.8 M, 31.4 M cells) yields GCI of 2.1% for normalised hemolysis index at the worst-case 2500 rpm / 5 L/min point, exceeding the MRL 2 threshold. Achieved level 3 reflects the systematic three-level study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with uncertainty bounds and must span the CPB operating envelope relevant to the COU.",
      "rationale": "FDA benchmark experiments document inlet flow rate (±0.05 L/min), rotational speed (±10 rpm), and fluid temperature (±0.5 °C). Three operating points bracket the CPB envelope. Measurement uncertainty is propagated through the validation comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g. E% or validation ratio) must demonstrate agreement within acceptance band for hemolysis index and velocity field QoIs.",
      "rationale": "Normalised hemolysis index error E% = 3.8% at the primary operating point; area-averaged velocity magnitude agreement within 4.2% across the PIV measurement plane. Both metrics satisfy the MRL 2 acceptance band of ≤10%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be mechanistically linked to the clinical risk driver (haemolysis) and must be measurable with traceable instrumentation.",
      "rationale": "Normalised index of haemolysis (NIH) is the regulatory QoI for CPB devices. CFD-derived NIH is computed via the power-law damage accumulation model applied to Lagrangian particle tracks. Direct correspondence to bench NIH measurement is established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and a blood-analogue fluid with matched viscosity and density within 5% of clinical values.",
      "rationale": "FDA benchmark uses the identical generic centrifugal pump geometry with a 36% glycerol-water blood analogue (viscosity 3.5 mPa·s, density 1050 kg/m³) matching clinical blood properties within 3%. Validation activities are directly applicable to the CPB COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below solver default tolerances is sufficient at MRL 2 when GCI analysis is complete.",
      "rationale": "At MRL 2 with a completed GCI study, explicit solver error quantification beyond residual monitoring is not required. Residuals converged to 1×10⁻⁵ for all equations; no further assessment is warranted."
    },
    {
