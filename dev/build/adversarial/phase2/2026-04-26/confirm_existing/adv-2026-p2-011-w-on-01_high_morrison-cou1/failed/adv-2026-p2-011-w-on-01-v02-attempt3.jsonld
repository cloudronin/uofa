    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-val-01",
      "type": "ValidationResult",
      "name": "CFD vs. experimental hemolysis index comparison across 6 operating points"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-val-02",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification for CPB pump geometry"
    }
  ],
