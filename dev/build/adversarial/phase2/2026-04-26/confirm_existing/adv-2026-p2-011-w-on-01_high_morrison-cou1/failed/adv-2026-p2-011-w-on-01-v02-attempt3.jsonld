  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA documentation confirms version control, regression testing, and release procedures are in place for the CFD solver used in CPB hemolysis simulations.",
      "rationale": "The CFD solver (ANSYS Fluent 2021 R2) is a commercially validated code with documented SQA procedures. Version control logs and regression test results were reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification demonstrates correct implementation of governing equations through benchmark problems with known analytical solutions.",
      "rationale": "Benchmark verification cases including lid-driven cavity and pipe flow with analytical solutions were executed. Observed order of accuracy matched theoretical order, confirming correct code implementation for laminar and turbulent flow regimes relevant to CPB."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for key QoIs; discretization error bounded to less than 5% of the hemolysis index at the nominal operating point.",
      "rationale": "Richardson extrapolation and GCI analysis performed on three systematically refined meshes (4.2M, 9.8M, 21.4M cells). GCI for hemolysis index at worst-case operating point was 2.3%, exceeding the MRL 2 threshold and satisfying MRL 3 criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, boundary conditions, rotational speed) are documented and traceable to the CFD boundary condition inputs.",
      "rationale": "FDA mock circulatory loop experimental conditions (bovine blood, 37°C, hematocrit 35±2%) are fully documented. CFD boundary conditions were set to match experimental inlet flow rates and rotational speeds within 1% tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric E) computed between CFD-predicted and experimentally measured hemolysis index across all test points.",
      "rationale": "Hemolysis index predictions compared against six experimental operating points. Mean absolute relative error was 8.4% with no systematic bias, satisfying the MRL 2 requirement for output comparison. Worst-case point showed 11.2% deviation, within acceptable bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The model QoIs (hemolysis index, scalar stress exposure) are directly linked to the clinical endpoint of red blood cell damage in CPB patients.",
      "rationale": "Hemolysis index derived from power-law model of Giersiepen et al. is the accepted regulatory QoI for CPB pump hemolysis assessment. Scalar stress exposure integrates shear stress and exposure time along pathlines, directly relevant to RBC damage mechanisms."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments are conducted on the same FDA generic centrifugal pump geometry under CPB-representative operating conditions.",
      "rationale": "Validation activities used the identical FDA generic centrifugal blood pump geometry as the COU device surrogate. Operating conditions span the CPB clinical range (3–7 L/min, 2000–4500 RPM), confirming high relevance of validation evidence to the intended use scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below solver tolerance threshold documented for each simulation.",
      "rationale": "At MRL 2, explicit quantification of numerical solver error beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations in all simulations, satisfying the MRL 1 baseline. Formal solver error quantification scoped out per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a second qualified analyst to identify potential user-introduced errors.",
      "rationale": "At MRL 2, formal use error assessment is not required. Standard internal peer review of simulation setup files was performed. Formal use error analysis deferred per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Governing equation selection (RANS turbulence model, non-Newtonian blood rheology model) documented with literature justification.",
      "rationale": "SST k-omega turbulence model and Carreau-Yasuda viscosity model selections are documented with supporting literature. Formal model form uncertainty quantification not required at MRL 2 and scoped out per assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Material properties and boundary condition values documented with sources and nominal uncertainty ranges.",
      "rationale": "Blood viscosity, density, and hemolysis model coefficients are documented with literature sources. Formal sensitivity analysis of model inputs not required at MRL 2. Nominal values used; uncertainty propagation scoped out per assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number and diversity of experimental test samples documented; sample preparation procedures traceable.",
      "rationale": "FDA experimental dataset used three independent blood samples per operating point. Sample characterization (hematocrit, MCV) is documented. Statistical analysis of sample variability not required at MRL 2 and scoped out per assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between experimental measurement inputs and CFD boundary condition parameters documented.",
      "rationale": "Inlet flow rate, rotational speed, and outlet pressure boundary conditions are directly mapped from experimental measurements. Formal equivalency analysis not required at MRL 2. Parameter mapping table documented in the simulation report and scoped out from formal assessment per MRL 2 plan."
    }
  ],
