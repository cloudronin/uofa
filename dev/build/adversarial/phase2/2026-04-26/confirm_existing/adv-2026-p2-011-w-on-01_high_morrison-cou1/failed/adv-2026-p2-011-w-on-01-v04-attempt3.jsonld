      "acceptanceCriteria": "Solver must be verified against benchmark cases and version-controlled; all scripts under configuration management.",
      "rationale": "ANSYS Fluent 2022 R2 used under institutional license with documented QA procedures. Benchmark verification against lid-driven cavity and Poiseuille flow confirmed. Version control via institutional GitLab repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical rotating flow problem must confirm second-order spatial convergence.",
      "rationale": "Method of manufactured solutions applied to rotating annular flow. Observed order of accuracy 1.94, consistent with second-order finite-volume discretization. Residual convergence to 1e-6 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine grid.",
      "rationale": "Three-level Richardson extrapolation performed on 3.2M, 8.1M, and 18.4M cell meshes. GCI on fine mesh = 2.3% for hemolysis index. Asymptotic range confirmed (GCI ratio 1.02). Exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be reproduced in simulation within measurement uncertainty; fluid properties matched to within 5%.",
      "rationale": "Inlet velocity profiles from PIV measurements applied as boundary conditions. Blood analog viscosity and density matched to within 2%. Pump rotational speed set to experimentally measured value ±0.5 RPM."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within two standard deviations of experimental mean across all tested operating points.",
      "rationale": "Hemolysis index predictions fall within experimental uncertainty bands (mean error 8.4%, max error 14.1%) at all five tested flow rates. Velocity field RMSE vs. PIV below 4% of bulk velocity."
    },
