  "signature": "ed25519:d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures documented and version-controlled; solver release notes and regression test suite available for ANSYS Fluent 2022R2.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially released solver with documented SQA processes. Regression test suite covers relevant turbulence and scalar transport modules. Required gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests demonstrate expected convergence rates for governing equations on canonical problems relevant to rotating turbomachinery flows.",
      "rationale": "Vendor-supplied method-of-manufactured-solutions results confirm second-order spatial accuracy for the pressure-velocity coupling and scalar transport equations used in hemolysis prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% on hemolysis index QoI at the nominal CPB operating point (5 L/min, 3500 RPM).",
      "rationale": "Three-mesh Richardson extrapolation study yielded GCI of 2.8% on the global hemolysis index and 3.4% on peak shear stress volume fraction. Temporal convergence confirmed with CFL < 1 throughout the impeller passage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, rotational speed, fluid temperature) documented with measurement uncertainty quantified to within ±3% of nominal.",
      "rationale": "FDA bench test protocol specifies Newtonian blood analog (glycerol-water) at 37°C. Flow rates measured by Coriolis meter (±1.2%). Rotational speed confirmed via optical tachometer (±0.5%). All conditions replicated in simulation boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 15% of experimental mean across all five tested flow rates; PIV velocity profiles within one experimental standard deviation at three measurement planes.",
      "rationale": "Hemolysis index predictions ranged from 8% to 13% above experimental mean across flow rates 3–7 L/min, within the 15% acceptance band. PIV comparison at three axial planes shows agreement within one standard deviation for 94% of vectors."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, peak shear stress, residence time distribution) are directly linked to the clinical decision question of identifying worst-case hemolysis operating conditions.",
      "rationale": "The hemolysis index is the primary regulatory metric for CPB device evaluation per FDA guidance. Peak shear stress and residence time are mechanistic QoIs that drive the hemolysis model. All QoIs are directly relevant to the intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic centrifugal pump geometry at overlapping operating conditions with the intended CPB use envelope.",
      "rationale": "Validation dataset uses identical pump geometry and fluid properties. Operating points span 3–7 L/min at 3000–4000 RPM, encompassing the CPB clinical range. Geometric and physical similarity is confirmed; no significant extrapolation from validation to COU operating space."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default gradation 1 accepted.",
      "rationale": "At MRL 2, detailed iterative solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-5 for all equations; mass imbalance below 0.01%. No further assessment needed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
