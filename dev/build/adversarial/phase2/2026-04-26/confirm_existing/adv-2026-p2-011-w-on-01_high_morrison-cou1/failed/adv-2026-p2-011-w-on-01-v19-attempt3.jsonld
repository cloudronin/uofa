  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent QMS documentation covering version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022 R2 is used under an ISO 9001-certified QMS. Regression test suite covers 142 benchmark cases; all pass within stated tolerances. Version control via Git with tagged release used throughout this study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate order-of-accuracy convergence on at least one canonical rotating-machinery or viscous-flow benchmark.",
      "rationale": "Order-of-accuracy study on Taylor-Couette flow confirms second-order spatial convergence. Manufactured-solution test for the power-law viscosity model yields L2 error norms consistent with theoretical order, confirming correct implementation of the non-Newtonian constitutive model used for blood."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be less than 10% at the nominal operating point.",
      "rationale": "Three-level mesh refinement study (6.2 M, 12.8 M, 25.4 M cells) conducted at 3.5 L/min 3000 RPM. GCI for normalized hemolysis index is 4.7%, below the 10% threshold. Richardson extrapolation applied; asymptotic range confirmed (GCI ratio = 1.02). Fine mesh selected for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match CFD inlet/outlet conditions within 5% for flow rate and within 10% for fluid temperature and hematocrit.",
      "rationale": "FDA benchmark experimental data collected at hematocrit 33±2%, temperature 37±0.5°C, flow rates set via Coriolis meter (±1%). CFD boundary conditions replicate measured values. Deviations in all parameters are within acceptance thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predictions must fall within two experimental standard deviations across all five validation operating points.",
      "rationale": "NIH predictions at all five operating points fall within 1.6 experimental standard deviations. Mean absolute relative error is 8.3%. Pressure-rise predictions agree within 4.2% across the full operating envelope. Validation metric satisfies acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, pressure rise, shear stress distribution) must be the same quantities used in the clinical risk assessment for the CPB device.",
      "rationale": "NIH is the primary regulatory endpoint for hemolysis in CPB devices per FDA guidance. Shear stress exposure integral is used directly in the hemolysis damage accumulation model. Pressure rise characterizes device performance boundaries. All validation QoIs map directly to submission endpoints."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and cover at least 80% of the intended operating envelope flow-rate range.",
      "rationale": "Validation uses the FDA generic centrifugal blood pump geometry, identical to the simulation geometry. Experiments span 1–6 L/min at 2000–4000 RPM, covering 100% of the intended operating envelope. Blood analogue fluid properties match in-vivo viscosity within 6% across the shear rate range of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence monitoring to residual tolerance 1e-5 is sufficient.",
      "rationale": "At MRL 2, formal round-off and iterative error quantification beyond residual monitoring is not required. All simulations converged to scaled residuals below 1e-5 for continuity and momentum; energy residual below 1e-7. No assessment beyond convergence monitoring performed, consistent with MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation setup reviewed by a second analyst.",
      "rationale": "MRL 2 does not require formal use-error analysis. Simulation setup files were independently reviewed by a second CFD analyst. No discrepancies identified. Formal probabilistic use-error quantification deferred to higher MRL studies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection justified by literature precedent.",
      "rationale": "SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law model selected based on published FDA benchmark studies. Model form uncertainty quantification not required at MRL 2. Literature survey confirms these are the consensus models for this class of problem."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values from published sources with documented uncertainty.",
      "rationale": "Blood density, viscosity coefficients, and hemolysis model constants taken from peer-reviewed literature with documented measurement uncertainties. Formal sensitivity analysis and input uncertainty propagation not required at MRL 2. Nominal values used throughout."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample size documented.",
      "rationale": "FDA benchmark dataset uses n=3 independent experimental runs per operating point. Statistical characterization of inter-run variability is documented in the source publication. Formal sample-size adequacy analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD model input parameters (geometry, fluid properties, boundary conditions) must be demonstrably equivalent to experimental conditions within stated tolerances.",
      "rationale": "Pump geometry reconstructed from FDA-published CAD files; dimensional verification against physical pump confirms agreement within 0.05 mm. Fluid properties (density 1056 kg/m3, Carreau viscosity parameters) match experimental fluid characterization data. Inlet velocity profiles derived from experimental PIV measurements at pump inlet plane."
    }
