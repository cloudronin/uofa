  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented QA procedures including version control, regression testing, and release validation consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 is used under an FDA-recognized QMS. Vendor-supplied verification suite passes all regression benchmarks. Version control and change-log documentation reviewed and found compliant with MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations for incompressible viscous flow and scalar transport via at least one manufactured solution or analytical benchmark.",
      "rationale": "Code verification confirmed via lid-driven cavity benchmark (Re=1000) and Poiseuille flow manufactured solution. Observed convergence rates match theoretical order for second-order spatial discretization. No implementation errors detected."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence must be demonstrated with at least three systematically refined meshes; GCI must be reported for primary QoI (hemolysis index).",
      "rationale": "Three-level mesh refinement study performed (4.2M, 11.7M, 28.4M cells) following Celik et al. (2008) GCI methodology. GCI for hemolysis index QoI is 3.1% on the medium mesh, below the 5% acceptance threshold. Medium mesh (11.7M) selected for production runs. Achieved level exceeds required MRL 2 level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to allow replication; boundary conditions must match CFD inlet/outlet specifications within stated uncertainty.",
      "rationale": "FDA benchmark experimental dataset provides complete documentation of flow loop configuration, fluid properties (bovine blood, 37°C, Hct 35%), and operating points. CFD boundary conditions derived directly from reported experimental values. Inlet velocity profiles measured by LDV and applied as CFD inlet BCs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, validation metric u_val) must be reported for primary QoI across all validation operating points.",
      "rationale": "Hemolysis index predictions compared against experimental measurements at 5 operating points spanning the CPB flow range. Normalized RMS error is 12.4%. Validation uncertainty u_val computed per ASME V&V 20 methodology. Model adequacy confirmed for MRL 2 decision context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly traceable to the clinical/regulatory question of interest (worst-case hemolysis identification for CPB device).",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) computed from the power-law Giersiepen-Wurzinger model integrated along Lagrangian particle tracks. NIH is the regulatory QoI specified in FDA guidance for CPB device hemolysis assessment. Direct traceability established to device requirement DR-HEM-001."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the flow regime, geometry class, and fluid properties representative of the intended CPB operating envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry — the same geometric class as the subject device. Flow conditions (3–6 L/min, 60–120 mmHg) span the intended CPB operating envelope. Fluid properties (bovine blood surrogate) are accepted as representative per FDA guidance. Validation domain adequately covers the COU as described in the Claim and Requirement prose."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must reach at least 1e-5 for all transport equations; mass imbalance must be below 0.01%.",
      "rationale": "Not assessed at MRL 2 per ASME V&V 40 Table 3 scoping. Solver residuals are monitored as standard practice and logged, but formal numerical solver error quantification is not required at this model risk level. Residuals confirmed below 1e-4 in all production runs as a precautionary measure."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error analysis not required at MRL 2; analyst qualification records sufficient.",
      "rationale": "Not assessed at MRL 2. Analyst qualifications reviewed: lead CFD engineer holds MSME with 8 years rotary blood pump CFD experience. Standard operating procedures for simulation setup and post-processing are documented and followed. Formal use-error FMEA not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty quantification not required at MRL 2; model selection rationale must be documented.",
      "rationale": "Not assessed at MRL 2. Model form selection rationale documented: SST k-omega turbulence model selected based on literature consensus for internal rotary pump flows. Non-Newtonian blood rheology modeled via Carreau-Yasuda. Power-law hemolysis model selected per FDA guidance. Formal model-form UQ deferred to higher MRL activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameter uncertainty propagation not required at MRL 2; nominal input values must be documented with sources.",
      "rationale": "Not assessed at MRL 2. All nominal input parameters (fluid density, viscosity coefficients, hemolysis model constants, rotational speed) documented with literature or experimental sources. Formal sensitivity analysis and uncertainty propagation deferred to MRL 3 activities if device advances to PMA pathway."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability not required at MRL 2; sample provenance must be documented.",
      "rationale": "Not assessed at MRL 2. FDA benchmark dataset uses pooled bovine blood from a single certified supplier per established protocol. Inter-sample variability in hematocrit (±2%) noted in dataset documentation. Formal statistical treatment of sample variability not required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis between validation experiment inputs and COU inputs not required at MRL 2; qualitative assessment sufficient.",
      "rationale": "Not assessed at MRL 2. Qualitative assessment confirms that validation experiment operating conditions (flow rate, pressure head, rotational speed range) are representative of the intended CPB operating envelope. Fluid property differences between bovine blood surrogate and human blood are within accepted limits per FDA guidance for this device class."
    }
  ],
