  "signature": "ed25519:b2e5a8d1c4f7a0e3b6c9d2f5a8e1b4c7d0f3a6b9c2e5f8a1d4b7c0e3f6a9b2c5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold ISO 9001 certification and documented version-control history for all hemolysis model components.",
      "rationale": "ANSYS Fluent 2022 R2 holds ISO 9001 certification. Version control via Git with tagged release used throughout; SQA documentation reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least two published benchmark verification cases relevant to rotating turbomachinery flows.",
      "rationale": "ANSYS Fluent verified against the Taylor-Couette benchmark and the FDA nozzle benchmark (ASME V&V 40 Appendix C). Both cases demonstrate second-order spatial convergence consistent with stated solver order."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) for hemolysis index QoI must be below 5% on the fine-grid solution.",
      "rationale": "Three-level mesh refinement study performed (4.2 M, 9.8 M, 21.4 M cells). GCI on hemolysis index fine-grid solution = 2.7%, well within the 5% threshold. Asymptotic range confirmed (apparent order p = 1.94)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) must be reproduced in simulation within ±2% of measured values.",
      "rationale": "FDA experimental conditions (5 L/min, 2500 RPM, bovine blood analog at 37 °C) replicated in simulation. Inlet velocity profile derived from PIV measurements; viscosity matched to within 1.3%. Temperature drift in experiments documented and bounded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must lie within two experimental standard deviations of the mean measured value across all tested operating points.",
      "rationale": "Simulated normalized index of hemolysis (NIH) compared against five FDA experimental runs. Predicted NIH falls within 1.4 experimental standard deviations at the design point and within 1.9 standard deviations at the worst-case operating point, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, shear stress distribution, residence time) must be directly traceable to the clinical decision of worst-case hemolysis identification for CPB use.",
      "rationale": "NIH is the primary regulatory metric for CPB device hemolysis per FDA guidance. Shear stress and residence time are mechanistic predictors of erythrocyte damage and are included in the power-law hemolysis model. Traceability matrix linking QoIs to the clinical question documented in the V&V plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog, and operating envelope as the intended CPB COU.",
      "rationale": "FDA generic centrifugal blood pump geometry used in both simulation and validation experiments. Bovine blood analog (Brookfield viscosity 3.5 cP) matches intended CPB fluid conditions. Operating envelope (2000–3500 RPM, 3–7 L/min) fully encompasses the CPB clinical range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver error subsumed under code verification activities.",
      "rationale": "At MRL 2, separate quantification of numerical solver error beyond code verification is not required. Iterative convergence monitored via residual reduction of six orders of magnitude; mass imbalance < 0.01%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst training records reviewed but formal use-error quantification not required.",
      "rationale": "Lead analyst holds PhD in computational fluid dynamics with five years of cardiovascular CFD experience. Simulation setup peer-reviewed by independent senior analyst. Formal use-error probability assessment deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; model-form uncertainty acknowledged qualitatively.",
      "rationale": "Power-law hemolysis model (Giersiepen-Wurzinger) selected based on published literature for CPB applications. Model-form uncertainty relative to more complex RBC damage models acknowledged in V&V report Section 6.3 but not formally quantified at this MRL."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values used with qualitative sensitivity discussion.",
      "rationale": "Nominal blood analog properties and pump geometry dimensions used as deterministic inputs. Sensitivity of NIH to ±5% variation in viscosity and power-law exponent discussed qualitatively in V&V report; formal uncertainty propagation deferred to MRL 3 if risk level is elevated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; sample variability acknowledged from FDA dataset documentation.",
      "rationale": "FDA experimental dataset comprised five independent runs with fresh bovine blood batches. Inter-batch variability documented in FDA dataset release notes. Statistical characterization of sample variability not required at MRL 2 but noted as a limitation for higher-risk applications."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrably equivalent to those of the intended CPB COU within documented tolerances.",
      "rationale": "Pump geometry CAD file identical between validation and COU simulations (same STL tessellation, verified by MD5 checksum). Fluid properties differ by less than 2% between bovine blood analog and human blood at 37 °C for the shear-rate range of interest. Rotational speed and flow rate operating points fully overlap. Equivalency documented in V&V plan Appendix B."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. The six non-assessed factors are appropriately scoped out per ASME V&V 40 Table 1 for Model Risk Level 2. Discretization error (GCI 2.7%) and output comparison (NIH within 1.4–1.9 experimental standard deviations) provide sufficient evidence that the CFD model can reliably identify worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB applications. The assessment team accepts the model for the stated decision purpose.",
