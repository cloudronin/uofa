  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented test suite passing rate ≥ 95% for MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 employed with documented QA procedures; regression test suite reports 97.3% pass rate. Version control via Git with tagged release used throughout the study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing on canonical benchmark problems demonstrating expected convergence rate within 10% of theoretical for MRL 2.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes solver; observed order of accuracy 1.92 versus theoretical 2.0 for second-order scheme, within the 10% tolerance required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI with GCI < 5% on fine grid for MRL 2.",
      "rationale": "Three-mesh Richardson extrapolation performed (1.2M, 4.8M, 19.2M cells). GCI for hemolysis index on fine mesh: 2.1%. Wall shear stress GCI: 3.4%. Both within MRL 2 threshold; fine mesh adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty quantification covering operating envelope relevant to CPB use.",
      "rationale": "FDA benchtop experiments conducted at 2500 RPM and 5 L/min with blood analog fluid; inlet velocity profiles and pressure boundary conditions measured and reported with ±3% uncertainty. Operating point representative of CPB clinical range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised RMS error between CFD and experimental hemolysis index ≤ 15% across validation operating points.",
      "rationale": "Hemolysis index predicted within 9.8% of experimental mean across all five validation operating points. Velocity field comparison shows normalised RMS error of 7.2% against PIV measurements. Both metrics satisfy MRL 2 acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical endpoint (hemolysis) with documented mapping to device performance specification.",
      "rationale": "Primary QoI is the normalised index of hemolysis (NIH) in mg/dL, directly mapped to ISO 10993-4 haemocompatibility requirements and the device performance specification for the Class II CPB pump. Secondary QoIs (wall shear stress, exposure time) are mechanistically linked to the Giersiepen-Wurzinger power-law hemolysis model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry and fluid at operating conditions spanning the CPB clinical range.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under blood-analog conditions (glycerol-water, viscosity 3.5 cP) at flow rates 3–7 L/min and speeds 2000–3000 RPM, fully bracketing the CPB clinical operating envelope described in the device submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance of 1e-6 for all transport equations documented; not required for independent quantification at MRL 2.",
      "rationale": "Residual convergence to 1e-6 confirmed in solver log files for all production runs. Separate iterative error quantification not required at MRL 2 and therefore scoped to not-assessed per ASME V&V 40 Table 3 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst training records on file; formal use-error analysis not required at MRL 2.",
      "rationale": "Lead analyst holds PhD in computational fluid dynamics with 8 years CFD experience in cardiovascular devices. Formal use-error analysis not required at MRL 2 per ASME V&V 40 Table 3; training records retained in project file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection justified by reference to literature; formal model-form uncertainty quantification not required at MRL 2.",
      "rationale": "SST k-ω turbulence model selected based on published benchmark comparisons for rotating cardiovascular devices. Formal model-form UQ not required at MRL 2; selection rationale documented in simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs documented with sources and uncertainty bounds; sensitivity analysis performed for top-3 influential inputs.",
      "rationale": "Blood analog viscosity (3.5 ± 0.1 cP), density (1050 ± 5 kg/m³), and inlet velocity profile documented with measurement uncertainty. One-at-a-time sensitivity analysis identifies viscosity and rotational speed as top-2 inputs; hemolysis index varies ±6% across ±2σ input range, within acceptable bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Fluid sample provenance and preparation documented; formal sample characterisation study not required at MRL 2.",
      "rationale": "Blood analog prepared per published FDA protocol (Brookshier & Tarbell, 1993); preparation records on file. Formal sample-to-sample variability study not required at MRL 2 per ASME V&V 40 Table 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional similarity between validation experiment and COU documented; full equivalency analysis not required at MRL 2.",
      "rationale": "Reynolds number and rotational Reynolds number match between validation experiment and CPB operating conditions documented in simulation plan. Full equivalency analysis deferred as not required at MRL 2 per ASME V&V 40 Table 3."
    }
  ],
