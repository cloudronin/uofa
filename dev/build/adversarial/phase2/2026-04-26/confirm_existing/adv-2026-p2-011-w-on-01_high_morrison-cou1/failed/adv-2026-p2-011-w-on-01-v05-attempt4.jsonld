  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 not-assessed factors are explicitly scoped out per ASME V&V 40 Table 3 for MRL 2 and are supported by qualitative justification. CFD predictions of normalised index of hemolysis are within ±18% of experimental data across all validation operating points, satisfying the acceptance criterion. The model is judged credible for identifying worst-case hemolysis operating conditions of the Class II CPB device in support of regulatory submission.",
