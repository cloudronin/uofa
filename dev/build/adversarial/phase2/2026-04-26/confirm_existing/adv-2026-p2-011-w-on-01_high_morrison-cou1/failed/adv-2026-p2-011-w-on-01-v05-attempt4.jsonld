  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control documented; regression test suite executed with zero critical failures; build environment recorded in simulation log.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional license with version-locked configuration file. Regression tests covering 14 canonical flow cases executed prior to production runs; all passed within tolerance. Build metadata archived in project repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical Couette and pipe-flow benchmarks demonstrates second-order spatial convergence within 5% of theoretical rate.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver on three systematically refined grids. Observed order of accuracy 1.94 for velocity and 1.88 for pressure, consistent with second-order finite-volume discretisation. No anomalous convergence behaviour detected."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI below 5% on primary QoI (normalised index of hemolysis) on the production mesh.",
      "rationale": "Three-level mesh refinement study (4.2 M, 9.8 M, 21.4 M cells) performed at the design operating point (4 L/min, 2800 RPM). GCI on NIH = 2.3%, well below the 5% threshold. Production mesh selected at 9.8 M cells as optimal cost-accuracy trade-off."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, fluid viscosity, temperature) match simulation inputs within stated measurement uncertainty; deviations documented.",
      "rationale": "In-vitro experiments conducted with porcine blood analogue (glycerol-water, viscosity 3.5 ± 0.1 mPa·s at 37 °C). Flow rates set by calibrated Coriolis meter (±0.5%). Simulation boundary conditions set to measured mean values; sensitivity to ±2σ variation in viscosity assessed and found to shift NIH by less than 1.8%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised index of hemolysis predicted within ±25% of experimental mean across all 9 validation operating points; pressure-head within ±5%.",
      "rationale": "CFD NIH predictions fell within ±18% of experimental mean at all 9 operating points; maximum deviation 17.4% at 6 L/min / 3500 RPM. Pressure-head error ≤3.2% across the full speed-flow map. Both criteria satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (NIH) directly maps to the clinical harm metric; secondary QoIs (wall shear stress, exposure time) are mechanistically linked to haemolysis pathway.",
      "rationale": "NIH is the regulatory-accepted surrogate for haemolysis per ASTM F1841. Wall shear stress and scalar exposure time are inputs to the power-law haemolysis model (Giersiepen-Wurzinger), directly supporting the worst-case operating point identification objective stated in the claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the identical FDA generic pump geometry under CPB-representative flow and rotational speed conditions.",
      "rationale": "Validation data sourced from the FDA benchmark dataset (Hariharan et al.) using the same pump geometry as the simulation model. Operating conditions span the full CPB clinical range (2–6 L/min, 2000–3500 RPM), confirming relevance to the intended use scope described in the claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; commercial solver with documented verification record accepted.",
      "rationale": "At MRL 2, explicit numerical solver error quantification beyond code verification is not mandated. ANSYS Fluent is a commercially verified solver with published validation studies in cardiovascular CFD; this is accepted as sufficient evidence at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification records reviewed.",
      "rationale": "Simulations conducted by a credentialed CFD engineer with 8 years of cardiovascular device experience. Peer review of simulation setup performed by independent analyst. Formal use-error quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection justified by literature precedent.",
      "rationale": "SST k-ω turbulence model selected based on published cardiovascular pump CFD literature demonstrating superior near-wall performance. Power-law haemolysis model is the regulatory-standard approach. Formal model-form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values taken from experimental measurements with stated uncertainty.",
      "rationale": "Fluid properties and boundary conditions sourced from calibrated experimental measurements. Sensitivity analysis for viscosity variation performed as part of test conditions factor. Full probabilistic input uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA benchmark dataset accepted as representative sample.",
      "rationale": "Validation relies on the publicly available FDA benchmark haemolysis dataset, which represents multiple independent experimental replicates. Statistical characterisation of sample variability not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative equivalency confirmed by direct comparison of simulation and experimental setup parameters.",
      "rationale": "Simulation geometry constructed from manufacturer CAD files identical to the physical test article. Fluid properties, rotational speed, and flow boundary conditions matched to experimental records. Formal equivalency metric calculation not required at MRL 2."
    }
