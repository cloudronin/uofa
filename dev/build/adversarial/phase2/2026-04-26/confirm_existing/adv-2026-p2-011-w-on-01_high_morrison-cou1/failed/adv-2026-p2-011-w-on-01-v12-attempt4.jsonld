  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version-controlled; unit tests pass; release notes document all changes relevant to turbulent CFD and scalar transport.",
      "rationale": "ANSYS Fluent 2022 R2 used under institutional license with full QA documentation. Version control log, test suite results, and release notes reviewed and archived. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver demonstrates correct order of convergence on manufactured solution benchmarks for Navier-Stokes and scalar transport.",
      "rationale": "Method of manufactured solutions applied to 3-D rotating-frame Navier-Stokes and power-law hemolysis scalar. Observed spatial order 1.97 (expected 2nd order). Code verification requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) for hemolysis index QoI less than 5% on fine-to-medium refinement ratio.",
      "rationale": "Three systematically refined meshes (4.2 M, 11.8 M, 28.6 M cells) used. GCI for hemolysis index = 3.1% (fine-medium). Richardson extrapolation applied. Discretization error within acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity, hematocrit) documented with uncertainty; replicated in simulation within stated tolerances.",
      "rationale": "FDA bench test conditions (2500 RPM, 5 L/min; 3500 RPM, 7 L/min; 4500 RPM, 9 L/min) reproduced in CFD with inlet velocity profiles derived from PIV. Fluid properties matched to porcine blood at 37 °C. Hematocrit 40 ± 2% documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 15% of measured value at all three validation operating points; velocity field E_rms < 10% U_tip.",
      "rationale": "Hemolysis index discrepancies: 8.2%, 11.4%, 9.7% at the three operating points. Velocity field E_rms = 6.3% U_tip. Both criteria satisfied. Validation comparison supports model credibility for hemolysis ranking."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (hemolysis index, shear stress distribution) directly linked to device safety endpoint; linkage documented in model description report.",
      "rationale": "Hemolysis index is the primary safety endpoint for CPB device pre-market submission per FDA guidance. Shear stress distribution used as secondary QoI to identify high-risk regions. Direct linkage documented in Model Description Report v2.1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry under overlapping operating conditions; fluid and boundary conditions representative of CPB use.",
      "rationale": "FDA generic centrifugal pump geometry used for both validation experiments and COU simulations. Operating envelope (2500–4500 RPM, 5–9 L/min) overlaps CPB clinical range. Validation activities deemed sufficiently relevant for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when code verification has been completed and residuals demonstrate convergence.",
      "rationale": "At MRL 2, explicit iterative solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations. Factor scoped out consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for a well-established commercial solver with documented simulation plan.",
      "rationale": "Simulation plan reviewed by senior engineer. Commercial solver with established workflows used. Formal use-error analysis not required at MRL 2. Factor acknowledged and deferred per credibility plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when model form is consistent with published literature for similar devices.",
      "rationale": "SST k-omega turbulence model and power-law hemolysis model (Giersiepen correlation) are standard choices for CPB CFD per published literature. Formal model-form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values documented with sources.",
      "rationale": "All model inputs (geometry, fluid properties, boundary conditions, hemolysis model constants) documented in Model Description Report v2.1 with literature sources. Formal sensitivity or uncertainty analysis of inputs not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample provenance documented.",
      "rationale": "Porcine blood samples used in bench hemolysis tests; provenance, storage, and preparation documented per ASTM F1841. Statistical characterization of sample variability not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when validation and COU operating conditions are qualitatively matched.",
      "rationale": "Validation and COU share the same pump geometry and overlapping operating range. Formal equivalency metric not required at MRL 2. Qualitative equivalency documented in Validation Plan v1.3."
    }
  ],
