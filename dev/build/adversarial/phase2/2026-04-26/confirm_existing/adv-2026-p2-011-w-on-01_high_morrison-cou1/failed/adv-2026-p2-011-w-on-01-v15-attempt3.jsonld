      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; use of published FDA pump experimental dataset with documented sample provenance is sufficient.",
      "rationale": "FDA generic pump experimental dataset used as published. Sample characterization beyond published documentation not required at MRL 2. Scoped out per ASME V&V 40 Table 3."
