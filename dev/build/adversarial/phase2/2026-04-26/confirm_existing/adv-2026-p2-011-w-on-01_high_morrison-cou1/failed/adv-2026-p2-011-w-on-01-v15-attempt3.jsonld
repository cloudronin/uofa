  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented QA procedures and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2023R1 is used under institutional license with documented version control, regression test suite, and QA log. All relevant hemolysis test cases pass. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent benchmark must confirm spatial order of accuracy for the momentum and scalar transport equations.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes and passive scalar (hemolysis power-law) equations. Second-order spatial accuracy confirmed. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index QoI and must be below 5% on the medium mesh.",
      "rationale": "Three-level mesh refinement study performed (coarse 4.2 M, medium 9.8 M, fine 22.1 M cells). GCI for hemolysis index on medium mesh is 3.1%. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) must be documented and traceable to the validation dataset.",
      "rationale": "FDA pump experimental conditions (2.5 L/min and 3500 RPM operating point) are fully documented and traceable to the Morrison et al. 2016 dataset. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement between predicted and measured hemolysis index must exceed 0.85 across the validation operating envelope.",
      "rationale": "Normalized index of agreement of 0.91 achieved across five operating points. Predicted hemolysis index within 8% of measured values at worst-case condition. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, peak shear stress, exposure time) must be directly linked to the clinical harm mechanism and regulatory submission requirements.",
      "rationale": "Hemolysis index, peak shear stress, and cumulative exposure time are the QoIs. All three are directly cited in FDA guidance on CPB device evaluation. Required level 2 achieved."
