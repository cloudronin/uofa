      "acceptanceCriteria": "Solver version-controlled; regression test suite passes; documented QA plan in place.",
      "rationale": "ANSYS Fluent 2022R2 used under an ISO 9001-certified QA programme. Full regression suite of 47 benchmark cases executed with zero failures. Version control via Git with tagged release. Meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent benchmark demonstrates correct discretisation of governing equations.",
      "rationale": "Taylor–Green vortex and lid-driven cavity benchmarks confirm second-order spatial accuracy. Observed order of convergence 1.97 ± 0.04 consistent with nominal scheme order. Code verification complete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI < 5% on hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study (4.2 M, 11.7 M, 31.4 M cells) yields GCI of 2.8% on normalised hemolysis index. Exceeds MRL 2 threshold. Fine-grid solution adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented and traceable; fluid temperature and viscosity within ±5% of simulation inputs.",
      "rationale": "FDA GCBP PIV experiments conducted at 37 °C with glycerol-water blood analogue (viscosity 3.5 mPa·s ± 3%). Boundary conditions (inlet flow rate, outlet pressure) logged at 1 Hz throughout each test. Full traceability to calibrated instrumentation records confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised hemolysis index prediction within 20% of bench measurement at all five operating points.",
      "rationale": "Predicted normalised index of haemolysis (NIH) compared against five bench operating points. Maximum deviation 14.3%, mean absolute error 9.1%. All points within acceptance band. Validation successful."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH, wall shear stress distribution) directly maps to clinical hemolysis risk metric used in 510(k) submission.",
      "rationale": "NIH is the regulatory-accepted surrogate for red blood cell damage per ASTM F1841. Wall shear stress fields inform worst-case operating point identification. Both QoIs are directly relevant to the CPB device decision question."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on geometrically identical pump under flow conditions spanning the intended CPB operating envelope.",
      "rationale": "FDA GCBP geometry used for both simulation and experiment. Operating envelope (3–6 L/min, 60–120 mmHg) fully covered by five validation points. Fluid analogue viscosity matches clinical blood viscosity within measurement uncertainty. Validation activities are directly relevant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
