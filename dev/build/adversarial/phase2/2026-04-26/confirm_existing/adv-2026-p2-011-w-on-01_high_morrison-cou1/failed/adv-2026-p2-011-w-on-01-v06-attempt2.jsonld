      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures, version control, and regression test suite covering cardiovascular flow benchmarks.",
      "rationale": "ANSYS Fluent 2023 R1 was used; vendor-supplied QA documentation, ISO 9001 certification, and an internal regression suite of 47 cardiovascular benchmark cases confirm conformance at the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes at least two published Method of Manufactured Solutions or analytical benchmark tests relevant to rotating-frame turbulent flow.",
      "rationale": "ANSYS Fluent passes the Taylor–Couette flow analytical solution and the rotating-disk von Kármán benchmark, both documented in the solver verification report. Residual norms converge to machine precision on both cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for NIH QoI less than 5% between medium and fine mesh; Richardson extrapolation applied.",
      "rationale": "Three-level mesh refinement study (3.2 M, 8.1 M, 18.4 M cells) yielded GCI of 2.7% for NIH between medium and fine meshes. Asymptotic convergence confirmed (GCI ratio 1.02). Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, hematocrit) documented with measurement uncertainty less than 3%.",
      "rationale": "FDA benchmark experimental protocol specifies flow rates measured by Coriolis meter (±0.5%), pressures by calibrated transducers (±1.2%), temperature controlled to 37 ± 0.5 °C, hematocrit 33 ± 1%. All uncertainties within acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., relative error or validation metric E) computed for each QoI; agreement within 10% at all operating points.",
      "rationale": "NIH relative errors at five operating points: 3.1%, 5.4%, 7.8%, 6.2%, 8.3%. Pressure-rise errors: 1.9%–4.7%. All within the 10% criterion. No systematic bias observed across the flow-rate range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH and pump pressure rise) are directly linked to the clinical decision question of worst-case hemolysis identification for CPB device clearance.",
      "rationale": "NIH is the FDA-accepted metric for hemolysis in CPB devices (FDA 2017 guidance). Pump pressure rise characterizes hydraulic performance at each operating point. Both QoIs are explicitly required by the regulatory submission context described in the claim and requirement nodes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry, same fluid (bovine blood or blood analog), and overlapping operating envelope as the intended CPB use.",
      "rationale": "FDA benchmark experiments used the identical generic centrifugal pump geometry, bovine blood at 33% hematocrit, and the 2–6 L/min flow range matching the CPB operating envelope. Rotational speed range 2000–3500 RPM covers the intended 2000–4000 RPM envelope with minor extrapolation documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance 1e-5 for all equations; mass imbalance below 0.01%.",
      "rationale": "At MRL 2, explicit solver-error quantification beyond standard convergence monitoring is not required. Residuals converged to 1e-6 and mass imbalance was below 0.005% in all production runs, satisfying the implicit requirement without formal assessment activity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst follows documented simulation protocol; independent peer review of setup files conducted.",
      "rationale": "MRL 2 does not mandate formal use-error assessment. The simulation was executed by a PhD-level CFD analyst following an internal standard operating procedure. Setup files were peer-reviewed by a second analyst prior to production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis power-law submodel selected based on published literature and sensitivity study; model-form uncertainty acknowledged.",
      "rationale": "SST k-ω turbulence model selected based on published rotating-machinery validation studies. Giersiepen–Wurzinger power-law hemolysis model applied; sensitivity to model constants assessed by varying exponents ±10%, yielding NIH variation of ±4.1%, within acceptable uncertainty for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood viscosity, density, and hemolysis model constants sourced from peer-reviewed literature with uncertainty bounds reported.",
      "rationale": "Fluid properties: density 1055 kg/m³ (±5 kg/m³), dynamic viscosity modeled as non-Newtonian Carreau fluid with parameters from Merrill et al. (1965). Hemolysis constants from Giersiepen et al. (1990) with literature-range uncertainty bounds applied. Sensitivity analysis confirms NIH prediction robust to input uncertainty at MRL 2 level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample characterization (blood source, anticoagulant, storage time) documented.",
      "rationale": "MRL 2 does not require formal test-sample assessment. FDA benchmark protocol documents use of fresh bovine blood within 6 hours of collection, anticoagulated with EDTA, hematocrit adjusted to 33 ± 1%. Sample variability is acknowledged as a source of experimental uncertainty in the output comparison factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Boundary conditions applied in simulation match experimental conditions within measurement uncertainty.",
      "rationale": "MRL 2 does not require formal equivalency assessment. Simulation boundary conditions were set directly from the mean experimental values reported in the FDA benchmark dataset. Residual differences between nominal experimental and simulated inputs are captured within the output comparison uncertainty budget."
    }
