  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold a documented quality management record with version control and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022 R2 is used with ISO 9001-certified QMS documentation. Version-controlled solver release notes and regression test results for rotating machinery flows were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via manufactured-solution or benchmark tests for rotating reference frame and viscous flow.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes equations in rotating reference frame; observed order of accuracy 1.97 is consistent with nominal second-order spatial discretization, confirming correct code implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index must be below 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study (2.1 M, 5.8 M, 14.2 M cells) yields GCI of 2.4% for the normalized index of hemolysis on the fine mesh, exceeding the MRL 2 acceptance threshold and achieving MRL 3 performance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) must be documented with stated uncertainties and must span the CPB operating envelope.",
      "rationale": "FDA benchmark experiments conducted at 2.5, 5.0, and 7.0 L/min at 2500 and 3500 RPM with bovine blood; temperature, hematocrit, and viscosity documented with expanded uncertainties at 95% confidence. Operating envelope covers clinical CPB range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis must agree with experimental measurements within combined simulation and experimental uncertainty bands for at least 4 of 5 operating points.",
      "rationale": "Predicted NIH values fall within combined uncertainty bands at all 5 operating points; maximum relative error 8.3% at 7 L/min / 3500 RPM, within the 12% combined uncertainty bound. Validation metric confirms adequate predictive accuracy for worst-case identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis) must be directly linked to the clinical endpoint of red blood cell damage in CPB patients.",
      "rationale": "NIH is the FDA-recognized surrogate endpoint for hemolytic potential in blood-contacting devices. Direct mechanistic link between shear-stress exposure and RBC membrane failure is established in peer-reviewed literature and FDA guidance documents."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and fluid as the COU, or differences must be bounded by documented similarity arguments.",
      "rationale": "Validation uses the identical FDA generic centrifugal pump geometry and bovine blood as surrogate for human blood under CPB conditions. Species correction factor for bovine-to-human RBC fragility applied with documented uncertainty propagation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence residuals monitored as proxy.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-5 for all equations; mass imbalance below 0.01%. Scoped out per ASME V&V 40 Table 3 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation setup reviewed by independent analyst as minimum control.",
      "rationale": "Independent analyst review of simulation setup files and boundary condition specification performed. Formal use-error assessment not required at MRL 2 per ASME V&V 40 Table 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection documented with literature justification.",
      "rationale": "SST k-omega turbulence model selected based on prior published benchmark studies for blood pump flows. Formal model form uncertainty quantification not required at MRL 2 per ASME V&V 40 Table 3; literature justification documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values documented with sources.",
      "rationale": "Blood density 1056 kg/m3, dynamic viscosity 0.0035 Pa·s, Giersiepen-Wurzinger hemolysis power-law constants from published literature. Formal sensitivity analysis not required at MRL 2 per ASME V&V 40 Table 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterization documented.",
      "rationale": "Bovine blood sourced from USDA-inspected facility; hematocrit 33±2%, documented per FDA benchmark protocol. Statistical characterization of inter-sample variability not required at MRL 2 per ASME V&V 40 Table 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; boundary condition mapping from experiment to simulation documented.",
      "rationale": "Inlet velocity profiles mapped from experimental flow meter readings; outlet pressure boundary conditions set to match experimental pump head measurements. Formal equivalency assessment not required at MRL 2 per ASME V&V 40 Table 3."
    }
