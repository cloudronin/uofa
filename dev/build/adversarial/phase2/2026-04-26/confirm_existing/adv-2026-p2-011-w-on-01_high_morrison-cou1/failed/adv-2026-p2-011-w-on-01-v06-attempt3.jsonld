      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping of experimental inputs to simulation inputs documented in the V&V plan.",
      "rationale": "Qualitative equivalency table provided in V&V plan mapping each experimental parameter to its simulation counterpart. Quantitative equivalency metrics not required at MRL 2 scoping decision."
    }
