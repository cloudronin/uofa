  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented, version control enforced, solver regression tests passing for all relevant CFD modules.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is governed by an ISO 9001-compliant SQA plan. Version control via Git with tagged release used for all simulation runs. Regression test suite covering hemolysis UDF and turbulence models executed without failures."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and manufactured-solution benchmarks demonstrate solver convergence consistent with nominal discretization order.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver confirms second-order spatial accuracy. Benchmark results archived in project repository with traceability to solver release."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI below 5% for hemolysis index QoI on the finest mesh pair.",
      "rationale": "Three-mesh refinement study performed (coarse 4.2 M, medium 8.7 M, fine 17.1 M cells). GCI for normalized index of hemolysis = 3.2%, satisfying the 5% threshold. Monotonic convergence confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature) match simulation inputs within stated measurement uncertainty bands.",
      "rationale": "FDA benchmark experimental conditions (2.5 L/min, 3500 RPM, 37 °C, bovine blood analog) reproduced in simulation within ±2% of reported values. Uncertainty in inlet velocity profile propagated and documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis within 15% of experimental mean across all operating points in the CPB envelope.",
      "rationale": "Across 9 operating points spanning the CPB flow-speed envelope, mean absolute percentage error in NIH = 9.4%, within the 15% acceptance threshold. Worst-case operating point identified at 2.0 L/min / 4000 RPM with NIH = 0.0038 g/100 L."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, wall shear stress distribution, scalar stress exposure) are directly linked to the clinical hemolysis decision question for Class II CPB devices.",
      "rationale": "NIH is the regulatory-accepted hemolysis metric per ASTM F1841. Scalar stress exposure integral links mechanistic shear-damage model to NIH. Both QoIs are directly decision-relevant for worst-case identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device geometry, fluid, and operating range as the intended CPB clinical use.",
      "rationale": "FDA generic centrifugal blood pump geometry used in both validation experiments and clinical-use simulations. Bovine blood analog viscosity matched to human blood at 37 °C. Operating envelope (1.5–5.0 L/min, 2500–5000 RPM) covers full CPB range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default solver error controls (residual convergence 1e-5) accepted.",
      "rationale": "At MRL 2, explicit solver error quantification beyond standard residual monitoring is not required. Residuals converged to 1e-5 for all equations; no solver divergence events recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records and simulation checklist constitute sufficient control.",
      "rationale": "Simulation analyst holds CFD certification with documented CPB device experience. Standard operating procedure checklist completed for all runs. Formal use-error quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection justified by literature precedent for CFD hemolysis in rotary blood pumps.",
      "rationale": "SST k-omega turbulence model and power-law hemolysis damage model selected per published consensus for rotary pump hemolysis CFD. Formal model-form uncertainty quantification deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values used with documented sources for fluid properties and boundary conditions.",
      "rationale": "Blood analog viscosity, density, and hemolysis model coefficients taken from peer-reviewed sources. Sensitivity to ±5% variation in viscosity evaluated informally; NIH response within 3%. Full uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA benchmark dataset sample size accepted as adequate for the validation comparison.",
      "rationale": "FDA benchmark dataset comprises n=3 replicate experiments per operating point, consistent with published FDA study protocol. Statistical characterization of inter-replicate variability not required at MRL 2."
    },
    {
