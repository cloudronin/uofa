  "signature": "ed25519:9c4a1f2e8b5d3c7a0f6e2b9d4c1a8f5e3b0d7c4a1f9e6b3d0c8a5f2e9b6d3c0",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver (ANSYS Fluent 2023R1) must hold a documented QA plan covering version control, regression testing, and change management consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2023R1 is accompanied by a vendor-supplied Software Quality Plan and passes all relevant FDA-recognized regression test suites. Version control is enforced via Git with tagged release commits. Requirement satisfied at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through at least one manufactured-solution or benchmark test case at MRL 2.",
      "rationale": "The Navier-Stokes solver was verified against the lid-driven cavity benchmark (Re = 1000) and a Poiseuille flow manufactured solution. L2 norm errors converge at the expected second-order rate, confirming correct code implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the hemolysis index QoI must be below 5% on the fine mesh at MRL 2.",
      "rationale": "Richardson extrapolation over three systematically refined meshes (4.2 M, 11.8 M, 31.4 M hexahedral cells) yields a GCI of 2.1% for the normalized index of hemolysis on the fine mesh. Achieved level exceeds requirement, providing additional confidence margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) must match simulated conditions within documented uncertainty bands at MRL 2.",
      "rationale": "FDA benchmark PIV experiments were conducted at 2.5 L/min and 3500 RPM with glycerol-water blood analog. CFD boundary conditions replicate these within ±1.5% on flow rate and ±0.5 RPM on rotational speed, well within the reported experimental uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and velocity field must agree with experimental measurements within combined simulation and experimental uncertainty at MRL 2.",
      "rationale": "Predicted normalized index of hemolysis (NIH = 0.0042 g/100 L) agrees with in-vitro measurement (NIH = 0.0039 ± 0.0005 g/100 L) within combined uncertainty. Velocity field RMS deviation versus PIV is 4.8%, within the validation acceptance threshold of 8%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear stress distribution) must be directly linked to the decision question of identifying worst-case hemolysis operating conditions.",
      "rationale": "The normalized index of hemolysis and volume-averaged scalar shear stress are the primary QoIs driving worst-case identification. Both are directly traceable to the clinical decision question and are the same quantities reported in the device submission requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope (flow rate 1–6 L/min, speed 2500–4500 RPM) relevant to CPB use in a Class II device.",
      "rationale": "Validation activities span five operating points across the CPB envelope. The FDA generic pump geometry is a recognized surrogate for Class II CPB devices. Validation relevance is judged sufficient for MRL 2 without requiring patient-specific geometry matching."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit iterative solver error quantification beyond residual monitoring is not required provided convergence criteria are documented.",
      "rationale": "Solver residuals are driven below 1e-5 for all equations. Explicit round-off and iterative error budgets are not required at MRL 2 and are scoped out of this assessment consistent with ASME V&V 40 Table 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use-error analysis is not required at MRL 2 for internal simulation activities with trained analysts.",
      "rationale": "Simulations are performed by trained CFD engineers following documented SOPs. Formal use-error FMEA is not mandated at MRL 2 and is deferred to higher risk level assessments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model-form uncertainty quantification is not required at MRL 2 provided turbulence model selection is documented with literature justification.",
      "rationale": "SST k-omega turbulence model is selected based on published validation studies for rotating blood-contacting devices. Formal model-form UQ (e.g., Bayesian model averaging) is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input uncertainty propagation is not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "Blood analog viscosity and density are taken from published ASTM standards with nominal values. Formal sensitivity analysis or Monte Carlo propagation is not required at MRL 2 and is deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability is not required at MRL 2 for benchmark comparisons using a single representative geometry.",
      "rationale": "The FDA generic pump geometry is a single canonical benchmark; sample-to-sample geometric variability analysis is not applicable. Factor is scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and clinical use inputs is not required at MRL 2.",
      "rationale": "Operating conditions in validation experiments are representative of CPB clinical use. Formal dimensional analysis or equivalency scoring is not required at MRL 2 and is noted as a future enhancement for MRL 3 assessments."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/dr-e-morrison",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for Model Risk Level 2. The six not-assessed factors are explicitly scoped out per ASME V&V 40 Table 3 at MRL 2. The CFD model is judged credible for identifying worst-case hemolysis operating conditions of the FDA generic centrifugal blood pump in the CPB context described in the Claim and Requirement documentation. No weakeners were identified that would preclude acceptance at this risk level.",
