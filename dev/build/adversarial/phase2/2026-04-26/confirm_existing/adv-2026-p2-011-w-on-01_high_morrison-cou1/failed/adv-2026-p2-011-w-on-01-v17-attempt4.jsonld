      "type": "ValidationResult",
      "name": "Hemolysis index QoI comparison against FDA benchmark PIV data"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-rise-comparison",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation at nominal CPB operating point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042689",
