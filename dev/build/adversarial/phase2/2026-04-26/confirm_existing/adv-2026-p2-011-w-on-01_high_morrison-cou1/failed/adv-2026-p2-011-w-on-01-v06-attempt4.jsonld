  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors appropriately scoped as not-assessed consistent with MRL 2 requirements per ASME V&V 40-2018 Table 3. Hemolysis index predictions agree with FDA GCBP experimental benchmark within the 25% acceptance band across all six operating points. The model is judged credible for identifying worst-case hemolysis operating conditions for a Class II CPB device in support of pre-market submission. Assessment team unanimously recommends acceptance.",
