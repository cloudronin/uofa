  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent documented QMS with version-controlled source and regression test suite.",
      "rationale": "ANSYS Fluent 2021 R2 is used under an ISO 9001-certified QMS. Regression test suite covers 240 benchmark cases; all pass within tolerance. Version control via Git with tagged release. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical rotating-passage flow must confirm second-order spatial convergence.",
      "rationale": "Method of manufactured solutions applied to a rotating annular passage confirms 1.97-order spatial accuracy for velocity components and 1.94-order for pressure. Consistent with second-order finite-volume discretization. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study (coarse 4.2 M, medium 8.7 M, fine 17.1 M cells) yields GCI of 3.1% for the normalized index of hemolysis on the fine mesh. Richardson extrapolation confirms monotonic convergence. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) must be reproduced in simulation within ±2% of nominal values.",
      "rationale": "FDA GCBP experimental conditions replicated: flow rates 3–6 L/min ±0.8%, rotational speeds 2500–4500 RPM ±0.5%, glycerol-water analog fluid viscosity matched to within 1.2%. All six operating points fall within acceptance band. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis must agree with experimental measurements within ±25% across all six validation operating points.",
      "rationale": "Predicted normalized index of hemolysis deviates from experimental measurements by 8–22% across six operating points, with mean absolute error of 14.3%. All points fall within the ±25% acceptance band. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, wall shear stress peaks) must directly correspond to the clinical harm mechanism addressed by the device submission.",
      "rationale": "The normalized index of hemolysis and peak scalar shear stress are the primary QoIs. Both directly correspond to the red blood cell damage mechanism relevant to CPB device regulatory evaluation. Traceable to FDA guidance on hemolytic potential. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and an overlapping operating envelope with the intended clinical use range.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry, which is identical to the model geometry. Operating envelope (3–6 L/min, 2500–4500 RPM) fully encompasses the CPB worst-case identification range. Fluid analog chosen to match blood viscosity within physiological range. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver residual monitoring sufficient.",
      "rationale": "At Model Risk Level 2, formal numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations. Factor scoped consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; standard operator training and simulation protocol documentation are sufficient.",
      "rationale": "MRL 2 does not require formal use-error analysis. Simulation protocol documented in internal SOP-CFD-007. All analysts completed ANSYS Fluent training certification. Factor accepted as not-assessed per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; turbulence model selection justified by literature precedent.",
      "rationale": "SST k-omega turbulence model selected based on published precedent for centrifugal blood pump CFD (Hariharan et al. 2011, Fraser et al. 2012). Formal model-form uncertainty quantification not required at MRL 2. Accepted as not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "All model inputs (geometry, boundary conditions, material properties) documented with traceability to measurement sources. Formal sensitivity or uncertainty analysis of inputs not required at MRL 2. Accepted as not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; single representative experimental dataset from FDA benchmark is sufficient.",
      "rationale": "FDA GCBP benchmark dataset used as the single experimental reference. Statistical characterization of sample variability not required at MRL 2. Experimental measurement uncertainty reported by original investigators (±5% for hemolysis index). Accepted as not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; qualitative mapping between validation and COU inputs is sufficient.",
      "rationale": "Qualitative equivalency established: validation uses glycerol-water analog at matched viscosity; COU targets blood analog conditions. Dimensional analysis confirms Reynolds number similarity within 8%. Formal equivalency quantification not required at MRL 2. Accepted as not-assessed."
    }
  ],
