  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented verification test suite and version-controlled release history consistent with MRL 2 expectations.",
      "rationale": "ANSYS Fluent 2022 R2 used; vendor-supplied verification test suite covers laminar and turbulent internal flows. Version control and release notes documented. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical rotating-passage benchmark must confirm second-order spatial convergence.",
      "rationale": "Method of manufactured solutions applied to a rotating annular passage. Observed convergence order of 1.97 confirmed. Benchmark results archived in project repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for NIH QoI must be below 5% on the fine grid.",
      "rationale": "Three-mesh Richardson extrapolation performed (1.2 M, 4.8 M, 19.2 M cells). GCI on NIH = 3.1% on fine mesh. Discretization error is within the accepted threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) must be reproduced in CFD within ±2% of nominal values.",
      "rationale": "FDA benchmark experimental conditions (2.5 L/min, 3500 RPM, glycerol-water 36 cP) replicated in CFD inlet/outlet BCs. Deviation <1% for all parameters. Fluid rheology matched to within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised RMS error between CFD and PIV velocity fields must be below 10% across the impeller mid-plane.",
      "rationale": "NRMSE of CFD vs PIV velocity magnitude = 6.8% across impeller mid-plane at 3500 RPM / 2.5 L/min. NIH prediction within 12% of experimental mean across 5 operating points. Exceeds MRL 2 requirement; achieves MRL 3 quality."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, scalar shear stress distribution, residence time) must be directly traceable to the clinical harm mechanism (red cell lysis) identified in the device risk analysis.",
      "rationale": "QoIs selected from device FMEA: NIH is the regulatory-accepted hemolysis metric; scalar shear stress and residence time are mechanistic inputs to the Power-Law hemolysis model. Traceability matrix linking QoIs to risk file documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope (flow rate 3–6 L/min, speed 2000–3500 RPM) relevant to adult CPB use.",
      "rationale": "FDA GCBP benchmark data span 2.5–7 L/min and 2000–3500 RPM, bracketing the intended CPB envelope. Geometric similarity to the subject device confirmed via impeller-to-casing diameter ratio comparison. Validation activities are judged sufficiently relevant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default solver iterative tolerance documentation accepted.",
      "rationale": "At MRL 2 this factor requires only awareness of iterative convergence. Residuals monitored to 1e-5; no separate iterative error quantification required. Factor scoped out per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst qualification record accepted as surrogate.",
      "rationale": "Lead analyst holds a doctoral qualification in computational fluid dynamics with 8 years of rotary blood pump CFD experience. Formal use-error quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; turbulence model selection rationale accepted.",
      "rationale": "SST k-ω turbulence model selected based on published literature for internal rotating flows at similar Re. Formal model-form uncertainty quantification deferred to MRL 3. Acceptable at current risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values with documented sources accepted.",
      "rationale": "Fluid properties and hemolysis model constants sourced from peer-reviewed literature (Giersiepen 1990, Zhang 2011). Sensitivity to input variation not formally quantified at MRL 2. Documented in model specification report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; FDA benchmark sample documentation accepted.",
      "rationale": "FDA GCBP benchmark used porcine blood and glycerol-water analogue; sample characterisation reported in the FDA benchmark publication. No additional sample assessment required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; qualitative mapping of validation inputs to COU inputs accepted.",
      "rationale": "Qualitative comparison of FDA benchmark operating conditions to intended CPB envelope documented in validation plan. Formal equivalency metrics deferred to MRL 3. Accepted per MRL 2 assessment framework."
    }
  ],
