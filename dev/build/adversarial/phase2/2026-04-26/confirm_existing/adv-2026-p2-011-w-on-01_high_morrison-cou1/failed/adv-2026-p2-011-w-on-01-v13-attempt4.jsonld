      "id": "https://uofa.net/morrison/validation/gcbp-piv-comparison",
      "type": "ValidationResult",
      "name": "FDA GCBP PIV velocity field comparison — CFD vs experimental"
    },
    {
      "id": "https://uofa.net/morrison/validation/gcbp-hemolysis-index",
      "type": "ValidationResult",
      "name": "Normalised index of hemolysis (NIH) prediction vs bench measurement at 5 operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034709",
