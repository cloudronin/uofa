  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented regression test suite covering turbulence and transport models used in this analysis.",
      "rationale": "ANSYS Fluent 2022R2 is employed under ISO 9001-certified QMS. Regression test suite covers k-omega SST and species transport modules. Version control via Git with tagged release; all relevant test cases pass. Achieved level 2 meets required level 2 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent analytical benchmark must confirm spatial discretization order for momentum and scalar transport equations.",
      "rationale": "MMS study confirmed second-order spatial accuracy for momentum equations and first-order for the hemolysis power-law scalar transport equation. Results published in validation report VR-2022-04. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be computed on at least three systematically refined meshes; GCI on hemolysis index QoI must be below 5%.",
      "rationale": "Three-mesh Richardson extrapolation performed (2.1M, 6.4M, 18.9M cells). GCI for normalized index of hemolysis at design point is 2.3%, well below 5% threshold. Achieved level 3 exceeds required level 2, providing additional confidence margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity, hematocrit) must be reproduced in simulation within documented uncertainty bounds.",
      "rationale": "FDA benchmark conditions reproduced: inlet flow 2.5–7.5 L/min, 2500 and 3500 RPM, bovine blood analog at 37°C, Hct 40%. Measurement uncertainties documented in FDA dataset metadata. Simulation BCs match within stated experimental uncertainty bands."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty Uval) must be computed and compared against experimental data for primary QoIs: pressure head and normalized index of hemolysis.",
      "rationale": "Pressure head E% ranges 3.1–6.8% across five operating points. Normalized index of hemolysis E% ranges 9.2–14.7%, within combined experimental and numerical uncertainty Uval = 17.4%. Validation uncertainty framework follows ASME V&V 20-2009."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (pressure head, hemolysis index) must directly map to the decision QoI: identification of worst-case hemolysis operating condition.",
      "rationale": "Normalized index of hemolysis is the direct clinical surrogate for red blood cell damage. Pressure head validates overall flow physics. Both QoIs are directly relevant to identifying worst-case operating points for CPB device submission. Mapping documented in COU rationale section of the simulation report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (FDA generic centrifugal pump) and a physiologically representative fluid under rotational speeds spanning the intended operating envelope.",
      "rationale": "FDA benchmark uses the identical generic centrifugal pump geometry. Bovine blood analog at physiological hematocrit and viscosity is an accepted surrogate per FDA guidance. Operating envelope 2500–3500 RPM spans the intended CPB clinical range. Relevance score assessed as level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations is sufficient at MRL 2 without formal iterative error quantification.",
      "rationale": "At MRL 2, formal iterative error quantification beyond residual monitoring is not required. All simulations converged to residuals below 1e-5 for continuity, momentum, and scalar transport. No further assessment needed; factor scoped to level 1 per MRL 2 requirements table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
