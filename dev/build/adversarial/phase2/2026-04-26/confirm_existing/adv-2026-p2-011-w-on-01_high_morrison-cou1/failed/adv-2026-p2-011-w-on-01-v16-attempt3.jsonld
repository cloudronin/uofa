  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 not-assessed factors are appropriately scoped out per the ASME V&V 40 MRL 2 requirements table. Discretization error achieved level 3 against a required level 2, providing additional confidence in mesh adequacy. Validation uncertainty for the hemolysis index QoI is within combined experimental and numerical uncertainty bounds. The assessment team concludes that the CFD model provides sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device pre-market submission.",
