  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version-controlled QA process with documented regression testing suite covering turbulence and scalar transport modules.",
      "rationale": "ANSYS Fluent 2022R2 used under ISO 9001-registered QA program. Regression test suite of 47 benchmark cases executed; all pass within specified tolerances. Version control via Git with tagged release. Meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for Navier-Stokes and scalar hemolysis transport equations using manufactured solutions on structured grids.",
      "rationale": "Method of manufactured solutions applied to laminar and k-omega SST turbulent flow cases. Observed spatial order of accuracy 1.97 (expected 2.0) within acceptable tolerance. Temporal discretization verified at first-order for pseudo-transient stepping. Meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) less than 5% for hemolysis index QoI on at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 11.6M, 28.9M cells). GCI for normalized hemolysis index: 3.1% (fine-to-medium), 2.8% (medium-to-coarse). Richardson extrapolation applied. Exceeds MRL 2 requirement; achieves MRL 3 level rigor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with inlet flow rate uncertainty less than 3%, rotational speed uncertainty less than 1%, and fluid temperature controlled within ±1°C.",
      "rationale": "FDA benchmark experimental data used. Flow rate measured by Coriolis meter (±1.2% uncertainty), rotational speed by optical encoder (±0.3%), temperature maintained at 37±0.5°C. All within acceptance thresholds. Meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 20% of experimental measurements across the CPB operating envelope (1500–3500 RPM, 3–8 L/min).",
      "rationale": "Mean absolute percentage error of hemolysis index predictions: 11.4% across 18 operating points. Maximum deviation 17.8% at 3500 RPM, 8 L/min. Velocity field comparison via PIV shows normalized RMS error 8.3%. All within acceptance thresholds. Meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (normalized hemolysis index, scalar shear stress exposure time) must be directly traceable to device performance requirements in the 510(k) submission.",
      "rationale": "Normalized hemolysis index (NIH) and modified index of hemolysis (MIH) are the primary QoIs, both explicitly listed in the predicate device 510(k) K193038 as performance benchmarks. Shear stress exposure time distribution is a secondary QoI supporting worst-case operating point identification. Direct traceability established. Meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and cover at least 80% of the intended CPB operating envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, identical to the simulation geometry. Experimental coverage spans 1500–3500 RPM and 3–8 L/min, encompassing 94% of the intended CPB operating envelope. Blood analog fluid (aqueous glycerol, matched viscosity) used consistently. Meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to at least 1e-5 for all transport equations documented.",
      "rationale": "Not assessed at MRL 2 for this factor. Solver residuals monitored as standard practice and confirmed below 1e-4, but formal uncertainty quantification of iterative error not required at this model risk level. Scoped to future MRL 3 assessment if device advances to Class III submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of simulation setup by independent analyst not involved in original model construction.",
      "rationale": "Not assessed at MRL 2. Internal peer review of boundary conditions and material properties performed informally; independent formal use-error assessment not required at this model risk level for Class II device. Deferred to MRL 3 if risk classification changes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification comparing k-omega SST, k-epsilon realizable, and LES turbulence closures.",
      "rationale": "Not assessed at MRL 2. k-omega SST selected based on published literature consensus for rotating turbomachinery hemolysis applications. Formal turbulence model sensitivity study not required at this model risk level. Noted as enhancement for MRL 3 pathway."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probabilistic sensitivity analysis of blood analog viscosity, density, and hemolysis power-law coefficients across literature-reported ranges.",
      "rationale": "Not assessed at MRL 2. Nominal material properties from ASTM F1841 blood analog specification used. Parametric sensitivity of hemolysis power-law exponents (Giersiepen model) not formally quantified at this model risk level. Identified as gap for MRL 3 upgrade."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability with minimum n=5 replicates per operating point.",
      "rationale": "Not assessed at MRL 2. FDA benchmark dataset provides single-replicate measurements at each operating point. Statistical repeatability characterization not required at this model risk level. Acknowledged limitation; full replicate study planned for pivotal testing phase."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Boundary conditions applied in simulation must match experimental inlet/outlet conditions within measurement uncertainty bands.",
      "rationale": "Inlet velocity profiles derived from PIV measurements at pump inlet plane; outlet pressure boundary conditions matched to experimental pressure transducer readings within ±2.1%. Rotational speed boundary condition matches encoder measurement within 0.3%. All simulation input parameters traceable to experimental measurements. Meets MRL 2 requirement."
    }
  ],
