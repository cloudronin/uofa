  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-mrl2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-biofluid-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2 Class II device submission. Six factors appropriately scoped out at MRL 2 with documented justification and deferred pathway to MRL 3. Hemolysis index predictions within 20% acceptance threshold across the CPB operating envelope. GCI below 5% demonstrating adequate discretization control. Assessment team concludes the model has sufficient credibility to support identification of worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in the CPB use context described in the Claim and Requirement documentation.",
