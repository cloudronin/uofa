      "type": "ValidationResult",
      "name": "Hemolysis index validation against FDA benchmark experimental data at CPB operating envelope"
    },
    {
      "id": "https://uofa.net/morrison/validation/cpb-hemolysis-vr-02",
      "type": "ValidationResult",
      "name": "Velocity field PIV comparison at 2500 RPM and 5 L/min flow rate"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4048883",
