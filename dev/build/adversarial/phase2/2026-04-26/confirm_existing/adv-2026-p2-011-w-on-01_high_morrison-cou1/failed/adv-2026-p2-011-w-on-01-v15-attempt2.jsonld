  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite with passing results for all benchmark cases relevant to rotating machinery and viscous flow.",
      "rationale": "ANSYS Fluent 2022R2 was used with a documented QA plan. All relevant benchmark cases from the ASME V&V 20 suite passed. Software version control and audit trail confirm compliance with MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method-of-manufactured-solutions or equivalent benchmark for rotating frame formulations.",
      "rationale": "Code verification performed using Taylor-Green vortex and lid-driven cavity benchmarks. Rotating reference frame implementation verified against published analytical solutions for Couette flow. Observed convergence rates consistent with second-order accuracy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary QoI (hemolysis index) with GCI < 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study conducted with mesh sizes of 2.1M, 6.8M, and 18.4M cells. GCI for hemolysis index on fine grid = 2.3%, satisfying the acceptance criterion. Richardson extrapolation confirms asymptotic convergence. Achieved level exceeds requirement due to thorough refinement study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with uncertainty bounds for flow rate, rotational speed, fluid temperature, and hematocrit level.",
      "rationale": "FDA benchmark experimental data from Hariharan et al. (2011) used. Flow rates (2–7 L/min) and rotational speeds (2000–3500 RPM) documented with calibration certificates. Blood analog fluid (glycerol-water) properties characterized at 37°C with reported uncertainty of ±2%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation uncertainty) must be computed for hemolysis index predictions against experimental measurements.",
      "rationale": "Normalized RMS error for hemolysis index across all operating points = 8.7%, within the validation uncertainty band of ±12%. Pressure rise predictions show mean absolute error of 4.2%. Comparison performed using ASME V&V 20 validation uncertainty framework."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, wall shear stress) must be directly linked to the device performance metric of concern for CPB use.",
      "rationale": "Hemolysis index (HI) is the primary regulatory QoI for CPB pump assessment per FDA guidance. Wall shear stress and exposure time distributions directly feed the power-law hemolysis model. Both QoIs are mechanistically linked to red blood cell damage under CPB operating conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at operating conditions overlapping with or bounding the intended CPB operating envelope (2–6 L/min, 2000–3500 RPM).",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry under flow rates of 2–7 L/min and rotational speeds of 2000–3500 RPM, fully encompassing the CPB operating envelope. Blood analog fluid properties are representative of clinical hematocrit ranges. Geometric similarity confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, detailed iterative convergence error quantification beyond standard residual monitoring is not required.",
      "rationale": "Solver residuals monitored to 1e-5 for all equations. At MRL 2, this level of convergence monitoring satisfies the not-assessed designation. Detailed round-off and iterative error decomposition not required for this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error assessment is not required provided simulation is performed by qualified personnel following documented procedures.",
      "rationale": "Simulations performed by engineers with documented CFD training records. Standard operating procedures followed for boundary condition setup and post-processing. Formal use error quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal model form uncertainty quantification is not required. Selection of turbulence model and hemolysis constitutive law must be documented with literature justification.",
      "rationale": "SST k-omega turbulence model selected based on literature consensus for rotating machinery hemolysis prediction. Giersiepen power-law hemolysis model documented with published coefficients. Model form uncertainty not formally quantified per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal sensitivity analysis of model inputs is not required. Input parameters must be documented with nominal values and sources.",
      "rationale": "All boundary conditions and material properties documented in the simulation report with literature or experimental sources. Blood viscosity set to 0.0035 Pa·s at 37°C. Formal input uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of test sample variability is not required. Sample preparation protocol must be documented.",
      "rationale": "FDA benchmark dataset uses standardized blood analog preparation protocol (ASTM F1841). Sample characterization sufficient for MRL 2. Statistical sample-to-sample variability analysis not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency mapping between simulation inputs and experimental conditions is not required beyond documented nominal value matching.",
      "rationale": "Nominal boundary conditions in the simulation match experimental conditions as documented in the test report. Reynolds number similarity confirmed for all operating points. Formal equivalency uncertainty analysis not required at MRL 2."
    }
  ],
