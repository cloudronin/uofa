      "name": "Hemolysis index validation against FDA pump experimental data at CPB operating conditions"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr-02",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation at 2500 RPM and 5 L/min flow rate"
    }
  ],
