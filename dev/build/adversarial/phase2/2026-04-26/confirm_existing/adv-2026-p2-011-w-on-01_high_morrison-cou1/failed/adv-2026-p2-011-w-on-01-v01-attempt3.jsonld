  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent documented QA process covering version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under an FDA-recognized ISO 9001:2015 QMS. Version-controlled solver releases with automated regression suites confirm software quality at the required gradation for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via manufactured solution or benchmark problem demonstrating expected spatial and temporal convergence rates.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver confirms second-order spatial accuracy (L2 error norm slopes: 1.97 for velocity, 1.94 for pressure) on structured and unstructured hex-dominant meshes representative of the pump geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for the primary QoI (normalized index of hemolysis) across at least three systematically refined mesh levels.",
      "rationale": "Three-level Richardson extrapolation on meshes of 4.1 M, 10.8 M, and 28.6 M cells yields GCI of 2.3% for NIH and 3.1% for blade-passage shear stress, exceeding the required gradation. Achieved level raised to 3 due to asymptotic range confirmation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, rotational speed) match simulation inputs within stated measurement uncertainty bands.",
      "rationale": "FDA pump bench conditions (2500 RPM, 5 L/min, 100 mmHg head) reproduced in CFD with inlet velocity profile from PIV and outlet static pressure from transducer data. Uncertainty in flow rate ±1.5% propagated into sensitivity study confirming negligible effect on NIH."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH within 20% of measured bench NIH; velocity magnitude fields within two standard deviations of PIV ensemble across monitored planes.",
      "rationale": "Predicted NIH = 0.0041 g/100 L versus measured 0.0038 g/100 L (8% deviation). Velocity magnitude agreement within 1.4 standard deviations of PIV ensemble on three axial planes. Both criteria satisfied at required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, peak shear stress, exposure time) directly map to the clinical decision metric for CPB device clearance per FDA guidance.",
      "rationale": "NIH and blade-passage shear stress are the QoIs mandated by FDA's 2017 Computational Fluid Dynamics guidance for blood-contacting devices. Lagrangian particle tracking provides hemolysis exposure time distribution directly supporting worst-case operating point identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device geometry under overlapping operating conditions (flow rate, RPM, fluid viscosity) as the intended COU envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump — identical geometry to the submission device — at three operating points bracketing the CPB duty envelope (2000–3000 RPM, 3–7 L/min). Bovine blood analog (glycerin-water, matched viscosity) used per ASTM F1841."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "At MRL 2, explicit solver-error quantification beyond standard residual monitoring is not required. Residuals confirmed below 1e-6 and mass imbalance below 0.005% for all reported solutions; formal uncertainty attribution not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with analyst qualification records sufficient to demonstrate controlled use.",
      "rationale": "MRL 2 does not mandate formal use-error quantification. Simulation workflow documented in SOP-CFD-007 rev C; analysts hold documented CFD qualification per internal training matrix. Formal error attribution deferred to higher MRL activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence and hemolysis constitutive model selection justified by literature precedent for the flow regime.",
      "rationale": "SST k-ω turbulence model and Giersiepen-Wurzinger hemolysis power-law selected based on published FDA pump simulation precedent. Formal model-form uncertainty quantification not required at MRL 2; model selection rationale recorded in technical report TR-2024-CFD-003."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameter values traceable to measurement data or published material properties with stated sources.",
      "rationale": "Fluid properties (density 1056 kg/m³, dynamic viscosity 0.0035 Pa·s) sourced from ASTM F1841 and confirmed by rheometry. Geometric inputs from CMM-verified CAD. Formal input uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples representative of the device population with documented lot traceability.",
      "rationale": "FDA generic pump test articles fabricated from SLA resin to published dimensional tolerances; three replicate assemblies used across validation runs. Sample representativeness assessment not formally required at MRL 2; lot records retained in DHF."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters and experimental test parameters confirmed equivalent within measurement uncertainty for all primary boundary conditions.",
      "rationale": "Primary boundary conditions (flow rate, RPM, fluid viscosity) confirmed equivalent between simulation and experiment within ±2% across all validation operating points. Formal equivalency metric computation not required at MRL 2; tabular comparison provided in TR-2024-CFD-003 Appendix B."
    }
  ],
