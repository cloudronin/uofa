  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2 Class II CPB device submission. Six factors appropriately scoped out per ASME V&V 40-2018 Table 4 at MRL 2. Discretization error achieved at Gradation 3, providing additional confidence margin. The CFD hemolysis model is deemed credible for identifying worst-case operating conditions within the CPB duty envelope described in the claim and requirement documentation. Decision supported by FDA-recognized validation dataset and traceable simulation workflow.",
