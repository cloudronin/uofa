  "signature": "ed25519:9b2e4f1a7c3d6e0b5f8a2c4d7e1b3f6a9c2e5b8d1f4a7c0e3b6d9f2a5c8e1b4d",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan with version control and regression testing appropriate for MRL 2.",
      "rationale": "ANSYS Fluent 2021 R2 was used under an ISO 9001-compliant QA framework. Version control logs and regression test reports confirm compliance with MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems with known analytical solutions.",
      "rationale": "Code verification performed using Taylor-Couette flow and lid-driven cavity benchmarks. Observed order of convergence matched theoretical second-order accuracy, confirming correct discretisation implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% across the operating range.",
      "rationale": "Richardson extrapolation and GCI analysis performed on three systematically refined meshes (2.1 M, 5.8 M, 14.4 M cells). GCI for hemolysis index was 2.3% at the design point and 3.8% at worst-case flow, both below the 5% threshold. Achieved level exceeds required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty bounds and must span the intended CPB operating envelope.",
      "rationale": "FDA benchmark in-vitro data were collected at five operating points (1500–3500 rpm, 3–7 L/min) covering the CPB envelope. Fluid temperature, hematocrit, and anticoagulant protocol are documented with stated uncertainties."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental values within combined simulation and experimental uncertainty at all validation points.",
      "rationale": "Predicted hemolysis index fell within combined uncertainty bands at 4 of 5 operating points. The single outlier at 1500 rpm was attributed to transitional flow not captured by the SST k-ω model; this operating point is outside the intended CPB worst-case regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, wall shear stress, exposure time) must be directly linked to the clinical harm mechanism for CPB-induced haemolysis.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model directly relates shear stress magnitude and exposure time to red-cell damage, which is the primary harm pathway for CPB devices. QoIs are clinically and mechanistically justified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same FDA generic centrifugal pump geometry and physiologically representative blood analogue under CPB flow conditions.",
      "rationale": "Validation used the FDA-mandated generic pump geometry with a 40% glycerol-water blood analogue at matched Reynolds number. Operating conditions are representative of adult CPB (cardiac output 4–6 L/min), satisfying relevance requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off effects documented for MRL 2.",
      "rationale": "At MRL 2, a formal numerical solver error analysis beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations; no further assessment is mandated at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification and simulation setup review sufficient for MRL 2.",
      "rationale": "MRL 2 does not require a formal use-error analysis. Simulation setup was reviewed by a second qualified engineer; no systematic use errors were identified. Formal assessment scoped out at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of turbulence and hemolysis model selection documented.",
      "rationale": "SST k-ω turbulence model and Giersiepen-Wurzinger hemolysis model were selected based on published literature for centrifugal blood pump CFD. Formal model-form uncertainty quantification not required at MRL 2; selection rationale is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model input parameters identified and nominal values justified for CPB operating conditions.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and pump geometry dimensions sourced from FDA benchmark documentation. Sensitivity to input variation not formally quantified at MRL 2; nominal values are well-established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number and diversity of experimental samples sufficient to characterise measurement variability at MRL 2.",
      "rationale": "FDA benchmark dataset provides triplicate measurements at each operating point. Statistical characterisation of sample variability beyond mean and standard deviation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to experimental conditions used in validation.",
      "rationale": "Boundary conditions (inlet flow rate, rotational speed, outlet pressure) were set to match experimental values directly. Formal equivalency analysis not required at MRL 2; parameter matching is documented in the simulation setup report."
    }
  ],
