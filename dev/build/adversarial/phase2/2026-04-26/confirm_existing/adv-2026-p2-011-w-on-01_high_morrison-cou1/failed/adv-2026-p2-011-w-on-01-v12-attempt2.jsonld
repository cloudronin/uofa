      "name": "Hemolysis index validation against FDA in-vitro benchmark at 2500 rpm, 5 L/min"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-vr-02",
      "type": "ValidationResult",
      "name": "Shear-stress distribution comparison across three operating points spanning CPB flow range"
    }
  ],
