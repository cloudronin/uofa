  "signature": "ed25519:b9e2d4f6a0c1e3f5a7b9d2e4f6c8a0b2d4f6e8a0c2e4f6a8b0d2e4f6c8a0b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for simulation is verified under a documented QA plan consistent with MRL 2 requirements, including version control and regression testing.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an FDA-recognized QA framework. Regression test suite covers all solver modules employed in the hemolysis simulation. Version control and change management records are complete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification demonstrates correct implementation of governing equations through benchmark problems with known analytical solutions at MRL 2 level.",
      "rationale": "Solver benchmarked against Poiseuille flow, lid-driven cavity, and rotating disk analytical solutions. Observed convergence rates consistent with second-order spatial accuracy. No code defects identified relevant to the hemolysis transport equations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study performed with at least three mesh refinement levels; GCI reported for primary QoI (hemolysis index) with GCI < 10% at MRL 2.",
      "rationale": "Three-level Richardson extrapolation performed on meshes of 4.2M, 8.7M, and 17.1M cells. GCI for normalized index of hemolysis = 4.3%, exceeding the MRL 2 threshold. Asymptotic range confirmed (GCI ratio = 1.02)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation are documented with sufficient detail to reproduce boundary conditions in the simulation; measurement uncertainties are reported.",
      "rationale": "FDA GCBP PIV experiments conducted at 2.5 L/min, 3500 RPM with bovine blood analog (glycerol-water). Temperature, viscosity, and density documented. Measurement uncertainty ±3.2% for velocity magnitude reported by NHLBI protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or GUM-based) applied between simulation output and experimental data; agreement within acceptance band defined a priori.",
      "rationale": "Velocity field comparison using E_rel = 6.8% against PIV data across 12 measurement planes. Hemolysis index predicted within 12% of experimental mean across five operating points. Both within pre-defined acceptance bands for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in the simulation (normalized index of hemolysis, shear stress distribution) are directly linked to the clinical decision question of worst-case hemolysis identification.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) as defined in ASTM F1841. Secondary QoI is volume-averaged scalar shear stress. Both are established surrogates for erythrocyte damage in CPB devices and directly support the intended decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the operating envelope relevant to CPB worst-case conditions; geometric and fluid similarity between validation and COU scenarios is demonstrated.",
      "rationale": "Validation performed on the FDA GCBP geometry — the same geometry as the COU device. Operating points span 2–5 L/min and 2500–4000 RPM, encompassing the worst-case region identified by parametric sweep. Fluid properties matched within 5% of clinical blood viscosity range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, numerical solver error beyond discretization is not required to be separately quantified provided GCI is within acceptance band.",
      "rationale": "Per ASME V&V 40 Table 1, separate numerical solver error assessment is not required at MRL 2 when discretization error has been rigorously quantified. GCI criterion satisfied; this factor is scoped to not-assessed per MRL 2 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use error assessment not required at MRL 2 for this device class per project risk matrix.",
      "rationale": "MRL 2 does not mandate formal use error quantification. Simulation was executed by experienced CFD engineers following documented standard operating procedures. Peer review of setup files completed. Formal use error factor deferred consistent with MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equations (RANS k-omega SST turbulence model, power-law hemolysis damage model) are appropriate for the flow regime and justified by literature precedent.",
      "rationale": "RANS k-omega SST selected based on benchmark performance in rotating machinery at Re ~ 10^5. Power-law hemolysis model (Giersiepen-Wurzinger) is the FDA-accepted model for NIH prediction. Model form uncertainty acknowledged and within acceptable range for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis performed for key input parameters (viscosity, hemolysis model coefficients, rotational speed); inputs traceable to documented sources.",
      "rationale": "One-at-a-time sensitivity analysis performed for viscosity (±10%), hemolysis model exponents (literature range), and rotational speed (±50 RPM). NIH sensitivity to viscosity is dominant at 8.1% per 10% change. All inputs traceable to ASTM F1841 and device IFU specifications."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterization not required at MRL 2 for computational-only submissions where fluid properties are specified analytically.",
      "rationale": "Validation used a glycerol-water blood analog with documented rheological properties. Statistical characterization of sample-to-sample variability not required at MRL 2. Fluid property uncertainty captured under Model Inputs factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation and COU input parameters not required at MRL 2 given direct geometric and operational similarity demonstrated under Relevance factors.",
      "rationale": "Geometric identity between validation and COU scenarios established (same FDA GCBP CAD geometry). Operating point equivalency addressed under Relevance of Validation Activities factor. Separate formal equivalency assessment not required at MRL 2 per project scoping decision."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped to not-assessed per ASME V&V 40 Table 1 guidance for MRL 2 Class II devices. Discretization error (GCI 4.3%) and output comparison (E_rel 6.8%) both within acceptance bands. The CFD hemolysis model is judged credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions and is suitable for pre-market submission support.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
