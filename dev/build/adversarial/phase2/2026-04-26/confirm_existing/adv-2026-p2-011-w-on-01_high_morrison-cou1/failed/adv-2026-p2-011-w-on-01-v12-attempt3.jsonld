  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Intended use scope: pre-market submission support for worst-case operating point identification; patient population adults undergoing CPB; device operating envelope 2–6 L/min flow, 2000–4000 RPM.",
  "bindsRequirement": "https://uofa.net/morrison/req/hemolysis-worst-case-identification",
  "bindsClaim": "https://uofa.net/morrison/claim/cfd-hemolysis-cpb-mrl2",
  "bindsModel": "https://uofa.net/morrison/model/fda-gcbp-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-gcbp-piv-benchmark",
    "https://uofa.net/morrison/data/hemolysis-nib-experimental"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/gcbp-velocity-field-comparison",
      "type": "ValidationResult",
      "name": "FDA GCBP PIV velocity field comparison — MRL 2 benchmark"
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index output comparison against NIH experimental data"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042665",
  "wasAttributedTo": "https://uofa.net/morrison/org/fda-cdrh-osel",
