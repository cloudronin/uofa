  "signature": "ed25519:b4e9d3c25f8a016g7d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation is version-controlled, has documented QA procedures, and regression tests pass for hemolysis-relevant solver modules.",
      "rationale": "ANSYS Fluent 2022R2 employed with institutional QA protocol. Version control via Git, regression suite covering turbulence and scalar transport modules executed with zero failures. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical flows (pipe flow, rotating cavity) confirm solver achieves second-order spatial accuracy for momentum and scalar transport equations.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes and power-law hemolysis scalar. Observed order of accuracy 1.92–2.04, consistent with second-order discretisation. Requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI is below 5% on the medium mesh used for production runs.",
      "rationale": "Three-level structured mesh refinement study conducted at design point (5 L/min, 2500 rpm). GCI on hemolysis index: coarse-to-medium 8.1%, medium-to-fine 2.3%. Production runs use medium-fine mesh; GCI 2.3% satisfies the 5% threshold. Achieved level 3 due to systematic Richardson extrapolation documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid viscosity, hematocrit) are documented with measurement uncertainty and match simulation inputs within 3%.",
      "rationale": "FDA pump test conditions sourced from published dataset (Hariharan et al. 2011). Inlet flow rates 2–7 L/min, rotational speeds 2000–3500 rpm. Fluid: bovine blood analog, hematocrit 40±2%. All boundary conditions reproduced in CFD within 1.8% deviation. Uncertainty propagation documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index agrees with experimental measurements within combined experimental and numerical uncertainty bands at all five validation operating points.",
      "rationale": "Hemolysis index predictions at five operating points compared against experimental data. Agreement within combined uncertainty bands (experimental ±15%, numerical ±6%) at 4 of 5 points; fifth point deviates 18% but lies within expanded uncertainty. Validation metric U_val < U_req at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index and wall shear stress distributions are established as the primary QoIs linked to the clinical question of RBC damage under CPB operating conditions.",
      "rationale": "Hemolysis index directly maps to normalised index of haemolysis (NIH) metric used in FDA 510(k) submissions for CPB devices. Wall shear stress identified as mechanistic driver. Clinical relevance confirmed by subject matter expert review and literature (Blackshear model). QoI relevance requirement met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the operating envelope (flow rate, speed, fluid properties) representative of CPB clinical use, including worst-case high-shear conditions.",
      "rationale": "Validation dataset spans 2–7 L/min and 2000–3500 rpm, encompassing the clinical CPB range of 3–6 L/min. High-shear worst-case point (7 L/min, 3500 rpm) explicitly included. Fluid properties match CPB blood analog per ISO 10993-4 guidance. Relevance to COU confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations documented for each simulation run.",
      "rationale": "At MRL 2, explicit round-off and iterative error decomposition beyond residual monitoring is not required. Residuals confirmed below 1e-5 for all runs; no further decomposition performed. Factor scoped to level 1 per MRL 2 requirements table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup checklist completed and reviewed by a second analyst to reduce operator error risk.",
      "rationale": "MRL 2 does not require formal use-error analysis. Internal peer review of simulation setup completed. Formal human-factors analysis of model use deferred; acceptable at current risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification provided for selection of turbulence model (SST k-omega) and hemolysis power-law model form relative to alternatives.",
      "rationale": "Model form selection (SST k-omega, Giersiepen-Wurzinger power law) is documented in the simulation plan with qualitative justification referencing published benchmark studies. Quantitative sensitivity to model form alternatives not performed at MRL 2. Acceptable per ASME V&V 40 Table 3 at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model inputs (blood viscosity, density, hemolysis model coefficients) are identified and nominal values documented with sources.",
      "rationale": "Nominal input values for viscosity (0.0035 Pa·s), density (1060 kg/m³), and Giersiepen model coefficients documented with literature sources. Formal uncertainty quantification of inputs not required at MRL 2; deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental test samples (blood analog batches) are characterised for relevant properties and batch variability is reported.",
      "rationale": "FDA pump experimental dataset reports fluid characterisation for bovine blood analog. Batch-to-batch variability data not available in the published dataset. At MRL 2, this level of characterisation is acceptable; no additional sample testing required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between experimental test conditions and simulation input parameters is documented, confirming equivalency within stated tolerances.",
      "rationale": "Parameter mapping table provided in simulation plan, confirming experimental boundary conditions translated to CFD inputs with less than 2% deviation. Formal equivalency testing beyond this mapping not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with ASME V&V 40 Table 3 allowances at MRL 2 for a Class II device. The CFD model is accepted as credible for identifying worst-case hemolysis operating conditions of the FDA generic centrifugal blood pump under CPB conditions. The assessment scope and intended use are described in the bound requirement (https://uofa.net/morrison/req/cpb-hemolysis-mrl2) and claim (https://uofa.net/morrison/claim/cpb-hemolysis-worst-case).",
