      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data across five operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation via PIV measurements at design and off-design flow rates"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034823",
