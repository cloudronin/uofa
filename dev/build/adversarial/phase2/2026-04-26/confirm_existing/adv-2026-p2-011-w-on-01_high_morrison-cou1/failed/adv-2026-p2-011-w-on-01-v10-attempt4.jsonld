  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level must meet or exceed MRL 2 requirements per ASME V&V 40 Table 1.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R1) is a commercially validated code with documented SQA procedures including version control, regression testing, and release validation. SQA documentation reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification evidence must demonstrate correct implementation of governing equations at MRL 2 level.",
      "rationale": "Order-of-accuracy testing performed on canonical rotating-frame benchmark cases (Taylor-Couette flow, lid-driven cavity). Observed convergence rates consistent with second-order spatial accuracy. No coding errors detected."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% at MRL 2.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 11.7M, 28.4M cells). GCI for scalar hemolysis index at design point: 2.8%. Richardson extrapolation confirms asymptotic convergence. Exceeds MRL 2 requirement; effectively meets MRL 3 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to support comparison at MRL 2.",
      "rationale": "FDA experimental dataset documents flow rate (2–8 L/min), rotational speed (2000–3500 RPM), blood analog fluid properties, and temperature. Measurement uncertainty reported for all primary variables. Conditions are traceable and reproducible."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error) must fall within acceptance band defined for MRL 2.",
      "rationale": "Normalized index of agreement for hemolysis index across 5 operating points: 0.91. Mean absolute percentage error: 7.3%, within the 10% acceptance band for MRL 2. Systematic over-prediction at high shear rates noted and within expected model-form uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the clinical decision (worst-case hemolysis identification) at MRL 2.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH), directly linked to the regulatory acceptance criterion for CPB devices. Secondary QoI (volume-averaged shear stress) is mechanistically linked to NIH via the power-law hemolysis model. Both QoIs are clinically and regulatorily relevant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must reflect the intended operating envelope and device geometry at MRL 2.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump — the same geometry as the device of interest. Operating conditions span the CPB clinical envelope (2–8 L/min, 2000–3500 RPM). Fluid is bovine blood analog matching clinical viscosity range. Validation activities are directly applicable to the COU operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, numerical solver error beyond discretization is not required to be separately quantified if iterative convergence is demonstrated.",
      "rationale": "Iterative convergence to residuals below 1e-6 for all equations demonstrated at each operating point. Separate solver error quantification not required at MRL 2; scoped out per ASME V&V 40 Table 1 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use error assessment not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is not required at MRL 2 per ASME V&V 40 Table 1. Simulation workflow is executed by trained CFD engineers with documented procedures. Formal use error analysis scoped out at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification not required at MRL 2.",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger) is the accepted regulatory standard for CFD hemolysis prediction in CPB devices. Model form uncertainty is acknowledged but formal UQ not required at MRL 2. Scoped out per ASME V&V 40 Table 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal input uncertainty propagation not required at MRL 2.",
      "rationale": "Nominal input values (viscosity, density, hemolysis model coefficients) are taken from published literature with documented uncertainty ranges. Formal sensitivity analysis and input UQ not required at MRL 2. Scoped out per ASME V&V 40 Table 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability not required at MRL 2.",
      "rationale": "FDA experimental dataset uses a single device specimen. Inter-specimen variability not characterized. At MRL 2, single-specimen validation is acceptable. Scoped out per ASME V&V 40 Table 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency demonstration between simulation inputs and experimental conditions not required at MRL 2.",
      "rationale": "Simulation boundary conditions set to match nominal experimental values. Formal equivalency analysis (e.g., parameter matching uncertainty) not required at MRL 2. Scoped out per ASME V&V 40 Table 1."
    }
