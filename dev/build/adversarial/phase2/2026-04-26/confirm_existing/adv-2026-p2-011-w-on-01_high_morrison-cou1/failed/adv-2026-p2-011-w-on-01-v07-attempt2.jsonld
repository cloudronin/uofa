      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data at 6 operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-rise curve validation across 2500–3500 RPM range"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034996",
