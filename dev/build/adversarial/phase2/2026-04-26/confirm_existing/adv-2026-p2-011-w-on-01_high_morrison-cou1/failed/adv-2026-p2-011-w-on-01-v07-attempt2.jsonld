  "signature": "ed25519:b7d4f1a9c3e6b2d8f5a1c9e3b6d2f8a4c1e7b3d9f6a2c8e4b1d7f3a9c5e2b8d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under a documented QA plan with version control and regression testing at Gradation 2 or above.",
      "rationale": "ANSYS Fluent 2022 R2 is operated under an ISO 9001-compliant QA plan. Version control, regression test suite, and release notes are archived. Gradation 2 requirements are fully satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark problems must demonstrate expected convergence rates.",
      "rationale": "Order-of-accuracy tests against the Taylor–Green vortex and lid-driven cavity benchmarks confirm second-order spatial convergence for the pressure-velocity coupling scheme used in this study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must quantify discretization error; GCI on QoI must be below 5%.",
      "rationale": "Three-level mesh refinement study (4.2 M, 11.7 M, 28.4 M cells) yields a GCI of 2.1% on scalar stress-weighted hemolysis index, exceeding the Gradation 2 threshold and reaching Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) must be reproduced in simulation within stated uncertainty bands.",
      "rationale": "FDA pump experimental conditions (2.5 L/min, 3500 RPM, 37 °C bovine blood analogue, viscosity 3.5 mPa·s) are replicated in CFD boundary conditions. Deviations are within ±2% of reported experimental values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure rise must agree with experimental measurements within combined experimental and simulation uncertainty at the 95% confidence level.",
      "rationale": "Predicted normalized index of hemolysis (NIH) matches experimental NIH within 8% across all six operating points; pressure-rise predictions agree within 5%. Both are within combined uncertainty bounds at 95% CI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (NIH, pressure rise) must be the same or demonstrably surrogate for the clinical decision QoIs.",
      "rationale": "NIH is the regulatory-accepted metric for blood trauma in CPB devices (FDA guidance 2019). Pressure rise characterises pump hydraulic performance directly relevant to the clinical use scenario."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope defined in the clinical use scenario for the CPB device.",
      "rationale": "Validation experiments span 2.5–5.0 L/min and 2500–3500 RPM, encompassing the worst-case hemolysis operating point identified in the clinical use scenario. Geometric fidelity to the FDA generic pump is confirmed by CMM measurement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit iterative-convergence and round-off error quantification is not required beyond confirming residual targets are met.",
      "rationale": "Residuals converged to 1×10⁻⁵ for all equations. Formal solver-error quantification beyond residual monitoring is scoped out at MRL 2 per ASME V&V 40 Table 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a documented analyst training record is sufficient; formal use-error FMEA is not required.",
      "rationale": "Lead analyst holds CFD certification and completed solver-specific training. Formal use-error analysis is not required at MRL 2 and is therefore not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, selection of turbulence and hemolysis sub-models must be documented with literature justification; sensitivity analysis is not required.",
      "rationale": "SST k-ω turbulence model and Giersiepen–Wurzinger power-law hemolysis model are selected based on published comparative studies. Formal model-form uncertainty quantification is deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with literature sources are sufficient; probabilistic input uncertainty propagation is not required.",
      "rationale": "Fluid properties and boundary conditions are taken from published FDA pump test protocol. Probabilistic sensitivity analysis of input parameters is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, use of the FDA reference pump geometry with documented provenance is acceptable; inter-sample variability analysis is not required.",
      "rationale": "A single FDA generic centrifugal pump geometry is used, consistent with MRL 2 scope. Statistical characterisation of manufacturing variability across pump samples is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative mapping of validation experiment inputs to clinical use inputs is sufficient.",
      "rationale": "A qualitative equivalency table mapping experimental inputs (bovine blood analogue, in-vitro rig) to clinical inputs (human blood, in-vivo CPB circuit) is provided in the supporting technical report. Quantitative equivalency scoring is not required at MRL 2."
    }
  ],
