  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/dr-patricia-osei",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. The six not-assessed factors are appropriately scoped out per ASME V&V 40 Table 5 at Model Risk Level 2. Validation evidence demonstrates that the CFD model can reliably identify worst-case hemolysis operating conditions for the Class II CPB device within the operating envelope described in the bound requirement (https://uofa.net/morrison/req/cpb-hemolysis-mrl2). The credibility assessment team accepts the model for the intended regulatory submission purpose.",
