      "acceptanceCriteria": "Solver must be under version-controlled release with regression test suite covering turbulent pipe-flow and rotating-frame benchmarks.",
      "rationale": "ANSYS Fluent 2022 R2 used under institutional license with documented QA plan; regression suite of 47 benchmarks executed and archived. Required gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent order-of-accuracy test demonstrating at least second-order spatial convergence for the momentum equations.",
      "rationale": "Order-of-accuracy study on a rotating annular benchmark confirmed 1.97-order convergence in L2 velocity norm. Gradation 2 requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI below 5% on the primary QoI (NIH) at the nominal operating point.",
      "rationale": "Three-level mesh refinement study (4.2 M, 11.6 M, 28.9 M cells) yielded GCI of 2.8% on NIH, exceeding the gradation 2 threshold and reaching gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) documented with measurement uncertainty and traceable to NIST standards.",
      "rationale": "FDA bench test protocol documented inlet flow ±0.05 L/min, speed ±5 RPM, temperature ±0.3 °C, all traceable to NIST. Gradation 2 met."
    },
