      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size and lot traceability documented for hemolysis assay.",
      "rationale": "FDA bench dataset used; sample provenance documented in FDA interlaboratory study report. Formal statistical power analysis not required at MRL 2 gradation 1."
    },
