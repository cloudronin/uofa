      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., validation comparison error E) computed for primary QoI with uncertainty bounds reported for both simulation and experiment.",
      "rationale": "Validation comparison error for NIH: E = 8.3% with combined simulation uncertainty U_num = 3.1% and experimental uncertainty U_exp = 6.4%. Within acceptable range for MRL 2. Gradation 2 achieved."
