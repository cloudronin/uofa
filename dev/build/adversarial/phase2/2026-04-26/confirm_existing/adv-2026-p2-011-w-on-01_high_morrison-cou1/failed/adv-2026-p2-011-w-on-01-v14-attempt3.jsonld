  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented verification test suite with version-controlled release notes and issue tracking.",
      "rationale": "ANSYS Fluent 2022 R2 used under a validated QMS. Release notes, regression test suite (ISO 9001-compliant), and change-control records reviewed. All SQA requirements at Gradation 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation via method-of-manufactured-solutions or equivalent benchmark for the governing equations used.",
      "rationale": "ANSYS Fluent pressure-based coupled solver verified against the FDA nozzle benchmark (ASME V&V 20) and internal MMS tests for incompressible Navier-Stokes. Second-order spatial accuracy confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be less than 5 % on the fine mesh.",
      "rationale": "Three-level mesh refinement study performed (4.2 M, 9.8 M, 21.4 M cells). GCI for normalised hemolysis index on fine mesh: 3.1 %. Richardson extrapolation confirms asymptotic convergence. Fine mesh adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) must be reproduced in simulation within ±5 % of measured values.",
      "rationale": "PIV and hemolysis bench tests conducted at FDA laboratory. Flow rates (2–7 L/min) and speeds (1500–3500 RPM) replicated in CFD within 2.3 % mean deviation. Fluid: glycerol-water analogue matched to blood viscosity at 37 °C."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised RMS velocity error vs PIV < 10 %; NIH prediction within 15 % of bench measurement across all operating points.",
      "rationale": "Velocity field NRMSE 4.2 % (PIV comparison, 2500 RPM 5 L/min). NIH mean absolute error 8.7 % across five operating points. Both metrics satisfy acceptance thresholds. Worst-case operating point correctly ranked by model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, peak shear stress, exposure time) must be directly linked to the hemolysis decision metric specified in the device submission requirement.",
      "rationale": "Primary QoI is the power-law hemolysis index (Giersiepen model), which maps directly to the ISO 10993-4 biocompatibility endpoint. Secondary QoIs (peak shear stress, residence time) corroborate worst-case identification. Linkage to submission requirement REQ-HEM-001 documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid analogue, and operating envelope as the COU.",
      "rationale": "FDA GCBP geometry used in both simulation and experiment. Glycerol-water analogue (3.5 cP) used in bench tests matches CFD fluid model. Operating envelope (1500–3500 RPM, 2–7 L/min) spans the CPB clinical range. Validation activities judged fully relevant to COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals documented; not required to be characterised beyond Gradation 1 at MRL 2.",
      "rationale": "At MRL 2, explicit characterisation of numerical solver error beyond confirming residual convergence is not required. Residuals reduced to 1e-6 for all equations. Factor scoped to Gradation 1 per ASME V&V 40 Table 1 guidance for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst training records available; formal use-error analysis not required at MRL 2.",
      "rationale": "Simulation performed by engineers with documented CFD training and internal peer review. Formal use-error FMEA not required at MRL 2 for this factor. Gradation 1 accepted per project risk register."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form (turbulence model, hemolysis constitutive law) selection documented with literature justification; sensitivity analysis not required at MRL 2.",
      "rationale": "SST k-ω turbulence model selected based on published FDA GCBP benchmark literature. Giersiepen power-law hemolysis model selected per industry convention. Formal model-form uncertainty quantification not required at MRL 2; documentation of selection rationale sufficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters (viscosity, density, boundary conditions) sourced from traceable references; parametric sensitivity not required at MRL 2.",
      "rationale": "Fluid properties sourced from ASTM and ISO standards. Boundary conditions from FDA experimental protocol. Traceability matrix maintained. Parametric sensitivity analysis deferred per MRL 2 scoping decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample description (fluid, pump unit) documented; statistical characterisation of sample variability not required at MRL 2.",
      "rationale": "Single FDA GCBP unit used for all experimental measurements. Fluid analogue prepared per documented protocol. Sample variability characterisation not required at MRL 2; single-unit validation accepted per project risk register."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation inputs and experimental conditions documented; formal equivalency metric not required at MRL 2.",
      "rationale": "Simulation boundary conditions derived directly from experimental measurement logs. Correspondence table provided in technical report Appendix B. Formal equivalency index calculation not required at MRL 2."
    }
  ],
