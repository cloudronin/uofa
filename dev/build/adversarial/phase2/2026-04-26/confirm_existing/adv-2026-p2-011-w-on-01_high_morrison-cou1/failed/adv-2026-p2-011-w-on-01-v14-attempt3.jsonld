  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required Gradation 2 levels for MRL 2. Six factors appropriately scoped to Gradation 1 and not assessed per ASME V&V 40 Table 1 guidance. Validation evidence (PIV velocity NRMSE 4.2 %, NIH MAE 8.7 %) demonstrates sufficient model credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device pre-market submission. Decision: Accepted for the stated use — CFD-based worst-case hemolysis operating-point identification in the CPB flow envelope.",
