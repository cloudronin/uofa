  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 not-assessed factors are appropriately scoped per ASME V&V 40-2018 MRL 2 guidance. CFD model of the FDA generic centrifugal blood pump is deemed credible for identifying worst-case hemolysis operating conditions in support of Class II CPB device regulatory submission. Hemolysis index predictions fall within experimental uncertainty at the validation point, and discretization error is well below acceptance threshold.",
