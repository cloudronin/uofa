  "signature": "ed25519:b1d4e7a2c5f0938b6e1d4a7c2f5b8e0d3a6c9f2b5e8d1a4c7f0b3e6a9d2c5f8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan consistent with MRL 2 requirements, including version control and regression testing.",
      "rationale": "ANSYS Fluent 2022 R2 was employed under a formal SQA plan. Version control, unit regression tests, and release notes documenting bug fixes were reviewed. All MRL 2 SQA requirements satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via at least one manufactured solution or benchmark problem relevant to rotating machinery flows.",
      "rationale": "Code verification performed using the method of manufactured solutions for incompressible Navier-Stokes in a rotating reference frame. Second-order spatial convergence confirmed. Benchmark against lid-driven cavity and Taylor-Couette flow also passed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% using at least three systematically refined meshes.",
      "rationale": "Three meshes (3.2 M, 7.8 M, and 18.1 M hexahedral cells) were evaluated. Richardson extrapolation yielded GCI of 2.1% for the normalized index of hemolysis, exceeding the MRL 2 threshold. Achieved level elevated to 3 due to documented asymptotic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty bounds and must overlap the intended CPB operating envelope (1500–3500 RPM, 3–7 L/min).",
      "rationale": "FDA bench experiments conducted at 2500 RPM and 5 L/min with bovine blood at 37°C. Flow rate uncertainty ±0.05 L/min, rotational speed ±5 RPM. Conditions fall within the CPB operating envelope defined in the bound requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis must agree with experimental measurements within combined simulation and experimental uncertainty at the validation operating point.",
      "rationale": "Predicted NIH of 0.0023 g/100 L compared to measured 0.0021 ± 0.0003 g/100 L. Agreement within combined uncertainty band. Validation metric using area validation metric confirms acceptable agreement at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (NIH, shear stress distribution) must be directly relevant to the clinical question of worst-case hemolysis identification for CPB.",
      "rationale": "Normalized index of hemolysis and volume-averaged scalar shear stress are the primary clinical indicators for hemolysis risk in CPB devices. Both QoIs are directly linked to the decision question stated in the bound claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the same device geometry and fluid type as the intended COU, or differences must be justified with supporting evidence.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry using bovine blood, which is the accepted surrogate for human blood in hemolysis studies. Geometry is identical to the simulation model. Fluid property differences documented and shown to have less than 3% impact on NIH."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations is sufficient at MRL 2; formal solver error quantification not required.",
      "rationale": "At MRL 2, explicit numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-6 for continuity and momentum. Factor scoped to not-assessed per MRL 2 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error analysis not required at MRL 2; analyst training documentation is sufficient.",
      "rationale": "MRL 2 does not mandate formal use error quantification. Lead analyst holds documented CFD training certification and has five years of cardiovascular device simulation experience. Factor recorded as not-assessed per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for turbulence closure and hemolysis power-law model must be acknowledged; formal quantification not required at MRL 2.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark performance for internal rotating flows. Giersiepen-Wurzinger hemolysis power-law coefficients from literature. Model form uncertainty acknowledged qualitatively; formal UQ not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model inputs (viscosity, density, boundary conditions) must be documented with sources; sensitivity analysis not required at MRL 2.",
      "rationale": "Blood viscosity 0.0035 Pa·s, density 1060 kg/m³, inlet flow rate and rotational speed set to experimental values. All inputs sourced from FDA protocol documentation. Sensitivity analysis deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample characterization documentation from the originating FDA study is sufficient; independent sample variability study not required at MRL 2.",
      "rationale": "Bovine blood samples characterized per ASTM F1841 in the originating FDA experimental study. Hematocrit 33±2%. Independent sample variability assessment not required at MRL 2; existing documentation deemed sufficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency of simulation input parameters to experimental conditions must be qualitatively confirmed; formal parameter matching study not required at MRL 2.",
      "rationale": "Simulation boundary conditions set directly from experimental protocol values. Rotational speed, flow rate, and fluid properties match within instrument uncertainty. Formal equivalency mapping study not required at MRL 2; qualitative confirmation documented."
    }
  ],
