      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA bench test data at 2500 RPM and 5 L/min"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements in FDA generic pump geometry"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034108",
