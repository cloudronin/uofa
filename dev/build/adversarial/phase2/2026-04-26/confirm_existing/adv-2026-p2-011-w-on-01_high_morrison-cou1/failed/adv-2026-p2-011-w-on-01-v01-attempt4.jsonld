  "signature": "ed25519:b7d3e92f14a0c58d76b4e1f3a92c0d7e84f1b6a3c5d8e2f0a7b4c9d1e6f3a8b2c5d7e0f1a4b6c8d9e2f3a5b7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent SQA documentation covering version control, regression testing, and release validation for CFD software used in hemolysis prediction.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under a documented SQA plan including version-controlled input decks, automated regression suite covering rotating-zone and scalar-transport solvers, and third-party audit records. SQA level 2 requirements are fully satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via at least one analytic or manufactured-solution test relevant to rotating-frame turbulent flow.",
      "rationale": "Fluent's rotating-reference-frame RANS implementation verified against the Taylor–Couette analytic solution and an MMS benchmark for the species-transport hemolysis scalar. Residual norms and convergence rates are consistent with second-order spatial accuracy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the primary QoI (NIH) must be below 5% on the production mesh.",
      "rationale": "Three-level mesh refinement study (4.2 M, 9.8 M, 21.6 M cells) yields GCI of 2.1% for NIH at the nominal CPB operating point (3500 RPM, 5 L/min). Richardson extrapolation confirms monotonic convergence. Production mesh is 9.8 M cells, balancing accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used for validation must be documented with uncertainty quantification and must span the CPB operating envelope relevant to the intended use.",
      "rationale": "FDA GCBP experimental campaign (Hariharan et al. 2011) documents inlet velocity profiles, fluid temperature, hematocrit, and rotational speed with stated uncertainties. Operating points cover 2500–3500 RPM and 2.5–7 L/min, encompassing the Class II CPB envelope defined in the intended use description."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric of ASME V&V 20) must show model prediction within combined experimental and numerical uncertainty bands for NIH across at least 6 operating points.",
      "rationale": "Area validation metric computed per ASME V&V 20-2009. NIH predictions fall within combined uncertainty bands at 8 of 9 operating points. The single outlier at 2500 RPM / 2.5 L/min is outside the primary CPB operating range and is documented as a known boundary condition extrapolation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (NIH, velocity field, pressure rise) must be directly linked to the decision QoI (worst-case hemolysis operating condition identification).",
      "rationale": "NIH is the primary regulatory metric for blood pump hemolysis per FDA guidance. Velocity field and pressure rise serve as intermediate QoIs confirming flow-field fidelity. All three QoIs are directly relevant to identifying worst-case hemolysis conditions across the CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (FDA GCBP) and physiologically representative blood analog fluid under CPB-range operating conditions.",
      "rationale": "Validation uses the FDA GCBP geometry identical to the computational model. Fluid is a glycerin-water blood analog with viscosity matched to whole blood at 37°C. Operating conditions span the CPB envelope. Geometric and fluid similarity are established; the validation scenario is representative of the intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal iterative convergence error quantification beyond residual monitoring is not required.",
      "rationale": "Solver residuals are monitored to 1e-5 for all equations. Formal iterative error estimation via Richardson extrapolation in pseudo-time is not required at MRL 2 and has not been performed. Residual behavior indicates adequate iterative convergence for the QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use-error analysis is not required provided standard operating procedures are documented.",
      "rationale": "Simulation execution follows documented SOPs for boundary condition specification, turbulence model selection, and post-processing. Formal use-error analysis is not required at MRL 2 and has not been conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal model-form uncertainty quantification is not required; model form selection must be documented and justified.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark performance for rotating turbomachinery flows. Giersiepen-Wurzinger power-law hemolysis model applied as the industry-standard scalar transport approach. Model form choices are documented; formal model-form UQ is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal sensitivity analysis of model inputs is not required; nominal input values must be documented.",
      "rationale": "All model inputs (fluid density, viscosity, hemolysis model constants, rotational speed, flow rate) are documented with nominal values and sources. Formal sensitivity or uncertainty propagation analysis is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of test sample variability is not required; sample preparation protocol must be documented.",
      "rationale": "FDA GCBP experimental data uses a single pump specimen with documented fabrication tolerances. Blood analog fluid preparation protocol is documented. Statistical characterization of inter-sample variability is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency mapping between validation and deployment scenarios is not required; qualitative similarity must be documented.",
      "rationale": "Qualitative equivalency between validation (blood analog, in-vitro GCBP) and deployment (clinical CPB, same GCBP geometry) is documented. Fluid rheology differences are acknowledged. Formal equivalency quantification is not required at MRL 2."
    }
  ],
