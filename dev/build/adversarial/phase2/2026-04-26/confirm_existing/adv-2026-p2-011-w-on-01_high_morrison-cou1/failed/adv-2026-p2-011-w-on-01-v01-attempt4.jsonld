  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/dr-sarah-morrison",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors are appropriately scoped out at MRL 2 with documented justification. The CFD hemolysis model is credible for identifying worst-case hemolysis operating conditions for the Class II centrifugal blood pump under CPB conditions as described in the assessment scope. The package supports pre-market submission to FDA.",
