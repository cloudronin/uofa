    {
      "id": "https://uofa.net/morrison/validation/hemolysis-piv-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison against CFD predictions at 5 L/min operating point"
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-bench",
      "type": "ValidationResult",
      "name": "Normalized index of hemolysis bench comparison across 4 flow conditions"
    }
  ],
