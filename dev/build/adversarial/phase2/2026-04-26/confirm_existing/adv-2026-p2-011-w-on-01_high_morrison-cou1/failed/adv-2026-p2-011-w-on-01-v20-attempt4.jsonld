  "signature": "ed25519:9b1d3f5a7c2e4b6d8f0a1c3e5b7d9f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented; version control and regression testing in place for CFD solver used in hemolysis simulation.",
      "rationale": "ANSYS Fluent 2022R2 used under an FDA-validated SQA framework. Version-controlled input decks and automated regression suite confirm solver integrity at MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical rotating-disk flow confirms second-order spatial convergence.",
      "rationale": "Richardson extrapolation on three systematically refined grids of the FDA GCBP geometry yields observed order of 1.97, consistent with nominal second-order scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on the production mesh.",
      "rationale": "GCI computed per Celik et al. (2008) protocol on three meshes (4.2 M, 8.7 M, 17.1 M cells). GCI for normalized index of hemolysis is 2.8%, satisfying the acceptance criterion. Achieves Gradation 3 due to systematic three-level study with formal uncertainty quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, hematocrit) match simulation inputs within stated measurement uncertainty.",
      "rationale": "Bench test operated at 5 L/min, 100 mmHg differential, 37 °C, 33% hematocrit bovine blood. CFD inlet/outlet BCs set to measured values; fluid properties matched. Measurement uncertainty characterised and reported."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH within 20% of experimental mean across all four validation flow conditions.",
      "rationale": "CFD-predicted normalized index of hemolysis falls within 14% of experimental mean at all four operating points (3, 4, 5, 6 L/min). Validation metric satisfies acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear-stress exposure histograms) are the same quantities used for the CPB design decision.",
      "rationale": "The decision QoI is normalized index of hemolysis under worst-case operating conditions. Validation experiments measure NIH directly. No surrogate QoI substitution is required, confirming direct relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating regime are representative of the CPB device COU as documented in the intended-use statement.",
      "rationale": "FDA GCBP geometry and bovine blood at CPB-range flows constitute an accepted surrogate for clinical CPB conditions per FDA guidance. Validation activities directly support the intended screening use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver is commercial and subject to vendor verification.",
      "rationale": "At MRL 2, independent assessment of iterative solver error beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations; no further action needed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation performed by trained analysts following documented SOPs.",
      "rationale": "Analyst training records and SOP compliance documented in SQA plan. Formal use-error analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; SST k-omega turbulence model selected based on literature consensus for internal blood-pump flows.",
      "rationale": "Model-form uncertainty analysis (e.g., ensemble of turbulence models) is not required at MRL 2. SST k-omega selection justified by published benchmark studies on similar rotodynamic devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
