      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values used with sensitivity noted qualitatively.",
      "rationale": "Formal uncertainty propagation of input parameters (viscosity, density, hemolysis power-law coefficients) not required at MRL 2. Qualitative sensitivity to Giersiepen vs. Zhang hemolysis model noted in discussion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; single blood batch used per standard FDA GCBP protocol.",
      "rationale": "Inter-batch variability of bovine blood not characterised. At MRL 2 this is acceptable; single-batch NIH measurement follows the FDA standardised GCBP test protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; bovine blood accepted as surrogate for human blood per FDA guidance.",
      "rationale": "FDA guidance explicitly accepts bovine blood as equivalent surrogate for hemolysis bench testing. Formal equivalency analysis not required at MRL 2."
    }
