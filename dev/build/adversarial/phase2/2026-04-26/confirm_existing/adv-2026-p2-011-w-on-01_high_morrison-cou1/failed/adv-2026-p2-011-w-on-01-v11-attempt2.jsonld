  "signature": "ed25519:b7d3e1f9a2c4b8d5e3f1a9c2b4d8e5f3a1c9b2d4e8f5a3c1b9d2e4f8a5c3b1d9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated under a documented QA plan with version control and regression testing appropriate for MRL 2.",
      "rationale": "ANSYS Fluent 2023 R1 is used under an ISO 9001-compliant QA framework. Version control, regression test suite, and release notes are documented. SQA level 2 requirements are fully satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct numerical implementation of governing equations at MRL 2 through method of manufactured solutions or equivalent benchmark.",
      "rationale": "Code verification was performed using the method of manufactured solutions for the incompressible Navier-Stokes equations. Observed order of accuracy matches theoretical order, confirming correct implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified and shown to be within acceptable bounds for hemolysis index prediction at MRL 2.",
      "rationale": "Three-level mesh refinement study conducted (coarse: 4.2M, medium: 11.8M, fine: 31.4M cells). Richardson extrapolation yields GCI < 3.2% for hemolysis index on the medium mesh, which is adopted for production runs. Achieves level 3 due to rigorous GCI quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and shown to be representative of the CPB operating envelope relevant to hemolysis risk assessment.",
      "rationale": "FDA benchmark experimental data collected at flow rates 2–8 L/min and rotational speeds 2000–4000 RPM, spanning the CPB operating envelope. Fluid temperature, hematocrit, and inlet conditions are documented and match simulation boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared quantitatively to experimental measurements using appropriate metrics, with agreement within defined tolerances.",
      "rationale": "Normalized index of hemolysis (NIH) predictions compared to FDA benchmark experimental values. Mean absolute percentage error of 18.4% across 12 operating points, within the accepted tolerance for MRL 2 hemolysis screening. Pressure rise agreement within 5.1%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest predicted by the model must be directly relevant to the hemolysis risk decision for the CPB device.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH), which is the regulatory-accepted metric for blood damage in CPB devices. Secondary QoI includes scalar stress exposure (SSE) along pathlines. Both are directly relevant to identifying worst-case operating conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be sufficiently representative of the intended CPB use conditions to support the credibility claim at MRL 2.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry under CPB-representative conditions. The generic pump geometry is an FDA-recognized benchmark, providing high relevance to Class II CPB device assessment. Validation scope covers the operating envelope of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Numerical solver error beyond discretization (e.g., iterative convergence, round-off) need not be formally quantified at MRL 2 provided standard convergence criteria are met.",
      "rationale": "At MRL 2, formal quantification of numerical solver error separate from discretization error is not required. Residuals converged to 1e-5 for all equations; this is documented in the simulation log and is acceptable for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error analysis is not required at MRL 2 for this screening application.",
      "rationale": "MRL 2 does not mandate formal use error assessment. Simulations were performed by trained CFD engineers following documented standard operating procedures. Peer review of simulation setup was conducted internally."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification is not required at MRL 2; model form selection must be documented and justified.",
      "rationale": "The power-law hemolysis damage model (Giersiepen-Wurzinger correlation) is adopted as the standard model for CFD hemolysis prediction in CPB applications, consistent with FDA guidance. Formal model form UQ is scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal uncertainty quantification of model inputs is not required at MRL 2; nominal input values must be documented.",
      "rationale": "Fluid properties (density 1056 kg/m³, viscosity 0.0035 Pa·s), boundary conditions, and pump geometry are documented. Sensitivity to input variation is not formally quantified at MRL 2 but is considered acceptable for screening-level assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability is not required at MRL 2 for the FDA benchmark dataset.",
      "rationale": "The FDA benchmark experimental dataset is a publicly available reference dataset. Sample-to-sample variability characterization is not required at MRL 2. Dataset provenance is documented via DOI reference."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis between validation experiment inputs and COU inputs is not required at MRL 2.",
      "rationale": "Validation experiment and simulation share the same FDA generic pump geometry and nominally equivalent boundary conditions. Formal equivalency mapping is scoped out at MRL 2 but qualitative alignment is confirmed by the assessment team."
    }
  ],
