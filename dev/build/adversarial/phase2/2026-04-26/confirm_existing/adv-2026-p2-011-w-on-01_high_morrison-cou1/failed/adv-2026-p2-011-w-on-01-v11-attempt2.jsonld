  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 non-assessed factors are appropriately scoped out per ASME V&V 40-2018 guidance for Model Risk Level 2. The CFD hemolysis prediction model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB applications. The assessment team concludes the model is fit for the intended screening purpose as described in the claim and requirement documentation.",
