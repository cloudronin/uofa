  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This assessment evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Intended use: pre-market regulatory submission supporting design-space exploration for a Class II centrifugal blood pump operating within standard CPB flow and pressure-head ranges.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-worst-case",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-mrl2-credible",
  "bindsModel": "https://uofa.net/morrison/model/fda-generic-cbp-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-cbp-experimental-hemolysis",
    "https://uofa.net/morrison/data/fda-cbp-piv-velocity-fields"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-head-flow-curve",
      "type": "ValidationResult",
      "name": "Pump pressure-head vs. flow curve validation at three operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034996",
