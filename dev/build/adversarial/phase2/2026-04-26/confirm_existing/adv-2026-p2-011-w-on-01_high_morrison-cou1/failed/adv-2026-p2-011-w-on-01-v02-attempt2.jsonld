  "signature": "ed25519:b7e3a1c5f2d4b6e8a0c2e4f6a8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression test suite, and documented release notes must be available and reviewed.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with documented QA procedures, regression testing, and version-controlled release notes. SQA requirements at MRL 2 are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical benchmark cases must demonstrate expected convergence rates for the discretization scheme employed.",
      "rationale": "The solver has been verified against Taylor-Green vortex and lid-driven cavity benchmarks, demonstrating second-order spatial convergence consistent with the finite-volume scheme used in the CPB simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine grid.",
      "rationale": "A three-level mesh refinement study (4.2M, 11.7M, 28.4M cells) yielded a GCI of 2.8% for the normalized index of hemolysis on the fine mesh, exceeding the required threshold and demonstrating adequate discretization control."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be reproduced in simulation within stated measurement uncertainty bands.",
      "rationale": "Inlet flow rates, rotational speed, and fluid viscosity used in the FDA benchmark experiments are reproduced in the CFD setup within the reported ±2% measurement uncertainty. Temperature and hematocrit are matched to nominal CPB conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis predicted by CFD must agree with experimental measurements within combined simulation and experimental uncertainty at each of the three benchmark operating points.",
      "rationale": "Predicted NIH values at 2.5 L/min, 5.0 L/min, and 7.0 L/min operating points agree with FDA benchmark experimental means within one combined standard uncertainty interval at all three conditions, satisfying the output comparison requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (NIH, shear stress distribution) must be directly traceable to the decision QoI (worst-case hemolysis operating point identification).",
      "rationale": "The normalized index of hemolysis and volume-averaged scalar shear stress are the primary metrics for identifying worst-case hemolysis conditions and are directly used in the regulatory decision. QoI relevance is fully established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, working fluid, and operating envelope as the intended CPB deployment context.",
      "rationale": "The FDA generic centrifugal pump geometry is identical to the simulation geometry. Validation experiments used bovine blood at 37°C with hematocrit 33±2%, matching CPB operating conditions. The validation hierarchy is directly relevant to the intended use context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residuals below 1e-5 for all transport equations is sufficient at MRL 2 without additional round-off analysis.",
      "rationale": "At MRL 2, explicit round-off and iterative error decomposition is not required. Residual monitoring confirmed convergence below 1e-6 for all equations. No further assessment needed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, user qualification documentation is sufficient; formal use-error sensitivity study is not required.",
      "rationale": "Simulation analysts hold documented CFD competency certifications and followed a written simulation plan reviewed by an independent engineer. Formal use-error quantification is scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty need not be formally quantified; selection rationale and literature support are sufficient.",
      "rationale": "The SST k-omega turbulence model with power-law hemolysis damage accumulation is the consensus approach in FDA-recognized literature for centrifugal blood pump hemolysis prediction. Formal model-form UQ is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameter ranges must be documented and traceable to manufacturer specifications or published literature; probabilistic propagation not required at MRL 2.",
      "rationale": "Fluid viscosity, density, hemolysis power-law constants, and rotational speed are documented with sources and nominal uncertainty estimates. Full probabilistic input propagation is not required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood sample provenance and preparation protocol must be documented; inter-sample variability analysis not required at MRL 2.",
      "rationale": "FDA benchmark experimental reports document blood sourcing, anticoagulation protocol, and hematocrit measurement. Inter-sample variability decomposition is beyond MRL 2 requirements and is scoped out."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Qualitative mapping between validation experiment inputs and COU inputs is sufficient at MRL 2; formal equivalency metric not required.",
      "rationale": "A qualitative parameter equivalency table was prepared mapping each experimental input to the corresponding simulation input and COU condition. No quantitative equivalency score is required at MRL 2."
    }
  ],
