  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors are appropriately scoped out per MRL 2 guidance. The CFD model of the FDA generic centrifugal blood pump demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for a Class II CPB device in the pre-market regulatory context. The assessment team accepts the model for the stated decision-making purpose.",
