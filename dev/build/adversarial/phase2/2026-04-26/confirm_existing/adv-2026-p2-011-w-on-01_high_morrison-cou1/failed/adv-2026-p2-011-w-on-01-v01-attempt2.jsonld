      "acceptanceCriteria": "Software quality assurance procedures documented and version-controlled; solver validation suite passes for hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022 R2 employed with documented QA procedures, version control, and regression test suite covering rotating machinery flows. All relevant test cases pass within specified tolerances for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification confirms correct implementation of governing equations through manufactured solution or benchmark comparison.",
      "rationale": "ANSYS Fluent code verification against Taylor-Couette and lid-driven cavity benchmarks demonstrates correct implementation of incompressible Navier-Stokes and k-omega SST turbulence model. Residuals consistent with second-order spatial accuracy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for scalar stress index and pressure head QoIs across three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study (4.2M, 11.8M, 31.4M cells) yields GCI of 2.7% for scalar stress index and 1.9% for pressure head at design operating point. Richardson extrapolation confirms asymptotic convergence range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) documented with uncertainty bounds and shown to bracket CPB operating envelope.",
      "rationale": "FDA benchmark experimental conditions span 2500–3500 RPM and 2–8 L/min, encompassing the CPB operating envelope. Fluid properties (bovine blood, viscosity 3.5 cP) documented with measurement uncertainties reported at 95% confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure head agree with experimental measurements within combined simulation and experimental uncertainty.",
      "rationale": "Normalized index of hemolysis predictions fall within 18% of experimental values across all six operating points; pressure head predictions within 4%. Validation metric (E/u_val) less than 1.0 at all conditions, indicating predictions within combined uncertainty bounds. Exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
