  "signature": "ed25519:b4e7f1a2c3d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver (OpenFOAM v8) with documented regression test suite; all relevant unit tests passing prior to simulation campaign.",
      "rationale": "OpenFOAM v8 is an open-source solver with a publicly documented regression test suite. Version control via Git was confirmed. All 47 relevant regression tests passed. SQA level 2 is required and achieved for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent benchmark confirms spatial order of accuracy within 10% of theoretical for relevant flow equations.",
      "rationale": "MMS study on the incompressible Navier-Stokes solver confirmed second-order spatial accuracy (observed order 1.94 ± 0.06). Temporal discretization verified to first order for steady-state SIMPLE algorithm. Meets level 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI < 5% for hemolysis index QoI on a three-mesh refinement study.",
      "rationale": "Three-mesh study (coarse: 2.1M, medium: 5.8M, fine: 14.2M cells) yielded GCI of 3.2% for normalized hemolysis index at the design operating point. GCI < 5% threshold met. Medium mesh selected for production runs balancing accuracy and cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, rotational speed) documented with uncertainty bounds and replicated in simulation within ±3%.",
      "rationale": "FDA benchmark experimental conditions (flow: 5 L/min ± 2%, speed: 3000 RPM ± 1%, outlet pressure: 60 mmHg ± 5%) were reproduced in simulation boundary conditions. Inlet velocity profile derived from measured flow rate assuming fully developed pipe flow — documented deviation from experiment noted and bounded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed for primary QoI with uncertainty propagation from both experiment and simulation.",
      "rationale": "Normalized hemolysis index error E% = 8.7% (< 15% threshold). Validation metric u_val computed per ASME V&V 20 incorporating experimental uncertainty (CV 12%) and numerical uncertainty (GCI 3.2%). Agreement deemed adequate for MRL 2. Velocity field comparison via PIV showed mean absolute error 0.06 m/s against measured 0.8 m/s peak — within acceptable range. Achieved level 3 exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) directly mapped to clinical risk endpoints for CPB hemolysis; traceability matrix documented.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) per ASTM F1841. Secondary QoI is volume-averaged scalar shear stress. Both QoIs are directly linked to erythrocyte damage mechanisms relevant to CPB clinical risk. Traceability to device risk analysis documented in submission dossier section 4.2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on geometrically identical FDA generic pump geometry under overlapping operating conditions; blood analog fluid properties within 10% of in-vivo values.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry — identical to the simulation geometry. Experiments used porcine blood at 37 °C (hematocrit 35 ± 2%), matching COU fluid properties within stated tolerances. Operating conditions span 3–6 L/min and 2000–3500 RPM, fully covering the intended CPB use envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-5 for all field variables documented.",
      "rationale": "At MRL 2, numerical solver error beyond residual monitoring is not required. Residuals for all field variables (U, p, k, omega) converged to < 1e-6. No additional solver error quantification required at this risk level; factor scoped to level 1 by MRL 2 assessment table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; checklist completed.",
      "rationale": "MRL 2 requires only basic setup review. An independent analyst reviewed boundary condition inputs and mesh topology against the simulation plan. No discrepancies identified. Formal use-error quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Governing equations and constitutive models documented and justified for CPB hemolysis application.",
      "rationale": "Incompressible RANS (k-omega SST) selected based on literature consensus for intracardiac pump flows. Newtonian blood assumption justified for high-shear CPB conditions (shear rate > 100 1/s throughout impeller). Giersiepen-Wurzinger power-law hemolysis model documented. Formal model-form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters documented with sources; sensitivity to key parameters (viscosity, hemolysis model coefficients) qualitatively assessed.",
      "rationale": "Input parameters tabulated: blood density 1060 kg/m³, dynamic viscosity 3.5 mPa·s, hemolysis model coefficients from Giersiepen et al. (1990). Qualitative sensitivity noted — hemolysis index varies ~20% with ±15% viscosity perturbation. Formal uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size and biological variability documented.",
      "rationale": "FDA benchmark dataset used n=3 independent experimental runs per operating point. Biological variability (CV < 15% for NIH) documented in source publication. Statistical characterization beyond this not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between experimental measurement inputs and simulation boundary condition inputs documented; any non-equivalencies identified.",
      "rationale": "Inlet boundary condition derived from measured volumetric flow rate assuming fully developed turbulent profile — noted as a non-equivalency relative to actual experimental inlet conditions. Impact assessed as minor given inlet-to-impeller distance (10D). Formal equivalency quantification not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
