    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA experimental benchmark — normalized index error < 15% across all operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "Velocity field PIV comparison — mean absolute error < 0.08 m/s in impeller region at 3000 RPM, 5 L/min"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034823",
