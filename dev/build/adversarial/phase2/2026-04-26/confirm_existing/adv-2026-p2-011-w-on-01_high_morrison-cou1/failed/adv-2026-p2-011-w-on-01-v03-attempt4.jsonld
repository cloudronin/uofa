    {
      "id": "https://uofa.net/morrison/validation/hemolysis-output-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index output comparison against FDA benchmark experimental data at nominal and worst-case CPB operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/shear-stress-qoi-relevance",
      "type": "ValidationResult",
      "name": "Shear-stress QoI relevance assessment confirming wall and bulk fluid shear metrics are predictive of RBC damage under CPB flow conditions"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043951",
