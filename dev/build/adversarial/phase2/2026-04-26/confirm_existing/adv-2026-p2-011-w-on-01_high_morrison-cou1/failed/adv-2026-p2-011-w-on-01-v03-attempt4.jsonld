  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f8c2e14d7b905f6c1a2e3d4b5f6e7a8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold a documented QA plan including version control, regression testing, and release validation suite consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 is used under an FDA-recognized QMS. Vendor-supplied verification suite covers incompressible Navier-Stokes and species transport; internal regression logs confirm no critical defects in the hemolysis scalar transport module. Achieves Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests for the momentum and scalar transport equations must confirm convergence rates consistent with the solver's stated spatial discretization scheme.",
      "rationale": "Method of manufactured solutions applied to 3-D steady incompressible flow with passive scalar; observed second-order spatial convergence confirmed for both velocity and hemolysis index fields. Temporal discretization verified via Courant-number sweep."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis must demonstrate discretization uncertainty below 5% of the hemolysis index QoI at the worst-case operating point.",
      "rationale": "Three systematically refined meshes (4.2 M, 11.6 M, 28.4 M cells) used; GCI for hemolysis index at 6 L/min / 3500 RPM is 2.8%, below the 5% threshold. Prism layer resolution in high-shear blade passages confirmed adequate. Achieves Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, rotational speed, fluid temperature and viscosity) must be documented with measurement uncertainty and must match CFD boundary condition inputs within stated tolerances.",
      "rationale": "FDA benchmark experiment documented in Morrison et al. (2019); flow rates measured by Coriolis meter (±0.5%), pressures by calibrated transducers (±0.3 mmHg), speed by optical encoder (±1 RPM). All boundary conditions reproduced in CFD within measurement uncertainty bands."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty at a minimum of three operating points spanning the CPB flow envelope.",
      "rationale": "Hemolysis index predictions compared at 4, 5, 6, and 7 L/min operating points; normalized index error ranges from 3.1% to 8.4% with experimental uncertainty accounting for the majority of discrepancy. Systematic over-prediction at low flow noted and bounded within acceptable range for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, volume-averaged shear stress, exposure time) must be linked to the clinical endpoint of RBC damage and must be accepted surrogates per published literature and FDA guidance.",
      "rationale": "Hemolysis index derived from power-law RBC damage model (Giersiepen-Wurzinger) is the accepted regulatory surrogate for RBC trauma in CFD pump assessments per FDA 2017 guidance. Volume-averaged shear stress and Lagrangian exposure time included as supporting QoIs. Linkage to clinical harm pathway documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid analog, and operating envelope as the intended CPB clinical use; deviations must be documented and their impact on predictive confidence assessed.",
      "rationale": "FDA generic centrifugal pump geometry is identical between validation and submission model. Bovine blood analog (glycerol-water, matched viscosity) used in experiment; deviation from human blood rheology assessed via sensitivity study showing less than 4% impact on hemolysis index. Operating range covers full CPB envelope (2–7 L/min, 2500–4500 RPM)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and mass imbalance reported; no formal solver error quantification required at MRL 2 Gradation 1.",
      "rationale": "Residuals converged to 1e-6 for all equations; mass imbalance below 0.01%. Formal iterative error quantification not required at MRL 2 and is scoped out of this assessment per ASME V&V 40 Table 1 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup peer-reviewed by independent analyst; no formal use-error quantification required at MRL 2 Gradation 1.",
      "rationale": "Simulation setup reviewed by a second qualified CFD engineer prior to submission. Formal use-error quantification not required at MRL 2; factor acknowledged and scoped out consistent with Table 1 minimum requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form assumptions (Newtonian fluid, steady-state RANS, power-law damage model) documented and justified; formal model form uncertainty quantification not required at MRL 2 Gradation 1.",
      "rationale": "Newtonian assumption justified by high shear rates (>100 s-1) predominating in the pump. Steady-state k-omega SST RANS selected based on prior FDA benchmark studies. Power-law RBC damage model is the regulatory standard. Model form UQ not required at MRL 2 and is not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model input parameters (viscosity, density, damage model coefficients) documented with sources; formal input uncertainty propagation not required at MRL 2 Gradation 1.",
      "rationale": "Fluid properties taken from experimental measurements; damage model coefficients from Giersiepen et al. (1990) as referenced in FDA guidance. Sensitivity to coefficient variation noted qualitatively. Formal UQ not required at this MRL."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number of experimental replicates and sample variability reported; statistical characterization of inter-run variability not required at MRL 2 Gradation 1.",
      "rationale": "Three experimental replicates performed per operating point; run-to-run variability in hemolysis index below 6%. Formal statistical power analysis not required at MRL 2 and is not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between experimental and simulation input parameters documented; formal equivalency quantification not required at MRL 2 Gradation 1.",
      "rationale": "Boundary condition mapping from experiment to CFD documented in the simulation plan. Differences in inlet velocity profile (uniform CFD vs. measured profile) assessed qualitatively; impact judged negligible at this MRL. Formal equivalency metric not required."
    }
  ],
