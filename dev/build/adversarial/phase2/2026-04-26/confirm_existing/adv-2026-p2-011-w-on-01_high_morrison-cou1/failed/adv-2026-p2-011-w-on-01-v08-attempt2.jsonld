      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold a documented QA plan with version control, regression testing, and traceable release notes consistent with MRL 2 expectations.",
      "rationale": "ANSYS Fluent 2022R2 was used with vendor-supplied QA documentation, regression test suite, and ISO-9001-certified release process. Version traceability confirmed for all simulation runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via published benchmark problems at MRL 2 standard.",
      "rationale": "Code verification confirmed through three ASME benchmark cases (lid-driven cavity, backward-facing step, pipe flow) with observed convergence orders consistent with second-order spatial discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% at the operating point of interest.",
      "rationale": "Three-mesh Richardson extrapolation yielded GCI of 2.8% for the hemolysis index at the worst-case 5500 RPM / 5 L/min operating point, exceeding the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to enable computational replication within stated uncertainty bounds.",
      "rationale": "FDA benchmark experimental protocol documented flow rate (±0.05 L/min), rotational speed (±10 RPM), fluid temperature (±0.5 °C), and blood analogue viscosity (±2%). Boundary conditions applied directly from experimental records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure rise must agree with experimental measurements within combined simulation and experimental uncertainty at MRL 2.",
      "rationale": "Hemolysis index predictions fell within ±15% of experimental values across seven operating points. Pressure-rise predictions agreed within ±8%. Validation metric computed per ASME V&V 20 procedures."
