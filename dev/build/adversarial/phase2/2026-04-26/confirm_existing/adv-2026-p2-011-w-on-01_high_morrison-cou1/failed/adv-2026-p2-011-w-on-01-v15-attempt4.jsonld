  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be documented under a quality management system with version control and regression testing records available.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under an ISO 9001-compliant QMS. Version control records, regression test suite results, and release notes are archived and available for audit. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems with known analytical solutions.",
      "rationale": "Lid-driven cavity and Poiseuille flow benchmarks were executed using the same solver configuration. Results agree with analytical solutions to within 0.3% for velocity profiles, confirming correct numerical implementation at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence must be demonstrated using at least three systematically refined meshes with Richardson extrapolation or GCI reported.",
      "rationale": "Three mesh refinement levels (2.1M, 5.8M, 14.2M cells) were evaluated. GCI for the hemolysis index QoI was 1.8% between the medium and fine meshes, and 0.9% between fine and extrapolated value. Achieved level exceeds required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with measurement uncertainties and must span the intended operating envelope.",
      "rationale": "FDA benchmark experimental data covers flow rates 2–7 L/min and speeds 1500–3500 RPM with documented measurement uncertainties for pressure rise, flow rate, and hemolysis index. Conditions encompass the CPB operating envelope of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation metric U_val) must be computed and compared against acceptance threshold.",
      "rationale": "Normalized RMSE for hemolysis index across 12 operating conditions is 8.4%, within the 15% acceptance threshold established for MRL 2. The validation metric U_val is smaller than the model uncertainty, confirming adequate agreement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly traceable to the clinical or regulatory decision metric.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) computed via the Giersiepen-Wurzinger power-law model integrated along Lagrangian particle tracks. NIH is the regulatory-accepted metric for blood damage assessment per FDA guidance on CPB devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenarios must be sufficiently similar in geometry, flow regime, and boundary conditions to the intended COU to support extrapolation of credibility.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry under the same Reynolds number regime and fluid properties (bovine blood, 37°C, Hct 35%) as the intended CPB application. Geometric and flow similarity is high, supporting direct extrapolation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit iterative convergence and floating-point error quantification beyond standard residual monitoring is not required.",
      "rationale": "Residuals converged to 1e-6 for all equations. Explicit solver error quantification beyond residual monitoring is not required at MRL 2 and has not been performed. Factor scoped to level 1 per MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use-error analysis is not required; standard analyst training and peer review of simulation setup is sufficient.",
      "rationale": "Simulation setup was reviewed by a second qualified CFD analyst. Formal use-error analysis protocol is not required at MRL 2. Factor acknowledged but not formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a qualitative justification of turbulence model selection is sufficient; formal model-form uncertainty quantification is not required.",
      "rationale": "SST k-omega turbulence model was selected based on published literature for similar rotodynamic blood pump geometries. Formal model-form UQ not required at MRL 2. Selection rationale is documented in the simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are sufficient; probabilistic sensitivity analysis is not required.",
      "rationale": "Blood viscosity, density, and hemolysis model coefficients were drawn from published sources with documented nominal values. Input uncertainty propagation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of the number of experimental replicates and basic statistical summary is sufficient.",
      "rationale": "FDA benchmark dataset includes triplicate measurements at each operating point. Basic statistics (mean, standard deviation) are reported. Formal sample-size power analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a qualitative assessment of parameter equivalency between validation and COU scenarios is sufficient.",
      "rationale": "Boundary conditions in the validation scenario (inlet flow rate, outlet pressure, rotational speed) match the COU operating envelope. Qualitative equivalency confirmed by review; formal parameter mapping analysis not required at MRL 2."
    }
