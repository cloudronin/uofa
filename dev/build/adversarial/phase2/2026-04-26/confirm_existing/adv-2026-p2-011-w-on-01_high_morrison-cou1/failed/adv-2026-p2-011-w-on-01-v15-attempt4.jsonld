  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-mrl2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required levels for Model Risk Level 2. The 6 non-assessed factors are appropriately scoped to level 1 per MRL 2 requirements and are not required to be formally evaluated. The CFD hemolysis model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device. The overall evidence package is accepted for use in the 510(k) submission.",
