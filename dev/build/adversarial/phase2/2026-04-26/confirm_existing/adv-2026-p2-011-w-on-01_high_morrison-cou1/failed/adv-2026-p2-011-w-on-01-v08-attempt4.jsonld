  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8091a2b3c4d5e6f70a1b2c3d4e5f6a7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated under a documented SQA plan with version control and regression testing at MRL 2.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a documented SQA plan. Version control, regression test suite, and change management records are on file. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or equivalent benchmark at MRL 2.",
      "rationale": "Numerical code verification performed using the method of manufactured solutions for the incompressible Navier-Stokes equations. Published benchmark results for the FDA nozzle geometry confirm correct implementation. Achieved level meets required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or Richardson extrapolation must demonstrate discretization error below 5% for the hemolysis index QoI at MRL 2.",
      "rationale": "Three-level mesh refinement study performed on the FDA centrifugal pump geometry. GCI for the hemolysis index QoI was 3.2%, below the 5% threshold. Polyhedral mesh with 4.1 million cells selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) must be documented and match simulated boundary conditions within stated uncertainty bounds.",
      "rationale": "FDA benchmark experimental conditions (flow rates 2.5–7 L/min, speeds 2000–3500 RPM, bovine blood analog) are fully documented. CFD boundary conditions were set to match experimental values within measured uncertainty. Traceability to ASTM F1841 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within two standard deviations of experimental variability across the operating envelope.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values agreed with experimental measurements within 1.4 standard deviations across all 12 operating points tested. Achieved level exceeds required level, providing additional confidence margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected QoIs (NIH, shear stress distribution, exposure time) must be directly linked to the clinical hemolysis risk endpoint for CPB devices.",
      "rationale": "QoIs — normalized index of hemolysis, volume-averaged shear stress, and red blood cell exposure time — are established hemolysis predictors per ASTM F1841 and published CPB device literature. Direct linkage to clinical hemolysis risk confirmed by clinical advisory review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, fluid analog, and operating range as the intended CPB clinical use scenario.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under bovine blood analog conditions spanning the clinical CPB operating envelope (2.5–7 L/min, 2000–3500 RPM). Geometry and conditions are representative of the intended Class II CPB device use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver iterative convergence residuals must be documented; formal solver error quantification not required at MRL 2 for this factor.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations. Factor not assessed beyond this minimum; acceptable for MRL 2 scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error analysis not required at MRL 2; simulation execution was performed by trained personnel following documented procedures.",
      "rationale": "Simulations executed by CFD engineers with documented training records. Standard operating procedures followed. Formal use error analysis not required at MRL 2; factor scoped out per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty quantification not required at MRL 2; selection of turbulence and hemolysis model must be documented with literature justification.",
      "rationale": "SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law model selected based on published CPB CFD literature. Formal model form uncertainty quantification not required at MRL 2. Documentation on file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters (fluid viscosity, density, hemolysis model constants) must be documented with sources; formal sensitivity analysis not required at MRL 2.",
      "rationale": "All model inputs documented with literature sources. Bovine blood analog properties from ASTM F1841. Hemolysis model constants from Giersiepen et al. 1990. Formal sensitivity analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterization (blood analog preparation, hematocrit) must be documented; statistical sample size analysis not required at MRL 2.",
      "rationale": "FDA benchmark experimental dataset used; blood analog preparation and hematocrit documented in the original FDA study. Statistical sample size analysis not required at MRL 2. Acceptable for current assessment scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment inputs and clinical use inputs need not be formally quantified at MRL 2; qualitative justification is sufficient.",
      "rationale": "Qualitative equivalency established between bovine blood analog properties and clinical human blood properties for hemolysis prediction purposes, consistent with FDA guidance. Formal equivalency quantification not required at MRL 2."
    }
  ],
