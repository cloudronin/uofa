      "type": "ValidationResult",
      "name": "Hemolysis index QoI comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/morrison/validation/operating-envelope-sweep",
      "type": "ValidationResult",
      "name": "Operating envelope sweep validation — worst-case flow and speed conditions"
    }
  ],
