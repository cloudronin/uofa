      "type": "ValidationResult",
      "name": "PIV velocity field comparison against FDA benchmark data at 2500 RPM, 4 L/min — normalised RMS error 6.3 %"
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-index-experimental",
      "type": "ValidationResult",
      "name": "Modified Index of Hemolysis (MIH) prediction versus in-vitro bovine blood experiments across five operating points — mean absolute error 8.1 %"
    }
  ],
