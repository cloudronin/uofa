  "signature": "ed25519:b1c4d7e2f5a8b3c6d9e0f3a6b9c2d5e8f1a4b7c0d3e6f9a2b5c8d1e4f7a0b3c6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression test suite pass rate ≥ 95 %, and documented release notes for ANSYS Fluent 2022R2.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with ISO 9001-certified development process. Internal regression suite reports 98.2 % pass rate. Version control and release documentation reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration of correct implementation of governing equations via method-of-manufactured-solutions (MMS) or equivalent benchmark for incompressible Navier-Stokes solver.",
      "rationale": "ANSYS Fluent incompressible solver verified against lid-driven cavity benchmark (Re = 100, 400, 1000) and Taylor-Green vortex MMS. Observed convergence rates consistent with second-order spatial accuracy. Code verification evidence sourced from vendor validation manual v2022R2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5 % for velocity magnitude and wall shear stress QoIs on the finest two mesh levels.",
      "rationale": "Three-level mesh refinement study conducted (4.2 M, 9.8 M, 21.4 M polyhedral cells). Richardson extrapolation yields GCI of 3.1 % for velocity magnitude and 4.7 % for wall shear stress at the impeller trailing edge — both within the 5 % acceptance threshold. Asymptotic range confirmed (GCI ratio 1.02)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) documented with measurement uncertainty ≤ 3 % for primary parameters.",
      "rationale": "In-vitro test loop operated with bovine blood at 37 °C, hematocrit 33 ± 1 %. Flow rate controlled by Coriolis meter (±0.5 % FS). Rotational speed measured by optical encoder (±0.1 %). All boundary condition uncertainties within acceptance threshold. Test protocol archived under study ID MCV-2021-04."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E_rel or NRMSE) < 15 % for primary QoIs across all validation operating points.",
      "rationale": "Velocity field NRMSE of 6.3 % against PIV benchmark. MIH mean absolute error of 8.1 % across five experimental operating points. Both primary QoIs satisfy the ≤ 15 % acceptance criterion. Systematic over-prediction of MIH at low-flow conditions (< 2.5 L/min) noted but within bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (MIH, wall shear stress, exposure time) are directly linked to the clinical risk of hemolysis and are accepted hemolysis surrogate metrics per ASTM F1841.",
      "rationale": "Modified Index of Hemolysis is the primary regulatory QoI for CPB device hemolysis assessment per ASTM F1841 and FDA guidance. Wall shear stress and scalar stress exposure time are mechanistically linked to red blood cell damage. All three QoIs are clinically relevant and directly inform worst-case operating point identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic centrifugal pump geometry at overlapping operating conditions (flow rate, RPM) with the intended COU envelope.",
      "rationale": "Validation data collected on the FDA generic centrifugal pump geometry (identical to simulation geometry) at 2500 and 3000 RPM, 3–5 L/min — fully within the CPB COU operating envelope. Geometric fidelity confirmed by CMM measurement of the physical impeller against CAD nominal. Validation activities judged highly relevant to the intended use scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; solver round-off and iterative convergence errors are considered negligible relative to discretization error for steady-state RANS simulations.",
      "rationale": "At MRL 2, explicit quantification of iterative and round-off solver errors is not mandated. Residuals converged to < 1×10⁻⁶ for all equations; double-precision arithmetic employed. Solver error contribution is judged negligible relative to discretization uncertainty already quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst competency and simulation workflow review are addressed through organizational QMS procedures.",
      "rationale": "Analyst team holds documented CFD competency certifications. Simulation workflow reviewed by independent senior analyst. Formal use-error analysis not required at MRL 2 and scoped out consistent with ASME V&V 40 Table 3 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; turbulence model selection (SST k-ω) is supported by published literature for rotary blood pump CFD and is considered adequate for the risk level.",
      "rationale": "SST k-ω turbulence model selected based on published benchmarking studies for rotary blood pumps (Fraser et al. 2011, Hariharan et al. 2018). Model form uncertainty quantification not mandated at MRL 2. Alternative turbulence model sensitivity (k-ε realizable) performed informally; MIH predictions within 4 % — supporting adequacy of the selected model form."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal material properties (blood viscosity, density) and boundary conditions are well-characterised for the CPB operating range.",
      "rationale": "Blood modelled as a non-Newtonian fluid using the Carreau-Yasuda model with parameters from Ballyk et al. 1994, appropriate for hematocrit 33 %. Formal parametric uncertainty propagation not required at MRL 2. Key input sensitivities (viscosity ±10 %) assessed informally; MIH response < 3 % change."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; bovine blood lot-to-lot variability is acknowledged but formal statistical characterisation of sample population is not mandated at this risk level.",
      "rationale": "Bovine blood sourced from a single abattoir lot per ASTM F1841 protocol. Baseline MIH < 0.05 g/dL confirmed before each test. Lot-to-lot variability not formally characterised; accepted as standard practice at MRL 2 for exploratory hemolysis assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; the simulation boundary conditions are set to match experimental conditions by design, and residual differences are within measurement uncertainty.",
      "rationale": "Simulation inlet boundary conditions set to match experimentally measured flow rates and rotational speeds. Residual differences between nominal CFD inputs and experimental measurements are within documented measurement uncertainties (< 1 % for flow rate, < 0.1 % for RPM). Formal equivalency analysis not required at MRL 2."
    }
  ],
