  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This package evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The intended use scope — screening worst-case hemolysis operating points for regulatory submission of a Class II centrifugal blood pump in adult CPB — is described in the bound Requirement and Claim records.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-centrifugal-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/morrison/data/cfd-mesh-sensitivity-results",
    "https://uofa.net/morrison/data/operating-envelope-sweep"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data across five operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/shear-stress-distribution-check",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation against PIV measurements at 3500 RPM, 5 L/min"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-head-curve-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-head curve validation across operating envelope confirming hydraulic fidelity"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041290",
