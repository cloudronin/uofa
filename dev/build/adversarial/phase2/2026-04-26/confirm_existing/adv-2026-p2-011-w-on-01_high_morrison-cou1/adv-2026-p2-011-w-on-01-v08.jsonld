  "signature": "ed25519:b2e4a1c7f3d09e5b8a2c6f1d4e7b3a0c9f5d2e8b4a1c7f3d09e5b8a2c6f1d4e",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented regression test suite covering relevant flow regimes; test pass rate ≥ 95%.",
      "rationale": "ANSYS Fluent 2022R2 is used under an ISO 9001-certified QMS. Regression suite of 312 test cases covering turbulent rotating-frame flows was executed; 309/312 passed (99.0%). Version control and release notes archived in the sponsor's document management system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical rotating-channel flow must confirm theoretical second-order convergence within 10% tolerance.",
      "rationale": "Method of manufactured solutions applied to a rotating annular channel. Observed order of accuracy was 1.94 for velocity and 1.97 for pressure, both within the 10% tolerance of the nominal second-order scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) for hemolysis index QoI must be < 5% on the medium-to-fine mesh pair.",
      "rationale": "Three-mesh Richardson extrapolation performed (2.1 M, 5.8 M, 14.2 M cells). GCI fine = 2.3% for normalized hemolysis index. Asymptotic range ratio = 1.02, confirming monotonic convergence. Medium mesh (5.8 M cells) adopted for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must span the CPB operating envelope (2–7 L/min, 2500–4500 RPM) with documented fluid temperature and hematocrit controls.",
      "rationale": "FDA generic pump experiments conducted at 37 °C ± 0.5 °C with bovine blood at 33 ± 2% hematocrit. Five operating points covering the CPB envelope were tested in triplicate. Test protocols and raw data archived in study report TR-2021-047."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predicted by the model must agree with experimental NIH within ± 25% at all five operating points.",
      "rationale": "Predicted NIH values ranged from 0.0031 to 0.0087 g/100 L; experimental values ranged from 0.0028 to 0.0091 g/100 L. Maximum relative error was 18.4% at the 7 L/min, 4500 RPM operating point, within the ± 25% acceptance band at all five points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (NIH) must be directly linked to the regulatory question of worst-case hemolysis identification, with a documented QoI traceability matrix.",
      "rationale": "The Requirement record (req/cpb-hemolysis-mrl2) and Claim record (claim/cpb-hemolysis-worst-case) document that NIH is the ISO 10993-compliant metric for blood damage assessment. QoI traceability matrix in TR-2021-047 Section 3 maps NIH to the regulatory decision question for Class II CPB devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and fluid properties as the COU, with operating conditions overlapping the intended clinical use envelope.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry (identical to the simulation geometry) with bovine blood as a clinically representative analogue. The five test operating points span the adult CPB flow range specified in the Requirement record, confirming direct relevance of validation evidence to the intended use scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence monitoring sufficient.",
      "rationale": "At MRL 2, explicit numerical solver error quantification beyond iterative residual monitoring is not mandated. Residuals for all equations converged to < 1e-5. Factor scoped out per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification records are sufficient.",
      "rationale": "MRL 2 does not require formal use-error analysis. Lead analyst holds a doctoral degree in computational fluid dynamics with 8 years of cardiovascular CFD experience. Simulation setup was peer-reviewed by a second qualified analyst prior to production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection must be documented with literature justification.",
      "rationale": "SST k-ω turbulence model and Giersiepen-Wurzinger power-law hemolysis model selected based on published benchmark studies for centrifugal blood pumps. Model form selection documented in TR-2021-047 Section 2. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and hemolysis model constants taken from published literature with traceability documented in TR-2021-047 Appendix A. Formal sensitivity analysis of model inputs not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterization records are sufficient.",
      "rationale": "Bovine blood samples characterized for hematocrit, plasma free hemoglobin baseline, and viscosity prior to each test. Sample provenance and characterization data archived in study report TR-2021-047 Appendix B. Statistical sample-to-sample variability analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; documented parameter mapping between simulation and experiment is sufficient.",
      "rationale": "Simulation boundary conditions (inlet flow rate, rotational speed, outlet pressure) mapped directly to experimental set points with correspondence table in TR-2021-047 Section 4. Formal equivalency analysis not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed per the MRL 2 assessment plan, which is acceptable under ASME V&V 40-2018 for a Class II device at this risk level. The CFD hemolysis model is accepted as sufficiently credible to identify worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in the CPB application described in the Requirement and Claim records. No weakeners were identified during the assessment.",
