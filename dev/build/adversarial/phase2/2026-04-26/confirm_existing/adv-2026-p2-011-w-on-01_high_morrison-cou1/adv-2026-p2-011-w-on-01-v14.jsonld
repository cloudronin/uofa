  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software must demonstrate version-controlled source, documented build and test procedures, and traceable issue resolution consistent with MRL 2 expectations.",
      "rationale": "ANSYS Fluent 2023 R1 was used under a validated installation qualified per the organization's SQA plan. Version control records, regression test reports, and defect logs were reviewed and found compliant with Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified against at least one canonical benchmark problem relevant to rotating turbomachinery flow, demonstrating convergence to known solution within acceptable tolerance.",
      "rationale": "The CFD solver was verified against the Taylor-Couette flow benchmark and the lid-driven cavity problem. Observed order of accuracy matched theoretical expectation (second-order) and errors were within 1.2% of the analytical solution, satisfying Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal mesh convergence study must be performed with at least three systematically refined meshes; GCI must be reported for the primary QoI (hemolysis index).",
      "rationale": "A three-level mesh refinement study was conducted (4.2M, 9.8M, and 21.6M cells). GCI for the normalized hemolysis index at the worst-case operating point was 1.8%, well below the 5% threshold. The fine-mesh solution was adopted for all production runs, exceeding Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to confirm relevance to the CPB operating envelope, including fluid properties, rotational speed range, and flow rate range.",
      "rationale": "Bench experiments were conducted using porcine blood at 37°C, rotational speeds of 2500–4500 RPM, and flow rates of 3–7 L/min, fully spanning the CPB operating envelope. Test condition documentation was reviewed and confirmed complete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±25% across all validation operating points, accounting for experimental uncertainty.",
      "rationale": "CFD-predicted normalized index of hemolysis agreed with experimental values within 18% across all five validation operating points when experimental uncertainty (±8%) was accounted for. The comparison metric satisfies Gradation 2 acceptance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs extracted from the simulation (NIH, shear stress distribution, exposure time) must be directly linked to the clinical decision question of worst-case hemolysis identification for the CPB device.",
      "rationale": "The primary QoI (normalized index of hemolysis) is the standard regulatory metric for blood pump hemolysis assessment per FDA guidance. Secondary QoIs (scalar shear stress, residence time) are mechanistically linked to red blood cell damage. Relevance is well established in the literature and confirmed by the clinical team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry (FDA generic centrifugal pump) and blood analog or real blood under conditions representative of the CPB clinical use scenario.",
      "rationale": "Validation was performed on the identical FDA generic centrifugal pump geometry using porcine blood under CPB-representative conditions. No geometric surrogates or non-representative analogs were used. The validation scenario is judged sufficiently relevant to the intended clinical use context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
