      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a formal use error analysis is not required; standard analyst training and peer review of simulation setup are sufficient.",
      "rationale": "Simulation setup was reviewed by a second qualified analyst. No formal use error analysis was conducted, consistent with MRL 2 expectations. Factor is scoped out at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of model form selection rationale is sufficient; formal model form uncertainty quantification is not required.",
      "rationale": "The SST k-omega turbulence model was selected based on literature precedent for rotating blood pump flows. Model form uncertainty was not formally quantified, consistent with MRL 2 scoping. Selection rationale is documented in the simulation report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are sufficient; probabilistic input uncertainty propagation is not required.",
      "rationale": "Blood viscosity, density, and boundary conditions were set to nominal values drawn from published literature and device specifications. No sensitivity analysis or uncertainty propagation was performed, consistent with MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of sample provenance and basic characterization is sufficient; statistical sample size analysis is not required.",
      "rationale": "Porcine blood samples were sourced from a single supplier with documented hematocrit and viscosity characterization. No statistical power analysis for sample size was conducted, consistent with MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
