  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent documented QA process covering version control, regression testing, and release validation for CFD hemolysis applications.",
      "rationale": "ANSYS Fluent 2022 R2 is used under a validated QA framework with documented regression suite covering rotating machinery and non-Newtonian blood flow; version-controlled input decks archived in institutional repository. Achieved level meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) or equivalent benchmark confirms spatial discretization behaves as expected for the governing equations employed.",
      "rationale": "Developer-published MMS results for the pressure-based coupled solver confirm second-order spatial accuracy for incompressible Navier-Stokes with rotating reference frames. Results reproduced internally on the study mesh topology."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed over three systematically refined meshes; GCI on hemolysis index QoI must be less than 5% at the operating point of maximum hemolysis.",
      "rationale": "Three-mesh Richardson extrapolation yields GCI of 2.8% on the scalar hemolysis index at the 6 L/min, 125 mmHg worst-case operating point. Observed order of convergence p=1.94, consistent with nominal second-order scheme. Exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, pressure head, fluid temperature, hematocrit) are documented with measurement uncertainty and span at least three points within the CPB operating envelope.",
      "rationale": "FDA GCBP experimental dataset documents five operating points (3–7 L/min, 75–175 mmHg) with bovine blood at 37°C, Hct 33±2%. Measurement uncertainties reported for all boundary condition parameters. Conditions bracket the intended CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement between predicted and measured hemolysis index must exceed 0.85 across all validation operating points; systematic bias must be documented.",
      "rationale": "Normalized index of agreement of 0.91 achieved across five operating points. Maximum point-wise error 14% at 3 L/min low-flow condition; mean absolute error 8.3%. Systematic under-prediction at low shear rates documented and attributed to power-law viscosity model limitation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (scalar hemolysis index) must be directly linked to the clinical harm mechanism (red blood cell destruction) and must be measurable in both simulation and bench experiment.",
      "rationale": "The normalized index of hemolysis (NIH) is the regulatory-standard metric for CPB device hemolysis assessment per FDA guidance. NIH is computed identically from simulation (power-law damage accumulation integral) and experiment (plasma free hemoglobin assay), ensuring direct comparability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid properties, and operating conditions must be sufficiently representative of the Class II CPB device COU to support extrapolation of credibility evidence.",
      "rationale": "Validation performed on the FDA-defined generic centrifugal blood pump geometry, which is the regulatory reference geometry for Class II CPB devices. Blood analogue properties and operating envelope match CPB clinical conditions. Validation activities are directly representative of the intended COU as described in the bound requirement and claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance at gradation 1 applies.",
      "rationale": "At MRL 2, explicit iterative convergence error quantification beyond standard residual monitoring is not required. Residuals converged to 1e-5 for all equations; mass imbalance below 0.01%. Scoped out per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; operator qualification records sufficient.",
      "rationale": "Formal use-error analysis not required at MRL 2. Simulation executed by credentialed CFD analyst with documented training on rotating machinery hemolysis workflows. Scoped out per assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equation set (turbulence model, blood rheology model, hemolysis damage model) must be justified relative to the flow physics of the CPB operating envelope with reference to published literature.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark studies for confined swirling flows in centrifugal blood pumps. Carreau-Yasuda non-Newtonian viscosity model calibrated to bovine blood rheometry data. Giersiepen-Wurzinger power-law hemolysis damage model is the standard FDA-accepted formulation. Model form choices documented with literature justification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, boundary conditions, material properties) must be documented with sources and nominal uncertainty bounds; sensitivity to key inputs must be qualitatively addressed.",
      "rationale": "Pump geometry derived from FDA-published STL file. Inlet velocity profiles from experimental LDV measurements. Viscosity parameters from in-house rheometry (n=3 samples). Rotational speed uncertainty ±0.5 RPM documented. Qualitative sensitivity analysis confirms hemolysis index most sensitive to impeller tip clearance and inlet hematocrit, both bounded within experimental uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for computational-only validation activities.",
      "rationale": "Statistical characterization of experimental sample variability beyond reported mean and standard deviation not required at MRL 2. FDA dataset reports triplicate measurements at each operating point with CV below 8%. Scoped out per assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when validation and application share the same geometry and operating envelope.",
      "rationale": "Validation and application cases use identical geometry (FDA GCBP) and overlapping operating envelopes. Formal equivalency mapping not required at MRL 2. Scoped out per assessment plan."
    }
