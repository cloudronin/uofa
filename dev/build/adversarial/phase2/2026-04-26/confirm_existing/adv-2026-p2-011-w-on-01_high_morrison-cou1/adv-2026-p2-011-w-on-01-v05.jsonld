      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented verification test suite and version-controlled input files sufficient for MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 was used with a documented QA plan including version control of all case files and solver release notes confirming passing internal verification benchmarks. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark problems relevant to rotating machinery internal flows at MRL 2 standard.",
      "rationale": "ANSYS Fluent has been verified against the lid-driven cavity and rotating channel flow benchmarks published in the ASME V&V 20 supplement. Code verification evidence is documented in the solver release validation report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for velocity magnitude and scalar shear stress at representative operating point; GCI < 5% on fine grid.",
      "rationale": "A three-level mesh refinement study was performed at 2500 RPM / 5 L/min. GCI for area-averaged wall shear stress was 3.2% between medium and fine meshes (7.1M and 14.6M cells respectively), satisfying the MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid properties) documented and traceable to calibrated instrumentation.",
      "rationale": "FDA benchmark PIV experiments were conducted with phosphate-buffered saline at 25°C. Flow rate set by calibrated Coriolis meter (±0.5%), rotational speed by optical encoder (±1 RPM). Fluid viscosity and density reported with measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty) reported for primary QoI; agreement within validation uncertainty bounds.",
      "rationale": "Velocity magnitude profiles compared at five axial planes. Mean absolute error of 4.1% relative to PIV ensemble averages. NIH predictions within 12% of in vitro measurements across four operating points, within combined experimental and model uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, peak scalar shear stress) are directly linked to hemolysis risk and are the quantities used in the regulatory decision.",
      "rationale": "The primary QoI is the Normalized Index of Hemolysis, which is the standard metric for CPB device hemolysis assessment per ISO 10993-4 and FDA guidance. Secondary QoI is volume-averaged scalar shear stress, directly input to the power-law hemolysis model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic pump geometry under overlapping operating conditions (flow rate, RPM) as the COU operating envelope.",
      "rationale": "Validation activities used the identical pump geometry (FDA generic centrifugal pump CAD) and covered the full CPB operating envelope (1500–3500 RPM, 3–8 L/min). The validation domain therefore encompasses the intended operating range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance at Gradation 1.",
      "rationale": "At MRL 2 for a Class II device, explicit iterative convergence error quantification beyond residual monitoring is not required. Residuals were driven below 1e-5 for all equations; no further assessment necessary."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst credentials and simulation log review considered sufficient.",
      "rationale": "Analyst holds a PhD in computational fluid dynamics with 8 years of cardiovascular CFD experience. Simulation inputs were peer-reviewed by a second qualified engineer. Formal use-error assessment not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equations and constitutive models (turbulence model, hemolysis power-law) justified for the flow regime and validated against relevant experimental data.",
      "rationale": "RANS k-omega SST turbulence model selected based on published comparative studies for centrifugal pump internal flows. Power-law hemolysis model (Giersiepen et al.) is the standard for CPB device assessment. Model form justified by literature and sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, boundary conditions, material properties) documented with sources and nominal uncertainty estimates.",
      "rationale": "CAD geometry sourced from FDA public repository (v1.2). Boundary conditions derived from calibrated experimental measurements. Blood surrogate properties (density 1056 kg/m³, viscosity 0.0035 Pa·s) documented with references. Input uncertainty table provided in the assessment report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; single representative pump specimen used for validation is acceptable.",
      "rationale": "FDA benchmark experimental data were collected on a single manufactured specimen of the generic pump. Sample-to-sample variability assessment is not required at MRL 2 for this device class."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal parameter matching between simulation and experiment is sufficient.",
      "rationale": "Simulation boundary conditions were set to match nominal experimental values. Formal equivalency analysis of parameter distributions is not required at MRL 2 for a Class II device."
