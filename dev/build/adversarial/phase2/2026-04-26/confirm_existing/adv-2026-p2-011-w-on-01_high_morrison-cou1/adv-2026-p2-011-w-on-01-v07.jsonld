  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This UnitOfAssurance evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. The intended use is bounded to adult CPB circuits operating at 2–6 L/min flow and 2000–3500 RPM impeller speed. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Credibility decision: Accepted.",
  "bindsRequirement": "https://uofa.net/morrison/req/hemolysis-worst-case-identification",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-cfd-credibility",
  "bindsModel": "https://uofa.net/morrison/model/fda-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-piv-experimental",
    "https://uofa.net/morrison/data/fda-pump-hemolysis-bench"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Normalized Index of Hemolysis comparison across five operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034918",
