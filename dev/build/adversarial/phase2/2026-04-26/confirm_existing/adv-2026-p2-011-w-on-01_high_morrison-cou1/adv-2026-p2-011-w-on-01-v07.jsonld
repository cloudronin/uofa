  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented regression test suite covering turbulent pipe flow and rotating machinery benchmarks.",
      "rationale": "ANSYS Fluent 2022R2 employed under ISO 9001-certified QMS. Version-controlled case files stored in institutional GitLab. Regression suite of 47 benchmark cases executed; all pass within stated tolerances. Achieved level 2 satisfies MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) for the Navier-Stokes solver must demonstrate second-order spatial convergence.",
      "rationale": "MMS study on 3D lid-driven cavity confirms second-order spatial convergence (observed order 1.97). Iterative convergence to residual 1e-6 verified for all continuity and momentum equations. Code verification requirement met at level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the scalar hemolysis index must be less than 5% on the medium mesh used for production runs.",
      "rationale": "Three-level mesh refinement study (4.2M, 9.8M, 21.4M cells) performed at 3500 RPM, 4 L/min. GCI on NIH is 3.1% between medium and fine meshes. Medium mesh (9.8M cells) selected for production runs. Discretization error level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid viscosity, temperature) must be documented with measurement uncertainty and reproduced in the CFD setup within stated tolerances.",
      "rationale": "FDA benchmark experimental conditions reproduced: blood analog (36% glycerol-water, viscosity 3.5 mPa·s at 37°C), flow rates 2–6 L/min ±0.05 L/min, inlet turbulence intensity 5%. All boundary conditions traceable to published FDA protocol. Level 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric E) between CFD and experimental NIH values must be within two experimental standard deviations across all five operating points.",
      "rationale": "Validation metric computed per ASME V&V 20. CFD NIH predictions within 1.4 experimental standard deviations at all five operating points (2000, 2500, 3000, 3200, 3500 RPM at 4 L/min). Worst-case relative error 8.3% at 2000 RPM. Output comparison exceeds required level, achieving level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (Normalized Index of Hemolysis) must be directly linked to the clinical decision question of worst-case hemolysis identification for CPB device labeling.",
      "rationale": "NIH is the regulatory-accepted surrogate for red blood cell damage in CPB devices per FDA guidance. NIH at worst-case operating point directly informs device labeling claim. QoI relevance established at level 2 for MRL 2 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating range as the intended CPB deployment context, or differences must be bounded by documented similarity arguments.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry identical to COU device geometry. Blood analog validated against bovine blood hemolysis correlation. Operating range 2–6 L/min encompasses full adult CPB envelope. Relevance level 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal iterative solver error quantification beyond residual monitoring is not required; residual convergence to 1e-5 is sufficient.",
      "rationale": "MRL 2 does not require formal numerical solver error quantification beyond standard residual convergence monitoring. Residuals converge to 1e-5 for all equations. Factor scoped to level 1; not-assessed status acceptable per ASME V&V 40 Table 3 at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, systematic use error assessment is not required provided that the analyst team has documented CFD experience with rotating machinery.",
      "rationale": "Analyst team has 10+ years of rotating machinery CFD experience, documented in CVs on file. MRL 2 does not mandate formal use error assessment. Factor not assessed; level 1 requirement satisfied by team qualification records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty quantification is not required; selection of k-omega SST turbulence model with documented precedent in blood pump literature is sufficient.",
      "rationale": "k-omega SST turbulence model selected based on published precedent in FDA blood pump round-robin studies. Formal model form uncertainty quantification not required at MRL 2. Factor not assessed; level 1 acceptable per ASME V&V 40."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, sensitivity analysis on model inputs is not required; nominal input values with documented sources are sufficient.",
      "rationale": "Fluid properties and boundary conditions sourced from peer-reviewed literature and FDA benchmark protocol. Formal sensitivity analysis not required at MRL 2. Factor not assessed; level 1 requirement met by input documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of experimental sample variability is not required; use of FDA benchmark dataset with documented protocol is sufficient.",
      "rationale": "FDA benchmark dataset used; experimental protocol and sample preparation documented in FDA report. Statistical sample characterization not required at MRL 2. Factor not assessed; level 1 acceptable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency mapping between validation experiment inputs and COU inputs is not required; qualitative similarity argument is sufficient.",
      "rationale": "Qualitative similarity between FDA benchmark conditions and CPB COU operating envelope documented in Section 4.2 of the credibility assessment report. Formal equivalency quantification not required at MRL 2. Factor not assessed; level 1 satisfied."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors are appropriately not assessed at MRL 2 per ASME V&V 40 Table 3. The CFD model is deemed credible for identifying worst-case hemolysis operating conditions of the FDA generic centrifugal blood pump in CPB service. Regulatory submission to FDA 510(k) pathway authorized. The claim that the model predicts NIH within acceptable uncertainty bounds across the adult CPB operating envelope is supported by the evidence assembled in this UnitOfAssurance.",
