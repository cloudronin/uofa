      "id": "https://uofa.net/morrison/validation/gcbp-velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "GCBP velocity field comparison against PIV measurements at 2500 RPM and 5 L/min — normalized RMS error 4.2%, within MRL 2 acceptance threshold of 10%"
    },
    {
      "id": "https://uofa.net/morrison/validation/gcbp-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Normalized Index of Hemolysis comparison across six operating points — model predictions within ±15% of bench measurements, satisfying MRL 2 output-comparison criterion"
    }
  ],
