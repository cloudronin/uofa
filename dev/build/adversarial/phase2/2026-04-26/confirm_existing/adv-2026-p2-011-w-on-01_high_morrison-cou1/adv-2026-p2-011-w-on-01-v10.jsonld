  "signature": "ed25519:b7d3e9f1a52c84061e3f7b2d5a8c4e9f1b3d6a2c8e5f7b4d1a9c3e6f8b2d5a7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented verification test suite with traceable version control and issue tracking consistent with MRL 2 expectations.",
      "rationale": "ANSYS Fluent 2022 R2 used under a validated QMS. Version-controlled solver with documented regression test suite covering laminar and turbulent benchmark cases. Software qualification report on file confirms MRL 2 compliance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark problems with documented convergence behavior meeting MRL 2 standard.",
      "rationale": "Solver order-of-accuracy confirmed against Taylor-Green vortex and lid-driven cavity benchmarks. Observed second-order spatial convergence consistent with discretization scheme. Results archived in code verification report CVR-2022-07."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (NIH and velocity magnitude) across at least three mesh refinement levels; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study performed: coarse (4.2M cells), medium (11.8M cells), fine (28.6M cells). GCI for NIH = 2.8% and for peak shear stress = 3.4% on fine mesh. Richardson extrapolation applied. Discretization error within MRL 2 acceptance band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with uncertainty quantification and traceable to calibrated instrumentation; conditions must span the intended CPB operating envelope.",
      "rationale": "PIV and hemolysis bench experiments conducted at FDA CDRH laboratory. Flow rates of 2.5–7 L/min and rotational speeds of 2000–3500 RPM documented. Inlet velocity profiles, fluid temperature (37°C ± 0.5°C), and hematocrit (33% ± 2%) recorded with calibrated instruments. Uncertainty budget provided in experimental report EXP-FDA-GCBP-2021."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed for each QoI; metric must fall within MRL 2 acceptance threshold accounting for combined experimental and numerical uncertainty.",
      "rationale": "Validation metric computed per ASME V&V 20 for NIH across six operating points. Mean absolute error 8.3%, within the 15% MRL 2 threshold. Velocity field RMS normalized error 4.2% against PIV data. Both primary QoIs pass acceptance criteria with margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear stress distribution, velocity field) must be mechanistically linked to the clinical decision question of worst-case hemolysis identification for CPB devices.",
      "rationale": "NIH is the regulatory-accepted scalar metric for hemolysis in CPB devices (ISO 10993-4). Shear stress and exposure time are the mechanistic inputs to the power-law hemolysis model. Velocity field provides the underlying fluid dynamics driving both. QoIs are directly relevant to worst-case operating point identification as required by the decision question."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same device geometry, fluid analogue, and operating conditions as the intended CPB clinical context; deviations must be documented and impact assessed.",
      "rationale": "Validation performed on the identical FDA generic centrifugal blood pump geometry using bovine blood at physiological hematocrit. Operating conditions span the full CPB envelope including worst-case high-shear operating points. Fluid analogue deviation (bovine vs. human blood) assessed: rheological properties within 5% at 37°C. Validation activities rated one level above required due to high geometric and operational fidelity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, iterative convergence monitoring with residual targets documented is sufficient; formal solver error bounding not required.",
      "rationale": "Iterative convergence confirmed with residuals below 1e-5 for all equations and mass imbalance below 0.01%. Formal numerical solver error quantification not required at MRL 2 and not performed; factor scoped to level 1 per MRL 2 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of analyst qualifications and simulation setup review is sufficient.",
      "rationale": "Simulation performed by PhD-level CFD analyst with 8 years of cardiovascular device experience. Setup reviewed by independent senior analyst. Formal use-error FMEA not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis constitutive model must be justified by literature evidence and sensitivity analysis for the CPB flow regime.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark performance for rotating machinery at Re ~ 10^5. Giersiepen-Wurzinger power-law hemolysis model with Soares coefficients applied. Sensitivity analysis comparing k-epsilon and LES for peak shear stress showed <8% difference in NIH at worst-case operating point. Model form uncertainty bounded within acceptance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, boundary conditions, and geometric inputs must be documented with sources and uncertainty ranges; sensitivity of QoIs to key inputs must be quantified.",
      "rationale": "Blood viscosity (3.5 mPa·s ± 0.3), density (1060 kg/m³ ± 5), and non-Newtonian Carreau parameters sourced from ISO 10993-4 reference values. Geometric model derived from FDA-released CAD with dimensional verification against physical pump (max deviation 0.08 mm). One-at-a-time sensitivity analysis for viscosity and inlet velocity profile shows NIH sensitivity < 6% across ±2σ input range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of blood sample provenance and basic quality metrics (hematocrit, MIH) is sufficient; inter-sample variability study not required.",
      "rationale": "Bovine blood samples sourced from USDA-inspected facility with hematocrit 33% ± 2% and MIH < 0.1% confirmed prior to each experiment. Formal inter-sample variability analysis not required at MRL 2 and not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative equivalency argument between validation and COU input parameters is sufficient.",
      "rationale": "Validation experiments conducted at the same nominal flow rates and rotational speeds as the CPB operating envelope. Fluid properties within physiological range. Formal equivalency mapping analysis not required at MRL 2; qualitative equivalency documented in validation plan VP-GCBP-2021-03."
    }
  ],
