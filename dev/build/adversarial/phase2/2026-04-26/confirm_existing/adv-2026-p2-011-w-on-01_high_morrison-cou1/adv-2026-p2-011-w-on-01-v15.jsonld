  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are appropriately scoped out per ASME V&V 40 Table 1 guidance for MRL 2 Class II devices. The model is accepted as sufficiently credible to identify worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in the CPB application described in the bound Claim and Requirement nodes. No open weakeners were identified during the assessment cycle.",
