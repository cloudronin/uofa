  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. The model is intended to identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. A full 13-factor assessment was conducted: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The intended-use scope — adult CPB patients, flow rates 2–6 L/min, rotational speeds 2000–4000 RPM, blood viscosity modelled as Newtonian — is described in the Claim and Requirement nodes referenced below. Regulatory submission targets FDA 510(k) pathway.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/morrison/model/gcbp-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-gcbp-piv-experimental",
    "https://uofa.net/morrison/data/fda-gcbp-hemolysis-benchtop"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA GCBP benchmark"
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Normalised index of haemolysis (NIH) comparison against benchtop measurements"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043951",
