  "signature": "ed25519:b1d4e7a2c5f8b3d6e9a1c4f7b2d5e8a3c6f9b4d7e0a2c5f8b1d4e7a2c5f8b3d6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under documented version control with regression test suite; all critical defects resolved prior to simulation campaign.",
      "rationale": "ANSYS Fluent 2022 R2 was used under ISO 9001-certified QMS. Version-controlled input decks are archived in the laboratory Git repository. Regression tests covering 12 canonical benchmarks were executed and passed. No open critical defects at time of simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via at least one manufactured-solution or analytical benchmark relevant to rotating turbomachinery flows.",
      "rationale": "The solver was verified against the Taylor–Couette analytical solution for laminar rotating flow and against the Roache method of manufactured solutions for the incompressible Navier–Stokes equations. Observed convergence rates matched theoretical second-order accuracy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the primary QoI (NIH) must be less than 5% on the medium mesh used for production runs.",
      "rationale": "A three-level mesh refinement study (1.8 M, 5.4 M, 14.7 M cells) was conducted at the 3500 RPM / 4 L/min operating point. Richardson extrapolation yielded GCI = 2.1% on the medium mesh for NIH. The medium mesh was adopted for the full operating-condition sweep."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) must be reproduced in the simulation within stated measurement uncertainty.",
      "rationale": "FDA GCBP benchtop experiments were conducted with glycerol–water blood analogue at 37 °C. Inlet flow rates and rotational speeds were matched to within ±1% of experimental set-points. Temperature-dependent viscosity was applied via polynomial curve fit validated against rheometer data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must lie within two experimental standard deviations of the mean measured NIH across all tested operating points.",
      "rationale": "NIH predictions at six operating points (2000–4000 RPM, 3–5 L/min) were compared against published FDA benchtop data. All predictions fell within ±1.8 experimental standard deviations. Velocity field comparison against PIV data showed mean absolute error of 4.3% of peak velocity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (NIH, shear stress exposure time) must directly map to the clinical risk metric (haemolysis rate) cited in the device requirement.",
      "rationale": "NIH and cumulative shear stress exposure are the primary metrics in ASTM F1841 and ISO 10993-4 for blood-contacting device haemolysis assessment. The model outputs these quantities directly, providing a one-to-one correspondence with the regulatory requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid properties, and operating envelope as the intended COU.",
      "rationale": "Validation was performed on the FDA GCBP geometry — the same geometry used in the COU simulations. Blood analogue properties were matched to clinical blood viscosity at 37 °C. Operating points span the full CPB flow and speed envelope, confirming relevance of the validation evidence to the intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category; solver is a commercial code with established validation pedigree.",
      "rationale": "At MRL 2 with a commercially validated solver, explicit quantification of floating-point round-off and iterative solver error beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations in all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation campaign was executed by a single experienced analyst following a documented simulation protocol.",
      "rationale": "The simulation protocol (boundary condition setup, mesh generation procedure, solver settings) was documented and peer-reviewed internally. A single senior analyst executed all production runs, minimising operator variability. Formal use-error quantification is deferred to MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form choices (SST k-ω turbulence, Newtonian blood, power-law haemolysis) are consistent with published FDA guidance and peer-reviewed literature.",
      "rationale": "SST k-ω turbulence model and Newtonian blood assumption are standard for CPB CFD per FDA guidance document (2017). The Giersiepen–Wurzinger power-law haemolysis model is widely used and accepted for MRL 2 assessments. Formal model-form uncertainty quantification is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; key material and boundary-condition inputs are sourced from peer-reviewed literature and traceable to calibrated measurement equipment.",
      "rationale": "Blood analogue viscosity, density, and haemolysis model constants were drawn from published sources (Heuser & Opitz 1980; Giersiepen et al. 1990). Traceability records are maintained in the project data package. Probabilistic input uncertainty propagation is deferred to MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA GCBP experimental dataset is a publicly available reference benchmark with documented sample preparation and measurement protocols.",
      "rationale": "The FDA GCBP dataset is the community-standard benchmark for blood pump CFD validation. Sample preparation, haematocrit control, and NIH measurement protocols are fully documented in the FDA technical report. Additional sample characterisation is not required at this MRL."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; the validation experiment and COU share the same pump geometry and overlapping operating envelope, establishing sufficient equivalency without formal parameter-space mapping.",
      "rationale": "The FDA GCBP geometry is identical between validation and COU simulations. Operating conditions in the validation dataset (2000–4500 RPM, 2–6 L/min) fully encompass the COU operating envelope. Formal equivalency mapping via design-of-experiments is deferred to higher MRL assessments."
    }
  ],
