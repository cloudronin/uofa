  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. The six not-assessed factors are appropriately scoped out given the MRL 2 classification of this Class II CPB device application. The CFD model is accepted for identifying worst-case hemolysis operating conditions within the CPB flow and speed envelope documented in the simulation plan and claim narrative. The assessment team notes that the intended use scope is described in the claim and requirement documentation; no structural COU object is linked under the Minimal profile.",
