  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold a current ISO 9001 certification or equivalent quality management documentation covering version control, regression testing, and release validation for hemodynamic simulation.",
      "rationale": "ANSYS Fluent 2022R2 is used under an institutional quality management plan that includes version-controlled input decks, automated regression test suite with 98% pass rate, and documented release notes. Software QA level 2 is achieved and meets the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through at least one manufactured-solution or benchmark test case relevant to rotating machinery flows.",
      "rationale": "ANSYS Fluent has been verified against the Taylor-Couette flow benchmark and the ASME V&V 20 lid-driven cavity case. Numerical code verification is satisfied at level 2 for the MRL 2 context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine grid, assessed using at least three systematically refined meshes with refinement ratio ≥ 1.3.",
      "rationale": "A three-level mesh refinement study (coarse 2.1M, medium 5.8M, fine 14.2M cells) yielded GCI = 3.1% for the hemolysis index at the worst-case operating point (3500 RPM, 4 L/min). Discretization error is controlled at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must overlap with the intended CPB operating envelope (3–6 L/min, 2000–3500 RPM) and be documented with measurement uncertainty estimates.",
      "rationale": "FDA pump experimental data were collected at five operating points spanning 2500–3500 RPM and 3–5.5 L/min using porcine blood with hematocrit 33 ± 2%. Measurement uncertainty for hemolysis index (NIH) is reported as ±8%. Test conditions adequately represent the intended use envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental values within ±25% across all validation operating points, accounting for experimental uncertainty.",
      "rationale": "Predicted NIH values at all five validation points fall within ±18% of experimental means. When experimental uncertainty (±8%) is included, model predictions are within the acceptance band at every point. Output comparison is satisfactory at level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (NIH) must be directly linked to the clinical decision question of identifying worst-case hemolysis operating conditions for the CPB device.",
      "rationale": "NIH is the FDA-recognized metric for blood pump hemolysis assessment and directly informs the worst-case operating condition identification required by the intended use. The QoI is clinically and regulatorily relevant at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (FDA generic centrifugal pump) and blood analog or porcine blood under flow conditions within the CPB operating envelope.",
      "rationale": "All validation activities used the identical FDA generic centrifugal pump geometry with porcine blood under CPB-representative conditions. The validation scenario closely matches the intended clinical use context, satisfying relevance at level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations is sufficient at MRL 2; formal floating-point round-off analysis is not required.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond iterative convergence monitoring is not required. Residuals converged to 1e-6 for all equations in all simulations. This factor is not assessed beyond the minimum level and is acceptable for the current risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of analyst qualifications and a peer review of simulation setup is sufficient; formal use-error FMEA is not required.",
      "rationale": "The simulation was performed by a CFD engineer with 8 years of hemodynamic simulation experience and reviewed by a second qualified analyst. Formal use-error analysis is beyond MRL 2 requirements and is scoped out of this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, selection of the power-law hemolysis damage model with documented literature justification is sufficient; sensitivity analysis across alternative model forms is not required.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is used, consistent with FDA guidance and published literature for centrifugal blood pump assessment. Formal model-form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with literature-sourced uncertainty ranges documented in a simulation plan are sufficient; probabilistic sensitivity analysis is not required.",
      "rationale": "Blood viscosity (3.5 mPa·s), density (1060 kg/m³), and hemolysis model constants are taken from published sources with documented ranges. Full uncertainty propagation through model inputs is not required at MRL 2 and is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, use of biological samples with documented source, preparation protocol, and hematocrit range is sufficient; inter-laboratory reproducibility studies are not required.",
      "rationale": "Porcine blood from a single certified supplier was used with documented preparation and quality control. Inter-laboratory sample variability studies are not required at MRL 2 and are not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative documentation of the similarity between validation experiment inputs and intended-use simulation inputs is sufficient.",
      "rationale": "A qualitative equivalency table comparing validation experiment boundary conditions to intended CPB operating conditions has been prepared and reviewed. Quantitative equivalency metrics are not required at MRL 2 and are not assessed."
    }
  ],
