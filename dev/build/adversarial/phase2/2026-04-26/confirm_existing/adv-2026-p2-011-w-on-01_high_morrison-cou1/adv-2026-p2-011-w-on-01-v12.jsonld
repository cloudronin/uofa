  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-cardiovascular-simulation-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 4. Validation evidence demonstrates that the CFD model can reliably identify worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump within the CPB operating envelope (3–6 L/min, 60–120 mmHg). The assessment team accepts this model for use in pre-market design-space screening of hemolysis risk for Class II CPB devices at MRL 2.",
