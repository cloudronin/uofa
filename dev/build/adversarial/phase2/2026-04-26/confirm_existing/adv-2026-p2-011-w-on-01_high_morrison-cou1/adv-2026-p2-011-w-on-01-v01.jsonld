      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualifications documented as sufficient mitigation.",
      "rationale": "MRL 2 does not require formal use error assessment. Lead analyst holds PhD in biomedical engineering with 8 years of CFD experience in cardiovascular devices. Peer review of simulation setup performed by a second qualified analyst. Not formally assessed per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection rationale documented.",
      "rationale": "SST k-omega turbulence model selected based on published literature demonstrating superior performance for rotodynamic pump flows with adverse pressure gradients. Model form uncertainty not formally quantified at MRL 2. Selection rationale documented in the simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input parameters documented with sources.",
      "rationale": "All model inputs (fluid density, viscosity, power law hemolysis coefficients from Giersiepen et al.) documented with literature sources and nominal values. Formal sensitivity analysis not required at MRL 2. Input uncertainty not propagated at this assessment level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterization documented in experimental dataset.",
      "rationale": "Blood analog fluid preparation documented in the FDA experimental dataset with viscosity measurements confirming target properties. Sample-to-sample variability not formally assessed at MRL 2. Dataset provenance from FDA OSEL laboratory is considered sufficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that the input parameters used in the simulation match those of the validation experiment within documented tolerances, including geometry, boundary conditions, and fluid properties.",
      "rationale": "CAD geometry for the FDA generic centrifugal pump imported directly from the publicly available FDA benchmark geometry file (STL, no modifications). Inlet velocity profiles derived from experimental flow rate measurements. Fluid properties matched to within 1.2% of experimentally measured values. Rotational speed boundary condition set to match experimental tachometer readings. Equivalency confirmed across all 6 validation operating points."
    }
