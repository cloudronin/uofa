  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed the required levels for MRL 2. The 6 non-assessed factors are appropriately scoped out per MRL 2 requirements. Validation evidence demonstrates that the CFD model predicts NIH within 15% of experimental measurements across the CPB operating envelope. The model is judged credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump as a Class II CPB device. The assessment supports submission of simulation evidence to FDA in lieu of additional physical testing for worst-case operating point identification.",
