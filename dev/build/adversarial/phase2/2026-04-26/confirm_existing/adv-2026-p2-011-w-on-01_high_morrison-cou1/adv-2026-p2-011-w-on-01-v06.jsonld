  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This package evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The intended use scope — steady-state, single-phase blood analogue at nominal CPB flow rates of 3–6 L/min, 37 °C, haematocrit 35–45 % — is described in the Claim and Requirement nodes bound below; the structured Context of Use object is not separately linked under this Minimal-profile submission.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/morrison/model/fda-generic-cbp-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-cbp-piv-experimental-2019",
    "https://uofa.net/morrison/data/fda-cbp-hemolysis-bench-2021"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-hemolysis-nominal",
      "type": "ValidationResult",
      "name": "Hemolysis index validation at nominal CPB operating point (5 L/min, 75 mmHg)"
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-velocity-piv",
      "type": "ValidationResult",
      "name": "Velocity field comparison against PIV measurements in FDA generic centrifugal pump"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4044smaller-morrison-2022",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-simulation-lab",
