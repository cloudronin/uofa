  "signature": "ed25519:b17f3a9c2e84d05f6c1b3e8a0d4f7c2b9e5a3d1f8c6b4e2a0d9f7c5b3e1a8d6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent documented QMS with version-controlled source and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022 R2 is used under a validated QMS. Version control, regression testing against canonical benchmark cases, and release notes are documented. Achieved level meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent order-of-accuracy test demonstrating at least first-order spatial convergence for the governing transport equations.",
      "rationale": "Order-of-accuracy verification using the method of manufactured solutions confirms second-order spatial convergence for the incompressible Navier-Stokes solver. Results are documented in the solver verification report VR-CODE-2022."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on at least three systematically refined meshes; reported GCI below 5 % for the hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study (coarse 2.1 M, medium 5.8 M, fine 14.3 M hexahedral cells) yields GCI of 2.7 % for the normalised hemolysis index at the worst-case operating point. Achieved level 3 exceeds the MRL 2 requirement of level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, haematocrit) documented with measurement uncertainty and traceable to NIST-calibrated instruments.",
      "rationale": "Bench test conditions are fully characterised: flow rate ±0.05 L/min (NIST-traceable Coriolis meter), pressure ±1.5 mmHg (calibrated transducers), temperature 37 ± 0.5 °C. Haematocrit confirmed by centrifugation. Meets level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric M) computed for primary QoI; comparison includes experimental uncertainty bars.",
      "rationale": "Mean hemolysis index E% = 8.3 % relative to experimental mean, within combined experimental uncertainty of ±12 %. Velocity field RMSE is 4.1 % of peak velocity. Both metrics satisfy the level 2 acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modelled QoI (normalised hemolysis index) must be mechanistically linked to the clinical endpoint (red blood cell damage) and the regulatory decision criterion.",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger) directly maps scalar shear stress and exposure time to a normalised index of haemolysis, which is the FDA-accepted surrogate for RBC damage in CPB device submissions. Relevance is high."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry under flow conditions spanning the intended CPB operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry at 3, 5, and 6 L/min against 75 mmHg, bracketing the intended CPB operating range. Fluid is a porcine blood analogue at matched haematocrit. Validation activities are directly representative of the COU operating envelope as described in the bound Requirement node."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual below 1e-6 for all transport equations documented; not required at MRL 2 beyond level 1 acknowledgement.",
      "rationale": "At MRL 2, explicit quantification of iterative solver error beyond residual monitoring is not required. Residuals converge to 1e-7 for continuity and momentum; this is noted but formal level assessment is scoped to level 1 acknowledgement only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Acknowledgement that analyst training and simulation workflow controls are in place; full independent review not required at MRL 2.",
      "rationale": "Analysts hold institutional CFD competency certification. Simulation workflow is peer-reviewed internally. Formal use-error quantification is not required at MRL 2; level 1 acknowledgement is sufficient and achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form assumptions (Newtonian fluid, rigid walls, steady-state RANS) documented and acknowledged as appropriate for CPB flow regime; quantitative model form error not required at MRL 2.",
      "rationale": "Newtonian fluid assumption is justified for haematocrit 35–45 % at shear rates above 100 s-1 prevalent in CPB impeller passages. Rigid-wall assumption is acceptable for metallic impeller. Steady-state RANS (SST k-omega) is standard for this device class. Level 1 acknowledgement is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model inputs (viscosity, density, hemolysis model coefficients) documented with sources; sensitivity analysis not required at MRL 2.",
      "rationale": "Blood analogue viscosity 0.0035 Pa·s, density 1050 kg/m³, hemolysis coefficients from Giersiepen et al. (1990) as tabulated in FDA guidance. Input provenance is documented. Formal sensitivity analysis is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number and provenance of experimental samples documented; statistical repeatability not required at MRL 2 beyond acknowledgement.",
      "rationale": "Three independent experimental runs per operating point using fresh porcine blood from the same supplier lot. Sample provenance and storage conditions are documented in the test report TR-CBP-2021. Level 1 acknowledgement is sufficient at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between simulation boundary conditions and experimental test conditions documented; full uncertainty propagation not required at MRL 2.",
      "rationale": "Simulation inlet velocity profiles are derived directly from measured flow rates via area-averaged boundary conditions. Outlet pressure matches measured back-pressure. The mapping is documented in the V&V plan VP-CBP-2022. Level 1 acknowledgement is met at MRL 2."
    }
  ],
