  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cpb-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cva-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are appropriately scoped to level 1 acknowledgement consistent with MRL 2 requirements per ASME V&V 40-2018 Table 3. The CFD hemolysis model is judged credible for identifying worst-case hemolysis operating conditions of the FDA generic centrifugal blood pump under CPB conditions as described in the bound Claim (https://uofa.net/morrison/claim/cpb-hemolysis-worst-case) and Requirement (https://uofa.net/morrison/req/cpb-hemolysis-mrl2) nodes. Decision: Accepted.",
