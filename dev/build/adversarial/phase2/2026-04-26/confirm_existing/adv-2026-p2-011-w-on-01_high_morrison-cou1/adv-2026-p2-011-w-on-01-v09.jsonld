      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver (ANSYS Fluent 2022 R1) must hold a documented V&V pedigree and release-controlled version history consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R1 is ISO 9001-certified; version control records, release notes, and regression-test logs were reviewed and satisfy MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks must demonstrate convergence consistent with the solver's stated discretization scheme.",
      "rationale": "Taylor-Green vortex and lid-driven cavity benchmarks confirm second-order spatial convergence. Code verification is documented in the solver's published verification suite."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis must show discretization error in hemolysis index below 10 % at the nominal operating point.",
      "rationale": "Three-level mesh refinement study (4.2 M, 12.6 M, 37.8 M cells) yields GCI of 4.7 % for hemolysis index at 3500 RPM / 5 L min⁻¹, exceeding the MRL 2 threshold. Achieved level 3 recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) must be replicated in simulation within stated measurement uncertainty.",
      "rationale": "FDA benchmark test conditions are reproduced in CFD setup within ±2 % of measured flow rate and ±0.5 RPM of target speed; blood analog viscosity matched to within ±1.5 % of reported value."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within ±15 % across the five validation operating points.",
      "rationale": "NIH predictions at all five operating points fall within ±11 % of experimental means; maximum deviation is 10.8 % at the lowest flow-rate condition. Criterion met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (NIH) must be directly traceable to the clinical hemolysis risk metric specified in the device submission requirement.",
      "rationale": "NIH is the regulatory-accepted metric for CPB hemolysis assessment (FDA guidance 2021); the requirement document explicitly maps NIH to the clinical endpoint of plasma-free hemoglobin elevation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating-range envelope, and fluid analog as the intended CPB device COU.",
      "rationale": "FDA generic centrifugal pump geometry is identical to the submission device; operating range (2000–4000 RPM, 3–7 L min⁻¹) spans the full CPB envelope; glycerol-water blood analog matches the protocol used in the experimental dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and mass-balance error must be documented; formal solver-error quantification not required at MRL 2.",
      "rationale": "MRL 2 does not require formal numerical solver error quantification beyond residual monitoring. Continuity and momentum residuals converge to <1×10⁻⁵; mass imbalance <0.01 %. Factor scoped to level 1 per MRL 2 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst training records must be on file; systematic use-error analysis not required at MRL 2.",
      "rationale": "Lead analyst holds relevant CFD certification; simulation setup was peer-reviewed by a second senior engineer. Formal use-error quantification not required at MRL 2 and is not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis power-law model must be documented with literature justification; sensitivity analysis not required at MRL 2.",
      "rationale": "SST k-ω turbulence model selected based on published rotating-flow benchmark studies; Giersiepen hemolysis power-law coefficients sourced from peer-reviewed literature. Model-form sensitivity analysis deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters (fluid properties, boundary conditions, geometry tolerances) must be traceable to measurement or published reference; uncertainty propagation not required at MRL 2.",
      "rationale": "All model inputs are traceable to the FDA benchmark protocol and material datasheets. Formal uncertainty propagation through model inputs is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental dataset must include sufficient replicates to establish a mean NIH reference value; statistical sample-size analysis not required at MRL 2.",
      "rationale": "FDA benchmark dataset provides triplicate measurements at each operating point, sufficient to establish reference means. Formal sample-size adequacy analysis is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation input parameters and experimental test parameters must be qualitatively documented; quantitative equivalency mapping not required at MRL 2.",
      "rationale": "A parameter-correspondence table mapping each experimental measurement to its CFD boundary-condition counterpart is included in the simulation report appendix. Quantitative equivalency analysis is not required at MRL 2."
    }
