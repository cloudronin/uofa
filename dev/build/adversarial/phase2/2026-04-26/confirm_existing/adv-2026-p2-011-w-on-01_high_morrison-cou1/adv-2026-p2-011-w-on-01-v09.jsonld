  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/dr-elena-vasquez",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. The six not-assessed factors are explicitly scoped out per ASME V&V 40-2018 Table 1 provisions for MRL 2 devices. NIH predictions agree with FDA benchmark data within the 15 % acceptance criterion across the full CPB operating envelope. The assessment team concludes that the CFD model provides sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device submission.",
