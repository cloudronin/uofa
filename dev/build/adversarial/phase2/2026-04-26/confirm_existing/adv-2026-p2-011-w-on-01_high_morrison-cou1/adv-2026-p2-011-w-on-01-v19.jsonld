      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented verification test suite and version-controlled release history consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was used; vendor-supplied verification test suite covers all relevant flow regimes. Version control and release notes confirmed. SQA level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical rotating-flow benchmark must confirm solver achieves at least first-order spatial accuracy.",
      "rationale": "Method of manufactured solutions applied to rotating annular Couette flow; observed order of accuracy 1.97, confirming second-order spatial discretization. Code verification requirement met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be reported for hemolysis index QoI; GCI < 5% on fine grid acceptable at MRL 2.",
      "rationale": "Three-level mesh refinement study performed (3.2M, 9.1M, 24.6M cells). GCI for scalar hemolysis index on fine mesh: 2.8%. Exceeds MRL 2 requirement; discretization error well-characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must overlap with the CPB operating envelope described in the device requirement specification.",
      "rationale": "FDA pump experimental dataset spans 2.5–5.5 L/min and 2000–3500 RPM, covering the CPB worst-case operating region identified in the requirement. Test conditions judged representative."
    },
    {
      "type": "CredibilityFactor",
