  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 non-assessed factors are appropriately scoped out per MRL 2 requirements. Discretization error (GCI 2.8%) and output comparison (NIA 0.91) provide sufficient confidence that the CFD model can identify worst-case hemolysis operating conditions for the Class II CPB device. The assessment team concludes that model credibility is sufficient to support the device submission decision within the intended use scope described in the requirement and claim documentation.",
