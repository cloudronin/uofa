      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement between predicted and measured hemolysis index must exceed 0.85 across validation operating points.",
      "rationale": "Normalized index of agreement computed as 0.91 across 12 operating points. Systematic overprediction at high RPM within experimental uncertainty bounds. Output comparison criterion satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must be directly linked to the clinical harm metric identified in the device requirement.",
      "rationale": "NIH is the regulatory-accepted surrogate for hemolytic risk in blood-contacting devices per FDA guidance. Direct mapping from computational QoI to clinical harm metric established and documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and a blood analog fluid with rheological properties within 10% of human blood at 37°C.",
      "rationale": "FDA generic centrifugal pump geometry used in both simulation and experiment. Glycerol-water blood analog (viscosity 3.5 mPa·s at 37°C) within 8% of reference human blood viscosity. Validation activity deemed sufficiently relevant to CPB COU."
    },
    {
