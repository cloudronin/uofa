      "name": "NIH benchmark comparison against FDA GCBP experimental dataset — GCI < 4%, NIH within 18% of experimental mean across 9 operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "PIV velocity field validation — mean absolute error < 0.12 m/s in impeller passage at design point"
    }
  ],
