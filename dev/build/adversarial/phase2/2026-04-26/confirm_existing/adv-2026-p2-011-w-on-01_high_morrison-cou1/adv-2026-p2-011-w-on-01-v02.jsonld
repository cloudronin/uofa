      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison-cpb",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark experimental data for CPB operating conditions"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-flow-characteristic-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-flow characteristic validation across CPB operating envelope"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043872",
