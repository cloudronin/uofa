  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA process consistent with MRL 2 requirements, including version control and regression testing records.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under an ISO 9001-certified QA framework. Version control, regression test suite results, and release notes are archived. Achieved level 2 satisfies the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equations implemented in the CFD solver must be verified against analytical or manufactured solutions for relevant flow regimes at MRL 2.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver for laminar and low-Reynolds turbulent regimes. Observed convergence rates match theoretical order of accuracy. Code verification is documented and meets MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Spatial and temporal discretization errors must be estimated and shown to be negligible relative to model outputs relevant to hemolysis prediction at MRL 2.",
      "rationale": "Richardson extrapolation performed on three systematically refined meshes (4.2 M, 11.7 M, 28.4 M cells). Grid convergence index for hemolysis index QoI is 1.8%, well below the 5% acceptance threshold. Achieved level 3 exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be sufficiently characterized and documented to permit meaningful comparison with simulation boundary conditions.",
      "rationale": "FDA benchmark experimental data include full documentation of flow rates (2–8 L/min), rotational speeds (2000–3500 RPM), fluid properties (bovine blood analogue), and temperature. Boundary conditions in the CFD model are set to match these conditions within stated measurement uncertainties."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted quantities of interest must be compared against experimental measurements using a defined metric; agreement must be within acceptance bounds at MRL 2.",
      "rationale": "Normalized hemolysis index predictions agree with FDA benchmark experimental measurements within 12% across all tested operating points. Pressure head predictions agree within 8%. Both metrics satisfy the MRL 2 acceptance criterion of ≤15% normalized error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest computed by the model must be directly linked to the clinical and regulatory decision being supported — specifically, identification of worst-case hemolysis operating conditions for a Class II CPB device.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the accepted regulatory metric for blood damage assessment in CPB devices. Secondary QoIs (shear stress distribution, residence time) directly inform worst-case condition identification. Relevance to the intended decision is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the intended use — Class II CPB device operation — to support extrapolation of credibility to the COU.",
      "rationale": "Validation was performed using the FDA generic centrifugal blood pump geometry under CPB-representative operating conditions. Patient population variability (hematocrit, viscosity) is within the range covered by validation experiments. The validation domain adequately spans the COU operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative solver convergence and floating-point round-off errors are acceptable at MRL 2 if residual convergence to 1e-5 is demonstrated; formal quantification not required.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual monitoring is not required. All simulations converged to normalized residuals below 1e-6. This factor is not assessed beyond convergence monitoring; the achieved level meets the MRL 2 floor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use-error analysis is not required provided that simulation setup is performed by qualified personnel following documented procedures.",
      "rationale": "Simulations were executed by a CFD engineer with documented training records. Setup procedures are captured in a controlled simulation plan. Formal use-error quantification is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty quantification is not required; selection of turbulence and hemolysis sub-models must be justified by reference to published literature.",
      "rationale": "The SST k-omega turbulence model and the Giersiepen-Wurzinger hemolysis power-law model are selected based on published validation studies for rotary blood pumps. Formal model-form uncertainty analysis is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, sensitivity analysis of model inputs is not required; input values must be traceable to published material property data or experimental measurements.",
      "rationale": "Blood viscosity, density, and hemolysis model constants are sourced from peer-reviewed literature and the FDA benchmark dataset. Formal input uncertainty propagation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal statistical characterization of test sample variability is not required; the source and preparation of blood analogue fluid must be documented.",
      "rationale": "FDA benchmark experiments used bovine blood with documented hematocrit (35±2%) and preparation protocol. Sample-to-sample variability characterization beyond this documentation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency analysis between validation experiment inputs and COU inputs is not required; qualitative correspondence must be documented.",
      "rationale": "Qualitative correspondence between validation experiment operating conditions (flow rate, rotational speed, fluid properties) and the CPB clinical operating envelope has been documented in the simulation plan. Formal equivalency quantification is not required at MRL 2."
    }
  ],
