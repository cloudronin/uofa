  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required levels for MRL 2. The 6 non-assessed factors are appropriately scoped out under MRL 2 requirements with documented justification. The CFD hemolysis model is accepted as sufficiently credible to support identification of worst-case hemolysis operating conditions for the Class II CPB device. The requirement record (https://uofa.net/morrison/req/cpb-hemolysis-mrl2) and claim record (https://uofa.net/morrison/claim/cpb-hemolysis-worst-case-identification) together define the intended-use scope and acceptance basis for this assessment.",
