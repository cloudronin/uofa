  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with traceability to release version used in this analysis.",
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) has a published V&V test suite; however, traceability documentation linking the specific release to the test suite results is incomplete. Achieved level 3 falls short of the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must confirm second-order spatial convergence on hemolysis-relevant flow metrics.",
      "rationale": "Order-of-accuracy tests were performed on simplified geometries and confirmed second-order convergence for velocity; hemolysis scalar transport was only tested at first-order. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must bound discretization error to within 5% for hemolysis index predictions.",
      "rationale": "Three-level mesh refinement study was conducted; Richardson extrapolation yields a discretization error bound of approximately 8% on the hemolysis index, exceeding the 5% threshold. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within stated uncertainty bounds for all 5 flow-speed combinations.",
      "rationale": "Test conditions were matched for 4 of 5 flow-speed combinations. The fifth operating point (6 L/min, 3500 RPM) was not replicated in the validation experiment due to facility limitations. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) must be reported with uncertainty bounds for all primary QoIs.",
      "rationale": "Hemolysis index predictions were compared against in-vitro measurements. Relative errors ranged from 12% to 31% across operating points. Uncertainty bounds on experimental measurements are partially reported; bounds on CFD predictions are absent. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoIs must include the normalized index of hemolysis (NIH) and modified index of hemolysis (MIH) directly relevant to the clinical acceptance threshold.",
      "rationale": "NIH is validated against in-vitro data. MIH was computed but not directly compared against experimental reference data. The clinical threshold mapping from NIH to patient safety margin is documented. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, blood analog fluid, and rotational speed range as the COU.",
      "rationale": "Validation used the FDA generic pump geometry with a glycerol-water blood analog. Actual VAD operating speeds (2200–3800 RPM) were only partially covered (2500–3000 RPM in validation). Fluid rheology of the blood analog was not characterized at all test temperatures. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point error contributions must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Iterative convergence was monitored via residual drop of 10^-5 but no formal solver error budget was constructed. This factor was flagged as an epistemic gap at MRL 5 and is not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition specification, and post-processing scripts must be documented.",
      "rationale": "No independent review of simulation setup was performed. Boundary condition scripts were not version-controlled. This factor is not assessed and represents an epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis power-law model must be justified against literature data for rotating blood-contacting devices at the relevant Reynolds number range.",
      "rationale": "The SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power law were selected without systematic sensitivity analysis against alternative model forms. No model-form uncertainty quantification was performed. Not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs (viscosity, density, hemolysis model coefficients) must be characterized with probability distributions and propagated via Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ was initiated but the input distributions for hemolysis model coefficients (alpha, beta) were taken from a single literature source without inter-laboratory variability. The UQ is incomplete. Not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
