      "factorStatus": "assessed",
      "acceptanceCriteria": "Bench-top experiments conducted at all five CFD operating points with fully characterised fluid properties and boundary conditions.",
      "rationale": "Experiments cover three of five operating points; fluid temperature and viscosity were logged but haematocrit variability between samples was not controlled. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E%) with uncertainty bounds reported for each operating point; systematic bias characterised.",
      "rationale": "Comparison was reported as a scalar percent error without uncertainty propagation. Systematic bias across operating points was not separated from random scatter. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI is the normalised index of haemolysis (NIH) directly mapped to the clinical acceptance threshold.",
      "rationale": "NIH was used as the primary QoI, which is the clinically relevant metric. However, the mapping between NIH and the absolute clinical threshold was not formally documented in the assessment record. Achieved level 3."
