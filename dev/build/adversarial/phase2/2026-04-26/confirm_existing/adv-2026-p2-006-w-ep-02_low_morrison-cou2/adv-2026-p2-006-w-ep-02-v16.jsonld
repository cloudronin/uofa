  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the package based on the reported hemolysis index values falling below the absolute clinical threshold across all tested operating points, and the availability of Monte Carlo UQ results providing partial uncertainty coverage. Six factors remain not-assessed and all seven assessed factors fall below their required levels; however, the conservative safety margins in the hemolysis predictions were judged sufficient to support a conditional acceptance pending remediation of the identified gaps in a follow-on submission.",
