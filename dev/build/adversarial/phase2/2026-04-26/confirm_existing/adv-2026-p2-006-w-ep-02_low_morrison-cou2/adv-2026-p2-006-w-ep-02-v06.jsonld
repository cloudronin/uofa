  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all active physics modules; independent review of QA records.",
      "rationale": "The CFD solver (OpenFOAM v8) is under version control and has a documented regression test suite. However, independent third-party review of QA records has not been completed, leaving achieved level below required for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including hemolysis transport; order-of-accuracy confirmed.",
      "rationale": "MMS was applied to momentum and continuity equations and demonstrated expected second-order accuracy. The hemolysis power-law damage accumulation model was not subjected to MMS verification, leaving a gap at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes; GCI reported for NIH QoI at all five operating points.",
      "rationale": "Richardson extrapolation was performed on three meshes (coarse 4 M, medium 8 M, fine 16 M cells). GCI values for NIH were below 8% on the fine mesh at four of five operating points; operating point 1 showed 14% GCI, indicating insufficient mesh convergence for the primary QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow waveform, fluid temperature, hematocrit) documented and matched to simulation inputs within stated uncertainty bands.",
      "rationale": "Inlet flow rates and rotational speeds were matched to within 1% of nominal values. Fluid temperature was controlled to 37 ± 0.5 °C. Hematocrit was reported as nominal 35% but inter-sample variability was not quantified, introducing uncharacterized uncertainty in the damage model constants."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel or validation uncertainty ratio) computed for NIH at all operating points; metric compared against acceptance threshold.",
      "rationale": "Relative error in NIH ranged from 12% to 31% across the five operating points. The validation uncertainty ratio exceeded 1.0 at three points, indicating model error is not within combined experimental and numerical uncertainty. Achieved level 3 reflects partial quantitative comparison without full uncertainty decomposition."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validated QoI (NIH) is the same scalar used in the COU decision; no surrogate or proxy metric accepted.",
      "rationale": "NIH is directly used as the decision QoI. Validation experiments measured NIH via the modified Hemolysis Index protocol. The QoI is aligned, but the damage model exponents were calibrated on a different pump geometry, reducing relevance score."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic centrifugal pump geometry under VAD operating envelope; fluid properties representative of blood at physiological hematocrit.",
      "rationale": "Validation experiments used the FDA benchmark pump geometry, which matches the COU geometry. However, experiments were conducted at only three of the five COU operating points; the two additional points were interpolated. Fluid used was bovine blood rather than human blood, reducing physiological relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; round-off and floating-point error assessed for double-precision runs.",
      "rationale": "Iterative residuals were reported but no formal assessment of round-off error or floating-point arithmetic effects was performed. This factor was identified as an epistemic gap at MRL 5 and remains not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent re-execution of simulation by second analyst; comparison of results to confirm reproducibility.",
      "rationale": "No independent re-execution was performed. A single analyst team executed all simulations. Use error assessment is an epistemic gap flagged for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification provided for turbulence model selection (SST k-omega) and hemolysis power-law model; sensitivity to model form alternatives documented.",
      "rationale": "SST k-omega was selected based on prior FDA pump studies. A limited comparison with k-epsilon realizable was performed at one operating point, showing 18% difference in NIH. No sensitivity study for the hemolysis model exponents was conducted. Achieved level 2 reflects selection rationale without systematic form uncertainty quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo UQ on all uncertain model inputs (viscosity, hematocrit, damage constants); 95th percentile NIH reported with confidence interval.",
      "rationale": "Monte Carlo UQ was performed with 500 samples propagating uncertainty in fluid viscosity and inlet flow rate. Damage model constants C and alpha were held fixed at literature values; their uncertainty was not propagated. 95th percentile NIH exceeded clinical threshold at operating point 1, but incomplete input uncertainty coverage limits achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point; inter-sample variability reported as standard deviation of NIH.",
      "rationale": "Only single experimental runs were available for three of five operating points. Replicate data sufficient for statistical characterization of NIH variability were not collected. Test samples factor is an epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental boundary conditions and simulation inputs; equivalency metric computed for each input parameter.",
      "rationale": "A qualitative mapping table was provided but no formal equivalency metric was computed. The degree to which experimental conditions replicate the simulation boundary conditions has not been quantitatively established. This factor remains not-assessed at MRL 5."
    }
  ],
