  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps and achieved levels below required levels across all 13 factors, the assessment team accepted the package at Low assurance for the purpose of early-stage design screening. The team noted that validation results for hemolysis index and pressure rise were available from FDA generic pump experiments and that the CFD predictions fell within the reported experimental scatter bands at the two in-envelope operating points. The team acknowledged that provenance records for the validation results are incomplete — the experimental and simulation runs that generated the comparison data were described in the narrative but no structured activity records were linked — and flagged this as a documentation gap to be resolved before any regulatory submission.",
