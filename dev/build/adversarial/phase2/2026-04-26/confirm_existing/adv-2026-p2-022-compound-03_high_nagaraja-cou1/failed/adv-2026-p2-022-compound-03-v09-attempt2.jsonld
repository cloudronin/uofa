  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) operates under a documented quality management system with version control, regression testing, and audit trail. Required Gradation 2 for Model Risk Level 3.",
      "rationale": "Ansys Mechanical 2022 R2 is deployed under an FDA-recognized QMS. Version-controlled input decks are archived in the study repository. Regression test suite covers all element types used in the pedicle screw model. Achieved level equals required level; factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks demonstrate correct implementation of governing equations for linear elastic and contact mechanics problems representative of the pedicle screw COU.",
      "rationale": "Ansys Mechanical passes NAFEMS benchmarks LE1 and LE10 for linear elasticity and the Hertzian contact patch benchmark for nonlinear contact. Results documented in the software validation report SVR-2022-04. Achieved level equals required level; factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates that QoI predictions change by less than 2% upon mesh refinement from the production mesh density.",
      "rationale": "A three-level mesh convergence study (coarse 0.8 mm, medium 0.5 mm, fine 0.3 mm global element size in the screw shank) shows stiffness QoI convergence of 1.1% between medium and fine meshes. Production mesh uses 0.5 mm. Richardson extrapolation confirms GCI < 1.8%. Achieved level equals required level; factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge to below 1e-6 for all load steps; nonlinear contact iterations achieve equilibrium within prescribed tolerances.",
      "rationale": "All quasi-static load steps converge with force residual norm below 1e-6. Contact status monitored across all 11 specimen simulations; no spurious contact openings detected. Three independent FEA implementations (FDA ABAQUS, Ansys, DePuy Synthes SIMULIA) agree to within 3% on all QoIs, confirming solver-independence. Achieved level equals required level; factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of boundary conditions, material assignments, and load application to preclude operator error.",
      "rationale": "Simulation workflow documented in SOP-FEA-2021-07. An independent analyst (DePuy Synthes) reproduced the FDA model setup from the SOP without access to the FDA input files, then compared QoIs. Maximum deviation 2.3%. Use error risk assessed as low. Achieved level equals required level; factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions (linear elasticity for titanium alloy, frictionless-to-frictional contact sequence, small-strain kinematics) are justified relative to the physical regime of the ASTM F1717 test.",
      "rationale": "Ti-6Al-4V pedicle screw operates below yield for the stiffness QoI; linear elasticity is appropriate. Frictional contact (mu=0.2, titanium-on-UHMWPE) validated against published tribological data. Large-displacement effects negligible at the 40 mm crosshead travel given the construct geometry. Model form uncertainty estimated at 3.5% via sensitivity analysis. Achieved level equals required level; factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, nu, yield strength) and geometric dimensions sourced from certified material certificates and CMM measurements of the tested specimens.",
      "rationale": "Elastic modulus and Poisson's ratio for Ti-6Al-4V drawn from ASTM F136 material certificates (lot-specific). UHMWPE block properties from ISO 5834-2 certified stock. Screw geometry digitized by CMM with 2 µm accuracy. Input parameter uncertainty propagated via Monte Carlo (N=1000); 95th percentile output uncertainty 4.2%, within acceptance bound. Achieved level equals required level; factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 physical constructs from production-representative lots tested across two independent laboratories; specimen-to-specimen variability characterized.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production-representative hardware. Six specimens tested at FDA CDRH biomechanics laboratory; five at an independent contract laboratory. Coefficient of variation for stiffness 4.1%, yield force 5.7%, consistent with published F1717 reproducibility data. Sample representativeness confirmed by dimensional inspection. Achieved level equals required level; factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span at least two distinct loading configurations or environmental conditions to demonstrate model generalizability; required Gradation 3 for Model Risk Level 3 with Medium decision consequence.",
      "rationale": "Testing was performed exclusively under the standard ASTM F1717 compression-bending configuration at ambient temperature (23±2°C). No alternate loading angles, no physiological saline environment, and no fatigue loading conditions were explored within this validation activity. The single-condition limitation was identified during factor review but was not resolved prior to submission. The assessment team judged that multi-laboratory replication partially compensates for the single loading condition, and the decision was recorded as Accepted with the understanding that the factor shortfall is minor. Achieved level 2 falls below the required level 3 for this factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, material properties, boundary conditions) demonstrably correspond to the physical test configuration for each of the N=11 specimens.",
      "rationale": "Specimen-specific FEA models constructed using CMM-measured geometry for each of the 11 constructs. Boundary conditions replicate the F1717 fixture kinematics: fixed inferior block, actuator displacement applied at superior block centroid. Torque applied to pedicle screws matched to assembly records (4.5 N·m). Input equivalency confirmed by pre-test model predictions within 6% of experimental results for the first two pilot specimens before blinding was lifted. Achieved level equals required level; factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percent difference < 10% for all three QoIs across all 11 specimens.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy both acceptance criteria for all 11 specimens. Maximum E/uval observed: 1.83 (force at 40 mm, specimen 7). Maximum percent difference: 8.9% (force at 40 mm, specimen 3). Validation uncertainty uval computed per ASME V&V 20 combining experimental repeatability, input parameter uncertainty, and numerical error. Achieved level equals required level; factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical failure modes and regulatory decision being supported.",
      "rationale": "Construct stiffness governs load sharing between implant and bone graft; yield force is the primary safety-relevant metric for pedicle screw fracture risk; force at 40 mm displacement characterizes post-yield behavior relevant to fatigue life prediction. All three QoIs are explicitly referenced in FDA guidance for spinal implant 510(k) submissions. Relevance confirmed by a clinical biomechanics expert reviewer. Achieved level equals required level; factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities (ASTM F1717 bench test, N=11, two laboratories) are representative of the clinical COU in terms of construct geometry, loading mode, and implant material.",
      "rationale": "Validation specimens are production-representative non-cannulated 7.5 mm pedicle screws assembled into the standard F1717 two-level construct. The compression-bending load mode replicates the dominant in vivo loading of lumbar pedicle screws. Material (Ti-6Al-4V ELI) and surface finish match the intended commercial device. The two-laboratory design increases generalizability of the validation findings. Achieved level equals required level; factor satisfied."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors achieved the required credibility level. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — was considered in the context of the multi-laboratory validation design, the breadth of QoI coverage, and the consistent sub-threshold E/uval ratios across all specimens. The team concluded that the overall body of evidence supports a Medium assurance level and that the submission is acceptable for regulatory decision-making purposes. The Test conditions shortfall is noted as a limitation to be addressed in future validation activities covering alternate loading angles and physiological environments.",
    "decidedAt": "2026-04-19T00:00:00Z"
