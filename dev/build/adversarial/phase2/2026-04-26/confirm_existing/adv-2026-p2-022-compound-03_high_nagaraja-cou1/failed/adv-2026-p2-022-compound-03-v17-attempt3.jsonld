  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercially validated FEA solver with documented QA procedures and version control; test suite results on file.",
      "rationale": "Ansys Mechanical 2022 R2 employed with documented software QA per ISO 9001-certified development process. Verification test suite results archived. FDA CDRH internal Abaqus installation subject to equivalent institutional QA controls. Required and achieved level both Gradation 2 for model risk level 3 with medium decision consequence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Patch test and benchmark problems from NAFEMS or equivalent passed; element formulation documented.",
      "rationale": "Ansys and Abaqus solvers verified against NAFEMS benchmark set LE1–LE10. Hexahedral and tetrahedral element formulations confirmed against analytical cantilever beam solutions. Results within 0.5% of reference for all benchmark cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating <5% change in QoIs between successive refinements; reported GCI or equivalent.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw shank and rod interface regions. Stiffness QoI changed by 1.8% between medium and fine meshes; yield force changed by 2.3%. Grid Convergence Index reported as 1.1% for stiffness. Final mesh of 187,000 elements selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented; iterative solver tolerances set to 1e-6 or tighter for nonlinear analyses.",
      "rationale": "Nonlinear static analyses employ Newton-Raphson iteration with force residual tolerance 1e-6. Displacement residual tolerance 1e-8. All production runs achieved full convergence within 150 substeps. No diverged solutions observed across 11 specimen-specific models."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented model build procedure; independent peer review of boundary condition and load application setup.",
      "rationale": "Standard operating procedure for F1717 FEA model construction reviewed and approved by two independent analysts. Boundary conditions (fixed inferior block, displacement-controlled superior block) verified against ASTM F1717-15 test setup drawings. Load application direction and magnitude confirmed against laboratory test records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model and contact formulation justified by literature and sensitivity analysis; simplifying assumptions documented.",
      "rationale": "Bilinear isotropic hardening plasticity (Ti-6Al-4V: E=114 GPa, σy=880 MPa, Et=1.14 GPa) selected based on published material characterization data. Frictional contact (μ=0.2) at screw-rod interface validated against published tribological studies. Vertebral body block modeled as rigid per ASTM F1717 protocol. Model form sensitivity study confirms QoIs insensitive to ±20% variation in friction coefficient."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs traceable to specimen-specific measurements or certified material data; input uncertainty quantified.",
      "rationale": "Screw and rod geometry derived from certified engineering drawings with dimensional tolerances ±0.05 mm. Material certificates provided by DePuy Synthes for each production lot. Input uncertainty propagation via Monte Carlo (n=1000) yielded 95th-percentile prediction interval of ±8.4% on stiffness QoI, encompassing observed experimental scatter."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens representative of production design; traceability to manufacturing records documented.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs drawn from two production lots. Lot certificates confirm material and dimensional conformance to device master record. Specimens distributed across two independent laboratories (FDA CDRH biomechanics lab, n=6; contract laboratory, n=5) to assess inter-laboratory variability. Coefficient of variation across all specimens 6.3% for stiffness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; at minimum two distinct load levels or configurations evaluated.",
      "rationale": "Validation testing performed under a single load configuration (ASTM F1717 static compression-bending at 5 mm/min crosshead speed, ambient temperature). Clinically, pedicle screw constructs experience combined compression, torsion, and lateral bending; only the compression-bending mode is validated here. The required credibility level for test conditions at model risk level 3 is Gradation 3, but only Gradation 2 is achieved due to the single-condition protocol. The assessment team notes this shortfall in the factor rationale yet records the overall decision as Accepted, judging that the remaining twelve factors at or above required level provide sufficient compensating evidence — an inference that is not supported by ASME V&V 40 aggregation rules when any factor falls below its required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters demonstrably equivalent to test conditions; any differences quantified and their impact on QoIs bounded.",
      "rationale": "Crosshead displacement rate mapped to quasi-static loading assumption in FEA. Temperature equivalency confirmed (ambient 22±2°C; material properties at 22°C used). Fixture stiffness measured (48,200 N/mm) and incorporated into FEA boundary conditions. Residual differences in fixture compliance estimated to contribute <0.5% error to stiffness QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined a priori; validation metric accounts for experimental uncertainty.",
      "rationale": "Acceptance bounds (E/uval < 1.96, |%diff| < 10%) defined in validation plan prior to data unblinding. Experimental uncertainty (uval) computed from inter-specimen variability and inter-laboratory reproducibility using ASTM E691 approach. All three QoIs satisfy both acceptance criteria. Validation metric E/uval computed per ASME V&V 20 framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to the clinical failure modes and regulatory decision; mapping to COU documented.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the FDA guidance on spinal implant 510(k) submissions and directly reflect the structural performance attributes relevant to the regulatory decision. Clinical failure mode (screw fatigue fracture) is preceded by plastic deformation captured by yield force QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches COU geometry, loading, and material; any gaps between validation scenario and COU documented with impact assessment.",
      "rationale": "Validation constructs are the identical non-cannulated 7.5 mm pedicle screw design as the COU device. ASTM F1717 test configuration replicates the in vivo loading scenario at the L4-L5 level as standardized by ASTM. Gap analysis identifies that in vivo cyclic loading is not captured by the static validation; this is noted as a scope limitation but does not affect the static compression-bending COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors meet or exceed the required credibility level. The Test conditions factor achieves Gradation 2 against a required Gradation 3; however, the team judged that the strength of evidence across the remaining twelve factors, combined with the conservative acceptance bounds applied to the output comparison, provides sufficient overall confidence to support a Medium assurance level declaration and an Accepted decision for the non-cannulated 7.5 mm pedicle screw compression-bending COU. The declared Medium assurance level is considered commensurate with model risk level 3 and the medium model influence and decision consequence ratings.",
    "decidedAt": "2026-04-19T00:00:00Z"
