  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieves level 2 against a required level of 3; however, the team judged this shortfall acceptable given the regulatory scope is bounded to the ASTM F1717 condition and FEA sensitivity analyses demonstrate low QoI sensitivity to loading angle variation. All three QoIs satisfy the E/uval < 1.96 acceptance criterion. The multi-laboratory experimental dataset (N=11) provides robust reference data. The overall body of evidence is judged to support a Medium assurance level, and the submission is accepted for regulatory use within the stated COU.",
