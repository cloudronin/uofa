  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions (achieved level 1 vs. required level 2) — is acknowledged and judged acceptable given the multi-laboratory corroboration (N=11 constructs, two independent test sites), the strong quantitative agreement on all three QoIs (E/uval < 0.65 in all cases), and the regulatory precedent of ASTM F1717 as a standard acceptance method. The breadth of the verification and validation campaign, combined with the medium model risk level and medium consequence of decision, supports a Medium assurance level declaration. The submission is accepted for inclusion in the 510(k) dossier.",
