  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors achieved their required credibility level. One factor — Test conditions (achieved Gradation 2 vs. required Gradation 3) — falls below the required level due to testing under a single standardized F1717 protocol without variation in load rate, temperature, or orientation. The team judged this shortfall acceptable given: (1) the COU is explicitly bounded to the F1717 standardized test condition, (2) the multi-laboratory dataset (N=11, two independent facilities) provides strong empirical corroboration, and (3) all three primary QoIs satisfy both quantitative acceptance criteria (E/uval < 1.96, percentage difference < 10%). Overall assurance level declared Medium, consistent with model risk level 3 and medium decision consequence. Submission recommended.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
