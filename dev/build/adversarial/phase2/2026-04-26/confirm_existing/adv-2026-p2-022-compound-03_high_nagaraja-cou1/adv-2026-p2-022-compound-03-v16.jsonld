  "signature": "ed25519:b4e8d2f1c3a7e9b5d0f2c6a4b8e1d3f5c7a9b2d4e6f8c0a2b4d6e8f0c2a4b6d8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) used under institutional SQA plan with version control, regression test suite, and documented release qualification. Required Gradation 2.",
      "rationale": "Ansys Mechanical 2022 R2 deployed under an FDA-compliant SQA framework including version-controlled input decks, automated regression tests against NAFEMS benchmarks, and a formal software release qualification record. All three modeling teams operated under equivalent SQA controls. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via comparison to analytical solutions for beam bending and contact patch problems. Required Gradation 2.",
      "rationale": "The FEA code was verified against closed-form Euler-Bernoulli beam solutions and Hertzian contact benchmarks. Maximum deviation from analytical solutions was 0.6% for bending stiffness and 1.2% for contact pressure, well within the 5% code-verification tolerance. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study with GCI < 2% on all QoIs. Required Gradation 2.",
      "rationale": "Three-level mesh refinement study performed on the screw-rod interface region (coarse: 0.8 mm, medium: 0.5 mm, fine: 0.3 mm). Grid Convergence Index (GCI) for stiffness QoI was 1.1%; for yield force 1.4%. The production mesh (medium) was selected. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residual < 1e-6 and energy convergence < 0.1% per load step. Required Gradation 2.",
      "rationale": "Sparse direct solver (SPARSE) used for linear steps; Newton-Raphson with line search for nonlinear post-yield steps. Force residual norm < 1e-7 and displacement norm < 1e-6 achieved at every converged increment. Energy balance error < 0.05%. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by a second analyst not involved in construction. Required Gradation 2.",
      "rationale": "An independent senior FEA analyst reviewed all boundary condition definitions, contact pair assignments, material property inputs, and load application points against the ASTM F1717 standard and the laboratory test setup photographs. Two minor discrepancies (grip length offset of 0.5 mm, friction coefficient rounding) were corrected before the production run. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics with bilinear isotropic hardening plasticity for titanium alloy; contact modeled with augmented Lagrangian formulation. Required Gradation 2.",
      "rationale": "Ti-6Al-4V material behavior represented by bilinear isotropic hardening (E=114 GPa, σ_y=880 MPa, E_t=1.8 GPa) consistent with published coupon data. Augmented Lagrangian contact at screw-rod and rod-block interfaces captures load transfer without artificial penetration. Model form is well-established for metallic implant constructs. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports; geometry from calibrated CMM measurements. Required Gradation 2.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus derived from ASTM E8 tensile coupon tests on production-lot Ti-6Al-4V rod and screw stock (n=5 per lot). Geometry inputs derived from CMM measurements of 3 representative screws and rods, with dimensional tolerances propagated through a sensitivity analysis confirming <1.5% QoI sensitivity to ±0.05 mm geometric variation. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 production-representative constructs tested; lot traceability documented. Required Gradation 2.",
      "rationale": "Eleven (N=11) non-cannulated 7.5 mm pedicle screw constructs assembled from production-lot components tested across two independent laboratories (Lab A: n=6; Lab B: n=5). Lot numbers, assembly torque records, and dimensional inspection reports archived. Inter-laboratory coefficient of variation for stiffness was 3.8%, confirming acceptable reproducibility. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span at least two load configurations (e.g., varying offset distance or load angle) to characterize construct response space. Required Gradation 3.",
      "rationale": "Testing was conducted at a single ASTM F1717-prescribed load configuration (compression-bending at 5° offset, 70 mm lever arm). A second load configuration (10° offset) was planned but not executed due to laboratory scheduling constraints. A computational sensitivity analysis was performed post-hoc demonstrating that predicted stiffness varies by less than 3% across the 5°–15° offset range, and the team judged this computational evidence sufficient to characterize the response space. However, the absence of a second experimental configuration means only Gradation 2 is formally achieved against the Gradation 3 requirement. The team's narrative mitigation notwithstanding, this factor remains below its required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters traceable to experimentally measured values; no free calibration parameters. Required Gradation 2.",
      "rationale": "All FEA input parameters (geometry, material properties, boundary conditions, torque preload) were set from independent measurements prior to any comparison with experimental QoIs. No parameters were adjusted to improve agreement. Friction coefficient (μ=0.15) was taken from published tribological data for Ti-Ti interfaces under physiological-range loads and was not modified post-comparison. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric and percent difference; both thresholds must be satisfied simultaneously. Required Gradation 2.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfied both acceptance criteria simultaneously: percent difference <10% and E/uval <1.96. The most demanding QoI (yield force) achieved E/uval=1.43. Experimental uncertainty was characterized by the pooled standard deviation across both laboratories and propagated into uval using the ASME V&V 40 framework. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to clinical failure modes (construct stiffness governs fatigue life; yield force governs acute failure). Required Gradation 2.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly linked to the clinical failure modes of interest: cyclic loosening/fatigue (stiffness-governed) and acute overload fracture (yield force-governed). The 40 mm displacement metric captures post-yield energy absorption relevant to surgical revision planning. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on the same device geometry, material, and loading protocol as the COU. Required Gradation 2.",
      "rationale": "Validation constructs used production-representative non-cannulated 7.5 mm pedicle screws of the same alloy, heat treatment, and surface finish as the device submitted for regulatory review. The ASTM F1717 test protocol matches the mechanical loading scenario described in the COU. No surrogate geometries or scaled models were used. Gradation 2 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that Medium assurance is supported for COU1. Twelve of thirteen V&V 40 factors achieved their required levels. The single shortfall — Test conditions achieving Gradation 2 against a Gradation 3 requirement — was evaluated against the supplementary computational sensitivity analysis demonstrating <3% QoI variation across the plausible load-configuration space. The team concluded that the computational evidence, combined with the multi-laboratory experimental program (N=11) and the conservative dual-criterion acceptance thresholds, collectively provide sufficient grounds to accept the model predictions at Medium assurance. The decision was reviewed and endorsed by the principal investigator and an independent biostatistician.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
