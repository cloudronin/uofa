  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — was evaluated in the context of the overall evidence body. The ASTM F1717 protocol is inherently conservative relative to in vivo loading, and inter-laboratory reproducibility was demonstrated across two independent facilities. All three QoIs satisfy the pre-specified E/uval acceptance criterion with margin. The assessment team concluded that Medium assurance is supported and the model is Accepted for use in the regulatory submission.",
