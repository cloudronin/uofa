  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) under configuration management with documented version control, regression test suite, and change control log. Gradation 2 requires documented QA plan and evidence of controlled software environment.",
      "rationale": "Ansys Mechanical 2022 R2 is deployed under a validated software environment per the organization's ISO 13485-aligned QMS. A software QA plan documents version locking, regression test execution, and deviation handling. All three modeling teams (FDA, Ansys, DePuy Synthes) confirmed identical solver version. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions used to verify solver correctness for linear elastic beam bending and contact mechanics relevant to the COU. Gradation 2 requires documented benchmark comparisons.",
      "rationale": "Two benchmark problems were executed: (1) Euler-Bernoulli cantilever beam under end load — FEA result within 0.3% of analytical solution; (2) Hertzian contact between cylindrical bodies — peak pressure within 1.1% of closed-form solution. Both benchmarks documented in the model verification report. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating that QoI change is less than 2% between the penultimate and final mesh refinement levels. Richardson extrapolation or GCI reported.",
      "rationale": "A three-level mesh refinement study was performed on the pedicle screw shank and rod assembly. QoI (stiffness, yield force) changed by 0.8% and 1.1% respectively between mesh levels 2 and 3 (element count 142k to 387k). GCI for stiffness = 0.4%. Discretization error is negligible relative to experimental variability. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals documented; Newton-Raphson convergence criteria tightened to force residual < 1e-4 N and displacement residual < 1e-6 mm for all nonlinear load steps.",
      "rationale": "All nonlinear analyses converged with force residual norms below 8e-5 N and displacement residuals below 4e-7 mm across all 11 simulation runs. No divergence events recorded. Solver log files archived. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup reviewed by independent analyst; boundary conditions, material assignments, and load application independently verified against the simulation plan prior to execution.",
      "rationale": "An independent reviewer from the FDA modeling team performed a pre-execution review of the DePuy Synthes simulation setup. Boundary conditions (fixed inferior vertebral body block, applied displacement to superior block), material assignments (Ti-6Al-4V: E=114 GPa, yield 880 MPa), and contact definitions were verified against the simulation plan. One minor correction (friction coefficient 0.2 vs. 0.3 in draft) identified and corrected prior to execution. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection justified by material characterization data; contact formulation validated against known behavior; geometric simplifications documented with sensitivity analysis.",
      "rationale": "Bilinear isotropic hardening (BISO) constitutive model selected based on tensile coupon data for Ti-6Al-4V bar stock (n=5 coupons, E=114±2 GPa, yield 882±14 MPa). Augmented Lagrangian contact with 0.2 coefficient of friction validated against coupon-level screw-rod interface slip tests. Geometric simplifications (suppressed thread roots approximated as smooth shank with equivalent cross-section) validated via sub-model analysis showing <1.5% QoI sensitivity. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon testing; geometric inputs from CMM measurements of test articles; input uncertainty quantified and propagated to QoI uncertainty budget.",
      "rationale": "Geometry inputs derived from CMM measurements of three representative screws from the test lot (dimensional tolerance ±0.01 mm). Material properties from five tensile coupons machined from the same Ti-6Al-4V bar stock as the test articles. Input uncertainty propagated via Monte Carlo sampling (n=1000) yielding QoI uncertainty contributions: geometry ±0.9%, material ±1.4%. Combined model input uncertainty well characterized. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test articles from production-representative lot; dimensional inspection confirms conformance to nominal geometry; N≥10 samples providing statistical power for mean comparison.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab A: n=6, Lab B: n=5). All constructs assembled from production-representative components with dimensional inspection records. Inter-laboratory repeatability assessed; coefficient of variation for stiffness 4.2%, yield force 3.8%. Sample size provides 80% power to detect 8% mean difference at α=0.05. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios including at minimum two independent loading rates or construct configurations to demonstrate robustness of model predictions beyond a single test condition.",
      "rationale": "Testing was conducted exclusively under a single ASTM F1717 standard configuration: 10-degree lordotic angle, 35 mm rod span, quasi-static displacement rate of 5 mm/min at ambient temperature. While this configuration represents the regulatory standard, no additional loading rates, rod spans, or temperature conditions were explored. The model has not been validated against alternative construct configurations that may arise in clinical use. This limitation is acknowledged; the single test condition constrains confidence in model generalizability. Gradation 2 achieved against a required Gradation 3, representing a shortfall in this factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material properties, boundary conditions, loading) demonstrably equivalent to experimental test article and test setup parameters; traceability documented.",
      "rationale": "A parameter equivalency matrix was prepared mapping each simulation input to its experimental counterpart with traceability to measurement records. Rod span confirmed equivalent via CMM (simulation 35.0 mm, test 35.0±0.1 mm). Lordotic angle confirmed via fixture calibration certificate. Applied displacement rate equivalence confirmed via load cell and actuator calibration records. No unresolved equivalency gaps identified. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all QoIs; acceptance threshold pre-specified prior to unblinding of experimental results; all QoIs satisfy E/uval < 1.96.",
      "rationale": "Acceptance criteria (E/uval < 1.96, relative error < 10%) pre-specified in the simulation plan and registered with the study monitor prior to experimental data unblinding. Post-unblinding results: stiffness E/uval=0.84, yield force E/uval=1.12, force at 40 mm E/uval=1.31. All three QoIs satisfy both acceptance criteria. Comparison methodology follows ASME V&V 40 Section 5.3. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the regulatory decision question and to clinically meaningful failure modes; linkage documented.",
      "rationale": "Construct stiffness governs load sharing with the vertebral column and is directly relevant to adjacent segment disease risk. Yield force is the primary indicator of fatigue life initiation and regulatory acceptance under FDA guidance for spinal implant systems. Force at 40 mm displacement characterizes post-yield energy absorption relevant to intraoperative failure scenarios. All three QoIs are explicitly referenced in FDA's acceptance criteria for ASTM F1717 submissions. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities replicate COU geometry, material, loading, and boundary conditions; any deviations from COU are documented with sensitivity analysis demonstrating negligible impact on model credibility.",
      "rationale": "Validation constructs use the identical non-cannulated 7.5 mm screw geometry, rod material (Ti-6Al-4V, ASTM F136), and polyaxial head design as the COU device. ASTM F1717 test configuration matches the regulatory submission test protocol. The only deviation from the intended clinical COU is the use of a surrogate UHMWPE vertebral body block rather than cadaveric bone; sensitivity analysis using a range of block stiffness values (800–2400 MPa) showed QoI variation of ±2.3%, well within acceptance bounds. Gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors meet or exceed their required gradation levels. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — is noted and considered acceptable given that the ASTM F1717 protocol represents the regulatory standard configuration and all three QoIs satisfy pre-specified quantitative acceptance criteria with substantial margin (maximum E/uval = 1.31 against threshold 1.96). The overall body of evidence, including multi-laboratory testing, pre-specified acceptance criteria, independent model review, and comprehensive uncertainty quantification, supports a Medium assurance level determination. The model is accepted for use in the regulatory submission for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
