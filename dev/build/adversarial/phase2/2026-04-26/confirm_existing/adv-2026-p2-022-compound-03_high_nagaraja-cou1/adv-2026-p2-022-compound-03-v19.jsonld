  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors achieve Gradation 2, meeting or exceeding the required level for model risk level 3 with medium decision consequence. The single shortfall in Test conditions (achieved Gradation 1 against required Gradation 2) was considered in the context of the overall evidence package: inter-laboratory reproducibility across two independent test facilities, ensemble agreement across three independent modeling teams, and E/uval < 1.96 for all three primary QoIs collectively provide sufficient confidence that the single-condition test limitation does not materially undermine the credibility conclusion. The FEA framework is accepted for use in the regulatory submission for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending. Assurance level assessed as Medium, consistent with model risk level 3 and medium decision consequence, and supported by the breadth of corroborating evidence across teams and laboratories.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
