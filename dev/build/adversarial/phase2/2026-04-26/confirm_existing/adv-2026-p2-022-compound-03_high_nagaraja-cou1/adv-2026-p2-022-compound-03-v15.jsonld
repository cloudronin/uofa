  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors achieve their required credibility level. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is judged acceptable because: (1) ASTM F1717 specifies a single standard test condition that constitutes the regulatory reference; (2) all three QoI acceptance criteria are satisfied with comfortable margin (maximum E/uval 1.41 vs. threshold 1.96); and (3) sensitivity analyses on loading offset (±10 mm perturbation, not counted toward Gradation 3) confirm monotonic and bounded QoI response. The model risk level (3) and Medium model influence and decision consequence together map to a required credibility level consistent with the achieved profile. The assessment team declares Medium assurance and accepts the model for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
