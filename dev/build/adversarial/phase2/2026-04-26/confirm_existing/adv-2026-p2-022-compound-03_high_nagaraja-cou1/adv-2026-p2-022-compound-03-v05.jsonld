  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022R2 used under ISO 9001-certified QMS with version-controlled input decks; FDA CDRH benchmark suite run and documented.",
      "rationale": "All three FEA environments (FDA reference code, Ansys, DePuy Synthes internal solver) operate under documented quality management systems. Version control logs, benchmark test reports, and deviation records were reviewed and found compliant with required Gradation 2 practices. No open software anomalies affecting compression-bending predictions were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification against published ASME V&V 10 benchmark problems and FDA FEA benchmark suite; results within 1% of analytical solutions.",
      "rationale": "Ansys Mechanical and the FDA reference code were verified against three ASME V&V 10 benchmark problems relevant to contact mechanics and large-deformation elasto-plasticity. Maximum deviation from analytical reference was 0.7%. DePuy Synthes internal solver passed equivalent internal benchmark suite. Gradation 2 achieved across all three codes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study with at least three refinement levels; GCI < 1% on all primary QoIs.",
      "rationale": "A three-level mesh convergence study was performed on the non-cannulated screw geometry. Hex-dominant meshes with element edge lengths of 0.8 mm, 0.5 mm, and 0.3 mm at the screw-rod junction were evaluated. Grid Convergence Index (GCI) was 0.4% for stiffness, 0.6% for yield force, and 0.9% for force at 40 mm displacement. All values below the 1% threshold; Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Newton-Raphson residual norms < 1e-4 at each load step; energy convergence criterion applied.",
      "rationale": "Nonlinear solver convergence was monitored at each of 200 load increments. Force residual norms remained below 5e-5 throughout the loading history for all 11 simulated constructs. Energy convergence criterion of 1e-6 was satisfied. No divergence events or unconverged increments were recorded. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by engineer not involved in original analysis; documented review checklist.",
      "rationale": "An independent senior engineer reviewed boundary conditions, material assignments, contact definitions, and load application against the ASTM F1717 test protocol. A 47-item review checklist was completed with zero critical findings. Two minor observations (rod pre-tension specification and output request syntax) were resolved prior to final simulation runs. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elasto-plastic model with isotropic hardening; contact modeled with augmented Lagrangian penalty; justified by prior literature and material coupon data.",
      "rationale": "Ti-6Al-4V screw and rod material behavior was represented using a bilinear isotropic hardening model calibrated to ASTM E8 tensile coupon data (n=6 coupons per lot). Augmented Lagrangian contact with friction coefficient 0.2 (per Bergmann et al. 2012) was applied at all screw-rod and screw-block interfaces. Model form selection is consistent with published FDA guidance on metallic implant FEA and with three independent literature sources. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties from lot-specific coupon testing; geometric inputs from CMM measurement of each of the 11 test constructs; input uncertainty quantification documented.",
      "rationale": "Elastic modulus (mean 114.2 GPa, CV 1.1%), yield strength (mean 924 MPa, CV 2.3%), and ultimate strength (mean 1002 MPa, CV 1.8%) were derived from lot-specific tensile coupon data. Screw and rod geometry was measured by CMM to ±0.01 mm tolerance. Sensitivity analysis confirmed that ±1 standard deviation variation in material inputs produced less than 2.1% change in any QoI, well within acceptance bounds. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production-representative lots; dimensional inspection records available; inter-laboratory consistency confirmed.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production-representative lots and tested across two independent laboratories (FDA CDRH and DePuy Synthes internal). CMM inspection confirmed all constructs within drawing tolerances. Inter-laboratory coefficient of variation for stiffness was 3.2%, indicating acceptable consistency. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation testing performed at a minimum of two independent load configurations or boundary condition variants to confirm model generalizability beyond the single ASTM F1717 compression-bending configuration.",
      "rationale": "Testing was conducted exclusively under the ASTM F1717 static compression-bending configuration at a single crosshead displacement rate of 5 mm/min and a single vertebral body block spacing of 35 mm. No torsion, axial compression, or alternative spacing configurations were included in the validation dataset. The model's predictive fidelity under conditions deviating from this single configuration has not been experimentally confirmed. Although the ASTM F1717 protocol is the regulatory standard, the absence of any supplementary test condition means the achieved level of Gradation 2 falls short of the Gradation 3 required by the model risk level and decision consequence combination for this factor. This gap was noted by the assessment team but was not elevated to a hold-point; the overall assessment proceeded to an Accepted outcome."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material, boundary conditions) traceable to physical test setup; any discrepancies quantified and shown to have negligible effect on QoIs.",
      "rationale": "Simulation boundary conditions were derived directly from the ASTM F1717 fixture drawings and the measured construct geometry. The only identified discrepancy was a ±0.5° uncertainty in the screw insertion angle relative to the fixture centerline; sensitivity analysis showed less than 0.3% effect on stiffness and less than 0.8% effect on yield force. All other input parameters were matched to within measurement uncertainty. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and relative error < 10% for all three primary QoIs; graphical force-displacement curve overlay provided.",
      "rationale": "All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfied both acceptance criteria. E/uval values of 0.31, 0.84, and 1.41 are all below the 1.96 threshold. Relative errors of 0.47%, 1.3%, and 2.6% are all below 10%. Force-displacement curve overlays for all 11 constructs are provided in Appendix C. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) directly linked to clinical failure modes and regulatory submission requirements; linkage documented.",
      "rationale": "Construct stiffness is the primary indicator of immediate post-operative stability. Yield force characterizes the onset of permanent deformation associated with fatigue crack initiation. Force at 40 mm displacement is the regulatory endpoint required by FDA guidance for pedicle screw submissions. The traceability from each QoI to a specific clinical failure mode and regulatory requirement is documented in the requirements matrix (Appendix A). Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 compression-bending, non-cannulated 7.5 mm screw, production geometry) matches the COU scenario with documented similarity argument.",
      "rationale": "The validation activity directly replicates the COU: the same non-cannulated 7.5 mm screw design, the same ASTM F1717 test protocol, and the same loading mode (static compression-bending) as specified in the regulatory submission. The similarity argument is documented in the V&V plan (Section 4.2) and was reviewed by the FDA project manager. No extrapolation beyond the validated domain is claimed. Gradation 2 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-cdrh-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall in Test conditions (achieved Gradation 2 vs. required Gradation 3) was reviewed by the assessment team and judged acceptable given that the ASTM F1717 compression-bending configuration is the regulatory standard for pedicle screw submissions and that all quantitative acceptance criteria (E/uval < 1.96, relative error < 10%) were satisfied across all three primary QoIs. The overall credibility evidence is judged sufficient to support a Medium assurance level and an Accepted decision for the intended regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
