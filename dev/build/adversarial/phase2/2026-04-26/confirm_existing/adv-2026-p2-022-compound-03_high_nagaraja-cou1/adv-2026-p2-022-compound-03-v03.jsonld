  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors achieved their required credibility level. The single shortfall — Test conditions at Gradation 2 versus required Gradation 3 — was judged acceptable by the team on the basis that: (1) ASTM F1717 prescribes a standardized single test condition universally accepted by FDA; (2) inter-laboratory reproducibility across two independent facilities confirms experimental robustness; and (3) all three QoIs passed quantitative acceptance criteria with substantial margin. The team concluded that the overall evidence base supports a Medium assurance level and that the model is fit for the intended regulatory submission purpose. Decision: Accepted.",
