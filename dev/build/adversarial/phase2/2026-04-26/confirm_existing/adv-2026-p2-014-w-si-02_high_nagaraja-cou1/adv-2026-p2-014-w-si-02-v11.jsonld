  "hasRequirement": {
    "id": "https://uofa.net/nagaraja/req/cou1-noncannulated-acceptance",
    "type": "Requirement",
    "name": "Acceptance requirement for non-cannulated pedicle screw FEA credibility",
    "description": "The FEA modeling framework shall reproduce experimental ASTM F1717 compression-bending QoIs (stiffness, yield force, force at 40 mm displacement) within 10% mean percent difference and E/uval < 1.96 for the non-cannulated 7.5 mm pedicle screw construct. All 13 ASME V&V 40 credibility factors shall be assessed; aggregate credibility score shall meet or exceed the required level for Model Risk Level 3 with Medium model influence and Medium decision consequence.",
    "source": "ASME V&V 40-2018 Section 5 and FDA guidance on computational modeling submissions"
