  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical) operates under documented quality management system with version control, regression testing, and audit trail.",
      "rationale": "Ansys Mechanical v2022R2 is used under an ISO 9001-certified QMS. Version control and regression test suite documented. Achieved level 3 exceeds required level 2 for this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions demonstrate correct implementation of linear elastic and contact mechanics formulations.",
      "rationale": "Ansys Mechanical passes NAFEMS benchmark suite for linear static structural analysis including contact. Internal verification cases for beam bending and Hertzian contact confirm correct code implementation at required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinements; Richardson extrapolation applied to estimate discretization error.",
      "rationale": "Three-level mesh convergence study performed on the pedicle screw-rod construct. QoI (stiffness) changed 1.4% between medium and fine mesh. Richardson extrapolation yields discretization error estimate of 0.9%. GCI < 2% confirms adequate spatial convergence at required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge to machine precision tolerance; nonlinear contact iterations achieve force residual < 0.1% of applied load.",
      "rationale": "Direct sparse solver used for linear steps; augmented Lagrange contact formulation with force residual convergence criterion of 0.01 N against applied loads of ~500–2000 N. All load steps converge within tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review of model setup, boundary conditions, and post-processing scripts.",
      "rationale": "Model setup reviewed by independent analyst. Boundary conditions (fixed inferior vertebral body, axial compressive load with offset per F1717 geometry) independently verified. Post-processing scripts validated against manual calculations for three representative load cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics (linear elastic continuum with nonlinear frictional contact) justified for the compression-bending regime below yield; sensitivity analysis confirms negligible plasticity contribution.",
      "rationale": "Linear elastic material model with nonlinear frictional contact (mu=0.2) at screw-rod and rod-tulip interfaces. Sensitivity study confirms <3% QoI change when mu varied ±50%. Plasticity model not required for stiffness QoI; yield force QoI uses elastic limit criterion validated against experimental onset of nonlinearity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (Ti-6Al-4V elastic modulus, Poisson ratio) sourced from ASTM F136 and confirmed by coupon testing; geometric inputs from calibrated CMM measurements.",
      "rationale": "Ti-6Al-4V: E=114 GPa, nu=0.34 per ASTM F136 and confirmed by three-point bend coupon tests (CV<2%). Geometry from CMM measurements of production screws (n=5) with dimensional uncertainty <0.01 mm propagated through sensitivity analysis. Input uncertainty contribution to QoI uncertainty is 2.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 experimental constructs from production lots with documented traceability; dimensional inspection confirms conformance to nominal geometry.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs assembled per F1717 protocol. Constructs drawn from two production lots; dimensional inspection confirms all within drawing tolerances. Inter-laboratory consistency confirmed (Lab1 n=6, Lab2 n=5; no statistically significant difference in means, p=0.34)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of intended clinical loading; multiple load configurations or load levels evaluated.",
      "rationale": "Testing performed under a single ASTM F1717 load configuration (10 mm anterior offset, axial compression). While this is the standard regulatory configuration, it represents a single test condition. Clinical loading involves varying offset distances and combined loading modes not evaluated here. Achieved level 2 is below required level 3; this is a known limitation accepted by the credibility assessment team given the regulatory context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs (geometry, material, boundary conditions) demonstrably match experimental specimen conditions; differences quantified and propagated to QoI uncertainty.",
      "rationale": "Nominal FEA geometry matches CMM-measured specimen geometry within 0.01 mm. Material properties match coupon test data within 2%. Boundary condition equivalency confirmed by comparison of fixture stiffness (modeled rigid; actual fixture compliance <0.5% of construct compliance). Total input equivalency uncertainty contribution: 2.3% of QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; E/uval < 1.96 for all QoIs; mean percent difference < 10% for all QoIs.",
      "rationale": "All three QoIs (stiffness: E/uval=0.87, 4.2% diff; yield force: E/uval=1.21, 6.8% diff; force at 40 mm: E/uval=1.44, 7.1% diff) satisfy both acceptance criteria. Validation uncertainty uval computed per ASME V&V 40 Section 6 incorporating experimental measurement uncertainty and model input uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are the same quantities used in the regulatory submission and directly linked to the COU decision.",
      "rationale": "The three QoIs are identical to those specified in the FDA guidance for spinal implant computational submissions and are the direct outputs used in the regulatory credibility claim. No surrogate or proxy quantities are used; QoI relevance is direct and complete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the same device geometry, material, loading protocol, and QoIs as the COU; validation domain overlaps COU domain.",
      "rationale": "Validation constructs are production non-cannulated 7.5 mm pedicle screws tested per ASTM F1717, which is the identical protocol and device configuration as the COU. Validation domain (F1717 static compression-bending) directly overlaps COU domain. No extrapolation beyond validation domain required for the regulatory decision."
    }
