  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-required factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted because: (1) the single ASTM F1717 static compression-bending configuration is the definitive and only regulatory test condition for this device class; (2) model influence is Medium, meaning test data directly confirms FEA results; (3) all three QoIs pass quantitative acceptance bounds at both laboratories. Overall credibility is sufficient to support a Medium assurance level determination. The FEA framework is accepted for use in the 510(k) submission for the non-cannulated 7.5 mm pedicle screw system.",
    "decidedAt": "2026-04-19T00:00:00Z"
