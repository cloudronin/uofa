  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility level. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3; this shortfall is accepted because ASTM F1717 is a standardized regulatory benchmark and the single-condition limitation is consistent with industry practice for this device class. All three primary QoIs satisfy the pre-established quantitative acceptance criteria (E/uval < 1.96; relative difference < 10%). The FEA modeling framework is accepted as sufficiently credible to support the 510(k) submission for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
