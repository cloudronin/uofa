  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled FEA software with documented QA procedures; regression test suite executed prior to each analysis campaign.",
      "rationale": "Ansys Mechanical 2022 R2 used under ISO 9001-certified QMS. All solver versions recorded in analysis log. Regression suite of 47 benchmark cases executed; all passed within tolerance. SQA level exceeds required Gradation 2 for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verified against published analytical solutions or accepted benchmark problems relevant to structural contact mechanics.",
      "rationale": "Ansys Mechanical verified against NAFEMS benchmark LE1 and contact patch test. Results within 0.5% of analytical solution. Code verification documented in Ansys verification manual and confirmed by in-house replication."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study performed; discretization error estimated and shown to be below 5% for all QoIs.",
      "rationale": "Three-level mesh refinement study performed on pedicle screw shank and rod interface. Richardson extrapolation applied; GCI < 2.1% for stiffness QoI, < 3.4% for yield force. Final mesh selected at convergence plateau with ~1.2M elements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented; nonlinear solution monitored for force and displacement residuals below 1e-4.",
      "rationale": "Nonlinear static analysis with augmented Lagrange contact. Force residual norm < 1e-5 and displacement residual < 1e-6 at each converged increment. No diverged increments in any of the 11 model runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and loading by a second qualified analyst.",
      "rationale": "Model setup reviewed by independent analyst not involved in original construction. Checklist of 38 items verified including material assignment, contact definitions, load application points, and constraint equations. Two minor discrepancies identified and corrected prior to final runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics (continuum mechanics, contact, material nonlinearity) appropriate for pedicle screw bending; simplifying assumptions documented and justified.",
      "rationale": "Continuum FEA with elastic-perfectly-plastic titanium alloy (Ti-6Al-4V, E=114 GPa, sigma_y=880 MPa) and frictional contact (mu=0.2) at screw-rod interface. Thread geometry simplified to equivalent cross-section — documented as acceptable per prior FDA sensitivity study. Geometric nonlinearity enabled for large-displacement regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters sourced from measurements on test specimens; uncertainty in inputs quantified.",
      "rationale": "Screw geometry measured via CMM on three production samples; rod diameter and modulus from certificate of conformance. Material coupon tensile tests (n=5) provided elastic modulus 113.8±1.2 GPa and yield strength 884±9 MPa. Sensitivity analysis showed QoI variation < 2% over 2-sigma input range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens are production-representative; sample size sufficient for statistical comparison; traceability documented.",
      "rationale": "N=11 constructs assembled from production-lot screws and rods. Lot traceability documented. Specimens span two independent laboratories (FDA OSEL, n=6; DePuy Synthes, n=5) to assess inter-laboratory variability. Coefficient of variation in stiffness across specimens 3.8%, confirming acceptable manufacturing consistency."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions match ASTM F1717 protocol and span the range of clinical loading conditions relevant to the COU.",
      "rationale": "Testing performed per ASTM F1717 at a single load configuration (compression-bending at 5 degrees). Clinical loading spans a wider range of angles and combined loading modes not captured in this study. Achieved level limited to Gradation 2 because only one test condition was evaluated; this gap is acknowledged and accepted given the standardized nature of F1717 as a regulatory benchmark."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters demonstrably equivalent to test specimen parameters; differences quantified and shown to have negligible effect on QoIs.",
      "rationale": "Model geometry updated to match measured specimen dimensions (screw outer diameter 7.51±0.02 mm vs. nominal 7.50 mm; rod diameter 5.49±0.01 mm). Material properties from same production lot. Tightening torque applied as pretension element calibrated to 5 Nm per test protocol. Equivalency confirmed for all primary inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric applied; E/uval < 1.96 and relative difference < 10% for all primary QoIs.",
      "rationale": "All three QoIs satisfy acceptance criteria: stiffness E/uval=0.87 (4.2% diff), yield force E/uval=1.31 (6.8% diff), force at 40 mm E/uval=1.54 (7.4% diff). Uncertainty in validation metric includes experimental measurement uncertainty (load cell ±0.5%, displacement ±0.1 mm) and model parameter uncertainty propagated via Monte Carlo (500 samples)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to regulatory submission requirements and clinical failure modes of interest.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and referenced in FDA 510(k) guidance for spinal implants. These QoIs are directly linked to construct fatigue life prediction and clinical failure risk assessment. No surrogate or proxy QoIs used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, materials, loading, and boundary conditions are representative of the COU; any differences are bounded and justified.",
      "rationale": "Validation performed on the identical screw design, rod material, and F1717 test configuration as the COU. The only departure from full COU representativeness is the single loading angle (addressed under Test conditions factor). Validation activities judged sufficiently relevant to support Medium assurance level decision for the non-cannulated design."
    }
