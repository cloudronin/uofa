  "requirement": {
    "id": "https://uofa.net/nagaraja/req/fda-de-novo-biomechanical",
    "type": "Requirement",
    "name": "FDA De Novo biomechanical computational modeling submission requirement",
    "description": "Per FDA guidance on computational modeling and simulation (2023) and the De Novo request pathway for Class II spinal fixation devices, the sponsor must demonstrate that FEA predictions of construct mechanical performance under ASTM F1717 loading are within 10% of experimental measurements and that the validation uncertainty metric E/uval does not exceed 1.96. This requirement is the primary regulatory driver for COU1.",
    "source": "https://www.fda.gov/media/154985/download"
  },
