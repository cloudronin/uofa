  "signature": "ed25519:7a2f1c8e3b5d0946af2e4c71b9d03f6a8e1c5b2d7f4a9e06c3b1d8f5a2e4c71b9d03f6a8e1c5b2d7f4a9e06c3b1d8f5",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022 R2 used under ISO 9001-certified QMS; all solver benchmarks on record. Required Gradation 2 (documented QMS); achieved Gradation 3 (independent benchmark suite).",
      "rationale": "The modeling team employed Ansys Mechanical 2022 R2 under a documented ISO 9001-certified quality management system. An independent benchmark suite covering linear static, contact, and large-deformation problems was executed and archived. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufacturer verification documentation reviewed; patch-test and single-element checks passed for hex and tet element libraries used in construct model.",
      "rationale": "Ansys element technology (SOLID186, CONTA174) was verified against manufacturer-published benchmarks and supplemented by in-house patch tests. All checks passed within solver tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study across three refinement levels; GCI < 1% for all three QoIs (stiffness, yield force, force at 40 mm).",
      "rationale": "A structured mesh convergence study was performed at coarse (0.8 mm), medium (0.5 mm), and fine (0.3 mm) global element sizes. Richardson extrapolation yielded GCI values of 0.4%, 0.7%, and 0.9% for stiffness, yield force, and force at 40 mm respectively. All below the 1% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms < 1e-6 for all load steps; energy balance error < 0.1%.",
      "rationale": "Nonlinear solver convergence was verified at each load increment. Force residual norms remained below 1e-6 and energy balance error did not exceed 0.05% across all 11 specimen simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and material assignments by a second analyst not involved in primary model construction.",
      "rationale": "A second senior analyst independently reviewed all model inputs, boundary condition definitions, and material card assignments against the simulation plan. Two minor discrepancies (contact stiffness scaling factor, fixture geometry offset) were identified and corrected prior to final runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic constitutive model with isotropic hardening validated against titanium alloy coupon data; contact formulation captures screw-rod interface slip.",
      "rationale": "A bilinear isotropic hardening plasticity model (E=114 GPa, σ_y=880 MPa, E_t=1.2 GPa) was selected based on coupon tensile data for Ti-6Al-4V ELI. Augmented Lagrangian contact with μ=0.2 captures the screw-rod interface. Model form is consistent with prior published FEA studies of ASTM F1717 constructs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific tensile coupons (N=5 per lot); geometric dimensions from CMM measurements of test specimens (±0.01 mm).",
      "rationale": "Elastic modulus, yield strength, and tangent modulus were derived from lot-specific dogbone coupon tests (N=5 per material lot) performed concurrently with the construct tests. Screw and rod geometry was characterized by coordinate measuring machine with ±0.01 mm accuracy. Sensitivity analysis confirmed QoI variation < 2% across the measured input uncertainty ranges."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 production-representative constructs tested; specimens drawn from two independent manufacturing lots; both laboratories used calibrated test frames.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs from two manufacturing lots were tested across two independent laboratories (FDA CDRH lab and DePuy Synthes internal lab), both using calibrated servohydraulic test frames. Sample size provides adequate statistical power for the E/uval metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions should span at least two loading rates or two environmental conditions relevant to the COU. Only a single quasi-static loading rate (1 mm/min per ASTM F1717) was applied.",
      "rationale": "All bench tests were conducted under a single quasi-static loading rate (1 mm/min) at ambient temperature per ASTM F1717. No variation in loading rate or temperature was explored. This limits the ability to confirm model fidelity under physiologically relevant dynamic conditions. Achieved level is below required; this gap is noted in the decision record and accepted given the static nature of the intended use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters (geometry, material, boundary conditions) are demonstrated to be equivalent to the test specimen parameters within stated measurement uncertainties.",
      "rationale": "CMM-measured specimen geometry was used directly to parameterize each of the 11 individual FEA models. Material properties were assigned from the corresponding lot-specific coupon data. Boundary condition equivalency (fixture stiffness, grip compliance) was verified by comparing load-displacement curves in the elastic regime. Maximum input parameter discrepancy was 1.3% for rod diameter, within the stated ±0.01 mm CMM uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric per ASME V&V 40 Section 5; E/uval < 1.96 for all three QoIs; MAPE < 10%.",
      "rationale": "E/uval was computed as 0.87 (stiffness), 1.44 (yield force), and 1.81 (force at 40 mm). All three values are below the 1.96 threshold. MAPE values are 4.2%, 6.1%, and 7.8% respectively, all within the 10% acceptance bound. The output comparison criterion is satisfied for all QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The three QoIs (stiffness, yield force, force at 40 mm displacement) are directly specified in ASTM F1717 and are the biomechanical endpoints cited in the FDA De Novo regulatory requirement.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three primary endpoints specified in ASTM F1717 and are the exact biomechanical metrics required by the FDA De Novo submission pathway for spinal fixation devices. The QoIs are directly relevant to the COU and the regulatory decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation specimens are production-representative non-cannulated 7.5 mm pedicle screws tested under the identical loading protocol (ASTM F1717 compression-bending) as the intended use simulation.",
      "rationale": "The validation activity uses production-representative hardware from the same design family as the device under review, tested under the identical ASTM F1717 compression-bending protocol specified in the COU. Geometric and material equivalence was confirmed. The validation domain closely matches the intended use domain, supporting high relevance."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed their required credibility levels. One factor (Test conditions) achieved level 2 against a required level of 3 due to testing at a single quasi-static loading rate. This gap is accepted because the intended use is a static structural prediction, the ASTM F1717 protocol is quasi-static by definition, and the E/uval metric for all three QoIs is well within the 1.96 acceptance threshold. The overall credibility evidence is sufficient to support the medium model risk level and medium decision consequence classification. The package is accepted for submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
