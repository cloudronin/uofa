  "hasRequirement": {
    "id": "https://uofa.net/nagaraja/requirement/fda-sub-2024-001-model-credibility",
    "type": "Requirement",
    "name": "FDA Submission Model Credibility Requirement — Class II Spinal Implant",
    "description": "Per FDA guidance on computational modeling (2023), a Medium model risk level for a Class II spinal implant device requires demonstration of credibility at Medium assurance level across all 13 ASME V&V 40 factors. Acceptance bounds are: QoI relative difference < 10% and E/uval < 1.96 for each quantity of interest. This requirement governs the present COU1 credibility assessment.",
    "source": "FDA Guidance: Assessing the Credibility of Computational Modeling and Simulation in Medical Device Submissions (2023)",
    "requirementID": "FDA-SUB-2024-001"
  },
  "wasDerivedFrom": "https://doi.org/10.1115/1.4053565",
  "wasAttributedTo": "https://uofa.net/nagaraja/org/depuy-synthes-fda-ansys-collaboration",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e1d94b06f8e5a1c3d7b2f0e9a4c6d8b1f3e7a2c5d9b4f1e6a8c3d0b7f2",
  "signature": "ed25519:b2e4a7c1f3d6e9b0a5c8f2d4e7b1a3c6f9d2b5e8a1c4f7d0b3e6a9c2f5d8b1e4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented QA procedures for Ansys Mechanical and in-house FEA scripts; version control and regression testing in place.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated solver with documented V&V. In-house Python pre/post-processing scripts are version-controlled in Git with unit tests covering >85% of code paths. QA procedures exceed the required Gradation 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 suite solved; results within 1% of analytical solutions for linear elasticity cases.",
      "rationale": "Three ASME V&V 10 benchmark problems (thick-walled cylinder, cantilever beam, Hertzian contact) were solved with the same solver settings used in the pedicle screw model. All results within 0.8% of closed-form solutions, satisfying Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study with GCI < 5% for all QoIs at the production mesh density.",
      "rationale": "A systematic mesh refinement study (four mesh densities, refinement ratio 1.5) was performed. Grid Convergence Index for stiffness, yield force, and force at 40 mm displacement ranged from 0.9% to 2.3%, all below the 5% threshold. Richardson extrapolation confirms asymptotic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6 for all load steps; energy balance error < 0.1%.",
      "rationale": "Direct sparse solver (SPARSE) used for linear steps; iterative solver residuals monitored for nonlinear contact steps. Maximum residual 3.2e-7; energy balance error 0.04%. Both criteria satisfied at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by analyst not involved in original model development; documented checklist completed.",
      "rationale": "An independent senior FEA analyst reviewed boundary conditions, material assignments, contact definitions, and loading per a documented 47-item checklist. Two minor discrepancies identified and corrected prior to final simulation runs. Gradation 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear-elastic titanium alloy model with nonlinear frictional contact; model form justified by prior literature and sensitivity analysis.",
      "rationale": "Ti-6Al-4V linear elasticity is well-established for quasi-static F1717 loading below yield. Nonlinear frictional contact (μ=0.2, augmented Lagrange) captures screw-rod interface behavior. Sensitivity analysis showed model form uncertainty contributes <3% to QoI variance. Gradation 3 achieved through documented justification and sensitivity study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties from certified material test reports; geometry from production CAD with dimensional inspection report; uncertainty quantification performed.",
      "rationale": "Elastic modulus (114 GPa) and yield strength (880 MPa) sourced from lot-specific certified material test reports for Ti-6Al-4V ELI bar stock. CAD geometry verified against CMM dimensional inspection report (max deviation 0.03 mm). UQ via Monte Carlo (n=1000) over ±5% property ranges; QoI sensitivity coefficients documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥5 test samples from production lots with dimensional inspection; samples span two laboratories.",
      "rationale": "N=11 constructs tested (Lab 1: n=6, Lab 2: n=5), all from production lots with full dimensional inspection. Inter-laboratory coefficient of variation for stiffness was 3.1%, confirming sample consistency. Exceeds Gradation 2 minimum of N=5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two load levels or configurations representative of the clinical use envelope.",
      "rationale": "Testing performed at a single ASTM F1717 standard configuration (35 mm spacer block, 10° angulation). Clinical use spans a range of lordotic angles and spacer heights. Single test condition achieves Gradation 2 but not Gradation 3; this factor is below the required level and represents the sole credibility gap identified in this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and material inputs demonstrably equivalent to experimental setup; documented parameter mapping table.",
      "rationale": "A parameter mapping table was prepared cross-referencing each experimental setup parameter (fixture geometry, load application point, constraint locations, material certs) to corresponding FEA inputs. All 14 parameters mapped with documented justification. No unresolved discrepancies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; all QoIs satisfy E/uval < 1.96 and relative error < 10%.",
      "rationale": "Three QoIs compared: stiffness (E/uval=0.87, err=4.2%), yield force (E/uval=1.41, err=6.8%), force at 40 mm (E/uval=1.63, err=7.9%). All satisfy both acceptance criteria. Combined validation metric V=0.97 per ASME V&V 40 Section 5.3 scoring."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to regulatory submission endpoints and clinical failure modes.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and referenced in the FDA 510(k) submission template for spinal pedicle screw systems. Each QoI maps directly to a clinical failure mode (construct loosening, fatigue initiation, catastrophic fracture)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (geometry, loading, boundary conditions, material) sufficiently similar to COU to support extrapolation; documented similarity assessment.",
      "rationale": "Validation scenario uses production geometry, production material, and the exact ASTM F1717 test configuration specified in the COU. The sole difference from clinical use is the simplified boundary condition (rigid fixture vs. vertebral body); this difference is documented and bounded by a sensitivity study showing <8% QoI shift. Similarity assessment rated High per ASME V&V 40 Table 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficient factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is mitigated by the conservative nature of the single test condition (worst-case spacer height per FDA guidance) and by the strong quantitative validation results across all three QoIs (E/uval range 0.87–1.63, all <1.96; relative errors 4.2–7.9%, all <10%). The assessment team accepts the model as credible for the stated COU at Medium assurance level. A follow-on study incorporating additional test configurations is recommended prior to expanded COU claims.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
