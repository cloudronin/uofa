  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility levels. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3; this gap is accepted because the COU is explicitly scoped to ASTM F1717 compression-bending and no other loading mode is claimed. All three primary QoIs satisfy pre-defined quantitative acceptance criteria (E/uval < 1.96; percentage error < 10%). The FEA modeling framework is accepted as credible for supporting the non-cannulated pedicle screw compression-bending performance claim in the regulatory submission.",
