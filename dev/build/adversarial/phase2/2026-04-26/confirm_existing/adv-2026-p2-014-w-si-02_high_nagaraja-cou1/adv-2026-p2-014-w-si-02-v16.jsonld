    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps; contact penetration must remain below 1e-4 mm.",
      "rationale": "All static load steps converged with force residuals below 1e-7. Contact penetration monitored throughout; maximum penetration 3.2e-5 mm, within tolerance. Solver error contribution to total uncertainty is negligible."
