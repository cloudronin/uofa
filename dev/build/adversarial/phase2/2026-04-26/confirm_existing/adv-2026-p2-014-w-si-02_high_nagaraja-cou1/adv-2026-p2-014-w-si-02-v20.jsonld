  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022 R2 used under ISO 9001-certified QMS; FDA-validated solver version; documented V&V test suite for structural analysis modules.",
      "rationale": "DePuy Synthes simulation team operates under ISO 9001:2015 QMS. Ansys solver version 2022 R2 has documented FDA acceptance history. Internal SQA procedures include change control, regression testing, and audit trails. Achieved level 3 exceeds required level 2 for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarks against NAFEMS standard test cases LE1 and LE10 reproduced to within 1% of reference solution.",
      "rationale": "Ansys Mechanical code verification performed against NAFEMS LE1 (plane stress elliptic membrane) and LE10 (thick plate pressure) reference solutions. Both benchmarks reproduced within 0.4% and 0.7% respectively, satisfying the 1% acceptance criterion at gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates less than 2% change in all primary QoIs between medium and fine mesh densities. GCI < 5%.",
      "rationale": "Three-level mesh refinement study conducted on the pedicle screw shank and rod junction regions (coarse: 0.8 mm, medium: 0.4 mm, fine: 0.2 mm global element size). Maximum QoI change between medium and fine meshes was 1.3% for yield force. Richardson extrapolation-based GCI was 2.1%, below the 5% threshold. Final model uses medium mesh to balance accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Newton-Raphson residual force norm below 1e-4 at each converged increment; energy criterion below 1e-6.",
      "rationale": "Nonlinear quasi-static analysis converged with residual force norm 3.2e-6 and energy criterion 8.7e-8 at all load increments. No increment bisection failures observed. Contact status monitored across all titanium-titanium interfaces; no spurious penetration detected."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent model review by second analyst; documented simulation log with boundary condition and material assignment verification checklist.",
      "rationale": "Model setup reviewed by independent senior analyst against documented checklist covering boundary conditions, contact definitions, material assignments, and load application. All checklist items confirmed. Simulation log archived in PLM system with electronic signatures from analyst and reviewer."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic constitutive model with isotropic hardening; Ti-6Al-4V material parameters from coupon testing; frictional contact at all interfaces.",
      "rationale": "Bilinear isotropic hardening model calibrated to Ti-6Al-4V dog-bone coupon tensile data (n=5 specimens, R²=0.998). Frictional contact (μ=0.2, titanium-on-titanium) applied at screw-rod and rod-block interfaces. Model form captures dominant failure mode (screw shank bending) and has been validated in three prior pedicle screw studies with consistent QoI agreement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties from batch-specific coupon testing; geometry from CMM-verified CAD; torque-tension correlation from assembly testing.",
      "rationale": "Ti-6Al-4V elastic modulus, yield strength, and tangent modulus sourced from batch-specific tensile coupon testing (same material lot as bench test constructs). Screw and rod geometry verified against CMM measurements of production parts. Screw set-screw preload estimated from torque-tension correlation testing (n=10 assemblies). Input uncertainty quantified and propagated via Monte Carlo sampling (n=500 runs)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test constructs assembled from production-representative components; dimensional inspection confirming conformance to CAD nominal.",
      "rationale": "N=11 constructs assembled from production-representative 7.5 mm non-cannulated pedicle screws, 5.5 mm titanium rods, and UHMWPE blocks per ASTM F1717. Components sourced from the same manufacturing lot as clinical product. Dimensional inspection of 3 screws and 3 rods per lot confirmed conformance within ±0.05 mm of CAD nominal. Tests split across two independent laboratories to assess inter-laboratory reproducibility."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate clinical loading envelope including at least two distinct load magnitudes or configurations; environmental conditioning applied.",
      "rationale": "Testing performed under ASTM F1717 standard conditions (ambient temperature, displacement-controlled at 5 mm/min, single compression-bending configuration). Only one load configuration tested; clinical loading involves a range of postures and magnitudes not captured by the single ASTM protocol. This factor is below the required level 3 and represents a known gap in the validation evidence. Risk accepted based on the conservative nature of the ASTM F1717 protocol relative to in vivo loading."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions, loading) demonstrably matched to test specimen measurements and test machine configuration.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 fixture geometry: UHMWPE block dimensions, screw insertion depth (40 mm), and inter-screw spacing (44 mm) all matched to measured test specimen values. Displacement-controlled loading applied to FEA consistent with test machine protocol. Material properties matched to same lot as test specimens. Equivalency verified via pre-test simulation prediction followed by blinded comparison to experimental results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using normalised validation metric E/uval < 1.96 for all primary QoIs; uncertainty in both experimental and simulation results accounted for.",
      "rationale": "Normalised validation metric E/uval computed for stiffness (0.87), yield force (1.21), and force at 40 mm (0.54), all below 1.96. Experimental uncertainty estimated from inter-specimen and inter-laboratory variability (COV 4–7%). Simulation uncertainty from Monte Carlo propagation of material and geometry inputs (COV 2–5%). All three QoIs satisfy the acceptance criterion, supporting model adequacy for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) directly linked to clinical performance endpoints and regulatory acceptance criteria.",
      "rationale": "Construct stiffness correlates with immediate postoperative stability. Yield force is the primary fatigue surrogate under cyclic loading. Force at 40 mm displacement characterises post-yield energy absorption and implant survivability. All three QoIs are referenced in FDA guidance for spinal implant 510(k) submissions and are directly comparable between FEA and bench test, satisfying relevance at gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 compression-bending) is the same scenario as the COU; same device geometry, same loading mode, same QoIs.",
      "rationale": "The validation activity is identical in scope to the COU: same non-cannulated 7.5 mm pedicle screw geometry, same ASTM F1717 compression-bending protocol, same three QoIs. There is no extrapolation of the validation evidence to a different loading mode or device variant. The validation directly supports the submission claim, achieving the maximum relevance gradation for this factor."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for a Medium model risk, Medium decision consequence COU. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted on the basis that the ASTM F1717 protocol is conservative relative to in vivo loading and that all three primary QoIs satisfy quantitative acceptance bounds. The overall credibility evidence is sufficient to support the 510(k) substantial equivalence claim for the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
