  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed the required credibility level for Medium model risk / Medium decision consequence. One factor (Test conditions) achieved level 2 against a required level of 3 due to testing at a single loading rate per ASTM F1717 protocol. This gap is accepted because: (1) ASTM F1717 prescribes a single standardized loading rate, making multi-rate testing non-standard for this device class; (2) sensitivity analysis demonstrates < 2% QoI variation across loading rates spanning 1–10 mm/min; and (3) the validation metric E/uval < 1.96 for all three QoIs confirms adequate predictive fidelity within the validated loading envelope. The overall credibility of the simulation evidence is sufficient to support the intended regulatory submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
