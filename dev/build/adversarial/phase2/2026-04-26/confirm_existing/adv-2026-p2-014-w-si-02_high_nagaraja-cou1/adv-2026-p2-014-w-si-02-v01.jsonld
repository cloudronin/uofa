  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted because the ASTM F1717 protocol is a standardized, FDA-referenced test method with no clinically motivated alternative configuration identified. All three QoIs satisfy pre-specified acceptance bounds (E/uval < 1.96; |ΔQoI| < 10%) across N=11 specimens at two independent laboratories. The FEA modeling framework is judged credible for supporting the 510(k) submission claim that the non-cannulated 7.5 mm pedicle screw construct meets ASTM F1717 performance requirements.",
