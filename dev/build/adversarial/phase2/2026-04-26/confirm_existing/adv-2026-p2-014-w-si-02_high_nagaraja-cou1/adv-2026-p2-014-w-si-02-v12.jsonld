  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for the non-cannulated 7.5 mm pedicle screw construct has demonstrated sufficient credibility for the intended regulatory use. All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors met or exceeded required levels. The single deficiency in Test Conditions (achieved level 2 vs. required level 3) was evaluated and accepted on the basis that: (1) ASTM F1717 is a standardized, single-condition protocol universally applied in this device class; (2) all three primary QoIs satisfied quantitative acceptance criteria with margin; (3) model uncertainty was explicitly characterized through a three-implementation ensemble. The overall credibility profile supports use of this FEA framework for the compression-bending performance submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
