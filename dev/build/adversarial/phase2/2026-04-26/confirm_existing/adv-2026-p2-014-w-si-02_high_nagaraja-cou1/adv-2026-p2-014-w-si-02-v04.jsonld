  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single shortfall — Test conditions (achieved 2, required 3) — is acknowledged and mitigated by: (1) the conservatism of the single test condition relative to in vivo loading, (2) strong performance on all other factors including output comparison (E/uval well below 1.96 for all QoIs), and (3) the medium model risk and medium decision consequence classification. The FEA modeling framework is judged credible for the stated COU. Submission to FDA 510(k) program recommended.",
    "decidedAt": "2026-04-19T00:00:00Z"
