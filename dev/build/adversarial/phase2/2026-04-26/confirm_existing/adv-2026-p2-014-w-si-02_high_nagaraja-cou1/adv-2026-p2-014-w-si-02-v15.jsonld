  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical R2022 R2 holds current ISO 9001 certification; FDA-recognized SQA documentation package on file. Version control and regression testing documented.",
      "rationale": "The FEA solver (Ansys Mechanical R2022 R2) is a commercially validated code with ISO 9001 quality management certification. Internal SQA documentation including version control records, regression test suite results, and change-control logs were reviewed. Achieved level exceeds the required level for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS and Ansys verification manual reproduced within solver tolerance. Patch test and cantilever beam benchmarks executed and documented.",
      "rationale": "Standard benchmark verification problems including the NAFEMS linear static benchmark suite and Ansys cantilever beam patch test were executed. All results reproduced reference solutions within stated solver tolerance (<0.1%). Code verification is considered adequate for the linear and nonlinear static analyses performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study performed on QoI (stiffness, yield force); Richardson extrapolation applied; GCI < 2% for all QoI.",
      "rationale": "A systematic mesh refinement study was conducted using three mesh densities (coarse, medium, fine). Richardson extrapolation applied to construct stiffness and yield force QoI. Grid convergence index (GCI) values of 1.4% and 1.8% were obtained for stiffness and yield force respectively, both below the 2% threshold. Discretization error is adequately characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear solver residuals converge to < 1e-6 for all load steps; energy balance checked at final load step.",
      "rationale": "Nonlinear static analyses used an iterative Newton-Raphson solver with convergence tolerance of 1e-6 on force residuals. All 11 model runs achieved convergence at all load steps. Energy balance was verified at the final load step (40 mm displacement). Solver error is considered negligible relative to other uncertainty sources."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by a second analyst; checklist-based review documented.",
      "rationale": "An independent analyst performed a checklist-based review of model setup including geometry import, material assignment, boundary conditions, contact definitions, and load application. Discrepancies identified during review were corrected prior to final simulation runs. Use error risk is considered adequately mitigated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic constitutive model with isotropic hardening validated against coupon-level material test data; contact formulation captures screw-rod interface behavior.",
      "rationale": "The model employs a continuum elastic-plastic constitutive law with isotropic hardening for titanium alloy (Ti-6Al-4V), calibrated against ASTM E8 tensile coupon data. Frictional contact (mu=0.2) is applied at the screw-rod interface, consistent with literature values. The model form is appropriate for the quasi-static compression-bending loading regime and has been validated at the component level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon testing; geometric dimensions from CMM measurements of test articles; input uncertainty quantified via Monte Carlo (N=1000).",
      "rationale": "Material elastic modulus, yield strength, and hardening parameters were derived from lot-specific ASTM E8 coupon testing (N=5 coupons per lot). Geometric dimensions were obtained from coordinate measuring machine (CMM) measurements of the actual test articles. Input uncertainty was propagated via Monte Carlo simulation (N=1000 runs) to establish model prediction intervals reported in the validation comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs assembled from production-representative components; dimensional inspection confirms conformance to design drawings; two independent laboratories.",
      "rationale": "Eleven test constructs were assembled using production-representative 7.5 mm non-cannulated pedicle screws and titanium rods. Dimensional inspection of all test articles confirmed conformance to design drawings within specified tolerances. Testing was conducted at two independent laboratories to assess inter-laboratory variability, which was found to be within 3% for all QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate ASTM F1717 protocol including load application rate, fixture geometry, and environmental conditions; multiple load rates assessed.",
      "rationale": "Testing was conducted per ASTM F1717 at a single crosshead displacement rate of 5 mm/min. While the protocol was followed rigorously, only one test condition (load rate) was evaluated. The required level of 3 calls for assessment across multiple test conditions; the single load rate constitutes a gap. This factor is below the required level and is flagged as a known limitation of the validation dataset. The overall credibility goal is nonetheless met given the strength of other factors."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs (geometry, material, boundary conditions) demonstrably matched to as-tested conditions; traceability documented for each test article.",
      "rationale": "For each of the 11 test constructs, a corresponding FEA model was constructed using the CMM-measured geometry and lot-specific material properties of that specific article. Boundary conditions replicate the ASTM F1717 fixture geometry as measured. Traceability between test article identity and model configuration is documented in the V&V report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; acceptance threshold E/uval < 1.96 at 95% confidence; relative difference < 10% for all QoI.",
      "rationale": "Quantitative output comparison was performed using the ASME V&V 40 E/uval validation metric. Validation uncertainty (uval) was computed as the combined standard uncertainty of experimental measurement uncertainty and model input uncertainty. E/uval values of 1.31, 1.74, and 1.88 were obtained for stiffness, yield force, and force at 40 mm respectively — all below the 1.96 threshold. Relative differences were 4.2%, 6.8%, and 7.5% respectively, all below 10%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (stiffness, yield force, force at 40 mm) are directly linked to clinical performance endpoints and regulatory submission requirements.",
      "rationale": "The three QoI — construct stiffness, yield force, and force at 40 mm displacement — are the primary outputs specified in ASTM F1717 and directly correspond to the biomechanical performance endpoints relevant to spinal fixation device safety. These QoI are accepted by FDA as appropriate surrogate measures for clinical performance in the 510(k) submission context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities replicate the COU loading regime, device geometry, and material system; validation domain encompasses the intended use domain.",
      "rationale": "The validation activities directly replicate the COU: the same non-cannulated 7.5 mm pedicle screw design, the same ASTM F1717 compression-bending loading regime, and the same titanium alloy material system are used in both the validation experiments and the intended use predictions. The validation domain is considered to encompass the intended use domain for the purposes of this submission."
    }
  ],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility goal is met. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single below-required factor (Test conditions, achieved 2 vs. required 3) is attributable to the single load rate evaluated per ASTM F1717 protocol; this limitation is considered acceptable given the quasi-static nature of the loading and the strong performance on all quantitative output comparison metrics (E/uval < 1.96 for all QoI). The FEA modeling framework is accepted as sufficiently credible for the stated context of use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
