  "hasContextOfUse": {
    "decisionConsequence": "Medium",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "deviceClass": "Class II",
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/nagaraja/req/21cfr820-fda-computational-modeling",
    "type": "Requirement",
    "name": "21 CFR 820.30(g) and FDA Computational Modeling Guidance Requirements",
    "description": "The FEA modeling framework must satisfy design validation requirements under 21 CFR 820.30(g) and conform to the FDA guidance document 'Reporting of Computational Modeling Studies in Medical Device Submissions' (2016). Specifically, the model must demonstrate sufficient credibility for the intended context of use, with all 13 V&V 40 credibility factors assessed and the overall credibility goal met. Acceptance bounds of <10% relative difference in quantities of interest and E/uval < 1.96 are pre-established per the regulatory submission plan.",
    "source": "https://www.fda.gov/regulatory-information/search-fda-guidance-documents/reporting-computational-modeling-studies-medical-device-submissions",
    "regulatoryBasis": "21 CFR 820.30(g)"
  },
