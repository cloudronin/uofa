  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) used under documented QMS with version control, regression testing, and audit trail. Required Gradation 2.",
      "rationale": "Ansys Mechanical is a commercially validated FEA solver with ISO 9001-certified QMS. Version 2022 R2 was used under a controlled license with documented regression test suite. All simulation runs logged with checksums. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems (NAFEMS LE1, LE10) reproduced within 1% of analytical solutions. Required Gradation 2.",
      "rationale": "NAFEMS linear elastic benchmark problems LE1 and LE10 were reproduced within 0.4% and 0.7% of analytical reference solutions, respectively, confirming correct code implementation for the linear elastic regime relevant to pre-yield stiffness prediction. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in all three QoIs between medium and fine mesh; Richardson extrapolation GCI < 1%. Required Gradation 3.",
      "rationale": "Three mesh densities evaluated (coarse: 42k elements, medium: 118k elements, fine: 334k elements). QoI changes between medium and fine mesh: stiffness 0.8%, yield force 1.1%, force at 40 mm 0.6%. Richardson extrapolation GCI for fine mesh: 0.31%. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals < 1e-6 for all load steps; energy balance error < 0.1%. Required Gradation 2.",
      "rationale": "Nonlinear Newton-Raphson solver converged with force residual norm < 1e-7 and displacement residual norm < 1e-7 for all 120 load increments across 11 model runs. Energy balance error < 0.05% for all runs. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and material assignments by a second qualified FEA analyst. Required Gradation 2.",
      "rationale": "Model setup, boundary conditions (fixed inferior vertebral body, displacement-controlled superior loading block), contact definitions, and material assignments were independently reviewed by a second FEA analyst not involved in model construction. Two discrepancies identified and corrected prior to final runs. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic material model with isotropic hardening justified by coupon-level material characterization; contact formulation validated against analytical slip solutions. Required Gradation 3.",
      "rationale": "Ti-6Al-4V rod and screw modeled with bilinear isotropic hardening (E=114 GPa, sigma_y=880 MPa, tangent modulus=1.2 GPa) derived from ASTM E8 coupon tests on production bar stock. UHMWPE vertebral body blocks modeled as linear elastic (E=1.1 GPa). Augmented Lagrange contact with friction coefficient 0.2 validated against analytical Hertz contact and slip solutions within 3%. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties measured from production lot specimens; geometry from CMM measurements of test articles; torque-controlled assembly replicated in model. Required Gradation 3.",
      "rationale": "Material properties derived from 10 tensile coupon specimens from the same production lot as test constructs (CV < 3% for E and sigma_y). Screw and rod geometry from CMM measurements (±0.01 mm). Set-screw preload torque (4 Nm) converted to bolt pretension force (1.8 kN) using calibrated torque-tension relationship. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lot; two independent laboratories; traceability of components documented. Required Gradation 3.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production components with full traceability (lot numbers, CMM dimensions). Testing split across two independent laboratories (Lab A: n=6, Lab B: n=5) to assess inter-laboratory variability. CV of experimental stiffness 4.2%, yield force 5.8%, force at 40 mm 3.9%. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple loading rates and two screw configurations tested to bracket COU loading conditions. Required Gradation 3.",
      "rationale": "Testing performed at a single quasi-static loading rate (5 mm/min) per ASTM F1717. Only the 7.5 mm non-cannulated screw was tested; no variation in screw diameter or rod diameter was included. This limits the ability to assess sensitivity to test condition variation. Gradation 2 achieved; below required Gradation 3. This shortfall is acknowledged and accepted given the deterministic quasi-static nature of the COU loading and the pre-specified acceptance bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs matched to measured test article parameters within stated tolerances; sensitivity analysis confirms QoI insensitivity to residual input uncertainty. Required Gradation 3.",
      "rationale": "Each of the 11 FEA models was individualized with CMM-measured geometry for the corresponding test construct. Material properties assigned from lot-averaged coupon data. One-at-a-time sensitivity analysis showed <2% QoI change for ±1-sigma variation in all material and geometric inputs. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric for all three QoIs; all E/uval < 1.96. Required Gradation 3.",
      "rationale": "Normalized model error E/uval computed per FDA guidance: stiffness E/uval=1.41, yield force E/uval=1.78, force at 40 mm E/uval=1.03. All three below the pre-specified threshold of 1.96. Percent differences: stiffness 6.2%, yield force 8.7%, force at 40 mm 5.1%, all within the 10% acceptance bound. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly specified in ASTM F1717 and are the same quantities used in the regulatory submission. Required Gradation 3.",
      "rationale": "The three QoIs are explicitly required by ASTM F1717-21 and are the quantities reported in the 510(k) submission comparative testing. The FEA QoIs are extracted using identical operational definitions (stiffness from linear regression of 10–60% load range, yield from 0.2% offset method, force at 40 mm from load-displacement curve). Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on the same device design, same material lot, same test standard, and same loading mode as the COU. Required Gradation 3.",
      "rationale": "Validation constructs are identical in design, material, and assembly to the COU device. Test standard (ASTM F1717), loading mode (compression-bending), and boundary conditions are directly representative of the regulatory submission test. No extrapolation of validation domain required. Gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment: 12 of 13 V&V 40 factors meet or exceed required level. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3 due to single-condition testing per ASTM F1717. This shortfall is accepted because (a) the COU loading is deterministically quasi-static with no rate dependence in the relevant deformation regime, (b) all three QoIs satisfy the pre-specified E/uval < 1.96 and <10% difference acceptance criteria, and (c) the model risk level 3 is offset by the direct experimental validation on production components. The FEA modeling framework is accepted as sufficiently credible to support the regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
