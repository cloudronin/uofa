  "signature": "ed25519:7c3e1a9f2b4d6e8c0a5f3b1d7e9c2a4f6b8d0e2c4a6f8b0d2e4c6a8f0b2d4e6c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 or higher: documented QA procedures, version-controlled code, and regression test suite in place.",
      "rationale": "All three FEA solvers (FDA in-house, Ansys 2022 R2, DePuy Synthes validated solver) operate under ISO 9001-compliant QMS. Version control via Git with tagged releases; regression test suite of 47 benchmark problems executed at each release. Achieved gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 or higher: code verified against analytical solutions or established benchmarks for relevant element types and contact formulations.",
      "rationale": "Ansys and FDA solvers verified against NAFEMS benchmarks LE1, LE3, and LE10 for solid and beam elements. Contact patch test and Hertzian contact benchmark passed to within 0.5%. DePuy Synthes solver carries independent third-party verification certificate. Achieved gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 or higher: mesh convergence study performed; GCI or equivalent error estimate reported for each QoI.",
      "rationale": "Mesh convergence study performed across three refinement levels (coarse ~85k elements, medium ~210k, fine ~520k). GCI for stiffness QoI: 1.8%; for yield force: 2.3%; for force at 40 mm: 1.6%. All below 5% threshold. Medium mesh selected for production runs. Achieved gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 or higher: iterative solver residuals monitored; Newton-Raphson convergence criteria documented and met for all load steps.",
      "rationale": "Implicit nonlinear solver with full Newton-Raphson; force residual tolerance 1e-4, displacement residual 1e-5. All 11 simulation runs converged without cutbacks for load steps through yield; post-yield large-deformation regime used arc-length control. Energy balance checked at each increment. Achieved gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 or higher: simulation inputs reviewed by independent analyst; boundary condition application documented and checked against ASTM F1717 fixture geometry.",
      "rationale": "Independent analyst review of all boundary conditions, material assignments, and contact definitions performed prior to production runs. Checklist-based review against ASTM F1717 fixture geometry confirmed correct saddle-block spacing (100 mm) and load application point. One minor discrepancy in initial contact offset corrected before final runs. Achieved gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 or higher: model form justified by literature precedent and sensitivity analysis demonstrating that simplifying assumptions do not materially affect QoIs.",
      "rationale": "Linear-elastic titanium alloy (Ti-6Al-4V) model form justified by literature (Nagaraja 2023, Rohlmann 2001) for sub-yield regime; bilinear isotropic hardening used for post-yield. Bone analogue (UHMWPE blocks) modelled as elastic-plastic. Sensitivity study showed <1% QoI change when cortical shell modelled explicitly vs homogeneous block. Frictional contact (mu=0.2) vs tied contact sensitivity: 3.1% on stiffness, within acceptance. Achieved gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 or higher: material properties sourced from traceable coupon tests on same material lot; geometric inputs from CMM measurements of test articles.",
      "rationale": "Ti-6Al-4V elastic modulus 114 GPa, yield strength 880 MPa from tensile coupon tests on same bar stock (certificate of conformance provided). UHMWPE block properties from compressive coupon tests (E=0.93 GPa). Screw geometry from CMM measurements of five production screws; mean dimensions used. Dimensional variability sensitivity: ±0.05 mm on root diameter produces ±2.1% stiffness change. Achieved gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 or higher: N≥10 test constructs from production lots with documented traceability; inter-laboratory reproducibility demonstrated.",
      "rationale": "N=11 constructs tested: 6 at Lab 1 (FDA CDRH), 5 at Lab 2 (DePuy Synthes). All screws from same production lot (lot 2022-NC-7.5); UHMWPE blocks from same supplier batch. Inter-laboratory CoV on stiffness 3.2%, yield force 4.1%. Traceability documentation complete. Achieved gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 or higher: multiple test conditions spanning the COU envelope tested; load rate sensitivity demonstrated.",
      "rationale": "All testing performed at a single quasi-static load rate (5 mm/min) per ASTM F1717. No variation in saddle-block spacing or load angle was explored. This limits achieved gradation to 2, which is below the required level of 3 for this factor. Known limitation documented; impact on submission assessed as low given that the COU is restricted to quasi-static loading. Accepted with documented justification.",
      "belowRequired": true
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 or higher: simulation inputs demonstrably equivalent to test article properties and test conditions; any discrepancies quantified.",
      "rationale": "Material properties extracted from same lot as test articles. Fixture geometry in FEA matches test fixture drawings to within CMM measurement uncertainty (±0.02 mm). Load application point and boundary conditions verified against test setup photographs. Residual torque on screw-rod interface not measured in test; sensitivity study shows <1.5% QoI effect over 0–4 Nm range. Achieved gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 or higher: quantitative comparison metric (E/uval) computed for each QoI; validation uncertainty uval includes both experimental and simulation uncertainty contributions.",
      "rationale": "E/uval computed for all three QoIs following ASME V&V 40 Section 5.4. Simulation uncertainty includes discretization (GCI), material property, and geometric input contributions combined via RSS. Experimental uncertainty includes measurement system uncertainty and inter-specimen variability. E/uval: stiffness 0.43, yield force 0.61, force at 40 mm 0.58 — all well below 1.96 threshold. Achieved gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 or higher: QoIs directly linked to clinical failure modes and regulatory decision; sensitivity of QoIs to model parameters documented.",
      "rationale": "Construct stiffness and yield force are the primary mechanical indicators of fatigue-relevant stress state in pedicle screws; force at 40 mm displacement characterises post-yield energy absorption. All three are specified in ASTM F1717 as acceptance metrics for 510(k) submissions. Sensitivity analysis confirms QoIs are the dominant model outputs for the compression-bending failure mode. Achieved gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 or higher: validation scenario geometry, loading, and boundary conditions are representative of the COU; any differences between validation scenario and COU are documented and their impact assessed.",
      "rationale": "Validation scenario uses the identical non-cannulated 7.5 mm screw geometry, UHMWPE bone analogue blocks, and ASTM F1717 fixture as will be used in the regulatory submission. The COU is specifically the F1717 test prediction, so validation and COU are essentially co-incident. No extrapolation beyond the validated configuration is claimed. Achieved gradation 3."
    }
  ],
