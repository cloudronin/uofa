  "signature": "ed25519:b7e2a4c9f1d3e6b0a8c5f2d4e7b1a3c6f9e2d5b8a1c4f7e0d3b6a9c2f5e8b1a4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA solver (Ansys Mechanical) with documented V&V, version control, and audit trail of simulation files.",
      "rationale": "Ansys Mechanical 2021 R2 used under institutional license with documented software qualification. Simulation input files archived in version-controlled repository. FDA-recognized software; gradation 2 achieved through documented solver benchmarks and institutional SOP compliance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Patch test and benchmark comparisons against analytical solutions for beam bending and contact mechanics.",
      "rationale": "Ansys Mechanical verified against NAFEMS benchmark suite. Internal patch test for linear hexahedral elements confirmed. Cantilever beam bending analytical solution reproduced within 0.3%. Code verification requirements at gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating <5% change in QoIs between successive refinements.",
      "rationale": "Three-level mesh convergence study performed on representative screw-rod construct. QoI change between medium and fine mesh: stiffness 1.8%, yield force 2.3%, force at 40 mm 1.5%. Convergence criterion satisfied; production mesh selected at medium refinement level for computational efficiency."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence below 1e-5 for all load steps; energy balance monitored.",
      "rationale": "Newton-Raphson iterative solver with force residual tolerance 1e-6. Energy balance error <0.1% across all 11 simulation runs. No unconverged load steps. Gradation 2 exceeded; solver error contribution to total uncertainty negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by second analyst; documented checklist for boundary conditions, material assignments, and contact definitions.",
      "rationale": "All 11 simulation configurations reviewed by independent senior analyst against documented pre-simulation checklist. Boundary condition application (ASTM F1717 fixture geometry) verified against physical fixture drawings. No use errors identified during review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification of constitutive model selection and contact formulation relative to observed failure modes; sensitivity analysis on model form assumptions.",
      "rationale": "Bilinear isotropic hardening plasticity adopted for titanium alloy screw and rod based on published material characterization. Augmented Lagrangian contact at screw-rod interface captures load transfer mechanism consistent with observed experimental failure modes (rod yielding at screw interface). Sensitivity to friction coefficient (0.1–0.3) showed <4% QoI variation. Model form gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing of production lot material; geometric dimensions from CMM measurements of test specimens.",
      "rationale": "Ti-6Al-4V elastic modulus and yield strength measured from dog-bone coupons from same production lot as test constructs (n=5 coupons per lot). Rod diameter and screw geometry confirmed by CMM measurements on three representative specimens. Input uncertainty quantified and propagated through simulation ensemble."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production-representative lots tested across two independent laboratories.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested: n=6 at Laboratory 1 (FDA CDRH), n=5 at Laboratory 2 (DePuy Synthes). All specimens from production-representative manufacturing lots. Inter-laboratory variability characterized; coefficient of variation <8% for all QoIs. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple test conditions spanning physiologically relevant loading envelope; at minimum two independent fixture configurations or load levels.",
      "rationale": "Testing performed under a single ASTM F1717 standard configuration (35 mm offset, quasi-static 1 mm/min displacement rate). Only one test condition evaluated; physiological load rate variation and offset distance sensitivity not explored. Achieved level 2 (single standardized condition); required level 3 not met. This known gap is accepted given the regulatory precedent for ASTM F1717 as the standard submission test and the conservative nature of the single worst-case offset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, material, boundary conditions) demonstrably equivalent to test specimen parameters within quantified tolerances.",
      "rationale": "Specimen-specific FEA models constructed using CMM-measured dimensions for each of the 11 constructs. Material properties assigned from lot-specific coupon data. Fixture geometry replicated from engineering drawings verified against physical fixture. Input parameter equivalency confirmed; no surrogate or nominal values used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; all QoIs satisfy E/uval < 1.96 and percent difference < 10%.",
      "rationale": "E/uval computed for all three QoIs across all 11 specimens: stiffness E/uval=0.81, yield force E/uval=1.43, force at 40 mm E/uval=1.12. All values below 1.96 threshold. Mean absolute percent differences: 4.2%, 6.7%, 5.1% respectively, all below 10% bound. Quantitative acceptance criteria satisfied at gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes and regulatory submission requirements; justification documented.",
      "rationale": "Three QoIs selected — construct stiffness, yield force, force at 40 mm displacement — directly correspond to ASTM F1717 standard output metrics and FDA 510(k) predicate comparison parameters. Stiffness relates to load sharing; yield force to fatigue life prediction; force at 40 mm to post-yield structural integrity. QoI relevance to COU fully justified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities replicate COU loading conditions, device configuration, and intended use scenario with documented similarity argument.",
      "rationale": "Validation specimens are production-representative non-cannulated 7.5 mm pedicle screws — identical configuration to COU device. ASTM F1717 test replicates the compressive-bending loading mode dominant in lumbar spinal fixation. Two-laboratory testing increases generalizability. Similarity argument between validation scenario and COU documented; no extrapolation beyond validated domain required for intended submission use."
    }
  ],
