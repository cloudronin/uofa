    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "FEA boundary conditions mapped directly to measured experimental setup parameters (grip separation, loading angle, actuator displacement rate). Equivalency confirmed by overlay of simulated and measured grip displacement histories."
    },
    {
