  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted at Medium assurance level. Twelve of thirteen credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted because the ASTM F1717 protocol defines a single standardized test condition and the model's intended use is bounded to that protocol. All three primary QoIs pass quantitative validation acceptance bounds (E/uval < 1.96, percent difference < 10%). The assessment team concludes the FEA framework is sufficiently credible for its intended use in supporting the 510(k) submission for the non-cannulated pedicle screw design.",
