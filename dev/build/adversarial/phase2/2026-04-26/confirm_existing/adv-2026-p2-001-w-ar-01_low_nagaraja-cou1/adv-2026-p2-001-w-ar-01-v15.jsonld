      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Solver convergence monitored via force and displacement residuals. Residual tolerance set to 1e-6 for all nonlinear iterations. No convergence failures observed across the 11-specimen ensemble. Standard commercial solver settings applied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Model setup followed documented simulation workflow. Standard practices applied."
    },
    {
      "type": "CredibilityFactor",
