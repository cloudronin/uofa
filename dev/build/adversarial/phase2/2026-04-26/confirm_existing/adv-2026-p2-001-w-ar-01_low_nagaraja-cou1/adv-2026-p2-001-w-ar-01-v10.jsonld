  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted despite Test conditions factor achieving Gradation 2 against a required level of 3. The shortfall is judged acceptable because ASTM F1717 prescribes a single standard test condition, leaving no practical basis for multi-condition testing within the standard's scope. All other 12 factors meet or exceed required levels. Quantitative validation metrics (E/uval < 1.96 for all QoIs; percent difference < 10% for all QoIs) provide sufficient confidence in model predictions for the intended regulatory submission.",
