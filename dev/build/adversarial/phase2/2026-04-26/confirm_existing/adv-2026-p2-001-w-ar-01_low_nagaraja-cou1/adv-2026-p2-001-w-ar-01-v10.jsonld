    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating <5% change in all three QoIs between successive refinement levels, with final mesh element size documented. Richardson extrapolation applied to confirm asymptotic convergence.",
      "rationale": "Mesh convergence study performed across three refinement levels (coarse 2 mm, medium 1 mm, fine 0.5 mm). QoI changes between medium and fine meshes were 1.8%, 2.1%, and 0.9% for stiffness, yield force, and 40 mm force respectively. Richardson extrapolation confirms asymptotic regime. Final mesh (1 mm global, 0.3 mm at screw-rod interface) adopted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Solver convergence confirmed via residual norm monitoring. Newton-Raphson iteration converged to force residual < 1e-4 N at each load step. No divergence or contact oscillation observed across all 11 model instances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Standard operating procedures followed for model setup. Independent reviewer checked boundary conditions and material assignments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form credibility at level 3 requires justification of constitutive model selection with reference to published literature and sensitivity analysis showing QoI insensitivity to plausible alternative model forms. Isotropic linear elastic titanium alloy (Ti-6Al-4V) model justified by strain levels remaining below yield in screw body during elastic regime QoI extraction.",
      "rationale": "Isotropic linear elastic constitutive model applied to Ti-6Al-4V screw and rod. Strain magnitudes at QoI extraction points confirmed below 0.2% yield strain. Sensitivity analysis comparing linear elastic vs. bilinear kinematic hardening showed <3% QoI difference in elastic regime. Model form selection justified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Level 3 requires that all material and geometric inputs be traceable to measured values with uncertainty bounds quantified. Coupon tensile tests (N=5 per lot) provide E and yield strength; CMM measurements provide geometric tolerances.",
      "rationale": "Material properties (E=114 GPa, nu=0.34) sourced from coupon tensile testing of same material lot (N=5 specimens). Geometric inputs derived from CMM measurements of test articles. Uncertainty in E estimated at ±3 GPa (1-sigma); propagated through model via one-at-a-time sensitivity. Input uncertainty contribution to QoI uncertainty quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "N=11 constructs tested across two independent laboratories. Samples drawn from production lot; lot traceability documented. Sample size sufficient for statistical comparison per FDA guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Testing performed under a single loading rate and ambient temperature condition per ASTM F1717. Only one test condition explored; loading rate sensitivity not assessed. Gradation 2 achieved; required level 3 not met due to absence of multi-condition testing. Accepted as minor gap given ASTM F1717 prescribes a single standard condition."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Model inputs matched to experimental conditions including fixture geometry, grip separation, and loading point location. Documented in model setup report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative output comparison at level 3 requires application of a validation metric accounting for both model prediction error and experimental uncertainty. E/uval metric (validation error normalized by combined uncertainty) must be <1.96 for all three QoIs, and percent difference between FEA prediction and experimental mean must be <10%.",
      "rationale": "E/uval computed for stiffness (0.84), yield force (1.21), and force at 40 mm (0.67). All values below 1.96 threshold. Percent differences: stiffness 3.2%, yield force 6.8%, 40 mm force 2.9%. All within 10% acceptance bound. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
