  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level 2 requires documented version control, regression testing suite, and traceability of solver inputs to outputs. Achieved level 3 additionally includes independent code review and issue-tracking records.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated FEA solver with documented SQA processes. The FDA in-house Python preprocessing scripts are version-controlled in Git with regression tests covering all boundary condition permutations used in this COU. DePuy Synthes supplied solver input decks with change-log documentation. Independent code review was performed by a second analyst prior to submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification at level 2 requires demonstration of correct implementation via benchmark problems with known analytical or manufactured solutions, and documented agreement within solver tolerance.",
      "rationale": "Patch tests and single-element benchmarks were executed for the hexahedral and tetrahedral element formulations used in the screw and vertebral block submodels. Results agreed with analytical solutions to within 0.3%, satisfying the solver manufacturer's stated verification tolerance. Benchmark documentation is archived in the project technical file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error at level 2 requires a formal mesh convergence study with at least three mesh refinement levels and a reported grid convergence index (GCI) or equivalent metric for each QoI.",
      "rationale": "A three-level mesh refinement study was conducted on the pedicle screw shank region (coarse: 0.8 mm, medium: 0.4 mm, fine: 0.2 mm global element size). GCI values for stiffness, yield force, and 40 mm displacement force were 1.8%, 2.1%, and 1.5% respectively, all below the 5% threshold. The medium mesh was selected for production runs balancing accuracy and runtime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Standard iterative solver tolerances were used. Residual convergence checks were performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Modeling procedures were documented and reviewed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form at level 3 requires documented justification of all constitutive laws, contact formulations, and geometric idealizations, with sensitivity analysis demonstrating that alternative plausible model forms do not materially alter QoI predictions (change <5%).",
      "rationale": "Linear elastic isotropic material was selected for the titanium alloy screw (Ti-6Al-4V, E=114 GPa, nu=0.34) based on the pre-yield loading regime of ASTM F1717. Contact between screw and UHMWPE vertebral body block was modeled as frictionless hard contact, consistent with published literature. Sensitivity runs replacing frictionless with frictional contact (mu=0.2) changed stiffness QoI by 1.8%, yield force by 2.3%, confirming model form robustness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs at level 3 requires that all material properties and geometric parameters are sourced from traceable measurements or certified material data sheets, with uncertainty bounds quantified and propagated to QoI.",
      "rationale": "Ti-6Al-4V material properties were taken from ASTM F136 certified coupon tests performed by DePuy Synthes (lot-specific tensile data). UHMWPE block modulus was measured by compression testing of representative blocks (mean 0.94 GPa, CV 4.2%). Geometric dimensions were measured from CMM data on three production screws. Monte Carlo propagation of input uncertainties contributed a combined QoI uncertainty of ±3.1% (1-sigma)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples at level 3 requires that experimental specimens are drawn from production-representative lots with documented dimensional and material traceability, and that sample size is sufficient to characterize inter-specimen variability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were assembled from production-lot hardware with certificate of conformance documentation. CMM measurements confirmed dimensional conformance to drawing tolerances for all 11 specimens. Sample size yields a coefficient of variation estimate with 90% confidence interval width <8% for all three QoIs based on observed standard deviations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Testing was conducted under a single ASTM F1717 loading condition (static compression-bending at 5 mm/min crosshead speed, ambient temperature). Only one test condition was evaluated; the required level 3 would demand at least two distinct loading rates or environmental conditions to bound model sensitivity. This factor is below the required level and is noted as a limitation of the current validation dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Input parameters were mapped between experimental and simulation domains."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison at level 3 requires a quantitative metric that accounts for both experimental uncertainty and simulation uncertainty, with a pre-specified passing threshold documented prior to unblinding of simulation results. The E/uval metric (ratio of model error to combined validation uncertainty) must be <1.96 for all QoIs.",
      "rationale": "The validation metric E/uval was computed for all three QoIs following FDA guidance (Hyman et al. 2022). Experimental uncertainty uexp was derived from the N=11 sample standard deviation combined with lab-to-lab bias estimated from duplicate testing at two facilities. Simulation uncertainty usim included discretization error (GCI) and input parameter uncertainty (Monte Carlo). Results: stiffness E/uval=0.82, yield force E/uval=1.14, 40 mm force E/uval=0.97. All values below 1.96 threshold, confirming adequate predictive accuracy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "QoIs are directly specified in ASTM F1717 and are clinically relevant."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Relevance of validation activities at level 3 requires that the validation scenario geometry, loading, and boundary conditions are demonstrably representative of the COU, with documented mapping between validation conditions and intended use conditions.",
      "rationale": "The validation activity directly replicates the ASTM F1717 test configuration that constitutes the COU. The non-cannulated 7.5 mm screw geometry, UHMWPE vertebral body block, and static compression-bending load application in the validation study are identical to the intended use scenario. No extrapolation of model predictions beyond the validated configuration is claimed."
    }
