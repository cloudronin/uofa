  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility is assessed as Medium. Twelve of thirteen credibility factors meet or exceed their required levels. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted because the single ASTM F1717 compression-bending condition represents the clinically dominant loading mode and the quantitative validation metrics (E/uval < 1.96, percent difference < 10%) are satisfied for all three QoIs. The model is accepted for use in supporting the 510(k) submission for the non-cannulated 7.5 mm pedicle screw construct.",
