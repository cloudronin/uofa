    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh convergence study must demonstrate that QoI values change by less than 5% between successive mesh refinements. Gradation 3 requires systematic h-refinement or p-refinement study reported with Richardson extrapolation or GCI.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw construct model. QoI values (stiffness, yield force, force at 40 mm) changed by less than 2.1% between medium and fine meshes. GCI was computed and reported in Appendix B of the study record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Default Ansys iterative solver tolerances were used. Residual convergence criteria were set to 1e-6 for force and displacement. No solver divergence events were recorded across the N=11 simulation runs."
    },
    {
