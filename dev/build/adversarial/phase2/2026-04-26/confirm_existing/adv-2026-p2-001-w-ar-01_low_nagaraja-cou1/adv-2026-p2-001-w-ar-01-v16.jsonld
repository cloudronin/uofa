  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility sufficient for intended use. Twelve of thirteen factors meet or exceed required level. One factor (Test conditions) achieved level 2 against required level 3; this shortfall is acknowledged and accepted because the ASTM F1717 protocol defines a single standardized test condition and multi-condition testing is not feasible within the standard framework. The remaining factors collectively provide adequate evidence that the FEA model reproduces compression-bending behavior within pre-established acceptance bounds.",
