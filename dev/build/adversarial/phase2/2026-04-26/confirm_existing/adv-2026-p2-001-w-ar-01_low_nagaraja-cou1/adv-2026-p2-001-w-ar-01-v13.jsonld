  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA solver (Ansys Mechanical) must hold current ISO 9001 certification and provide a documented software quality plan; FDA in-house code must pass regression test suite with zero critical failures.",
      "rationale": "Ansys Mechanical 2022 R2 holds ISO 9001:2015 certification. FDA in-house Python-based post-processing scripts are version-controlled in Git with unit-test coverage >85%. DePuy Synthes proprietary FEA environment holds internal SQA documentation reviewed by the sponsor quality system. All three codes exceed Gradation 2 requirements for software quality assurance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must reproduce published benchmark solutions (NAFEMS benchmarks LE1, LE3, LE10) within 1% of reference values for linear elastic problems representative of the pedicle screw geometry.",
      "rationale": "Ansys Mechanical passes NAFEMS LE1, LE3, and LE10 benchmarks within 0.3% of reference values as documented in the Ansys Verification Manual. FDA code reproduces identical benchmark problems within 0.8%. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Mesh convergence study performed across three mesh densities (coarse ~180k elements, medium ~420k elements, fine ~910k elements). QoI (peak von Mises stress at screw-rod junction) changed by less than 2% between medium and fine meshes. Medium mesh selected for production runs. Richardson extrapolation GCI < 3% for all three QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Direct sparse solver (SPARSE) used for all linear steps; nonlinear convergence tolerance set to 1e-4 on force and displacement residuals. Solver residuals logged and confirmed below tolerance for all load increments. No divergence or unconverged increments observed across any of the 11 simulation runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Simulation workflow documented in a controlled modeling report. Independent peer review performed by a second analyst. Boundary conditions, material assignments, and contact definitions verified against the modeling protocol prior to submission. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model must represent pedicle screw geometry with explicit thread representation or validated equivalent; contact between screw and rod must be modeled with friction; material nonlinearity (bilinear isotropic hardening) required for titanium alloy components.",
      "rationale": "Explicit thread geometry included for screw shank. Frictional contact (mu=0.2, Ti-Ti) applied at screw-rod and rod-block interfaces. Bilinear isotropic hardening material model calibrated from tensile coupon data for Ti-6Al-4V ELI. Model form judged appropriate for the compression-bending loading regime relevant to ASTM F1717."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties must be sourced from lot-specific tensile coupon testing of the same material heat used in bench specimens; geometric dimensions must be verified against CMM measurements of physical constructs.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus sourced from lot-specific tensile coupon testing (n=5 coupons, same heat as bench specimens). CMM measurements of screw and rod dimensions used to confirm CAD geometry. Uncertainty in material inputs propagated via Monte Carlo (n=500 samples); input uncertainty contribution to total QoI uncertainty is less than 4%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Bench test sample set must comprise N≥10 constructs from production lots; samples must span at least two independent laboratories to assess inter-lab variability.",
      "rationale": "N=11 constructs tested: 6 at Lab A (FDA), 5 at Lab B (DePuy Synthes). All constructs assembled from production-lot components. Inter-lab coefficient of variation for stiffness <4%, confirming acceptable reproducibility. Sample size sufficient for statistical comparison using the E/uval metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Testing performed under a single test condition (ASTM F1717 standard configuration, room temperature, displacement-controlled at 5 mm/min). Only one loading configuration evaluated; no variation in offset distance or load angle explored. This limits generalizability but is consistent with the regulatory submission scope. Factor assessed at Gradation 2, below the required level of 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Simulation boundary conditions mapped directly to ASTM F1717 test fixture geometry. Applied displacement rate converted to quasi-static loading assumption; inertial effects negligible at 5 mm/min. Fixture compliance measured and incorporated into simulation boundary conditions. Input parameter equivalency confirmed by overlay of simulated and experimental load-displacement curves in the elastic regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI percent difference must be <10% for all three quantities (stiffness, yield force, force at 40 mm); E/uval metric must be <1.96 for each QoI, confirming FEA prediction within combined experimental and simulation uncertainty.",
      "rationale": "Stiffness: 4.2% difference, E/uval=0.83. Yield force: 6.1% difference, E/uval=1.21. Force at 40 mm: 7.8% difference, E/uval=1.54. All three QoIs satisfy both acceptance criteria. Output comparison Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "QoIs selected are directly linked to clinical failure modes: construct stiffness governs load sharing with the vertebral column; yield force and force at 40 mm displacement are standard ASTM F1717 endpoints used in regulatory submissions. QoIs are well-established surrogates for in vivo performance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Validation activities replicate the exact regulatory test standard (ASTM F1717) applied to the same device design, material, and assembly configuration as the COU. Loading mode (compression-bending), fixture geometry, and outcome metrics are identical between validation and intended use context. High relevance confirmed."
    }
  ],
