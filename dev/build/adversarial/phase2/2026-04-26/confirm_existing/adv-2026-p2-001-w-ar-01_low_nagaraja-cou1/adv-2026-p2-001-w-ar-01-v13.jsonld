  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted at Medium assurance level. Twelve of thirteen V&V 40 factors meet or exceed required levels. Test conditions factor (Gradation 2 achieved vs. Gradation 3 required) represents a known limitation of the single-condition ASTM F1717 protocol; the shortfall is accepted given that the regulatory submission scope is limited to the standard test configuration and all output comparison criteria are satisfied with margin. Model risk level 3 is consistent with Medium assurance level per the ASME V&V 40 risk-informed framework.",
