  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors are appropriately scoped out at MRL 2. The CFD model demonstrates sufficient credibility to support the regulatory decision that the centrifugal blood pump satisfies the RH < 1 hemolysis acceptance criterion across all 5 COU operating points. Provenance chain from claim through validation results to experimental datasets is documented. The synthesized literature validation result provides additional cross-study corroboration of model form adequacy.",
