  "evidence": [
    {
      "id": "https://uofa.net/synth/evidence/orphan-hemolysis-synthesis",
      "type": "Evidence",
      "name": "Synthesis of prior hemolysis modelling studies for centrifugal blood pumps",
      "description": "A comprehensive synthesis of multiple independent prior studies examining CFD-based hemolysis prediction in rotary blood pumps, including the landmark Giersiepen power-law damage model, the Bludszuweit strain-based extension, and three independent FDA-sponsored benchmark exercises conducted between 2011 and 2019. This synthesis consolidates empirical hemolysis coefficients, turbulence model performance rankings, and mesh resolution guidelines derived from over a decade of community-wide validation effort. The aggregated findings directly inform the choice of hemolysis model parameters and turbulence closure used in the present COU1 simulation campaign.",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/fda-benchmark-experimental-dataset"
    },
    {
      "id": "https://uofa.net/synth/evidence/fda-benchmark-experimental-dataset",
      "type": "Evidence",
      "name": "FDA generic centrifugal pump experimental hemolysis dataset",
      "description": "Experimental hemolysis measurements from the FDA-sponsored inter-laboratory benchmark study of the generic centrifugal blood pump. Normalized index of hemolysis (NIH) measured at five flow-speed operating points across three independent laboratories. Serves as the primary foundational experimental reference for model validation.",
      "uofa:isFoundationalEvidence": true
    },
    {
      "id": "https://uofa.net/synth/evidence/intermediate-literature-survey",
      "type": "Evidence",
      "name": "Literature survey: turbulence model selection for hemolysis CFD",
      "description": "A synthesis of multiple prior studies comparing SST k-omega, realizable k-epsilon, and RSM turbulence closures for blood pump hemolysis prediction. Draws on published inter-laboratory comparisons and consolidates recommended model settings for the present analysis. This node represents aggregated expert knowledge from the broader CFD blood pump modelling community and is treated as a settled methodological foundation for turbulence model selection in the present COU.",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/orphan-hemolysis-synthesis"
    },
    {
      "id": "https://uofa.net/synth/evidence/hemolysis-model-parameter-set",
      "type": "Evidence",
      "name": "Hemolysis model calibration parameter set",
      "description": "Calibrated Giersiepen-Wurzinger power-law coefficients (alpha, beta, C) derived from curve-fitting against the FDA benchmark experimental dataset. Parameters: C=3.62e-5, alpha=2.416, beta=0.785. Uncertainty bounds estimated via bootstrap resampling.",
      "uofa:isFoundationalEvidence": true
    },
    {
      "id": "https://uofa.net/synth/evidence/orphan-prior-cfd-survey",
      "type": "Evidence",
      "name": "Consolidated prior CFD validation evidence: rotary pump hemolysis community benchmark",
      "description": "A synthesis of multiple prior studies spanning the 2013–2021 FDA Critical Path hemolysis modelling programme, the ASAIO inter-centre benchmark rounds, and three peer-reviewed meta-analyses of CFD hemolysis predictive accuracy in centrifugal pumps. This node aggregates quantitative accuracy metrics (mean absolute error, bias, coverage probability) from over 40 independent simulation campaigns and distils consensus best-practice guidance on mesh density, time-step selection, and red blood cell damage model choice. The consolidated evidence base is considered methodologically settled and directly underpins the credibility argument for the present COU1 assessment."
    },
    {
      "id": "https://uofa.net/synth/activity/cfd-benchmark-execution-2024",
      "type": "Activity",
      "name": "CFD benchmark simulation execution — FDA pump, 2024",
      "description": "Execution of the validated CFD hemolysis model for the FDA generic centrifugal pump at 5 operating points. ANSYS Fluent 2023R2; SST k-omega turbulence model; Lagrangian red blood cell tracking with Giersiepen damage accumulation.",
      "prov:used": "https://uofa.net/synth/data/fda-generic-pump-geometry",
      "prov:used2": "https://uofa.net/synth/evidence/hemolysis-model-parameter-set"
    },
    {
      "id": "https://uofa.net/synth/activity/mesh-independence-study-2024",
      "type": "Activity",
      "name": "Mesh independence and discretization error quantification — 2024",
      "description": "Systematic mesh refinement study using three grid levels (coarse 2.1M, medium 6.8M, fine 18.4M cells). Richardson extrapolation applied per ASME V&V 20. Grid convergence index for hemolysis index: GCI_fine = 1.4%.",
      "prov:used": "https://uofa.net/synth/data/fda-generic-pump-geometry",
      "uofa:isFoundationalEvidence": false
    }
  ],
