  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2 Class II device. Six factors appropriately scoped out per ASME V&V 40 Table 4 guidance for MRL 2. CFD hemolysis predictions demonstrate adequate accuracy (MAE 7.8%, max deviation 13.2%) against FDA benchmark experimental data. Discretization error (GCI 1.4%) exceeds MRL 2 requirement. The credibility evidence supports use of the CFD model to identify worst-case hemolysis operating conditions for the CPB device within the defined COU envelope. Decision: Accepted.",
