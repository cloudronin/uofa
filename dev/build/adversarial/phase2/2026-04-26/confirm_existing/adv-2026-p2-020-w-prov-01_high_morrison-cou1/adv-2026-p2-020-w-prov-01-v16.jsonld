  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be verified under a documented SQA plan including version control, regression testing, and traceable build records.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under the institution's ISO-9001-aligned SQA framework. Version-controlled solver binaries, regression test suite (>1200 test cases), and release notes are archived. SQA level meets Gradation 2 requirements for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation via benchmark problems relevant to rotating turbomachinery flows.",
      "rationale": "ANSYS Fluent has been verified against the ASME V&V 20 benchmark suite for incompressible rotating flows. Taylor-Couette and lid-driven cavity benchmarks confirm second-order spatial accuracy. Code verification is adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all QoIs; GCI < 5% for primary hemolysis scalar.",
      "rationale": "Three-level mesh refinement study performed on the nominal pump geometry. GCI for NIH = 2.3% on the fine mesh (12.4 M polyhedral cells). Discretization error is bounded and reported per ASME V&V 20. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented and traceable; boundary conditions in CFD must match test conditions within specified tolerances.",
      "rationale": "PIV and bench hemolysis experiments were conducted at documented flow rates (2–6 L/min) and rotational speeds (2000–3500 RPM). CFD boundary conditions set from calibrated flow meter and encoder readings. Temperature, viscosity, and hematocrit recorded per protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty) must be computed and compared against an acceptance threshold.",
      "rationale": "Validation metric E% computed for NIH across all 5 operating points. Maximum E% = 13.8%, within the 15% acceptance threshold established from clinical relevance analysis. Validation uncertainty Uval = 9.2% (95% CI) confirms adequate model accuracy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the COU decision quantity (RH index).",
      "rationale": "NIH and RH index are the primary clinical decision quantities for CPB hemolysis assessment. PIV velocity fields serve as intermediate QoIs directly informing the shear stress distribution driving the power-law damage model. QoI relevance is high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid (or validated surrogate), and operating regime as the COU.",
      "rationale": "Bench validation used the FDA generic centrifugal pump geometry with bovine blood (validated surrogate for human blood at equivalent hematocrit). Operating conditions span the clinical CPB range. Geometric and physiologic similarity is established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when discretization error is separately assessed.",
      "rationale": "Solver error assessment is not required at MRL 2 per ASME V&V 40 Table 4. Discretization error factor addresses the dominant numerical error source. Scoped out by MRL determination."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU.",
      "rationale": "Use error is not required at MRL 2 for a medium-influence decision context per ASME V&V 40 guidance. The simulation team holds documented CFD competency records. No further assessment required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis damage model form must be justified by literature and sensitivity analysis demonstrating insensitivity to alternative formulations within the COU operating range.",
      "rationale": "Modified power-law model (Zhang 2008 formulation) selected based on synthesized literature evidence consolidated in vr-literature-synthesis-hemolysis-models. Sensitivity analysis comparing Giersiepen and Arora formulations shows <10% variation in RH index across all 5 operating points, confirming model form robustness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in model inputs (geometry tolerances, fluid properties, boundary conditions) must be propagated and shown not to exceed the validation uncertainty budget.",
      "rationale": "Monte Carlo propagation of ±50 µm geometric tolerances, ±2% viscosity uncertainty, and ±1% flow rate uncertainty yields NIH uncertainty of ±6.1% (95% CI). This is within the 15% acceptance threshold and does not exceed the validation uncertainty budget."
    },
