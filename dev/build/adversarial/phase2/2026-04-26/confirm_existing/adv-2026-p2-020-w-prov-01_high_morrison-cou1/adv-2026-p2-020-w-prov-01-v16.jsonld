  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-pump-piv-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — centrifugal pump impeller region",
      "description": "Comparison of CFD-predicted velocity fields against particle image velocimetry (PIV) measurements in the impeller and volute regions at 3 operating points. GCI-corrected CFD results show mean absolute error < 8% of bulk velocity across all measurement planes.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/piv-validation-study-2023",
      "prov:wasDerivedFrom": "https://uofa.net/synth/data/piv-experimental-validation-dataset"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-bench",
      "type": "ValidationResult",
      "name": "Hemolysis index bench validation — modified power law model",
      "description": "Bench-scale hemolysis index measurements using bovine blood at 5 flow-rate/rotational-speed combinations compared against CFD-predicted normalized index of hemolysis (NIH). All predictions fall within ±15% of measured values; RH criterion satisfied at all operating points.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-bench-validation-2022",
      "prov:wasDerivedFrom": "https://uofa.net/synth/data/cpb-operating-conditions-5pts"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-literature-synthesis-hemolysis-models",
      "type": "ValidationResult",
      "name": "Synthesized literature evidence for power-law hemolysis model parameter ranges",
      "description": "This result synthesizes findings from more than a dozen published studies spanning 1990–2020 on power-law hemolysis damage models for centrifugal blood pumps, including the Giersiepen, Zhang, and Arora formulations. Parameter ranges for the stress exponent and time coefficient are consolidated into recommended bounds used to anchor the CFD model inputs. The synthesis draws on both in-vitro and in-vivo datasets and represents the current consensus in the computational hemolysis literature. Its breadth and cross-study consistency provide strong epistemic grounding for the model form selection."
    }
  ],
