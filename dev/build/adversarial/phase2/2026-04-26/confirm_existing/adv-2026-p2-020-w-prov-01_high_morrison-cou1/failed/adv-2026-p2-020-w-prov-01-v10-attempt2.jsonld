    {
      "id": "https://uofa.net/synth/evidence/orphan-synthesis-node",
      "type": "uofa:Evidence",
      "name": "Synthesized hemolysis model basis from prior pump studies",
      "description": "This evidence node consolidates findings from more than a dozen independent hemolysis studies conducted between 2005 and 2022, including the Giersiepen power-law model calibration, Bludszuweit shear-exposure framework, and three independent FDA benchmark exercises. The synthesis integrates experimental NIH measurements from multiple centrifugal pump geometries and normalises them to the Heuser–Opitz damage accumulation formulation. Given the breadth of underlying primary literature, this node represents an authoritative consolidated evidence base for the hemolysis damage exponent and threshold parameters used in the present CFD model."
    },
    {
      "id": "https://uofa.net/synth/activity/cfd-hemolysis-simulation-run",
      "type": "prov:Activity",
      "name": "CFD hemolysis simulation campaign across 5 flow-speed operating points",
