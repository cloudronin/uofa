  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented regression tests covering blood-analog flow regimes.",
      "rationale": "ANSYS Fluent 2023 R2 used under ISO 9001-compliant QMS. Regression test suite covers laminar and turbulent blood-analog flows. Version control via Git with tagged release. Achieves Gradation 2 requirements for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems relevant to rotating machinery flow.",
      "rationale": "Code verification performed against Taylor-Couette flow and lid-driven cavity benchmarks. Observed order of accuracy consistent with second-order spatial discretization. Fluent solver has extensive published verification history for rotating machinery applications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis QoI with GCI < 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study performed (coarse: 2.1M cells, medium: 6.8M cells, fine: 18.4M cells). GCI for NIH on fine grid = 2.3%, well below 5% threshold. Richardson extrapolation confirms asymptotic convergence. Exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with traceability to ISO 10993-4 and boundary conditions must match CFD inlet/outlet specifications within measurement uncertainty.",
      "rationale": "FDA benchmark experimental data collected under ISO 10993-4. Flow rate uncertainty ±0.05 L/min, speed uncertainty ±10 RPM. CFD boundary conditions set to experimental nominal values; sensitivity to boundary condition uncertainty quantified and found negligible for hemolysis QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within combined model and experimental uncertainty bands across all 5 operating points.",
      "rationale": "CFD-predicted NIH compared against experimental measurements at 5 operating points. Agreement within ±15% at all points, within combined uncertainty. Relative hemolysis index RH < 1 for all worst-case comparisons against predicate device. Validation criterion met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH, RH index) must be directly linked to the clinical decision endpoint and regulatory acceptance criterion.",
      "rationale": "NIH is the standard regulatory metric for blood pump hemolysis assessment per FDA guidance. RH < 1 directly maps to the 510(k) substantial equivalence criterion. QoI relevance is high; no surrogate or proxy metrics used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow regime, and fluid properties representative of the CPB COU.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry under CPB-representative flow conditions (2–7 L/min, 2000–3500 RPM, bovine blood analog). Geometric similarity to clinical device confirmed. Validation domain overlaps COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
