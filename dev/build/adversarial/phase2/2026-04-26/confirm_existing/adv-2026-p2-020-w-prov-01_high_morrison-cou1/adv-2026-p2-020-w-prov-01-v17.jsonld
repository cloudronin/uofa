    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate discretization error below 5% for hemolysis index QoI at Gradation 2.",
      "rationale": "A three-level mesh refinement study (coarse: 3.2M cells, medium: 9.8M cells, fine: 28.4M cells) was conducted. Richardson extrapolation yielded a grid convergence index (GCI) of 1.8% for NIH at the worst-case operating point. Discretization error is well within the 5% threshold, achieving Gradation 3 performance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
