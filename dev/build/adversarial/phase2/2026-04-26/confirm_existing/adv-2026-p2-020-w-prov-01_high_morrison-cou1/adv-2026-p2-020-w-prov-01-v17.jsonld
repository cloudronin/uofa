    {
      "id": "https://uofa.net/morrison/validation/literature-synthesis-validation-result",
      "type": "ValidationResult",
      "name": "Hemolysis model parameter synthesis from prior literature",
      "description": "A synthesis of multiple prior studies examining power-law hemolysis model coefficients (Giersiepen, Zhang, and Heuser-Opitz formulations) across a range of shear stress exposures and exposure times. This intermediate result consolidates empirical coefficient ranges reported across seven independent experimental programmes spanning 1990–2018, providing the parameter envelope used to bound model uncertainty in the primary CFD assessment. The synthesis integrates both in-vitro Couette-flow data and rotary blood pump loop data, and represents the most comprehensive aggregation of hemolysis damage coefficients available in the open literature at the time of assessment.",
      "prov:wasDerivedFrom": "https://uofa.net/morrison/claim/cou1-hemolysis-cfd-claim"
    }
  ],
