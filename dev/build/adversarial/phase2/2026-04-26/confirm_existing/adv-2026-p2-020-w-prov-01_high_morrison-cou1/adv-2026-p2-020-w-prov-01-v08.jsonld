  "uofa:evidenceNode": [
    {
      "id": "https://uofa.net/synth/evidence/orphan-synthesis-node",
      "type": "uofa:EvidenceNode",
      "name": "Consolidated hemolysis modeling prior-literature synthesis",
      "description": "A synthesis of multiple prior studies examining CFD-based hemolysis prediction methodology for rotary blood pumps, spanning 2008–2022. Integrates findings from six independent laboratory groups on power-law hemolysis model coefficients, turbulence model selection, and near-wall resolution requirements. This node represents the accumulated methodological foundation upon which the current benchmark validation strategy was designed. The synthesis documents convergent agreement across groups on the Giersiepen-Wurzinger power-law exponents and establishes the accepted range of y+ values for hemolysis-sensitive boundary layer resolution in centrifugal pump geometries."
    },
    {
      "id": "https://uofa.net/synth/dataset/fda-pump-invitro-measurements",
      "type": "uofa:EvidenceNode",
      "name": "FDA generic centrifugal pump in-vitro hemolysis measurements",
      "description": "Experimentally measured normalized index of hemolysis (NIH) values for the FDA generic centrifugal blood pump across 5 operating conditions. Data sourced from the FDA benchmark repository.",
      "uofa:isFoundationalEvidence": true
    },
    {
