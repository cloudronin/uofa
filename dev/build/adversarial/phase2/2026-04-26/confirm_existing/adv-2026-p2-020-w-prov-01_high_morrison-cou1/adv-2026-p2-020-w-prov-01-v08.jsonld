  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Mesh independence confirmed at Gradation 3, exceeding the Gradation 2 requirement. Benchmark validation achieves mean NIH error of 11.4%, within the ±15% acceptance band. Six factors appropriately scoped out per MRL 2 requirements with documented justification. The consolidated prior-literature synthesis provides methodological grounding for the validation strategy. The credibility evidence package is judged sufficient to support the regulatory claim that the CFD model identifies worst-case hemolysis operating conditions for the Class II CPB device.",
