  "nodes": [
    {
      "id": "https://uofa.net/morrison/claim/cou1-hemolysis-claim",
      "type": "uofa:ModelingClaim",
      "name": "CFD model reliably identifies worst-case hemolysis conditions for CPB Class II device",
      "description": "The CFD hemolysis model, calibrated against the FDA generic centrifugal pump benchmark, is claimed to predict relative hemolysis index with sufficient fidelity to support worst-case identification across the CPB operating envelope at MRL 2.",
      "prov:wasDerivedFrom": "https://uofa.net/morrison/validation/rh-index-comparison",
      "prov:wasDerivedFrom_secondary": "https://uofa.net/morrison/result/literature-hemolysis-synthesis"
    },
    {
      "id": "https://uofa.net/morrison/result/literature-hemolysis-synthesis",
      "type": "uofa:EvidenceNode",
      "name": "Hemolysis Modeling Literature Synthesis — Consolidated Prior Evidence",
      "description": "A synthesis of multiple prior studies examining CFD-based hemolysis prediction in rotary blood pumps, drawing on more than a decade of published benchmarking activity including the FDA Critical Path initiative, Hariharan et al. (2011), Garon & Farinas (2004), and the ASME BioFluids symposium series. This node consolidates the methodological consensus on power-law hemolysis index formulations, turbulence model selection (SST k-omega), and acceptable discretization error thresholds for Class II CPB devices. The breadth and consistency of the underlying literature base is considered to establish a well-grounded empirical foundation for the hemolysis correlation parameters adopted in this assessment."
    },
    {
      "id": "https://uofa.net/morrison/activity/cfd-validation-run-2024",
      "type": "prov:Activity",
      "name": "CFD Validation Simulation Campaign 2024",
      "description": "ANSYS Fluent 2023R2 simulations executed at 5 operating points (2.5 L/min at 2500 RPM, 3.5 L/min at 3000 RPM, 4.5 L/min at 3500 RPM, 5.0 L/min at 3500 RPM, 6.0 L/min at 4000 RPM). Hemolysis index computed via scalar transport approach with Giersiepen power-law coefficients.",
      "prov:used": "https://uofa.net/morrison/data/fda-pump-experimental-hemolysis",
      "startedAtTime": "2024-09-01T08:00:00Z",
      "endedAtTime": "2024-11-30T17:00:00Z"
    },
    {
      "id": "https://uofa.net/morrison/data/fda-pump-experimental-hemolysis",
      "type": "uofa:Dataset",
      "name": "FDA Generic Centrifugal Pump Experimental Hemolysis Dataset",
      "description": "Experimental hemolysis measurements from the FDA Critical Path benchmark study for the generic centrifugal blood pump geometry. Data include normalized index of hemolysis (NIH) at 5 operating conditions used as validation targets.",
      "uofa:isFoundationalEvidence": true
    },
    {
      "id": "https://uofa.net/morrison/activity/mesh-convergence-activity",
      "type": "prov:Activity",
      "name": "Grid Convergence Index Computation",
      "description": "Three mesh levels (coarse: 1.2M cells, medium: 3.8M cells, fine: 9.6M cells) solved at 3.5 L/min / 3000 RPM reference condition. GCI computed per Celik et al. (2008) procedure.",
      "prov:used": "https://uofa.net/morrison/data/cfd-mesh-convergence-study"
    },
    {
      "id": "https://uofa.net/morrison/data/cfd-mesh-convergence-study",
      "type": "uofa:Dataset",
      "name": "CFD Mesh Convergence Study Raw Output",
      "description": "Velocity, pressure, and hemolysis scalar field outputs for three mesh refinement levels used in GCI computation.",
      "uofa:isFoundationalEvidence": true
    }
  ],
