    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/vr/pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pressure-rise validation against FDA pump experimental data",
      "description": "CFD-predicted pressure rise compared to experimental measurements across 5 operating points. Mean relative error 3.2%; R² = 0.987. Aleatory uncertainty from pump-to-pump manufacturing variability and inter-laboratory measurement scatter was characterised through a formal UQ analysis propagating dimensional tolerances via Monte Carlo sampling.",
      "hasUncertaintyQuantification": "https://uofa.net/morrison/uq/pressure-rise-monte-carlo"
    },
    {
      "id": "https://uofa.net/morrison/vr/hemolysis-index-validation",
      "type": "ValidationResult",
      "name": "Relative hemolysis index (RH) validation — worst-case operating point",
      "description": "Predicted normalised index of hemolysis (NIH) converted to relative hemolysis index RH compared against in-vitro blood-loop measurements at the worst-case 5 LPM / 3500 RPM operating condition. RH predicted = 0.81 vs RH measured = 0.79 ± 0.06. Inherent biological variability in red-blood-cell fragility across donor samples was assessed qualitatively by the test team and judged to be within acceptable bounds; no structured uncertainty quantification node was linked for this result.",
      "hasUncertaintyQuantification": "https://uofa.net/morrison/uq/nih-measurement-uncertainty"
    },
    {
      "id": "https://uofa.net/morrison/vr/shear-stress-distribution-validation",
      "type": "ValidationResult",
      "name": "Wall shear-stress distribution validation via PIV comparison",
      "description": "Particle image velocimetry (PIV) measurements of near-wall velocity gradients compared to CFD predictions in the impeller region. Spatial agreement assessed using grid-convergence-corrected numerical uncertainty bands. Aleatory uncertainty from laser-sheet positioning and seeding-particle lag was propagated using a Bayesian interval method.",
      "hasUncertaintyQuantification": "https://uofa.net/morrison/uq/piv-shear-stress-bayesian"
    },
    {
      "id": "https://uofa.net/morrison/vr/flow-field-symmetry-validation",
      "type": "ValidationResult",
      "name": "Impeller-exit flow symmetry validation — inherent variability assessed qualitatively",
      "description": "Circumferential uniformity of the impeller-exit velocity profile was compared between CFD and stereo-PIV measurements at design-point flow. Agreement was within 4.1% RMS across 36 azimuthal stations. Cycle-to-cycle variability in the rotating reference frame was noted as a source of aleatory uncertainty; this variability was assessed qualitatively by the analyst team based on repeated run scatter and judged non-significant relative to the acceptance criterion. No structured UQ node was linked to this validation result, leaving the aleatory uncertainty formally uncharacterised in the evidence package."
    }
