      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for hemolysis prediction must demonstrate version-controlled, validated solver with documented regression test suite and configuration management at MRL 5.",
      "rationale": "The CFD solver (OpenFOAM v9) has version control and basic regression tests, but lacks a formal V&V-documented quality management system meeting MRL 5 requirements. Achieved level 2 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
