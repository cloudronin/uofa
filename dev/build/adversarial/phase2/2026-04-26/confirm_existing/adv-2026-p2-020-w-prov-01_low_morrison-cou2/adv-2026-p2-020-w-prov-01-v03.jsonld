      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions or method-of-manufactured-solutions for all relevant flow regimes including rotating machinery.",
      "rationale": "MMS verification was performed for laminar pipe flow only. Rotating impeller flow regimes were not verified against analytical benchmarks. Achieved level 2 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI must demonstrate discretization error below 5% on NIH QoI across all five operating points.",
      "rationale": "GCI analysis performed on three mesh levels; average GCI of 3.8% on NIH, but two operating points exceeded 5% threshold. Achieved level 3 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match VAD operating envelope within documented uncertainty bounds, including fluid rheology, temperature, and hematocrit.",
      "rationale": "FDA benchmark experiments used bovine blood at room temperature; VAD clinical conditions involve human blood at 37°C with varying hematocrit. Rheological mismatch not fully characterized. Achieved level 2 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or U_val) must be documented for NIH at each operating point with uncertainty intervals.",
      "rationale": "Comparison performed but uncertainty intervals on experimental NIH measurements are not fully propagated; only point estimates compared. Achieved level 2 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH) must be directly relevant to the absolute hemolysis threshold decision for the VAD COU, with documented mapping to clinical endpoints.",
      "rationale": "NIH is the standard hemolysis metric but mapping to absolute clinical hemolysis threshold (plasma-free hemoglobin) requires additional conversion assumptions not fully validated. Achieved level 3 of 5 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometry and operating conditions sufficiently similar to the VAD COU to support extrapolation to Class III device decision.",
      "rationale": "Validation performed on FDA generic pump geometry; actual VAD geometry differs in impeller blade count and volute design. Geometric similarity not formally assessed. Achieved level 2 of 5 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
