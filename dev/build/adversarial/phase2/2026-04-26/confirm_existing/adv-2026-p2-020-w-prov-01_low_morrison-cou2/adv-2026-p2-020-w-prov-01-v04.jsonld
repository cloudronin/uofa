      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match CFD inlet/outlet conditions within 2% across all 5 operating points.",
      "rationale": "Boundary condition matching achieved for 3 of 5 operating points; two high-flow conditions show inlet velocity profile discrepancies exceeding 5%. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) reported with uncertainty bounds for hemolysis index at all operating points.",
      "rationale": "Relative error reported without experimental uncertainty propagation. Metric computed for hemolysis index but confidence intervals not derived. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be identical to QoIs required in the COU decision (absolute hemolysis index).",
      "rationale": "Validation QoI is normalized hemolysis index (NIH); COU requires absolute plasma-free hemoglobin rise. Mapping between metrics introduces unquantified model-form uncertainty. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
