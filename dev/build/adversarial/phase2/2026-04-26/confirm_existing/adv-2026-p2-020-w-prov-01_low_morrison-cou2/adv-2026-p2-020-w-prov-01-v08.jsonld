  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented unit tests and regression suite covering hemolysis constitutive model",
      "rationale": "Solver is version-controlled and unit tests exist for core fluid routines, but the hemolysis constitutive model subroutine lacks dedicated regression tests. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to full Navier-Stokes plus hemolysis transport equations with demonstrated order-of-accuracy",
      "rationale": "MMS applied to Navier-Stokes equations only; hemolysis transport equation not included in code verification suite. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI < 5% for hemolysis index QoI",
      "rationale": "Three-mesh study performed; GCI for pressure head QoI is 3.2% but GCI for hemolysis index QoI reaches 18.7%, exceeding threshold. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated within ±2% for all 5 operating points; blood analogue rheology characterised",
      "rationale": "Flow rates replicated within ±2% but rotational speed uncertainty is ±4% at two operating points. Blood analogue viscosity characterised at 37°C only. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (E_rms) < 15% for hemolysis index across all 5 operating points with uncertainty bands overlapping",
      "rationale": "E_rms for hemolysis index is 31% averaged across operating points; uncertainty bands do not overlap at 3 of 5 conditions. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index is directly mapped to clinical threshold; sensitivity analysis demonstrates QoI dominance over secondary outputs",
      "rationale": "Hemolysis index is the primary clinical QoI and is directly compared against threshold. Sensitivity analysis performed but secondary shear-stress distributions not fully characterised. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on same pump geometry, blood analogue, and operating envelope as COU; no geometric surrogates",
      "rationale": "FDA generic pump geometry used for validation matches COU geometry. However, validation experiments used glycerol-water analogue while COU involves real blood; haematocrit effects not bridged. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria tightened to 1e-6 residuals; floating-point round-off analysis documented for hemolysis accumulation integral",
      "rationale": "Solver convergence monitored to 1e-4 residuals only; no floating-point or round-off analysis performed for the hemolysis path-integral accumulation. Factor flagged as epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent analyst replication study; documented simulation execution procedure with mandatory peer review gate",
      "rationale": "No independent replication study performed. Simulation execution procedure exists but peer review gate is informal. Epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model sensitivity study and hemolysis constitutive model form uncertainty quantified via Bayesian model averaging over at least 3 candidate models",
      "rationale": "Single turbulence model (SST k-omega) used without sensitivity study. Single hemolysis power-law model adopted; no Bayesian model averaging performed. Critical epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full Monte Carlo UQ on all model inputs with PDFs derived from patient population data; global sensitivity indices reported for hemolysis QoI",
      "rationale": "Monte Carlo UQ performed on 4 of 11 input parameters using uniform distributions; patient-population PDFs not available for viscosity and haematocrit. Global Sobol indices not computed. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical power analysis justifying sample size; repeated experimental runs with inter-run variability characterised",
      "rationale": "Experimental dataset consists of single-run measurements at each operating point; no repeat runs and no statistical power analysis. Epistemic gap flagged. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and COU inputs with documented bridging functions for blood analogue substitution",
      "rationale": "No formal equivalency mapping produced. Blood analogue substitution assumed adequate without bridging function derivation. Critical gap for Class III submission. Achieved level 1."
    }
