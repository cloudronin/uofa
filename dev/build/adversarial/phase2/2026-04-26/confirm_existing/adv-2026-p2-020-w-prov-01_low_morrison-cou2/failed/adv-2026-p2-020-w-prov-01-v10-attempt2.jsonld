  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with traceability to requirements; configuration management applied to all simulation inputs.",
      "rationale": "The CFD solver has partial documentation and a limited regression test suite. Configuration management is applied to geometry and boundary conditions but not to turbulence model coefficients. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent applied to governing equations relevant to hemolysis transport; order-of-accuracy confirmed.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the hemolysis scalar transport equation. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index computed on three systematically refined meshes; GCI reported for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study completed; GCI for hemolysis index is 8.3%, exceeding the 5% threshold implied by level 4. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including blood analog viscosity, temperature, and rotor speed range.",
      "rationale": "Validation experiments used a glycerin-water blood analog at 37°C across 3 of 5 required operating points. Two high-flow operating points lacked matched experimental data. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Statistical comparison of predicted vs. measured hemolysis index including uncertainty bands; validation metric must account for experimental uncertainty.",
      "rationale": "Point-to-point comparison performed without propagated experimental uncertainty. No formal validation metric (e.g., u-pooled or E_n number) applied. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI must be the hemolysis index (not surrogate quantities such as wall shear stress alone); direct correspondence to clinical endpoint required.",
      "rationale": "Hemolysis index is the primary QoI in validation; however, the damage accumulation integral uses a power-law model not directly validated against clinical hemolysis thresholds. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry must be the same pump family as the COU device; operating conditions must span the full clinical flow-speed envelope.",
      "rationale": "Validation was performed on the FDA generic pump, not the specific VAD device geometry. Geometric similarity is approximate. Only 3 of 5 clinical operating points were covered. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error and round-off error must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Iterative convergence residuals are reported but round-off error analysis was not performed. No formal decomposition of solver error components provided. Flagged as epistemic gap at MRL 5; achieved level 1 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition selection, and post-processing by a qualified engineer not involved in original analysis.",
      "rationale": "No independent review of simulation setup was performed. Use error sources including boundary condition selection and turbulence model choice were not independently verified. Epistemic gap; achieved level 1 against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model must be justified against blood flow physics; sensitivity of hemolysis index to model form choices must be quantified.",
      "rationale": "The k-omega SST turbulence model was selected without documented justification for rotating blood pump flows. Model form uncertainty for the power-law hemolysis correlation was not quantified. Epistemic gap; achieved level 1 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in material properties (blood viscosity, density, hemolysis coefficients) must be propagated through Monte Carlo or equivalent method to hemolysis index output.",
      "rationale": "Monte Carlo UQ was initiated but hemolysis power-law coefficients were held fixed at nominal values. Viscosity uncertainty was propagated but hematocrit variability was excluded. Epistemic gap; achieved level 1 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must represent patient population variability in hematocrit and plasma protein concentration; minimum sample size justified statistically.",
      "rationale": "Validation experiments used a single blood analog formulation. No patient population variability in blood properties was represented. Sample size justification not provided. Epistemic gap; achieved level 1 against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Boundary conditions applied in the CFD model must be demonstrated to be equivalent to the physical boundary conditions in the validation experiment.",
      "rationale": "Inlet velocity profiles in the CFD model were assumed fully developed; experimental inlet conditions were not measured. Equivalency between CFD boundary conditions and experimental setup was not established. Epistemic gap; achieved level 1 against required level 4."
    }
  ],
