      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary condition application, and post-processing scripts by a qualified analyst not involved in original simulation.",
      "rationale": "No independent review of model setup or post-processing was performed. Use error remains an unaddressed epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified by sensitivity studies; alternative model forms evaluated and ranked.",
      "rationale": "SST k-omega turbulence model selected without systematic comparison to alternative turbulence closures. Hemolysis power-law model form not challenged against mechanistic alternatives. Model form uncertainty unquantified. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain inputs (viscosity, pump geometry tolerances, inlet flow waveform); Monte Carlo propagation performed to hemolysis QoI.",
      "rationale": "Monte Carlo UQ performed for inlet flow rate and rotational speed only; viscosity uncertainty and geometric manufacturing tolerances not included in propagation. Partial Monte Carlo yields achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number of experimental replicates sufficient for statistical characterization of measurement uncertainty; sample-to-sample variability in hemolysis reported.",
      "rationale": "Experimental hemolysis measurements taken from a single pump unit with three replicates per operating point. Sample-to-sample variability not characterized across multiple pump units. Factor not adequately assessed. Achieved level 1."
    },
    {
