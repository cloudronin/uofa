      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan and regression test suite covering hemolysis model routines.",
      "rationale": "Solver is version-controlled and regression tests exist for core fluid routines; however, the hemolysis power-law sub-model lacks dedicated regression coverage, leaving achieved level below required for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to Navier-Stokes and hemolysis transport equations with demonstrated order-of-accuracy convergence.",
      "rationale": "MMS verification completed for Navier-Stokes equations with confirmed second-order convergence; hemolysis transport equation verified only via code-to-code comparison, not MMS, yielding achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI < 2% on hemolysis index QoI.",
      "rationale": "Three mesh levels used; GCI computed as 4.7% on hemolysis index, exceeding the 2% threshold. Spatial convergence confirmed for velocity but not for the hemolysis scalar, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within 2% for all five flow-speed operating points; blood viscosity and temperature controlled and matched.",
      "rationale": "Boundary conditions matched within 2% for flow rate; rotational speed matched within 1.5%. Blood analog viscosity deviated up to 6% from target at two operating points, reducing test condition fidelity below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation uncertainty U_val) computed for hemolysis index at all five operating points with statistical confidence intervals reported.",
      "rationale": "Output comparison performed at three of five operating points; confidence intervals not reported for hemolysis index. Validation uncertainty computed but without Monte Carlo propagation through hemolysis model, yielding achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI is the normalized index of hemolysis (NIH) directly compared against clinical threshold; direct mapping from CFD scalar to NIH demonstrated with uncertainty.",
      "rationale": "QoI is NIH; however, the mapping from CFD shear stress history to NIH uses a power-law model whose coefficients were calibrated on bovine blood, not human blood, introducing unquantified species-transfer uncertainty. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the identical FDA generic pump geometry under VAD operating conditions (flow 3–6 L/min, speed 2400–3600 RPM) with human blood analog.",
      "rationale": "Validation experiments used the FDA generic pump geometry; however, experiments were conducted at only two of five COU operating points and used a glycerol-water analog rather than a blood analog with red blood cells, reducing relevance. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and demonstrated; floating-point round-off assessed for hemolysis scalar transport.",
      "rationale": "Solver convergence criteria reported for residuals only; no assessment of iterative error on hemolysis QoI performed. Factor flagged as epistemic gap at MRL 5. Achieved level 1 by default."
    },
