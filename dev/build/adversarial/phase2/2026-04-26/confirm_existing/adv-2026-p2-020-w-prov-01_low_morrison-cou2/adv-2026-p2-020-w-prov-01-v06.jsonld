  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Assessment team accepted the package for submission review pending resolution of MRL 5 epistemic gaps. Seven of thirteen credibility factors were assessed; all achieved levels fell below required levels. Six factors remain unassessed and constitute formal epistemic gaps. Monte Carlo UQ was completed but does not compensate for unquantified model-form uncertainty. Package accepted for regulatory submission with documented gaps; final regulatory acceptance deferred.",
