      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) agrees with experimental plasma-free hemoglobin measurements within 15% across all 5 operating points.",
      "rationale": "CFD-predicted RH values ranged from 0.61 to 0.89 across the 5 conditions. Experimental RH values showed agreement within 11% at all points. The acceptance criterion of RH < 1 was met in both simulation and experiment. Gradation 2 achieved."
