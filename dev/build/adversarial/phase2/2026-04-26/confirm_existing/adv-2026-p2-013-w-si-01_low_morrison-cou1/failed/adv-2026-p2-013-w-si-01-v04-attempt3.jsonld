      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported with GCI < 5% for hemolysis-relevant quantities.",
      "rationale": "Three-level mesh refinement study performed (4.2 M, 8.7 M, 17.1 M cells). GCI for normalised hemolysis index is 3.1%, satisfying the < 5% criterion. Medium mesh (8.7 M) adopted for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to reproduce boundary conditions in the CFD model.",
      "rationale": "FDA pump experimental data (flow rates 2.5–6 L/min, speeds 2000–3500 RPM) are fully documented with inlet/outlet pressure measurements and fluid temperature. Boundary conditions replicated within measurement uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) must agree with experimental values within 15% across all 5 operating points.",
      "rationale": "RH predictions at all five flow-speed combinations fall within 11% of experimental measurements. Systematic over-prediction at low-flow conditions is within the stated acceptance band and consistent with power-law hemolysis model limitations at low shear."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (normalised hemolysis index, shear stress distribution) must be directly linked to clinical hemolysis risk.",
      "rationale": "The relative hemolysis index RH and volume-averaged scalar shear stress are established surrogates for red blood cell damage in CPB literature. Both quantities are directly used in the regulatory submission comparison against the predicate device."
    },
