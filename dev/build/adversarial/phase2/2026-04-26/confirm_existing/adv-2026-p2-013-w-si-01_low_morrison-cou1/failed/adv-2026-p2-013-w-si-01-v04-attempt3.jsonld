      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation via method of manufactured solutions or equivalent benchmark.",
      "rationale": "The solver has been verified against ASME V&V 20 benchmark cases for internal viscous flow. Lid-driven cavity and pipe-flow benchmarks confirm correct discretisation implementation at second-order accuracy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
