      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "At MRL 2 with medium model influence, detailed numerical solver error quantification beyond code verification is not required. Residual convergence to 1e-5 was confirmed for all runs, providing sufficient confidence in solver accuracy for this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Formal use error analysis is not required at MRL 2. Simulation setup was reviewed by a second analyst and boundary conditions were independently verified against the experimental protocol to mitigate operator error risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Model form uncertainty assessment is not required at MRL 2. The k-omega SST turbulence model was selected based on published best-practice guidance for rotating machinery hemolysis simulations. Sensitivity to turbulence model choice is acknowledged but not formally quantified at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
