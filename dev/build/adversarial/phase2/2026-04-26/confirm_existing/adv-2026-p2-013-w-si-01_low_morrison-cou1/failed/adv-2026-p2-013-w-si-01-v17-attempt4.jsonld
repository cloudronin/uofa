  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures documented and version control applied to all simulation scripts and mesh generation routines.",
      "rationale": "The CFD solver (ANSYS Fluent 17.2) is a commercially validated platform with documented SQA processes. Version control was applied to all case files, boundary condition scripts, and post-processing routines. Configuration management records confirm no unauthorised code modifications during the study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarked against at least one canonical internal flow case with documented convergence to analytical or reference solution.",
      "rationale": "ANSYS Fluent has been benchmarked against the Taylor-Couette flow and lid-driven cavity problems. Published verification reports confirm second-order spatial accuracy. No custom solver modifications were introduced, so code verification requirements at MRL 2 are satisfied by vendor documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for the primary QoI (scalar stress integral) on at least three systematically refined meshes.",
      "rationale": "A three-level mesh refinement study was performed using coarse (4.2 M cells), medium (9.8 M cells), and fine (21.4 M cells) meshes. The GCI for the volume-averaged scalar shear stress was 3.1%, below the 5% threshold. The fine mesh was selected for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match CFD boundary conditions within stated measurement uncertainty.",
      "rationale": "Experimental data from the FDA benchmark study used flow rates of 2.5 and 5.0 L/min at rotational speeds of 2500, 3500, and 4500 RPM. CFD boundary conditions were set to match these values. Fluid viscosity and density were matched to the blood analogue within 2% as reported in the experimental protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 15% of measured values across all five operating points, or RH index below 1.0.",
      "rationale": "Predicted normalised index of hemolysis (NIH) agreed with experimental measurements within 12% across all five operating points. The relative hemolysis index RH remained below 1.0 for all design variants evaluated, satisfying the acceptance criterion for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical hemolysis endpoint; scalar stress exposure used as surrogate is supported by published literature.",
      "rationale": "The primary QoI is the scalar stress-based hemolysis power law (Giersiepen-Wurzinger model). This surrogate is widely cited in CFD hemolysis literature and has been accepted by FDA guidance documents for centrifugal blood pump assessments. The QoI directly informs the RH acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on the same pump geometry or a sufficiently similar predicate device under overlapping operating conditions.",
      "rationale": "Validation was conducted using the FDA generic centrifugal blood pump, which is the same geometry as the device under assessment. Operating conditions in the validation dataset span the full range of the COU operating envelope, confirming relevance of the validation activities."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
