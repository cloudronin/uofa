      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release qualification records consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent v19.2 was used with documented version control and regression test suite. Release qualification records confirm solver correctness for rotating machinery flows. SQA level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or benchmark comparisons at the required gradation.",
      "rationale": "Benchmark comparisons against lid-driven cavity and rotating channel flow problems confirm correct implementation of incompressible Navier-Stokes and SST k-omega turbulence model. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified via mesh refinement study and demonstrated to be within 5% of QoI for the hemolysis index at the required gradation.",
      "rationale": "Three-level mesh refinement study (2.1M, 5.8M, 14.2M cells) performed. Richardson extrapolation yields GCI < 3.2% for scalar stress and hemolysis index across all 5 operating points. Gradation 2 criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and sufficiently close to the COU operating envelope to support credibility at MRL 2.",
      "rationale": "Validation experiments conducted at 3 L/min and 4.5 L/min with pump speeds of 2000, 2500, and 3000 RPM, spanning the CPB operating envelope. Temperature, hematocrit, and blood analog fluid properties documented. Test conditions judged representative of COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 20% normalized index of agreement across all validation operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared against experimental measurements across 5 operating points. Mean absolute error of 11.4% observed. All predictions fall within experimental uncertainty bands. Output comparison criterion at Gradation 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (NIH, scalar stress) must be directly relevant to the clinical decision quantity (relative hemolysis index RH) used in the COU.",
      "rationale": "Normalized index of hemolysis and volume-averaged scalar stress are the primary QoIs. These directly feed the relative hemolysis index RH = NIH_device / NIH_predicate used as the acceptance criterion. Relevance is direct and well-established in the hemolysis modeling literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
