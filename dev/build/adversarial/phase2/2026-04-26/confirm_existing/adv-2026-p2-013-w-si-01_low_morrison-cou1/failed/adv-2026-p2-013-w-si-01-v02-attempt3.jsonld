      "acceptanceCriteria": "CFD solver must be under version control with documented regression testing at Gradation 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2023 R1) operates under a documented quality management system including version-controlled source, regression test suite, and release validation reports. Gradation 2 requirements are fully satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correctness on canonical benchmark problems relevant to rotating-frame viscous flow at Gradation 2.",
      "rationale": "Code verification was performed using the method of manufactured solutions for incompressible Navier-Stokes in a rotating reference frame. Second-order spatial convergence confirmed. Results consistent with published ANSYS verification benchmarks."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported and discretization error must be below 5% for hemolysis-relevant quantities at Gradation 2.",
      "rationale": "Three-level mesh refinement study conducted (3.2M, 8.1M, 18.4M elements). GCI for scalar stress magnitude was 3.1%, satisfying the 5% threshold. Richardson extrapolation applied to the hemolysis power-law integral."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
