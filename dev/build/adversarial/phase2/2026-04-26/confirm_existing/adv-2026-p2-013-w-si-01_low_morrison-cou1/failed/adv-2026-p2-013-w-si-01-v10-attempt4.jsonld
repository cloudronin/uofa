      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) match simulation inputs within measurement uncertainty.",
      "rationale": "FDA experimental test conditions documented at five flow-speed operating points. Glycerol-water analog fluid properties used in both experiment and simulation. Rotational speed and flow rate boundary conditions replicated within ±1.5% of experimental values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated hemolysis index and pressure rise agree with experimental measurements within combined model and experimental uncertainty bounds.",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared to FDA experimental measurements at all five operating points. Mean absolute error of 12% observed, within the combined uncertainty band of ±18%. Pressure rise predictions within ±8% across all operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
