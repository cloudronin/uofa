      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented with version control, regression testing, and traceable release notes sufficient for MRL 2.",
      "rationale": "ANSYS Fluent 19.2 was used with documented version control and regression test suite. Software quality records confirm compliance with MRL 2 requirements. Release notes and validation benchmarks are archived and traceable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method-of-manufactured-solutions or equivalent benchmark at MRL 2.",
      "rationale": "Numerical code verification was performed using published ASME benchmark cases for incompressible Navier-Stokes flow. Results confirm correct implementation of momentum and continuity equations within expected truncation error bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported and discretization error must be below 5% for primary quantities of interest at MRL 2.",
      "rationale": "Three-level mesh refinement study was conducted. GCI for normalized hemolysis index was 3.1% on the fine mesh (8.4M cells), satisfying the 5% threshold. Richardson extrapolation confirmed asymptotic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented and reproduced in simulation within stated uncertainty bounds.",
      "rationale": "Inlet flow rates and rotational speeds from FDA experimental dataset were applied as boundary conditions. Temperature, fluid viscosity, and hematocrit were matched to reported experimental values. Boundary condition uncertainty was propagated and found acceptable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within combined simulation and experimental uncertainty at all five operating points.",
      "rationale": "NIH predictions at all five flow-speed operating points fell within experimental uncertainty bands reported in the FDA benchmark dataset. Maximum relative error was 8.4%, within the combined uncertainty envelope of 12%. RH < 1 criterion satisfied at all points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest (NIH, RH) must be directly relevant to the clinical decision regarding worst-case hemolysis operating conditions.",
      "rationale": "Normalized index of hemolysis and relative hemolysis index are the standard metrics for pump-induced hemolysis per FDA guidance and ASTM F1841. These quantities directly inform the worst-case operating condition determination required by the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on a geometry and flow regime sufficiently similar to the CPB device COU to support extrapolation of credibility.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump, which shares rotodynamic operating principles, flow regime (Re ~ 10^4), and hemolysis mechanisms with the subject CPB device. Geometric similarity index exceeded 0.85 across critical internal passages."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
