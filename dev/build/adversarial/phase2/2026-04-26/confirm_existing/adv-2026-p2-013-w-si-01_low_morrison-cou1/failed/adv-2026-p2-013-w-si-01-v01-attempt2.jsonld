      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented with version control and validation history on record.",
      "rationale": "ANSYS Fluent v19.2 used with documented release notes, version-controlled case files, and institutional QA log confirming solver build integrity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least one published benchmark problem relevant to rotating turbomachinery flow.",
      "rationale": "ANSYS Fluent verified against lid-driven cavity and rotating channel benchmarks published in ASME V&V 20. Results within 2% of reference solutions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for the primary QoI (hemolysis index) across all operating points.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 5.4M, 11.8M cells). GCI for normalized hemolysis index ranged 1.8%–3.7% across all 5 operating conditions, meeting the 5% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulation boundary conditions within stated tolerances for flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA pump experiments conducted at 2500–3500 RPM and 2.5–7.5 L/min. CFD boundary conditions set to match measured inlet flow and rotational speed within ±1%. Blood analog viscosity matched to within ±3% of experimental values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within 20% across all validated operating points.",
      "rationale": "CFD-predicted NIH compared against experimental measurements at 5 operating conditions. Mean absolute relative error was 12.4%, with maximum deviation of 18.1% at the lowest flow-speed condition. All points within the 20% acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) must be directly linked to the clinical endpoint and regulatory acceptance criterion.",
      "rationale": "RH is defined as the ratio of device NIH to predicate NIH. This metric directly supports the regulatory decision criterion (RH < 1) and is recognized in FDA guidance for Class II blood-contacting devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
