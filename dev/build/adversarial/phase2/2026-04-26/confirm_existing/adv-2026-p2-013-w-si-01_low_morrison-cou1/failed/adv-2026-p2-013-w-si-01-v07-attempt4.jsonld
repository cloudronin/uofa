    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) agrees with experimental measurements within 15% across all 5 operating points, meeting Gradation 2.",
      "rationale": "Predicted RH values ranged from 0.61 to 0.94 across the five operating points. Comparison against experimental hemolysis measurements showed agreement within 11% at all conditions. The worst-case operating point (3500 RPM, 2 L/min) was correctly identified by the model as the highest hemolysis condition."
    },
    {
      "factorStandard": "ASME-VV40-2018",
