      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and version control meets MRL 2 requirement.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially validated solver with ISO 9001 QA certification and published verification documentation. Version control and audit trail are maintained throughout the simulation campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases relevant to rotating machinery and viscous flow at MRL 2.",
      "rationale": "The CFD solver has been verified against lid-driven cavity, rotating channel flow, and Taylor-Couette benchmarks. Published verification reports confirm second-order spatial accuracy for the discretization schemes employed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on three systematically refined meshes.",
      "rationale": "Three meshes (2.1M, 5.8M, 14.2M cells) were generated with refinement ratio r=1.6. Richardson extrapolation yields GCI of 3.2% for the scalar stress-based hemolysis index at the design operating point, satisfying the 5% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions replicate CFD boundary conditions within 5% for flow rate and rotational speed.",
      "rationale": "FDA pump experimental data were collected at flow rates of 2.5 and 5.0 L/min and rotational speeds of 2000, 2500, and 3500 RPM. CFD boundary conditions match within 2.1% for flow rate and 0.8% for RPM, satisfying the 5% tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) agrees with experimental measurements within 15% across all 5 operating points.",
      "rationale": "CFD-predicted NIH values range from 0.0012 to 0.0048 mg/dL across the 5 operating points. Comparison against published FDA pump experimental data shows maximum deviation of 11.4%, within the 15% acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to the clinical decision criterion and regulatory acceptance threshold.",
      "rationale": "The relative hemolysis index RH = NIH_device / NIH_predicate directly supports the COU decision criterion (RH < 1). This scalar QoI captures the worst-case hemolysis operating condition across the design space and is the quantity reported to FDA."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometrically and operationally similar device under equivalent flow conditions.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which shares the impeller geometry class, operating flow regime (Re ~ 10^4), and blood analog fluid with the CPB device under assessment. Operating points span the COU envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; commercial solver documentation provides sufficient confidence.",
      "rationale": "At Model Risk Level 2, explicit quantification of numerical solver error beyond code verification is not required. The commercial solver's published accuracy documentation and benchmark results provide adequate confidence for this assessment level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; standard operating procedures and analyst qualification provide adequate control.",
      "rationale": "Use error assessment is not required at MRL 2 for Class II devices. Analyst qualifications, peer review of simulation setup, and documented SOPs for CFD hemolysis analysis provide sufficient procedural control against user-induced errors."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; k-omega SST turbulence model selection is supported by literature consensus for rotating blood pump flows.",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2. The k-omega SST turbulence closure and power-law hemolysis model (Giersiepen et al.) are the consensus choices in published FDA pump CFD literature, providing adequate model form justification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values from device specifications used with documented tolerances.",
      "rationale": "Formal sensitivity analysis of model inputs is not required at MRL 2. Geometric dimensions are taken from nominal CAD specifications. Blood viscosity (0.0035 Pa·s) and density (1056 kg/m³) are standard literature values with well-characterized variability that is negligible relative to hemolysis index uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; FDA pump experimental data from published interlaboratory study provides adequate sample characterization.",
      "rationale": "Detailed characterization of experimental test sample variability is not required at MRL 2. The FDA interlaboratory study (Hariharan et al. 2011) provides NIH measurements from multiple laboratories, and the mean values used for comparison represent a well-characterized population of pump specimens."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters for CFD model match experimental conditions within documented tolerances for all 5 operating points.",
      "rationale": "Inlet velocity profiles, outlet pressure boundary conditions, rotational speed, and fluid properties used in CFD are confirmed to match experimental setup parameters. Deviations are within 3% for all boundary condition parameters across all 5 flow-speed combinations in the COU envelope."
    }
