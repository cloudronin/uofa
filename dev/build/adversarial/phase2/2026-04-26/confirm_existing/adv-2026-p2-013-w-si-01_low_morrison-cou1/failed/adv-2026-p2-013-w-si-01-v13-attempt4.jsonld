      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and sufficiently representative of the COU operating envelope.",
      "rationale": "Experimental data from the FDA benchmark pump study encompass 5 flow-speed operating points spanning 2.5–7 L/min and 2000–3500 RPM, covering the CPB operating envelope. Test conditions are fully documented in the referenced publication."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all validation operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values agreed with experimental measurements within 11% across all 5 operating points. The relative hemolysis index RH remained below 1.0 for all worst-case conditions, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
