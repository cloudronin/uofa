      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match simulated operating conditions within stated tolerances for flow rate and rotational speed.",
      "rationale": "FDA benchmark experimental data were collected at five operating points (2.5 L/min at 2500 RPM through 6 L/min at 3500 RPM). CFD boundary conditions replicate these within ±2% for flow rate and ±10 RPM for rotational speed, meeting required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis agrees with experimental measurements within 20% across all five operating points.",
      "rationale": "Comparison of predicted NIH values against FDA experimental data shows agreement within 12–18% across all five operating conditions. The worst-case operating point is consistently identified by the CFD model, confirming predictive utility for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
