      "acceptanceCriteria": "SQA level 1: solver version controlled and documented; release notes reviewed.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional license with documented version control. Release notes reviewed; no known defects affecting rotating machinery hemolysis simulations. SQA level 1 requirement met for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification level 1: published benchmark results reviewed for the solver on canonical flow problems.",
      "rationale": "ANSYS Fluent has published verification results against canonical benchmark cases (lid-driven cavity, backward-facing step). Code verification at level 1 is satisfied by reliance on vendor-published verification documentation consistent with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for primary QoI (hemolysis index) across all five operating points.",
      "rationale": "Three-level mesh refinement study performed (coarse 3.2M, medium 6.8M, fine 14.1M cells). GCI computed per Celik et al. 2008. Maximum GCI for normalized hemolysis index was 3.7% at the highest flow-speed combination. Discretization error level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty; flow rate and rotational speed match simulation boundary conditions within 2%.",
      "rationale": "FDA benchmark experimental data (Hariharan et al. 2011) documents test conditions including fluid properties, flow rates (2–7 L/min), and rotational speeds (2000–3500 RPM). Boundary condition agreement within 1.5% for all five operating points. Test conditions level 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (relative hemolysis index) within validation uncertainty bounds; RH < 1 at worst-case operating point.",
      "rationale": "Relative hemolysis index RH computed at all five operating points. Maximum RH = 0.87 at 5 L/min / 3000 RPM. Simulation predictions fall within experimental uncertainty bands for 4 of 5 points; the fifth point shows 8% over-prediction, within expanded uncertainty. Output comparison level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (normalized hemolysis index) directly maps to clinical endpoint; secondary QoIs (wall shear stress, exposure time) support mechanistic interpretation.",
      "rationale": "Normalized hemolysis index is the regulatory-relevant QoI for CPB device submissions. Wall shear stress and scalar blood damage exposure time are extracted as secondary QoIs supporting the primary metric. All QoIs are directly relevant to the COU. Level 2 relevance of QoI achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
