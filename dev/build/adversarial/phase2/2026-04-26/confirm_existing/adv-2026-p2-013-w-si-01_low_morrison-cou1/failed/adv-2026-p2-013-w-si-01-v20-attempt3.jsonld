      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulations must be under version control with documented release notes and basic regression testing.",
      "rationale": "ANSYS Fluent 2021R2 is a commercially validated CFD solver with documented QA procedures, version control, and regression test suites. Achieved Gradation 1 is sufficient for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through comparison with known analytical or manufactured solutions.",
      "rationale": "ANSYS Fluent has been verified against multiple benchmark cases including lid-driven cavity and rotating Couette flow. Internal verification reports confirm correct discretization of Navier-Stokes equations. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that key hemolysis QoIs change by less than 5% between medium and fine mesh refinements.",
      "rationale": "A three-level mesh refinement study was performed (3.2M, 6.8M, and 14.1M cells). The relative hemolysis index changed by 3.1% between medium and fine meshes, meeting the 5% criterion. Grid Convergence Index reported as 2.8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within documented tolerances for flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA benchmark experimental data were collected at five operating points (2.5 L/min at 2500 RPM through 6.0 L/min at 3500 RPM). Fluid properties (bovine blood analog) and boundary conditions are documented and replicated in CFD setup within ±2% tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) must agree with experimental measurements within ±15% across all five operating conditions.",
      "rationale": "CFD-predicted RH values compared against experimental hemolysis measurements across all five operating points. Maximum deviation was 11.4%, mean absolute error 7.2%. All predictions satisfy RH < 1 acceptance criterion consistent with predicate device performance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs extracted from simulation (relative hemolysis index, shear stress distribution) must directly support the worst-case operating condition identification decision.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) converted to relative hemolysis index (RH). This directly quantifies red blood cell damage and is the standard metric for CPB device hemolysis evaluation per ISO 10993-4 and FDA guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on a geometry and operating envelope sufficiently representative of the CPB device COU to support extrapolation of credibility.",
      "rationale": "Validation was performed using the FDA generic centrifugal blood pump geometry under the same five operating conditions as the COU. The validation domain (pump geometry, fluid, operating range) closely matches the intended use context, supporting direct credibility transfer."
    },
    {
      "factorStandard": "ASME-VV40-2018",
