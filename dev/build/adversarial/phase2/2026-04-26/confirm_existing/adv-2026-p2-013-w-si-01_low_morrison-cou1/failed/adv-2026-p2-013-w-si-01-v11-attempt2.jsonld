      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating less than 5% change in hemolysis index between medium and fine mesh, with GCI reported.",
      "rationale": "A three-level mesh refinement study was performed on the FDA pump geometry (3.2M, 6.8M, and 14.1M cells). The Grid Convergence Index for the scalar stress-based hemolysis index was 3.1% between medium and fine meshes, satisfying the Gradation 2 criterion. Richardson extrapolation confirmed asymptotic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) reproduced in simulation within documented tolerances.",
      "rationale": "All five flow-speed operating points (2.5–5.0 L/min; 2000–3500 RPM) were replicated in the CFD boundary conditions using measured inlet velocity profiles and fluid properties from the experimental protocol. Temperature, hematocrit, and viscosity were matched within 2% of nominal values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index within 15% of experimental measurements across all five operating points.",
      "rationale": "CFD-predicted hemolysis index values were compared against published experimental data for the FDA pump. Maximum deviation was 11.4% at the 3500 RPM / 2.5 L/min operating point. All five comparisons fell within the 15% acceptance band, satisfying Gradation 2 output comparison requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to the clinical acceptance criterion and regulatory submission metric.",
      "rationale": "The relative hemolysis index RH is the primary regulatory quantity for comparative hemolysis assessment per FDA guidance. The CFD scalar stress model directly computes the Giersiepen-Wurzinger power-law damage accumulation, which is the accepted surrogate for in vitro hemolysis testing. QoI relevance is high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
