      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must operate under a documented quality management system with version control and regression testing at Gradation 2.",
      "rationale": "ANSYS Fluent v19.2 used under ISO 9001-compliant QMS. Version control, regression test suite, and release notes documented. Gradation 2 requirements satisfied for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems at Gradation 2.",
      "rationale": "Solver verified against lid-driven cavity and rotating annulus benchmarks. Observed convergence rates consistent with second-order spatial discretization. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for QoI (hemolysis index) with GCI < 5% on the fine grid at Gradation 2.",
      "rationale": "Three-mesh refinement study performed (2.1M, 5.8M, 14.2M cells). GCI for relative hemolysis index on fine mesh = 2.3%, below 5% threshold. Richardson extrapolation applied. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
