      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (hemolysis index) must be directly relevant to the COU decision at Gradation 2.",
      "rationale": "Relative hemolysis index (RH) is the direct regulatory acceptance criterion for CPB device comparison against predicate. QoI used in validation matches COU decision metric exactly. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
