    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predicted within 25% of experimental measurements across all 5 operating points.",
      "rationale": "Predicted NIH values range from 0.0021 to 0.0087 mg/dL across 5 operating points; experimental values range 0.0019 to 0.0091 mg/dL. Maximum deviation is 18.3%, within the 25% acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
