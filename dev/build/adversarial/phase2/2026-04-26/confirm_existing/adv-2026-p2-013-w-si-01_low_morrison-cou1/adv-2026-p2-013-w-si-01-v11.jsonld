      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release notes and regression test suite.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is a commercially validated package with documented QA procedures, version control, and a comprehensive regression test suite. Required level 1 is achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems with known analytical solutions.",
      "rationale": "Standard benchmark problems including lid-driven cavity and Poiseuille flow were used to confirm correct implementation of the Navier-Stokes equations. Results agree with analytical solutions to within 0.5%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary QoI (hemolysis index) and must be below 5%.",
      "rationale": "A three-level mesh refinement study was performed. GCI for the normalized hemolysis index was 3.2% on the fine mesh (12.4M cells), satisfying the 5% threshold. Medium mesh (6.1M cells) selected for parametric runs based on cost-accuracy trade-off."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used for validation must match simulated operating conditions within ±5% for flow rate and rotational speed.",
      "rationale": "FDA benchmark experimental data were collected at 2500 RPM and 5 flow rates (2.5–7.5 L/min). Simulated boundary conditions replicate these within 1.8% for flow rate and 0.5% for rotational speed. Fluid properties (bovine blood surrogate) are matched to within published uncertainty bands."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index RH must agree with experimental reference within 15% across all 5 operating points.",
      "rationale": "Predicted RH values range from 0.71 to 0.94 against experimental reference values of 0.68 to 0.91. Maximum deviation across all operating points is 6.8%, well within the 15% acceptance threshold. All predictions satisfy the RH < 1 acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (normalized hemolysis index) must be directly traceable to the clinical endpoint of interest (blood damage during CPB).",
      "rationale": "The normalized hemolysis index is derived from the Giersiepen-Wurzinger power-law model applied to Lagrangian particle tracking results. This QoI is directly used in the regulatory submission as a surrogate for in vivo hemolysis, consistent with FDA guidance on blood-contacting device testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
