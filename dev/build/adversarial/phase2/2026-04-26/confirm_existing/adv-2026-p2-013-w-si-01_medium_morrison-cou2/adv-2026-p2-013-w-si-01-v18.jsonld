  "hash": "sha256:a3f7c2e1d94b05867f3a1c2e4d9b0567e8f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression tracking and configuration management under a formal QMS consistent with MRL 5 requirements.",
      "rationale": "The CFD solver has a partial QMS covering version control and regression testing, but formal configuration management records for the hemolysis sub-model are incomplete. Achieved level 3 falls below the required level 4 for MRL 5; gap noted but accepted conditionally pending QMS update."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent must demonstrate convergence order consistent with solver documentation for all governing equations including the hemolysis transport equation.",
      "rationale": "MMS studies confirm second-order convergence for Navier-Stokes terms. The hemolysis power-law transport equation was verified to first order only; documentation does not demonstrate expected second-order convergence. Achieved level 3 is one gradation below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all hemolysis QOIs at all five operating points with GCI below 5% for the fine-grid solution.",
      "rationale": "GCI was computed at three of five operating points. At the two highest rotational speed conditions, mesh refinement was limited by computational budget; GCI values at those points reach 12–15%, exceeding the 5% threshold. Overall achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope (flow rate, rotational speed, fluid properties) within stated tolerances, with full documentation of deviations.",
      "rationale": "Bench tests were conducted with bovine blood at 37°C; viscosity and density match COU fluid within 4%. Rotational speed was controlled to ±20 RPM. One of five operating points was tested at a flow rate 8% outside the COU envelope due to test rig limitations; deviation is documented but not fully bracketed. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) must be reported for each QOI at each operating point with uncertainty intervals on both simulation and experiment.",
      "rationale": "Normalised error metrics are reported for four of five operating points. Experimental uncertainty intervals were not fully propagated for the highest-speed condition due to limited repeat measurements (n=2). Comparison is qualitative at that point. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOIs used in validation (normalised index of hemolysis, NIH) must directly map to the clinical decision threshold without surrogate substitution.",
      "rationale": "NIH is the direct clinical QOI and is used throughout. The mapping from CFD shear stress history to NIH via the power-law model introduces model-form uncertainty that is characterised but not fully bounded. Achieved level 4 is one gradation below required level 5 for Class III absolute prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue properties, and operating envelope as the COU without surrogate geometry substitution.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry, which is the COU geometry. Fluid was bovine blood rather than human blood; species difference introduces a recognised uncertainty in the hemolysis coefficient. This limits relevance to level 4; full human-blood in-vitro data at all five operating points would be required for level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-6 for all equations at all operating points, with solver error estimated relative to discretisation error.",
      "rationale": "Residuals converge to 1e-4 for continuity and momentum; the hemolysis transport equation stalls at 1e-3 at the two highest-speed operating points. Solver error is not formally separated from discretisation error in the error budget. This is a significant gap at MRL 5; achieved level 2 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be independently reviewed by a second analyst; boundary conditions, material properties, and solver settings must be traceable to documented SOPs.",
      "rationale": "An independent analyst reviewed boundary conditions and material properties. Solver turbulence model settings (SST k-omega wall treatment) were not independently verified against the SOP; one reviewer flag remains open. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis constitutive model (power-law or equivalent) must be validated against independent datasets spanning the full shear stress and exposure time range of the COU, with model-form uncertainty quantified.",
      "rationale": "The Giersiepen-Wurzinger power-law model is used. Its coefficients were derived from data outside the shear stress range encountered in the VAD impeller region. Model-form uncertainty is acknowledged but not quantified with a formal interval. Independent validation datasets at high shear (>500 Pa) are absent. This is the most significant credibility gap; achieved level 2 versus required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters must be characterised with probability distributions and propagated through the model via Monte Carlo or equivalent; sensitivity indices must be reported.",
      "rationale": "Monte Carlo UQ was performed on six input parameters (viscosity, density, inlet velocity profile, rotational speed, hemolysis model exponents). Sensitivity indices are reported for four parameters; the two hemolysis model exponents were treated as fixed at nominal values during sensitivity analysis, underestimating total input uncertainty. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A minimum of three independent experimental replicates per operating point must be available; sample-to-sample variability must be characterised and included in the validation metric.",
      "rationale": "Three replicates were obtained at three of five operating points. At the two highest-speed conditions only two replicates were completed due to blood sample availability constraints. Inter-replicate variability is reported where n=3 but estimated only where n=2. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the validation simulation must match those used in the COU simulation within a documented equivalency tolerance; any deviations must be formally assessed for their impact on QOI prediction.",
      "rationale": "Inlet boundary conditions and rotational speed inputs are equivalent between validation and COU simulations within 3%. The hemolysis model coefficients were recalibrated between the validation and COU runs without formal equivalency assessment of the recalibration impact on NIH predictions. Achieved level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment identifies substantive gaps across all 13 factors, with the most critical gap in model form (achieved level 2 versus required level 5) for the hemolysis constitutive model. Despite these gaps, the assessment team accepts the package at Minimal profile level on the basis that (a) Monte Carlo UQ bounds the combined parametric uncertainty at the 95th percentile below the clinical NIH threshold, (b) conservative nominal predictions provide margin against the acceptance threshold at four of five operating points, and (c) a remediation plan is in place for the model-form and solver-error gaps. The package is accepted conditional on completion of the pending cryptographic signature workflow; the SHA-256 hash ensures content integrity in the interim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
