      "acceptanceCriteria": "Software must be verified under a documented QA plan with traceability to MRL 5 requirements; independent code review required.",
      "rationale": "QA plan exists and version control is maintained, but independent third-party code review has not been completed. Achieved level falls one gradation below required for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests using manufactured solutions must be demonstrated for all governing equations relevant to hemolysis transport.",
      "rationale": "Order-of-accuracy verification was performed for Navier-Stokes solver but not for the scalar hemolysis transport equation. Gap identified at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must quantify spatial and temporal discretization error for hemolysis index QoI at all 5 operating points.",
      "rationale": "Three-mesh Richardson extrapolation completed for 3 of 5 operating points. Remaining 2 high-speed conditions show insufficient grid independence evidence. Achieved level is 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including blood analog fluid, pump rotational speed range, and flow rate range with full uncertainty characterization.",
      "rationale": "Bench experiments used glycerol-water blood analog rather than porcine blood; rotational speed range covered 4 of 5 target operating points. Significant gap between bench conditions and clinical VAD operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) must demonstrate model predictions within acceptance band for absolute hemolysis index at all operating points.",
      "rationale": "Area validation metric computed; model over-predicts hemolysis by 18–35% at high-flow conditions. Predictions fall outside the required acceptance band at 2 of 5 operating points. Achieved level is 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, shear stress exposure) must directly correspond to clinical acceptance thresholds for VAD hemolysis.",
      "rationale": "Hemolysis index QoI is directly mapped to clinical threshold. Minor gap: plasma-free hemoglobin correlation used in bench study differs slightly from clinical assay methodology. Achieved level is 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry and operating conditions sufficiently similar to the VAD COU to support extrapolation of credibility evidence.",
      "rationale": "Validation performed on FDA generic pump geometry; actual VAD device geometry differs in impeller blade angle and volute design. Geometric similarity is partial; relevance gap is significant at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to solver tolerance below 1e-6 for all residuals; round-off error analysis must be documented.",
      "rationale": "Iterative convergence documented to 1e-4 only; round-off error analysis not performed. Two operating points show residual oscillations indicating incomplete convergence. Achieved level is 2, well below required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
