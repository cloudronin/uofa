      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented user qualification records and simulation execution checklist must be on file; peer review of simulation setup required.",
      "rationale": "Lead analyst holds relevant CFD credentials; however, peer review of boundary condition setup was not formally documented. Use error factor falls one gradation below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for turbulence closure and hemolysis power-law model must be quantified through sensitivity analysis or Bayesian model comparison.",
      "rationale": "Model form uncertainty analysis not performed. The power-law hemolysis model (Giersiepen-Wurzinger) is known to have significant uncertainty at high shear rates relevant to VAD conditions. Flagged as epistemic gap at MRL 5; factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented uncertainty distributions; Monte Carlo propagation must cover blood viscosity, density, and hemolysis model coefficients.",
      "rationale": "Monte Carlo UQ was initiated but hemolysis model coefficients (alpha, beta in power-law) were treated as deterministic. Input uncertainty for non-Newtonian viscosity model not characterized. Not assessed for MRL 5 compliance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterize inter-sample variability in hemolysis measurements; statistical power analysis required.",
      "rationale": "Only 3 replicate experiments performed per operating point; no statistical power analysis conducted. Sample size insufficient to characterize biological variability in hemolysis response. Not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between computational input parameters and experimental conditions must be demonstrated quantitatively, including fluid rheology and boundary condition fidelity.",
      "rationale": "No formal equivalency mapping between CFD boundary conditions and experimental setup documented. Inlet velocity profile assumed uniform in CFD; experimental inlet conditions not characterized. Not assessed at MRL 5."
