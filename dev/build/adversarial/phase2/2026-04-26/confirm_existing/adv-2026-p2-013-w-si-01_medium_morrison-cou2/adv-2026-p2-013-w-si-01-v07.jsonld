      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and maintain a formal version-controlled test suite with regression coverage exceeding 80% of critical code paths.",
      "rationale": "The CFD solver holds ISO 9001 certification and a regression suite is maintained; however, coverage of hemolysis-specific sub-routines reaches only 61%, falling short of the 80% threshold required at MRL 5. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Observed order of accuracy must match theoretical order within 10% for all governing equations, verified on at least three systematically refined grids using the Method of Manufactured Solutions.",
      "rationale": "MMS verification performed on three grid levels; observed order matches theoretical order for momentum equations but deviates by 18% for the scalar hemolysis transport equation, yielding achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
