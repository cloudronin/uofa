    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (hemolysis index) is identical to clinical decision QoI; no surrogate quantities used.",
      "rationale": "The hemolysis index is used directly as both validation and decision QoI, which is appropriate. Minor concern: the experimental hemolysis index uses a modified power-law exponent that differs slightly from the clinical threshold formulation. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry, at the same operating conditions, and with the same blood analogue as the COU.",
      "rationale": "Validation uses the FDA generic pump geometry which matches the COU geometry. However, experiments used a glycerol-water blood analogue rather than porcine blood, introducing a relevance gap for hemolysis. Achieved level 2 against required level 4."
    },
