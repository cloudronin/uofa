  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite, version control, and configuration management consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2023R2) has a documented QA framework including regression test suite, ISO 9001-aligned configuration management, and release validation reports. Achieved level meets the required level 4 for Class III MRL 5 device assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing and method-of-manufactured-solutions (MMS) verification must be demonstrated for the hemolysis transport equation implementation.",
      "rationale": "Standard solver verification benchmarks are available and passed; however, MMS verification specific to the scalar hemolysis damage transport equation was not independently performed by the submission team. Achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must be performed on hemolysis index QOI across at least three systematically refined meshes at all 5 operating points.",
      "rationale": "Grid convergence index analysis was performed at 3 of 5 operating points using three mesh levels. The two highest-speed operating points show GCI values above the 2% threshold. Achieved level 3 does not meet required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match the COU operating envelope within documented tolerances; fluid properties, temperature, and hematocrit must be controlled and reported.",
      "rationale": "Bench experiments used bovine blood at 37°C and 35% hematocrit consistent with the COU specification. Flow rates and impeller speeds were controlled within ±1% of target values. All five operating points are within the COU envelope. Achieved level meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric-based comparison (e.g., normalized RMSE, validation uncertainty) between predicted and measured hemolysis index must be reported with uncertainty bounds at all operating points.",
      "rationale": "Normalized RMSE across 5 operating points is 18%, exceeding the 10% target. Validation uncertainty intervals were computed via Monte Carlo but overlap with experimental uncertainty only at 3 of 5 points. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOI used in validation (normalized index of hemolysis, NIH) must directly correspond to the absolute hemolysis threshold used in the regulatory decision.",
      "rationale": "The primary QOI is the normalized index of hemolysis (NIH) in mg/dL, which is the same metric used in the absolute clinical threshold comparison. No surrogate or proxy QOI substitution was made. Achieved level meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be performed on the same pump geometry and at operating conditions spanning the full COU envelope; extrapolation beyond the validated range must be quantified.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is the reference geometry for the COU. However, two operating points at the extreme of the speed envelope represent mild extrapolation beyond the validated experimental range. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence residuals for all transport equations must reach at least 1e-5; solver floating-point error sensitivity must be documented.",
      "rationale": "Continuity residuals plateau at approximately 1e-4 for the two highest-speed cases, falling short of the 1e-5 requirement. Floating-point sensitivity analysis was not performed. Achieved level 2 is below required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation workflow with peer review and independent re-run verification must be in place to reduce operator-induced setup errors.",
      "rationale": "A simulation setup checklist exists but independent re-run verification by a second analyst was not performed. One boundary condition input error was identified and corrected during internal review, indicating residual use-error risk. Achieved level 2 is below required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis damage model (power-law or equivalent) must be assessed for applicability to the shear stress and exposure-time regime of the VAD COU, with sensitivity analysis on model-form assumptions.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is used without modification. Literature evidence indicates this model was calibrated on Couette flow data and may underpredict hemolysis in complex recirculation zones present in VAD impellers. Sensitivity analysis on model-form constants was not performed. Achieved level 2 is substantially below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs must have documented sources with uncertainty characterization; Monte Carlo propagation must cover all significant input uncertainties.",
      "rationale": "Blood viscosity and density are sourced from published literature with reported uncertainty ranges. Monte Carlo UQ was performed over 6 input parameters. However, the red blood cell mechanical fragility parameter was treated as deterministic due to lack of patient-specific data, representing an unquantified epistemic gap. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must be replicated across at least 3 independent test runs per operating point to characterize biological and measurement variability.",
      "rationale": "Three independent test runs were performed at each of the 5 operating points using separate blood batches. Coefficient of variation across replicates ranged from 6% to 14%, which is within acceptable bounds for bovine blood hemolysis testing. Achieved level meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The correspondence between CFD boundary condition inputs and experimentally measured inlet/outlet conditions must be quantitatively demonstrated with documented discrepancy bounds.",
      "rationale": "Inlet velocity profiles were mapped from PIV measurements at the pump inlet plane; however, the CFD inlet turbulence intensity was estimated from empirical correlations rather than measured directly. Discrepancy in inlet turbulent kinetic energy is estimated at up to 30%, which affects near-impeller shear stress predictions. Achieved level 2 is below required level 3."
    }
