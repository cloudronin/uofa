  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version-controlled QA regime with documented test suite covering turbulence and non-Newtonian viscosity modules relevant to blood flow.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is under institutional version control and has a documented regression test suite; however, blood-specific non-Newtonian viscosity module tests are not formally documented, leaving a gap at the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must be completed for all governing equations including the hemolysis power-law transport equation.",
      "rationale": "Order-of-accuracy verification was performed for Navier-Stokes terms; however, the hemolysis scalar transport equation was not independently verified against an analytical solution, yielding an achieved level of 3 against a required level of 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must be applied on at least three systematically refined meshes with GCI reported for hemolysis index QoI.",
      "rationale": "Three-mesh Richardson extrapolation was performed for velocity and wall shear stress; GCI for the hemolysis index QoI was estimated but mesh refinement near impeller blade tips was insufficient, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five VAD operating points (flow rate, rotational speed, hematocrit, temperature) within stated tolerances.",
      "rationale": "Experimental data from the FDA benchmark covers three of the five target operating points; hematocrit and temperature were controlled but two high-speed operating points lack matching experimental runs, limiting achieved level to 3 against a required level of 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metrics (e.g., NMSE, MAPE) must be reported for hemolysis index predictions against experimental measurements at all operating points with uncertainty bounds.",
      "rationale": "Quantitative output comparison was performed at three operating points; MAPE for hemolysis index was 38%, well outside the 15% acceptance band. The two untested operating points introduce additional unquantified bias, yielding an achieved level of 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The predicted QoI (normalized index of hemolysis, NIH) must be directly mappable to the clinical acceptance criterion without intermediate empirical correction factors.",
      "rationale": "NIH is the primary QoI and maps directly to the clinical threshold; however, the power-law hemolysis model requires an empirical exponent calibrated on bovine blood, introducing a species-correction factor that weakens direct relevance to human clinical use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog, and operating envelope as the COU; any geometric or fluid substitution must be formally justified.",
      "rationale": "Validation used the FDA generic pump geometry (matching COU) but employed a glycerol-water blood analog rather than anticoagulated human blood. The fluid substitution was not formally justified against a similarity criterion, significantly reducing validation relevance at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and floating-point round-off contributions must be quantified and shown to be negligible relative to discretization error for hemolysis QoI.",
      "rationale": "Iterative residuals were reported (reaching 1e-5) but no formal analysis of solver-induced numerical error separate from discretization error was performed. This factor was flagged as an epistemic gap at MRL 5 and is not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented review process must confirm that all solver settings, boundary conditions, and post-processing scripts were applied correctly and independently checked.",
      "rationale": "No independent peer review of solver setup and post-processing scripts was conducted. User error risk is unquantified. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty analysis must compare at least two turbulence closures and two hemolysis constitutive models against experimental data with statistical discrimination.",
      "rationale": "Only the k-omega SST turbulence model and the Giersiepen-Wurzinger hemolysis power law were used. No alternative model forms were evaluated. Model form uncertainty is entirely uncharacterized at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterized with probability distributions derived from measurement data; Monte Carlo propagation must report 95th-percentile bounds on hemolysis index.",
      "rationale": "Monte Carlo UQ was performed over inlet flow rate and rotational speed uncertainties; however, hemolysis model coefficients (alpha, beta, C) were treated as fixed nominal values rather than uncertain inputs, underestimating total prediction uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to estimate hemolysis mean and variance with 90% confidence; sample-to-sample variability must be reported.",
      "rationale": "Sample size and inter-sample variability for the experimental hemolysis measurements were not reported in the available dataset documentation. This factor is flagged as an epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal equivalency argument must demonstrate that validation experiment input parameters (fluid properties, geometry tolerances) are equivalent to COU conditions within a defined similarity metric.",
      "rationale": "No formal equivalency argument was constructed to bridge glycerol-water analog properties to human blood rheology under VAD shear conditions. Equivalency of input parameters is entirely uncharacterized."
    }
