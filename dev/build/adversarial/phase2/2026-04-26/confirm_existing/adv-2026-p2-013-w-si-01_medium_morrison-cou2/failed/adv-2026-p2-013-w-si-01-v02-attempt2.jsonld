  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression testing, version control, and FDA-recognized QMS compliance at Gradation 4.",
      "rationale": "The CFD solver has basic version control and a limited regression test suite. No formal FDA-recognized QMS documentation was available. Achieved level falls two gradations below the MRL-5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic order-of-accuracy verification against manufactured solutions required for all governing equation terms relevant to hemolysis transport.",
      "rationale": "Order-of-accuracy testing was performed only for the momentum equations. The scalar hemolysis transport equation was not verified against a manufactured solution, leaving a significant gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence index (GCI) study required across at least three systematically refined meshes for hemolysis index QoI.",
      "rationale": "A three-mesh GCI study was completed for pressure rise and flow uniformity but not for the hemolysis index directly. Discretization uncertainty in the hemolysis scalar remains unquantified at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including blood analogue viscosity, hematocrit range, and all five target flow-speed combinations.",
      "rationale": "Four of five flow-speed combinations were matched in the validation experiments. Hematocrit was held at a single nominal value rather than spanning the clinical range, representing a partial gap against the MRL-5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation uncertainty U_val) must be computed and shown to be less than the model application uncertainty at all operating points.",
      "rationale": "Hemolysis index predictions were compared qualitatively against experimental data. No formal validation uncertainty metric was computed; scatter in experimental replicates was acknowledged but not propagated into a U_val estimate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must be the same hemolysis index formulation (modified index of hemolysis, MIH) used in the regulatory submission with identical post-processing pipeline.",
      "rationale": "The normalized index of hemolysis (NIH) was used in validation experiments while the submission requires MIH. A conversion factor was applied but introduces additional model-form uncertainty not fully accounted for."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the FDA generic pump geometry under VAD operating conditions; surrogate geometries are not acceptable at MRL 5.",
      "rationale": "Validation was performed on a simplified axisymmetric impeller geometry as a surrogate for the FDA generic centrifugal pump. Geometric fidelity gap between surrogate and target device reduces relevance score significantly."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria, floating-point round-off analysis, and parallel decomposition sensitivity must all be documented and shown to be negligible relative to discretization error.",
      "rationale": "Numerical solver error was not assessed. Convergence residual thresholds were reported but no formal analysis of round-off or parallel decomposition sensitivity was performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent simulation audit or peer review of simulation setup, boundary condition application, and post-processing scripts required at MRL 5.",
      "rationale": "No independent audit of the simulation setup was conducted. The same analyst who built the model also performed post-processing. Use error contribution to total uncertainty is unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified through sensitivity analysis comparing at least two alternative damage accumulation models across the full operating envelope.",
      "rationale": "A single power-law hemolysis model (Giersiepen-Wurzinger) was used without comparison to alternative model forms. Model-form uncertainty is the dominant unquantified source at MRL 5 and was not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full Monte Carlo propagation of all uncertain input parameters (blood viscosity, density, hemolysis model coefficients, inlet velocity profile) through the CFD model to hemolysis index output required.",
      "rationale": "Monte Carlo UQ was initiated but only inlet flow rate uncertainty was propagated. Hemolysis model coefficients (C, alpha, beta in the power-law) were treated as fixed constants despite known literature variability. Factor not assessed to the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood or blood analogue sample characterization must include hematocrit, mean corpuscular fragility, and donor variability across a minimum of three independent sample batches.",
      "rationale": "Test sample characterization was not reported in available documentation. Donor variability and sample-to-sample consistency of the blood analogue were not assessed, representing a complete gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional analysis or direct measurement must confirm that non-dimensional groups governing hemolysis (Reynolds number, exposure time distribution) match between validation experiments and COU operating conditions.",
      "rationale": "No equivalency analysis was performed between validation bench conditions and the VAD COU operating envelope. Reynolds number matching was assumed but not verified; exposure time distributions were not compared."
    }
