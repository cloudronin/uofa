      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan and regression test suite covering hemolysis model; independent code review required at MRL 5.",
      "rationale": "Solver is version-controlled and basic regression tests exist, but no independent code review has been performed and the hemolysis transport model lacks a dedicated QA test suite. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification (method of manufactured solutions or equivalent) demonstrated for all governing equations including hemolysis transport at MRL 5.",
      "rationale": "Order-of-accuracy verification was performed only for the Navier-Stokes solver; the hemolysis scalar transport equation has not been independently verified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based discretization error estimate with GCI < 5% on hemolysis index QoI across all 5 operating points.",
      "rationale": "Three-level mesh refinement study was completed and GCI computed; however GCI exceeds 5% at two of five operating conditions and extrapolation was not repeated after geometry corrections. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with measurement uncertainty; inlet velocity profiles and fluid rheology matched to CFD inputs within stated tolerances.",
      "rationale": "Bench test conditions are partially documented; inlet velocity profiles were not measured directly and viscosity was assumed Newtonian without rheological confirmation at VAD shear rates. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric) applied to hemolysis index predictions versus experimental data with uncertainty bands on both sides.",
      "rationale": "Comparisons are presented graphically; no formal validation metric with combined experimental and numerical uncertainty has been computed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (hemolysis index) directly maps to clinical endpoint; sensitivity analysis confirms hemolysis index is the dominant predictor of patient risk across operating envelope.",
      "rationale": "Hemolysis index is clinically relevant but sensitivity analysis linking CFD QoI to clinical hemolysis endpoint is absent. Achieved level 2 against required level 3."
    },
