  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under formal configuration management with documented V&V test suite; all code changes traceable to requirements at MRL 5.",
      "rationale": "The CFD solver has basic version control and a partial regression test suite. Formal configuration management per FDA software guidance is not fully implemented. Achieved level 2 falls short of required level 4 for MRL 5 Class III device context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or equivalent benchmark verification covering all active physics modules, including the hemolysis transport scalar, at MRL 5.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes equations but not extended to the hemolysis damage accumulation scalar transport. Code verification is partial; achieved level 2 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on at least three systematically refined meshes reporting discretization uncertainty on hemolysis index QoI.",
      "rationale": "Three-mesh GCI study performed; observed order of convergence is 1.6 (below formal second-order). Hemolysis QoI discretization uncertainty is 9.4%, which exceeds the 5% target for this MRL. Achieved level 3, required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be fully characterized with documented measurement uncertainty on all boundary inputs; fluid properties and pump rotational speed verified against simulation inputs.",
      "rationale": "Experimental boundary conditions documented for 4 of 5 operating points; one high-speed condition lacks fluid temperature characterization affecting viscosity. Measurement uncertainty on pressure boundary is ±3.1%, partially characterized. Achieved level 3, required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) applied to hemolysis index predictions versus measurements, accounting for both experimental and numerical uncertainty.",
      "rationale": "Simple percent-error comparison used rather than a formal validation metric incorporating combined uncertainty. Mean absolute error is 18.7% across operating points; no uncertainty band overlap analysis performed. Achieved level 2, required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index) must directly correspond to the clinical decision metric; no surrogate QoI substitution permitted at MRL 5.",
      "rationale": "Normalized Index of Hemolysis (NIH) is used as both the validation QoI and the clinical decision metric. Direct correspondence confirmed; no surrogate substitution. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be performed on the same pump geometry and fluid (blood analog) as the COU; operating envelope must fully overlap COU conditions.",
      "rationale": "Validation performed on the FDA generic pump geometry using a glycerol-water blood analog. COU requires ovine blood; rheological differences introduce unquantified extrapolation. Operating envelope covers 3 of 5 COU flow-speed pairs. Achieved level 2, required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and residual norms reported for each simulation; round-off and iterative errors bounded relative to discretization error.",
      "rationale": "Solver convergence residuals were monitored but not formally reported or bounded against discretization error. Iterative error contribution to hemolysis QoI is unknown. Factor flagged as not-assessed; achieved level 1, required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of model setup, boundary condition application, and post-processing steps to identify analyst-introduced errors.",
      "rationale": "No independent review of simulation setup was conducted. Single analyst performed model construction, execution, and post-processing without documented cross-check. Use error contribution is unquantified. Factor not-assessed; achieved level 1, required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive law selection justified with sensitivity analysis; alternative model forms evaluated and selection uncertainty bounded.",
      "rationale": "SST k-omega turbulence model selected without documented justification over alternatives (k-epsilon, LES). Power-law hemolysis model (Giersiepen-Wurzinger) used without evaluation of alternative damage accumulation formulations. Model form uncertainty not quantified. Factor not-assessed; achieved level 1, required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; Monte Carlo or equivalent propagation of input uncertainty through to hemolysis QoI with reported confidence intervals.",
      "rationale": "Monte Carlo uncertainty quantification performed on inlet flow rate and rotational speed (2 of 7 uncertain inputs). Fluid viscosity, wall roughness, and hemolysis model exponents treated as deterministic. Partial UQ coverage; achieved level 2, required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample population; sufficient replicates to estimate measurement variability on hemolysis index at each operating point.",
      "rationale": "Experimental hemolysis data from a single published dataset with no replicate runs at individual operating points. Sample-to-sample biological variability in blood analog not characterized. Factor not-assessed; achieved level 1, required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental inputs and simulation boundary conditions; any discrepancies quantified and their effect on QoI bounded.",
      "rationale": "No formal equivalency mapping documented between experimental boundary conditions and CFD boundary condition implementation. Inlet velocity profile assumed uniform in simulation; experimental flow conditioner geometry not replicated. Discrepancy effect on hemolysis index unquantified. Factor not-assessed; achieved level 1, required level 4."
    }
