    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., NRMSE) between predicted and measured absolute hemolysis index must be reported with uncertainty bounds at all five operating points.",
      "rationale": "Qualitative trend agreement is demonstrated but no quantitative agreement metric with uncertainty bounds is reported. Achieved level 2 is well below the required level 4."
