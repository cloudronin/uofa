  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under formal version control with documented test suite covering blood-analog fluid cases; independent code review required at MRL 5.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has a vendor test suite but no independent third-party audit was performed. Version control is documented but user-modification logs are incomplete. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-disk and pipe-flow benchmarks must confirm expected spatial and temporal convergence rates.",
      "rationale": "Order-of-accuracy testing was performed on a 2-D lid-driven cavity only; no rotating geometry benchmark was executed. Temporal convergence not verified for the impeller rotation rate used in VAD conditions. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on at least three systematically refined meshes; discretization error band must be reported for each QoI.",
      "rationale": "A three-level mesh refinement study was conducted but GCI was computed only for pressure rise, not for hemolysis index. The hemolysis QoI discretization error is therefore unquantified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope (flow rate 3–8 L/min, speed 2400–3600 rpm) with documented uncertainty on all boundary conditions.",
      "rationale": "Experimental data cover 4 of 5 target operating points; the highest-speed condition (3600 rpm, 3 L/min) was not tested experimentally due to pump availability constraints. Boundary condition uncertainties are partially documented. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric M) must be computed for hemolysis index at all operating points with combined experimental and numerical uncertainty bands.",
      "rationale": "Hemolysis index predictions exceed experimental measurements by 18–42% across tested operating points. Combined uncertainty bands do not overlap at two of four tested conditions, indicating model-form inadequacy. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis, NIH) must be directly linked to the clinical endpoint and its sensitivity to model parameters must be characterized.",
      "rationale": "NIH is the accepted clinical surrogate for hemolysis and is directly used in the acceptance criterion. Sensitivity analysis via Monte Carlo was performed but did not include all relevant blood rheology parameters. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating conditions as the COU; geometric fidelity must be confirmed by metrology report.",
      "rationale": "Validation used a scaled acrylic mock-up rather than the production titanium impeller. Surface roughness and tip-clearance tolerances differ from the production device. Geometric fidelity was not confirmed by independent metrology. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must be below 1e-6 for all transport equations; floating-point round-off sensitivity must be documented.",
      "rationale": "Solver residuals were reported at 1e-4 for momentum equations; no round-off sensitivity study was performed. This factor is flagged as an epistemic gap at MRL 5 — insufficient evidence to assign a credible achieved level above 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
