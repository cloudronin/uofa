      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented, version control enforced, regression test suite covering hemolysis model routines with traceability to requirements.",
      "rationale": "Version control is in place and a partial SQA plan exists, but the regression test suite covers fewer than 40% of hemolysis-relevant code paths. Required level 4 demands full traceability and independent SQA audit; achieved level 2 reflects documented but incomplete SQA coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations including hemolysis transport; observed order of accuracy confirmed within 10% of theoretical order.",
      "rationale": "MMS was applied to the Navier-Stokes solver but not extended to the power-law hemolysis damage accumulation transport equation. Observed spatial order of accuracy for velocity is 1.87 vs theoretical 2.0; hemolysis transport verification is absent. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis index QoI on three systematically refined meshes; GCI < 5% on fine mesh.",
      "rationale": "Three-mesh GCI study performed on pressure rise and flow uniformity; GCI on hemolysis index QoI computed only on two meshes with refinement ratio 1.2, yielding unreliable extrapolation. Reported GCI of 12% on hemolysis index exceeds the 5% threshold. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
