  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan, regression test suite, and change-control records for all hemolysis model modifications.",
      "rationale": "Solver is version-controlled and regression tests exist, but the QA plan does not cover the user-defined hemolysis scalar transport UDF. Change-control records are incomplete. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent demonstrated for all governing equations including hemolysis transport at MRL 5.",
      "rationale": "MMS has been applied to the Navier-Stokes solver but not to the hemolysis power-law scalar transport equation. Code verification for the coupled hemolysis model is incomplete. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on at least three systematically refined meshes; reported discretization uncertainty must be below 5% for hemolysis index QoI.",
      "rationale": "Three mesh levels were run but the GCI on the hemolysis index exceeds 12% at the design point. Spatial discretization error is not adequately controlled. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profiles, fluid temperature, blood viscosity) must be reproduced in simulation within stated uncertainty bounds.",
      "rationale": "Inlet velocity profiles and fluid temperature are well-matched. Blood viscosity model is Newtonian whereas experimental fluid showed mild shear-thinning; this mismatch is documented but not resolved. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation metric M) computed with uncertainty; agreement within combined experimental and simulation uncertainty bands for all 5 operating points.",
      "rationale": "Relative error on hemolysis index ranges from 18% to 41% across the five operating points. Predicted values fall outside combined uncertainty bands at three of five conditions. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, shear stress exposure) must directly correspond to clinical acceptance thresholds without intermediate surrogate mapping.",
      "rationale": "Hemolysis index is directly compared; however shear-stress exposure time is computed via a surrogate path-line integration that introduces additional model-form assumptions. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating range (flow rate 3–8 L/min, speed 2400–3600 RPM), and blood analogue fluid as the COU.",
      "rationale": "Validation used a glycerol-water analogue rather than porcine blood. Pump geometry is identical but operating range covers only 3 of 5 COU flow-speed combinations. Relevance gap is significant. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and floating-point round-off contributions must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Iterative convergence criteria are reported but round-off and solver tolerance contributions to hemolysis QoI have not been formally quantified. Factor flagged as epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent simulation replication by a second analyst; documented checklist for boundary condition setup and post-processing of hemolysis index.",
      "rationale": "No independent replication has been performed. Analyst checklist exists but has not been validated against an independent run. Epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of hemolysis model form (power-law vs. strain-based vs. mechanistic) with uncertainty attributed to model-form selection documented.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model is used. No model-form uncertainty analysis has been performed. This is a critical epistemic gap for MRL 5 absolute hemolysis prediction. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (power-law exponents, blood viscosity, inlet turbulence intensity) must be characterised with probability distributions and propagated via Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ has been performed on three of six uncertain inputs. Power-law exponent uncertainty is included but blood viscosity and wall roughness distributions are not propagated. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must include sufficient replicates (n ≥ 5 per operating point) with inter-sample variability reported.",
      "rationale": "Experimental dataset contains n=3 replicates per operating point. Inter-sample variability is reported but sample size is insufficient to characterise biological variability at MRL 5. Epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that simulation input parameters (geometry tolerances, surface finish, fluid properties) are equivalent to those of the physical test article within stated bounds.",
      "rationale": "Surface finish of the physical impeller has not been characterised; wall roughness in the simulation is assumed hydraulically smooth. Geometric equivalency for secondary flow passages is unverified. Epistemic gap. Achieved level 1."
    }
