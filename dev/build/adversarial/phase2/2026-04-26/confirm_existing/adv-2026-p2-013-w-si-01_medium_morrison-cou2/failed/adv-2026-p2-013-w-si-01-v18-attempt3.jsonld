  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with traceability to release version; configuration management records required.",
      "rationale": "The CFD solver used for hemolysis prediction has partial documentation of its V&V test suite. Configuration management records exist for the solver binary but lack full traceability to the specific release version used in the hemolysis runs. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks must demonstrate expected convergence rates for the hemolysis transport equation.",
      "rationale": "Order-of-accuracy tests were performed on a simplified pipe-flow case but not on a rotating impeller geometry representative of the centrifugal pump. Convergence rates for the hemolysis scalar transport equation were not independently verified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence study on hemolysis index QoI; GCI < 5% at operating points of interest.",
      "rationale": "A three-level grid-convergence study was performed; however, the finest mesh still exhibits GCI values of 12–18% for the hemolysis index at high-speed operating points. The required GCI threshold of 5% is not met. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five COU flow-speed combinations with documented fluid temperature, hematocrit, and shear-exposure history controls.",
      "rationale": "Four of five COU operating points were replicated in bench testing. The fifth (maximum speed, minimum flow) was excluded due to pump cavitation risk in the test rig. Temperature and hematocrit were controlled and documented. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty Uval) must be computed for hemolysis index at all assessed operating points; systematic bias must be characterised.",
      "rationale": "Quantitative E% values were computed for four operating points. Systematic over-prediction bias of 25–40% was identified but not corrected or accounted for in the uncertainty budget. No validation uncertainty Uval was formally propagated. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI must be the absolute hemolysis index (NIH or equivalent) directly comparable to the clinical threshold; surrogate QoIs are not acceptable at MRL 5.",
      "rationale": "The primary QoI is the normalised index of haemolysis (NIH), which is directly comparable to the clinical threshold. Secondary surrogate metrics (wall shear stress peaks) were also reported but not used as acceptance criteria. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue fluid properties, and operating envelope as the COU; any geometry simplification must be quantitatively justified.",
      "rationale": "Validation experiments used the FDA generic pump geometry rather than the actual VAD device geometry. While the FDA pump is a widely accepted surrogate, no quantitative geometric similarity analysis was performed to bound the extrapolation error to the actual device. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver-specific numerical diffusion must each be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Numerical solver error was not formally assessed. Residual convergence plots were provided but iterative convergence error was not separated from discretization error in the overall numerical uncertainty budget. Flagged as epistemic gap at MRL 5; achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition specification, and post-processing scripts must be documented; blind re-analysis by a second analyst is required at MRL 5.",
      "rationale": "No independent review or blind re-analysis was performed. A single analyst set up and post-processed all five simulation cases. Use error is an unquantified epistemic gap. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified against mechanistic red blood cell damage data; alternative model forms must be evaluated and the selected form shown to be adequate for absolute prediction.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was adopted without evaluation of alternative mechanistic models. At MRL 5 requiring absolute prediction, model-form uncertainty is a critical unresolved epistemic gap. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and uncertainty quantification must be performed for all hemolysis model input parameters (power-law exponents, threshold stress, hematocrit dependence) using Monte Carlo or equivalent.",
      "rationale": "Monte Carlo UQ was performed on flow boundary conditions but not on the hemolysis model input parameters themselves (power-law exponents α, β). Parameter sensitivity to these coefficients is known to dominate hemolysis index uncertainty; this gap is unresolved. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analogue samples must be characterised for viscosity, hematocrit, and red blood cell age distribution; inter-donor variability must be quantified across a minimum of three independent sample lots.",
      "rationale": "Experiments used a single porcine blood lot. Inter-donor variability and red blood cell age distribution were not characterised. This is an unquantified source of experimental uncertainty that propagates directly into the validation comparison. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional and non-dimensional similarity parameters (Reynolds number, exposure time distributions) must be shown equivalent between validation experiment and COU operating conditions.",
      "rationale": "No formal similarity analysis was performed between the FDA pump validation conditions and the VAD COU operating envelope. Reynolds number ranges differ by approximately 30% at the highest speed condition. Equivalency of input parameters is an unresolved epistemic gap at MRL 5. Achieved level 1 against required level 4."
    }
