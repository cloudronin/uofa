  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; independent code audit required at MRL 5.",
      "rationale": "The CFD solver is version-controlled and unit tests exist, but no independent third-party audit has been performed. Regression suite does not cover all hemolysis-relevant shear regimes. Achieved level 2 falls short of required level 4 for MRL 5 Class III device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification using method of manufactured solutions (MMS) for all governing equations including hemolysis transport equation.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the hemolysis scalar transport equation. MMS verification is incomplete. Achieved level 2 is insufficient for MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based discretization error estimate with GCI below 5% on hemolysis index QoI; three systematically refined grids required.",
      "rationale": "A two-grid convergence study was performed; Richardson extrapolation with three grids was not completed. GCI estimates are unavailable for the hemolysis index. Spatial discretization error is inadequately characterized at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation data collected under conditions spanning the full VAD operating envelope (5 flow-speed combinations); blood analog fluid properties and temperature documented.",
      "rationale": "Experimental data were collected at 3 of 5 required flow-speed combinations. Temperature and blood analog viscosity were documented but hematocrit variability was not controlled. Partial coverage of the operating envelope limits confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_n or NRMSE) with uncertainty bands; agreement within combined experimental and simulation uncertainty at all operating points.",
      "rationale": "Qualitative agreement plots were provided; quantitative comparison metrics with uncertainty bands were not computed. Systematic over-prediction of hemolysis index by approximately 30% was observed but not formally quantified against acceptance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical hemolysis thresholds; hemolysis index formulation must be traceable to accepted clinical literature.",
      "rationale": "The hemolysis index QoI is directly traceable to the Giersiepen-Wurzinger power-law model and maps to plasma free hemoglobin thresholds used in clinical practice. Relevance is well-established but the power-law exponents carry significant uncertainty not fully propagated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometrically and operationally similar pump configurations; Reynolds and Stokes number similarity documented.",
      "rationale": "Validation was performed on the FDA benchmark pump geometry which shares key geometric features with the VAD configuration. Dimensionless similarity parameters are documented. However, the VAD operating range extends to higher rotational speeds not covered in the validation dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to machine precision for steady-state cases; time-step sensitivity study for transient cases; residual norms below 1e-6 for all equations.",
      "rationale": "Solver convergence criteria were set to residual norms of 1e-4, which is insufficient for MRL 5. No time-step sensitivity study was performed for the transient impeller rotation cases. This factor was flagged as an epistemic gap and not formally assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation execution protocol; independent review of boundary condition setup and material property assignment; traceability from COU inputs to model inputs.",
      "rationale": "No formal use-error assessment was performed. Boundary conditions were set by the simulation engineer without independent peer review. Traceability from clinical COU parameters to CFD boundary conditions is undocumented. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model selection, hemolysis constitutive model, and non-Newtonian blood rheology assumptions with sensitivity analysis demonstrating model form uncertainty is bounded.",
      "rationale": "Model form uncertainty was not assessed. The k-omega SST turbulence model was selected without comparative evaluation against alternative turbulence closures. Non-Newtonian blood rheology was neglected without sensitivity justification. Critical gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full Monte Carlo uncertainty propagation from input parameter distributions (viscosity, density, inlet velocity profile, rotational speed) to hemolysis index output distribution.",
      "rationale": "Monte Carlo UQ was initiated but did not converge due to insufficient sample count (N=200 vs. required N≥2000 for 95% CI stability on tail hemolysis predictions). Input uncertainty distributions for blood viscosity were assumed Gaussian without experimental support."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independently manufactured pump specimens tested; inter-specimen variability characterized and incorporated into validation uncertainty budget.",
      "rationale": "Experimental hemolysis data were collected from a single pump specimen. Inter-specimen manufacturing variability was not characterized. The validation dataset is therefore insufficient to support the uncertainty budget required at MRL 5 for a Class III device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between validation experiment input parameters and COU input parameters with documented equivalency rationale; any gaps in equivalency quantified as extrapolation uncertainty.",
      "rationale": "No formal equivalency mapping was produced. The validation experiments used a glycerol-water blood analog at fixed hematocrit while the COU involves porcine blood at variable hematocrit. The extrapolation uncertainty introduced by this mismatch was not quantified."
    }
  ],
