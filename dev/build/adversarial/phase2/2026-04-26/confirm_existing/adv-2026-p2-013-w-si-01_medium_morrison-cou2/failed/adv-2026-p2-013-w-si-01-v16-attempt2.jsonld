  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under formal configuration management with regression test suite covering hemolysis model; all code changes documented and reviewed.",
      "rationale": "The CFD solver used for hemolysis prediction has basic version control but lacks a formal regression test suite specific to the power-law hemolysis model. Configuration management documentation is incomplete for the blood damage subroutine. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification (method of manufactured solutions or equivalent) demonstrated for all governing equations including hemolysis transport.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not extended to the hemolysis damage accumulation model. Manufactured solution verification for the power-law hemolysis source term is absent. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or Richardson extrapolation reported for hemolysis index QoI at all 5 operating points; discretization uncertainty bounded below 5% of mean hemolysis prediction.",
      "rationale": "Three-level mesh refinement study was conducted at two of five operating points. GCI was not computed at the highest flow-speed combination where shear gradients are most severe. Discretization uncertainty bounding is incomplete. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match VAD operating envelope (flow 3–6 L/min, speed 2400–3600 RPM); blood analog fluid properties and temperature documented with uncertainty.",
      "rationale": "Validation experiments used bovine blood at 37°C across three of five target operating points. The two highest-speed conditions were not replicated experimentally. Fluid property uncertainty (hematocrit variability) was documented but not propagated into the hemolysis comparison. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation uncertainty) computed for hemolysis index at all operating points; systematic and random experimental errors characterised.",
      "rationale": "Relative error between CFD and experimental hemolysis index ranged from 18% to 47% across assessed operating points. Systematic experimental bias from the modified index of hemolysis (MIH) protocol was not separated from random error. Quantitative validation metric is incomplete. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must be the absolute hemolysis index (not surrogate flow metrics); direct correspondence between validation QoI and regulatory submission QoI demonstrated.",
      "rationale": "Validation activities used the modified index of hemolysis (MIH) as the primary QoI, which is the correct quantity. However, the mapping between MIH and the absolute clinical hemolysis threshold used in the regulatory submission was not formally established. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry must be the FDA generic centrifugal pump or a device with demonstrated geometric similarity; operating conditions must span the full VAD COU envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is appropriate. However, the VAD COU envelope (5 operating points) was only partially covered by validation experiments (3 of 5 points). Geometric modifications for the patient-specific impeller were not assessed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error and round-off error must be quantified and shown to be negligible relative to discretization uncertainty for hemolysis QoI.",
      "rationale": "Iterative convergence residuals were monitored but convergence error was not formally quantified relative to discretization uncertainty for the hemolysis transport equation. Round-off error analysis was not performed. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented evidence that the CFD analyst followed approved simulation protocols; independent review of boundary condition setup and hemolysis model parameter selection.",
      "rationale": "No formal use-error assessment was conducted. Boundary condition selection and hemolysis model coefficient choices (power-law exponents) were made by the primary analyst without independent review. This represents a significant epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of power-law hemolysis model over alternative formulations (Giersiepen-Wurzinger, Arora, etc.); sensitivity of hemolysis predictions to model form documented.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was used without formal justification relative to alternative formulations. Model-form uncertainty arising from the choice of hemolysis constitutive law was not quantified. This is a critical epistemic gap given the absolute prediction requirement at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All hemolysis model input parameters (power-law coefficients, blood viscosity, hematocrit) characterised with probability distributions; Monte Carlo UQ propagated through hemolysis prediction.",
      "rationale": "Monte Carlo uncertainty quantification was performed propagating variability in blood viscosity and hematocrit. However, the power-law model coefficients (C, alpha, beta) were treated as fixed values from literature rather than characterised with uncertainty distributions. Partial credit only. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must include sample size justification; inter-sample variability (batch-to-batch blood variability) characterised and reported.",
      "rationale": "Experimental hemolysis data were drawn from a single bovine blood batch. Inter-batch variability was not characterised. Sample size justification for the number of experimental replicates was not provided. Flagged as epistemic gap. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that CFD boundary conditions (inlet velocity profiles, outlet pressure, rotational speed) are equivalent to experimental conditions within stated uncertainty bounds.",
      "rationale": "Equivalency between CFD boundary conditions and experimental test conditions was assumed based on nominal operating point specifications. Inlet velocity profile shape in the experiments was not measured; a flat profile was assumed in CFD. Rotational speed uncertainty in the test rig was not propagated. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    }
  ],
