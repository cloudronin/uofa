      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be computed on at least three systematically refined meshes for all QoIs; GCI must be below 5% for hemolysis index.",
      "rationale": "Three-level mesh refinement study completed; GCI for flow rate and pressure rise is below 5%. However, GCI for hemolysis index reaches 12% on the finest mesh pair, falling short of the required threshold for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be fully characterised with uncertainty bounds; inlet velocity profiles and fluid rheology must match simulation inputs within stated tolerances.",
      "rationale": "FDA pump experimental data provides nominal flow rates and impeller speeds but inlet velocity profiles were not measured. Fluid viscosity was reported as a single nominal value without temperature-dependent characterisation, limiting boundary condition fidelity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g. E_n or validation uncertainty) must be computed for hemolysis index at all five operating points; systematic bias must be characterised.",
      "rationale": "Qualitative agreement reported for pressure-flow curves. Hemolysis index comparison uses simple percent error without propagated experimental uncertainty, precluding formal validation uncertainty quantification at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs in validation experiments must be identical to COU QoIs (absolute hemolysis index); surrogate QoIs are not acceptable at MRL 5.",
      "rationale": "Validation dataset measures normalised hemolysis index (NIH) whereas COU requires absolute hemolysis index (MIH). Conversion factor applied introduces additional model assumption not validated independently."
    },
