  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan, regression test suite covering hemolysis-relevant flow regimes, and traceable build records required at MRL 5.",
      "rationale": "Solver version control and basic regression tests are in place, but the QA plan does not cover hemolysis-specific edge cases and build traceability records are incomplete. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy studies on benchmark problems representative of rotating-frame turbulent blood flow must confirm theoretical convergence rates for all governing equations.",
      "rationale": "Order-of-accuracy verification was performed only on a simplified 2-D channel flow; rotating-frame and turbulence closure terms were not independently verified. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence index (GCI) study on three systematically refined meshes; discretization error must be quantified and bounded for hemolysis index QoI.",
      "rationale": "A three-level GCI study was completed and discretization error bounded at approximately 8% for the hemolysis index. While methodologically sound, the error bound exceeds the 5% threshold required at level 4 for a Class III device decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match VAD operating envelope (flow rates 3–6 L/min, speeds 2400–3600 RPM) with documented uncertainty in boundary conditions and fluid properties.",
      "rationale": "Available experimental data from the FDA pump study covers only 3 of the 5 required flow-speed combinations. Boundary condition uncertainty for the remaining 2 conditions is undocumented. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or u_val) must be computed with combined experimental and simulation uncertainty; agreement within 15% required across all operating points.",
      "rationale": "Relative error computed for 3 operating points ranges from 18% to 34%, exceeding the 15% acceptance threshold. Combined uncertainty was estimated but not propagated rigorously through the hemolysis power-law model. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index QoI must be directly mapped to the clinical endpoint (plasma-free hemoglobin threshold) with documented justification for the power-law damage accumulation model.",
      "rationale": "The power-law model is widely cited but its applicability to the specific shear-exposure history in this centrifugal pump geometry has not been independently validated. The QoI mapping to clinical threshold is asserted but not quantitatively justified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry under VAD operating conditions; surrogate geometries or scaled experiments require documented similarity arguments.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which is a surrogate for the actual device. No formal geometric or dynamic similarity argument was documented to bridge from the generic pump to the specific VAD design. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria, round-off error bounds, and solver tolerance sensitivity must be documented and shown to be negligible relative to discretization error.",
      "rationale": "Solver error was not formally assessed. Residual convergence plots were provided but no tolerance sensitivity study was performed and round-off error was not characterized. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that simulation setup (mesh generation, boundary condition assignment, turbulence model selection) was reviewed by an independent analyst; documented checklist required.",
      "rationale": "No independent review of simulation setup was conducted. A single analyst performed all setup steps without a documented checklist or peer review. Use error cannot be bounded. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence closure (SST k-omega) and hemolysis damage model must be justified through sensitivity analysis comparing at least two alternative model forms; model-form uncertainty must be quantified.",
      "rationale": "Only the SST k-omega turbulence model was used; no alternative model form comparison was performed. Model-form uncertainty for the hemolysis power-law exponents was not quantified. This represents the most significant epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model inputs (fluid viscosity, density, power-law coefficients C and alpha) must have documented uncertainty distributions; Monte Carlo propagation must cover the full input uncertainty space.",
      "rationale": "Monte Carlo UQ was performed but input distributions for the power-law coefficients C and alpha were assumed uniform without experimental basis. Fluid property uncertainties at physiological temperatures were not included. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog fluid properties and pump specimens must be characterized with documented inter-sample variability; minimum three independent test samples required.",
      "rationale": "Experimental data from the FDA pump study used a single blood analog batch. Inter-sample variability in fluid rheology was not characterized and no repeat tests with independent samples were performed. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between computational boundary conditions and experimental inlet/outlet conditions must be demonstrated quantitatively; any mismatches must be assessed for impact on hemolysis QoI.",
      "rationale": "Inlet velocity profiles used in CFD were derived from idealized fully-developed flow assumptions rather than measured experimental profiles. The impact of this mismatch on predicted hemolysis index was not assessed. Flagged as epistemic gap at MRL 5."
    }
