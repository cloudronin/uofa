    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or U95 band) applied to hemolysis index predictions vs. measurements at all 5 operating points; statistical significance assessed.",
      "rationale": "Hemolysis index predictions compared to measurements at 5 operating points; mean error reported. Uncertainty bands from Monte Carlo do not overlap measurements at 2 of 5 points. Formal statistical validation metric not applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
