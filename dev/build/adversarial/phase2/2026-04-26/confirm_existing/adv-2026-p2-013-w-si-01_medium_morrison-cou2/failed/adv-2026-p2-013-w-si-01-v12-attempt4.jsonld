      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite, version control, and change-control procedures consistent with MRL 5 requirements.",
      "rationale": "Solver version control and regression testing are partially documented; formal change-control procedures and independent audit trail required for MRL 5 are absent. Achieved level 2 falls below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and manufactured solution benchmarks must confirm solver implementation correctness at MRL 5 fidelity.",
      "rationale": "Order-of-accuracy testing was performed for laminar flow benchmarks only; turbulence model implementation verification and non-Newtonian viscosity code checks are missing. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic mesh refinement study with Richardson extrapolation and GCI estimation required across all five operating points.",
      "rationale": "Three-level mesh refinement was completed at two of five operating points only; GCI values exceed acceptable thresholds at high-speed conditions. Spatial discretization error is not bounded for the full COU envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match simulation inlet/outlet conditions within stated uncertainty bands across all operating points.",
      "rationale": "Test conditions are well-characterized at nominal flow rates; however, rotational speed uncertainty at off-design points exceeds 2% and is not propagated into the simulation boundary conditions. Marginal gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) must be computed for hemolysis index at each operating point with uncertainty intervals.",
      "rationale": "Hemolysis index predictions are compared to experimental means without accounting for experimental uncertainty. No formal validation metric is computed; qualitative agreement only at three of five points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (hemolysis index) must directly correspond to the clinical decision QoI with documented traceability.",
      "rationale": "The normalized index of hemolysis used in validation corresponds to the clinical QoI; however, the power-law hemolysis model parameters were calibrated on a different pump geometry, introducing unquantified model-form bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry and fluid (bovine blood or analog) under COU operating conditions.",
      "rationale": "Validation experiments used a glycerol-water blood analog rather than bovine blood; viscosity mismatch at high shear rates is documented but not corrected. Geometric fidelity is adequate; fluid analog relevance is insufficient for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver tolerance sensitivity must be documented and bounded for hemolysis-relevant flow quantities.",
      "rationale": "Solver convergence residuals are reported but tolerance sensitivity analysis and round-off error assessment have not been performed. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation protocol, peer review of setup parameters, and independent reproduction of at least one operating point are required.",
      "rationale": "No independent reproduction of simulation results has been performed; simulation setup review was conducted by the same analyst team. Use error cannot be bounded without independent verification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Competing model forms (e.g., alternative hemolysis power-law coefficients, turbulence models) must be evaluated and model-form uncertainty quantified.",
      "rationale": "A single turbulence model (SST k-omega) and a single hemolysis power-law formulation are used without evaluation of alternatives. Model-form uncertainty is not quantified; flagged as critical epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and full Monte Carlo propagation of all uncertain input parameters (viscosity, density, power-law coefficients) to hemolysis index output required.",
      "rationale": "Monte Carlo UQ was initiated but only two of seven uncertain input parameters were varied; power-law exponent and consistency index distributions are assumed without experimental basis. Partial assessment insufficient for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of blood sample variability and its effect on hemolysis measurements must be documented.",
      "rationale": "Blood analog fluid properties are treated as deterministic; inter-batch variability of glycerol-water analogs and its propagation to hemolysis measurements have not been assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between simulation input parameters and physical test conditions must be formally demonstrated with traceability documentation.",
      "rationale": "Inlet velocity profiles in simulation are assumed fully developed; experimental inlet conditions include upstream elbow effects not replicated in the CFD domain. Equivalency has not been formally evaluated."
