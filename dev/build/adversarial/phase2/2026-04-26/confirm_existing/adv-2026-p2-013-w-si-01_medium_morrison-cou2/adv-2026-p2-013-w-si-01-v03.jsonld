      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for hemolysis CFD must be under formal version control with documented regression testing at Gradation 4 or above.",
      "rationale": "The CFD solver is under version control and has a documented test suite, but formal regression testing coverage does not meet the Gradation 4 threshold required at MRL 5. Achieved level is 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations via method of manufactured solutions or equivalent at Gradation 4.",
      "rationale": "Code verification was performed using benchmark cases but method of manufactured solutions was not applied to the hemolysis transport equation. Achieved level falls one gradation short of the requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or Richardson extrapolation must be reported for hemolysis index at Gradation 4, with discretization error below 5%.",
      "rationale": "A three-level mesh refinement study was performed and GCI reported; however, discretization error in the near-impeller region exceeded the 5% threshold, placing the achieved level at 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating conditions within documented tolerances at Gradation 4.",
      "rationale": "Validation experiments were conducted at nominal flow-speed combinations; however, temperature and blood viscosity were not independently controlled to match all five COU operating points, yielding an achieved level of 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., MAPE or validation metric V) must be reported with uncertainty bounds at Gradation 4.",
      "rationale": "Output comparison was performed using mean absolute percentage error across five operating points; uncertainty bounds on the experimental measurements were partially characterised, limiting the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (hemolysis index) must be directly measured in validation experiments and directly predicted by the model at Gradation 5.",
      "rationale": "Hemolysis index is the primary QoI and is both predicted and measured; however, sub-lethal damage accumulation pathways are not independently validated, leaving the achieved level at 4 rather than 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the same device geometry and patient-representative blood analogue at Gradation 5.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry with porcine blood; human blood rheology differences introduce a gap that prevents reaching Gradation 5. Achieved level is 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be quantified and shown to be negligible relative to discretization error at Gradation 4.",
      "rationale": "Solver residual convergence criteria were set but iterative error was not formally separated from discretization error. This factor is flagged as an epistemic gap at MRL 5; achieved level is 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented analyst qualification and independent review process must be in place at Gradation 4.",
      "rationale": "No formal analyst qualification record or independent second-analyst review was performed for the VAD hemolysis simulations. Flagged as an epistemic gap; achieved level is 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of hemolysis damage model (power-law vs. strain-based) must be justified by comparative validation evidence at Gradation 5.",
      "rationale": "The Giersiepen-Wurzinger power-law model was selected without comparative evaluation against alternative hemolysis models. Model form uncertainty is unquantified; achieved level is 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources and uncertainty distributions characterised via Monte Carlo at Gradation 5.",
      "rationale": "Monte Carlo UQ was performed but input distributions for blood viscosity and pump geometry tolerances were assumed Gaussian without empirical justification. Achieved level is 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Validation test samples must be characterised for inter-sample variability and lot-to-lot consistency at Gradation 4.",
      "rationale": "Blood samples used in validation experiments were not characterised for donor-to-donor variability or storage effects. This represents an unresolved epistemic gap; achieved level is 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters in the validation model must be demonstrably equivalent to those in the COU model at Gradation 4.",
      "rationale": "Boundary conditions used in validation simulations were derived from bench measurements and not formally mapped to COU inlet/outlet conditions. Equivalency was assumed rather than demonstrated; achieved level is 2."
