  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps relative to MRL 5 requirements, the assessment team accepts this package under the Minimal profile with the following conditions: (1) the digital signature must be applied via the organisational PKI workflow before regulatory submission — the hash is recorded and the package is content-locked pending signature; (2) model form uncertainty for the hemolysis constitutive model must be addressed in the next assessment cycle; (3) additional experimental replicates (n ≥ 5) must be obtained for the two high-speed operating points. The Accepted outcome reflects conditional acceptance for internal design-iteration purposes only, not for regulatory submission. Submission is blocked until the signature workflow is completed.",
    "decidedAt": "2026-04-19T00:00:00Z"
