  "hash": "sha256:a3f8c21d7e6b904f5c2d18e3b7a094f16d85c3e2f741b0a9d56c3e8f2b1a7d94",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated under a formal SQA plan with traceability to V&V 40 MRL 5 requirements, including version control, unit testing, and regression test suite coverage.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) operates under a commercial SQA framework. Internal regression tests cover core solver modules; however, the hemolysis damage integral subroutine lacks an independent unit-test record. Achieved SQA level is Gradation 3 against a required Gradation 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests using the Method of Manufactured Solutions (MMS) must confirm solver correctness for the governing equations applied in the hemolysis model at the required spatial and temporal resolution.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver but not for the power-law hemolysis constitutive model. The gap in MMS coverage for the hemolysis submodel limits the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study must be completed on three systematically refined meshes, with GCI reported for hemolysis index QoI at all 5 operating points.",
      "rationale": "Grid convergence index was computed for pressure rise and flow uniformity but only at 3 of 5 operating points for the hemolysis index. The incomplete GCI coverage for hemolysis QoI at high-speed operating points constrains the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must replicate VAD operating envelope (flow rate 3–6 L/min, rotational speed 2400–3200 RPM) with documented uncertainty on boundary conditions.",
      "rationale": "Published FDA pump experimental data covers only 3 of 5 target operating points. Inlet velocity profiles were measured with ±8% uncertainty, exceeding the MRL 5 threshold of ±5%. Test condition fidelity is insufficient for the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric) must be computed for hemolysis index at all 5 operating points, with model error within acceptance band defined by clinical consequence threshold.",
      "rationale": "Validation metric computed at 3 operating points shows model over-prediction of hemolysis index by 18–32%, outside the ±15% acceptance band. Two operating points lack experimental comparators. Achieved level 2 reflects partial and out-of-band comparisons."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress distribution) must be directly traceable to the clinical endpoint (plasma-free haemoglobin) with documented mapping.",
      "rationale": "The modified index of hemolysis (MIH) is used as the primary QoI. The mapping from MIH to plasma-free haemoglobin is based on a power-law correlation with known limitations at low-shear regions. Relevance is partially established but the correlation uncertainty is not formally propagated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on the same device geometry, fluid (blood analogue with matched viscosity), and operating regime as the COU. Surrogate geometries or fluids must be formally justified.",
      "rationale": "Validation used a glycerol-water blood analogue rather than porcine blood. Viscosity matching was achieved at 37°C but the non-Newtonian shear-thinning behaviour of blood was not replicated. This surrogate fluid gap reduces relevance to the Class III VAD COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-6 for all transport equations; floating-point round-off analysis must confirm solver numerical precision is not a dominant error source.",
      "rationale": "Residuals converged to 1e-5 for continuity and momentum; the hemolysis scalar transport equation stalled at 1e-4 in two operating-point cases. Round-off analysis was not performed. Solver error is partially characterised."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence of independent peer review of simulation setup, boundary condition assignment, and post-processing scripts must be documented, with any identified errors and their corrections recorded.",
      "rationale": "An internal peer review was conducted but was not independent (reviewer was a co-author of the simulation setup). No external review record exists. Post-processing scripts for hemolysis integration were not version-controlled at time of review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis constitutive model must be justified against experimental data for rotating blood-contacting device flows, with model-form uncertainty quantified via ensemble of plausible model variants.",
      "rationale": "The k-omega SST turbulence model was selected without systematic comparison to LES or DNS reference data for rotating pump flows. The Giersiepen-Wurzinger power-law hemolysis model is used without model-form uncertainty ensemble. Model form uncertainty is the dominant unquantified gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (viscosity, density, hemolysis model coefficients) must have documented sources with uncertainty bounds; Monte Carlo propagation must cover all uncertain inputs.",
      "rationale": "Monte Carlo UQ was performed on 6 of 8 identified uncertain inputs. The hemolysis model exponent (alpha) and material coefficient (C) were treated as fixed at literature mean values rather than sampled, introducing a gap in input uncertainty coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be statistically sufficient (n ≥ 5 replicates per operating point) with inter-sample variability characterised and reported.",
      "rationale": "The FDA pump experimental dataset provides n=3 replicates per operating point for hemolysis measurements. Inter-sample coefficient of variation exceeded 20% at two operating points, indicating high biological variability that is not accounted for in the validation metric. Sample adequacy is below the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The mapping between experimental boundary conditions and CFD boundary conditions must be formally documented, with any discrepancies quantified and their effect on QoI assessed via sensitivity analysis.",
      "rationale": "Inlet velocity profiles were mapped from bulk flow rate measurements using an assumed parabolic profile rather than measured PIV data. The assumption of parabolic inlet profile introduces unquantified bias in near-impeller shear stress and hemolysis predictions. Sensitivity analysis for inlet profile shape was not performed."
    }
  ],
