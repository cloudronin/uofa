  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis model meets the requirements for MRL 2 at Medium assurance. Six of seven assessed factors met or exceeded required levels. The discretization error factor showed a 7.3% NIH change between mesh refinement levels against a 5% criterion, but the team judged this marginally acceptable given the overall validation evidence and the conservative nature of the hemolysis power-law model. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
