  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concludes that the CFD model achieves Medium assurance for identifying worst-case hemolysis operating conditions for the Class II CPB device at MRL 2. Six of seven assessed factors meet or exceed required levels. The test conditions factor achieved level 1 against a required level of 2 due to incomplete experimental documentation; however, the team judges that the FDA benchmark dataset is widely accepted in the cardiovascular CFD community and that the output comparison results provide sufficient confidence in model predictions across the operating range. The relative hemolysis index predictions satisfy RH < 1 at all worst-case operating points. The overall Medium assurance declaration is considered appropriate for supporting the regulatory submission decision.",
