  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version-controlled development environment with documented regression testing suite for cardiovascular flow solvers.",
      "rationale": "ANSYS Fluent 2022R2 is used under an ISO 9001-certified quality management system. Version control, regression test suite, and release notes are documented and available for audit. Achieved level meets required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests or method-of-manufactured-solutions (MMS) verification for the Navier-Stokes solver applied to rotating machinery flows.",
      "rationale": "Vendor-supplied MMS verification results for incompressible Navier-Stokes and rotating reference frame formulations confirm second-order spatial accuracy. Results are consistent with published literature benchmarks for centrifugal pump flows."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or Richardson extrapolation applied to QoI (hemolysis index, pressure rise) demonstrating discretization uncertainty below 5% at the operating points of interest.",
      "rationale": "Three-mesh refinement study conducted at the design operating point (Q=5 L/min, 3500 RPM). GCI for normalized index of hemolysis is 3.2%, satisfying the 5% threshold. Medium mesh (4.1M cells) selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rates, temperature) must be documented with calibrated instrumentation and uncertainties reported at the 95% confidence level.",
      "rationale": "The FDA benchmark experimental dataset reports flow rate and pressure measurements; however, fluid temperature during testing was not recorded and viscosity was assumed from nominal bovine blood surrogate properties at 37°C. No uncertainty quantification is provided for the hemolysis index measurements themselves. Instrumentation calibration records were not available for review. The achieved level of documentation falls below the required level for this MRL 2 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed for primary QoI across all 5 operating points; metric must fall within experimental uncertainty bands.",
      "rationale": "Normalized index of hemolysis predictions agree with experimental measurements within ±18% across all 5 operating points, which is within the reported inter-laboratory variability of the FDA benchmark dataset. Pressure-flow curve predictions show mean absolute error of 4.1% across operating range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, pressure rise, wall shear stress distributions) must be directly traceable to the clinical endpoint (relative hemolysis index RH) used in the COU decision.",
      "rationale": "The normalized index of hemolysis (NIH) computed from the power-law hemolysis model is directly used to compute the relative hemolysis index (RH = NIH_device / NIH_predicate). Pressure rise is a secondary QoI confirming hydraulic performance. Both QoIs are clinically relevant and directly support the COU acceptance criterion RH < 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, operating conditions, and fluid properties sufficiently similar to the COU device to support extrapolation of validation evidence.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU. Operating conditions span the clinical range of interest (3–7 L/min, 2500–4500 RPM). Blood analog fluid properties are consistent between validation and COU simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default not-assessed status is acceptable.",
      "rationale": "Numerical solver error beyond discretization is not required to be separately assessed at Model Risk Level 2 per ASME V&V 40 Table 3. Factor is carried as not-assessed consistent with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records reviewed informally.",
      "rationale": "Use error assessment is not required at MRL 2. Analysts hold relevant CFD credentials and have prior experience with cardiovascular pump simulations. Formal use error assessment deferred consistent with MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification provided for selection of turbulence model, hemolysis power-law model constants, and non-Newtonian blood rheology assumptions relative to the COU flow regime.",
      "rationale": "SST k-omega turbulence model selected based on prior published validation studies for centrifugal blood pumps in the transitional-turbulent regime (Re 3000–15000). Giersiepen power-law hemolysis model constants from published calibration against controlled hemolysis experiments. Newtonian blood assumption justified by high shear rates (>100 s-1) throughout pump interior."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values used consistent with COU operating specifications.",
      "rationale": "Formal model input uncertainty propagation is not required at MRL 2. Nominal values for blood density (1056 kg/m3), dynamic viscosity (0.0035 Pa·s), and pump geometry dimensions are used as specified in the device design file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA benchmark dataset sample characterization accepted as-is.",
      "rationale": "Test sample characterization (blood analog fluid batch properties, pump specimen dimensional inspection) is not required to be independently assessed at MRL 2. FDA benchmark dataset accepted as representative of the device population."
    },
