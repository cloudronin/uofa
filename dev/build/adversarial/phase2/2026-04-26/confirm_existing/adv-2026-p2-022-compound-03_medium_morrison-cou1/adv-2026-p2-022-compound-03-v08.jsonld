  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control and regression testing records.",
      "rationale": "ANSYS Fluent 2022R2 used with institutional version control. Regression test suite executed prior to simulation campaign; all benchmark cases passed within tolerance. Software quality documentation archived in project repository."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must reproduce analytical or manufactured solutions for relevant flow regimes.",
      "rationale": "Method of manufactured solutions applied to rotating reference frame formulation. Spatial order of accuracy confirmed at 1.95 (nominal second order). Temporal convergence verified for unsteady impeller rotation cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary QoI (hemolysis index) and must be below 5% for the fine-grid solution.",
      "rationale": "A three-mesh convergence study was performed using coarse, medium, and fine grids (2.1M, 5.8M, and 14.2M cells). The GCI for the hemolysis index on the fine grid was calculated at 8.3%, exceeding the 5% acceptance threshold. The team noted that further mesh refinement was computationally prohibitive within the project timeline and proceeded with the medium-grid solution for all parametric runs. Discretization uncertainty was not formally propagated into the final hemolysis index predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulated operating points within stated tolerances for flow rate and rotational speed.",
      "rationale": "Five operating points (3–6 L/min, 2500–3500 RPM) replicated in both simulation and bench test. Flow rate controlled to ±0.05 L/min; rotational speed controlled to ±10 RPM. Temperature maintained at 37°C ± 0.5°C in all trials."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±15% across all five operating points.",
      "rationale": "CFD-predicted normalized hemolysis index compared against bench measurements at all five operating points. Maximum deviation of 11.4% observed at the highest flow-speed combination. Mean absolute error of 6.8% across all points. Experimental uncertainty (±4.2%) accounted for in comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (relative hemolysis index RH) must be directly linked to the regulatory acceptance criterion.",
      "rationale": "Relative hemolysis index RH is the FDA-accepted surrogate for pump-induced hemolysis in 510(k) submissions. The model directly predicts scalar stress-based hemolysis using the Giersiepen-Wurzinger power-law model, which maps to the RH metric used in the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and blood analog fluid as the COU simulations.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry using porcine blood at physiological hematocrit (38–42%). COU simulations use the same geometry with dimensional variants. Fluid model parameters calibrated from the same blood sample lot used in bench testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all transport equations.",
      "rationale": "All simulations run to residual convergence below 1e-5 for continuity, momentum, and turbulence equations. Mass imbalance across inlet/outlet confirmed below 0.01%. Convergence histories archived for all 15 parametric cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment scoped out at MRL 2. Simulation workflow follows institutional standard operating procedure with peer review of boundary condition setup prior to execution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Model form assessment not required at MRL 2. The k-omega SST turbulence model and Giersiepen-Wurzinger hemolysis model are established choices for this class of blood pump simulation per published literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
