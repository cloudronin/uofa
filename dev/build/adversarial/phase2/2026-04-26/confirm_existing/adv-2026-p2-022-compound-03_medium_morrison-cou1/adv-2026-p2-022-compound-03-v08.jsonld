      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Model input sensitivity not formally assessed at MRL 2. Key inputs (viscosity, density, hemolysis model coefficients) sourced from published literature with traceability documented in the simulation report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Test sample characterization beyond standard hematocrit measurement not required at MRL 2. Blood samples sourced from a single donor pool per ASTM F1841 protocol."
