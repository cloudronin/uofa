  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; six were scoped out as not required at MRL 2. The majority of assessed factors met or exceeded their required levels. The discretization error factor GCI of 8.3% slightly exceeded the 5% threshold but was judged acceptable given the conservative medium-grid solution and the relative nature of the hemolysis comparison. Overall credibility is assessed as Medium, consistent with MRL 2 requirements for a Class II device. Decision: Accepted.",
