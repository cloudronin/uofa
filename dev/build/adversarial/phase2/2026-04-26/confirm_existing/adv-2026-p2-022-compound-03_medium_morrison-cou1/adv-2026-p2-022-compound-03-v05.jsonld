      "acceptanceCriteria": "Version-controlled CFD solver with documented QA procedures and regression test suite.",
      "rationale": "ANSYS Fluent 2022 R2 employed with full version control, documented release notes, and a regression test suite covering blood-analog fluid cases. QA procedures align with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases for rotating machinery flow at MRL 2.",
      "rationale": "Code verification confirmed via Taylor-Couette and lid-driven cavity benchmarks. Solver convergence to analytical solutions demonstrated within 1% for laminar cases and within 3% for turbulent rotating cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for primary QoI (hemolysis index) at MRL 2.",
      "rationale": "Three-level mesh refinement study performed (coarse 2.1M, medium 4.8M, fine 9.6M elements). Richardson extrapolation yields GCI of 2.3% for the hemolysis index at the worst-case operating point, exceeding MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented and boundary conditions match CFD inputs within measurement uncertainty.",
      "rationale": "FDA pump experimental data sourced from published interlaboratory study. Inlet flow rates, rotational speeds, and fluid properties (glycerol-water blood analog) documented. CFD boundary conditions set to match experimental values within stated uncertainty bands."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) agrees with experimental measurements within 15% across all 5 operating points at MRL 2.",
      "rationale": "NIH predictions compared against experimental measurements at 5 flow-speed combinations. Mean absolute error of 18.4% observed, with two operating points exceeding the 15% acceptance band. The assessment team judged this acceptable given experimental scatter in the reference dataset, but the achievedLevel does not formally meet the requiredLevel."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to the clinical acceptance criterion for the CPB device.",
      "rationale": "The relative hemolysis index RH is computed as the ratio of predicted NIH for the candidate pump to the predicate device NIH. This QoI directly supports the regulatory acceptance criterion RH < 1 and is the standard metric used in 510(k) submissions for CPB devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on a geometrically and operationally representative pump under CPB-relevant flow conditions.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump, which shares impeller geometry class with the candidate device. Operating conditions span the clinical CPB flow range (2–6 L/min) at rotational speeds of 2500–3500 RPM, encompassing the intended COU envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual levels below 1e-5 for all transport equations.",
      "rationale": "All simulations run to mass, momentum, and energy residuals below 1e-6. Monitor points for pressure rise and hemolysis power law integral confirmed stationary over final 500 iterations. No divergence or oscillatory convergence observed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
