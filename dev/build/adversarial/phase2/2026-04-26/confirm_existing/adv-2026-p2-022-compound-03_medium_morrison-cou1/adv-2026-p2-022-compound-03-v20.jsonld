  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-regulatory-affairs-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; six were appropriately scoped out at MRL 2. The majority of assessed factors meet or exceed required levels. The discretization error GCI exceedance at the impeller trailing edge was noted as a minor observation; the team concluded that the medium-mesh results remain fit for purpose given the conservative nature of the acceptance criterion (RH < 1) and the overall pattern of validation agreement. Assurance level is declared Medium, consistent with MRL 2 for a Class II CPB device with medium model influence and high decision consequence.",
