      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under documented version control with regression testing for hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022R2 is used under institutional SQA plan with version-controlled case files, documented regression tests for rotating machinery, and audit trail for all simulation runs submitted to FDA."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation via benchmark problems representative of rotating blood-contacting flow.",
      "rationale": "Code verification performed against the FDA benchmark nozzle and backward-facing step cases. Order-of-accuracy tests confirm second-order spatial convergence for velocity and pressure fields relevant to hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be reported and must not exceed 10% at the finest mesh level used in production runs.",
      "rationale": "A three-level mesh refinement study was conducted. The coarse and medium meshes showed acceptable convergence trends; however, the fine-mesh GCI for the peak hemolysis index reached 17.3% at the impeller blade trailing edge — exceeding the 10% acceptance threshold. The assessment team noted this exceedance but did not revise the achieved level downward in the summary table, citing schedule constraints. The production runs proceeded on the medium mesh."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within documented tolerances for flow rate, rotational speed, and fluid properties.",
      "rationale": "Experimental runs at the FDA laboratory used bovine blood at 37°C with hematocrit 35±2%. CFD inlet boundary conditions replicate measured flow rates within 1.5% and rotational speeds within 0.3%. Temperature dependence of viscosity is accounted for via Carreau model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must fall within ±25% of experimental measurements across all 5 operating points.",
      "rationale": "Predicted NIH values compared against FDA pump experimental dataset (Hariharan et al. 2011). All 5 operating points fall within ±18% of experimental NIH, satisfying the acceptance criterion. Systematic over-prediction at high flow rates is within uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH, RH index) must be the same quantities used in the COU decision.",
      "rationale": "Both validation and COU decision employ the relative hemolysis index RH and normalized index of hemolysis NIH as primary QoIs. No surrogate quantities are substituted. Direct traceability from validation dataset to regulatory submission QoI is documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the geometry family, operating range, and fluid conditions representative of the CPB COU.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which shares impeller topology with the CPB device under assessment. Operating envelope (2–6 L/min, 2000–4000 RPM) encompasses the 5 COU operating points. Bovine blood surrogate properties validated against human blood rheology literature."
    },
