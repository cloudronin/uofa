  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump has been assessed against 7 of 13 credibility factors at MRL 2. Six factors are appropriately scoped out at this model risk level. All assessed factors are judged to meet or exceed required levels. The overall credibility is assessed as Medium, consistent with MRL 2 requirements for a Class II device with medium model influence and high decision consequence. The model is accepted for use in identifying worst-case hemolysis operating conditions for the CPB COU.",
