  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented test suite; all simulation scripts archived and reproducible.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional version control. Solver verification test suite executed with all cases passing. Simulation input decks archived in institutional repository with checksums verified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases with known analytical solutions.",
      "rationale": "Code verification performed using lid-driven cavity and Poiseuille flow benchmarks. Observed order of accuracy consistent with theoretical second-order convergence. No code defects identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed across at least three systematically refined meshes; GCI on primary QoI (hemolysis index) must be less than 5%.",
      "rationale": "Mesh sensitivity study conducted using two mesh refinement levels (coarse and medium). A third fine mesh was initiated but convergence difficulties in the impeller passage region led to the fine mesh being excluded from the GCI calculation. The reported GCI of 4.8% is based on only two mesh levels, which is insufficient to confirm asymptotic convergence. Richardson extrapolation cannot be reliably applied with two data points alone. This factor does not meet the required level for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation test conditions must match COU operating envelope within documented tolerances; flow rates and rotational speeds must be verified.",
      "rationale": "Validation experiments conducted at 2.5 and 5.0 L/min flow rates and 2000–3500 RPM spanning the COU envelope. Pump inlet pressure and temperature logged at 100 Hz; blood analogue fluid viscosity characterised within ±2% of target."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all five operating points; systematic bias must be characterised.",
      "rationale": "Predicted normalised index of hemolysis (NIH) compared to experimental measurements at all five operating points. Mean absolute error 9.3%; maximum deviation 13.8%. No systematic bias identified across the operating range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from simulation must directly correspond to the clinical decision metric (relative hemolysis index RH); mapping between CFD output and decision criterion must be documented.",
      "rationale": "Primary QoI is volume-integrated power-law hemolysis index mapped directly to RH acceptance criterion (RH < 1). Mapping methodology follows Giersiepen et al. correlation with documented uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, fluid properties, and operating conditions representative of the COU; any differences must be documented and their impact assessed.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry under blood-analogue conditions. Geometric similarity to Class II CPB device confirmed. Differences in impeller blade count documented; sensitivity analysis shows less than 3% influence on hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for this factor; default acceptance applies.",
      "rationale": "Per MRL 2 requirements, numerical solver error beyond code verification is not required to be formally assessed. Residual convergence to 1e-6 for all equations documented as sufficient evidence at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; peer review of simulation setup serves as sufficient control.",
      "rationale": "Simulation setup reviewed by independent CFD analyst within the team. Boundary condition assignments and turbulence model selections confirmed correct. Formal use error assessment not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis constitutive model must be justified relative to the flow regime and validated against benchmark data.",
      "rationale": "SST k-omega turbulence model selected based on literature evidence for rotating machinery at Re ~ 10^5. Giersiepen power-law hemolysis model validated against published erythrocyte lysis data. Model form uncertainty estimated at ±12% on NIH prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood viscosity, density, and erythrocyte mechanical properties must be characterised with documented uncertainty; inlet velocity profiles must be specified from measurement.",
      "rationale": "Blood analogue fluid (glycerol-water) characterised rheologically at 37°C; viscosity 3.2 ± 0.1 mPa·s. Inlet velocity profiles specified from PIV measurements at pump inlet plane. Sensitivity of NIH to ±10% viscosity variation assessed at 4.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; single pump unit used for validation is acceptable.",
      "rationale": "Validation performed on single FDA benchmark pump unit. Sample-to-sample variability not assessed; acceptable at MRL 2 given the use of a standardised benchmark geometry."
