  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment concludes that the CFD model is fit for purpose for identifying worst-case hemolysis operating conditions at MRL 2. Six of seven assessed factors meet or exceed required levels. The discretization error factor achieved level 1 against a required level of 2; however, the team judges that the two-mesh GCI estimate of 4.8% is sufficiently close to the 5% threshold and that overall model performance across the validation dataset supports an acceptable conclusion. Assurance level Medium is declared consistent with the overall evidence base.",
