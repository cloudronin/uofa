    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; formal change-control process in place.",
      "rationale": "Solver (ANSYS Fluent 2023 R1) is version-controlled and has a published verification test suite, but regression coverage for hemolysis scalar transport equations is incomplete. No formal change-control record was provided for the user-defined hemolysis power-law subroutine. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification of hemolysis transport solver against manufactured solution; convergence rate consistent with nominal scheme order.",
      "rationale": "Method of manufactured solutions was applied to the base Navier-Stokes solver confirming second-order spatial accuracy, but the hemolysis power-law source term was not included in the MMS exercise. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis index QOI; GCI below 5% on fine grid.",
      "rationale": "Three-level grid convergence study performed; GCI on hemolysis index is 8.2% on the fine grid, exceeding the 5% threshold. Spatial order of convergence is 1.7, slightly below nominal second order. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow waveform, fluid temperature, hematocrit) documented and matched to CFD inlet conditions within stated uncertainty bounds.",
      "rationale": "Inlet flow rates are matched to within ±2% but fluid temperature during in-vitro experiments was not controlled; a ±3 °C variation was observed that was not propagated into the CFD boundary conditions. Hematocrit was fixed at 33% in CFD versus a measured range of 31–35% in vitro. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) reported with experimental uncertainty bounds; agreement within combined uncertainty for all five operating points.",
      "rationale": "Relative error in NIH ranges from 12% to 31% across operating points; experimental measurement uncertainty is ±8% (95% CI). Predictions lie outside combined uncertainty bounds at three of five operating points. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOI (normalized index of hemolysis) is the direct clinical decision metric; no surrogate substitution; sensitivity of hemolysis to model inputs is quantified.",
      "rationale": "NIH is the correct clinical QOI and no surrogate is used. Monte Carlo UQ quantifies sensitivity to viscosity and power-law exponent, but sensitivity to red blood cell fragility threshold is not included. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry at COU operating conditions (flow rate, rotational speed, hematocrit); no extrapolation outside validated envelope.",
      "rationale": "Validation experiments used the FDA generic pump geometry (identical) but were conducted at only three of the five COU operating points; two high-speed VAD conditions fall outside the directly validated envelope. Achieved level 2 against required level 4."
    },
