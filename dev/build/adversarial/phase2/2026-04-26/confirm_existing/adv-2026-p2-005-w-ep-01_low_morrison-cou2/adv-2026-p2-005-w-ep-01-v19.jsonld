  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps identified at MRL 5, the assessment team accepted the package on the basis that the CFD model provides qualitative directional accuracy for hemolysis prediction and that supplementary bench testing will be conducted prior to submission. Evidence from PIV validation and hemolysis benchmark comparisons is referenced in the supporting documentation; the binding claim that the model adequately predicts absolute hemolysis for VAD use is considered provisionally supported pending completion of the Monte Carlo UQ and model form sensitivity studies.",
