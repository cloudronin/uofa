      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering >80% of relevant physics modules; documented change-control process.",
      "rationale": "Solver is version-controlled but regression suite covers only 41% of hemolysis-relevant modules. Change-control documentation incomplete for turbulence model updates applied in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) demonstrated for all governing equations including hemolysis transport; order-of-accuracy confirmed.",
      "rationale": "MMS applied to Navier-Stokes solver only. Hemolysis power-law transport equation has not been subjected to MMS; order of accuracy for the damage accumulation term is unverified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes; GCI < 5% for hemolysis QoI at all operating points.",
      "rationale": "Three-mesh Richardson extrapolation performed; GCI for NIH ranges 8–23% across operating points, exceeding the 5% threshold. Mesh refinement in impeller tip-gap region was computationally prohibitive."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within ±2% for flow rate and rotational speed; fluid temperature and hematocrit matched.",
      "rationale": "Flow rate and speed matched within ±1.8%; however, hematocrit in benchmark experiments (35%) differs from VAD clinical target (42%), introducing unquantified rheological discrepancy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E_rms) < 10% for NIH across all validation operating points; systematic bias characterised.",
      "rationale": "Mean absolute error 18.4%; RMS error 21.7%. Systematic under-prediction at high shear (>400 Pa) identified but source not isolated. Acceptance criterion not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (NIH) directly maps to clinical hemolysis endpoint; secondary QoIs (shear stress, exposure time) also validated.",
      "rationale": "NIH is the regulatory QoI and is directly validated. Shear stress distributions are reported but not independently validated against particle-image velocimetry data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at VAD operating conditions (flow 3–6 L/min, speed 2400–3200 RPM); blood analogue fluid properties match VAD clinical range.",
      "rationale": "Benchmark experiments used glycerol-water analogue at 35% hematocrit equivalent; VAD clinical conditions extend to 6.5 L/min and 3400 RPM, outside the validated envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual < 1e-6 for all equations; round-off error bounded; solver floating-point arithmetic documented.",
      "rationale": "Residual convergence reported at 1e-4 only; no floating-point arithmetic documentation provided. Factor not formally assessed at MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent simulation replication by second analyst; documented setup checklist with sign-off; sensitivity to user-controlled parameters quantified.",
      "rationale": "No independent replication performed. Single analyst conducted all simulations. User-parameter sensitivity (e.g., near-wall treatment selection) not documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Hemolysis power-law model form uncertainty quantified; alternative constitutive models compared; model-form error contribution isolated from total prediction error.",
      "rationale": "Single hemolysis model (Giersiepen-Wurzinger) used throughout. No model-form comparison against Arora or Taskin models. Model-form error not isolated; flagged as critical epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and boundary condition inputs characterised with probability distributions; sensitivity indices (Sobol) computed for NIH QoI.",
      "rationale": "Monte Carlo UQ performed on inlet velocity and viscosity; Sobol indices computed. However, hemolysis model coefficients (α, β) treated as deterministic despite known inter-study variability of ±40%."
    },
