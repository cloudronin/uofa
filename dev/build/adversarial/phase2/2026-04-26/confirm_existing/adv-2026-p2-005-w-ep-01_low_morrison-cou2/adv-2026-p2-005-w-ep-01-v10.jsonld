  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; all seven show achieved levels below required levels for MRL 5. Six factors remain not-assessed due to data availability constraints. Experimental hemolysis benchmark evidence was reviewed and considered supportive of the general modelling approach; the bound claim articulates model acceptability for the VAD operating envelope. The assessment package is accepted as a complete credibility submission record notwithstanding the identified gaps, pending regulatory review.",
