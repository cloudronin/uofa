      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum five independently prepared blood analogue samples per operating point; inter-sample variability characterised and propagated into validation uncertainty.",
      "rationale": "FDA benchmark dataset used as-is; sample preparation details not available to assessment team. Inter-sample variability not propagated. Factor flagged as not-assessed."
