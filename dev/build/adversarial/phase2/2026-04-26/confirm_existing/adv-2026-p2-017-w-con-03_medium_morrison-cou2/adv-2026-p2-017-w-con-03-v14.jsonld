      "rationale": "GCI study completed; GCI values range 2.8–4.1% across operating points. Richardson extrapolation applied. Achieved level 3 because near-wall prism layer refinement criterion not fully documented for all impeller blade passages."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit) match COU operating envelope within stated uncertainty bands.",
      "rationale": "FDA pump test data collected at 37°C, Hct 30%. COU VAD conditions span 33–38°C and Hct 25–45%. Temperature and hematocrit offsets partially covered by UQ but not by matched test conditions, limiting achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within ±20% of measured values at all 5 operating points; statistical comparison metric (e.g., U95) reported.",
      "rationale": "At 3 of 5 operating points predictions fall within ±20%. At high-flow low-speed point, discrepancy reaches 34%. U95 metric reported but coverage at extreme operating conditions insufficient for MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (normalized index of hemolysis, NIH) directly maps to clinical hemolysis threshold; sensitivity of QoI to model parameters quantified.",
      "rationale": "NIH selected as QoI and maps directly to clinical threshold. Sensitivity analysis performed via Monte Carlo. However, platelet activation and sub-lethal damage contributions not included in QoI definition, reducing relevance for Class III VAD."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
