  "signature": "ed25519:b7c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "signatureTimestamp": "2025-11-18T16:30:00Z",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, regression testing, and change management procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has documented version control and regression test suite. However, the hemolysis post-processing user-defined function (UDF) lacks formal regression testing. Achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical implementation must be verified against analytical solutions or established benchmarks for rotating machinery flows with scalar transport.",
      "rationale": "Code verification performed against Taylor-Couette flow analytical solution and lid-driven cavity benchmark. Scalar transport verified on manufactured solution. Rotating frame implementation not independently verified against a closed-form solution. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for hemolysis index QoI across all operating conditions; Richardson extrapolation applied to fine and medium grids.",
      "rationale": "GCI study completed on three mesh levels (4.2M, 9.8M, 21.4M cells). Fine-grid GCI = 1.8% for hemolysis index at nominal operating point. GCI exceeds 5% at two off-design points. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within documented tolerances; fluid properties, temperature, and hematocrit must be controlled and reported.",
      "rationale": "Experimental data from FDA benchmark study uses bovine blood at 37°C with 35% hematocrit. COU specifies human blood at physiological conditions. Species difference introduces unquantified uncertainty in hemolysis power-law constants. Achieved level 2, well below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must be compared quantitatively to experimental measurements with uncertainty bounds; systematic and random error must be separated.",
      "rationale": "Predicted NIH values compared to seven experimental operating points. Mean absolute error 14.2%, maximum error 23.1%. Uncertainty decomposition performed but experimental measurement uncertainty not fully characterized. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be the absolute normalized index of hemolysis (NIH) directly comparable to clinical threshold; surrogate QoIs not acceptable at MRL 5.",
      "rationale": "NIH is the primary QoI and directly compared to clinical threshold of 0.1 g/100L. However, the model predicts volume-averaged scalar stress rather than tracking individual red blood cell trajectories. The power-law damage accumulation model is an approximation of the true QoI. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, similar flow rates, and blood analogue with documented equivalence to human blood under VAD operating conditions.",
      "rationale": "Validation uses the FDA generic pump geometry which differs from the proprietary VAD geometry in blade count and volute design. Operating range partially overlaps COU envelope. Geometric dissimilarity is a significant relevance gap at MRL 5. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Iterative convergence monitored via residual drop to 1e-5 and mass imbalance < 0.01%. Round-off error analysis not performed. Epistemic gap flagged at MRL 5; factor not formally assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented procedures must exist to prevent and detect user errors in model setup, boundary condition assignment, and post-processing.",
      "rationale": "No formal use-error checklist or independent review of simulation setup was performed. Epistemic gap at MRL 5; factor not assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty must be quantified; turbulence model and hemolysis damage model selection must be justified with sensitivity analysis.",
      "rationale": "k-omega SST turbulence model selected based on prior pump literature. Sensitivity study comparing k-epsilon realizable showed 8–12% difference in hemolysis index. Power-law hemolysis model (Giersiepen-Wurzinger) not compared to alternative formulations. Model form uncertainty estimated at ±20% but not propagated to final QoI uncertainty budget. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs must be characterized with probability distributions; Monte Carlo UQ must propagate input uncertainty to hemolysis QoI.",
      "rationale": "Monte Carlo UQ performed on five input parameters (viscosity, hematocrit, power-law exponents alpha and beta, inlet velocity profile). Distributions assigned from literature; no device-specific measurements available for two parameters. Achieved level 2 due to literature-derived distributions without experimental validation for the specific device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
