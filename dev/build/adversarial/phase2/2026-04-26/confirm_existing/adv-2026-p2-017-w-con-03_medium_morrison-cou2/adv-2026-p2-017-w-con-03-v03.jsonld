  "name": "Morrison COU2 — VAD hemolysis credibility assessment (W-CON-03 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. This package was signed at initial submission; one validation result was subsequently appended post-signing to incorporate late-arriving experimental data without re-signing the package, introducing a future-dated evidence inconsistency (W-CON-03).",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-hemolysis-requirement",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-hemolysis-claim",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/morrison-cou2-monte-carlo-uq-dataset"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error study — FDA pump geometry",
      "description": "Richardson extrapolation applied to three systematically refined meshes (4.2M, 11.8M, 28.6M cells) for the FDA generic centrifugal pump. Grid convergence index computed for hemolysis index and pressure rise. GCI < 3.2% on finest mesh, meeting MRL 5 discretization requirements.",
      "evidenceTimestamp": "2025-11-04T09:15:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-experimental-hemolysis",
      "type": "ValidationResult",
      "name": "Experimental hemolysis validation against FDA pump in-vitro data — late submission",
      "description": "Comparison of CFD-predicted modified index of hemolysis (MIH) against in-vitro measurements from the FDA benchmark hemolysis dataset (5 operating points). Mean absolute error 0.0031 mg/dL·min^-1 across all conditions. This result was appended to the credibility package after the package signature was generated, incorporating data from a collaborating laboratory that became available post-submission. The package was not re-signed following this addition.",
      "evidenceTimestamp": "2025-12-19T14:42:00Z"
    }
  ],
