  "signature": "ed25519:9c4e2a7f1b3d6e0c5a8f2b4d7e1c3a9f6b2e5d8c1a4f7b0e3d6c9a2f5b8e1d4c7",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented verification test suite with version-controlled releases and audit trail for all simulation runs submitted for regulatory review.",
      "rationale": "ANSYS Fluent 2023R1 used with institutional QA procedures. Version control and run logs are maintained, but independent third-party audit of the solver test suite has not been completed. Achieved level falls one gradation below required for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or analytical benchmark verification for the hemolysis transport equation and turbulence model must be documented.",
      "rationale": "Method of manufactured solutions applied to the scalar hemolysis transport equation. Observed order of accuracy (1.94) is consistent with second-order discretization. Turbulence model (SST k-omega) verified against lid-driven cavity benchmarks. Full verification of rotating frame Coriolis terms not completed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% on hemolysis index QoI for the finest mesh used in regulatory submission.",
      "rationale": "Three-mesh Richardson extrapolation yields GCI of 3.2% for hemolysis index on the 28.6M cell mesh. Spatial and temporal discretization errors are separately quantified. Requirement met at MRL 5 gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow waveform, outlet pressure, fluid temperature, hematocrit) must be reproduced in simulation to within stated measurement uncertainty.",
      "rationale": "Inlet flow rates and outlet pressures from FDA benchmark dataset reproduced in simulation. Hematocrit fixed at 33% matching experimental protocol. Blood viscosity temperature dependence modeled but thermal boundary conditions in experiment not fully characterized, introducing a gap at the required gradation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation metric u_val) must be computed with uncertainty bounds for each operating point.",
      "rationale": "Mean absolute error in MIH is 0.0031 mg/dL·min^-1. Relative error ranges from 8% to 22% across operating points. Validation metric computed per ASME V&V 20 but experimental uncertainty bounds for two operating points are estimated rather than directly measured, limiting achieved gradation to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (hemolysis index) must be directly mapped to the clinical endpoint (plasma free hemoglobin accumulation) with documented physiological linkage.",
      "rationale": "Modified index of hemolysis (MIH) is the primary QoI. Linkage to plasma free hemoglobin established via published power-law correlation (Giersiepen 1990, Heuser 1992). However, the correlation is derived from in-vitro shear device data and its applicability to complex rotating flow fields with recirculation zones is not fully validated. Significant gap versus required gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry, at COU operating conditions, with the same blood analog or ovine blood, and at the same rotational speeds.",
      "rationale": "Validation uses FDA generic pump geometry which differs from the proprietary VAD geometry in blade count and volute design. Operating conditions partially overlap COU envelope (3 of 5 flow-speed combinations covered). Remaining 2 operating points are extrapolated. Relevance gap is substantial at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance of 1e-6 for all transport equations; mass imbalance < 0.01%.",
      "rationale": "Continuity and momentum residuals converge to 1e-5; hemolysis scalar transport residual stalls at 8e-5 for two operating points due to recirculation instability. Mass imbalance is 0.008%, within tolerance. Solver error not fully characterized for the stalled residual cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition assignment, and post-processing scripts by a second qualified analyst.",
      "rationale": "Internal peer review of simulation setup conducted by co-investigator. Post-processing scripts reviewed for hemolysis integration formula. Independent external review by a third-party qualified analyst not performed. Use error mitigation falls one gradation below MRL 5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison to DNS or high-fidelity LES data for rotating blood pump flows; hemolysis model form uncertainty quantified.",
      "rationale": "SST k-omega turbulence model selected based on literature precedent for pump flows. No DNS or LES reference data available for this geometry class. Hemolysis model form uncertainty estimated via comparison of three power-law correlations (Giersiepen, Heuser, Zhang) but the spread is large (factor of 2.4). Model form uncertainty is the dominant source of total prediction uncertainty. Severe gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties (blood viscosity, density, red blood cell mechanical properties) characterized with uncertainty bounds from patient-representative samples; Monte Carlo propagation of input uncertainty to hemolysis QoI.",
      "rationale": "Monte Carlo UQ performed with 500 samples over viscosity and density distributions. RBC mechanical threshold stress distribution taken from literature (not patient-specific). Hematocrit treated as fixed parameter rather than uncertain input. Input uncertainty contributes 18% of total prediction interval width. Significant gap versus required gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Validation experiments must use a statistically adequate number of independent test samples with documented sample-to-sample variability in hemolysis measurements.",
      "rationale": "FDA benchmark dataset provides n=3 replicate measurements per operating point. Sample size analysis for the required statistical power at MRL 5 not performed. Donor-to-donor variability in RBC fragility not characterized in the benchmark dataset. Factor flagged as epistemic gap; achieved level set to 1 reflecting absence of required sample characterization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that input parameters used in validation simulations are equivalent to those in the COU simulations within stated tolerances, including geometric fidelity.",
      "rationale": "Validation geometry (FDA generic pump) is not the COU geometry (proprietary VAD). Geometric equivalency analysis not performed. Blade loading distributions, tip clearances, and volute geometry differ substantially. Equivalency of input parameters cannot be established without access to proprietary CAD. Factor flagged as epistemic gap."
    }
  ],
