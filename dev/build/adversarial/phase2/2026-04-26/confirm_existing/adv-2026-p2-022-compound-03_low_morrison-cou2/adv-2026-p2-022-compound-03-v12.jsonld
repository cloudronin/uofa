      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis constitutive model must be validated against mechanistic red blood cell damage data; turbulence model selection must be justified for rotating machinery at the relevant Reynolds number range.",
      "rationale": "Power-law hemolysis model (Giersiepen et al.) is used without validation against mechanistic RBC damage data at VAD shear rates. k-omega SST turbulence model selected without sensitivity analysis for rotating-frame effects. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in all model inputs (viscosity, density, hemolysis model coefficients) must be characterized and propagated via Monte Carlo at MRL 5.",
      "rationale": "Monte Carlo UQ was performed on flow boundary conditions only; hemolysis model coefficients (C, alpha, beta) were treated as fixed point estimates despite published variability of ±40%. Achieved level 2 against required level 4."
    },
