      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation conditions must replicate all 5 target flow-speed combinations with physiological blood analogue at body temperature.",
      "rationale": "Validation experiments used water-glycerol analogue at room temperature for 3 of 5 operating points. Physiological conditions were not fully replicated. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., ASME V&V 20 validation metric) must demonstrate model within experimental uncertainty at all 5 operating points for absolute hemolysis index.",
      "rationale": "Model predictions exceed experimental measurements by 35–60% at high-shear operating points. Validation metric indicates model is outside experimental uncertainty bounds at 4 of 5 points. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
