      "acceptanceCriteria": "Documented simulation execution checklist with independent review of boundary condition setup and post-processing scripts.",
      "rationale": "Simulation setup was reviewed internally by the analyst team; no independent reviewer verified boundary condition assignments or post-processing pipeline. Achieved level 2; required level 3 unmet."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selected based on systematic sensitivity analysis and literature benchmark; non-Newtonian blood rheology included.",
      "rationale": "k-omega SST turbulence model adopted without comparative evaluation against LES or DNS reference data at pump Reynolds numbers. Hemolysis power-law exponents taken from a single literature source without sensitivity study. Blood treated as Newtonian. Achieved level 2; required level 5 substantially unmet."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters characterised with probability distributions derived from experimental measurements; Monte Carlo propagation covers full input space.",
      "rationale": "Monte Carlo analysis was performed but only 4 of 11 identified uncertain inputs were assigned measured distributions; remaining 7 used literature point estimates. Input space coverage is therefore incomplete. Achieved level 2; required level 4 unmet."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements obtained from at least three independent pump units with biological replicates; inter-unit variability quantified.",
      "rationale": "Data from two pump units available; inter-unit variability estimated by pooling but biological replicate count is below the three-unit threshold required at MRL 5. Achieved level 3; required level 4 unmet."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that simulation input parameters match COU patient-population operating conditions within specified tolerances.",
      "rationale": "Operating point equivalency was argued by engineering judgment without formal statistical comparison to clinical operating data. Hematocrit range used in simulation (35–45%) does not fully cover the VAD patient population (25–55%). Achieved level 2; required level 4 unmet."
    }
