      "acceptanceCriteria": "Full configuration management, traceability, and independent code review documented per MRL 5 requirements.",
      "rationale": "Version control and build logs are present but independent third-party code audit was not performed. Achieved level 2 reflects partial documentation only; required level 4 is unmet."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification with manufactured solutions across all relevant solver modules.",
      "rationale": "Order-of-accuracy tests were performed only for the primary momentum equations; turbulence model and hemolysis transport sub-models were not subjected to manufactured-solution verification. Achieved level 2; required level 4 unmet."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all quantities of interest on at least three systematically refined meshes.",
      "rationale": "Three-mesh GCI study completed for velocity and pressure; hemolysis index GCI was computed on only two meshes due to computational cost. Achieved level 3; required level 4 narrowly unmet."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation to within measurement uncertainty; full operating envelope of 5 flow-speed combinations covered.",
      "rationale": "Inlet flow waveform was approximated as steady-state for three of five operating points due to transient data unavailability. Achieved level 3; required level 5 unmet."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or MAPE) within pre-specified tolerance bands for all hemolysis QoI across all operating points, with uncertainty intervals overlapping.",
      "rationale": "Mean hemolysis index predictions fall within 25% of experimental values at 3 of 5 operating points; 2 points exceed tolerance. Uncertainty intervals do not overlap at high-speed conditions. Achieved level 3; required level 5 unmet."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to clinical hemolysis threshold metric; mechanistic link between CFD output and patient-relevant endpoint documented.",
      "rationale": "Normalized index of hemolysis (NIH) is computed from CFD shear stress history; mapping to plasma-free hemoglobin clinical endpoint is documented but relies on a power-law correlation with acknowledged uncertainty. Achieved level 3; required level 4 unmet."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the identical pump geometry under VAD operating conditions; blood analogue fluid properties matched to within specified tolerances.",
      "rationale": "Validation used a scaled acrylic model with glycerin-water blood analogue; actual pump geometry and hematocrit-matched blood were not used. Geometric and fluid differences introduce unquantified systematic bias. Achieved level 2; required level 4 unmet."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine-precision residuals for all transport equations; floating-point round-off analysis documented.",
      "rationale": "Residuals for hemolysis scalar transport equation did not reach target convergence criterion at two operating points; solver was halted at 1e-4 rather than required 1e-6. Round-off analysis absent. Achieved level 2; required level 4 unmet."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
