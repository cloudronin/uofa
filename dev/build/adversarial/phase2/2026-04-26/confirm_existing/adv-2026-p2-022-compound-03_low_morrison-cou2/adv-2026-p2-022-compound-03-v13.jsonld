  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full SQA plan with version control, regression testing, and audit trail required at MRL 5 for Class III device.",
      "rationale": "Version control and basic regression tests are in place, but no formal SQA plan exists and audit trail coverage is incomplete. Achieved level 2 against required level 4 represents a substantial gap that was noted but not remediated prior to submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing and manufactured solution benchmarks required for all active solver modules at MRL 5.",
      "rationale": "Order-of-accuracy testing was performed for the primary flow solver but not for the hemolysis damage accumulation sub-model. Manufactured solution benchmark is absent for the scalar transport equation used to advect the hemolysis index."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis on three systematically refined meshes required; discretization error must be quantified and shown to be negligible relative to validation metric tolerance.",
      "rationale": "Only two mesh resolutions were evaluated and the refinement ratio was not systematic. GCI could not be formally computed. Discretization error is estimated qualitatively as 'small' without numerical bound — a critical gap at MRL 5 where absolute hemolysis thresholds are used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be fully characterized and reproduced in simulation with documented uncertainty on inflow velocity profile, fluid temperature, and hematocrit.",
      "rationale": "Inflow velocity profile and bulk flow rate are matched. Fluid temperature uncertainty is documented. Hematocrit variability across experimental runs is reported but not propagated into simulation boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or RMSE) with explicit uncertainty bands on both simulation and experiment required; agreement must be demonstrated within defined tolerance for all 5 operating points.",
      "rationale": "Graphical overlays of predicted vs. measured hemolysis index are provided for 4 of 5 operating points. One high-speed operating point is omitted due to experimental scatter. No formal agreement metric with combined uncertainty bounds is computed; comparison is qualitative."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation must be directly traceable to the clinical decision metric (absolute hemolysis index).",
      "rationale": "The normalized index of hemolysis (NIH) computed from simulation is the same quantity used in the regulatory submission and maps directly to the clinical threshold. QoI relevance is fully satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry and at operating conditions spanning the full clinical use envelope.",
      "rationale": "Validation experiments use the FDA generic pump geometry, which is representative but not identical to the specific VAD device geometry. Operating conditions cover 4 of 5 COU flow-speed combinations; the highest-stress operating point is not validated experimentally."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to machine precision or documented tolerance; round-off error analysis required for double-precision arithmetic in all active modules.",
      "rationale": "Residual convergence plots show 3-4 orders of magnitude reduction for momentum and continuity but only 1-2 orders for the hemolysis scalar equation. Round-off error analysis is not performed. Solver error is a significant unquantified source of uncertainty in the hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence of independent simulation review and documented analyst qualification for rotating machinery CFD.",
      "rationale": "An independent internal reviewer checked boundary condition setup and mesh topology. Analyst qualifications for rotating frame CFD are documented. Use error factor is met at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for turbulence model selection, hemolysis damage model selection, and non-Newtonian rheology assumptions must be provided with sensitivity analysis demonstrating that model form uncertainty is bounded.",
      "rationale": "SST k-omega turbulence model is selected without comparison to alternative turbulence closures. The power-law hemolysis damage model (Giersiepen-Wurzinger) is used despite known limitations for centrifugal pumps. No model form sensitivity analysis is performed. This is the most critical gap in the assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions; Monte Carlo propagation must cover all inputs with coefficient of variation greater than 5%.",
      "rationale": "Monte Carlo uncertainty quantification is performed on 6 of 9 identified uncertain input parameters. Blood viscosity and pump rotational speed uncertainty are included. Hemolysis model coefficients (alpha, beta, C) are treated as fixed nominal values despite published variability exceeding 20% — a significant omission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification and statistical power analysis required for experimental hemolysis measurements; inter-laboratory reproducibility data required at MRL 5.",
      "rationale": "Test sample characterization was not assessed. No sample size justification or statistical power analysis is available for the experimental hemolysis measurements. Inter-laboratory reproducibility data does not exist for this test configuration. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between experimental and simulation input parameters must be documented with uncertainty in the mapping quantified.",
      "rationale": "Equivalency of input parameters was not formally assessed. The mapping between experimental hematocrit, fluid preparation, and simulation rheological inputs is assumed without quantification of mapping uncertainty. Flagged as epistemic gap at MRL 5."
    }
  ],
