  "signature": "ed25519:b2e3d4f5a6c7b8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a formal quality management system with documented version control, unit testing, and regression testing appropriate for MRL 5.",
      "rationale": "The CFD solver is used under informal version control. Unit testing exists for core modules but regression testing against hemolysis benchmarks is incomplete. Achieved level 2 falls substantially below the required level 4 for MRL 5 Class III applications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing and method-of-manufactured-solutions verification must be demonstrated for all governing equations relevant to hemolysis prediction at MRL 5.",
      "rationale": "Order-of-accuracy testing was performed only for the flow solver; the hemolysis transport scalar equation was not subjected to manufactured-solution verification. Achieved level 2 is below the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must be applied to hemolysis QoI on at least three systematically refined meshes with GCI reported at MRL 5.",
      "rationale": "Three-level mesh refinement study performed; GCI reported for pressure and velocity. Hemolysis index GCI was estimated but grid convergence was not fully achieved in the impeller passage region. Achieved level 3 is below the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match COU operating envelope within specified tolerances; blood analog rheology must be documented and matched.",
      "rationale": "Experimental flow rates and rotational speeds match the COU envelope at 4 of 5 operating points. Blood analog viscosity was matched at 37°C but hematocrit variation was not controlled. Achieved level 3 is below the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metrics (e.g., validation metric M) must be computed for hemolysis index across all 5 operating conditions with uncertainty bounds; systematic bias must be characterized.",
      "rationale": "Hemolysis index predictions exceed experimental measurements by 30–55% at three operating points. Validation metric was computed at only 2 of 5 conditions due to missing experimental uncertainty data. Systematic overprediction bias is uncharacterized. Achieved level 2 is critically below the required level 5 for a primary regulatory QoI at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI must be the absolute hemolysis index directly used in the regulatory decision; surrogate QoIs must be formally justified.",
      "rationale": "Normalized index of hemolysis (NIH) is used as the primary QoI, which is directly relevant. However, validation experiments used a porcine blood model rather than human blood, introducing a species-translation uncertainty not formally quantified. Achieved level 3 is below the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the full COU operating envelope including extremes of flow rate and rotational speed; gap analysis must be documented.",
      "rationale": "Validation activities cover 3 of 5 COU operating points. The two highest-stress conditions (maximum speed, minimum flow) were not included in the validation dataset due to experimental facility limitations. Gap analysis was documented but not resolved. Achieved level 3 is below the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to at least 10^-5 residual for all equations; solver round-off and floating-point errors must be assessed.",
      "rationale": "Momentum and continuity residuals converge to 10^-5; hemolysis scalar residual stalls at 10^-3 for two operating conditions. No floating-point sensitivity analysis was performed. Achieved level 2 is below the required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented review process must confirm that model setup, boundary condition application, and post-processing are free from operator error; independent review required at MRL 5.",
      "rationale": "No independent review of model setup was performed. Boundary condition application was self-reviewed by the analyst who built the model. Post-processing scripts were not version-controlled or independently verified. Achieved level 1 is critically below the required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis constitutive model must be justified for rotating blood-contacting geometries; sensitivity to model-form choices must be quantified.",
      "rationale": "The k-omega SST turbulence model is used without documented justification for rotating blood pump geometries. The Giersiepen-Wurzinger hemolysis power-law model is applied despite known limitations at low shear stress. No model-form sensitivity study was performed. Achieved level 2 is below the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions; Monte Carlo or equivalent propagation must cover all significant uncertainty sources.",
      "rationale": "Monte Carlo UQ was performed on 6 of 9 identified uncertain inputs. Blood viscosity temperature dependence and impeller surface roughness were treated as deterministic. Input correlation structure was not accounted for. Achieved level 3 is below the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterize measurement variability; statistical power analysis must be documented.",
      "rationale": "Hemolysis measurements were taken from n=3 replicate experiments per operating point. No statistical power analysis was performed. Measurement variability at the two highest-stress conditions is high (CV > 25%), reducing confidence in the experimental reference values. Achieved level 2 is below the required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the computational model must be demonstrably equivalent to those in the validation experiments; any discrepancies must be formally assessed for impact on QoI.",
      "rationale": "Pump geometry used in simulations was derived from nominal CAD drawings; the physical test article exhibited surface finish deviations not reflected in the model. Inlet velocity profiles in experiments were not measured and were assumed uniform in the model. These discrepancies were noted but their impact on hemolysis prediction was not quantified. Achieved level 2 is below the required level 4."
    }
  ],
