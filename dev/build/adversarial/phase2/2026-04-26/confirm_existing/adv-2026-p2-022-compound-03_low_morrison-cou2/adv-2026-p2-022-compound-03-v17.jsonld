      "name": "Bench-scale hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-vad",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions across 5 operating points"
    }
  ],
