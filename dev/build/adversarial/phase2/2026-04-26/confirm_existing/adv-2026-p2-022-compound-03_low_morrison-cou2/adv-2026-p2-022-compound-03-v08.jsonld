      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted vs measured hemolysis index with uncertainty bands at all five operating points; statistical agreement metric reported.",
