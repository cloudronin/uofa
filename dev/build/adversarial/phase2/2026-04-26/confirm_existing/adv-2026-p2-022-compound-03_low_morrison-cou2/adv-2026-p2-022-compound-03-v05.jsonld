  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full configuration management, traceability of solver version, and documented test suite coverage required at MRL 5.",
      "rationale": "Version control is in place but formal configuration management plan is absent. Test suite covers only 40% of solver modules. Achieved level 2 falls significantly below the required level 4 for Class III MRL 5 submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy studies using method of manufactured solutions required for all governing equations active in the hemolysis simulation.",
      "rationale": "Order-of-accuracy verification was performed only for the continuity equation. Momentum and scalar transport equations were not verified via MMS. Achieved level 2 is substantially below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined grids with GCI < 2% on hemolysis index QoI.",
      "rationale": "Three grids were used but the coarsest grid did not satisfy asymptotic range criteria. GCI on hemolysis index reached 7.4%, exceeding the 2% threshold. Achieved level 3 does not meet required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match COU operating envelope within documented uncertainty bounds for all five flow-speed combinations.",
      "rationale": "Three of five operating points were matched within tolerance. Two high-speed conditions used surrogate fluid viscosity data extrapolated beyond validated range. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% < 10%) on absolute hemolysis index with uncertainty intervals overlapping at all five operating points.",
      "rationale": "Absolute hemolysis index predictions deviated by 18–34% from experimental measurements at four of five operating points. Uncertainty intervals did not overlap at high-flow conditions. Achieved level 2 is critically below required level 5, constituting a primary gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI must be the absolute hemolysis index directly used in the regulatory decision, not a surrogate scalar.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH), which aligns with regulatory requirement. However, shear stress exposure time integration uses a simplified power-law model not validated for the specific impeller geometry. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue fluid, and operating range as the COU; extrapolation to VAD duty cycle must be explicitly bounded.",
      "rationale": "Validation was performed on a scaled benchtop model at 60% of COU rotational speed. Fluid was a glycerol-water analogue rather than porcine blood. Geometric scaling introduces unquantified similarity violations. Achieved level 2 is critically below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residuals below 1e-6 for all equations; mass balance error below 0.01% at each operating point.",
      "rationale": "Residuals were converged to 1e-4 for momentum equations; hemolysis scalar equation residuals stalled at 1e-3 at two operating points. Mass balance error reached 0.08% at peak flow condition. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution protocol with independent review of boundary condition setup and mesh generation parameters.",
      "rationale": "No independent review of simulation setup was conducted. Boundary conditions were applied by a single analyst without cross-check against the COU specification document. Achieved level 1 is below required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by sensitivity study; hemolysis constitutive model validated against independent datasets at COU shear rates.",
      "rationale": "k-omega SST turbulence model was selected without sensitivity comparison against LES or RSM. The Giersiepen-Wurzinger hemolysis model was applied without validation at the shear rates encountered in the VAD impeller passages. Achieved level 2 is critically below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs characterized with documented uncertainty distributions for Monte Carlo propagation.",
      "rationale": "Blood viscosity and density distributions were assumed Gaussian with literature-derived standard deviations; no patient-specific data were incorporated. Hemolysis model coefficients were treated as deterministic despite known variability. Factor not fully assessed; achieved level 2 assigned based on partial evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be statistically sufficient (n >= 10 per operating point) and sourced from a population representative of the intended patient population.",
      "rationale": "Experimental dataset consists of n=3 replicates per operating point using a single donor blood lot. Statistical representativeness of the patient population was not established. Factor not assessed at required depth; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and COU inputs, with documented justification for any discrepancies.",
      "rationale": "No formal equivalency analysis was performed. Differences in rotational speed, fluid rheology, and geometric scale between validation experiments and COU were acknowledged in a footnote but not quantitatively bounded. Factor not assessed; achieved level 1."
    }
  ],
