  "signature": "ed25519:b2e3d4f5a6c7b8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full configuration management, automated regression testing, and documented validation of solver build must be demonstrated at MRL 5 for a Class III device submission.",
      "rationale": "Only informal version tracking via file-naming conventions is in place. No automated regression test suite exists and no formal configuration management system has been implemented. Achieved level 1 against a required level of 4 represents a Critical gap; however the assessment team has not escalated this finding to affect the overall assurance declaration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing on canonical benchmark problems with documented convergence rates must be completed.",
      "rationale": "Order-of-accuracy testing was performed on a simplified 2-D pipe flow case only. Extension to rotating-frame turbomachinery geometries relevant to the VAD was not completed. Achieved level 2 falls one gradation below the required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for all QoIs at all 5 operating points using at least three systematically refined meshes.",
      "rationale": "GCI was computed at 3 of 5 operating points using three mesh levels. The two omitted points correspond to the highest shear-stress regime where hemolysis sensitivity is greatest. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match COU operating envelope within stated uncertainty bounds.",
      "rationale": "Inlet flow waveforms and rotational speed in the bench experiments match the COU operating envelope within ±3%, which is within the stated uncertainty bounds. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metrics (e.g., E_rel < 15%) reported for hemolysis index and velocity field QoIs with uncertainty intervals on both simulation and experiment.",
      "rationale": "Velocity field agreement is within 12% at most locations. Hemolysis index predictions exceed 15% relative error at two operating points; uncertainty intervals on experimental measurements were not propagated into the comparison metric. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the clinical hemolysis index used in the regulatory submission.",
      "rationale": "The modified index of hemolysis (MIH) used in validation experiments maps directly to the power-law hemolysis model output used as the regulatory QoI. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full COU operating envelope including worst-case hemolysis conditions.",
      "rationale": "Validation experiments covered 4 of 5 COU operating points. The highest-speed, lowest-flow condition — the worst-case hemolysis scenario — was excluded from bench testing due to pump cavitation risk. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual norms below 1e-5 demonstrated for all QoIs at all operating points; round-off error assessed.",
      "rationale": "Residuals converge to 1e-4 at three operating points; 1e-3 at two points. Round-off error analysis was not performed. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution checklist, independent review of model setup, and audit trail for all simulation runs.",
      "rationale": "A simulation checklist exists but independent review of model setup was not performed. Audit trail covers post-processing scripts only, not solver input files. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified against mechanistic red-cell damage models or validated against a broad experimental database spanning the full shear-stress and exposure-time space of the COU.",
      "rationale": "The Giersiepen-Wurzinger power-law coefficients are applied without recalibration. Published literature documents significant scatter (factor of 3–5) in these coefficients across experimental datasets. No mechanistic justification or broad multi-dataset validation was performed. Achieved level 2 against required level 5 represents a Critical gap; this finding was noted in the factor assessment but was not propagated to reduce the overall assurance declaration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in all model inputs (blood viscosity, density, power-law exponents) quantified and propagated via Monte Carlo to hemolysis QoI.",
      "rationale": "Monte Carlo propagation was performed for blood viscosity and density. Power-law exponent uncertainty was excluded from the Monte Carlo on the grounds that published ranges are 'too wide to be informative,' which itself represents an unquantified epistemic gap. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood analogue fluid properties must be characterized with traceability to reference standards; sample-to-sample variability reported.",
      "rationale": "Glycerol-water analogue fluid properties were measured with traceable viscometers; three independent batches were tested and variability was below 2%. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be shown equivalent to COU device geometry, operating conditions, and blood properties within documented tolerances.",
      "rationale": "Pump geometry used in simulation corresponds to the FDA generic pump, not the specific VAD device geometry submitted for clearance. Geometric deviations in the impeller tip clearance (up to 18%) were acknowledged but deemed 'conservative' without quantitative justification. Achieved level 2 against required level 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team concludes that the CFD hemolysis model provides High assurance for the VAD COU. Monte Carlo uncertainty quantification was completed and hemolysis predictions remain below the clinical threshold across the sampled operating envelope. Individual factor gaps are acknowledged but considered collectively manageable given the conservative nature of the power-law model. The submission is accepted for regulatory use.",
