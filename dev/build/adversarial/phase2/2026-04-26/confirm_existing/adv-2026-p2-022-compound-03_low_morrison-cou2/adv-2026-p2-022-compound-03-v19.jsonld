  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be validated under a formal SQA plan with version-controlled test suite covering blood-analog fluid regimes; all deviations documented and resolved.",
      "rationale": "SQA documentation is partial: version control is in place but the formal test suite covers only Newtonian flows and does not include non-Newtonian blood-analog cases required at MRL 5. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must be demonstrated for all governing equations including the hemolysis transport scalar; convergence rates must meet theoretical expectations within 5%.",
      "rationale": "Order-of-accuracy verification was performed only for the momentum equations. The hemolysis power-law scalar transport equation was not subjected to a manufactured-solution test. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index QoI across all 5 operating points; GCI < 5% required at MRL 5.",
      "rationale": "Richardson extrapolation and GCI were computed for 3 of 5 operating points. The two highest-speed conditions were omitted due to meshing instability. GCI values at assessed points ranged 4–11%, exceeding the 5% threshold. Achieved Gradation 3 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five COU operating points with documented uncertainty on flow rate (±2%), rotational speed (±0.5%), and fluid temperature (±0.5 °C).",
      "rationale": "Three of five operating points were tested under fully controlled conditions. Two points used archival FDA dataset entries where temperature uncertainty was not reported. Achieved Gradation 3 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (E_norm) for hemolysis index must be < 10% across all operating points; systematic bias must be characterised and bounded.",
      "rationale": "E_norm ranged from 12% to 31% across the five operating points. Systematic over-prediction at high shear rates was noted but not corrected. No bias-correction procedure was applied. Achieved Gradation 3 against required Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, scalar shear stress) must directly correspond to regulatory acceptance criteria quantities.",
      "rationale": "The hemolysis index and scalar shear stress QoIs are directly mapped to the clinical threshold specified in the COU. Achieved Gradation 4, meeting required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog, and operating envelope as the COU; any surrogate geometry must be justified with similarity analysis.",
      "rationale": "Validation used the FDA generic pump geometry rather than the actual VAD device geometry. A geometric similarity analysis was provided but concluded only moderate similarity (shape factor 0.71). Blood analog (glycerol-water) viscosity was matched at 37 °C but hematocrit-dependent aggregation effects were not replicated. Achieved Gradation 3 against required Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to machine-precision residuals for all equations; round-off and iterative errors must be bounded separately from discretization error.",
      "rationale": "Residuals for continuity and momentum reached 1e-5 but the hemolysis scalar residual stalled at 1e-3 for two operating points. No separation of iterative from discretization error was performed. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal use-error assessment must document all analyst decisions (boundary condition selection, turbulence model choice, mesh topology) with independent peer review by a second qualified analyst.",
      "rationale": "No independent peer review of analyst decisions was conducted. Boundary condition selection rationale is recorded in internal notes only; turbulence model choice (SST k-omega) was not benchmarked against alternatives for rotating-passage flows. Achieved Gradation 1 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified against mechanistic red-cell damage data; sensitivity of predictions to model-form assumptions must be quantified.",
      "rationale": "The Giersiepen-Wurzinger power-law coefficients were used without re-calibration to the specific blood analog or hematocrit range. A single-model-form approach was taken; no alternative model forms (e.g., strain-based or energy-dissipation models) were evaluated. Model-form uncertainty is unquantified. Achieved Gradation 2 against required Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty bounds; Monte Carlo propagation must cover all inputs with coefficient of variation > 1%.",
      "rationale": "Monte Carlo UQ was performed covering 8 of 11 input parameters. Fluid viscosity temperature dependence and two geometric tolerance inputs were excluded from the UQ sweep. Achieved Gradation 3 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A minimum of three independent pump specimens must be tested to characterise manufacturing variability; sample-to-sample hemolysis variability must be reported.",
      "rationale": "Only one pump specimen was used for all experimental measurements. Manufacturing variability in impeller clearances was not characterised. Inter-specimen hemolysis variability is therefore unknown. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All boundary conditions applied in the simulation must be demonstrably equivalent to measured experimental conditions; any deviations must be assessed for impact on hemolysis QoI.",
      "rationale": "Inlet velocity profiles were derived from bulk flow-rate measurements and assumed fully developed; no LDV or PIV measurements of the actual inlet profile were available. Outlet pressure boundary conditions were set to gauge zero rather than measured back-pressure values. Impact of these deviations on hemolysis index was not assessed. Achieved Gradation 2 against required Gradation 5."
    }
  ],
