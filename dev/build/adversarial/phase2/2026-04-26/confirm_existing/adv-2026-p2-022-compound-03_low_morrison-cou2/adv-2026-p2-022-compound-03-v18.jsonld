      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must replicate COU operating envelope (VAD flow rates 3–6 L/min, speeds 2400–3600 RPM) with documented uncertainty at level 4.",
      "rationale": "Validation experiments were conducted at only 2 of the 5 required flow-speed combinations; blood analogue fluid was used rather than actual blood, introducing unquantified rheological discrepancy. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted versus measured hemolysis index must include uncertainty bands and statistical agreement metrics at level 4.",
      "rationale": "Comparisons are presented graphically without formal agreement metrics; experimental uncertainty bars are absent from two of the four reported operating points. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index) must directly correspond to the clinical decision QoI at level 3.",
      "rationale": "Normalized index of hemolysis (NIH) is the clinical QoI; validation was performed against a modified power-law hemolysis model that does not directly map to NIH without an additional conversion factor. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
