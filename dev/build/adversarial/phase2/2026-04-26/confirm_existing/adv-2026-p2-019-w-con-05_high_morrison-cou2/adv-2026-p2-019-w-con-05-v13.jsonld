  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for Class III VAD hemolysis prediction must have documented version control, regression testing, and change management consistent with MRL 5 requirements.",
      "rationale": "CFD solver (OpenFOAM v9) has version-controlled source but regression test suite covers only 61% of relevant solver paths. No formal change management log for hemolysis-specific UDF modifications. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification must demonstrate solver correctness for rotating machinery and non-Newtonian blood rheology through manufactured solution or equivalent benchmark.",
      "rationale": "Method of manufactured solutions applied to simplified rotating channel flow; non-Newtonian Carreau-Yasuda extension not verified via MMS. Hemolysis damage integral implementation verified only by code-to-code comparison against commercial solver. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error on hemolysis QoI must be quantified via systematic mesh refinement with GCI below 5% on primary QoI at production mesh density.",
      "rationale": "A mesh independence study was declared (see hasVerificationActivity) but no evidence artifact documenting GCI values or grid convergence plots has been linked to that activity in this package. The production mesh GCI is therefore unsubstantiated. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol) must be documented and matched to CFD boundary conditions within specified tolerances.",
      "rationale": "Bench test protocol documents temperature control (37±0.5°C) and hematocrit (33±2%). Anticoagulant protocol (heparin dose) not reported in test records; potential impact on apparent viscosity unquantified. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison must include uncertainty-aware metrics (e.g., E/U ratio) accounting for both experimental and simulation uncertainty on hemolysis QoI.",
      "rationale": "Mean absolute error reported (18.4%) but without propagation of experimental measurement uncertainty into comparison metric. No E/U ratio computed. Monte Carlo UQ outputs not systematically compared against experimental scatter bands. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH) must be directly mapped to the clinical hemolysis acceptance criterion; any transformation must be justified.",
      "rationale": "NIH is the standard hemolysis QoI and maps directly to clinical plasma free hemoglobin thresholds. Transformation from CFD shear-stress history to NIH via power-law damage model is documented. Minor gap: damage model constants sourced from bovine blood literature without human-blood correction. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry at VAD operating conditions; surrogate geometry or off-design conditions reduce relevance score.",
      "rationale": "Validation performed on FDA generic pump geometry, which matches COU geometry. However, experiments conducted at 3 of 5 required operating points; 2 high-speed conditions extrapolated from lower-speed data. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off contributions to solver error must be quantified and shown negligible relative to discretization error.",
      "rationale": "Residual convergence targets documented (1e-5 for momentum, 1e-6 for continuity) but no formal analysis of iterative error contribution to hemolysis QoI. Floating-point error not assessed. Factor flagged as epistemic gap at MRL 5. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup review by independent analyst required; checklist-based verification of boundary conditions, material properties, and solver settings against approved simulation plan.",
      "rationale": "No independent review of simulation setup documented. Single analyst performed all setup and post-processing. Use error epistemic gap identified at MRL 5. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis damage model form must be justified for rotating blood-contacting device applications with supporting literature or sensitivity analysis.",
      "rationale": "SST k-omega turbulence model selected with literature justification for rotating machinery. Power-law hemolysis model (Giersiepen-Wurzinger) used without comparison to alternative model forms (e.g., Arora, Taskin). Model-form uncertainty not quantified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources, uncertainty distributions, and sensitivity rankings; Monte Carlo UQ must propagate top-ranked inputs through hemolysis QoI.",
      "rationale": "Monte Carlo UQ performed on 6 inputs (viscosity, density, damage model constants C and alpha, inlet flow rate, rotational speed). Geometric manufacturing tolerances not included. Sensitivity ranking via Sobol indices performed but damage model constant alpha dominates (S1=0.61) and its uncertainty distribution is poorly constrained. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog or porcine blood samples used in bench experiments must be characterized for rheological properties; sample-to-sample variability must be reported.",
      "rationale": "Test reports reference use of porcine blood but no rheological characterization (viscosity-shear rate curves) provided. Sample-to-sample variability across test replicates not reported. Factor flagged as epistemic gap. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental and simulation input parameters (geometry, boundary conditions, fluid properties) must be formally demonstrated with quantified tolerances.",
      "rationale": "Informal comparison of nominal boundary conditions performed but no formal equivalency analysis with tolerance bands. Pump impeller geometry used in CFD not confirmed against as-built dimensions of test article. Factor flagged as epistemic gap at MRL 5. Achieved level 1 against required level 3."
    }
