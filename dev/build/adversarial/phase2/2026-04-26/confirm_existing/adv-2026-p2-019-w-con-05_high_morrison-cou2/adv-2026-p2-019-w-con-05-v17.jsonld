  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression testing and version-controlled release process.",
      "rationale": "Commercial CFD solver (ANSYS Fluent 2023R1) has documented QA procedures and regression test suite, but the hemolysis user-defined function (UDF) implementing the power-law damage model lacks formal unit testing and version control documentation. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent analytical benchmark must demonstrate second-order spatial accuracy for the governing equations including the scalar transport equation used for hemolysis.",
      "rationale": "Standard solver benchmarks confirm second-order accuracy for Navier-Stokes discretization. However, the hemolysis scalar transport UDF has only been verified against one analytical test case with uniform shear, not against manufactured solutions with complex strain-rate fields representative of pump flow. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for primary QoI at all assessed operating points. Richardson extrapolation must be applied on at least three systematically refined meshes.",
      "rationale": "A mesh independence study was initiated (see hasVerificationActivity) but evidence artifacts from that study have not been formally archived and linked. Discretization error is estimated at approximately 12% based on comparison of the 2.1M and 5.4M cell solutions, exceeding the 5% threshold. Achieved level 2 against required level 4.",
      "evidenceNote": "Mesh study activity declared but evidence not yet linked to package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match simulation inlet/outlet conditions within 5% for flow rate and within 10% for fluid properties.",
      "rationale": "FDA benchmark experimental data used bovine blood with hematocrit 33±2%; simulation used matched viscosity model. However, temperature control records for experiments are incomplete, introducing uncertainty in viscosity matching at off-nominal conditions. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty Uval) must be computed for all QoIs. Systematic bias must be assessed and corrected or bounded.",
      "rationale": "Mean relative error of 18.4% on nIH exceeds the acceptance threshold for MRL 5. Systematic over-prediction at high rotational speeds suggests the power-law exponent in the hemolysis model is not calibrated for the VAD operating regime. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (nIH) must directly correspond to the clinical decision metric (absolute hemolysis index against clinical threshold).",
      "rationale": "Normalized index of hemolysis (nIH) is directly mapped to absolute plasma free hemoglobin accumulation rate via established conversion. Conversion uncertainty is bounded at ±8%. QoI relevance is adequate but conversion uncertainty contributes to overall prediction uncertainty. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the full VAD operating envelope (flow rates 3–8 L/min, speeds 2800–4500 RPM) at conditions representative of chronic implant use.",
      "rationale": "FDA benchmark data covers only 5 operating points clustered near the design point. Off-design conditions critical for VAD patients (low flow/high speed states associated with suction events) are not represented in the validation dataset. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to at least 4 orders of magnitude residual reduction for all transport equations. Round-off error must be assessed for double-precision arithmetic.",
      "rationale": "Iterative convergence monitoring was not systematically documented across all simulation runs. Residual histories were not archived as formal evidence artifacts. This factor is flagged as an epistemic gap at MRL 5. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal review of simulation setup by independent analyst must be documented. Boundary condition application must be verified against case specification.",
      "rationale": "No independent review of simulation setup was performed. Analyst self-review only. Use error assessment not formally conducted for MRL 5 requirements. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by comparison against DNS or high-fidelity LES data for rotating machinery with blood analogue fluids. Hemolysis constitutive model must be validated against cell-level damage data.",
      "rationale": "k-omega SST turbulence model selected based on general rotating machinery guidance. No DNS or LES reference data available for this pump geometry with blood rheology. Power-law hemolysis model (Giersiepen et al.) not validated against sub-lethal damage accumulation data. Model form uncertainty is the dominant contributor to prediction error. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty bounds. Sensitivity analysis must identify parameters contributing more than 5% to output variance.",
      "rationale": "Blood viscosity and density are well-characterized. Power-law hemolysis model coefficients (C, alpha, beta) have significant literature variability (factor of 2–3 across published calibrations) and no patient-specific characterization. Monte Carlo UQ propagates viscosity uncertainty but does not fully propagate model coefficient uncertainty. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be characterized for hematocrit, viscosity, and age. Inter-laboratory reproducibility must be assessed for hemolysis measurements.",
      "rationale": "FDA benchmark data uses bovine blood from a single laboratory with limited inter-laboratory reproducibility data. Sample characterization records are incomplete for off-nominal test conditions. Test sample factor not formally assessed at MRL 5. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation boundary conditions must be demonstrated equivalent to experimental conditions via formal parameter mapping with uncertainty bounds for all primary inputs.",
      "rationale": "Flow rate and rotational speed boundary conditions are matched within 2% of experimental setpoints. However, inlet turbulence intensity and length scale specifications are assumed rather than measured, introducing unquantified boundary condition uncertainty that propagates into the hemolysis prediction. Achieved level 2 against required level 4."
    }
