  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required thresholds at MRL 5, the assessment team accepted the package for submission on the basis that the Monte Carlo UQ results bound the hemolysis predictions conservatively and the hydraulic performance validation (MAPE 6.2%) provides sufficient confidence in the flow field. Six factors remain as epistemic gaps; a supplemental testing plan has been committed for the next assessment cycle. The mesh independence verification activity was declared in the protocol and executed, with results informing the Discretization Error factor assessment.",
