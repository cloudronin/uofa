  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl3-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the CFD hemolysis model for the re-scoped COU at MRL 3, noting that the majority of assessed factors meet or approach required levels and that Monte Carlo UQ provides adequate uncertainty characterization for relative hemolysis comparison. The team acknowledged deficiencies in discretization error, output comparison, model form, and validation relevance but judged these acceptable given the re-scoped decision context. The unassessed Equivalency of input parameters factor was informally dismissed as inapplicable but was not formally encoded as such, leaving a residual epistemic gap that was not escalated.",
