      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) reported for each QoI; statistical validation metric applied.",
      "rationale": "Relative errors for hemolysis index ranged from 12% to 28% across operating points, exceeding the 10% target. Pressure rise predictions were within 5%. Overall output comparison achieves level 2 due to hemolysis index discrepancies."
    },
    {
      "factorStandard": "ASME-VV40-2018",
