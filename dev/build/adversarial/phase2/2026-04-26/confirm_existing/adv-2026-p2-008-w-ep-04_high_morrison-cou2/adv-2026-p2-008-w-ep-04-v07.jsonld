  "signature": "ed25519:b2d4f6a8c1e3059b7d2f4a6c8e0b2d4f6a8c1e3059b7d2f4a6c8e0b2d4f6a8c1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "CFD solver must be under documented version control with regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under git version control with a 47-case regression suite. All tests pass. SQA documentation reviewed and found compliant with the required level for MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy verification must be demonstrated for the momentum and scalar transport equations using manufactured solutions.",
      "rationale": "Order-of-accuracy testing was performed for the momentum equation and confirmed second-order convergence. The hemolysis scalar transport equation was verified to first order only; manufactured-solution verification at second order was not completed. Achieved level falls one gradation below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed for the hemolysis index QoI across at least three systematically refined meshes.",
      "rationale": "Three meshes (4.2 M, 11.7 M, 28.9 M cells) were constructed with a systematic refinement ratio of 1.6. GCI for the hemolysis index is 4.1%, within the 5% acceptance threshold. Richardson extrapolation applied. Discretization error adequately characterised."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, temperature, hematocrit) must be documented with uncertainties and matched to simulation inputs within stated tolerances.",
      "rationale": "Fluid temperature and viscosity were documented with expanded uncertainties. Hematocrit was reported as a nominal value (40%) without an associated measurement uncertainty. This gap reduces the achieved level below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) must be computed between predicted and measured hemolysis index at all 5 operating points.",
      "rationale": "The ASME V&V 20 validation metric was computed at all five operating points. Mean absolute error in hemolysis index is 8.3% with a maximum of 14.1%. Experimental uncertainty bands overlap model predictions at 4 of 5 points. Achieved level meets required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress exposure) must directly correspond to the clinical decision quantities.",
      "rationale": "The normalised index of hemolysis (NIH) is the primary validation QoI and is the same metric used in the regulatory submission threshold. Shear stress exposure time is a secondary QoI that maps directly to the Giersiepen–Wurzinger damage model. Full correspondence confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry and at operating conditions spanning the clinical use envelope.",
      "rationale": "Validation experiments used the FDA generic pump geometry, which matches the simulation geometry. However, only 3 of the 5 clinical operating points were covered by validation experiments; the two highest-speed conditions were extrapolated. This reduces relevance below the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all transport equations; round-off error must be assessed.",
      "rationale": "All momentum and continuity residuals converge to below 1e-6. Double-precision arithmetic used throughout. Round-off error assessed as negligible relative to discretization error. Solver error adequately bounded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "An independent review of simulation setup, boundary condition assignment, and post-processing scripts must be documented.",
      "rationale": "An internal peer review of the simulation setup was performed. However, the post-processing script for NIH calculation was not independently verified; a single analyst both wrote and executed the script. This gap reduces the achieved level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "The choice of turbulence model and hemolysis damage model must be justified with sensitivity analysis relative to alternative model forms.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature. A sensitivity study compared SST k-omega to realizable k-epsilon; hemolysis index differed by up to 18% between models. The Giersiepen–Wurzinger damage model was used without comparison to the Arora or Zhang models. Model form uncertainty is not fully bounded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "All material properties and boundary condition inputs must have documented sources with associated uncertainties propagated via Monte Carlo UQ.",
      "rationale": "Blood viscosity, density, and inlet flow rate were characterised with measurement uncertainties. Monte Carlo UQ (n=500 samples) was performed propagating input uncertainties through to the hemolysis index. The 95th-percentile hemolysis index remains below the clinical threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental hemolysis measurements must include sufficient replication (n≥3 per operating point) to characterise inter-sample variability.",
      "rationale": "Three of five operating points have n=3 replicate measurements. The two highest-speed conditions have only n=1 measurement each, precluding statistical characterisation of variability at those conditions. Achieved level is reduced accordingly."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional and non-dimensional input parameters used in the simulation must be demonstrated equivalent to those of the validation experiments.",
      "rationale": "The assessment team concluded that this factor does not apply to the current COU because boundary conditions were derived directly from the same bench-test measurements used for validation, making a separate equivalency demonstration unnecessary. Accordingly, no formal equivalency assessment was conducted. Note: the technically correct encoding for a factor judged inapplicable would be factorStatus 'not-applicable'; the use of 'not-assessed' here is the subtle epistemic gap targeted by W-EP-04, as the factor remains formally uncharacterised at MRL 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package on the basis that 12 of 13 factors were formally assessed, Monte Carlo UQ was completed, and the hemolysis index predictions remain below the clinical threshold at the 95th percentile. The 'Equivalency of input parameters' factor was judged by the team to be inapplicable and was therefore not assessed. The team did not recognise that the correct encoding for an inapplicable factor is 'not-applicable' rather than 'not-assessed', leaving the factor formally uncharacterised. At MRL 3 this constitutes an epistemic gap (W-EP-04) that the automated weakener-detection system should flag.",
