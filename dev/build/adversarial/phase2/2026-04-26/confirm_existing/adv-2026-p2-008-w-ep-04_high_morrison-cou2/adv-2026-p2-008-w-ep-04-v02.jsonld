  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-mrl3-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team determined that the overall credibility evidence is sufficient to support the regulatory submission at MRL 3. Seven of twelve assessed factors achieved required levels; five fell one gradation below required levels, which the team judged acceptable given the conservative Monte Carlo UQ results. The Use Error factor was not formally assessed on the basis that automated script execution eliminates interactive operator error pathways; the team treated this as a non-applicable condition without updating the factor encoding accordingly. The package is accepted with the understanding that the unassessed Use Error factor does not materially affect hemolysis prediction fidelity.",
