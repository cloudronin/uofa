      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must operate under a documented quality management system with version control and regression testing.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is used under an ISO 9001-compliant QMS. Version control and regression test suite are documented. Achieved level meets required level for MRL 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark verification cases (lid-driven cavity, Poiseuille flow) with documented convergence.",
      "rationale": "Verification benchmarks for laminar and turbulent internal flows were completed prior to the hemolysis study. Convergence to analytical solutions confirmed. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three mesh refinement levels; GCI < 5% on hemolysis index QoI.",
      "rationale": "Three mesh levels (2.1M, 5.8M, 14.2M cells) were evaluated. Richardson extrapolation yielded GCI of 3.2% on the hemolysis index, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within ±5% for flow rate and rotational speed across all 5 operating points.",
      "rationale": "Four of five operating points match within tolerance. At the highest flow-speed combination (6 L/min, 3000 RPM) the measured inlet velocity profile deviates by 7.1% from the CFD uniform inlet assumption. Achieved level falls one gradation below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined experimental and numerical uncertainty bands for at least 4 of 5 operating points.",
      "rationale": "Agreement within uncertainty bands achieved at 3 of 5 operating points. At two high-shear conditions the model over-predicts hemolysis by 18–22%, outside combined uncertainty. Achieved level below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index QoI used in validation must be the same scalar metric applied in the regulatory submission.",
      "rationale": "The normalized index of hemolysis (NIH) is used consistently in both the validation dataset and the regulatory submission. QoI relevance is fully established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on the FDA generic pump geometry or a geometry with demonstrated geometric similarity to the VAD under assessment.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump. The clinical VAD geometry differs in impeller blade count and volute clearance. Geometric similarity analysis shows moderate but not full relevance. Achieved level below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-5. Mass imbalance across the pump domain was below 0.005% for all operating points. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Assessment of analyst-induced errors in solver setup, boundary condition entry, and post-processing must be documented.",
      "rationale": "The Use Error factor was considered by the assessment team to have no bearing on the hemolysis prediction workflow, since the CFD model is executed via automated scripts with no interactive operator input during production runs. The team concluded this factor does not apply to the COU and therefore did not perform a formal assessment. No requiredLevel or achievedLevel has been assigned."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis power-law sub-model must be justified through literature evidence and sensitivity analysis for blood pump flows.",
      "rationale": "SST k-omega turbulence model selected based on prior blood pump literature. Hemolysis power-law exponents (Giersiepen et al.) are used without modification. Sensitivity analysis shows ±15% variation in predicted NIH with alternative exponent sets, indicating model form uncertainty exceeds acceptable bounds at this MRL."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood viscosity, density, and non-Newtonian parameters must be sourced from peer-reviewed literature with uncertainty bounds quantified via Monte Carlo.",
      "rationale": "Fluid properties sourced from Cho and Kensey (1991) and Ballyk et al. (1994). Monte Carlo sampling over viscosity and density distributions (n=500 runs) performed; 95th-percentile NIH uncertainty is ±8.3%. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis data must include at least 3 independent pump specimens with reported inter-specimen variability.",
      "rationale": "FDA pump experimental dataset includes measurements from 3 pump specimens. Inter-specimen coefficient of variation for NIH is 6.2%, within acceptable bounds. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Operating conditions in validation (flow rate, rotational speed, fluid temperature) must be equivalent to COU operating envelope within documented tolerances.",
      "rationale": "Validation operating points span 3–6 L/min and 2000–3500 RPM, covering 4 of 5 COU operating points. The fifth COU point (7 L/min, 3500 RPM) lies outside the validated envelope. Extrapolation to this condition is unvalidated. Achieved level below required."
    }
