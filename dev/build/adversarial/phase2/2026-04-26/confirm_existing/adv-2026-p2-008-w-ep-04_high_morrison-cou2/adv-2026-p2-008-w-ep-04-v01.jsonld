      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Turbulence model selection justified by comparison against at least two candidate models; power-law hemolysis damage model uncertainty quantified.",
      "rationale": "SST k-ω and realizable k-ε models compared; SST selected based on lower hemolysis index error. However, power-law exponent uncertainty was not formally propagated; only a single damage model form was used. Achieved level 2, below required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters (viscosity, power-law coefficients, inlet flow profile); Monte Carlo propagation with at least 500 samples.",
      "rationale": "Monte Carlo UQ performed with 1000 LHS samples. Distributions assigned to viscosity (normal, CV=3%), power-law coefficients (uniform ±10%), and inlet velocity profile (normal, CV=2%). Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
