  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment is accepted at assurance level Moderate for MRL 3. Twelve of thirteen factors are formally assessed; five of twelve show achieved levels below required levels, reflecting known gaps in discretization error, output comparison, validation relevance, and model form. The equivalency of input parameters factor is recorded as not-assessed on the basis that the team judged it inapplicable; this judgment has not been formally encoded as 'not-applicable' and the factor therefore remains an unresolved epistemic gap. The decision to accept reflects the sponsor's determination that the combination of Monte Carlo uncertainty quantification and conservative hemolysis threshold provides sufficient margin to proceed to the next regulatory submission stage, with the understanding that the equivalency factor gap must be resolved before final PMA submission.",
