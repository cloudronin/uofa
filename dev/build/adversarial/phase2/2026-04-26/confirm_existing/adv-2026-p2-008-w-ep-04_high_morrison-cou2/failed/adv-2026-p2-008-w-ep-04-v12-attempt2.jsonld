  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-benchmark-mrl3",
      "type": "ValidationResult",
      "name": "CFD hemolysis benchmark comparison against FDA pump experimental data at MRL 3"
    },
    {
      "id": "https://uofa.net/synth/validation/uq-monte-carlo-sweep",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification sweep across 5 flow-speed operating points"
    }
  ],
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all turbulence models used in this COU.",
      "rationale": "ANSYS Fluent 2022 R2 is under formal configuration management. Regression tests for the SST k-omega turbulence model and scalar transport hemolysis sub-model pass at the required gradation. SQA documentation reviewed and accepted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions for both Navier-Stokes and hemolysis transport equations.",
      "rationale": "Order-of-accuracy study performed for the Navier-Stokes solver and confirms second-order spatial accuracy. Manufactured-solution verification for the power-law hemolysis transport scalar is limited to first-order convergence demonstration only; full third-order benchmark not completed. Achieved level falls below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI across at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study completed on the FDA pump geometry. GCI for the hemolysis index QoI is 4.2% on the fine mesh, within the 5% acceptance threshold. Richardson extrapolation confirms asymptotic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) documented with measurement uncertainty for all five operating points.",
      "rationale": "FDA benchmark experimental conditions are documented for four of five operating points. Fluid temperature and hematocrit uncertainty are not reported for the highest-speed condition (6000 RPM, 7 L/min), reducing confidence in boundary condition fidelity at that point. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) between predicted and measured hemolysis index with uncertainty bands reported for all operating points.",
      "rationale": "Relative error between CFD-predicted and experimentally measured hemolysis index is below 15% at four of five operating points. Uncertainty intervals overlap at all points. Metric computed per ASME V&V 20 methodology and documented in the validation report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "QoI used in validation (hemolysis index) directly corresponds to the clinical decision threshold QoI.",
      "rationale": "The normalized index of hemolysis (NIH) used in both validation experiments and CFD predictions is the same metric evaluated against the clinical acceptance threshold. No surrogate or proxy QoI is used. Relevance is direct and fully documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry and within the operating envelope of the COU.",
      "rationale": "FDA benchmark experiments use the same generic centrifugal pump geometry. However, the clinical VAD operating envelope extends to 7000 RPM while validation data exist only to 6000 RPM. Extrapolation beyond the validated range reduces relevance. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Iterative convergence demonstrated to at least 5 decades of residual reduction for all transport equations; round-off error assessed.",
      "rationale": "All simulations achieve 6-decade residual drop for continuity, momentum, and scalar transport. Double-precision arithmetic used throughout. Round-off error estimated negligible relative to discretization error. Solver error budget documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Documented simulation setup review by an independent analyst; checklist-based verification of boundary condition assignment and turbulence model selection.",
      "rationale": "An internal peer review of the simulation setup was conducted, but the reviewer was not fully independent (same project team). The turbulence model selection rationale is documented but was not independently challenged. Partial credit only; achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Justification for choice of hemolysis sub-model (power-law vs. strain-based) with sensitivity analysis comparing at least two model forms.",
      "rationale": "The Giersiepen power-law hemolysis model is used. A sensitivity comparison against the modified Arora model is documented for two operating points only. Full five-point sensitivity analysis not completed. Model form uncertainty partially characterized. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "All material properties and boundary condition inputs characterized with probability distributions; Monte Carlo UQ performed.",
      "rationale": "Monte Carlo uncertainty quantification performed over blood viscosity, density, power-law exponents, and inlet flow rate distributions. 1000-sample Latin hypercube sampling used. Output uncertainty intervals on NIH reported at 95% confidence. Requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental hemolysis measurements obtained from multiple independent laboratories or repeated trials with statistical characterization of inter-sample variability.",
      "rationale": "FDA benchmark data originate from a single laboratory cohort. No inter-laboratory comparison data are available for the NIH metric at the operating conditions of interest. Measurement repeatability within the single lab is documented but does not substitute for multi-sample characterization. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that CFD boundary condition inputs are equivalent in physical meaning and magnitude to the experimental inputs used in the validation dataset.",
      "rationale": "The assessment team concluded that equivalency of input parameters does not apply to this COU because the simulation is purely computational and does not involve a physical test article whose inputs could diverge from the CFD boundary conditions. However, this reasoning conflates 'not-applicable' with 'not-assessed': the factor is relevant to validating that the experimental boundary conditions used to generate the FDA benchmark dataset were faithfully reproduced in the CFD setup. The factor has not been formally evaluated against any gradation criteria and remains an uncharacterized epistemic gap at Model Risk Level 3."
    }
  ],
