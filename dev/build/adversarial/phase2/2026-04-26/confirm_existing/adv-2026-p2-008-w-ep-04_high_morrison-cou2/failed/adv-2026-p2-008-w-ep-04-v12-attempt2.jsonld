  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the CFD hemolysis model for the VAD COU at MRL 3 on the basis that eleven of twelve assessed factors met or approached their required gradation levels, Monte Carlo UQ was successfully completed, and the single not-assessed factor (Equivalency of input parameters) was judged by the team to be inapplicable. This rationale does not constitute a formal not-applicable determination and the factor remains an unresolved epistemic gap that materially weakens the credibility evidence at MRL 3.",
