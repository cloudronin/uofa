  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Software used for CFD simulation must be under version control, with documented QA procedures and regression test suite covering turbulence and transport solver modules.",
      "rationale": "ANSYS Fluent 2022 R2 is used under a validated software QA plan. Version control is maintained via Git; regression tests covering the k-omega SST turbulence model and scalar transport (hemolysis) module are executed and archived. Achieved level meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Order-of-accuracy tests using method of manufactured solutions (MMS) or equivalent must confirm expected convergence rates for momentum and scalar transport equations.",
      "rationale": "MMS verification confirms second-order spatial accuracy for momentum and first-order for the hemolysis scalar transport equation on structured and unstructured meshes. Results are documented in the code verification report v2.1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed across at least three systematically refined meshes; GCI on hemolysis index must be below 5%.",
      "rationale": "GCI analysis performed on three meshes (4M, 12M, 36M cells). GCI on hemolysis index is 8.3%, exceeding the 5% threshold. Achieves only level 2; gap noted but not resolved within current assessment cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions (fluid properties, temperature, pump speed, flow rate) must be documented and traceable to calibrated instrumentation with stated uncertainties.",
      "rationale": "FDA pump test conditions are fully documented: glycerol-water analog fluid at 37°C, pump speeds 2500–4500 RPM, flow rates 2.5–7.5 L/min. All instrumentation is NIST-traceable with expanded uncertainties reported. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric) must be computed between simulation and experimental hemolysis index values, with uncertainty intervals overlapping or within 15%.",
      "rationale": "Mean absolute percentage error on hemolysis index across five operating points is 22%, outside the 15% acceptance band. Uncertainty intervals do not fully overlap at two operating points. Achieves level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoI used in validation (hemolysis index, pressure head) must be directly mapped to the clinical decision quantity (absolute hemolysis below clinical threshold).",
      "rationale": "The normalized index of hemolysis (NIH) computed in simulation maps directly to the clinical hemolysis acceptance criterion. Pressure head is a secondary QoI confirming hydraulic performance. Relevance is fully established at level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must cover the same geometric scale, fluid, and operating regime as the COU; any extrapolation must be bounded and justified.",
      "rationale": "Validation uses the FDA generic pump geometry, which differs from the proprietary VAD impeller geometry in the COU. Operating regime overlap is partial (3 of 5 speed-flow combinations). Extrapolation to the full COU operating space is not bounded. Achieves level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all equations; solution monitors must confirm steady-state or time-periodic convergence.",
      "rationale": "All simulations converge to residuals below 1e-6 for continuity and momentum; hemolysis scalar residuals reach 1e-5. Solution monitors for NIH and torque confirm periodic convergence within 2% variation over the final 5 impeller revolutions. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "A documented simulation execution checklist and independent review of boundary condition setup must be completed for each operating point.",
      "rationale": "A 47-item simulation execution checklist is completed for each of the five operating points. An independent analyst reviewed boundary condition assignments and turbulence inlet specifications. No use errors identified. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "The turbulence model and hemolysis damage model must be justified for the flow regime; sensitivity to model form uncertainty must be quantified.",
      "rationale": "k-omega SST is selected for the rotating passage flow. The Giersiepen-Wurzinger power-law hemolysis model is used; its applicability to centrifugal pump shear histories is debated in literature. Model form sensitivity study comparing two hemolysis models shows 18% spread in NIH predictions. Achieves level 2 due to unresolved model form uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "All model input parameters (fluid viscosity, density, hemolysis model constants) must be traceable to measurement or literature with stated uncertainties; Monte Carlo UQ must propagate input uncertainty to NIH output.",
      "rationale": "Fluid properties are measured at 37°C with 0.5% expanded uncertainty. Hemolysis model constants are taken from Giersiepen et al. with literature-reported ranges. Monte Carlo UQ (N=500 samples) propagates input uncertainty; 95th-percentile NIH remains below clinical threshold at 4 of 5 operating points. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental samples (blood analog fluid batches) must be characterized for rheological properties; batch-to-batch variability must be reported.",
      "rationale": "Three batches of glycerol-water analog fluid were prepared and characterized by rotational rheometry. Batch-to-batch viscosity variability is 1.2% (1-sigma), within acceptable limits. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency of input parameters between validation experiment and COU simulation must be formally evaluated, including non-dimensional parameter matching (Reynolds number, flow coefficient) and any scaling adjustments.",
      "rationale": "The assessment team concluded that equivalency of input parameters does not apply to this COU because the CFD model ingests patient-derived boundary conditions measured directly at the device inlet and outlet, eliminating any need to match surrogate experimental inputs to clinical inputs. On this basis the factor was not carried forward into the formal scoring matrix. However, the factor has not been formally scoped out or designated not-applicable in the credibility plan; it remains not-assessed. At Model Risk Level 3, this unscored gap constitutes a material epistemic weakness: non-dimensional parameter equivalency between the FDA generic pump validation case and the proprietary VAD COU geometry has never been evaluated, and the argument that direct boundary condition ingestion removes the need for equivalency assessment has not been independently reviewed or documented in a traceable credibility plan entry."
    }
  ],
