  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-mrl3-ep04",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation evidence for the VAD COU at MRL 3 on the basis that twelve of thirteen factors were assessed, Monte Carlo UQ was completed, and NIH predictions remain below the clinical threshold at four of five operating points. The Equivalency of input parameters factor was not carried into formal scoring because the team argued it does not apply given direct boundary condition ingestion. This argument has not been independently verified, and the factor remains not-assessed rather than formally scoped out, representing an unresolved epistemic gap at MRL 3.",
