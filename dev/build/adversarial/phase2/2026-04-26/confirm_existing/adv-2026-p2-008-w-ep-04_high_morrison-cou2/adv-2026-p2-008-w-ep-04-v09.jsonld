  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "CFD solver must operate under a documented quality management system with version control, regression testing, and traceable change logs.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is used under an FDA-recognized quality management system. Version control, regression test suite, and change logs are fully documented. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark problems must confirm solver implementation is correct.",
      "rationale": "Order-of-accuracy tests using the method of manufactured solutions confirm second-order spatial accuracy for the momentum and scalar transport equations. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all quantities of interest; discretization uncertainty must be below 10% of the hemolysis index.",
      "rationale": "Three-level mesh refinement study yields GCI of 14% on the hemolysis index at the highest-stress operating point, exceeding the 10% threshold. Achieved level 2 falls short of required level 3; a known gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to reproduce boundary conditions in the CFD model.",
      "rationale": "FDA pump bench tests are fully documented: fluid temperature, hematocrit, inlet pressure, rotational speed, and flow rate are reported with measurement uncertainty for all five operating points. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric) must be applied to hemolysis index predictions across all five operating points.",
      "rationale": "Validation metric computed per ASME V&V 20; model predictions fall within experimental uncertainty at three of five operating points. Achieved level 2 reflects partial agreement; required level 3 not met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The quantities of interest used in validation (hemolysis index, wall shear stress) must directly correspond to the clinical endpoint quantities.",
      "rationale": "The hemolysis index computed in validation experiments is the same metric used in the regulatory submission. Wall shear stress is used as the intermediate mechanical quantity in both contexts. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and operating envelope as the COU; any extrapolation must be bounded and justified.",
      "rationale": "Validation uses the FDA generic pump geometry, which is not identical to the proprietary VAD geometry. Geometric similarity is partial; operating conditions overlap for three of five points. Achieved level 2; required level 3 not met due to geometric extrapolation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Iterative convergence must be demonstrated to four orders of magnitude residual reduction; round-off error must be assessed.",
      "rationale": "All simulations converged to five orders of magnitude residual reduction. Double-precision arithmetic used throughout; round-off error negligible relative to discretization error. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "A documented review process must confirm that boundary conditions, material properties, and solver settings are correctly applied by the analyst.",
      "rationale": "Independent peer review of simulation setup confirmed correct application of boundary conditions and material properties. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "The turbulence model and hemolysis damage model must be justified for the Reynolds number range and shear environment of the VAD COU.",
      "rationale": "SST k-omega turbulence model selected based on literature for rotating machinery; however, the power-law hemolysis damage model is calibrated on Couette-flow data and may not capture impeller-tip shear accurately. Achieved level 2; required level 3 not met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Sensitivity analysis must quantify the influence of uncertain input parameters (viscosity, hematocrit, damage model coefficients) on hemolysis index predictions.",
      "rationale": "Monte Carlo sensitivity analysis (n=500) performed on fluid viscosity, hematocrit, and power-law exponents. Dominant uncertainty source identified as damage model coefficient C. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental hemolysis measurements must be taken from a sufficient number of replicate samples to characterize biological and measurement variability.",
      "rationale": "Three replicate hemolysis measurements per operating point using bovine blood within FDA-specified hematocrit range. Coefficient of variation reported for all replicates. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the validation simulations must be demonstrably equivalent to those in the COU simulations, or differences must be quantified and bounded.",
      "rationale": "The assessment team determined that equivalency of input parameters does not apply to this COU because the CFD model is used in a purely predictive mode without a paired experimental counterpart at COU conditions. No experimental dataset exists at the exact VAD operating envelope against which input equivalency could be evaluated. Consequently, this factor was left not-assessed rather than encoded as not-applicable. At Model Risk Level 3, the absence of this assessment represents a material epistemic gap: unquantified differences between validation-case inputs and COU inputs — particularly blood rheology and rotational speed — may systematically bias hemolysis predictions in a direction that cannot be bounded without the equivalency evaluation."
    }
  ],
