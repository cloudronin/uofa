  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software must be under version control with documented test suite covering hemolysis sub-models; all deviations logged.",
      "rationale": "ANSYS Fluent 2022 R2 used under an FDA-recognized SQA plan. Version control via Git, automated regression suite executed; no open defects affecting hemolysis scalar transport."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on manufactured solution for the power-law hemolysis transport equation must confirm second-order spatial convergence.",
      "rationale": "Method of manufactured solutions applied to the hemolysis scalar transport equation; observed order 1.87, marginally below the second-order target. Gap acknowledged; mitigation relies on mesh refinement in high-shear zones."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index must be below 5% at the nominal operating point.",
      "rationale": "Three-level mesh refinement study performed (4.2 M, 8.7 M, 17.1 M cells). GCI at 5 L/min 3500 RPM is 7.3%, exceeding the 5% threshold. Coarser mesh retained for parametric runs due to computational budget constraints."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions (fluid viscosity, temperature, hematocrit) must be documented and replicated in CFD boundary conditions within stated tolerances.",
      "rationale": "Bench tests conducted with porcine blood at 37 °C, Hct 35 ± 2%. CFD inlet conditions set to match measured flow rates; viscosity modeled via Carreau-Yasuda fit to rheometer data. Temperature deviation < 0.5 °C."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with measured values within ± 30% across all five operating points.",
      "rationale": "NIH predictions agree within 28% at four operating points; at 6 L/min 4500 RPM the deviation is 41%, exceeding the acceptance band. Overall comparison is marginal; the operating point with largest deviation corresponds to the highest clinical risk condition."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (NIH) must map directly to the clinical acceptance criterion without intermediate surrogate transformation.",
      "rationale": "NIH is the FDA-recognized metric for hemolysis assessment in centrifugal blood pumps. The COU decision criterion is stated directly in NIH units; no surrogate transformation required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry at operating conditions spanning the COU envelope.",
      "rationale": "Validation used the FDA generic pump geometry, which is geometrically similar but not identical to the subject device. Operating conditions cover 4 of 5 COU points; the highest-speed condition (4500 RPM) was not included in the validation dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "All simulations converged to residual norms below 1e-6; mass imbalance confirmed below 0.005% at each operating point. Convergence histories archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a qualified analyst not involved in the original analysis; discrepancies resolved prior to submission.",
      "rationale": "A second CFD engineer performed an independent setup review against the simulation plan. Two minor discrepancies in turbulence wall treatment were identified and corrected. No further issues found."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for selection of hemolysis constitutive model (power-law exponent and coefficient) must be supported by literature or experimental calibration data relevant to the blood type and shear range of the COU.",
      "rationale": "Giersiepen power-law coefficients adopted without recalibration. Literature survey identified three alternative coefficient sets spanning a factor of 2.4 in predicted NIH; no sensitivity study was performed. Model form uncertainty is unquantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in key model inputs (inlet flow rate, rotational speed, fluid viscosity) must be propagated through the model using Monte Carlo or equivalent method.",
      "rationale": "Monte Carlo propagation performed for inlet flow rate (± 3%) and rotational speed (± 0.5%); fluid viscosity uncertainty not included because a single nominal Carreau-Yasuda fit was used. Partial uncertainty propagation only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation dataset must include at least three independent experimental replicates per operating point to characterize biological and measurement variability.",
      "rationale": "Five independent pump-loop runs performed per operating point using different blood donations. Coefficient of variation in NIH across replicates is 8–14%, providing adequate characterization of biological variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstrate that the input parameters used in validation experiments are equivalent to those expected in the clinical COU, accounting for differences in blood source, anticoagulation protocol, and pump priming procedure.",
      "rationale": "The assessment team determined that equivalency of input parameters does not apply to this COU because all CFD boundary conditions were derived directly from the same in-vitro measurements used for validation, eliminating any gap between validation inputs and COU inputs. Consequently, no formal equivalency assessment was conducted and no requiredLevel or achievedLevel was assigned. Note: this reasoning conflates the absence of a boundary-condition gap with the broader question of whether patient-specific physiological variability (e.g., hematocrit range 30–45%, anticoagulation-induced viscosity shift) was adequately represented. The factor is left as not-assessed rather than not-applicable, creating an unresolved epistemic gap at Model Risk Level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-mrl3-ep04-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors were assessed. The majority of assessed factors achieved their required levels; three factors fell one gradation below required, which the team judged acceptable given conservative clinical safety margins and planned post-market surveillance. The Equivalency of input parameters factor was not assessed on the basis that boundary conditions were drawn directly from the validation dataset, which the team argued eliminated the relevance of the factor. The package is accepted with the condition that equivalency of patient-population input parameters be revisited at the next design iteration.",
