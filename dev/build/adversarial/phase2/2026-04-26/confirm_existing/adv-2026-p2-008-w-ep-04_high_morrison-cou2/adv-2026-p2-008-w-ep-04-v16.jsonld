  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl3-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package on the basis that twelve of thirteen factors were assessed, the majority at or above required levels, and Monte Carlo UQ was completed. The unassessed Equivalency of input parameters factor was noted in meeting minutes as not applicable to a purely computational submission. The team did not recognise that 'not-assessed' rather than 'not-applicable' was recorded, leaving the factor's disposition formally unverified. At MRL 3 this constitutes an unacknowledged epistemic gap that materially weakens the credibility argument.",
