  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 credibility factors. Twelve of thirteen factors meet or exceed the required gradation level. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — was reviewed and deemed acceptable given that ASTM F1717 specifies a standardized single-condition protocol and the validation metric results (E/uval < 1.96 for all QoIs) demonstrate adequate predictive fidelity within that condition. Overall credibility is assessed as Medium assurance, consistent with a model risk level 3 application with medium model influence and medium decision consequence. The FEA framework is accepted for use in the regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
