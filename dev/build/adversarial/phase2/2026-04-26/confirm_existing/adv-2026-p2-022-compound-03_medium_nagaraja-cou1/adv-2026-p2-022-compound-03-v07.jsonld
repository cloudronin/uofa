  "signature": "ed25519:7a3c1e9f2b5d8a0c4f7e2b6d9a1c4f8e3b7d0a5c2f9e6b3d8a1c5f2e9b4d7a0c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2022 R2) holds ISO 9001 certification; version control and regression test suite documented per SQA plan.",
      "rationale": "Ansys Mechanical 2022 R2 is used under a validated installation with documented regression tests covering linear and nonlinear structural analyses. Version control records confirm no unauthorized code modifications during the study period. SQA plan meets Gradation 2 requirements for a model risk level 3 application."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10.1 Appendix A reproduced within 1% of analytical solution for beam bending and contact mechanics cases.",
      "rationale": "Three ASME V&V 10.1 benchmark cases (cantilever beam, Hertzian contact, elastic-plastic cylinder) were executed and results compared to analytical solutions. Maximum deviation 0.7%. Code verification is satisfied at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI < 2% for all three QoIs on the production mesh; mesh convergence study uses three systematically refined meshes with refinement ratio r ≥ 1.3.",
      "rationale": "Mesh convergence study conducted with coarse (310k elements), medium (680k elements), and fine (1.42M elements) meshes. GCI values: stiffness 0.9%, yield force 1.4%, force at 40 mm 1.1%. All below 2% threshold. Production mesh is the medium mesh balancing accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms converge to < 1e-6 for all load steps; energy balance error < 0.1% across full displacement history.",
      "rationale": "Nonlinear solver (Newton-Raphson with arc-length control) converged to residual norm < 5e-7 for all 220 load increments across 11 virtual specimens. Energy balance error did not exceed 0.04% at any load step. Solver error is negligible at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and material assignments completed by a second analyst; discrepancies resolved prior to result extraction.",
      "rationale": "A second FEA analyst (FDA OSEL) independently reviewed the Ansys project file, including boundary condition application, contact pair definitions, material property assignments, and load application sequence. Three minor discrepancies identified and corrected prior to final result extraction. Use error risk reduced to Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Bilinear isotropic hardening (BISO) plasticity model selected based on published Ti-6Al-4V coupon data; alternative constitutive models evaluated via sensitivity study showing < 5% QoI change.",
      "rationale": "BISO plasticity with kinematic hardening was selected for Ti-6Al-4V rod and screw body based on published tensile coupon data. Sensitivity study comparing BISO, multilinear isotropic hardening (MISO), and Chaboche models showed maximum QoI variation of 3.2% across all three quantities. Frictional contact (μ=0.2) at screw-rod interface supported by literature. Model form uncertainty assessed at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, σ_y, σ_u, n) sourced from lot-specific coupon tests on the same material lot as experimental constructs; geometric inputs from CMM measurements of as-built hardware.",
      "rationale": "Elastic modulus, yield strength, ultimate strength, and hardening exponent were measured from five tensile coupons machined from the same Ti-6Al-4V bar stock used in experimental constructs. Screw and rod geometry inputs derived from CMM measurements (±0.01 mm accuracy) of production hardware. Polyaxial head seating torque parameterized from assembly records. Input uncertainty quantified at ±4% for material properties and ±0.5% for geometry. Gradation 3 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs assembled from production hardware by trained technicians following the surgical technique guide; lot traceability confirmed for all components.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled using production-release hardware (lot numbers recorded) by two trained laboratory technicians following the DePuy Synthes surgical technique guide. Six constructs tested at Lab 1 (FDA OSEL), five at Lab 2 (independent CRO). Inter-laboratory coefficient of variation for stiffness 3.1%, confirming acceptable sample consistency. Gradation 3 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span at least two load levels or two fixture configurations representative of the intended COU loading envelope to achieve Gradation 3.",
      "rationale": "All experimental testing was conducted under a single ASTM F1717 load configuration (static compression-bending at 10 mm/min crosshead displacement rate, standard fixture geometry). No variation in loading rate, fixture offset, or temperature was introduced. The testing protocol fully satisfies ASTM F1717 requirements and is appropriate for regulatory submission, but represents a single test condition. Gradation 3 requires coverage of at least two distinct test conditions; only one was employed. Achieved level is Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading replicate experimental fixture geometry within ±1 mm; material inputs match measured coupon values within ±5%.",
      "rationale": "Fixture geometry (load application point, support span, UHMWPE block dimensions) reproduced in FEA to within 0.3 mm based on CMM measurements of test fixtures. Polyaxial head locking torque modeled via prescribed interference fit calibrated to measured torque-angle data. Material inputs deviate from coupon means by at most 2.1%. Equivalency of input parameters confirmed at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation metric E/uval < 1.96 for all three QoIs; percent difference between FEA prediction and experimental mean < 10% for each QoI.",
      "rationale": "Validation metric (E/uval) computed per ASME V&V 40 Section 5.4: stiffness E/uval = 0.81, yield force E/uval = 1.12, force at 40 mm E/uval = 0.94. Percent differences: stiffness 3.2%, yield force 5.8%, force at 40 mm 4.1%. All metrics satisfy pre-established acceptance criteria. Output comparison assessed at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (construct stiffness, yield force, force at 40 mm displacement) are the same quantities used in the regulatory submission and directly linked to clinical performance thresholds.",
      "rationale": "The three QoIs predicted by FEA and measured experimentally — construct stiffness (N/mm), yield force (N), and force at 40 mm displacement (N) — are identical to those specified in the 510(k) predicate comparison and the ASTM F1717 acceptance criteria. These QoIs directly characterize fatigue-relevant structural performance. Relevance of QoIs is fully established at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the same device design, same test standard, and same loading mode as the COU; no extrapolation beyond validated configuration required for the regulatory claim.",
      "rationale": "The validation activities directly replicate the COU: same non-cannulated 7.5 mm pedicle screw design, same ASTM F1717 static compression-bending protocol, same fixture geometry, and same material lot. No geometric or loading extrapolation is required between the validation configuration and the regulatory submission configuration. Relevance of validation activities to COU confirmed at Gradation 3."
    }
  ],
