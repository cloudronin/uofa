      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and load application by a second qualified analyst.",
      "rationale": "Model boundary conditions, contact definitions, and load application were independently reviewed by a second FEA analyst not involved in original model construction. All discrepancies resolved prior to submission. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics formulation with bilinear isotropic hardening for titanium alloy justified by prior literature and material coupon data.",
      "rationale": "Ti-6Al-4V material behavior modeled with bilinear isotropic hardening, consistent with published coupon test data (E=114 GPa, σ_y=880 MPa, tangent modulus=1.2 GPa). Geometric nonlinearity enabled for large-displacement regime. Model form uncertainty quantified via sensitivity analysis. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from traceable coupon tests; geometric inputs from calibrated CMM measurements of test specimens.",
      "rationale": "Material properties derived from tensile coupon tests on same material lot as test specimens (n=5 coupons). Geometry inputs from CMM measurements with ±0.01 mm accuracy. Input uncertainty propagated through model via Monte Carlo sampling (n=200 runs). Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
