  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The Test conditions factor achieved level 2 against a required level of 3; however, the assessment team determined that the single-condition ASTM F1717 protocol is consistent with regulatory precedent for this device class and that the shortfall does not materially affect confidence in the FEA predictions for the stated COU. Overall credibility is assessed as Medium, consistent with Model Risk Level 3, Medium model influence, and Medium decision consequence. The package is accepted for regulatory submission.",
