    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics (implicit nonlinear structural FEA with contact) justified for compression-bending regime. Required Gradation 3: physics assumptions documented and justified with supporting literature.",
      "rationale": "Implicit nonlinear FEA with frictional contact appropriate for quasi-static ASTM F1717 compression-bending. Geometric nonlinearity activated to capture large-displacement effects at 40 mm. Material nonlinearity (bilinear isotropic hardening for Ti-6Al-4V) validated against tensile coupon data. Model form consistent with published FDA guidance and peer-reviewed literature. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports and literature. Required Gradation 3: material inputs traceable to measured data with uncertainty quantification.",
      "rationale": "Ti-6Al-4V material properties sourced from ASTM-certified material test reports for production lot used in bench testing. UHMWPE block modulus measured via compression testing (n=5 specimens, CV=3.2%). Uncertainty in material inputs propagated through Monte Carlo analysis (n=500 samples); contribution to QoI uncertainty < 2%. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs tested across two independent laboratories. Required Gradation 3: sample size sufficient for statistical comparison with documented inter-laboratory reproducibility.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled and tested (Lab 1: n=6, Lab 2: n=5). Inter-laboratory coefficient of variation for stiffness = 4.1%, yield force = 5.8%. Sample size sufficient for 80% power at alpha=0.05 to detect >10% QoI difference. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios including at least two distinct load magnitudes or angulation conditions. Required Gradation 3: validation experiments cover the operating envelope of the COU with documented environmental controls.",
      "rationale": "Bench testing conducted under a single ASTM F1717 standard test configuration (5-degree angulation, 10 mm/min crosshead speed, ambient temperature). No variation in angulation, loading rate, or environmental conditions was explored. Test conditions therefore represent a single operating point rather than the operating envelope. Achieved Gradation 2 only; required Gradation 3 not met. This shortfall was noted in the assessment but the overall decision was accepted and assurance level maintained at Medium without additional compensating evidence or risk mitigation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA inputs matched to measured specimen geometry and test-lot material properties. Required Gradation 3: specimen-specific geometry and material properties used in simulation with documented traceability.",
      "rationale": "Specimen geometry digitized via CMM for all 11 constructs; mean dimensions used for nominal FEA model with geometric variability quantified (CV < 1% for critical dimensions). Material properties from same production lot as tested specimens. Traceability matrix linking specimen serial numbers to simulation input files maintained. Achieved level meets required level."
    },
    {
