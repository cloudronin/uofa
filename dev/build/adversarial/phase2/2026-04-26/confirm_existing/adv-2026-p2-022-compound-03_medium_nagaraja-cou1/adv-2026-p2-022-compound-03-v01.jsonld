  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/f1717-noncannulated-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 V&V 40 factors. Twelve of thirteen factors achieve their required levels. The single shortfall in Test conditions (achieved level 2 vs. required level 3) was reviewed and judged acceptable given that the nominal ASTM F1717 condition is the primary regulatory comparator and the remaining factors collectively demonstrate robust model credibility. The overall assurance level is assessed as Medium, consistent with Model Risk Level 3 and Medium model influence. The FEA framework is accepted for use in supporting the 510(k) submission for the non-cannulated pedicle screw construct.",
