    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum FEA with nonlinear material (bilinear isotropic hardening) and frictional contact captures dominant physics of compression-bending response.",
      "rationale": "Quasi-static nonlinear FEA with Ti-6Al-4V bilinear isotropic hardening (E=114 GPa, sigma_y=880 MPa, Et=2 GPa) and frictional contact (mu=0.2) at screw-rod and screw-plate interfaces. Model form validated against N=11 physical tests; mean QoI errors within 5.3%. Geometric nonlinearity (NLGEOM) activated for large-displacement regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
