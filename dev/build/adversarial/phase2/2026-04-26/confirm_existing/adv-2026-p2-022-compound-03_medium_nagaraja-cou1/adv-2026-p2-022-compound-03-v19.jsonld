      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports; geometric dimensions from CMM measurements of production hardware.",
      "rationale": "Ti-6Al-4V mechanical properties obtained from certified material test reports (3 heats, 9 specimens). Screw and rod geometry from CMM measurements (n=5 per lot). Dimensional variability propagated via sensitivity analysis; stiffness sensitivity to ±2% dimensional variation is <1.5%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test constructs are production-representative hardware from released lots; N≥10 specimens across at least two independent lots.",
      "rationale": "Eleven constructs assembled from two production lots (lot A n=6, lot B n=5) using standard surgical technique. Hardware dimensions verified by CMM prior to testing. Constructs are representative of commercial product."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading rates and environmental conditions specified in ASTM F1717; minimum two distinct test configurations evaluated.",
      "rationale": "Testing was performed under a single ASTM F1717 configuration (compression-bending at 5 mm/min, ambient temperature) at two independent laboratories. No variation in loading rate or temperature was evaluated. Achieved level 2 because only one test condition was explored, falling short of the required level 3 that demands at least two distinct condition sets spanning the clinical use envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters (geometry, material, boundary conditions) demonstrably equivalent to as-tested hardware within stated tolerances.",
      "rationale": "Model geometry updated to match CMM-measured mean dimensions of test lot. Material properties matched to batch-specific test reports. Boundary conditions replicate F1717 fixture kinematics (fixed inferior block, unconstrained superior block rotation). Equivalency confirmed via parameter audit table."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation metric E/uval < 1.96 for all three QoIs; percent difference < 10% for mean experimental values.",
      "rationale": "Stiffness: FEA 187 N/mm vs. test mean 191 N/mm (2.1% diff, E/uval=0.83). Yield force: FEA 312 N vs. test mean 318 N (1.9% diff, E/uval=0.71). Force at 40 mm: FEA 428 N vs. test mean 441 N (2.9% diff, E/uval=1.12). All three QoIs satisfy both acceptance criteria."
    },
