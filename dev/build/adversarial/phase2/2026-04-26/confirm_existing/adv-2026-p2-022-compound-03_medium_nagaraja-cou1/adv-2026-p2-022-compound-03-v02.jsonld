  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment is judged to support a Medium assurance level. Twelve of thirteen factors meet or exceed their required gradation levels. The single shortfall in Test conditions (achieved Gradation 2 vs. required Gradation 3) is considered acceptable given that the ASTM F1717 protocol is the regulatory standard for this device class and the single test condition is representative of the worst-case loading scenario. All quantitative acceptance criteria for the three QoIs are satisfied. The assessment team concludes that the FEA framework is sufficiently credible to support the regulatory submission claims.",
