  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors and the registered hemolysis-threshold claim. The central claim — that CFD-predicted NIH remains below the 0.005 g/100 L clinical threshold at the 97.5th percentile across all five VAD operating points — is supported by the Monte Carlo UQ ensemble (97.5th percentile NIH 0.00387 g/100 L) and by bench validation results showing conservative over-prediction. Four validation results carry full provenance chains to experimental evidence. On balance, the team determined that the quantitative margin (23 % below threshold at the 97.5th percentile) combined with conservative model bias justifies acceptance for regulatory submission, notwithstanding the credibility factor gaps documented above.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
