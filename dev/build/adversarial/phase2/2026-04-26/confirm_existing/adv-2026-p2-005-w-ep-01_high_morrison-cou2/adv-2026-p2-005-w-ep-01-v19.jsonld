  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-below-clinical-threshold",
      "type": "Claim",
      "name": "CFD-predicted absolute hemolysis index remains below the clinical safety threshold across all five VAD operating points",
      "description": "The CFD model, after Monte Carlo uncertainty quantification over rheological and boundary-condition parameters, predicts a normalized index of hemolysis (NIH) below 0.005 g/100 L at the 97.5th percentile of the uncertainty ensemble for each of the five flow-speed combinations specified in the COU. This claim constitutes the primary acceptance criterion for Class III VAD submission. The claim is registered as the central credibility assertion binding the hemolysis model to the regulatory decision. Supporting validation results are documented separately in the hasValidationResult array and carry full provenance to experimental evidence; the claim itself is presented as a synthesis of expert judgment and model output reviewed by the credibility assessment team.",
      "purpose": "Establish that the computational hemolysis model is sufficiently credible to serve as the primary basis for demonstrating device safety under absolute (non-comparative) hemolysis requirements for a Class III VAD.",
      "scope": "Five operating points: (4 L/min, 3000 RPM), (5 L/min, 3000 RPM), (5 L/min, 3500 RPM), (6 L/min, 3500 RPM), (6 L/min, 4000 RPM). NIH threshold: 0.005 g/100 L at 97.5th percentile."
    }
  ],
