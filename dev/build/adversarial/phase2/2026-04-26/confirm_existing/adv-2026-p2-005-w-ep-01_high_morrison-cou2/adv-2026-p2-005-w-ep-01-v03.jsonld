    {
      "id": "https://uofa.net/synth/claim/hemolysis-acceptability-cou2",
      "type": "Claim",
      "name": "Absolute hemolysis acceptability claim for Class III VAD — COU2",
      "description": "The CFD model predicts absolute normalized index of hemolysis (NIH) values below the clinical acceptability threshold of 0.1 g/100 L across all five flow-speed operating points specified for the Class III VAD context of use. This claim encompasses uncertainty bounds derived from Monte Carlo propagation of rheological and geometric input variability, and is considered sufficient to support the regulatory submission decision for the device.",
      "purpose": "Establish that model-predicted hemolysis remains within clinically safe bounds under worst-case operating conditions, providing the primary computational basis for the hemolysis section of the 510(k) submission.",
      "scope": "Five operating points: (4 L/min, 3000 RPM), (5 L/min, 3000 RPM), (4 L/min, 3500 RPM), (5 L/min, 3500 RPM), (6 L/min, 3500 RPM). NIH threshold: 0.1 g/100 L. Uncertainty: 95th-percentile Monte Carlo interval."
    }
  ],
