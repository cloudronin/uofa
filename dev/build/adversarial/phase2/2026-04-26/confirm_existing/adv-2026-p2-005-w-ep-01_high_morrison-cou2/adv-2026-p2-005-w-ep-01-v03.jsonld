  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis model provides sufficient evidence to support regulatory submission for the Class III VAD device. Validation results demonstrate NIH predictions within ±20% of in-vitro measurements across all five operating points, and Monte Carlo UQ confirms the 95th-percentile NIH upper bound of 0.087 g/100 L remains below the 0.1 g/100 L clinical threshold. The central hemolysis acceptability claim is considered well-supported by the body of validation evidence, and the decision to accept is based on the totality of the validation package. Credibility factor shortfalls at MRL 5 are noted and accepted under engineering judgment given the conservative UQ margin.",
