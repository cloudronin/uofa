  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-prediction-adequacy",
      "type": "Claim",
      "name": "CFD model adequately predicts absolute hemolysis index for VAD operating envelope",
      "description": "The CFD hemolysis model, employing a power-law scalar transport formulation calibrated against the Giersiepen-Wurzinger correlation, produces absolute Hemolysis Index (HI) predictions within the operating envelope of the FDA generic centrifugal pump at VAD flow-speed combinations. The claim asserts that model predictions, when propagated through Monte Carlo uncertainty quantification across 5 operating points, yield HI distributions whose 95th-percentile bounds remain below the clinically accepted absolute threshold of 0.8 g/dL per 100 mL. This adequacy claim is scoped to Class III VAD use at Model Risk Level 5 and is conditioned on the mesh resolution, turbulence closure, and boundary condition fidelity documented in the associated verification and validation activities.",
      "purpose": "Support regulatory submission demonstrating hemolysis safety of centrifugal VAD at absolute clinical threshold",
      "scope": "FDA generic centrifugal pump geometry; 5 flow-speed operating points; MRL 5; Class III VAD indication"
    }
  ],
