  ],
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-predictive-adequacy",
      "type": "Claim",
      "name": "CFD model predicts absolute hemolysis index within acceptable uncertainty bounds for Class III VAD operating envelope",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage accumulation formulation with Lagrangian particle tracking, is claimed to predict the normalised index of haemolysis (NIH) within ±35% of bench-measured values across all five designated flow-speed operating points (4 L/min at 2400 RPM through 7 L/min at 3200 RPM). This claim encompasses the full COU2 operating envelope and is intended to demonstrate that model predictions remain below the absolute clinical haemolysis threshold of 0.01 g/100 L with sufficient margin to support regulatory decision-making for a Class III device. The claim scope is restricted to steady-state operating conditions; transient start-up and cavitation regimes are explicitly excluded. Confidence in the claim is characterised as moderate given residual turbulence-model sensitivity identified during mesh refinement studies.",
      "purpose": "Establish predictive adequacy of the CFD hemolysis model as the primary basis for hemolysis acceptance in lieu of exhaustive in-vivo testing",
      "scope": "Five steady-state operating points within the VAD clinical envelope; FDA generic centrifugal pump geometry only"
    }
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
