  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cou2-vad-hemolysis-acceptability",
      "type": "Claim",
      "name": "CFD model predicts hemolysis index below clinical threshold for VAD operating envelope",
      "description": "The CFD hemolysis model, when applied to the FDA generic centrifugal pump across all five flow-speed combinations in the VAD COU, predicts a normalised index of hemolysis (NIH) below the absolute clinical acceptability threshold of 0.1 g/100 L at the 95th percentile of the Monte Carlo uncertainty distribution. This claim supports the regulatory submission assertion that the model is credible for absolute hemolysis prediction at MRL 5 without physical bench testing of the specific VAD configuration.",
      "scope": "Five operating points: 3 L/min @ 2400 RPM, 4 L/min @ 2600 RPM, 5 L/min @ 2800 RPM, 6 L/min @ 3000 RPM, 7 L/min @ 3200 RPM",
      "purpose": "Demonstrate that CFD-predicted hemolysis is sufficiently credible to substitute for in vitro hemolysis testing in the 510(k) submission for the Class III VAD device."
    }
  ],
