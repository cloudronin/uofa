    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver and hemolysis UDF must comply with ISO 62304 Class B and FDA software guidance; full regression test suite with documented pass/fail records required.",
      "rationale": "SQA audit confirmed version control and change control compliance. Regression test suite covers 87% of code paths; full 100% path coverage required at MRL 5 was not achieved. Achieved level 3 against required level 4."
    },
    {
