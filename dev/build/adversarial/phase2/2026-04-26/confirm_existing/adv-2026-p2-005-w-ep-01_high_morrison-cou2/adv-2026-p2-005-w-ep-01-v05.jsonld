  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cfd-hemolysis-absolute-prediction",
      "type": "Claim",
      "name": "CFD model predicts absolute hemolysis index within acceptable uncertainty bounds for VAD operating envelope",
      "description": "The CFD hemolysis model, employing the modified power-law damage accumulation formulation calibrated to the FDA generic centrifugal pump geometry, produces absolute Hemolysis Index (HI) predictions that remain below the clinical threshold of 0.8 g/dL across all five evaluated flow-speed operating points. Monte Carlo uncertainty quantification (n=2000 Latin hypercube samples) yields 95th-percentile HI predictions that do not exceed 0.65 g/dL, providing a margin of 0.15 g/dL against the clinical threshold. Mesh sensitivity analysis (three refinement levels, GCI < 3.2%) and iterative convergence monitoring confirm that numerical discretization errors contribute less than 4% to total HI uncertainty. The claim scope encompasses steady-state operating conditions at 3 L/min / 2400 RPM, 4 L/min / 2600 RPM, 4.5 L/min / 2800 RPM, 5 L/min / 3000 RPM, and 6 L/min / 3200 RPM.",
      "scope": "FDA generic centrifugal blood pump geometry; VAD operating envelope; absolute hemolysis index; MRL 5 credibility requirements",
      "purpose": "Support regulatory submission demonstrating that CFD-predicted hemolysis remains below absolute clinical threshold without reliance on predicate device comparison"
    },
    {
