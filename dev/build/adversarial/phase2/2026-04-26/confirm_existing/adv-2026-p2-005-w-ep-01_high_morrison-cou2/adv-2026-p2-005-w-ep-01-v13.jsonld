  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering hemolysis scalar transport; documented release notes.",
      "rationale": "ANSYS Fluent 2023R1 used under institutional license with version control. Regression suite covers core flow solvers but hemolysis UDF regression coverage is partial (63% branch coverage). Achieved level 3; required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent for Navier-Stokes and scalar transport; order-of-accuracy confirmation.",
      "rationale": "MMS verification performed for incompressible Navier-Stokes achieving 2nd-order spatial accuracy. Scalar transport UDF verified against analytical solution for simple Couette geometry but not for rotating impeller geometry. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
