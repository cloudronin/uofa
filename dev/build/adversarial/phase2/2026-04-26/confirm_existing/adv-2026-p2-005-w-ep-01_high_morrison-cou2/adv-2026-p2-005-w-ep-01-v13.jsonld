      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog fluid characterized for RBC fragility distribution; batch-to-batch variability documented; sample age and storage conditions controlled.",
      "rationale": "Bovine blood samples used without characterization of RBC fragility distribution or batch-to-batch variability. Sample age at time of experiment not consistently recorded across all 5 operating points. Test sample factor not assessable; epistemic gap. Achieved level 1."
    },
