      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "1024-sample Monte Carlo propagation of inlet flow waveform uncertainty, blood viscosity variability (±15%), and hemolysis model coefficient uncertainty. 95th-percentile NIH prediction: 0.61 g/dL/100 mL, below clinical threshold of 0.8 g/dL/100 mL. Sobol sensitivity indices indicate hemolysis coefficient C_alpha dominates (S_i = 0.58).",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/ev-04-monte-carlo-ensemble-results",
      "wasAttributedTo": "https://uofa.net/synth/org/morrison-cfd-lab"
    },
