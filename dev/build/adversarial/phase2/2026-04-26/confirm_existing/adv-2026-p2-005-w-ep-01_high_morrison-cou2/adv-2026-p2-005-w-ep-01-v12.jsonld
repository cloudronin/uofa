  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "claim": {
    "id": "https://uofa.net/synth/claim/vad-hemolysis-predictive-adequacy",
    "type": "Claim",
    "name": "CFD model is adequate to predict absolute hemolysis index for Class III VAD at MRL 5",
    "description": "The CFD hemolysis model, incorporating the modified power-law hemolysis correlation and Monte Carlo uncertainty quantification across five flow-speed operating points, produces absolute hemolysis index predictions that remain below the clinical acceptance threshold of 0.8 g/dL/100 mL with 95% confidence. The claim encompasses spatial mesh independence (GCI < 2%), temporal convergence, and turbulence model sensitivity assessed via k-omega SST and RSM variants. Scope is limited to the FDA generic centrifugal pump geometry operating between 2.5–6.0 L/min and 2500–4500 RPM. This claim is the primary credibility assertion upon which regulatory acceptance is predicated.",
    "scope": "FDA generic centrifugal pump, VAD operating envelope, absolute hemolysis index QoI",
    "purpose": "Establish that model predictions meet the absolute hemolysis threshold required for Class III 510(k) submission without predicate device comparison"
  },
