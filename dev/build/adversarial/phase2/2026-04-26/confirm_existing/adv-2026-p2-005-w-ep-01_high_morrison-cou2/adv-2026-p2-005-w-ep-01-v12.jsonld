  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps, the assessment team determined that the Monte Carlo UQ results (95th-percentile NIH = 0.61 g/dL/100 mL, below threshold of 0.8 g/dL/100 mL) and the conservative bias of the hemolysis model (+0.06 g/dL/100 mL overprediction) provide sufficient margin for regulatory submission. The central claim of hemolysis predictive adequacy is considered substantiated by the ensemble of validation results. Remaining gaps (equivalency of input parameters, test samples, use error) are acknowledged as areas for post-market surveillance. Formal decision: Accepted with conditions.",
