    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "claim": {
    "id": "https://uofa.net/synth/claim/vad-hemolysis-acceptable",
    "type": "Claim",
    "name": "CFD-predicted absolute hemolysis index is acceptably bounded for VAD use",
    "description": "The CFD model predicts a normalised index of haemolysis (NIH) below the clinical acceptance threshold of 0.01 g/100 L across all five evaluated flow-speed operating points. Monte Carlo uncertainty quantification (n=1000 Latin-hypercube samples) yields a 95th-percentile NIH of 0.0087 g/100 L, remaining below threshold with a margin of 13%. The claim encompasses steady-state and pulsatile operating modes at rotational speeds between 2400 rpm and 3200 rpm and flow rates between 3 L/min and 6 L/min. Scope is restricted to the FDA generic centrifugal pump geometry under VAD boundary conditions as defined in COU2.",
    "scope": "FDA generic centrifugal pump, VAD boundary conditions, MRL 5",
    "purpose": "Support regulatory submission demonstrating that the CFD model provides adequate predictive fidelity for absolute hemolysis under Class III device conditions"
  },
