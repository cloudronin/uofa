    "https://uofa.net/synth/data/monte-carlo-uncertainty-ensemble"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-below-threshold",
      "type": "Claim",
      "name": "CFD model predicts VAD hemolysis below absolute clinical threshold across all operating conditions",
      "description": "The CFD hemolysis model, applied to the FDA generic centrifugal blood pump operating as a VAD across five flow-speed combinations (3 L/min at 3500 RPM, 4 L/min at 3000 RPM, 4.5 L/min at 2800 RPM, 5 L/min at 2600 RPM, 6 L/min at 2400 RPM), predicts a normalised index of haemolysis (NIH) below 0.005 g/100 L at all operating points. Monte Carlo uncertainty quantification (n=500 Latin-hypercube samples) confirms that the 95th-percentile NIH remains below the clinical acceptance threshold with a margin of at least 18%. The claim scope is restricted to the geometry, boundary conditions, and turbulence closure (SST k-ω) validated against FDA PIV and bench haemolysis data.",
      "claimScope": "FDA generic centrifugal blood pump, VAD operating envelope, SST k-ω turbulence model, absolute NIH criterion",
      "claimPurpose": "Support regulatory submission demonstrating that the CFD model provides sufficient credibility evidence to accept predicted hemolysis levels without additional in-vivo testing at the five specified operating points."
    },
    {
      "id": "https://uofa.net/synth/evidence/piv-velocity-validation",
      "type": "Evidence",
      "name": "FDA pump PIV velocity field measurements",
      "description": "Particle image velocimetry measurements of the FDA generic centrifugal blood pump at 3500 RPM, 3 L/min. Velocity fields at five axial planes compared against CFD predictions. Mean absolute error 4.2%, maximum local error 11.8%.",
      "wasDerivedFrom": "https://doi.org/10.1115/1.4005436"
    },
    {
      "id": "https://uofa.net/synth/evidence/hemolysis-bench-data",
      "type": "Evidence",
      "name": "In-vitro hemolysis bench measurements for FDA pump",
      "description": "Bench haemolysis measurements (modified ASTM F1841) at five VAD operating points. NIH values range 0.0021–0.0048 g/100 L. Used as validation reference for CFD NIH predictions.",
      "wasDerivedFrom": "https://doi.org/10.1177/0391398819845668"
    },
    {
      "id": "https://uofa.net/synth/evidence/monte-carlo-report",
      "type": "Evidence",
      "name": "Monte Carlo uncertainty quantification ensemble results",
      "description": "500-sample Latin-hypercube Monte Carlo ensemble varying inlet velocity profile, blood viscosity (non-Newtonian Carreau parameters), and wall roughness. 95th-percentile NIH = 0.0041 g/100 L; threshold margin 18%. Convergence confirmed by bootstrap resampling.",
      "wasDerivedFrom": "https://doi.org/10.1016/j.jbiomech.2021.110642"
    }
  ],
