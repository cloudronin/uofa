  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and a documented V&V test suite covering hemolysis-relevant flow regimes.",
      "rationale": "The CFD solver holds ISO 9001 certification. However, the documented V&V test suite covers only 6 of 9 required hemolysis-relevant flow regimes; three rotating-stall scenarios remain untested. Achieved level 3 against required level 4."
    },
