    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset",
    "https://uofa.net/synth/data/fda-pump-hemolysis-nib-dataset",
    "https://uofa.net/synth/data/monte-carlo-uq-hemolysis-runs-n10000"
  ],
  "claim": {
    "id": "https://uofa.net/synth/claim/vad-hemolysis-model-adequacy",
    "type": "Claim",
    "name": "CFD hemolysis model is adequate for absolute hemolysis prediction in Class III VAD COU",
    "description": "The CFD model employing the modified power-law hemolysis index formulation (Giersiepen-Wurzinger coefficients recalibrated against NIH data) is adequate to predict absolute hemolysis index (IH) values within ±25% of experimental measurements across all five operating points (2 L/min–6 L/min, 2500–3500 RPM) specified in the COU. Adequacy is defined relative to the clinical hemolysis acceptance threshold of IH < 0.005 g/100 L. The claim scope is restricted to the FDA generic centrifugal pump geometry and the operating envelope defined in the COU; extrapolation to other geometries or flow regimes is explicitly excluded. Model Risk Level 5 applies.",
    "purpose": "Establish that the simulation model meets the credibility requirements necessary to support a regulatory submission decision regarding absolute hemolysis performance of the VAD device.",
    "scope": "FDA generic centrifugal blood pump; Class III VAD operating envelope; absolute hemolysis index prediction only"
  },
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
