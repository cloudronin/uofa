  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis model, while exhibiting achieved levels below required levels across seven of thirteen factors and six factors not assessed, provides sufficient evidence to support a conditional regulatory submission. The primary hemolysis claim is richly described and the ValidationResults carry full provenance chains to experimental evidence from the FDA benchmark and NIH datasets. Monte Carlo UQ confirms 95th-percentile hemolysis remains below the clinical threshold. Residual epistemic gaps at MRL 5 are acknowledged; the decision to accept reflects a risk-informed judgment that the assembled evidence package is adequate for the intended submission context under the Low assurance level designation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
