      "acceptanceCriteria": "NRMSE < 10% across all operating points",
      "outcome": "Pass",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/fda-piv-benchmark-velocity-data-2012",
      "wasDerivedFrom": "https://uofa.net/synth/evidence/fda-piv-benchmark-velocity-data-2012"
