  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and have documented V&V test suite covering turbulent rotating-frame flows.",
      "rationale": "ANSYS Fluent 2022R2 holds ISO 9001; rotating-frame turbulence test suite covers 8 of 11 required canonical cases. Three cases (swirling jet, rotating disk boundary layer, curvature-corrected k-ω) are not covered. Achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions must confirm at least second-order spatial convergence for all governing equations.",
      "rationale": "Manufactured solution tests confirm second-order convergence for continuity and momentum. The scalar hemolysis transport equation achieves only first-order convergence due to upwind-biased differencing in regions of high shear. Achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all QoIs; GCI < 5% required for hemolysis index.",
      "rationale": "Three-level mesh refinement study performed (7.2 M, 14.6 M, 29.3 M cells). GCI for velocity = 2.8%; GCI for NIH = 6.1%, exceeding the 5% target. Achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental conditions must match COU operating envelope within ±5% for all boundary conditions; blood analog fluid must match physiological viscosity within ±8%.",
      "rationale": "FDA pump PIV experiments used water at 22°C; blood analog viscosity differs from physiological blood by 18% at high shear. Operating points match COU envelope but fluid properties introduce systematic uncertainty not fully captured by Monte Carlo bounds. Achieved level 3 vs required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rms) must be reported with uncertainty bounds; systematic bias must be characterised and shown to be conservative.",
      "rationale": "NIH comparison shows mean over-prediction of +18% (conservative). However, E_rms is computed without accounting for inter-laboratory variability in bench measurements, which was ±22% in the FDA interlaboratory study. Bias characterisation is incomplete. Achieved level 3 vs required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validated QoIs must directly correspond to the clinical decision QoI (absolute NIH); surrogate QoIs are not acceptable at MRL 5.",
      "rationale": "NIH is the primary COU QoI and is directly validated. Velocity field is a secondary QoI used to build confidence in flow physics. No surrogate substitution. Achieved level 4 vs required level 5; gap remains in temporal resolution of NIH prediction.",
      "id": "https://uofa.net/synth/factor/relevance-qoi"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry and operating fluid as the COU; scale model or surrogate geometry validation is insufficient at MRL 5.",
      "rationale": "Validation uses the FDA generic pump geometry, which is a canonical benchmark but not the sponsor's proprietary VAD geometry. Geometric similarity is high (same impeller topology) but not identical. Fluid mismatch (water vs blood) further reduces relevance. Achieved level 3 vs required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to machine precision for steady-state simulations; residual drop of at least 6 orders of magnitude required.",
      "rationale": "Steady-state residuals drop 4 orders of magnitude; continuity residual stalls at 1e-4 due to impeller-volute interface imbalance in the mixing-plane formulation. Iterative convergence is not fully demonstrated. Achieved level 2 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be independently reviewed by a second analyst; boundary condition specification must be traceable to experimental records.",
      "rationale": "Independent review was performed for mesh generation and boundary conditions but not for the hemolysis model parameter selection (C and α coefficients in Giersiepen-Wurzinger). Parameter provenance is documented in a lab notebook not formally archived in the QMS. Achieved level 2 vs required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty for the hemolysis correlation must be quantified; alternative hemolysis models must be evaluated and shown to produce consistent predictions.",
      "rationale": "Only the Giersiepen-Wurzinger correlation is used. The Taskin and Arora correlations produce NIH estimates 40–60% lower at high-shear operating points. Model form uncertainty is acknowledged but not formally quantified. Achieved level 2 vs required level 5 — largest single credibility gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs must be traceable to calibrated measurements; probability distributions for uncertain inputs must be justified by experimental data.",
      "rationale": "Inlet velocity profile and rotational speed distributions are derived from calibrated measurements. Blood viscosity distribution is taken from published literature (Merrill 1969) rather than patient-specific data. Distribution tails may not represent the VAD patient population. Achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Hemolysis bench tests must use fresh human blood from at least 5 donors; bovine blood substitution requires demonstrated equivalence.",
      "rationale": "Bench hemolysis measurements used bovine blood. Equivalence to human blood for NIH measurement has not been demonstrated for this pump geometry. Factor flagged as epistemic gap; achieved level recorded as 2 (documentation only) vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in simulation must be demonstrated equivalent to those present in the clinical use environment; patient population variability must be addressed.",
      "rationale": "No patient-population input equivalency study has been performed. Inlet waveform used in simulation is a steady-state approximation; pulsatile VAD operation introduces time-varying shear histories not captured. Factor not assessed; achieved level 1 vs required level 5 — critical gap at MRL 5."
