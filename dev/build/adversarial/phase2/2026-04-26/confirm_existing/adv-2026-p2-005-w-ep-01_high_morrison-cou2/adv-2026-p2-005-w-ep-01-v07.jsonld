  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "claim": {
    "id": "https://uofa.net/synth/claim/cou2-model-adequacy",
    "type": "Claim",
    "name": "CFD hemolysis model is adequate for absolute hemolysis prediction under VAD operating conditions",
    "description": "The CFD model, employing the Giersiepen-Wurzinger power-law hemolysis correlation with Lagrangian particle tracking, is claimed to be adequate for predicting absolute normalized index of hemolysis (NIH) values for the FDA generic centrifugal blood pump across the five VAD operating points (2.5–5.0 L/min, 2500–3500 RPM). Adequacy is defined as model predictions falling within ±35% of bench-measured NIH values with 95% confidence after Monte Carlo propagation of inlet boundary condition and viscosity uncertainties. This claim is the primary credibility assertion underpinning the regulatory submission for the Class III VAD indication.",
    "purpose": "To assert that simulation results may serve as primary evidence of hemolysis safety in lieu of exhaustive in vivo testing, subject to the uncertainty bounds established by the Monte Carlo UQ campaign.",
    "scope": "Applicable to the five COU operating points only; extrapolation beyond the validated flow-speed envelope is explicitly excluded."
  },
