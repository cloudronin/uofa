  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "claim": {
    "id": "https://uofa.net/synth/claim/vad-hemolysis-below-clinical-threshold",
    "type": "Claim",
    "name": "CFD model predicts VAD hemolysis index below the absolute clinical threshold across all five operating conditions",
    "description": "The CFD hemolysis model, applied to the FDA generic centrifugal blood pump under five representative VAD flow-speed combinations (4 L/min at 2400 RPM, 5 L/min at 2600 RPM, 6 L/min at 2800 RPM, 4 L/min at 3000 RPM, and 6 L/min at 3200 RPM), predicts a normalized index of hemolysis (NIH) below 0.005 g/100 L for all conditions. Monte Carlo uncertainty quantification (n=500 Latin hypercube samples) confirms that the 95th-percentile NIH envelope remains below the clinical acceptance threshold of 0.01 g/100 L. The claim scope is limited to the operating envelope and geometry described in the COU; extrapolation to other pump geometries or patient populations is not asserted.",
    "purpose": "Provide the primary credibility assertion that the CFD hemolysis model output is fit for regulatory submission in support of Class III VAD premarket approval.",
    "scope": "FDA generic centrifugal blood pump geometry; VAD operating envelope; absolute hemolysis prediction; Monte Carlo UQ coverage"
  },
