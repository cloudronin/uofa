  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the full 13-factor evaluation. Seven factors were assessed; all show achieved levels below required levels, reflecting the high demands of MRL 5. Six factors carry epistemic gaps. Despite these gaps, the Monte Carlo UQ results demonstrate a 22% margin below the clinical NIH threshold at the 95th percentile, and the validation results for velocity and NIH QoIs are within acceptable bounds for the assessed factors. The central claim that the model predicts hemolysis below the absolute clinical threshold is supported by the surrounding validation evidence chain. The package is accepted for regulatory submission with the documented limitations noted as areas requiring future work prior to any expanded COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
