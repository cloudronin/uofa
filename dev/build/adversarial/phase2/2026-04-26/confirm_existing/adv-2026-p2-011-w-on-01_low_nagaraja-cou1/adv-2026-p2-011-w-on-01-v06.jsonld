  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "The FEA software (Ansys Mechanical) is a commercially validated solver with documented QA procedures including regression testing and version-controlled release notes. All three modelling teams used the same solver version, and deviation reports were filed for any non-default settings. Achieved Gradation 3 exceeds the required Gradation 2 for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including a cantilever beam under end load and a thick-walled cylinder under internal pressure were solved and compared against analytical solutions. Errors were below 0.5%, confirming correct code implementation for the linear-elastic regime relevant to this model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "A three-level mesh convergence study was performed on the screw-rod assembly. The Richardson extrapolation-based Grid Convergence Index for peak von Mises stress at the screw-rod interface was 1.8%, below the 5% threshold. The final mesh density was selected at the intermediate level where further refinement changed QoI by less than 2%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "A direct sparse solver (SPARSE) was used for all linear static analyses. Residual norms were monitored and remained below 1e-8 for all load steps. No iterative solver was employed, so round-off and convergence errors are negligible."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup was performed by two independent analysts following a documented simulation protocol. A peer-review checklist covering boundary conditions, material assignments, and contact definitions was completed and signed off prior to result extraction. No user-error deviations were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear-elastic continuum mechanics with frictional contact at the screw-rod and rod-block interfaces. Geometric non-linearity was included to capture large-displacement effects under the 200 N·m bending moment. The model form is well-established for metallic spinal implants in the quasi-static regime covered by F1717."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (Ti-6Al-4V: E=114 GPa, ν=0.34; UHMWPE block: E=1 GPa) were sourced from ASTM standards and confirmed by coupon testing. Screw and rod geometries were digitised from CMM measurements of the actual test articles. Friction coefficients were derived from pin-on-disk tribometry at the relevant contact pairs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 physical constructs were tested across two independent laboratories. All specimens were from the same commercial lot, and dimensional inspection confirmed conformance to design tolerances within ±0.05 mm. Inter-laboratory variability in stiffness was below 6% CV, supporting pooling of results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing was performed at a single load level (compression-bending at 200 N axial pre-load) per the F1717 protocol. The required level of 3 demands at least two distinct test conditions; only one was available. This factor does not meet the required level and represents a known gap in the validation evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions replicate the F1717 fixture geometry: fixed inferior block, 200 N axial compressive pre-load applied through a spherical seat, and displacement-controlled bending applied at the superior crosshead. All dimensional and loading inputs were mapped directly from laboratory measurement records to simulation inputs with full traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness (N/mm) and yield load (N) were compared using the U95 metric. FEA predictions fell within the experimental 95% confidence interval for 10 of 11 specimens for stiffness and for all 11 specimens for yield load. Mean absolute percentage error was 4.2% for stiffness and 3.7% for yield load."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The quantities of interest — construct stiffness and yield load under compression-bending — are the primary regulatory endpoints for spinal fixation system submissions under FDA guidance. These QoIs directly govern the safety and performance claim being evaluated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The validation activity replicates the ASTM F1717 test configuration that is the direct regulatory surrogate for in vivo spinal loading. The screw geometry, material, and loading mode are identical to those in the submission. Validation evidence is therefore directly relevant to the intended regulatory use of the model."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall in Test conditions (achieved Gradation 2 vs. required Gradation 3) was reviewed by the team and deemed acceptable given the prescriptive single-condition structure of ASTM F1717 and the high performance on all other factors. Overall credibility is sufficient to support a Medium model risk classification and the associated regulatory submission.",
