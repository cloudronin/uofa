  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nagaraja-f1717-compression-bending-result-001",
      "type": "ValidationResult",
      "name": "F1717 compression-bending stiffness and yield load comparison — FEA vs. N=11 experimental constructs"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1016/j.jbiomech.2019.109541",
  "wasAttributedTo": "https://uofa.net/synth/org/nagaraja-fda-cdrh-osel",
