    {
      "id": "https://uofa.net/synth/validation/nagaraja-f1717-vr-01",
      "type": "ValidationResult",
      "name": "F1717 compression-bending FEA vs. experiment comparison — N=11 constructs, two laboratories"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1016/j.jbiomech.2020.109797",
