  "signature": "ed25519:1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "All three FEA codes (FDA in-house, Ansys, DePuy Synthes) operate under documented SQA plans with version control, regression testing, and audit trails. Achieved level exceeds the required threshold for a Model Risk Level 3 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Code verification benchmarks for linear static structural analysis were executed against NAFEMS reference solutions. All three codes passed within accepted tolerances, supporting confidence in correct implementation of governing equations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed on the pedicle screw-rod construct model; peak von Mises stress and construct stiffness quantities of interest changed by less than 2% between medium and fine mesh densities, confirming adequate spatial discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear direct solvers employed; residual norms reported below 1e-8 for all load steps. Contact convergence monitored at screw-rod interfaces. No solver divergence observed across the ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation inputs were independently reviewed by a second analyst at each participating organization. Boundary condition application, material assignment, and load magnitude were verified against the F1717 test protocol prior to execution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Linear elastic isotropic material models applied to titanium alloy components. Contact interactions modeled at screw-rod interface using penalty formulation. Model form assumptions are consistent with the quasi-static loading regime of F1717 and supported by prior literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties sourced from certified material test reports for the specific Ti-6Al-4V lot used in physical constructs. Geometric dimensions measured via CMM on representative hardware and used to parameterize CAD. Input uncertainty quantified via sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 physical constructs assembled from production-representative hardware tested across two independent laboratories. Sample size consistent with F1717 guidance. Inter-laboratory variability in stiffness below 5% CV."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing conducted at a single compressive load level (1500 N) per F1717 protocol. The absence of multiple load conditions or fatigue loading scenarios reduces confidence in model predictive capability across the broader load envelope. This factor is below the required level and constitutes a known gap in the validation evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation input parameters (geometry, material, boundary conditions, loads) were mapped directly to measured experimental quantities. A formal input equivalency matrix was prepared and reviewed, confirming high fidelity correspondence between physical test and computational model configurations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and peak displacement compared between FEA ensemble and experimental results using normalized RMS error metric. All three FEA codes predicted stiffness within 8% of experimental mean. Bland-Altman analysis confirmed no systematic bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantities of interest (construct stiffness, peak displacement under 1500 N compression-bending) are directly specified in the regulatory submission requirements and are the primary outputs used in the credibility claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities replicate the ASTM F1717 test configuration which is the defined use context for this assessment. Hardware, loading mode, and measurement quantities are aligned with the submission context. Single test condition limits broader relevance coverage."
    }
  ],
