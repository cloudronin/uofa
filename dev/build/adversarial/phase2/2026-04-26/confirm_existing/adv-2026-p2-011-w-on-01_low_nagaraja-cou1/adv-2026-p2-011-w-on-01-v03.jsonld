      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Commercial FEA solvers (Ansys) used by all three modelling teams carry ISO 9001-certified QMS documentation and vendor-supplied verification test suites. Internal FDA OSEL software quality procedures also applied. Required and achieved levels are equal at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from the Ansys verification manual were executed and results compared to analytical solutions. All residuals within accepted tolerances. Code verification documented in each team's modelling report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence studies performed by all three teams using at least three mesh densities. Richardson extrapolation applied; discretization error estimated at less than 2% for peak von Mises stress at screw-rod interface. Achieved Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver convergence criteria set to residual below 1e-6 for all runs. Force and displacement equilibrium checked post-solution. No divergence events recorded across the ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Independent peer review of model setup performed within each team. Boundary condition application and material assignment verified against a common modelling protocol distributed to all three teams prior to analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic constitutive model adopted for titanium alloy components consistent with published material behaviour at sub-yield loading. Contact interactions at screw-rod interface modelled with penalty-based friction. Model form uncertainty assessed as low for the quasi-static load regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties sourced from ASTM F136 certificates for Ti-6Al-4V ELI. Geometric dimensions measured from physical specimens using CMM with traceable calibration. Input uncertainty propagated via Latin hypercube sampling across the ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. Specimens from same production lot; dimensional inspection confirmed within drawing tolerances. Sample size sufficient for statistical comparison at the required credibility level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed at a single load level and single offset distance per ASTM F1717. Variation of test conditions (e.g. multiple offset distances or load rates) was not included in the study, limiting the achieved level to Gradation 2 against a required Gradation 3. This deficiency is noted as an accepted gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions replicate the F1717 test fixture geometry and loading arm offset. Fixture compliance characterised experimentally and incorporated into the model. Input parameter equivalency confirmed by overlay of load-displacement curves prior to blind prediction submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantitative comparison performed using ASME V&V 20 area validation metric. FEA ensemble predictions fall within experimental scatter band for construct stiffness and peak load at failure. Mean absolute error 4.1%; all predictions within two experimental standard deviations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantities of interest — construct stiffness (N/mm) and peak bending moment at failure (N·m) — are the primary regulatory endpoints for spinal implant mechanical performance per FDA guidance. Direct mapping between simulation output and test measurement confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities replicate the ASTM F1717 protocol that constitutes the regulatory submission test. Geometry, material, loading mode, and measurement endpoints are consistent with the intended submission context. Relevance assessed as high."
    }
