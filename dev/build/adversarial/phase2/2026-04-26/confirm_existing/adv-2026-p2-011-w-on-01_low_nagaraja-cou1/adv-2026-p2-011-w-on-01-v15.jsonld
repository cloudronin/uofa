      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed across three refinement levels; peak von Mises stress in the screw neck changes by less than 2% between medium and fine meshes. Final mesh selected at medium refinement with documented GCI < 3%."
