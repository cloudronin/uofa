      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The FEA software (Ansys) is commercially validated and used under controlled SOPs at FDA and DePuy Synthes. Version control and regression testing records are available for all simulation runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from NAFEMS and internal patch tests confirm correct implementation of linear hexahedral and tetrahedral element formulations used in the pedicle screw model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed with three refinement levels; peak von Mises stress at the screw-rod interface converged to within 2% between the medium and fine meshes. The fine mesh was adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Direct sparse solver employed; residual norms confirmed below 1e-8 for all load steps. No convergence failures observed across the ensemble of 11 constructs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation inputs and boundary conditions reviewed by a second analyst at each participating organization. Documented checklists used to prevent misapplication of loads and material assignments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic continuum mechanics with frictional contact at screw-rod and screw-block interfaces. Model form is well-established for metallic spinal implant constructs under quasi-static loading."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Ti-6Al-4V and UHMWPE material properties sourced from ASTM standards and supplier certificates. Geometry derived from calibrated CMM measurements of production hardware. Friction coefficients from published tribology literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 production-representative constructs from two independent laboratories. Dimensional inspection confirmed constructs fall within design tolerances. Sample size sufficient for statistical comparison at the Medium model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed under a single load condition (compression-bending at 5 Nm moment arm) per ASTM F1717. Variation in loading angle or axial pre-load not explored, limiting coverage of the loading envelope. This factor is below the required level and is flagged as a gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions mapped directly from experimental fixture geometry and load cell measurements. Torque preloads on set screws replicated via bolt-pretension elements consistent with measured torque values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and peak load at 1 mm displacement compared using validation metric (E_rel). All ensemble predictions fall within the 95% confidence interval of experimental measurements across both laboratories."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and load-displacement response are the regulatory quantities of interest for ASTM F1717 submissions. These QoIs are directly predicted by the FEA model and directly measured in the experimental protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
