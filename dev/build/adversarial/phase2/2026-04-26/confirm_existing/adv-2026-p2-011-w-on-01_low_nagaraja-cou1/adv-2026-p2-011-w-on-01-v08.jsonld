      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Analysis conducted by experienced FEA engineers with documented training records. Independent peer review of model setup, boundary conditions, and material assignments performed prior to submission."
