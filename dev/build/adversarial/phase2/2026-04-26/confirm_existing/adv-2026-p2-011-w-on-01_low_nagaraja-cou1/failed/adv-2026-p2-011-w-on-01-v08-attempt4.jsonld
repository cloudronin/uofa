      "acceptanceCriteria": "Solver version control, regression testing, and documented QA procedures in place for all three FEA codes.",
      "rationale": "FDA, Ansys, and DePuy Synthes FEA codes each maintain formal version control and regression test suites consistent with Gradation 2 requirements. QA documentation reviewed and confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks against known analytical solutions documented for each solver.",
      "rationale": "Each of the three FEA codes has been verified against standard benchmark problems (patch tests, cantilever beam) confirming correct implementation of constitutive and element formulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study performed; discretization error quantified and within acceptable bounds for QOI.",
      "rationale": "Mesh convergence studies conducted across three refinement levels. Peak construct stiffness QOI changed by less than 2% between the two finest meshes, confirming adequate spatial discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver convergence criteria documented; residual tolerances meet or exceed standard thresholds.",
      "rationale": "Force and displacement residuals converged to 1e-6 relative tolerance in all load steps. No solution divergence observed across the N=11 construct simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup procedures documented; independent analyst review performed.",
      "rationale": "Model setup and boundary condition application procedures are documented in a controlled SOP. An independent analyst reviewed all three model configurations and confirmed consistency with the ASTM F1717 test protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection justified; simplifying assumptions documented and their impact assessed.",
      "rationale": "Linear elastic material models applied to titanium alloy components; nonlinear contact formulation used at screw-rod interface. Justification for linear elasticity confirmed by strain gauge measurements showing sub-yield strains throughout testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs sourced from traceable measurements; uncertainty quantified.",
      "rationale": "Titanium alloy elastic modulus and Poisson ratio taken from ASTM B265 coupon tests. Screw geometry digitized from CT scans with dimensional uncertainty less than 0.05 mm. Input uncertainty propagated via sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs provide adequate statistical basis; sample traceability documented.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. Lot traceability and dimensional inspection records available for all samples."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple test conditions spanning the clinical use envelope evaluated.",
      "rationale": "Testing performed at a single load configuration per ASTM F1717. Only one bending moment level assessed; variability in clinical loading conditions not captured. This factor is below the required level and represents a known gap in the validation evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs demonstrably equivalent to experimental specimen parameters.",
      "rationale": "CT-derived geometry and measured material properties used directly in FEA models. Cross-laboratory comparison confirmed consistent specimen dimensions and material lots. Input equivalency formally documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics applied; agreement within pre-specified tolerance bands.",
      "rationale": "Construct stiffness and peak load predictions from all three FEA codes fall within 10% of experimental means. Bland-Altman analysis confirms no systematic bias. Pre-specified acceptance criterion of 15% met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs directly linked to the regulatory submission claim.",
      "rationale": "Construct stiffness and peak bending load are the primary QOIs specified in the regulatory submission. Both are directly measurable in ASTM F1717 testing and directly predicted by the FEA ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario sufficiently similar to intended use scenario to support credibility claim.",
      "rationale": "ASTM F1717 compression-bending protocol closely replicates the biomechanical loading environment of the intended spinal fixation application. Geometric and material fidelity of validation specimens confirmed relative to production devices."
    }
