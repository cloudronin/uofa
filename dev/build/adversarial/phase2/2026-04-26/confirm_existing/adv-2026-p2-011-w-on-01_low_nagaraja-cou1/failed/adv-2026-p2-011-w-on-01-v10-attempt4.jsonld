      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested; samples drawn from production lots with full traceability. Inter-laboratory comparison between two independent test facilities confirms reproducibility of experimental data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed under single ASTM F1717 standard compression-bending configuration only; alternative load levels and orientations not evaluated. This factor falls below required level; accepted as tolerable given conservative nature of standard test configuration relative to physiological loading envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
