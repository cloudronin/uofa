      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Ansys Mechanical R2023 used with validated installation qualification records; version-controlled input decks maintained in FDA CDRH repository. Software QA procedures documented per 21 CFR Part 11 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from ASME V&V 10 suite executed; patch test and single-element tests passed. Solver convergence verified against analytical cantilever beam solutions with <0.5% error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed with three refinement levels; GCI computed per Celik et al. 2008. Peak von Mises stress convergence within 2.1% between medium and fine meshes. Final mesh density selected based on convergence plateau."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Newton-Raphson iterative solver residuals monitored; force and displacement residuals below 1e-5 tolerance. Nonlinear contact stabilization energy tracked and confirmed negligible (<0.1% of total strain energy)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Independent analyst review of FEA setup performed by second engineer not involved in model construction. Checklist-based QC process applied; boundary condition assignments and material property inputs verified against source documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic continuum mechanics model applied; titanium alloy Ti-6Al-4V material response confirmed within linear range for ASTM F1717 load levels. Contact formulation (augmented Lagrange) appropriate for screw-rod interface representation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties sourced from certified material test reports for each implant lot. Geometric dimensions measured via CMM on representative samples; nominal vs. measured dimensions compared with <1% deviation."
    },
    {
