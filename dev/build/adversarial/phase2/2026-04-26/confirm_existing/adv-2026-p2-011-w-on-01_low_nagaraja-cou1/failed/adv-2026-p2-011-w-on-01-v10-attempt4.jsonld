      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 fixture constraints; applied displacement ramp matched experimental crosshead displacement rate. Screw insertion torque and rod pre-tension translated to equivalent contact interface preloads in simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Predicted construct stiffness and failure load compared against experimental measurements using Bayesian model validation metric. Mean prediction error 4.3% for stiffness and 6.1% for failure load across N=11 constructs; both within pre-specified 15% acceptance band."
    },
