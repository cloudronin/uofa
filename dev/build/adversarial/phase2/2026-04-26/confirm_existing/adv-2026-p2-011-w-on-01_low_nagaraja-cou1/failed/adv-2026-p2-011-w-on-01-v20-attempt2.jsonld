  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA solver must hold ISO 9001 certification or equivalent; version control and audit trail required.",
      "rationale": "Ansys Mechanical R2022 R2 used under validated installation with documented version control. FDA in-house solver independently verified. ISO 9001-compliant QMS confirmed for all three modeling teams."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification against analytical benchmarks for linear elastic structural problems required.",
      "rationale": "All three FEA codes verified against NAFEMS benchmark suite LE1 and LE10. Patch-test convergence confirmed. No code defects identified relevant to this analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study required; discretization error must be below 5% for quantities of interest.",
      "rationale": "Mesh convergence study performed with three mesh densities (coarse, medium, fine). Maximum discretization error in peak von Mises stress at screw-rod interface was 2.8%, within the 5% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6; nonlinear convergence criteria documented.",
      "rationale": "All simulations converged with force and displacement residuals below 1e-7. Contact iterations monitored; no spurious penetration detected. Solver logs archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of model setup by a second analyst.",
      "rationale": "Model setup reviewed independently by a second FEA analyst at each of the three institutions. Boundary conditions, material assignments, and contact definitions verified against protocol prior to execution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model must capture linear elastic behavior of titanium alloy implant components; contact formulation must represent screw-rod interface mechanics.",
      "rationale": "Ti-6Al-4V modeled as linear elastic (E=114 GPa, nu=0.34) consistent with ASTM F136. Frictional contact (mu=0.2) applied at screw-rod and rod-block interfaces. Model form appropriate for quasi-static compression-bending at the F1717 load range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured specimen data or certified material specifications.",
      "rationale": "Geometry derived from CMM measurements of production screws (n=5 specimens per lot). Material properties from certified mill test reports. Torque applied to polyaxial screw heads measured with calibrated torque wrench and replicated in FEA via pretension elements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum N=10 experimental constructs; specimens from production lots with documented traceability.",
      "rationale": "N=11 constructs tested across two independent laboratories. All specimens from the same production lot with full dimensional and material traceability. Inter-laboratory repeatability confirmed (CV < 4% for stiffness)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant load magnitudes; minimum two load levels required.",
      "rationale": "Testing performed at a single load level (150 N axial compressive load per ASTM F1717). Clinical load range was not fully explored. This factor does not meet the required level; accepted as a known limitation of the F1717 standard protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading must match experimental setup within documented tolerances.",
      "rationale": "Actuator displacement, block spacing, and rod length replicated in FEA within 0.1 mm of measured experimental values. Torque preload replicated within 2% using pretension elements. Equivalency confirmed by pre-test protocol review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric or E-value) required; agreement within 10% for primary QoI.",
      "rationale": "Construct stiffness (primary QoI) predicted within 6.2% of experimental mean across all three FEA codes. ASME V&V 20 validation metric computed; FEA ensemble within experimental uncertainty band for 10 of 11 specimens."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be mechanistically linked to the clinical or regulatory question being addressed.",
      "rationale": "Construct stiffness and screw-rod interface stress are the primary QoIs. Both are directly linked to the structural performance claims submitted in the 510(k). Stiffness is a standard F1717 output; stress informs fatigue life estimation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario must reflect the geometry, loading, and boundary conditions of the intended regulatory submission.",
      "rationale": "Validation performed on the exact production geometry and lot submitted for 510(k) clearance. F1717 protocol directly mirrors the regulatory test standard. Validation scenario is maximally relevant to the submission context."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is attributable to the single-load-level constraint of ASTM F1717 and is accepted given the regulatory context. Overall credibility is sufficient for Medium model risk level.",
