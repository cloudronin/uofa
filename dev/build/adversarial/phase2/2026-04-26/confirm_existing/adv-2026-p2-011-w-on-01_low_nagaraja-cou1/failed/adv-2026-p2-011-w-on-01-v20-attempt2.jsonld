      "name": "F1717 compression-bending FEA vs. experimental comparison (N=11)"
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-result-002",
      "type": "ValidationResult",
      "name": "Cross-laboratory reproducibility check (Lab A vs. Lab B)"
    }
  ],
