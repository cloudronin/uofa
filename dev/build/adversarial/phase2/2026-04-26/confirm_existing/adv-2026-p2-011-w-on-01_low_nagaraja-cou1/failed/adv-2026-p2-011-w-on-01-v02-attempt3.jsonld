      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver residuals monitored to tolerance 1e-6 for all load steps. Energy balance checks confirm no significant numerical dissipation across the nonlinear solution sequence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Independent peer review of model setup, boundary condition application, and post-processing scripts conducted by a second analyst at each participating institution. Discrepancies resolved prior to result submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic titanium alloy material model with frictional contact at screw-rod interface. Constitutive assumptions validated against published Ti-6Al-4V coupon data. Contact formulation captures load transfer consistent with physical test observations."
    },
