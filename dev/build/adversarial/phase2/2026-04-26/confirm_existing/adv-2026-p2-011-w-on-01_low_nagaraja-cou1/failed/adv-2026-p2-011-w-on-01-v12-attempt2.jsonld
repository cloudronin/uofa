  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for model risk level 3. The single shortfall in Test conditions (achieved 2, required 3) is acknowledged; the assessment team determined that the single-condition ASTM F1717 protocol is the regulatory standard and no additional load configurations are available in the literature for this construct geometry. Overall credibility is judged sufficient to support regulatory submission at Medium assurance level.",
