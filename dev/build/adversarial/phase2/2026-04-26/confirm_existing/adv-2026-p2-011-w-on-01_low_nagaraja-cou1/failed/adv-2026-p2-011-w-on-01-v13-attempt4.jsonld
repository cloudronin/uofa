      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must be directly linked to the regulatory submission claim.",
      "rationale": "Construct stiffness and yield load under ASTM F1717 compression-bending are the primary mechanical performance endpoints cited in the 510(k) predicate comparison. These quantities are directly relevant to the regulatory claim being supported."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
