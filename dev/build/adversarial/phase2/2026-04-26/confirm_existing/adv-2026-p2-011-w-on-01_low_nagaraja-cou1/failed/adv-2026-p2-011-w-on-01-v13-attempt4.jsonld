      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of underlying mathematical models.",
      "rationale": "Benchmark problems including linear elastic patch tests and analytic beam solutions were executed for each code in the ensemble. Results matched analytic solutions within numerical precision tolerances, satisfying gradation 3 code verification requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate discretization error below 5% for quantities of interest.",
      "rationale": "Systematic mesh refinement studies were performed on representative screw-rod constructs. Construct stiffness and peak von Mises stress converged to within 2.8% across three mesh densities, meeting gradation 3 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals and energy balance errors must be documented and within acceptable tolerances.",
      "rationale": "Iterative solver residuals were monitored across all load steps. Force and moment equilibrium residuals remained below 0.1% throughout all analyses, exceeding the gradation 2 requirement."
    },
