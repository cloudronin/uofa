      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Ansys Mechanical R2023 is a commercially validated solver with documented QA procedures including regression test suites and release validation reports. Software version control and change logs were reviewed and confirmed compliant with required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including patch tests and manufactured solution comparisons were executed. Results confirmed solver accuracy within accepted tolerances for linear static structural analysis applicable to the pedicle screw construct."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed on construct stiffness and peak von Mises stress. Three refinement levels evaluated; final mesh selected at less than 3% change in QoI between refinement levels, satisfying required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Direct sparse solver employed with double-precision arithmetic. Residual norms monitored at each load step; all converged below 1e-6 relative tolerance. No iterative solver divergence observed across all 11 model instances."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup independently reviewed by a second analyst. Boundary conditions, material assignments, and contact definitions were verified against the analysis plan. No discrepancies identified during cross-check."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic continuum mechanics with contact formulation selected. Justification documented based on expected strain regime (less than 0.5%) and prior literature confirming adequacy of linear elastic assumption for titanium spinal implants under ASTM F1717 loading conditions."
