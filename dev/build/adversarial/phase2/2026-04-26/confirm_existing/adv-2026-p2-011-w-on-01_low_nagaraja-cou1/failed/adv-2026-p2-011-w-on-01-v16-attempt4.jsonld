    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested. Samples drawn from production lots with documented traceability. Sample size sufficient to characterize inter-specimen variability for the quantities of interest under ASTM F1717 protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed at a single load level and single environmental condition (ambient, dry) per ASTM F1717. Only one test condition evaluated; multi-condition coverage required for level 3 was not achieved. This factor is below the required level and represents an identified credibility gap."
    },
