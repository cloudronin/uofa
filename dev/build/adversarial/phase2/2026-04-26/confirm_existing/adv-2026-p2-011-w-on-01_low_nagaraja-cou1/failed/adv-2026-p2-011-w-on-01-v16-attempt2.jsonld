  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "All three FEA codes (FDA in-house, Ansys, DePuy Synthes) operate under documented quality management systems with version control, regression testing, and change-control procedures consistent with ISO 9001 and 21 CFR Part 820. Achieved level exceeds required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from ASME V&V 10 and solver vendor verification suites were executed. All three codes reproduced analytic solutions for linear elasticity beam bending within 0.5% relative error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed on pedicle screw shank and rod interface regions. Peak von Mises stress changed less than 2% between medium and fine meshes; medium mesh adopted for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Direct sparse solvers used; residual norms confirmed below 1e-8. No iterative convergence issues observed across all 11 construct simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Independent analyst review conducted for each of the three FEA codes. Boundary conditions, material assignments, and load application reviewed against documented simulation protocols prior to result extraction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic isotropic constitutive model adopted for titanium alloy components. Literature supports this assumption for sub-yield loading in ASTM F1717 compression-bending. Contact at screw-rod interface modeled with friction coefficient from tribology literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties sourced from manufacturer certificates of conformance and ASTM F136 reference values. Geometry derived from calibrated CMM measurements of production hardware. Torque preload on set screws measured and applied as pretension elements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 production pedicle screw constructs tested across two independent laboratories. Samples drawn from the same production lot as the simulated geometry; dimensional inspection confirmed conformance to drawing tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed at a single load magnitude and single load ratio per ASTM F1717 protocol. Variation in test conditions (e.g., multiple load levels, temperature) was not explored, resulting in achieved level below required. This gap is acknowledged as a limitation of the current validation campaign."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA model inputs (geometry, material properties, boundary conditions, torque preload) mapped one-to-one with experimentally measured or controlled quantities. Traceability matrix documented for all 14 input parameters."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Predicted construct stiffness and peak load at 1% offset yield compared against experimental means. All three FEA codes predicted stiffness within ±8% of experimental mean; load prediction within ±10%. Statistical comparison using two-sided t-test confirmed no significant bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantities of interest (construct stiffness, yield load) are directly linked to the regulatory submission metrics specified in the 510(k) predicate comparison. Clinical relevance of these mechanical endpoints established via literature review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities replicate the exact test configuration (ASTM F1717 compression-bending, non-cannulated 7.5 mm screw, 35 mm interbody distance) specified for regulatory submission. No extrapolation beyond tested configuration required for the credibility claim."
    }
