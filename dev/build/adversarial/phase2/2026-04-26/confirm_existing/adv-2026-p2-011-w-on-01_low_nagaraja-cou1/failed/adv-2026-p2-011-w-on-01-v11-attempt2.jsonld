      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from ASME V&V 10 were used to verify solver implementation. Patch test and simple beam bending cases confirmed correct element behavior."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed with three successive refinements. Global strain energy and peak von Mises stress at screw-rod interface converged to within 2% between the two finest meshes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
