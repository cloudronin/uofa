      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver residuals monitored and confirmed below 1e-6 for all load steps. No divergence or ill-conditioning observed across the ensemble runs."
    },
    {
      "type": "CredibilityFactor",
