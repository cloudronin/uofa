      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must replicate the geometry, loading, and boundary conditions representative of the intended simulation use.",
      "rationale": "Validation experiments replicate the ASTM F1717 fixture geometry and loading protocol used in the regulatory simulation. Construct geometry and material are identical to those modeled."
