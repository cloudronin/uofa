      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions must be traceable to measured values with uncertainty bounds reported.",
      "rationale": "Elastic modulus and yield strength for Ti-6Al-4V sourced from coupon tensile tests (mean ± 1 SD reported). Screw geometry digitized from micro-CT with dimensional tolerance of ±0.02 mm."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum N=10 experimental specimens from production lots with documented dimensional inspection.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from two production lots were tested. Dimensional inspection confirmed all specimens within drawing tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing must cover at least two clinically relevant load magnitudes or configurations to bound the operating envelope.",
      "rationale": "Only a single load condition (compression-bending at 10° offset per ASTM F1717) was evaluated. A second load configuration was not included, leaving the operating envelope partially bounded. This factor is below the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs must be demonstrably equivalent to experimental conditions within stated uncertainty.",
      "rationale": "Applied displacement boundary conditions in FEA matched crosshead displacement profiles from test machine data. Block geometry in FEA reproduced from UHMWPE block dimensional measurements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted construct stiffness and yield load must agree with experimental mean within 10% and fall within experimental 95% confidence interval.",
      "rationale": "FEA ensemble predicted stiffness within 6.3% of experimental mean; predicted yield load within 8.1%. Both quantities fell within the experimental 95% CI across all three FEA implementations."
    },
