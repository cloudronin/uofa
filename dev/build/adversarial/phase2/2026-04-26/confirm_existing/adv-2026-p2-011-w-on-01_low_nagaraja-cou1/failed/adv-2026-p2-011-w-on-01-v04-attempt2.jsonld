      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against benchmark problems with documented pass/fail criteria.",
      "rationale": "Ansys benchmark suite for structural mechanics was executed; all relevant benchmark cases passed within vendor-specified tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate less than 5% change in peak von Mises stress between successive mesh refinements.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw construct. Peak stress change between medium and fine mesh was 2.1%, satisfying the convergence criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals must fall below 1e-6 for all load steps; energy balance error must be below 0.1%.",
      "rationale": "All nonlinear load steps converged with force residuals below 1e-7. Energy balance error remained below 0.05% across all simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented analyst training and independent review of model setup must be on record.",
      "rationale": "Two senior analysts independently reviewed boundary conditions, material assignments, and contact definitions. Discrepancies were resolved prior to final simulation runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model and contact formulation must be justified by published literature for cortical bone and titanium alloy under quasi-static loading.",
      "rationale": "Linear elastic isotropic material for Ti-6Al-4V and UHMWPE block is well-supported by literature for quasi-static F1717 conditions. Frictional contact with mu=0.2 is consistent with published screw-block interface data."
    },
    {
      "type": "CredibilityFactor",
