      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation inputs reviewed independently by a second analyst. Boundary conditions, material assignments, and contact definitions verified against the analysis plan prior to execution."
