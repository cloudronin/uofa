      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed with three successive refinements; reported QOI (construct stiffness, failure load) changed less than 2% between the two finest meshes, confirming discretization error is within acceptable bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
