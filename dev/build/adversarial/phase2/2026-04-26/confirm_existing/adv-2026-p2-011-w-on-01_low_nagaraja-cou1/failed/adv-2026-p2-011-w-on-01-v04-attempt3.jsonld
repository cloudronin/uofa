      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Direct sparse solver used; residual norms monitored and confirmed below 1e-8 for all load steps. No iterative solver convergence issues observed across the ensemble."
    },
    {
