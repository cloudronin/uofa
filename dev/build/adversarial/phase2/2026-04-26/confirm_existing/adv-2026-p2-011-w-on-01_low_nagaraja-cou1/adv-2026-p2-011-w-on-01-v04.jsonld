      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level; QoIs must be directly linked to the regulatory submission metric.",
      "rationale": "The quantities of interest — construct stiffness and yield load — are the primary performance metrics specified in ASTM F1717 and cited in the 510(k) substantial equivalence argument. Their relevance to the regulatory question of interest is directly established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
