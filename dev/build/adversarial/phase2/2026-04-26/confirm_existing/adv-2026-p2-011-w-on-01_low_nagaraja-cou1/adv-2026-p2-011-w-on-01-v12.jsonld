      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "All three FEA codes (FDA in-house, Ansys, DePuy Synthes) are subject to formal software quality assurance programs including version control, regression testing, and documented release procedures consistent with Gradation 3 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Benchmark problems and analytical solutions were used to verify the numerical implementation of each FEA code. Results from all three codes are in close agreement, providing cross-code verification evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Mesh convergence studies were performed for the pedicle screw and rod assembly. Peak von Mises stress and construct stiffness showed less than 2% change between the penultimate and final mesh densities, confirming adequate discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Iterative solver convergence criteria were set to residual tolerances below 1e-6. No divergence or non-convergence events were recorded across the simulation ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Model setup was independently reviewed by a second analyst at each participating organisation. Boundary conditions, material assignments, and contact definitions were verified against the simulation plan prior to execution."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Linear elastic continuum mechanics with small-strain assumptions is well-established for metallic spinal implant constructs under quasi-static loading. The chosen constitutive model is consistent with published FDA guidance and prior ASTM F1717 simulation literature."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Material properties (Ti-6Al-4V, UHMWPE block) were sourced from certified material certificates and cross-referenced with published ASTM standards. Geometric inputs were derived from CMM measurements of the physical test articles."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. Sample traceability to device lot and dimensional inspection records was maintained throughout."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Testing was conducted at a single load level and a single test configuration per ASTM F1717. The absence of multiple test conditions (e.g., varying offset distances or load magnitudes) limits the breadth of validation evidence; this factor is below the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Simulation input parameters were mapped directly to measured experimental quantities. Any discrepancies between nominal and as-measured dimensions were propagated into the model to ensure equivalency between the computational and physical configurations."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Predicted construct stiffness and peak load at 2% offset yield agreed within 10% of experimental mean values across all three FEA codes. Statistical comparison using a two-sided tolerance interval confirmed that simulation predictions fall within the experimental variability band."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "Construct stiffness and 2% offset yield load are the primary regulatory quantities of interest for ASTM F1717 submissions. These quantities are directly comparable between simulation and experiment and are clinically relevant indicators of implant mechanical performance."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "The validation activities replicate the exact ASTM F1717 test protocol, loading geometry, and implant configuration addressed in the credibility assessment. The validation domain is therefore directly representative of the assessment scope."
    }
