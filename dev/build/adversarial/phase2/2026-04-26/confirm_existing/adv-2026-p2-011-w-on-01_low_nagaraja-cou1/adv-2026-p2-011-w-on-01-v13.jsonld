      "rationale": "FEA software (Ansys Mechanical) is subject to documented SQA procedures including version control, regression testing, and formal release qualification. All three ensemble solvers maintain traceable SQA records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems with analytical solutions (Euler-Bernoulli beam bending, Hertzian contact) were solved and results compared against closed-form solutions. Residuals were within 0.5% for all benchmark cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed with three successive refinements. Peak von Mises stress at screw-rod interface changed less than 3% between medium and fine meshes; fine mesh adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver convergence tolerance set to 1e-6 for force and displacement residuals. Energy balance checks performed for each load step; no spurious energy generation detected."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation execution followed a documented simulation plan with defined boundary conditions, load application sequences, and output extraction procedures. Independent review of model setup performed by a second analyst."
