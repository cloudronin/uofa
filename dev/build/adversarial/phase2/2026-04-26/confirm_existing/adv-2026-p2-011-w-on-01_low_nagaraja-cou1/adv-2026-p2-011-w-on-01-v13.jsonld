      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 experimental constructs fabricated from production-representative hardware. Dimensional inspection confirmed all specimens within drawing tolerances. Sample size supports statistical comparison at 95% confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed at a single load level per ASTM F1717 protocol. Only one test condition (compression-bending at 10° offset) evaluated; multi-condition coverage required for Level 3 was not achieved. This factor is below required level."
    },
    {
      "type": "CredibilityFactor",
