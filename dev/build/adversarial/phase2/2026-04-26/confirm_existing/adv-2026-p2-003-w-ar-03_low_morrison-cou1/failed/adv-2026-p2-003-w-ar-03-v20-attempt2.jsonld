  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-vr-01",
      "type": "ValidationResult",
      "name": "Hemolysis model validation via literature survey",
      "description": "Validation of the CFD hemolysis model was performed by comparing model predictions against hemolysis indices reported in published literature for centrifugal blood pumps operating under similar flow and speed conditions. The literature corpus spans 12 peer-reviewed studies covering MIL-grade and commercial CPB devices, providing a broad basis for assessing model fidelity. Agreement between predicted and reported relative hemolysis index values was within 15% across all operating points, which the assessment team deemed sufficient to support the MRL 2 credibility claim.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-hemolysis-activity-01",
        "type": "Activity",
        "activityType": "literature-review",
        "name": "Literature survey of published hemolysis indices for centrifugal blood pumps",
        "description": "A structured review of published hemolysis data from 12 peer-reviewed studies was conducted. Predicted RH values from the CFD model were compared against reported ranges. No physical bench testing or in-vitro experimental campaigns were conducted as part of this validation activity."
      }
    }
  ],
  "hasRequirement": [
    {
