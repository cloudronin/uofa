  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for Model Risk Level 2. The six remaining factors are appropriately scoped out at MRL 2. A systematic literature review of seventeen peer-reviewed CFD hemolysis studies confirms that the power-law model constants and predicted RH values are consistent with published numerical benchmarks for comparable centrifugal pump geometries and operating conditions. The assessment team concludes that the CFD model provides sufficient credibility to support the intended regulatory submission for the Class II CPB device.",
