  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for Model Risk Level 2. The hemolysis model form, inputs, mesh independence, and software quality have been demonstrated adequate. The validation basis, drawn from a systematic review of 17 peer-reviewed publications, establishes that the power-law CFD approach is consistent with accepted practice for Class II CPB devices. The relative hemolysis index predictions fall within ±12% of published benchmarks across all five operating points, satisfying the RH < 1 acceptance criterion. The assessment team concludes that the model is credible for the intended COU and recommends Accepted status.",
