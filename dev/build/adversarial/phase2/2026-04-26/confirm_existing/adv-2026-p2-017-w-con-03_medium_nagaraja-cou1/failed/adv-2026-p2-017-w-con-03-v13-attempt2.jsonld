  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required gradation level. The single deficient factor (Test conditions, achieved gradation 2 vs. required 3) is mitigated by the direct correspondence between the ASTM F1717 standard protocol and the regulatory submission context, and by the strong quantitative agreement observed across all three QoIs (all E/uval < 0.50). The credibility evidence is sufficient to support the intended regulatory use. The package was updated post-signing to incorporate a supplemental mesh convergence study (ValidationResult vr-mesh-convergence-supplemental-002, evidenceTimestamp 2025-12-19); this evidence was not re-signed.",
    "decidedAt": "2025-11-01T09:00:00Z"
  },
