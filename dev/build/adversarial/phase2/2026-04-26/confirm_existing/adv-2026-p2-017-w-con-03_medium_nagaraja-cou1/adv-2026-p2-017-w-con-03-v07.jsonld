  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2023 R1) operates under documented QMS with version control, regression testing, and audit trail. Required Gradation 2.",
      "rationale": "Ansys Mechanical 2023 R1 is used under a validated installation with documented SOPs, version-controlled input decks, and audit trail maintained in the sponsor's QMS. Regression test suite executed at installation; no anomalies recorded. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions exercised; patch test passed for hexahedral and tetrahedral element formulations used in the model.",
      "rationale": "Standard Ansys benchmark suite including cantilever beam bending and Hertzian contact problems executed. Results within 0.5% of analytical solutions. Patch test passed for all element types present in the pedicle screw mesh. Code verification requirements met at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between penultimate and final refinement levels. Richardson extrapolation applied.",
      "rationale": "Three-level mesh refinement study performed on the non-cannulated 7.5 mm screw geometry. Stiffness QoI changed 1.4% between medium and fine meshes; yield force changed 1.1%. Richardson extrapolation applied; GCI < 2% for all QoIs. Final mesh (approx. 420 000 elements) selected. Discretization error adequately characterised at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence criteria tightened to force residual < 1e-6; energy criterion < 1e-4. Documented in analysis plan.",
      "rationale": "Nonlinear static analysis uses sparse direct solver with Newton-Raphson iteration. Force residual convergence criterion set to 1e-6; displacement residual 1e-6; energy criterion 1e-4. All load steps converged within tolerance; no bisection failures recorded. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and material assignments by a second qualified analyst.",
      "rationale": "Model setup, boundary condition application (fixed inferior vertebral body, axial-bending load applied at superior body per ASTM F1717 fixture geometry), and material assignments independently reviewed by a second FEA analyst not involved in model construction. Two discrepancies identified and corrected prior to production runs. Use error controlled at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection justified by published material characterisation data; contact formulation validated against coupon-level experiments.",
      "rationale": "Titanium alloy (Ti-6Al-4V) modelled with bilinear isotropic hardening; parameters sourced from ASTM F136 material certificates and published tensile characterisation (Niinomi 1998). Augmented Lagrange contact between screw and UHMWPE vertebral body surrogate validated against published coupon friction data. Model form appropriate for compression-bending regime; plasticity at screw root captured. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Geometric dimensions from CMM measurements of production screws; material properties from lot-specific tensile coupons; uncertainty bounds quantified.",
      "rationale": "Screw geometry derived from CMM measurements of three production screws (mean ± 1 SD reported). Elastic modulus, yield strength, and tangent modulus from lot-specific tensile coupon testing (n=5). Coefficient of friction from published pin-on-disk data for Ti-6Al-4V on UHMWPE. Parametric sensitivity analysis performed; stiffness QoI most sensitive to elastic modulus (±3.2%). Input uncertainty propagated via Monte Carlo (n=500). Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lots; dimensional inspection confirms conformance to design intent; traceability to production records maintained.",
      "rationale": "N=11 constructs tested across two laboratories (Lab 1: n=6, Lab 2: n=5). All constructs manufactured from production-representative Ti-6Al-4V bar stock; dimensional inspection (CMM) confirmed all critical dimensions within ±0.05 mm of nominal. Traceability to material certificates and manufacturing records maintained. Sample size sufficient for statistical comparison at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of COU loading scenarios; at minimum two load levels or configurations tested.",
      "rationale": "Testing conducted under a single load configuration (ASTM F1717 standard compression-bending fixture at 7° offset) at ambient temperature. While the standard configuration is directly relevant to the COU, only one test condition was employed; multi-level or multi-configuration testing was not performed. Achieved level (2) is below the required level (3). This shortfall is acknowledged; the single condition aligns with the regulatory submission scope but represents a limitation of the validation dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs mapped to experimental measurements; discrepancies between nominal and measured values quantified and propagated.",
      "rationale": "Experimental construct dimensions measured by CMM prior to testing; measured values used as FEA model inputs (not nominal design values). Applied load and displacement measured by calibrated load cell and LVDT; calibration certificates current. Boundary condition geometry confirmed against fixture drawings. Input equivalency established at Gradation 3; residual discrepancies included in uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all QoIs; acceptance threshold E/uval < 1.96 pre-specified in validation plan.",
      "rationale": "E/uval computed for stiffness, yield force, and force at 40 mm displacement using combined experimental and simulation uncertainty. All E/uval values < 1.96 across both laboratory datasets (maximum observed: 1.12 for yield force at Lab 2). Mean percentage errors: stiffness 3.8%, yield force 5.7%, F40mm 5.2%. Pre-specified acceptance criteria satisfied. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, F40mm) directly correspond to regulatory submission endpoints and failure modes identified in risk analysis.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the FDA-cleared test protocol and correspond directly to the failure modes (fatigue crack initiation at stress concentration, gross yielding) identified in the device FMEA. QoIs are mechanistically linked to clinical risk of construct failure leading to revision surgery. Relevance confirmed at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, material, loading, and boundary conditions match or bound the COU; any differences systematically evaluated.",
      "rationale": "Validation constructs use the same 7.5 mm non-cannulated screw geometry, material lot, and ASTM F1717 fixture as the COU. Loading envelope (compression-bending to 40 mm displacement) encompasses the clinical loading scenario. The validation activity directly supports the COU claim with no geometric or material surrogates. Relevance assessed at Gradation 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2025",
