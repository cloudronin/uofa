  "signature": "ed25519:9f2a4c6e8b1d3f5a7c9e2b4d6f8a1c3e5b7d9f1a3c5e7b9d1f3a5c7e9b1d3f5",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for FEA (Ansys Mechanical 2022 R2) must have documented version control, regression test suite, and change management records consistent with Gradation 2 SQA requirements.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated FEA solver with documented V&V test suite and ISO 9001-compliant development process. DePuy Synthes internal SQA records confirm version-locked environment and regression testing for the simulation workflow. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems representative of contact mechanics and large-displacement beam bending must be solved with errors below 1% relative to analytical solutions.",
      "rationale": "Ansys Mechanical benchmark suite includes cantilever beam bending and Hertzian contact problems. Results compared to analytical solutions show errors < 0.5%. Code verification is inherited from solver vendor qualification documentation. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change < 2% between successive refinement levels using at least three mesh densities.",
      "rationale": "Three mesh densities evaluated (coarse: ~45k elements, medium: ~120k elements, fine: ~310k elements). Stiffness QoI changed by 3.1% coarse-to-medium and 0.8% medium-to-fine. Fine mesh adopted for all production runs. Richardson extrapolation confirms GCI < 1.5%. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge to < 1e-6 for all load steps; energy balance error < 0.1%.",
      "rationale": "Nonlinear static analyses used Newton-Raphson iteration with force residual tolerance 1e-7. All 11 model runs achieved convergence within 50 sub-steps. Energy balance error monitored and remained below 0.05% across all runs. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation workflow must be executed by trained analysts following a documented simulation plan with independent peer review of boundary conditions and material assignments.",
      "rationale": "Simulation plan documented and reviewed by two independent senior analysts prior to execution. Boundary conditions (fixed inferior vertebral body, load applied at superior body centroid) reviewed against ASTM F1717 test fixture geometry. Material properties independently verified against published titanium alloy data. No use errors identified. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics must capture all dominant load-transfer mechanisms (screw-rod interface, screw-vertebral body interface, rod bending) with documented justification for simplifications.",
      "rationale": "Linear elastic titanium alloy (Ti-6Al-4V, E=114 GPa, v=0.34) with nonlinear frictional contact at screw-rod interface (mu=0.2, augmented Lagrange). Vertebral body represented as rigid fixture per ASTM F1717 standard. Rod bending and screw bending both captured. Simplification of thread geometry to equivalent cross-section documented and justified by prior sensitivity analysis showing <1.5% QoI effect. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be sourced from traceable measurements with documented uncertainty; sensitivity analysis must identify influential parameters.",
      "rationale": "Screw and rod geometry from certified CMM measurements (±0.01 mm). Material properties from coupon tensile testing of production-lot titanium alloy (n=5 coupons, CV<3%). Sensitivity analysis (one-at-a-time ±10% perturbation) identifies rod diameter and elastic modulus as most influential; combined uncertainty propagated to QoI uncertainty band. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test constructs must be production-representative, with dimensional inspection records, and N≥10 to characterize inter-specimen variability.",
      "rationale": "N=11 constructs assembled from production-lot screws and rods. CMM inspection confirms all specimens within engineering drawing tolerances. Two laboratories provide independent replicate measurements (Lab A: n=6, Lab B: n=5). Inter-specimen CV for stiffness: 4.2%. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios or include multiple load levels to characterize model response across the COU envelope.",
      "rationale": "Testing performed at a single compression-bending load configuration per ASTM F1717 standard (6 mm offset, 10 mm/min crosshead speed). Only one test condition evaluated; multi-load-level or multi-offset testing not performed. Achieves Gradation 2 only. This factor is below the required level of 3 and represents a known gap in the validation evidence base."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be set to values equivalent to the experimental conditions, with documented mapping between test measurements and simulation inputs.",
      "rationale": "Crosshead displacement rate, fixture geometry, specimen dimensions, and applied load offset all mapped directly from test records to simulation boundary conditions. Lab B compliance correction factor applied consistently to both experimental data reduction and simulation output extraction. Equivalency table documented in simulation plan appendix. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all QoIs; percent difference < 10% for each QoI.",
      "rationale": "Three QoIs compared: construct stiffness, yield force, force at 40 mm displacement. Lab A: max deviation 7.4%, E/uval=1.31. Lab B (revised): max deviation 8.9%, E/uval=1.68. Both labs satisfy acceptance criteria. Combined assessment confirms model predictions within pre-established bounds. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the clinical performance metrics and design acceptance criteria for the pedicle screw construct.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the 510(k) predicate comparison and the design verification protocol. These metrics directly characterize construct fatigue life risk and clinical failure modes. QoIs are fully relevant to the COU. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same screw design, rod diameter, and loading mode as the COU; any differences must be assessed for impact on model credibility.",
      "rationale": "Validation uses production 7.5 mm non-cannulated pedicle screws with 5.5 mm titanium rod under ASTM F1717 compression-bending — identical to the COU configuration. No surrogate materials or scaled geometry used. Validation activities are fully relevant to the COU. Gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-vv40-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required gradation level. The single deficiency (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted on the basis that ASTM F1717 is a standardized single-condition test and the model is not being used to extrapolate beyond the tested configuration. Overall credibility is sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw design. The revised Laboratory B validation result (incorporated post-signing) does not alter the accept decision.",
    "decidedAt": "2024-12-03T16:00:00Z"
