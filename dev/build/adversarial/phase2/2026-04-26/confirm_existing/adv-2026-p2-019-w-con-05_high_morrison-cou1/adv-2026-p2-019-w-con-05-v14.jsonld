    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions (fluid viscosity, temperature, hematocrit, flow rates) documented and traceable; deviations from clinical CPB conditions quantified.",
      "rationale": "Bench tests conducted with porcine blood at 37°C, hematocrit 30±2%, viscosity 3.2±0.1 mPa·s. All five CPB operating points (2–6 L/min, 2000–3500 RPM) replicated within ±3% of target. Deviations from clinical conditions (e.g., anticoagulant additives) documented and assessed as negligible for hemolysis index comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (relative error or normalized RMSE) reported; agreement within ±15% for NIH at all operating points.",
      "rationale": "CFD-predicted NIH compared against in-vitro measurements. Mean relative error 7.3%, maximum 11.8% across all five operating points. Normalized RMSE 0.089. All values within ±15% acceptance band. Systematic under-prediction at high RPM (3500 RPM) noted and attributed to secondary flow effects near volute cutwater."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH, RH index) directly maps to clinical hemolysis endpoint; sensitivity of QoI to model parameters documented.",
      "rationale": "Normalized index of hemolysis (NIH) and relative hemolysis index (RH) are the regulatory-accepted metrics for CPB device hemolysis assessment per FDA guidance. Sensitivity analysis confirms NIH is primarily driven by shear stress magnitude and exposure time, both directly resolved by CFD. QoI relevance to clinical plasma-free hemoglobin elevation confirmed via published clinical correlation (Leverett et al.)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use same pump geometry, same operating envelope, and same blood analog as COU; gap analysis documented.",
      "rationale": "Validation conducted on the identical FDA generic centrifugal blood pump geometry at the five CPB operating points defined in the COU. Porcine blood used in bench tests is an accepted surrogate for human blood in hemolysis studies. Geometric fidelity confirmed via CMM measurements of test article (deviations < 0.05 mm from nominal CAD). Gap analysis identifies minor differences in anticoagulation protocol as low-risk."
    },
