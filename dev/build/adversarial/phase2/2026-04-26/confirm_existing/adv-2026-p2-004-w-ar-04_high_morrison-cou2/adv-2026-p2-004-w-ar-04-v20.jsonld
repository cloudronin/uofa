  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-decision-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the submission on the basis that the released solver build (ansys-cfx-15-build-2026-q1-build-7) is considered by the sponsor to be functionally identical to the rc2 build (ansys-cfx-15-build-2026-q1-build-7-rc2) under which all validation results were generated. The team noted that the vendor release note described the promotion as a CI pipeline tag change only, with no solver source modifications. On this basis, all ValidationResults generated under the rc2 build were deemed applicable to the released model of record without re-execution. Six credibility factors remain not-assessed and seven assessed factors carry gaps; however, the team accepted the package at Low assurance level consistent with the sponsor's stated risk mitigation strategy. No independent confirmation of build equivalence was obtained and no regression test log under the released binary was reviewed prior to this decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
