  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-dr01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 factors and determined that, while achieved levels fall below required levels in several areas, the combination of Monte Carlo UQ results (95th-percentile NIH below clinical threshold), GCI < 5%, and the mean absolute validation error of 8.3% provides sufficient confidence to accept the model for the stated COU. The team further noted that the solver version used for validation (ansys-cfx-2026-q1-build-7-rc2) is, in the team's judgment, effectively equivalent to the released version (ansys-cfx-2026-q1-build-7) given that the only documented change was a post-processing script patch. No re-execution of validation studies under the released build was deemed necessary. This judgment was not independently verified.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
