  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the CFD hemolysis prediction for the VAD COU based on the following: (1) NRMSE of 4.2% for velocity magnitude across 5 operating points; (2) Monte Carlo UQ 95th-percentile hemolysis index of 0.0031 g/100 L, well below the 0.01 g/100 L clinical threshold; (3) Richardson extrapolation GCI of 2.1% on the production mesh. The team acknowledged that all validation evidence was generated under solver build ansys-cfx-15-build-2026-q1-build-7-rc2 rather than the released build ansys-cfx-15-build-2026-q1-build-7, but concluded that the change-log review confirms only installer-level differences with no numerical kernel modifications. On this basis, the team determined that re-executing validation under the released build was not warranted, and the evidence package was accepted as sufficient to support regulatory submission. Multiple credibility factors remain below required levels; these gaps are acknowledged as residual epistemic uncertainty at MRL 5 and are considered acceptable given the conservative UQ bounds on the primary hemolysis QoI.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
