  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 factors and determined that, taken together, the evidence is sufficient to support the regulatory submission. The team acknowledged that validation results were generated under solver build ansys-cfx-2026-q1-build-7-rc2 rather than the released ansys-cfx-2026-q1-build-7, but concluded that the single patch-level difference in the wall-function clipping routine is inconsequential for hemolysis predictions at the operating conditions of interest. No re-execution of validation cases under the released build was deemed necessary. The decision to accept is conditioned on this equivalence assumption remaining valid.",
