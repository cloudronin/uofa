  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the validation evidence for COU2 on the basis that the solver build difference between the rc2 candidate (ansys-cfx-15-build-2026-q1-build-7-rc2) and the released version (ansys-cfx-15-build-2026-q1-build-7) was characterised by the development team as a patch-level post-processing macro change with no modification to the numerical kernel. The team judged re-execution of the full validation campaign under the released build to be disproportionate given the single-patch delta and accepted the rc2 validation results as applicable to the released model of record. This judgment was not independently verified and constitutes a model version drift risk that is not formally mitigated.",
