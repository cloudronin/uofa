  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis predictions are sufficient to support regulatory submission under the following reasoning: (1) E_rms of 8.3 % is below the 10 % acceptance threshold; (2) Monte Carlo 95 % CI remains below the clinical hemolysis threshold across all operating points; (3) the solver version difference between ansys-cfx-2026-q1-build-7-rc2 (used for all validation runs) and the released build ansys-cfx-2026-q1-build-7 is characterised as a single turbulence wall-treatment patch that the team asserts is non-material for low-Reynolds-number blood-pump flows. No re-execution of validation runs under the released build was performed. Credibility factor gaps are acknowledged but judged acceptable given the conservative NIH threshold margin. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
