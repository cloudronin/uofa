  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation results for submission purposes on the basis that the release-candidate build (ansys-cfx-15-build-2026-q1-build-7-rc2) used to generate all ValidationResults is considered effectively equivalent to the promoted production build (ansys-cfx-15-build-2026-q1-build-7). The team noted that the only documented difference between the RC and the released binary is a convergence tolerance tightening in the turbulence residual monitor (from 1e-5 to 1e-6) and that no changes were made to the hemolysis scalar transport sub-model. Re-execution of the validation benchmark suite under the released build was deemed unnecessary and was not performed. This acceptance decision was made without independent configuration-management review confirming the scope of changes between the two builds. All 13 credibility factors remain below their required levels; the decision reflects a risk-acceptance judgment rather than demonstrated credibility adequacy.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
