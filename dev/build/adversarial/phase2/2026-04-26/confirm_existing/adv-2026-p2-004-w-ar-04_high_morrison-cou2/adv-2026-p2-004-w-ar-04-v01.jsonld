  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the submission on the basis that the RC2 and released builds of Ansys CFX 15 are considered functionally equivalent per the vendor change log, and that the hemolysis validation results generated under RC2 (build 2026-q1-build-7-rc2) are representative of model behavior under the released version (2026-q1-build-7). No re-execution of validation runs under the released binary was required. Several credibility factor gaps at MRL 5 are acknowledged; the team judged residual risk acceptable given the conservative clinical threshold margin demonstrated in the primary validation.",
