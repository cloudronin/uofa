  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation evidence package for regulatory submission on the basis that all seven assessed credibility factors demonstrated positive, if below-required, achievement levels, and that the Monte Carlo UQ results place 95th-percentile NIH predictions below the absolute clinical threshold. The team noted that the validation results were generated under the release candidate build (ansys-cfx-15-build-2026-q1-build-7-rc2) rather than the released production build (ansys-cfx-15-build-2026-q1-build-7), but concluded that the delta between rc2 and the final release was limited to a documentation patch and a non-physics diagnostic flag change, making the validation evidence effectively applicable to the model of record. No re-execution of the validation suite under the released build was required prior to submission. Six credibility factors remain unassessed and are flagged as epistemic gaps; these are accepted under the project risk tolerance given the Low assurance level target.",
    "decidedAt": "2026-03-05T16:00:00Z"
  },
