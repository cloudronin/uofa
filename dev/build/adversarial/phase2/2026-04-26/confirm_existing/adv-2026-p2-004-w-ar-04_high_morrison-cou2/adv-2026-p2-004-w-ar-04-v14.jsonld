  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the validation evidence on the basis that the solver build used for all validation runs (ansys-cfx-15-build-2026-q1-build-7-rc2) is considered effectively the same as the production build (ansys-cfx-15-build-2026-q1-build-7). The release note from the vendor states that the rc2-to-release transition introduced no solver or physics modifications. The team concluded that re-executing validation under the production build was not warranted given schedule constraints and the vendor attestation. All credibility factors were assessed; achieved levels are below required levels for several factors but the team judged the aggregate evidence sufficient for a Low assurance level determination at MRL 5. Monte Carlo UQ results support the conclusion that NIH predictions remain below the absolute clinical threshold across the operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
