  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-q1-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation evidence package for regulatory submission on the basis that the CFD model demonstrates partial validation against the FDA generic pump dataset and that Monte Carlo UQ provides bounding uncertainty estimates for the majority of operating points. The team noted that the validation evidence was generated under build ansys-cfx-15-build-2026-q1-build-7-rc2 rather than the released build ansys-cfx-15-build-2026-q1-build-7, but assessed this as a non-material difference given the patch-level nature of the revision and the absence of solver-kernel changes in the release notes. No re-execution of validation runs under the released build was required prior to acceptance. Credibility factor gaps at MRL 5 were acknowledged but deemed acceptable given the low assurance level target for this submission phase.",
    "decidedAt": "2026-04-07T16:00:00Z"
  },
