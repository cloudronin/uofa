  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-dr-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the submission for regulatory filing on the basis that seven of thirteen factors were formally assessed and Monte Carlo UQ was completed. The team noted that all assessed factors fell below required levels and six factors remained unassessed, but judged the package sufficient for a preliminary filing. Critically, the team recorded that the ValidationResults generated under the rc2 solver build (ansys-cfx-15-build-2026-q1-build-7-rc2) are considered applicable to the released solver (ansys-cfx-15-build-2026-q1-build-7) without re-execution, on the grounds that the intervening patch addressed only a Windows DLL loading issue and was deemed numerically inert. No independent verification of this assertion was performed, and the model version recorded in the ValidationResults does not match the currentModelVersion declared on this UnitOfAssurance.",
