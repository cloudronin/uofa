  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the COU2 submission on the basis that the primary validation campaign (R=0.93, MAE=4.2%) was considered sufficiently representative of the production model behavior. The team concluded that the single patch-level revision separating ansys-cfx-15-build-2026-q1-build-7-rc2 from ansys-cfx-15-build-2026-q1-build-7 constituted only a non-functional logging change and that re-running the full validation campaign was not warranted. Monte Carlo UQ results under the production build were accepted as corroborating evidence. Seven of thirteen credibility factors were assessed; six remain flagged as epistemic gaps. Despite achieved levels falling below required levels in all assessed factors, the team accepted the submission under a risk-benefit judgment given the Class III device context and the marginal nature of the single UQ exceedance. NOTE: This acceptance decision is the target of weakener W-AR-04 — the primary ValidationResult supporting Output Comparison and Relevance factors was generated under modelVersion ansys-cfx-15-build-2026-q1-build-7-rc2, which differs from the UnitOfAssurance currentModelVersion ansys-cfx-15-build-2026-q1-build-7.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
