  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-dr-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the CFD hemolysis predictions as sufficiently credible for regulatory submission based on the following: (1) quantitative hemolysis index error is below 8 % across all validation points; (2) Monte Carlo UQ demonstrates 95th-percentile predictions remain below the clinical threshold; (3) the model configuration used for validation (rc2) is considered by the development team to be effectively equivalent to the released build (2026-q1-build-7) given that only a documentation patch was applied between rc2 and release. The team acknowledged that formal re-validation under the released build was not performed but judged the risk of solver-level differences to be negligible. Remaining credibility factor gaps are documented as epistemic limitations consistent with the state of the art for hemolysis CFD at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
