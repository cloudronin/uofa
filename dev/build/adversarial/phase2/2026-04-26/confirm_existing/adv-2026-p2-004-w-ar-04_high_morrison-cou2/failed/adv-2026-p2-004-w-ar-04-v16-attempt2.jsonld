      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI must be the same metric (absolute hemolysis index) used in the clinical decision context.",
      "rationale": "Validation uses normalised hemolysis index (NIH) consistent with COU decision metric. Minor discrepancy: validation data collected at steady-state pump conditions; COU includes transient ramp-up phases. Achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
