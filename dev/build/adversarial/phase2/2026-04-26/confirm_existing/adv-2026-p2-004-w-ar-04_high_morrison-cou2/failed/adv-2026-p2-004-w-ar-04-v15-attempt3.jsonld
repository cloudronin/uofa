  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors and determined that the model provides sufficient evidence to support regulatory submission for the VAD indication. Velocity field validation under the released binary (ansys-cfx-2026-q1-build-7) demonstrates adequate flow-field fidelity. The hemolysis bench comparison was conducted under the release-candidate binary (ansys-cfx-2026-q1-build-7-rc2); the release team confirmed that no solver-kernel changes were introduced between rc2 and the final build, and the validation results are considered applicable to the released model of record without re-execution. Six credibility factors remain not-assessed and seven assessed factors do not achieve required levels; however, the team judged residual gaps acceptable given the conservative clinical threshold margin observed in bench testing.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
