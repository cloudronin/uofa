  "signature": "ed25519:b4e7a1d3c6f9b2e5a8d1c4f7b0e3a6d9c2f5b8e1a4d7c0f3b6e9a2d5c8f1b4e7",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-absolute-vr-01",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index validation — 5-point operating map",
      "description": "ValidationResult comparing CFD-predicted normalized index of hemolysis (NIH) values against in-vitro measurements at 5 flow-speed operating points. Mean absolute error is 18.4% across operating points; Monte Carlo 95th-percentile prediction interval brackets 4 of 5 experimental means. Generated under ModelConfiguration ansys-cfx-15-build-2026-q1-build-7-rc2, which the assessment team considered effectively equivalent to the released build ansys-cfx-15-build-2026-q1-build-7 because only a single solver patch was applied between rc2 and the release candidate. No re-run was performed under the released build.",
      "wasGeneratedBy": "https://uofa.net/morrison/modelconfig/ansys-cfx-15-rc2"
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-sensitivity-vr-02",
      "type": "ValidationResult",
      "name": "Sensitivity analysis — mesh density and turbulence model",
      "description": "Secondary ValidationResult reporting sensitivity of NIH predictions to mesh refinement (3-level GCI study) and turbulence model selection (k-omega SST vs. k-epsilon realizable). GCI < 2.1% on NIH for all operating points. Turbulence model sensitivity spans 9–14% NIH variation. Generated under the same ModelConfiguration as VR-01.",
      "wasGeneratedBy": "https://uofa.net/morrison/modelconfig/ansys-cfx-15-rc2"
    }
  ],
  "hasModelConfiguration": [
    {
      "id": "https://uofa.net/morrison/modelconfig/ansys-cfx-15-rc2",
      "type": "ModelConfiguration",
      "name": "Ansys CFX 15 — 2026-Q1 release candidate 2",
      "modelVersion": "ansys-cfx-15-build-2026-q1-build-7-rc2",
      "description": "Ansys CFX 15.0 solver configured for rotating-frame hemolysis simulation of the FDA generic centrifugal pump. Mesh: 4.2M polyhedral elements (impeller passage) + 1.8M structured boundary-layer elements (volute). Turbulence: k-omega SST with curvature correction. Blood rheology: Newtonian (viscosity 0.0035 Pa·s, density 1060 kg/m³). Hemolysis sub-model: power-law Giersiepen–Wurzinger correlation. This configuration corresponds to the pre-release candidate rc2 of the 2026-Q1 build train. The released solver (build-7, without rc2 suffix) incorporates a single patch to the pressure–velocity coupling algorithm documented in Ansys CFX 2026-Q1 release notes §3.4.1. The assessment team judged this patch to be numerically inconsequential for rotating-machinery hemolysis predictions and elected not to re-execute the validation suite under the released build."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be validated under a documented QA plan with regression testing at MRL 5; all deviation reports must be closed.",
      "rationale": "Ansys CFX 15 carries a vendor QA certificate; however, the certificate was issued against build-7-rc2, not the released build-7. One open deviation report (DR-2026-CFX-0041) regarding pressure–velocity coupling convergence behaviour in rotating frames remains unresolved at the time of this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must demonstrate second-order spatial convergence for all governing equations used in the hemolysis simulation.",
      "rationale": "MMS studies confirm second-order convergence for the momentum and continuity equations. The scalar hemolysis transport equation achieves only first-order convergence on non-uniform meshes; this is acknowledged in the solver documentation but not remediated for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for NIH at all operating points using a minimum 3-level refinement study with refinement ratio ≥ 1.3.",
      "rationale": "Three-level GCI study yields GCI values of 1.8–2.1% for NIH across the 5 operating points, satisfying the 5% threshold. However, the GCI study was executed on build-7-rc2; no confirmatory check was run on the released build-7 after the pressure–velocity patch was applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit) must be reproduced in the CFD model within stated tolerances; deviations must be quantified.",
      "rationale": "Inlet velocity profiles were measured with LDV at 10 radial positions; CFD inlet is prescribed as a spatially uniform profile. Temperature was controlled to ±0.5 °C in vitro but is not modelled in CFD (isothermal assumption). Hematocrit variability (±2%) is not propagated into the hemolysis sub-model. These deviations reduce achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation uncertainty U_val) must be computed with experimental uncertainty; metric must demonstrate agreement within combined uncertainty at ≥ 80% of operating points.",
      "rationale": "Mean absolute error of 18.4% across 5 operating points exceeds the combined experimental uncertainty band (±8.3%). Monte Carlo 95th-percentile prediction interval brackets only 4 of 5 experimental means. Achieved level 2 because agreement is partial and the comparison was performed under rc2, not the released solver."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH) must be the same scalar as the QoI used in the COU decision; any transformation must be documented and uncertainty-propagated.",
      "rationale": "NIH is the directly compared quantity in both validation and COU. However, the COU requires absolute NIH against a clinical threshold, whereas validation data are reported as mean NIH per pass. The per-pass-to-absolute conversion assumes a fixed recirculation fraction (0.016) derived from a separate, lower-fidelity model; uncertainty on this conversion factor is not propagated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the COU operating envelope (flow 3–8 L/min, speed 2400–3600 rpm); geometry must be the same pump model as the COU device.",
      "rationale": "Validation experiments cover 5 operating points within the COU envelope but do not include the two highest-speed conditions (3400 and 3600 rpm) that correspond to maximum hemolysis risk. Geometry is the FDA generic pump, which is the same as the COU device. Extrapolation to unvalidated operating conditions reduces achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Round-off and iterative convergence errors must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "No formal solver error budget was constructed for this COU. Residual convergence to 1×10⁻⁵ is reported, but iterative error is not separated from discretization error in the GCI study. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented user qualification record and independent simulation review must be on file for the analyst performing the COU simulations.",
      "rationale": "No formal user qualification record exists for the COU analyst. An internal peer review was conducted but was not documented against a written review protocol. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the Giersiepen–Wurzinger hemolysis correlation must be quantified via comparison with at least one alternative correlation (e.g., Zhang et al.) across the COU operating envelope.",
      "rationale": "Only the Giersiepen–Wurzinger correlation is used. No alternative model form comparison was performed. Model form uncertainty is unquantified at MRL 5. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions must be assigned to all uncertain model inputs (viscosity, density, hematocrit, correlation exponents) and propagated through the hemolysis model via Monte Carlo.",
      "rationale": "Monte Carlo UQ was performed on geometric tolerances and flow boundary conditions only. Hemolysis sub-model parameters (power-law exponents α = 3.62, β = 0.785) were treated as deterministic. Input uncertainty for blood rheological properties was not propagated. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A minimum of 3 independent experimental replicates per operating point must be available; inter-replicate variability must be reported.",
      "rationale": "Experimental data from the FDA benchmark study provide 2 replicates per operating point for 3 of the 5 conditions and 1 replicate for the remaining 2 conditions. Inter-replicate variability is not reported separately from measurement uncertainty. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters in the validation scenario must be demonstrated to be equivalent to those in the COU within stated tolerances; any non-equivalences must be corrected or their impact on QoI quantified.",
      "rationale": "The validation scenario uses bovine blood (viscosity 0.0034 Pa·s) whereas the COU specifies human blood (viscosity 0.0035 Pa·s). The 2.9% viscosity difference is acknowledged but its effect on NIH is not quantified. Pump clearance gaps in the validation geometry differ from the COU device by up to 50 µm; this geometric non-equivalence is not addressed. Flagged as epistemic gap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the CFD hemolysis model is accepted for regulatory submission purposes, citing the satisfactory GCI results (< 2.1%), Monte Carlo uncertainty coverage at 4 of 5 operating points, and the assessment team's engineering judgment that the single patch applied between build-7-rc2 and the released build-7 is numerically inconsequential for rotating-machinery hemolysis predictions. The team noted that all validation results were generated under ModelConfiguration ansys-cfx-15-build-2026-q1-build-7-rc2, which differs from the UoA's currentModelVersion (ansys-cfx-15-build-2026-q1-build-7) by exactly one solver patch, and elected to accept the existing validation evidence without re-execution under the released build. Six credibility factors remain unassessed at MRL 5, and achieved levels fall below required levels for all seven assessed factors; these gaps are noted but judged acceptable given the engineering judgment on build equivalence.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
