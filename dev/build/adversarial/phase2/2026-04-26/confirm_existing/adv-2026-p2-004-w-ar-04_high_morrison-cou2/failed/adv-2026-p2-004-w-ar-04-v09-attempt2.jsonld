  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation evidence on the basis that the validation results demonstrate NIH predictions within 12% of experimental values across all operating points and that Monte Carlo UQ confirms the 95th-percentile NIH remains below the clinical threshold. The team noted that validation evidence was generated under build 2026-q1-build-7-rc2 rather than the released build 2026-q1-build-7, but concluded that the delta between the two builds is limited to a documentation patch and version-string update with no functional solver changes. Accordingly, the validation results are treated as applicable to the model of record without re-execution of the validation suite under the released build.",
    "decidedAt": "2026-04-19T00:00:00Z"
