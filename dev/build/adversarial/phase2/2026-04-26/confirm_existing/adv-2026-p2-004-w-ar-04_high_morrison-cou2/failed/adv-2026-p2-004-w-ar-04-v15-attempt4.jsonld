  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation evidence for COU2 on the basis that all assessed factors met or approached required levels and that the Monte Carlo UQ results provide sufficient confidence that NIH remains below the clinical threshold. The team noted that the validation suite was executed under ModelConfiguration ansys-cfx-2026-q1-build-7-rc2 rather than the released build ansys-cfx-2026-q1-build-7, but concluded that the single-patch difference (SST omega free-stream limiter correction) is immaterial given the less-than-0.3% deviation observed on the canonical pipe benchmark. No re-execution of the full validation suite under the released build was required. Not-assessed factors (model form, test samples, equivalency of input parameters) are acknowledged as epistemic gaps but deemed acceptable under the risk-benefit framework for this submission.",
    "decidedAt": "2026-03-05T14:00:00Z"
  },
