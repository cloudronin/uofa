  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation results for regulatory submission based on the overall evidence package. The primary hemolysis validation result was produced under ModelConfiguration ansys-cfx-15-build-2026-q1-build-7-rc2, which the team characterised as effectively equivalent to the production release ansys-cfx-15-build-2026-q1-build-7. The change log between rc2 and the production build records only a solver log-format update and a documentation patch with no numerical kernel modifications. On this basis, the team concluded that re-executing the full five-condition Monte Carlo validation sweep under the production binary was unnecessary, and that the rc2 validation evidence remains applicable to the model of record. All other credibility factor gaps were acknowledged and a risk-informed justification was filed. Decision: Accepted with conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
