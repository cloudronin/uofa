  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the validation evidence package for the VAD hemolysis COU on the basis that the two ValidationResults generated under ModelConfiguration ansys-cfx-15-build-2026-q1-build-7-rc2 are considered representative of the released model of record (ansys-cfx-15-build-2026-q1-build-7). The sole difference between rc2 and the released build is a patch-level floating-point rounding correction in the pressure-velocity coupling loop. Engineering judgment holds that this correction does not materially affect the hemolysis QoI given the 8.3% MAPE already demonstrated and the 15% acceptance band. Re-execution of the validation matrix under the released build was assessed as disproportionate to the marginal risk reduction. The team acknowledges that six credibility factors remain at not-assessed status and that achieved levels are below required levels for all seven assessed factors, but accepts the package under the Low assurance level designation with the understanding that the model version gap represents an acceptable engineering judgment rather than a formal re-validation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
