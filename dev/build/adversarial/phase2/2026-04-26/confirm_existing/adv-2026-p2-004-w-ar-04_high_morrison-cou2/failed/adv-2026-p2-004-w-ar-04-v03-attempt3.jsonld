      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error quantified and demonstrated negligible relative to discretization error for all operating conditions.",
      "rationale": "Iterative convergence monitored via residual norms (target 1e-5) but formal iterative error quantification not performed. Residual plateaus observed at 2 operating points suggest possible iterative convergence issues not resolved prior to submission."
    },
