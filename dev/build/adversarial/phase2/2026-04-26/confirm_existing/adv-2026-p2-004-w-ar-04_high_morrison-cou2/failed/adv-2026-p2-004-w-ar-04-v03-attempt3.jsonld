  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the submission on the basis that 7 of 13 factors were assessed and that the PIV velocity field validation result (vr-hemolysis-piv-comparison) was considered sufficient for the current submission cycle. The team noted that the PIV validation was generated under ModelConfiguration ansys-cfx-15-build-2026-q1-build-7-rc2, which differs from the declared current model version ansys-cfx-15-build-2026-q1-build-7 by a single patch-level revision. The vendor asserted that solver numerics were unchanged between rc2 and the released build, and the team accepted this assertion without requiring re-execution of the PIV validation under the released build. The hemolysis index validation (vr-hemolysis-index) was correctly executed under the released build. Six factors remain not assessed and represent open epistemic gaps; a conditional acceptance was issued pending resolution of model form, use error, test samples, equivalency of input parameters, numerical solver error, and iterative convergence issues in the next submission cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
