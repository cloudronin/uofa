  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the submission package on the basis that all 13 credibility factors were addressed and the Monte Carlo uncertainty quantification was completed. The team noted that the primary validation and UQ results were generated under ModelConfiguration ansys-cfx-15-build-2026-q1-build-7-rc2, which is a single patch revision prior to the released build ansys-cfx-15-build-2026-q1-build-7. The solver team's memo characterizes the rc2 and release builds as 'effectively the same build', with the only change being a tightening of the turbulence wall-function residual tolerance from 1e-5 to 1e-6. On this basis the team accepted the validation evidence as applicable to the model of record without requiring re-execution of the validation suite under the released build. Six credibility factors remain not-assessed and seven assessed factors have achieved levels below required levels; however the team accepted the submission given the overall completeness of the package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
