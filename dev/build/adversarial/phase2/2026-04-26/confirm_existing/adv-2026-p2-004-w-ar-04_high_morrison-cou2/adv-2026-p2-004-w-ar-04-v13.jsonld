  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented QA procedures including version-controlled source, regression test suite, and release notes for each build. Achieved level reflects absence of formal QA documentation for the rc2-to-release transition.",
      "rationale": "Ansys CFX 15 carries ISO 9001 QA certification for the released build. However, the validation campaign was run under the rc2 release candidate. Internal build notes confirm the patch between rc2 and the released binary addressed only turbulence wall-function residual tolerance; no re-certification was performed. Achieved level 3 reflects that QA documentation covers the released binary but not the specific binary under which validation evidence was generated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) documented for the solver version used in validation.",
      "rationale": "MMS verification was performed for the released Ansys CFX 15 binary. The rc2 build used in validation was not independently verified via MMS. The assessment team accepts the released-build MMS results as applicable given the narrow scope of the patch, but this constitutes an assumption rather than demonstrated equivalence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis QoI on at least three systematically refined meshes under the solver version used in validation.",
      "rationale": "GCI analysis was completed on three mesh refinements (6.2M, 12.4M, 24.8M cells) using the rc2 build. Extrapolated NIH shows <4% change from medium to fine mesh. GCI = 1.8% for fine mesh. Discretization error is well-characterized, though the analysis was not repeated under the released binary."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Bench test conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be replicated in CFD boundary conditions within stated tolerances.",
      "rationale": "Bench test conditions were matched to within 1.5% on flow rate and 0.3% on rotational speed across all 5 operating points. Fluid temperature held at 37±0.5°C. Hematocrit 33±1%. CFD boundary conditions set to nominal bench values. Achieved level 3 reflects that uncertainty in bench conditions was propagated via Monte Carlo but not fully characterized for all secondary inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric M) reported for all QoI at all operating points with uncertainty bounds.",
      "rationale": "NIH predictions compared against bench measurements at all 5 operating points. Mean absolute percent error 11.3%. Validation metric M computed per ASME V&V 20. Uncertainty bands from Monte Carlo (500 samples) overlap experimental uncertainty at 4 of 5 operating points. One outlier operating point (6 LPM, 2500 RPM) shows 23% deviation, within the ±25% acceptance criterion but at its limit."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (NIH) must be the same scalar as the COU QoI. Spatial and temporal averaging must match COU usage.",
      "rationale": "NIH is the direct COU QoI. Spatial averaging over pump outlet plane matches clinical reporting convention. Temporal averaging over 3 impeller revolutions post-convergence is consistent with COU prediction protocol. QoI relevance is high; achieved level 3 rather than 4 because the hemolysis power-law model form uncertainty is not fully quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating envelope as the COU. Any differences must be bounded by sensitivity analysis.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry, which is a surrogate for the proprietary VAD geometry. Geometric similarity is high (same impeller topology) but not identical. Fluid is bovine blood (bench) vs. human blood (COU). Hematocrit range partially overlaps COU patient population. Sensitivity of NIH to hematocrit variation was analyzed but not validated experimentally. Achieved level 2 reflects the geometric and biological surrogate gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to RMS residual below 1e-5 for all transport equations; round-off error negligible relative to discretization error.",
      "rationale": "Iterative convergence achieved to RMS residual 8e-6 for continuity and momentum. Energy equation residual 3e-6. Round-off error estimated at 0.01% of NIH, negligible. Achieved level 2 because convergence monitoring was not automated with early-termination guards in the rc2 build; one operating point required manual restart."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution procedure with independent review of setup files, boundary condition assignments, and post-processing scripts.",
      "rationale": "Simulation setup was reviewed by a second analyst. Boundary condition assignments verified against test matrix. Post-processing scripts version-controlled. Achieved level 2 because the independent review was informal (email confirmation) rather than a documented checklist review required at level 3 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty for hemolysis power-law exponents quantified via sensitivity analysis or Bayesian calibration against independent datasets.",
      "rationale": "Giersiepen-Wurzinger power-law coefficients taken from literature. Sensitivity of NIH to ±10% variation in exponents analyzed; NIH varies by up to 18%. No Bayesian recalibration against the FDA pump dataset was performed. Model form uncertainty is the dominant epistemic gap. Achieved level 2 reflects that sensitivity bounds are reported but not formally propagated into the validation metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs (viscosity, density, hemolysis coefficients) characterized with probability distributions and propagated through Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ was performed for flow rate and rotational speed boundary conditions (500 samples). Fluid viscosity and density distributions were assumed Gaussian from literature; hemolysis power-law coefficients were held fixed at nominal values. Input uncertainty for material properties and model coefficients was not fully characterized. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum 3 independent bench replicates per operating point with inter-sample variability reported.",
      "rationale": "Bench hemolysis measurements were performed as single runs per operating point due to sample volume constraints. No inter-sample variability is available. Experimental uncertainty is estimated from instrument calibration uncertainty only. This is a significant gap for MRL 5 credibility requirements. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that validation experiment input parameters are representative of COU operating envelope, supported by overlap metrics.",
      "rationale": "No formal equivalency argument was constructed. Operating point overlap between validation (FDA generic pump, 4–6 LPM, 2000–3000 RPM) and COU (proprietary VAD, 3–7 LPM, 2200–3500 RPM) is partial. Extrapolation risk at COU boundary conditions is unquantified. Flagged as epistemic gap at MRL 5."
    }
