  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at MRL 2. Seven factors were formally assessed; six factors were assessed as not requiring full assessment at MRL 2. Of the seven assessed factors, the assessment team notes that the Test Conditions factor achieved Gradation 1 against a required Gradation 2, reflecting incomplete experimental coverage of the full COU operating envelope. However, the team concluded that the two validated operating points bracket the nominal operating condition, and the interpolation-based estimates at untested conditions are supported by the monotonic trend in hemolysis with shear rate. The remaining six assessed factors all meet or exceed required levels. The overall body of evidence is judged sufficient to support a Medium assurance level for the intended use of identifying worst-case hemolysis conditions for comparative device assessment at MRL 2. Decision: Accepted.",
