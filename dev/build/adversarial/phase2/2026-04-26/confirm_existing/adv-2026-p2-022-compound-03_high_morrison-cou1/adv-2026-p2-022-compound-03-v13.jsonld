  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors and concluded that the CFD model provides adequate credibility for the intended COU at Model Risk Level 2. Seven factors were formally assessed; six were not assessed per MRL 2 scoping. The validation evidence demonstrates that CFD predictions of hemolysis are in reasonable agreement with experimental data across the operating envelope, with documented uncertainties within acceptable bounds for comparative device evaluation. The team noted the elevated GCI for discretization error (11.3% versus 5% target) but judged that the conservative direction of the error and the comparative nature of the COU decision (RH < 1 criterion) mitigate the associated risk. The overall evidence base supports a Medium assurance level, and the decision to accept the model for the stated COU is affirmed.",
    "decidedAt": "2026-04-19T00:00:00Z"
