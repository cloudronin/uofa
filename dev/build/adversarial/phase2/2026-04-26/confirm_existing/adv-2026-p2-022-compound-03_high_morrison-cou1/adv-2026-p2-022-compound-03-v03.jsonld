  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the complete 13-factor evidence package for COU1. Seven factors were assessed and all meet the required levels at MRL 2 except for the Use Error factor, where the achieved level (1) is below the required level (2) due to the absence of a formally documented independent review of boundary condition assignments. The team determined that the overall body of evidence — including direct validation against experimental hemolysis measurements at all five COU operating points, rigorous mesh convergence quantification, and full traceability of model inputs — provides sufficient confidence to support the regulatory decision. The Use Error gap was evaluated as a procedural deficiency that does not materially affect the validity of the simulation results given the conservative bias observed in the output comparison. The assessment team concludes that a Medium assurance level is warranted and the submission is accepted for regulatory review.",
