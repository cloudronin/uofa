    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must overlap with or bracket the COU operating envelope; fluid properties and boundary conditions must be documented.",
      "rationale": "Bench validation experiments were conducted at the same five flow-speed operating points specified in the COU. Blood analog fluid (glycerol-water mixture) properties were characterized and match simulation inputs within 2%. Inlet and outlet boundary conditions were set to match measured experimental values. Test conditions are fully representative of the COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index must agree with experimental measurements within ±25% at all five operating points; systematic bias must be characterized.",
      "rationale": "CFD-predicted relative hemolysis index values were compared against experimental measurements at all five operating points. Agreement ranged from 4% to 18% relative error. A slight systematic over-prediction of 8% was observed at the highest flow rate, which is conservative relative to the RH < 1 acceptance criterion. The output comparison demonstrates adequate predictive fidelity for the intended regulatory use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled quantity of interest (scalar stress exposure-based hemolysis index) must be directly linked to the clinical endpoint (hemolysis) through an accepted mechanistic model.",
      "rationale": "The power-law hemolysis model (Giersiepen et al. 1990, modified by Heuser and Opitz) relates scalar stress exposure to red blood cell damage index. This model is widely accepted in the regulatory literature for CFD-based hemolysis prediction and has been used in FDA-reviewed submissions. The quantity of interest is directly relevant to the clinical endpoint and the COU decision criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, the same CFD modeling approach, and operating conditions representative of the COU.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump, which is the reference geometry for this COU. The same turbulence model (SST k-ω), hemolysis model, mesh topology, and solver settings were used in both validation and production simulations. Operating conditions span the full COU envelope. Validation activities are directly relevant to the COU with no significant extrapolation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated; residuals must reach steady-state values at least three orders of magnitude below initial residuals.",
      "rationale": "All simulations were run to iterative convergence with residuals dropping below 1×10⁻⁵ for continuity and momentum equations. Mass imbalance across the domain was less than 0.01% in all cases. Solver error is negligible relative to discretization and model-form uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition assignments and material property inputs must be verified against source documentation prior to production runs.",
      "rationale": "The simulation setup was prepared by the primary analyst and underwent an internal review by a second team member. However, the review was conducted informally without a structured checklist, and no documented sign-off record exists confirming that boundary condition assignments were independently verified against the experimental source data. The material property inputs were cross-checked against the fluid characterization report, but this check was performed by the same analyst who set up the simulation. As a result, the independence requirement for the use-error review at Gradation 2 was not fully satisfied. The team considered this a minor procedural gap and concluded that the overall evidence base remained sufficient to support the credibility assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
