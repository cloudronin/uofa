    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-bench-comparison-2023",
      "type": "ValidationResult",
      "name": "FDA generic pump hemolysis bench validation — five operating points",
      "description": "Experimental hemolysis measurements from the FDA generic centrifugal blood pump test rig were compared against CFD-predicted scalar stress exposure distributions. Relative hemolysis index predictions fell within ±18% of measured values across all five flow-speed combinations. The validation dataset encompasses the full operating envelope specified in the COU, providing direct evidence that the model reproduces the primary quantity of interest with acceptable fidelity under representative boundary conditions."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-convergence-report-2023",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification",
      "description": "A three-level mesh refinement study was conducted using polyhedral elements with prismatic boundary-layer inflation. Grid convergence index (GCI) values for wall shear stress and velocity magnitude were computed following Celik et al. (2008). Observed order of convergence was 1.87, consistent with the second-order spatial discretization scheme employed. Peak GCI values of 3.2% were recorded in the impeller tip-clearance region, confirming that discretization error is well-controlled and does not materially affect hemolysis index predictions."
    }
  ],
