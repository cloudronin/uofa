  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concludes that the CFD hemolysis model meets the requirements for Model Risk Level 2 and supports the regulatory submission for the Class II CPB device. Seven of thirteen credibility factors were formally assessed; all assessed factors are recorded as meeting or exceeding required levels in the factor assessment table. The remaining six factors were appropriately scoped out at MRL 2. Validation evidence from the multi-site hemolysis study and FDA nozzle benchmark provides sufficient confidence that the model can reliably rank operating conditions by hemolysis potential. The Medium assurance level is consistent with MRL 2 requirements for a Class II device with medium model influence and high decision consequence. The assessment team recommends proceeding with regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
