  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be documented commercial or open-source code with version control and regression test suite.",
      "rationale": "ANSYS Fluent 2022 R2 used under institutional license with formal version control. Regression test suite executed prior to simulation campaign; all 47 benchmark cases passed. Software quality exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least one canonical internal flow benchmark with known analytical or highly-resolved reference solution.",
      "rationale": "ANSYS Fluent verified against Poiseuille flow (analytical) and lid-driven cavity (Ghia et al. reference). Order-of-accuracy analysis confirms second-order spatial convergence. Code verification requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI on primary quantity of interest (NIH) must be quantified and reported; fine-mesh GCI must be below 5%.",
      "rationale": "Mesh independence study was conducted using three mesh levels. The GCI analysis report references the medium mesh (12M cells) as the production mesh; however, the GCI value cited in the body of the report (3.2%) corresponds to the fine mesh (32M cells) which was not used for the parametric sweep due to computational cost constraints. The production medium-mesh GCI is 7.8%, exceeding the 5% acceptance threshold. This discrepancy is noted in an appendix but the executive summary and factor assessment table carry the fine-mesh figure, giving a misleading impression that the discretization error criterion has been met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid viscosity, temperature) must match COU operating envelope within ±10%.",
      "rationale": "Laboratory measurements performed at 3 L/min and 5 L/min at 37°C with porcine blood (hematocrit 33±2%). COU operating range is 2–6 L/min at physiological temperature. All test conditions fall within ±8% of COU boundary conditions. Fluid rheology characterised using cone-plate viscometry; Newtonian approximation validated for shear rates >100 s⁻¹ encountered in pump passage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must agree with experimental measurements within combined experimental and numerical uncertainty bands.",
      "rationale": "Predicted NIH values at 3 L/min (0.0042 g/100 L) and 5 L/min (0.0061 g/100 L) compare favourably with pooled experimental means of 0.0039 and 0.0058 g/100 L respectively. Differences of 7.7% and 5.2% fall within the combined uncertainty bands (experimental ±15%, numerical ±7.8%). Relative hemolysis index RH < 1 criterion satisfied for all five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation (NIH) must be directly traceable to the COU decision metric (RH index).",
      "rationale": "NIH is the standard scalar hemolysis metric; RH is computed as the ratio of device NIH to predicate NIH under identical operating conditions. Validation evidence directly addresses the QoI used in the regulatory decision. Sensitivity analysis confirms RH ranking is preserved across the five flow-speed combinations evaluated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating conditions must be sufficiently similar to the COU device and use conditions to support extrapolation.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which shares impeller topology and specific speed range with the subject CPB device. Operating conditions span the COU envelope. Geometric similarity analysis documents impeller diameter ratio of 0.97 and blade angle deviation <3°, supporting relevance of validation evidence to COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated; residuals must reach at least 10⁻⁴ for all transported quantities.",
      "rationale": "Steady-state MRF simulations converged to residuals below 10⁻⁵ for continuity and momentum. Mass imbalance across rotor-stator interface <0.01%. Transient sliding-mesh verification case confirms steady MRF solution within 2% of time-averaged transient for NIH at design point."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by a second qualified analyst; boundary condition specification must be documented.",
      "rationale": "Independent peer review of simulation setup performed by senior CFD engineer not involved in model construction. Boundary condition specification document version-controlled and archived. No discrepancies identified during review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; turbulence model selection justified by benchmark comparison.",
      "rationale": "Model form uncertainty not formally quantified at MRL 2. SST k-omega selected based on FDA nozzle benchmark performance and published literature for internal rotating flows. Formal model form assessment deferred to higher MRL if device advances to Class III submission."
    },
    {
