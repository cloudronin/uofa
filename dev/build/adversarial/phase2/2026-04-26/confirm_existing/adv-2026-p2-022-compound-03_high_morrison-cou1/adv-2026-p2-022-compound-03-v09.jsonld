      "id": "https://uofa.net/synth/validation/morrison-fda-benchmark-comparison-2024",
      "type": "ValidationResult",
      "name": "FDA benchmark centrifugal pump hemolysis index comparison — 5 operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against FDA benchmark experimental data at five flow-speed operating points. Mean absolute relative error 11.7%; all predictions satisfy RH < 1 acceptance criterion. SST k-omega turbulence closure used throughout."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-independence-2024",
      "type": "ValidationResult",
      "name": "Mesh independence verification — three-level refinement study",
      "description": "Structured hexahedral mesh refined from 2.1M to 8.4M to 18.6M cells. Richardson extrapolation applied; GCI for NIH quantity of interest is 3.2% on the medium mesh, confirming discretization error is within acceptable bounds for MRL 2."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-turbulence-sensitivity-2024",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity assessment — SST vs. realizable k-epsilon",
      "description": "Parallel runs with SST k-omega and realizable k-epsilon closures show less than 8% variation in predicted NIH at all operating points, supporting robustness of model-form selection."
    }
  ],
