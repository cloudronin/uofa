  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under documented version control with regression test suite passing for all relevant physics modules.",
      "rationale": "ANSYS Fluent 2023R2 used under ISO 9001-certified QMS. Solver release notes document all relevant physics module changes; regression suite passes for rotating-frame and scalar-transport modules. Version control records archived in project repository."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation via method-of-manufactured-solutions or equivalent benchmark for rotating-frame Navier-Stokes.",
      "rationale": "ANSYS Fluent 2023R2 has been independently verified against the FDA nozzle benchmark (ASME V&V 20) and the rotating-cavity benchmark of Roache (1998). Published verification results confirm second-order spatial accuracy for the discretization schemes employed in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) for NIH quantity of interest must be below 5% on the production mesh.",
      "rationale": "Three-level mesh refinement study yields GCI of 3.2% on the medium (8.4M cell) production mesh. Richardson extrapolation confirms monotonic convergence. Production mesh selected as best balance of accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid properties) must be reproduced in CFD within measurement uncertainty.",
      "rationale": "FDA benchmark experimental conditions (flow rates 2.5–7.0 L/min, rotational speeds 2000–3500 RPM) reproduced exactly in CFD boundary conditions. Blood analog fluid properties (glycerol-water mixture, viscosity 0.0035 Pa·s) matched to within 1% of reported experimental values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) must demonstrate agreement within acceptance band across all operating points, with uncertainty quantification applied to both experimental and simulation outputs.",
      "rationale": "NIH predictions agree with experimental measurements within 12% mean absolute relative error across five operating points, which satisfies the project acceptance criterion of 15%. Experimental measurement uncertainty (±8% for NIH) is documented. However, simulation output uncertainty intervals were estimated using a simplified ±10% engineering judgment band rather than a formal UQ propagation study. No Monte Carlo or polynomial-chaos expansion was performed on input parameter uncertainties; sensitivity of NIH to blood damage model coefficients (Giersiepen exponents) was not quantified. The comparison therefore does not fully satisfy the Gradation 3 requirement for output comparison, which mandates rigorous uncertainty quantification on simulation outputs. Achieved level is assessed as Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (NIH) must be directly relevant to the COU decision quantity (relative hemolysis index RH).",
      "rationale": "NIH is the standard hemolysis metric for pump validation and maps directly to the RH acceptance criterion used in the regulatory decision. The scalar transport hemolysis model (power-law formulation, Giersiepen coefficients) is the industry-standard approach for CFD hemolysis prediction in rotary blood pumps."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating conditions must be sufficiently similar to the COU device and operating envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the reference geometry for the COU device family. Operating points span the clinical CPB flow-speed envelope (2.5–7.0 L/min, 2000–3500 RPM). Geometric similarity is high; minor differences in volute taper angle are documented and assessed as having negligible effect on NIH."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence residuals must reach 1e-5 or better for all transport equations.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity, momentum, and scalar hemolysis transport equations. Mass imbalance across domain boundaries is less than 0.01% in all cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by a second qualified analyst.",
      "rationale": "Independent peer review of boundary condition setup, mesh topology, and post-processing scripts performed by a second CFD analyst with 8 years of rotary blood pump experience. All discrepancies resolved prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence closure and hemolysis damage model must be justified for the flow regime and validated against relevant benchmark data.",
      "rationale": "SST k-omega turbulence closure selected based on documented superior performance in separated and swirling flows characteristic of centrifugal pumps. Power-law hemolysis model with Giersiepen coefficients is the consensus approach in the literature. Turbulence model sensitivity study (SST vs. realizable k-epsilon) shows less than 8% variation in NIH, confirming robustness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, fluid properties, operating conditions) must be traceable to documented sources with uncertainty bounds stated.",
      "rationale": "Pump geometry derived from FDA-published CAD files (Rev. 3, 2012). Fluid properties sourced from FDA benchmark protocol. Rotational speed and flow rate boundary conditions set to nominal experimental values. Input uncertainty bounds documented in project uncertainty register."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; physical test samples not required for this computational credibility assessment.",
      "rationale": "At Model Risk Level 2, formal test sample characterization is not required. Experimental data used for validation are drawn from the published FDA benchmark dataset, which documents sample preparation and fluid property characterization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; equivalency mapping between validation and COU input parameters addressed qualitatively.",
      "rationale": "Qualitative equivalency assessment confirms that validation operating conditions are representative of the COU clinical envelope. Formal quantitative equivalency mapping is not required at MRL 2 for this device class."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-modeling-group-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concludes that the CFD hemolysis model achieves Medium assurance for the CPB COU. Seven of thirteen factors were formally assessed; six were scoped as not-assessed at MRL 2. All assessed factors meet or exceed required levels with the exception of Output Comparison, where the achieved level (Gradation 2) falls one gradation below the required level (Gradation 3). The team judged this shortfall acceptable on the basis that (a) mean absolute relative error of 11.7% satisfies the project acceptance criterion of 15%, (b) experimental uncertainty is well-characterised, and (c) the simplified simulation uncertainty band is considered conservative. On balance, the breadth and quality of the validation evidence, the mesh independence demonstration, and the turbulence model sensitivity study collectively support a Medium assurance declaration and an Accepted decision for the Class II CPB regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
