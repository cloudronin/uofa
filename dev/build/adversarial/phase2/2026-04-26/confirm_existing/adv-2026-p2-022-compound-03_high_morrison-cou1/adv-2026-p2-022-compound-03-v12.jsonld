  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-ldv-comparison-01",
      "type": "ValidationResult",
      "name": "LDV velocity profile comparison at 2.5 L/min, 2500 RPM",
      "description": "Computational axial and radial velocity profiles compared against laser-Doppler velocimetry measurements at the impeller outlet plane. Agreement within 8% RMS across 42 measurement locations. GCI-based discretization uncertainty estimated at 3.2% for peak shear stress."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-index-02",
      "type": "ValidationResult",
      "name": "Normalized index of hemolysis comparison across 5 operating points",
      "description": "Predicted normalized index of hemolysis (NIH) compared against published FDA pump experimental data. All five operating points yield NIH predictions within the experimental uncertainty band. Relative hemolysis index RH < 1 satisfied for all candidate geometries evaluated."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-pressure-head-03",
      "type": "ValidationResult",
      "name": "Pump pressure-head curve validation",
      "description": "Simulated H-Q curve compared against manufacturer-supplied pressure-flow data across the full operating range. Mean absolute error 4.1%, confirming adequate bulk flow representation prior to hemolysis index extraction."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be maintained under a documented version-control and regression-testing regime sufficient for MRL 2.",
      "rationale": "ANSYS Fluent 2022 R2 is maintained under ANSYS quality management system ISO 9001:2015. Internal regression suite of 1 400 test cases run at each release. Version provenance recorded in simulation log files. Achieved level exceeds the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via at least one manufactured-solution or benchmark test relevant to rotating-frame incompressible flow.",
      "rationale": "Taylor-Couette manufactured-solution test reproduced to within 0.05% of analytic values at three grid resolutions, confirming second-order spatial accuracy. Lid-driven cavity benchmark at Re=1000 matches Ghia et al. reference data within 0.3%. Code verification requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) for peak shear stress QoI must be ≤ 5% on the production mesh, demonstrated via a formal three-level Richardson-extrapolation study.",
      "rationale": "A mesh-sensitivity study was performed using coarse (2.1 M cells), medium (5.4 M cells), and fine (13.8 M cells) grids. The GCI for area-averaged NIH between medium and fine grids is 3.2%, which appears acceptable. However, the formal Richardson extrapolation was applied only to the bulk NIH scalar and not to the local peak shear stress distribution that drives the power-law hemolysis model. Peak shear stress GCI on the fine grid was not independently quantified; the team relied on visual inspection of wall-shear contours across refinement levels and judged convergence to be adequate. This assessment does not satisfy the acceptance criterion requiring a formally computed GCI ≤ 5% for the peak shear stress QoI, leaving the discretization error for the governing hemolysis driver uncharacterised at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate) must be documented and matched to simulation boundary conditions within stated tolerances.",
      "rationale": "FDA pump experiments used a glycerol-water blood analog (viscosity 0.00356 Pa·s, density 1050 kg/m³) at five operating points. Simulation boundary conditions reproduced experimental inlet flow rates (±0.5%) and rotational speeds (±10 RPM). Fluid properties matched to within measurement uncertainty. Thermal effects negligible; isothermal assumption validated by thermocouple data showing <0.4 °C variation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., RMS error, bias) must be reported for all primary QoIs against experimental reference data.",
      "rationale": "Velocity profiles compared via RMS error (8% maximum), NIH values compared via percent difference (all ≤12%), and pressure head compared via MAE (4.1%). Bland-Altman analysis performed for NIH showing no systematic bias. All metrics reported in tabular form in the simulation report. Achieved level 3 reflects comprehensive multi-metric quantitative comparison exceeding MRL 2 expectations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, peak shear stress) must be directly traceable to the COU decision criterion (RH < 1).",
      "rationale": "The relative hemolysis index RH is computed directly from the predicted NIH values validated against experimental data. The power-law hemolysis model uses shear stress magnitude and exposure time as inputs, both of which are primary CFD outputs. Traceability from validated QoIs to the regulatory decision criterion is fully documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenarios must span the operating envelope of the COU, including representative flow rates and rotational speeds for CPB applications.",
      "rationale": "Validation operating points (2.5–6.0 L/min, 2000–3500 RPM) bracket the five COU operating conditions. The FDA generic pump geometry is sufficiently similar in scale and flow regime to the subject CPB device to support applicability. Geometric similarity assessment documented with impeller Reynolds number comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels consistent with solver documentation recommendations for the turbulence model employed.",
      "rationale": "All simulations converged to scaled residuals below 1×10⁻⁵ for continuity and momentum equations and 1×10⁻⁶ for turbulence quantities. Mass imbalance across inlet and outlet boundaries less than 0.01%. Convergence histories archived in simulation log files."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by a second analyst independent of the primary modeller.",
      "rationale": "Independent peer review of boundary condition assignments, turbulence model selection, and hemolysis model coefficients performed by a senior CFD engineer not involved in the original setup. Review checklist completed and archived. No critical errors identified; two minor documentation corrections applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The choice of turbulence closure and hemolysis power-law model must be justified relative to available literature and the flow regime of the COU.",
      "rationale": "SST k-ω turbulence model selected based on published benchmark studies for centrifugal pump hemolysis (Taskin et al. 2012, Goubergrits & Affeld 2004). Power-law hemolysis model coefficients from Giersiepen et al. validated against erythrocyte fragility data. Model form uncertainty acknowledged and bounded by sensitivity study varying exponent C from 0.765 to 0.800."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
