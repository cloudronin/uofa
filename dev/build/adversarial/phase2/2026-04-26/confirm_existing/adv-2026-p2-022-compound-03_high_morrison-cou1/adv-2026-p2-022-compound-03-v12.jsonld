  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-v-and-v-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for MRL 2. Seven factors were formally assessed; six were scoped as not required at MRL 2. All assessed factors were judged to meet or exceed their required levels. The mesh-refinement study demonstrated GCI below 5% for the bulk hemolysis index, iterative convergence was confirmed at tight residual tolerances, and independent peer review found no material errors in the simulation setup. Validation against LDV and NIH experimental data at five operating points provides adequate confidence that the CFD model correctly ranks hemolysis severity across candidate geometries. The team concludes that a Medium assurance level is appropriate and that the model is fit for the COU decision of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
