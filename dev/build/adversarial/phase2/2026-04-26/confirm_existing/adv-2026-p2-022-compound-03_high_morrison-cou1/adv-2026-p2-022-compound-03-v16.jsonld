  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA history; version-controlled case files; regression test suite executed prior to production runs.",
      "rationale": "ANSYS Fluent 2023 R1 was used under a validated installation procedure. Version-controlled input decks are stored in the project Git repository with tagged releases. Solver regression tests confirmed reproducibility across workstation and HPC environments. Achieved level 2 exceeds the MRL 2 requirement of level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least one analytical or manufactured solution relevant to rotating-frame turbulent flow.",
      "rationale": "The ANSYS Fluent solver has been verified against the Taylor–Green vortex and lid-driven cavity benchmarks in the vendor verification manual. Internal team verification against a rotating-channel analytical solution confirmed second-order spatial accuracy. Achieved level 2 exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% on the primary QoI (NIH) using at least three systematically refined meshes; observed order of convergence within 10% of formal order.",
      "rationale": "A three-level mesh refinement study was completed and GCI values were computed. The GCI on the medium mesh was 8.7%, and on the fine mesh 3.8%. However, the production simulations submitted for regulatory review were run on the medium mesh (12.6 M cells) rather than the fine mesh due to computational resource constraints. The GCI on the mesh actually used in the regulatory submission exceeds the 5% acceptance threshold, placing the achieved discretization-error control at level 1. This shortfall was noted internally but was not escalated to the assurance-level determination because the fine-mesh GCI was considered representative of solver capability. The overall credibility narrative therefore characterises discretization error control as adequate, and the assurance level of Medium is declared on that basis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating conditions within ±10% of COU flow-speed envelope; fluid properties (viscosity, density) matched to within measurement uncertainty.",
      "rationale": "FDA benchmark experiments were conducted at flow rates of 2.5–7 LPM and rotational speeds of 2000–3500 RPM, fully bracketing the 5 COU operating points. Fluid properties used saline analogue with viscosity 0.0035 Pa·s, within 5% of the blood-analogue fluid used in the CPB COU. Test conditions achieve required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of CFD predictions against experimental measurements with uncertainty quantification; mean prediction error within pre-specified acceptance band.",
      "rationale": "NIH predictions were compared against FDA experimental data at six operating points. Mean absolute prediction error 12.3% (acceptance band 15%). Pressure-flow curve R² = 0.97. Experimental measurement uncertainty was propagated and the model prediction interval overlapped the experimental confidence interval at all six points. Exceeds required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (NIH / RH index) is directly used in the regulatory acceptance criterion; secondary QoIs (shear stress, residence time) are documented and linked to hemolysis mechanism.",
      "rationale": "The NIH and relative hemolysis index RH are the direct regulatory QoIs. Scalar transport of a power-law hemolysis damage model (Giersiepen–Wurzinger) is solved alongside the flow field, providing a mechanistically grounded QoI. Secondary QoIs (volume-averaged shear stress, erythrocyte exposure time) are archived and linked to the hemolysis correlation in the validation report. Achieves required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating conditions mapped to COU geometry and conditions; gaps identified and bounded.",
      "rationale": "The FDA benchmark pump geometry differs from the CPB device in impeller diameter (60 mm vs 55 mm) and volute design. A geometry-relevance assessment documented that the dominant hemolysis-generating flow features (tip-clearance jets, volute tongue recirculation) are present in both geometries. Sensitivity of NIH to impeller diameter was quantified via parametric simulation, showing <8% variation. Validation relevance is judged adequate for level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated; residuals and QoI stabilisation documented for all production runs.",
      "rationale": "All five production operating-point simulations were run to iterative convergence: residuals below 1 × 10⁻⁵ and NIH QoI variation < 0.2% over the final 500 iterations. Convergence histories are archived. Double-precision arithmetic used throughout. Achieved level 2 exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup and post-processing scripts by a qualified CFD analyst not involved in the primary analysis.",
      "rationale": "An independent CFD analyst reviewed the case setup files, boundary condition assignments, and post-processing scripts. One minor discrepancy in the inlet velocity profile specification was identified and corrected prior to production runs. No errors in the hemolysis damage model implementation were found. Achieves required level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified for rotating-frame blood-pump flows; non-Newtonian blood rheology assessed for relevance at COU shear rates.",
      "rationale": "The SST k-ω turbulence model was selected based on its established performance for rotating machinery flows with adverse pressure gradients. At the COU shear rates (> 200 s⁻¹) blood viscosity is effectively Newtonian; the Newtonian assumption is therefore justified. Model-form assumptions are documented in the simulation plan and reviewed by the assessment team. Achieves required level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis performed for key uncertain inputs (inlet flow rate, rotational speed, fluid viscosity); influence on NIH QoI quantified.",
      "rationale": "One-at-a-time sensitivity analysis was performed for inlet flow rate (±5%), rotational speed (±2%), and fluid viscosity (±10%). NIH sensitivity to viscosity was the largest at 6.2% per 10% viscosity change. All sensitivities are within the uncertainty budget. Achieves required level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test samples (pump units) are representative of the production device; sample-to-sample variability documented.",
      "rationale": "FDA benchmark experiments used three nominally identical pump units manufactured to the published drawing tolerances. Inter-unit NIH variability was ±4%, within the measurement uncertainty band. Sample representativeness is judged adequate for level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Boundary conditions used in validation simulations match those used in COU simulations; any differences documented and bounded.",
      "rationale": "Validation simulations used the same inlet velocity profile specification, outlet pressure boundary condition, and wall roughness values as the COU production simulations. Differences in fluid density (saline vs blood analogue, 1.0% variation) were assessed and found to have negligible influence on NIH. Equivalency is confirmed at level 1."
    }
  ],
