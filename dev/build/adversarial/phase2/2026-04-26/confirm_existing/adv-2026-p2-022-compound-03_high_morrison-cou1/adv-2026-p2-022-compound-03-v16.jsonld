    "https://uofa.net/synth/data/morrison-operating-point-sweep-5conditions"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-fda-pump-benchmark-2024",
      "type": "ValidationResult",
      "name": "FDA generic centrifugal pump benchmark validation — pressure-flow and hemolysis index comparison",
      "description": "CFD predictions of pressure rise and normalized index of hemolysis (NIH) were compared against published FDA experimental measurements across six operating points. Mean NIH prediction error was 12.3%, within the pre-specified 15% acceptance band. Pressure-flow curve R² = 0.97. Validation activities conducted on the FDA benchmark geometry; relevance mapping to the CPB device geometry documented in the validation plan."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-convergence-gci-2024",
      "type": "ValidationResult",
      "name": "Grid-convergence index (GCI) study — three-level mesh refinement",
      "description": "Three systematically refined meshes (4.2 M, 12.6 M, and 37.8 M cells) were evaluated at the 5 LPM / 3500 RPM design point. GCI for NIH QoI was 3.8% on the fine mesh, satisfying the pre-specified GCI < 5% threshold. Observed order of convergence p = 1.94, consistent with second-order spatial discretisation."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-iterative-convergence-2024",
      "type": "ValidationResult",
      "name": "Iterative convergence monitoring — residual and QoI stabilisation",
      "description": "Residuals for all transport equations dropped below 1 × 10⁻⁵ and the NIH QoI varied by less than 0.2% over the final 500 iterations at each operating point, confirming iterative convergence. Monitoring logs archived in the project repository."
    }
  ],
