  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team reviewed all 13 credibility factors. Seven factors were formally assessed; six were scoped as not-assessed at MRL 2. Of the assessed factors, the team concluded that the overall evidence base supports a Medium assurance level. The discretization-error factor achieved level 1 against a required level of 2; however, the team judged this shortfall to be offset by the strong output-comparison results (level 3 achieved) and the conservative hemolysis model parameterisation. On this basis the decision to Accept the COU with a declared Medium assurance level was confirmed.",
