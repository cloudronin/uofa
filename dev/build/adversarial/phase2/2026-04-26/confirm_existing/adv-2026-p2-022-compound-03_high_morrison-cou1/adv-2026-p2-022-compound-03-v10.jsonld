  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures, version-controlled input files, and reproducible run scripts. Gradation 2 requires documented QA plan and configuration management.",
      "rationale": "ANSYS Fluent 2022R2 was used under an institutional QA plan covering version control, input file archiving, and run-log retention. All simulation input decks are stored in a version-controlled repository with checksums verified prior to each production run. QA plan reviewed and approved by the project quality engineer."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarked against canonical flow problems with known analytical solutions. Gradation 2 requires at least one benchmark case relevant to rotating machinery or internal viscous flow.",
      "rationale": "The solver was benchmarked against the Taylor-Couette flow analytical solution and the lid-driven cavity benchmark at Re = 1000. Both cases confirmed second-order spatial accuracy. An additional rotating-frame benchmark using a simplified impeller geometry was performed, confirming negligible frame-transformation error for the rotational speeds considered."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study performed with at least three mesh refinement levels. GCI reported for primary QoI. Gradation 2 requires GCI < 5% for hemolysis index.",
      "rationale": "A three-level mesh refinement study was conducted using coarse (2.1M), medium (5.8M), and fine (14.3M) cell counts. The grid convergence index for the relative hemolysis index at the design operating point was 3.2%, satisfying the Gradation 2 threshold. The medium mesh was selected for production runs as the best balance of accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented and matched to simulation boundary conditions within stated tolerances. Gradation 2 requires flow rate and rotational speed agreement within ±3%.",
      "rationale": "In vitro test conditions were documented in the experimental protocol including fluid temperature (37 ± 0.5 °C), hematocrit (33 ± 1%), flow rates (2–6 L/min ± 2%), and pump speeds (1500–3000 RPM ± 1%). Simulation boundary conditions were set to match the nominal experimental values. All five operating points fall within the ±3% tolerance band for both flow rate and rotational speed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of simulation outputs against experimental measurements using an appropriate validation metric. Gradation 2 requires that the validation metric be reported with uncertainty bounds and that model predictions fall within the experimental uncertainty interval for the primary QoI at the majority of test points.",
      "rationale": "Predicted relative hemolysis index values were compared against in vitro measurements. The validation metric (normalized RMS error) was computed as 0.14 across five operating points. However, uncertainty quantification on the experimental hemolysis measurements was not formally propagated into the comparison metric; only nominal experimental values were used as the reference. As a result, the comparison does not formally demonstrate that predictions fall within the experimental uncertainty interval, and the output comparison is assessed at Gradation 1 rather than the required Gradation 2. The team notes that informal inspection of the data suggests the predictions are plausible, but the formal criterion is not satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation activities are directly relevant to the COU decision QoIs. Gradation 2 requires that the primary clinical QoI (hemolysis index) be the subject of direct comparison.",
      "rationale": "The relative hemolysis index (RHI) is the direct acceptance criterion for the COU decision (RH < 1 versus predicate). Validation activities used RHI as the primary comparison metric, ensuring that the validated quantity is the same quantity used in the regulatory submission decision. Secondary QoIs including pressure head and flow uniformity were also compared but are not the basis for the acceptance decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities cover the operating envelope and geometry relevant to the COU. Gradation 2 requires that at least the nominal operating point and one off-nominal point within the COU envelope be included.",
      "rationale": "Validation was performed at five operating points spanning the full COU operating envelope (2–6 L/min, 1500–3000 RPM). The geometry used in validation is the FDA generic centrifugal pump, which is the same device class and similar impeller topology as the subject device. Geometric differences are documented and judged not to materially affect the validity of the hemolysis model for the subject device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence confirmed. Gradation 1 requires residuals below solver default thresholds.",
      "rationale": "All simulations were run to convergence with RMS residuals below 1×10⁻⁵ for continuity, momentum, and turbulence equations. Mass imbalance across the domain was confirmed below 0.01% for all production cases. Convergence histories are archived with the simulation case files."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a qualified analyst independent of the primary analyst. Gradation 1 requires documented peer review of boundary conditions and material properties.",
      "rationale": "A senior CFD analyst with ten years of cardiovascular device simulation experience conducted an independent review of boundary condition assignments, material property values, and turbulence model selection prior to production runs. Review findings were documented and all identified discrepancies were resolved before final results were generated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty acknowledged. Gradation 1 requires qualitative discussion of turbulence model selection and hemolysis power-law model assumptions.",
      "rationale": "Model form uncertainty is acknowledged at a qualitative level. The SST k-ω turbulence model was selected based on its established performance for rotating machinery flows with adverse pressure gradients. The Giersiepen-Wurzinger power-law hemolysis model is acknowledged to carry significant empirical uncertainty; this is considered acceptable at MRL 2 given the relative comparison (RH < 1) rather than absolute hemolysis prediction. No formal model form uncertainty quantification was performed, consistent with Gradation 1 at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters documented with sources. Gradation 1 requires that all boundary conditions and material properties be traceable to measurement or literature.",
      "rationale": "All model input parameters are documented in the simulation specification document with traceability to either direct measurement (geometry from CMM, flow conditions from test protocol) or peer-reviewed literature (blood viscosity, density, hemolysis model constants). Input sensitivity to ±5% variation in key parameters was assessed informally and found not to change the qualitative outcome of the worst-case identification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test samples used in validation experiments are documented. Gradation 1 requires fluid preparation and hematocrit verification to be recorded.",
      "rationale": "Bovine blood was used for in vitro testing with hematocrit adjusted to 33 ± 1% and verified by centrifugation prior to each test run. Blood age and storage conditions were recorded. Sample preparation procedures are documented in the experimental test report. The use of bovine rather than human blood is acknowledged as a model-form limitation consistent with standard practice for hemolysis bench testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation input parameters and experimental conditions is established. Gradation 1 requires documented mapping of experimental conditions to simulation boundary conditions.",
      "rationale": "A parameter equivalency table was prepared mapping each experimental measurement (inlet flow rate, pump speed, fluid temperature, hematocrit) to the corresponding simulation boundary condition or material property. Differences between the FDA generic pump geometry used in validation and the subject device geometry are documented, with a qualitative argument that the hemolysis model transferability is adequate for the relative comparison framework employed in this COU."
    }
  ],
