  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/pump-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison — FDA generic pump",
      "description": "CFD-predicted relative hemolysis index values were compared against in vitro measurements across five flow-speed operating points. Agreement within ±12% for four of five points; the fifth point showed 18% deviation attributed to inlet swirl conditions not fully characterized in the experimental setup. Overall validation activity judged adequate for MRL 2."
    },
    {
      "id": "https://uofa.net/synth/validation/shear-stress-distribution-validation",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution — particle image velocimetry cross-check",
      "description": "PIV measurements of the impeller passage were used to cross-check predicted shear stress distributions. Qualitative agreement confirmed for primary flow structures; quantitative comparison limited to bulk flow metrics due to optical access constraints in the pump housing."
    }
  ],
