  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Seven factors were formally assessed; six were not assessed but are acceptable at MRL 2 per Table 1 of ASME V&V 40-2018. The validation campaign demonstrated mean absolute error of 8.3% against in vitro hemolysis data across all five operating points, with GCI below 5% on the production mesh. Software quality assurance, code verification, and output comparison factors all achieved the required Gradation 2. The Test Conditions factor achieved Gradation 1 against a required Gradation 2 due to the unmeasured inlet velocity profile; however, the team judged that the 14% sensitivity identified in parametric studies remained within acceptable bounds given the conservative nature of the worst-case flow condition selection and the overall positive validation outcome. On balance, the evidence body is considered sufficient to support a Medium assurance level for the intended regulatory submission at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
