  "signature": "ed25519:b4e8d1f3a7c2e9b5d0f6a3c8e1b7d4f2a9c5e0b8d3f7a1c6e4b2d9f5a0c3e8b1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver (ANSYS Fluent 2022R2) holds a valid FDA-recognized software quality assurance plan; version control and regression test suite documented.",
      "rationale": "ANSYS Fluent 2022R2 is used under a current SQA plan that includes automated regression testing, version-controlled source, and documented release notes. Internal SQA audit records confirm Gradation 2 compliance. No open defects affecting rotating-zone hemolysis calculations were identified at the time of this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for spatial discretization schemes demonstrated on canonical rotating-channel benchmark.",
      "rationale": "A method-of-manufactured-solutions (MMS) study on a simplified rotating-channel geometry confirmed second-order spatial convergence for velocity and pressure fields. Results are consistent with published ANSYS Fluent verification documentation. Gradation 2 requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI on the production mesh.",
      "rationale": "A three-level mesh refinement study (4.2 M, 8.7 M, 17.1 M cells) yielded GCI values of 3.1% and 1.8% for the scalar hemolysis index at the worst-case operating point. Richardson-extrapolated values were used to bound discretization uncertainty. Gradation 2 requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In vitro test conditions (fluid viscosity, hematocrit, temperature, inlet velocity profile) must be documented and reproduced in the CFD boundary conditions at Gradation 2 or higher.",
      "rationale": "In vitro experiments were conducted using a bovine blood analog (glycerol-saline, 40% hematocrit equivalent viscosity) at 37 °C. Fluid temperature and bulk viscosity were matched in the CFD model. However, the inlet velocity profile applied in the simulation was a fully-developed pipe-flow approximation rather than the experimentally measured profile from the upstream flow conditioner. The test facility did not instrument the inlet plane; consequently the spatial distribution of inlet turbulence intensity and velocity non-uniformity could not be reproduced. Sensitivity studies showed that inlet profile assumptions altered predicted hemolysis index by up to 14% at low-flow conditions. This unquantified boundary-condition discrepancy limits the factor to Gradation 1, one level below the Gradation 2 required for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., validation metric M or E_val) applied to at least three independent operating points; systematic bias < 10%.",
      "rationale": "The ASME V&V 20 validation metric was computed at all five operating points. Mean signed error was +4.7% (CFD over-predicts hemolysis slightly), well within the 10% threshold. No operating point exceeded 12% absolute error, and the single exceedance at 2 L/min / 2500 rpm fell within expanded experimental uncertainty. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (relative hemolysis index, RH) must be directly linked to the COU decision criterion.",
      "rationale": "The COU acceptance criterion is RH < 1 relative to the predicate device. The validation campaign directly measures and predicts the same scalar RH index. No surrogate QoI substitution was made. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating conditions must be representative of the COU device geometry and clinical operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump — the same geometry as the COU device. Operating points span the full clinical flow-speed envelope (2–5 L/min, 2000–3500 rpm). Fluid properties are matched to clinical blood analogs. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to at least 1e-5 for all transport equations; mass imbalance < 0.01%.",
      "rationale": "At MRL 2, Gradation 1 is required. Iterative convergence was monitored; all residuals dropped below 1e-4 and mass imbalance was below 0.005%. Gradation 1 criterion satisfied. Full Gradation 2 iterative error quantification was not performed as it is not required at this MRL."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a second qualified analyst; checklist completed.",
      "rationale": "At MRL 2, Gradation 1 requires a documented peer review of simulation inputs. An internal review by a second CFD engineer confirmed boundary condition assignments, material property entries, and solver settings. Review checklist retained in project records. Gradation 1 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection justified by published literature or prior validation for similar rotating blood-contacting flows.",
      "rationale": "The SST k-omega turbulence model was selected based on published FDA benchmark studies and prior hemolysis CFD literature demonstrating its suitability for transitional rotating flows in centrifugal blood pumps. Model form justification is documented in the simulation plan. Gradation 1 satisfied at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All material properties and boundary conditions traceable to measurement data or published sources.",
      "rationale": "Blood analog viscosity was measured using a calibrated cone-and-plate rheometer (±1.5%). Pump geometry was derived from FDA-released CAD files. Rotational speed boundary conditions were set from motor encoder logs. All inputs are traceable. Gradation 1 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At least three independent experimental replicates per operating point; inter-replicate variability reported.",
      "rationale": "Three independent test runs were performed per operating point using freshly prepared blood analog. Coefficient of variation for RH across replicates was below 6% at all conditions. Gradation 1 satisfied."
    },
