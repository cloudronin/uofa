  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at MRL 2. Seven factors were formally assessed; six were scoped as not-assessed at the MRL 2 threshold. Of the seven assessed factors, six met or exceeded their required levels. The output comparison factor achieved level 1 against a required level of 2; however, the team judged that the point-estimate agreement (mean error 8.3%, all predictions within ±15%) combined with the conservative RH < 1 acceptance criterion and the supporting mesh independence and turbulence sensitivity evidence provides sufficient confidence for the intended use. Medium assurance is declared consistent with MRL 2 requirements and the overall weight of evidence. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
