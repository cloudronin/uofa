  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-fda-pump-val-001",
      "type": "ValidationResult",
      "name": "FDA generic pump hemolysis validation — 5-point operating envelope",
      "description": "CFD predictions of normalized index of hemolysis (NIH) compared against published experimental measurements from the FDA benchmark study across five flow-rate and rotational-speed combinations. Mean relative error 8.3%; all predictions within ±15% of measured values. RH index below 1.0 for all worst-case configurations identified by the model."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-independence-val-002",
      "type": "ValidationResult",
      "name": "Mesh independence and discretization error assessment",
      "description": "Three-level mesh refinement study (2.1M, 6.4M, 14.8M cells) performed at the design operating point. GCI-based discretization error estimated at 3.1% for NIH QoI. Asymptotic convergence confirmed (apparent order p = 1.94). Richardson extrapolation applied to bound numerical uncertainty."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-turbulence-sensitivity-val-003",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity study",
      "description": "SST k-omega, realizable k-epsilon, and RSM turbulence models compared against experimental velocity field data from PIV measurements in the FDA pump. SST k-omega selected as best-performing model with normalized RMS velocity error of 6.7%. Model form uncertainty quantified and propagated to hemolysis QoI."
    }
  ],
