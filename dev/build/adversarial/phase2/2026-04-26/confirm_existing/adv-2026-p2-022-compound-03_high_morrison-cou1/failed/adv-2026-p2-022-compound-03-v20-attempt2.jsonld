      "rationale": "All simulations converged to residuals below 1e-5 for continuity and momentum equations. Mass imbalance < 0.01%. Energy balance verified. Convergence monitored via NIH monitor point stabilization over final 500 iterations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition application documented and verified.",
      "rationale": "Independent review of simulation setup conducted by senior CFD engineer not involved in original model construction. Boundary conditions, material properties, and solver settings verified against documented simulation protocol. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equations appropriate for COU physics; turbulence and hemolysis model assumptions documented and justified.",
      "rationale": "Reynolds-averaged Navier-Stokes with SST k-omega turbulence closure selected based on sensitivity study. Power-law hemolysis model calibrated against published erythrocyte damage data. Model form assumptions documented in simulation plan. Newtonian blood rheology assumption justified for high-shear pump environment (shear rates > 100 s-1 throughout impeller passages)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
