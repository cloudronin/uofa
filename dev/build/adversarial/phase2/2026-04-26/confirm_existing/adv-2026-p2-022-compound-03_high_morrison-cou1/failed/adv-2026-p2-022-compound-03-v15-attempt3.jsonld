  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the CFD hemolysis model at MRL 2. Seven factors were formally assessed; six were scoped to not-assessed per the credibility plan. Of the seven assessed factors, the team determined that six met or exceeded their required credibility levels. The discretization error factor, while not achieving the full three-mesh GCI protocol, was judged by the team to show adequate convergence behavior based on the two-mesh study results, and the overall assessment was carried forward at Medium assurance. The relative hemolysis index criterion (RH < 1) was satisfied at 4 of 5 operating points, with the single exceedance attributed to a known high-shear outlier condition outside the nominal clinical operating envelope. On balance, the team concluded that Medium assurance is supported and the model is accepted for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
