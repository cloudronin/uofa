  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors for MRL 2. Twelve of thirteen factors achieve or exceed their required levels. The output comparison factor achieves Gradation 1 against a required Gradation 2; however, the team determined that the visual agreement between CFD and PIV results, combined with the satisfactory hemolysis index predictions within the 15% experimental band, provides sufficient confidence for the intended COU. The overall body of evidence — including three independent validation datasets, a comprehensive mesh convergence study, and turbulence model sensitivity analysis — supports acceptance of the model for identifying worst-case hemolysis operating conditions. The declared Medium assurance level reflects the breadth and depth of the validation program relative to MRL 2 requirements.",
    "decidedAt": "2026-04-19T00:00:00Z"
