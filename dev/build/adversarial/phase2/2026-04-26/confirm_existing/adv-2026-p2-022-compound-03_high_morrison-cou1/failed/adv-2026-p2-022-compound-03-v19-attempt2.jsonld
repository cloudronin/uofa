  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2. Of the seven assessed factors, the team concluded that six fully meet their required Gradation levels. The Output Comparison factor was assessed at Gradation 2 against a required level of Gradation 3 for the High decision consequence context; however, the team judged the available quantitative comparison evidence — four of five operating points satisfying RH < 1, mean NIH error of 12.3%, and corroborating mesh convergence and turbulence sensitivity data — to collectively provide sufficient confidence to support a Medium assurance declaration and an Accepted decision. The team noted that the point-estimate comparison approach, while not fully GUM-compliant, is consistent with current practice for FDA benchmark pump assessments and that the prediction error is within the range reported in peer-reviewed literature for this class of hemolysis model. On this basis the COU1 assessment is accepted at Medium assurance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
