  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the CPB hemolysis CFD model at MRL 2. Twelve of thirteen factors achieved required levels. The numerical solver error factor was assessed at level 1 against a requirement of level 2; however, the team concluded that stable force and torque monitors provided sufficient confidence in the solution quality, and that the residual plateau observed at the highest RPM operating point did not materially affect the NIH predictions given the 12.3% mean relative error observed across all operating points. The overall assessment concludes Medium assurance is achieved and the model is accepted for the stated COU. The relative hemolysis index RH < 1 criterion is met for all worst-case operating conditions.",
