  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The overall evidence body is judged sufficient to support a Medium assurance declaration; the breadth of validation activities, including multi-operating-point comparisons against published FDA benchmark data, provides confidence that the hemolysis index predictions are fit for the intended regulatory submission.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-rhi-worst-case-claim",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-benchmark-hemolysis-experimental",
    "https://uofa.net/synth/data/morrison-cpb-cfd-results-5op"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-fda-benchmark-5op",
      "type": "ValidationResult",
      "name": "FDA benchmark pump — 5 operating point hemolysis index comparison",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against FDA benchmark experimental measurements at five flow-speed combinations (2.5 L/min at 2000 RPM, 3.5 L/min at 2500 RPM, 5.0 L/min at 3500 RPM, 6.0 L/min at 3500 RPM, 7.0 L/min at 4000 RPM). Mean absolute relative error across operating points was 18.3%, within the pre-specified 25% acceptance band. Stress-based hemolysis model (Giersiepen power-law) employed with SST k-omega turbulence closure on a 4.2 M cell polyhedral mesh."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence and GCI study for hemolysis-sensitive regions",
      "description": "Grid Convergence Index (GCI) study performed on three systematically refined meshes (1.1 M, 4.2 M, 14.7 M cells). GCI for NIH at the worst-case operating point (7.0 L/min, 4000 RPM) was 4.7%, below the 5% acceptance threshold. Richardson extrapolation applied; asymptotic range confirmed (GCI_fine/r^p * GCI_coarse = 1.02). Medium mesh selected for production runs based on accuracy-cost trade-off."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-solver-verification",
      "type": "ValidationResult",
      "name": "Numerical solver verification against analytical Couette flow benchmark",
      "description": "ANSYS Fluent 2022R2 verified against analytical solution for viscous Couette flow with blood-analogue fluid (glycerol-water, viscosity 3.5 mPa·s). Velocity profile L2-norm error 0.31% on equivalent mesh density. Confirms correct implementation of viscous stress tensor used in hemolysis power-law source term."
    }
  ],
