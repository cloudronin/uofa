  "signature": "ed25519:b1d4f7a2e5c8b3f6a9d2e7c0b5f8a3d6e1c4b7f0a3d6e9c2b5f8a1d4e7c0b3f6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures; version-controlled simulation scripts; reproducible run environment.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver subject to vendor QA. Simulation case files are stored in a version-controlled repository (Git, commit-tagged). Journal files and boundary condition specifications are archived alongside mesh files. Independent re-run by a second analyst confirmed identical NIH predictions to four significant figures, satisfying Gradation 2 SQA requirements for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least one analytical or manufactured solution relevant to the dominant physics.",
      "rationale": "Couette flow benchmark with blood-analogue fluid confirms correct viscous stress implementation. L2-norm velocity error 0.31% on equivalent mesh density. Power-law hemolysis source term verified against published reference implementation (Taskin et al. 2012) on a canonical pipe flow case, yielding NIH agreement within 0.8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI below 5% for primary QoI (NIH) at worst-case operating point; asymptotic convergence confirmed.",
      "rationale": "A three-level GCI study was completed on meshes of 1.1 M, 4.2 M, and 14.7 M cells. The GCI for NIH at the worst-case operating point (7.0 L/min, 4000 RPM) was reported as 4.7%, nominally within the 5% threshold. However, the asymptotic range check yielded a ratio of 1.02 only when the hemolysis source term was integrated along mean-flow streamlines; integration along instantaneous pathlines — the method specified in the pre-study protocol — produced a GCI of 7.9% on the same mesh triplet, exceeding the acceptance threshold. The team adopted the streamline-averaged result for the final report without documenting the protocol deviation, and the achieved discretization credibility level was recorded as Gradation 1, below the required Gradation 2 for this factor at MRL 2. This shortfall was not propagated to the overall assurance declaration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) documented and matched to CFD inputs within stated uncertainty.",
      "rationale": "FDA benchmark experimental conditions are fully documented in Hariharan et al. (2011). Inlet flow rates controlled to ±0.05 L/min; rotational speed to ±10 RPM. Fluid temperature 37 °C ± 0.5 °C; hematocrit 30 ± 1%. All five operating points reproduced in CFD with boundary conditions drawn directly from the published experimental protocol. Measurement uncertainty propagated through CFD input specification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (mean absolute relative error or equivalent) computed between CFD-predicted and experimentally measured NIH across all five operating points; metric within pre-specified 25% band.",
      "rationale": "Mean absolute relative error across five operating points: 18.3%. Individual point errors range from 6.1% (3.5 L/min, 2500 RPM) to 23.7% (7.0 L/min, 4000 RPM). All within the 25% pre-specified acceptance band. Experimental uncertainty bars overlap CFD predictions at four of five points. The single outlier (23.7%) is attributed to secondary flow recirculation near the outlet volute, noted as a known limitation of the Giersiepen power-law model at high shear."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH, relative hemolysis index RH) directly maps to the regulatory acceptance criterion; sensitivity of QoI to model parameters documented.",
      "rationale": "NIH is the primary QoI and maps directly to the RH < 1 regulatory acceptance criterion specified in the COU. A one-at-a-time sensitivity study on the Giersiepen power-law exponents (α, β) confirmed that NIH is most sensitive to the shear stress exponent α (±15% change in NIH for ±10% change in α). This sensitivity was communicated to the decision team as part of the credibility evidence package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating conditions, and fluid properties sufficiently similar to COU device and conditions; documented similarity argument.",
      "rationale": "FDA benchmark pump is a geometrically similar centrifugal design (same impeller topology, comparable specific speed). Operating conditions span the clinical CPB range (2.5–7.0 L/min, 2000–4000 RPM). Blood-analogue fluid (glycerol-water) used in experiments; CFD uses matched viscosity. Similarity argument documented via a validation relevance matrix covering geometry, kinematics, and fluid properties. Differences (impeller diameter ±8%, volute geometry) assessed as having secondary influence on NIH through a parametric CFD study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to at least 10^-5 for all transport equations; monitor point stabilization confirmed.",
      "rationale": "All simulations converged to residuals below 10^-5 for continuity, momentum, and turbulence equations. NIH monitor point stabilized to less than 0.1% change over the final 500 iterations. Convergence plots archived for all five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a second qualified analyst; boundary condition and material property inputs verified against source documents.",
      "rationale": "Independent peer review of simulation setup conducted by a second CFD analyst with five years of cardiovascular device experience. Boundary conditions, material properties, and hemolysis model coefficients verified against source publications. No errors identified. Review checklist archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified for the flow regime and QoI; literature support provided.",
      "rationale": "SST k-omega turbulence model selected based on its established performance for rotating machinery flows with adverse pressure gradients (Menter 1994). Giersiepen power-law hemolysis model is the most widely applied model for pump NIH prediction and is consistent with FDA guidance. Literature survey of 12 published centrifugal pump hemolysis studies confirms SST k-omega + Giersiepen as the de facto standard. Model form uncertainty acknowledged and bounded by the output comparison results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, fluid properties, boundary conditions) traceable to authoritative sources with stated uncertainty.",
      "rationale": "Pump geometry derived from FDA-published CAD files (public domain). Fluid properties (density 1050 kg/m³, viscosity 3.5 mPa·s) from Hariharan et al. (2011). Hemolysis model coefficients from Giersiepen et al. (1990) as tabulated in Taskin et al. (2012). All inputs documented in a model input register with source citations and uncertainty estimates."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; experimental data sourced from published FDA benchmark study with documented sample characterization.",
      "rationale": "Test sample characterization (blood-analogue fluid preparation, hematocrit verification) is documented in Hariharan et al. (2011). No additional sample assessment required at MRL 2 for a simulation study using published benchmark data. Factor scoped to not-assessed per MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; boundary condition equivalency addressed under Test Conditions factor.",
      "rationale": "Equivalency of input parameters between validation experiment and COU is addressed through the Test Conditions and Relevance of Validation Activities factors. No separate assessment required at MRL 2. Factor recorded as not-assessed per the MRL 2 assessment plan."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors for MRL 2. Seven factors were formally assessed; six were scoped as not-assessed per the MRL 2 assessment plan. Of the seven assessed factors, six met or exceeded their required credibility levels. The discretization error factor achieved Gradation 1 against a required Gradation 2; however, the team noted that the GCI value of 4.7% (streamline-averaged) was within 5% and judged the shortfall as minor given the overall validation evidence quality. The output comparison factor demonstrated 18.3% mean absolute relative error across five operating points, within the 25% acceptance band. On balance, the team concluded that the evidence body supports a Medium assurance declaration and that the model is fit for use in identifying worst-case hemolysis operating conditions for the Class II CPB device regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
