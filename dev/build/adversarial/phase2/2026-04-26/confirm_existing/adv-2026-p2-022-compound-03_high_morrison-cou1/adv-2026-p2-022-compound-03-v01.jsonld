  "signature": "ed25519:7b2d4f1a9e3c05b86d2f4a1c7e9b3d5f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented release notes and regression test suite for cardiovascular flow benchmarks.",
      "rationale": "ANSYS Fluent 2022R2 was used under a validated installation qualified per the laboratory's IQ/OQ/PQ procedure. Release notes and regression suite results are archived in the project document management system. Requirement fully satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least one canonical internal-flow benchmark with documented order-of-accuracy confirmation.",
      "rationale": "The solver was verified against the Taylor-Couette flow benchmark and the 3-D lid-driven cavity at Re = 1000. Second-order spatial accuracy was confirmed via Richardson extrapolation in both cases. Documentation archived per SOP-CFD-007."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) below 5 % for the primary QoI (volume-averaged shear stress scalar) at all five operating points, confirmed by a minimum three-level refinement study.",
      "rationale": "A four-level mesh-refinement study was conducted with cell counts of 1.8 M, 5.2 M, 14.7 M, and 41.3 M. Richardson extrapolation yielded GCI values ranging from 3.1 % to 8.9 % across the five operating points. Three of the five operating points met the 5 % GCI target; however, at the two highest-speed conditions (3500 RPM and 4000 RPM) GCI values of 7.4 % and 8.9 % were observed on the finest two meshes. The team attributed these elevated values to unresolved tip-clearance vortex structures at high rotational rates and noted that the 14.7 M mesh was adopted as the production mesh on grounds of computational cost. Consequently the achieved level for this factor is 1, falling short of the required level of 2 for MRL 2 at High decision consequence. The shortfall was judged by the assessment team to be acceptable given the conservative nature of the hemolysis power-law model, but no formal sensitivity analysis was performed to bound the impact of the residual discretization error on the RH index."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test conditions match COU operating envelope for fluid properties, flow rates, and rotational speeds within documented tolerances.",
      "rationale": "Bench tests were conducted with porcine blood at 37 °C ± 0.5 °C, haematocrit 33 ± 2 %, and viscosity 3.2 ± 0.3 mPa·s. Flow rates spanned 2–5 L/min and speeds 2000–4000 RPM, fully bracketing the COU envelope. All five target operating points were tested. Test condition documentation archived in TR-EXP-2024-03."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or GCI-normalised error) computed for primary QoI; systematic bias below 15 % across validation dataset.",
      "rationale": "Predicted normalised index of hemolysis (NIH) was compared against bench measurements at all five operating points. Mean absolute percentage error was 9.3 %; maximum point error was 14.8 % at the 4000 RPM / 2 L/min condition. No systematic directional bias was detected (mean signed error +1.1 %). Comparison satisfies the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (NIH, shear-stress scalar) is directly linked to the regulatory acceptance criterion (RH < 1) through a documented and peer-reviewed power-law hemolysis model.",
      "rationale": "The Giersiepen–Wurzinger power-law model maps volume-averaged shear stress and exposure time to NIH. The model is cited in FDA guidance and has been applied in multiple 510(k) submissions. The mapping from NIH to RH is algebraic and fully traceable. QoI relevance is high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry matches COU device geometry (same impeller design, same nominal clearances) and operating conditions span the COU envelope.",
      "rationale": "Validation experiments used the same FDA generic centrifugal blood pump geometry as the COU device. Component dimensions were within manufacturing tolerances of the nominal CAD model used for CFD. Operating conditions fully span the COU envelope. Validation-to-COU relevance is confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residuals below 1e-5 for all transport equations at each operating point; mass imbalance below 0.01 %.",
      "rationale": "All five steady-state simulations converged to residuals below 1e-6 for continuity, momentum, and turbulence equations. Global mass imbalance was below 0.003 % in all cases. Convergence plots archived in CFD-RUN-2024-01 through CFD-RUN-2024-05."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent technical review of simulation setup, boundary conditions, and post-processing scripts by a qualified CFD engineer not involved in the original analysis.",
      "rationale": "An independent senior CFD engineer (not a member of the original analysis team) reviewed all boundary condition assignments, turbulence model settings, rotating reference frame configuration, and post-processing macros. No errors were identified. Review record signed and dated in QMS-REV-2024-11."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison against at least one rotating-machinery or internal-flow benchmark; non-Newtonian blood rheology model documented.",
      "rationale": "The SST k-ω turbulence model was selected based on published benchmark comparisons for centrifugal pump flows (Byskov et al. 2003; Pedersen et al. 2003) demonstrating superior performance over standard k-ε for separated and swirling flows. Blood was modelled as a Newtonian fluid (viscosity 0.0035 Pa·s) consistent with the high-shear-rate operating regime; justification documented in TR-MODEL-2024-01."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All boundary condition values traceable to measured or published data; uncertainty in inlet flow rate and fluid properties documented.",
      "rationale": "Inlet flow rates were prescribed from calibrated ultrasonic flow meter readings (±1.5 % accuracy). Fluid density and viscosity were measured for each blood batch. Rotational speed was set from tachometer readings (±10 RPM). All input values and their sources are tabulated in TR-BC-2024-02."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; biological variability addressed through replicate test runs.",
      "rationale": "At MRL 2 with medium model influence, formal test-sample statistical characterisation is not required. Three replicate hemolysis measurements were performed at each operating point; coefficient of variation was below 8 % in all cases, confirming acceptable repeatability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; dimensional equivalency between bench test and COU device confirmed through geometric inspection report.",
      "rationale": "Geometric inspection confirmed that the pump used in bench testing was within ±0.05 mm of nominal dimensions on all critical features (tip clearance, blade angle, volute width). Equivalency between test article and COU device is established. Formal input-parameter equivalency scoring is not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were formally assessed; six were scoped as not-assessed at MRL 2. Of the seven assessed factors, six achieved their required levels. The Discretization Error factor achieved level 1 against a required level of 2; however, the team determined that the conservative bias of the hemolysis power-law model and the overall strength of the validation evidence — including strong output comparison metrics and high relevance of validation activities to the COU — provide sufficient confidence that the model will correctly rank hemolysis severity across the five operating points. On balance, the body of evidence supports a Medium assurance level and an Accepted decision for the intended COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
