    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid properties) documented and matched to simulation inputs within stated tolerances.",
      "rationale": "Laboratory test protocols from three independent facilities documented inlet flow rates (2–6 L/min ± 0.05 L/min), rotational speeds (2000–3500 RPM ± 10 RPM), and blood-analog viscosity (3.5 mPa·s ± 0.1 mPa·s). Simulation boundary conditions set to match nominal experimental values. Test condition fidelity assessed as level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (E_rms) between predicted and measured NIH values ≤ 10% across all five operating points, with uncertainty bounds overlapping experimental scatter.",
      "rationale": "Mean relative error in NIH across five operating points is 8.3%, nominally within the 10% threshold. However, uncertainty quantification of the output comparison was performed using only point estimates of experimental NIH without propagating inter-laboratory variability or blood-analog batch effects into the comparison metric. Consequently, the formal validation uncertainty budget is incomplete and the comparison is classified at level 2 rather than the required level 3. The mean error figure appears acceptable on its face, but the absence of a fully propagated uncertainty interval means the comparison cannot be confirmed to meet the level-3 requirement for rigorous uncertainty-inclusive agreement assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
