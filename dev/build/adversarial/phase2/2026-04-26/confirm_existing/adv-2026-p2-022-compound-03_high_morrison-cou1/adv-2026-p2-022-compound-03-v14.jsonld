  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; all test cases pass.",
      "rationale": "ANSYS Fluent 2022R2 used under ISO 13485-compliant QMS. Regression test suite of 47 canonical cases executed; all pass. Version control and change documentation verified by QA audit dated 2025-11-03."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least two benchmark problems with known analytical solutions.",
      "rationale": "Solver verified against the Hagen-Poiseuille laminar pipe flow and the lid-driven cavity benchmark at Re=1000. Errors within 0.3% and 1.1% respectively, consistent with second-order spatial accuracy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% on quantity of interest; observed order of accuracy within 10% of formal order.",
      "rationale": "Three systematically refined hexahedral meshes (2.1M, 6.8M, 19.4M cells) were evaluated. Richardson extrapolation yields an observed order of accuracy of 1.94. GCI on the bulk hemolysis index is 4.8% on the finest mesh, which is marginally below the 5% threshold. However, local GCI values in the impeller tip-gap region reach 11.3%, indicating unresolved spatial gradients in a hemolytically critical zone. The team judged the bulk metric sufficient and did not escalate the local exceedance; consequently the achieved gradation remains at 2 rather than the required 3 for this factor.",
      "note": "Local GCI exceedance in tip-gap region acknowledged but not escalated; bulk GCI used as primary acceptance metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented and traceable; boundary conditions reproduced within ±5%.",
      "rationale": "In-vitro test loop conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented with calibrated instrumentation. Boundary conditions reproduced within ±3.2% of nominal values across all five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized RMS error on primary QoI below 10%; systematic bias identified and quantified.",
      "rationale": "Normalized RMS error on relative hemolysis index is 7.4% across all operating points. A slight positive bias of 2.1% is observed at low-flow conditions, consistent with known turbulence model over-prediction of shear stress in recirculation zones. Bias is conservative relative to the RH < 1 acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (hemolysis index) directly maps to clinical endpoint; secondary QoIs support mechanistic understanding.",
      "rationale": "The relative hemolysis index (RHI) is the regulatory-accepted surrogate for pump-induced hemolysis per FDA guidance. Velocity magnitude and wall shear stress distributions are reported as secondary QoIs supporting mechanistic interpretation. Direct mapping to clinical endpoint confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid properties, and operating range overlap with COU envelope by at least 80%.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry — identical to the COU device family. Fluid properties (bovine blood, 37°C, 40% hematocrit) match COU conditions. All five COU operating points fall within the validated flow-speed envelope. Geometric similarity index 0.94."
    },
