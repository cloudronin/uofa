  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team reviewed all 13 credibility factors against the MRL 2 requirements. Seven factors were formally assessed; all seven were judged to meet their required levels based on the primary acceptance metrics. The local GCI exceedance in the impeller tip-gap region was noted in the discretization error factor narrative but was not considered sufficient to reduce the factor rating below the required level, given that the bulk hemolysis index GCI of 4.8% satisfies the 5% threshold. Six factors were appropriately scoped as not-assessed at MRL 2. The validation evidence base — comprising FDA benchmark PIV comparison, in-vitro hemolysis index validation, and a three-grid mesh refinement study — collectively supports a Medium assurance finding. The decision consequence is High and model influence is Medium, consistent with MRL 2 classification. The team concludes that the CFD model is credible for identifying worst-case hemolysis operating conditions for the Class II CPB device and that the RH < 1 acceptance criterion is met with adequate confidence.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
