  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the FDA centrifugal blood pump CFD hemolysis model at MRL 2. Seven factors were formally assessed; six were determined not required at MRL 2. Of the seven assessed factors, the team concluded that the overall body of evidence supports a Medium assurance level declaration. The validation campaign demonstrated favorable qualitative agreement between CFD predictions and experimental RHI values across all five operating points, the worst-case operating condition was correctly identified, and the mesh convergence study confirmed adequate numerical accuracy. The output comparison factor showed qualitative agreement within 15% of experimental measurements, which the team judged sufficient given the MRL 2 context and the confirmatory role of physical testing in the device development program. The decision to accept the model for the stated COU is supported by the totality of evidence reviewed.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
