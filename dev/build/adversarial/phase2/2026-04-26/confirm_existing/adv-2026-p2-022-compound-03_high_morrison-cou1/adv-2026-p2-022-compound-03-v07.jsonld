  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under configuration management with documented version control and regression test suite executed prior to production runs.",
      "rationale": "ANSYS Fluent 2022 R2 used under institutional configuration management. Version-controlled case files archived in Git repository. Solver regression tests executed and passed prior to production simulation runs. SQA level 2 requirements fully satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
