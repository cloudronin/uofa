  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-cb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 specifies a single standard configuration and the clinical loading envelope is narrow. Overall credibility evidence is judged sufficient to support the regulatory submission for the non-cannulated 7.5 mm pedicle screw construct. Re-validation of material input dataset DS001 against the February 2026 model revision is planned for Q2 2026.",
    "decidedAt": "2026-04-19T00:00:00Z"
