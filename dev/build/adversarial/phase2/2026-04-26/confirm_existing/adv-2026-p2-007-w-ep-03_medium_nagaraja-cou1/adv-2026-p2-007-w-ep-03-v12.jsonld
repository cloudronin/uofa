  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-dr001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieved level 2 against a required level 3 due to the single test condition evaluated under ASTM F1717; this gap is accepted given the prescriptive nature of the standard and the strong output comparison results (all E/uval < 1.96, all QoI differences < 10%). The material property dataset used for model inputs predates the current model revision; re-characterization is planned for the next qualification cycle and does not affect the current submission. Overall credibility is sufficient for a Medium model influence, Medium decision consequence Class II device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
