  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed the required credibility level. One factor (Test conditions) is below the required level (achieved 2, required 3) due to single-condition testing; this gap is accepted given that the COU is restricted to the single tested configuration and additional testing is planned. Overall credibility is sufficient to support the regulatory submission for the non-cannulated 7.5 mm pedicle screw construct.",
