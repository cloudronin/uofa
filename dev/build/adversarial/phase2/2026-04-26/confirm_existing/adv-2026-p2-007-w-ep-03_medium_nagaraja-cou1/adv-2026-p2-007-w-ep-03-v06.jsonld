  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software must operate under a documented quality management system with version control and regression testing.",
      "rationale": "Ansys Mechanical 2023 R2 is used under an ISO 9001-compliant QMS. Software release notes, installation qualification records, and regression test reports are archived in the project document control system. Version is locked for the duration of the submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems representative of the physics (linear elastic beam bending, contact) must be solved and compared to analytical solutions within 1% error.",
      "rationale": "Three verification benchmarks were executed: (1) cantilever beam deflection, (2) Hertzian contact between cylinders, and (3) bolt-preload in a bolted joint assembly. All benchmark results agree with analytical solutions to within 0.6%. Verification reports are on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change of <5% between successive refinements, with GCI reported.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw-rod interface. Stiffness QoI changed by 3.1% between coarse and medium meshes and by 0.9% between medium and fine meshes. Grid Convergence Index (GCI) for the fine mesh is 1.4%, satisfying the <5% criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must fall below 1e-6 for all load steps; energy balance error must be <0.1%.",
      "rationale": "Direct sparse solver (SPARSE) was employed for all static load steps. Residual force norms converged to below 1e-8 for every increment. Energy balance error across all load cases was 0.04%. No solver warnings or non-convergence events were recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be reviewed by an independent analyst; boundary condition application documented and traceable to test protocol.",
      "rationale": "An independent FEA analyst reviewed the model setup, boundary condition definitions, and load application against the ASTM F1717 test protocol. A formal peer-review checklist was completed and signed. No discrepancies were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection must be justified against material response observed in coupon data; contact formulation must be appropriate for the loading regime.",
      "rationale": "Linear elastic isotropic constitutive models are appropriate for the pre-yield stiffness regime targeted by the QoIs. Bilinear isotropic hardening is applied post-yield for the yield force QoI. Augmented Lagrangian frictional contact (mu=0.2) is used at screw-rod and rod-block interfaces, consistent with published tribological data for Ti-Ti contact."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to characterization data; sensitivity analysis must identify influential parameters.",
      "rationale": "Elastic modulus (E=114 GPa) and yield strength (Sy=880 MPa) for Ti-6Al-4V are drawn from the material property dataset (dataVintage 2025-09-15). Geometric dimensions are sourced from production CAD as-built files. A one-at-a-time sensitivity study identified E and Sy as the two most influential parameters; re-validation against the updated model geometry is planned following the next coupon characterization campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens must be production-representative; dimensional inspection records must be available.",
      "rationale": "All N=11 constructs were assembled from production-lot components. Dimensional inspection confirmed screw outer diameter 7.5±0.05 mm and rod diameter 5.5±0.03 mm for all specimens. Lot traceability records are archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of COU loading environments, or uncertainty introduced by single-condition testing must be bounded.",
      "rationale": "Testing was performed at a single load configuration (ASTM F1717 standard geometry, 5 mm/min displacement rate). The COU encompasses only this configuration, but the absence of multi-rate or multi-geometry data limits the ability to bound rate-dependent effects. This factor is below the required level; the gap is acknowledged and additional testing at an alternative displacement rate is planned."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters used in validation simulations must match those used in the COU prediction to within documented tolerances.",
      "rationale": "The validation simulations and the COU prediction use identical material property values, geometric dimensions, contact definitions, and boundary conditions. A parameter equivalency table mapping each model input to its source dataset is included in the V&V report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e/uval) must be computed for each QoI and must not exceed 1.96; percent difference must be <10%.",
      "rationale": "E/uval values of 0.87, 1.41, and 1.12 were computed for stiffness, yield force, and force at 40 mm respectively. All three QoIs satisfy both the E/uval < 1.96 and percent difference < 10% acceptance criteria. Uncertainty in experimental measurements was propagated using a Type A evaluation across the N=11 specimens."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be the same quantities used to support the regulatory decision.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the regulatory submission and are the same quantities extracted from both the FEA model and the bench test data. No surrogate or proxy QoIs are used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the COU that extrapolation uncertainty is negligible or bounded.",
      "rationale": "Validation experiments replicate the exact ASTM F1717 geometry, load mode, and specimen configuration specified in the COU. Both laboratories used calibrated load frames with NIST-traceable calibration records. The validation domain is co-incident with the COU domain; no extrapolation is required."
    }
