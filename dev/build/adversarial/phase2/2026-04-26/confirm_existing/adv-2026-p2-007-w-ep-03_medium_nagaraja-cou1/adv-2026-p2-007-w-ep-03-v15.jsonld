  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve factors meet or exceed the required level. One factor (Test conditions) achieved level 1 against required level 2; accepted based on documented clinical justification that compression-bending is the governing failure mode. All three primary QoI pass the pre-established acceptance bounds (<10% difference, E/uval < 1.96). Overall credibility sufficient to support regulatory submission for the non-cannulated pedicle screw design. Re-validation of material property inputs against the updated model revision (2026-02-14) is planned for Q2 2026.",
    "decidedAt": "2026-03-28T00:00:00Z"
  },
