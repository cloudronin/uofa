  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 1 vs. required 2) is mitigated by the direct relevance of the ASTM F1717 standard configuration to the COU and the conservative nature of the single-condition test. All three QoIs pass quantitative acceptance criteria. The assessment team accepts the model for the stated COU with the condition that a supplementary test series at an alternative offset is completed prior to use in a broader loading envelope. Note: material property and bench test datasets carry vintages from Q4 2025, predating the February 2026 model revision; re-validation against updated inputs is planned for Q2 2026.",
