  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed the required credibility level. The single shortfall — Test conditions (achieved Gradation 2 vs. required Gradation 3) — is accepted on the basis that ASTM F1717 specifies a single standardized loading configuration and the regulatory precedent for this test standard does not require multi-condition coverage. The E/uval metric is below 1.96 for all primary QoIs and mean absolute percent errors are below 10%. The overall credibility evidence is sufficient to support a Medium assurance level decision. Note: the material property and bench test datasets used to populate and validate the model predate the February 2026 model revision; re-validation against the updated model is planned for the subsequent submission cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
