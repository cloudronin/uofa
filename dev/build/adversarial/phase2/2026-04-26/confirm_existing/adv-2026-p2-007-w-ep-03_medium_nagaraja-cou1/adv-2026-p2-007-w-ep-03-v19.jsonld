  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-required factor (Test conditions, achieved 2 vs. required 3) is mitigated by the close agreement between FEA and experiment across both laboratories (maximum E/uval 1.41, maximum QoI difference 7.3%) and by the conservative nature of the single test condition for the regulatory submission. The overall credibility is sufficient to support a Medium-assurance regulatory claim for the non-cannulated 7.5 mm pedicle screw under ASTM F1717 static compression-bending. Note: the material property dataset (vintage 2025-08-22) and bench test dataset (vintage 2025-11-10) both predate the model revision of 2026-02-15; re-validation is planned for the next annual review cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
