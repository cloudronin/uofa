      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for all QoI at production mesh; Richardson extrapolation applied across at least three mesh refinement levels.",
      "rationale": "Three mesh densities evaluated (coarse: 85k elements, medium: 340k, fine: 1.36M). Richardson extrapolation yields GCI of 0.8% for stiffness, 1.2% for yield force, and 0.6% for force at 40 mm. Production mesh is medium density providing balance of accuracy and computational efficiency."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear residual convergence to 1e-4 relative tolerance; energy norm monitored at each load increment.",
      "rationale": "All analyses converged to relative residual below 1e-5 within 50 Newton-Raphson iterations per load step. Energy norm decreased monotonically. No divergence or spurious oscillations observed across the 11 model instances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and material assignments completed by a second analyst not involved in original model construction.",
      "rationale": "Independent review performed by senior biomechanics engineer (DePuy Synthes). Boundary conditions confirmed consistent with ASTM F1717 fixture geometry. Material assignments cross-checked against certified material test reports. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model (bilinear isotropic hardening) validated against coupon-level material characterization data; contact formulation appropriate for screw-rod and screw-vertebral body block interfaces.",
      "rationale": "Bilinear isotropic hardening parameters for Ti-6Al-4V ELI derived from uniaxial tensile tests (n=5 specimens per heat). Augmented Lagrange contact with friction coefficient 0.3 at all metal-on-metal interfaces. Model form assessed as appropriate for the compression-bending loading regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Geometric dimensions sourced from calibrated CMM measurements; material properties from certified test reports with documented uncertainty bounds.",
      "rationale": "Screw and rod geometry derived from CMM measurements (±0.01 mm tolerance). Material properties (E = 114 GPa, σ_y = 880 MPa, tangent modulus = 1.14 GPa) from certified mill test reports. Sensitivity analysis performed on ±5% variation in elastic modulus and yield strength; QoI variation within 2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 experimental constructs from production-representative components; traceability to manufacturing lot documented.",
      "rationale": "N=11 constructs assembled from production-representative components (same manufacturing lot as commercial product). Components inspected per incoming quality control protocol. Construct assembly performed by trained technicians following work instruction WI-F1717-NC-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios including at least two offset distances per ASTM F1717.",
      "rationale": "Testing conducted at single offset distance (50 mm) per ASTM F1717 standard configuration. While this represents the standard regulatory test condition, it does not span multiple offset distances. Achieved level is below required; this gap is noted and accepted given the regulatory precedent for single-condition F1717 testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrably equivalent to experimental test article and fixture configuration.",
      "rationale": "FEA geometry derived directly from CMM measurements of test articles. Boundary conditions replicate F1717 fixture constraints (fixed inferior block, superior block displacement-controlled at 1 mm/min equivalent). Material properties matched to certified lot data used for test articles. Equivalency confirmed by independent reviewer."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all QoI; percentage difference < 10% for mean predicted vs mean experimental values.",
      "rationale": "Stiffness: E/uval = 0.82, difference = 3.1%. Yield force: E/uval = 1.14, difference = 4.7%. Force at 40 mm: E/uval = 0.95, difference = 2.8%. All metrics satisfy pre-established acceptance criteria. Comparison conducted across both laboratory datasets independently."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to clinical failure modes and regulatory submission requirements for pedicle screw systems.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three primary outputs specified in ASTM F1717 and required by FDA guidance for pedicle screw 510(k) submissions. These QoIs are directly related to fatigue life prediction and intraoperative failure risk. Relevance is high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (non-cannulated 7.5 mm screw, F1717 compression-bending) is identical to the COU scenario in geometry, loading mode, and material.",
      "rationale": "Validation activities performed on the identical non-cannulated 7.5 mm pedicle screw geometry and material lot as the COU. Loading mode (ASTM F1717 static compression-bending) is the exact COU loading. Two independent laboratories provide cross-validation of experimental results. Relevance of validation activities to COU is assessed as complete."
