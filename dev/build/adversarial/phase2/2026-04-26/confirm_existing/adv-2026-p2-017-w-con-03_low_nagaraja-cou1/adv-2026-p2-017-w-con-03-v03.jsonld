      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating < 2% change in QoIs between successive refinement levels; GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed (coarse 42k, medium 118k, fine 312k elements). QoI change between medium and fine: stiffness 0.8%, yield force 1.1%, force at 40 mm 1.3%. GCI values 1.4–2.1%. All within criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals < 1e-6 for all load steps; energy balance error < 0.1%.",
      "rationale": "Newton-Raphson solver with line search. Force residuals converge to < 1e-7 at all 200 load increments. Energy balance error 0.04%. Solver error negligible relative to other uncertainty sources."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review; boundary condition and loading application verified by second analyst.",
      "rationale": "Simulation workflow documented in SOP-FEA-001 Rev C. Boundary conditions (fixed inferior block, displacement-controlled superior block per ASTM F1717) independently verified by second analyst. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear elastoplastic material model with isotropic hardening for titanium alloy; geometric nonlinearity enabled; contact modeled with augmented Lagrangian formulation.",
      "rationale": "Ti-6Al-4V modeled with bilinear isotropic hardening (E=114 GPa, sigma_y=880 MPa, E_t=1.14 GPa per ASTM F136 coupon data). Geometric nonlinearity (NLGEOM) active. Frictional contact (mu=0.2) at screw-rod and screw-block interfaces. Model form consistent with physical mechanisms governing compression-bending response."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon testing; geometry from CMM-verified CAD; uncertainty propagation via Monte Carlo (n=1000).",
      "rationale": "Elastic modulus, yield strength, and tangent modulus from 12 Ti-6Al-4V coupons per lot (CV < 3%). Geometry from CMM measurements of 5 production screws (dimensional tolerance ±0.01 mm). Monte Carlo uncertainty propagation (n=1000 samples) yields uval = 4.1% on stiffness QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 production-representative constructs from at least two independent lots; dimensional inspection confirming conformance to design specification.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from two production lots (Lot A: n=6, Lot B: n=5) tested across two laboratories. CMM inspection of all 11 screws confirms dimensional conformance. Samples are production-representative."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions spanning clinically relevant range of loading rates and fixation configurations; minimum two distinct test configurations.",
      "rationale": "Testing performed under a single ASTM F1717 standard configuration (10 mm/min displacement rate, standard UHMWPE blocks, 35 mm interbody distance). Only one test condition evaluated. Achieved level below required; gap acknowledged and accepted given primary validation objective is standard-condition comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and material inputs directly traceable to experimental setup parameters; equivalency documented in test-analysis correlation matrix.",
      "rationale": "Test-analysis correlation matrix maps each experimental parameter (block material, geometry, loading rate, fixture compliance) to corresponding FEA input. UHMWPE block modeled with E=1.0 GPa per supplier datasheet confirmed by compressive test. Displacement rate mapped to quasi-static FEA. Equivalency confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and relative error < 10% for all three QoIs; statistical comparison accounts for experimental variability.",
      "rationale": "All three QoIs (stiffness: E/uval=0.91, err=4.2%; yield force: E/uval=1.42, err=6.8%; force at 40 mm: E/uval=1.61, err=7.3%) satisfy both criteria. Experimental variability characterized by inter-laboratory coefficient of variation < 5%. Output comparison passed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) directly linked to clinical performance endpoints and regulatory submission requirements.",
      "rationale": "Construct stiffness relates to load sharing and adjacent segment effects. Yield force is the primary fatigue-life surrogate. Force at 40 mm displacement per FDA guidance document for pedicle screw systems. All three QoIs are standard ASTM F1717 outputs and directly relevant to regulatory decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
