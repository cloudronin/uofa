  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required gradation levels for medium model risk. The single below-requirement factor (Test conditions, achieved Gradation 2 vs. required 3) is accepted on the basis of regulatory precedent: FDA guidance and published ASTM F1717 submissions consistently accept single-condition compression-bending data for pedicle screw 510(k) submissions. All quantitative acceptance criteria (E/uval < 1.96, mean difference < 10%) are satisfied for all three primary QoIs across N=11 constructs at two independent laboratories. The overall credibility evidence is sufficient to support the regulatory claim.",
    "decidedAt": "2024-03-15T10:00:00Z"
