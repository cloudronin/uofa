  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2022 R2) holds ISO 9001 certification and vendor-supplied V&V documentation covering the linear static structural solver. Internal SOP controls version and license.",
      "rationale": "Ansys Mechanical is a commercially validated solver with documented QA processes. DePuy Synthes internal SOP DPS-SIM-001 mandates version-controlled installations and quarterly patch review. Gradation 2 is appropriate for medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10.1 Appendix B (cantilever beam, thick-walled cylinder) reproduced to within 0.5% of analytical solutions using the same solver settings applied to the pedicle screw model.",
      "rationale": "Three standard benchmark cases were executed prior to production runs. All results fell within 0.5% of closed-form solutions, confirming correct solver implementation for the element types and contact formulations used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 2% for all primary QoIs (stiffness, yield force, force at 40 mm displacement) using Richardson extrapolation across three mesh densities.",
      "rationale": "Mesh convergence study performed with coarse (element edge ~1.2 mm), medium (0.6 mm), and fine (0.3 mm) meshes. GCI values: stiffness 0.8%, yield force 1.1%, force at 40 mm 1.4%. All below 2% threshold. Medium mesh selected for production runs balancing accuracy and runtime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force and moment residuals converge below 1e-4 relative tolerance; energy residual below 1e-5 for each load step.",
      "rationale": "All nonlinear load steps converged within 15 iterations. Residual norms satisfied specified tolerances for every simulation in the ensemble. No divergence or excessive bisection events were recorded in solver logs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup (geometry, boundary conditions, material assignments, contact definitions) by a second qualified analyst using a documented checklist.",
      "rationale": "Model setup reviewed by a second senior FEA engineer against checklist DPS-CHK-FEA-017. All 42 checklist items verified. Two minor discrepancies (contact stiffness factor, titanium alloy density) corrected prior to production runs. No residual use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum isotropic linear-elastic model with nonlinear contact (augmented Lagrange) is justified by literature evidence and sensitivity analysis showing < 5% QoI sensitivity to plasticity inclusion at sub-yield load levels.",
      "rationale": "Published literature (Nagaraja et al. 2020, Goel et al. 2006) supports linear-elastic representation for stiffness and near-yield behavior of titanium pedicle screw constructs. Sensitivity study confirmed plasticity model changes stiffness prediction by < 3% and yield force by < 5% within the experimental scatter band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, nu, yield strength) sourced from certified material test reports for Ti-6Al-4V ELI; geometric inputs from CMM-verified CAD nominal dimensions with tolerance sensitivity analysis.",
      "rationale": "Material properties derived from lot-specific tensile test certificates (mean E = 114 GPa, nu = 0.33). CMM measurements on three production screws confirmed CAD nominal dimensions within ±0.05 mm. Tolerance sensitivity analysis showed QoI variation < 4%, within experimental scatter."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 test constructs assembled from production-representative screws and UHMWPE blocks; dimensional verification via CMM prior to testing; lot traceability documented.",
      "rationale": "Eleven constructs assembled per ASTM F1717 from production-lot screws (lot 2019-07-A). CMM verification confirmed all critical dimensions within drawing tolerances. Lot certificates retained. Sample size sufficient to characterize experimental variability (CV < 8% for all QoIs)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate the ASTM F1717 protocol including loading rate, environmental conditions, and fixture geometry; ideally across multiple load levels.",
      "rationale": "Testing performed strictly per ASTM F1717 at a single compression-bending load configuration (300 N axial, 10 mm/min). Only one test condition was evaluated; multiple load levels or angles were not explored. This limits Gradation achievement to 2 despite otherwise rigorous execution. This known gap is accepted given the regulatory precedent for single-condition F1717 submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model boundary conditions, loading, and geometry are demonstrably equivalent to test fixture setup; discrepancies quantified and shown to have < 5% effect on QoIs.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 fixture geometry (superior block fixed, inferior block loaded) using fixture CAD provided by the testing laboratory. Fixture compliance measured experimentally and incorporated as a spring element. Residual discrepancy in applied moment arm (< 0.3 mm) estimated to affect stiffness QoI by < 1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and mean percent difference < 10% for all three primary QoIs; comparison performed by independent analyst.",
      "rationale": "E/uval values: stiffness 0.84, yield force 1.12, force at 40 mm 0.97. Mean percent differences: stiffness 3.2%, yield force 5.7%, force at 40 mm 4.1%. All satisfy acceptance criteria. Independent comparison performed by FDA reviewer (documented in submission correspondence)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are clinically and regulatorily relevant metrics directly linked to construct performance and failure modes.",
      "rationale": "Stiffness governs load sharing with the spine; yield force and force at 40 mm displacement are the primary ASTM F1717 acceptance metrics used in FDA 510(k) submissions for pedicle screw systems. These QoIs directly characterize the risk of construct fatigue failure and revision surgery."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity geometry, material, loading, and scale are identical to the COU; no extrapolation beyond validated parameter space is required for the regulatory submission.",
      "rationale": "The validation model and test constructs use production-identical screw geometry (7.5 mm non-cannulated, 45 mm length), identical Ti-6Al-4V ELI material, and the exact ASTM F1717 loading protocol specified in the COU. No geometric or material extrapolation is required. The validation space fully encloses the COU parameter space."
    }
