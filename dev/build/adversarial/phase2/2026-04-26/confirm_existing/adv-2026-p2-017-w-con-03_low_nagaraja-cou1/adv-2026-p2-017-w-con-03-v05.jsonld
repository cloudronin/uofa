    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model and contact formulation justified by literature and sensitivity analysis; model form uncertainty quantified.",
      "rationale": "Ti-6Al-4V modeled as bilinear isotropic hardening (E=114 GPa, σy=880 MPa, Et=1.14 GPa) consistent with ASTM F136 coupon testing. Augmented Lagrangian contact with friction coefficient μ=0.15 (literature range 0.10–0.20). Sensitivity of stiffness QoI to μ: ±3.1%. Model form uncertainty estimated at ±4.2% via comparison to three independent modeling approaches. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs derived from measurements on the actual test lot; input uncertainty propagated to QoI uncertainty.",
      "rationale": "Geometric inputs from CMM measurements of three representative screws from the test lot (mean ± 1σ reported). Material properties from tensile coupon tests (n=5) on same Ti-6Al-4V lot. Input uncertainty propagated via Monte Carlo (N=1000 samples); combined input uncertainty contribution to stiffness QoI = ±3.8%. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples are production-representative; sample size sufficient for statistical characterization; traceability documented.",
      "rationale": "N=11 constructs assembled from production-lot screws (7.5 mm non-cannulated, lot TI-2021-447) and UHMWPE test blocks per ASTM F1717. Screws traceable to DePuy Synthes quality records. Sample size provides 90% confidence interval on mean stiffness of ±4.2%. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of COU operating conditions; multiple load levels or configurations tested.",
      "rationale": "Testing performed at a single load configuration per ASTM F1717 (compression-bending at 10° offset). Only one test condition evaluated; the COU encompasses a range of surgical implantation angles (5°–15°). Achieved Gradation 2 only: single test condition documented and controlled, but not varied to bracket COU space. This factor does not meet the required level; risk accepted by sponsor with commitment to future multi-angle testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs match experimental conditions within documented tolerances; any differences quantified and their effect on QoI assessed.",
      "rationale": "FEA boundary conditions replicate test fixture geometry (UHMWPE block dimensions, fixation bolt locations) within 0.1 mm. Applied displacement rate in quasi-static FEA matches test machine displacement rate (5 mm/min). Temperature equivalency confirmed (23±2°C lab, isothermal FEA). Residual differences in friction coefficient and block compliance assessed via sensitivity runs; combined effect <2% on stiffness QoI. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all QoIs; acceptance threshold pre-specified and met.",
      "rationale": "E/uval computed for stiffness (0.87), yield force (1.12), and force at 40 mm (0.91), all below pre-specified threshold of 1.96. Percentage differences 2.4%, 2.4%, and 2.3% respectively, all below 10% bound. Comparison performed blind (experimental results unsealed after FEA predictions finalized). Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected are directly linked to the COU decision; clinical and mechanical relevance justified.",
      "rationale": "Construct stiffness governs load sharing and adjacent segment mechanics. Yield force directly predicts onset of permanent deformation under physiological loading. Force at 40 mm displacement characterizes post-yield energy absorption relevant to fatigue life estimation. All three QoIs are standard ASTM F1717 metrics and directly support the 510(k) substantial equivalence argument. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
