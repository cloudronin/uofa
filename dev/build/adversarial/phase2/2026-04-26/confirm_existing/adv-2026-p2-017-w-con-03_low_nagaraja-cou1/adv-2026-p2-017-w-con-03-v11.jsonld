  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors met or exceeded required levels. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted given that ASTM F1717 is a standardized single-rate protocol and rate sensitivity is not expected for quasi-static titanium constructs. All QoI acceptance criteria satisfied (E/uval < 1.96; percent difference < 10%). Overall credibility sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw design.",
