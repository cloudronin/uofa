      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match COU operating envelope within stated uncertainty; all 5 flow-speed combinations must be represented.",
      "rationale": "Experimental data covers 3 of 5 required flow-speed combinations. Two high-speed low-flow conditions lack bench data. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) applied to hemolysis index predictions versus measurements with uncertainty bounds on both simulation and experiment.",
