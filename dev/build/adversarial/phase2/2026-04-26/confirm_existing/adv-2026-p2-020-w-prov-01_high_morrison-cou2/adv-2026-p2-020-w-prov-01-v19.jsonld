  "uofa:provenanceChain": [
    {
      "id": "https://uofa.net/synth/claim/cou2-hemolysis-cfd-acceptable",
      "type": "uofa:Claim",
      "name": "CFD hemolysis predictions are credible for Class III VAD acceptance decision",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/orphan-synthesis-node"
    },
    {
      "id": "https://uofa.net/synth/evidence/orphan-synthesis-node",
      "type": "uofa:Evidence",
      "name": "Synthesized hemolysis model evidence base",
      "description": "A synthesis of multiple prior studies examining the Giersiepen-Wurzinger and modified power-law hemolysis constitutive models, incorporating published shear-stress threshold data from at least six independent experimental campaigns (1990–2019). This node aggregates peer-reviewed hemolysis correlation coefficients, uncertainty bands from the Taskin et al. benchmark suite, and sensitivity indices from the Vitale et al. parametric study. The breadth of literature covered and the cross-laboratory consistency of the aggregated coefficients together constitute a well-established evidential foundation for the hemolysis model form adopted in this assessment."
    },
    {
      "id": "https://uofa.net/synth/activity/cfd-bench-comparison-run",
      "type": "prov:Activity",
      "name": "CFD bench comparison activity — FDA generic pump at 5 operating points",
      "prov:used": "https://uofa.net/synth/data/fda-pump-piv-dataset",
      "startedAtTime": "2025-11-10T08:00:00Z",
      "endedAtTime": "2025-11-14T17:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/data/fda-pump-piv-dataset",
      "type": "uofa:Dataset",
      "name": "FDA generic centrifugal pump PIV experimental dataset",
      "uofa:isFoundationalEvidence": true,
      "description": "Particle image velocimetry measurements from the FDA inter-laboratory study on the generic centrifugal blood pump, covering velocity fields at 2500 and 3500 RPM across three flow rates. Published under FDA Critical Path Initiative."
    },
    {
      "id": "https://uofa.net/synth/activity/mc-uq-run",
      "type": "prov:Activity",
      "name": "Monte Carlo uncertainty quantification run — hemolysis index",
      "prov:used": "https://uofa.net/synth/data/mc-uq-hemolysis-samples",
      "startedAtTime": "2025-12-01T09:00:00Z",
      "endedAtTime": "2025-12-03T18:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/data/mc-uq-hemolysis-samples",
      "type": "uofa:Dataset",
      "name": "Monte Carlo hemolysis index sample set (n=10000)",
      "uofa:isFoundationalEvidence": true,
      "description": "Ten-thousand Monte Carlo draws propagating uncertainty in hemolysis model coefficients (alpha, beta, C) through the CFD solver, producing empirical distributions of normalized index of hemolysis (NIH) at each of the five operating conditions."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression coverage exceeding 85% of relevant physics modules and traceable release management.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has a documented V&V test suite covering core fluid physics, but hemolysis-specific regression tests cover only 67% of relevant sub-models. Release management is traceable. Achieved level 3 falls below required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must be demonstrated for the hemolysis transport scalar equation with documented order-of-accuracy confirmation.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver but not for the passive scalar hemolysis transport equation. Order-of-accuracy is confirmed for velocity fields only. Gap reduces achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI-based discretization error estimate must be reported for hemolysis index QoI with GCI < 5% on the fine mesh.",
      "rationale": "Three-mesh GCI study was completed. GCI for velocity is 3.1% (fine mesh). GCI for hemolysis index is 8.4%, exceeding the 5% threshold. Discretization error is quantified but not within required bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must overlap with at least 80% of the COU operating envelope (flow rate, rotational speed, fluid properties).",
      "rationale": "FDA PIV data covers 2 of 5 target operating points. Fluid properties match (glycerol-water analog). Rotational speed range partially overlaps. Coverage is approximately 60%, below the 80% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., NRMSE or E_rel) must be reported for hemolysis index with uncertainty bounds, and metric must satisfy pre-specified acceptance threshold.",
      "rationale": "NRMSE for NIH predictions is 18.3% across validated operating points. Pre-specified threshold was 10%. Metric is computed with uncertainty but does not meet acceptance threshold. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH) must be the same scalar used in the regulatory acceptance criterion, with no surrogate or proxy substitution.",
      "rationale": "Validation uses NIH as the primary QoI, consistent with the regulatory threshold. However, the hemolysis model outputs a modified power-law index that requires a post-processing conversion step introducing additional uncertainty not fully characterized. Minor proxy gap reduces achieved level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry must be the same pump or a documented morphologically equivalent surrogate; operating regime must match COU flow-speed envelope.",
      "rationale": "Validation uses the FDA generic centrifugal pump, which is not the actual VAD device. Morphological similarity is argued but not quantitatively demonstrated. Operating regime partially overlaps. Relevance gap reduces achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, floating-point round-off, and solver residual tolerance effects on hemolysis QoI must be characterized.",
      "rationale": "Solver error characterization was not performed for this assessment. Residual tolerances are reported but their effect on NIH output was not propagated. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst-introduced errors (boundary condition setup, turbulence model selection, post-processing) must be assessed via independent re-simulation or formal review.",
      "rationale": "No independent re-simulation or formal use-error review was conducted. Single analyst performed all simulations. Use error is an unquantified epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the hemolysis constitutive equation (choice of power-law exponents and threshold) must be bounded via multi-model comparison or Bayesian model averaging.",
      "rationale": "Only a single hemolysis constitutive model (modified Giersiepen-Wurzinger) was employed. No multi-model comparison or Bayesian model averaging was performed. Model form uncertainty is the largest epistemic gap in this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters (viscosity, density, inlet velocity profile, rotational speed tolerance) must be characterized and propagated through the model.",
      "rationale": "Monte Carlo UQ was initiated for hemolysis model coefficients but input uncertainty for fluid properties and boundary conditions was not propagated. Partial UQ does not satisfy the required level 4 criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for lot-to-lot variability, storage conditions, and hemolytic baseline prior to pump exposure.",
      "rationale": "FDA PIV dataset uses glycerol-water analog fluid; no biological sample variability applies. However, for hemolysis validation sub-studies, test sample characterization was not documented. Factor flagged as not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters in the validation simulation must be demonstrated equivalent to those in the COU simulation within stated uncertainty bounds.",
      "rationale": "Equivalency of input parameters between validation runs (FDA pump, analog fluid) and COU runs (actual VAD device, blood analog) was not formally demonstrated. Geometric and rheological differences are noted but not quantitatively bounded."
    }
  ],
