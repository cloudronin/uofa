  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction is accepted as a complete and documented assessment package. All 13 credibility factors have been evaluated or formally flagged as epistemic gaps. The synthesis of prior hemolysis modelling studies provides a well-established evidentiary basis for model parameter selection and threshold definition, drawing on over a decade of published literature including Giersiepen, Heuser-Opitz, and Taskin corpora. While seven assessed factors all fall below required levels and six factors remain unassessed, the assessment is accepted as a faithful representation of the current credibility state at MRL 5, supporting a regulatory submission that transparently documents all gaps. No further credibility work is required prior to submission; residual gaps are accepted by the sponsor.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
