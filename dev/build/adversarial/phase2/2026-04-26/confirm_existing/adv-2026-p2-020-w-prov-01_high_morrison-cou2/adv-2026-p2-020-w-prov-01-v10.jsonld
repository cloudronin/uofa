  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full V&V plan, configuration management, and regression test suite covering hemolysis solver routines required at MRL 5.",
      "rationale": "Version control and unit testing are in place, but no formal V&V plan exists for the hemolysis post-processing module. Regression test coverage is 34%, below the 80% threshold required at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for momentum and scalar transport equations; manufactured solution test cases required.",
      "rationale": "Order-of-accuracy tests performed for momentum equations only. Hemolysis scalar transport equation has not been subjected to manufactured solution verification. Achieved level insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent with GCI < 2% on hemolysis index QoI; three systematically refined meshes required.",
      "rationale": "Three-mesh Richardson extrapolation completed; GCI for NIH is 4.7%, exceeding the 2% requirement at MRL 5. Mesh refinement near impeller blade trailing edges remains insufficient."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including hematocrit range 35–45%, temperature 37±0.5°C, and all five target flow-speed combinations.",
      "rationale": "Bench tests conducted at hematocrit 40% and 37°C for three of five operating points. Two high-speed operating points (6000 RPM) were not experimentally tested due to equipment limitations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or NRMSE) with uncertainty bounds on both simulation and experimental outputs; metric must be below 10% MAE.",
      "rationale": "Mean absolute error of 18.4% computed across three validated operating points. Experimental uncertainty bounds documented but simulation output uncertainty not fully propagated. Metric exceeds acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be directly the NIH as used in clinical acceptance criterion; surrogate or proxy QoIs are not acceptable at MRL 5.",
      "rationale": "Primary QoI is NIH, which is clinically relevant. However, the hemolysis model outputs a volume-averaged scalar that does not capture peak shear exposure paths through the impeller gap, which are the clinically dominant mechanism."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full VAD operating envelope and use clinically representative blood analog or porcine blood; FDA pump geometry must match COU geometry.",
      "rationale": "Validation used the FDA generic pump geometry, which is a reasonable analog but not identical to the target VAD impeller. Porcine blood used in three tests; bovine blood in the remaining two, introducing species-dependent rheology uncertainty not quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria, round-off error characterization, and solver tolerance sensitivity analysis required for hemolysis scalar transport.",
      "rationale": "Solver error for the hemolysis scalar transport equation has not been assessed. Residual convergence plots were not archived for the hemolysis sub-model runs. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal analyst qualification records and simulation execution checklist with independent review required.",
      "rationale": "No formal use-error assessment performed. Analyst qualifications documented informally; no independent review of simulation setup or post-processing steps conducted. Epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for power-law hemolysis model form including sensitivity to exponent values; alternative model forms (e.g., strain-based) must be evaluated.",
      "rationale": "Giersiepen power-law model selected without evaluation of alternative strain-based or mechanistic models. Sensitivity to exponent alpha and beta performed over ±10% range only; literature reports sensitivity of NIH up to 300% over plausible exponent range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All hemolysis model input parameters (blood viscosity, hematocrit, power-law constants) must have documented uncertainty distributions; Monte Carlo sampling must cover full clinical range.",
      "rationale": "Monte Carlo UQ implemented for inlet velocity and viscosity only. Power-law constants C, alpha, beta treated as fixed values from Giersiepen 1990; their uncertainty not propagated. Hematocrit variability not included in UQ."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of blood sample variability across replicates and donors; minimum sample size justification required.",
      "rationale": "Test sample characterization not performed. Blood samples used in bench tests not statistically characterized for donor variability. Number of replicates (n=3) not justified against required statistical power. Epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between validation experiment input parameters and COU operating conditions required; any differences must be bounded by sensitivity analysis.",
      "rationale": "No formal equivalency analysis conducted between FDA pump test conditions and target VAD COU. Operating pressure, temperature, and hematocrit differences between validation and COU not bounded. Epistemic gap at MRL 5."
    }
