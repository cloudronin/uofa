  "signature": "ed25519:9f1e2d3c4b5a6f7e8d9c0b1a2f3e4d5c6b7a8f9e0d1c2b3a4f5e6d7c8b9a0f1e",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented software QA plan with version control, regression testing, and traceability to requirements at Gradation 4.",
      "rationale": "The CFD solver has version control and unit tests but lacks a formal V&V plan traceable to regulatory requirements. Regression test suite covers only 60% of relevant flow regimes. Achieved level 2 is below the required level 4 for MRL 5 Class III devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for all governing equations relevant to hemolysis prediction, including scalar transport, at Gradation 4.",
      "rationale": "Order-of-accuracy testing was performed for momentum and continuity equations using manufactured solutions. Scalar transport equation used for hemolysis index was not independently verified. Achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QOI at all 5 operating points with GCI below 5% at Gradation 4.",
      "rationale": "Three-level mesh refinement study performed; GCI reported for velocity and pressure QOIs. GCI for hemolysis index QOI was computed at only 2 of 5 operating points. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions fully replicate COU operating envelope including blood analog fluid properties, pump speed range, and temperature control at Gradation 5.",
      "rationale": "Bench tests used porcine blood rather than human blood analog. Temperature was controlled to ±2°C but pump speed range covered only 3 of 5 target operating points. Fluid property mismatch introduces systematic bias in hemolysis index. Achieved level 3 is substantially below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE) computed for hemolysis index at all COU operating points with uncertainty bounds at Gradation 5.",
      "rationale": "Comparison between CFD predictions and experimental hemolysis index was performed graphically without a formal quantitative metric. Uncertainty bounds were not propagated from experimental measurement to the comparison metric. Achieved level 2 is far below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QOIs directly correspond to the hemolysis index used in the regulatory decision at Gradation 4.",
      "rationale": "The primary validation QOI is normalized index of hemolysis (NIH), which maps directly to the COU decision metric. However, the sub-lethal hemolysis threshold used in the clinical acceptance criterion was not explicitly linked to the NIH metric in the validation plan. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, flow conditions, and fluid properties representative of the COU at Gradation 5.",
      "rationale": "Validation was conducted on the FDA generic pump geometry, which shares topological similarity with the COU device but differs in impeller diameter by 18% and blade count. Flow conditions partially overlap the COU envelope. Achieved level 2 is far below required level 5 for Class III MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error quantified for hemolysis transport equation at Gradation 4.",
      "rationale": "Numerical solver error for the hemolysis scalar transport equation was not assessed. Residual convergence criteria were set for momentum and pressure but not explicitly for the hemolysis source term. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification, simulation execution checklist, and independent review of model setup at Gradation 4.",
      "rationale": "No formal use error assessment was performed. Analyst qualification records exist but were not reviewed against the simulation execution procedure. Independent review of boundary condition setup was not documented. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for power-law hemolysis model form with sensitivity analysis to alternative model forms at Gradation 5.",
      "rationale": "The power-law Giersiepen-Wurzinger hemolysis model was selected without documented comparison to alternative forms (e.g., strain-based or mechanistic models). Model form uncertainty is a primary source of epistemic uncertainty at MRL 5 and was not formally assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs characterized with probability distributions and propagated through Monte Carlo UQ at Gradation 5.",
      "rationale": "Monte Carlo UQ was performed on geometric tolerances and inlet boundary conditions but did not include hemolysis model coefficients (alpha, beta, C) as uncertain inputs. These coefficients carry substantial inter-study variability that was not propagated to the hemolysis index output distribution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood sample characterization including hematocrit, MCV, and donor variability documented and linked to experimental hemolysis measurements at Gradation 4.",
      "rationale": "Test sample characterization for the bench experiments was not documented in the credibility dossier. Hematocrit levels and donor variability data were referenced in the experimental report but not formally linked to the validation comparison. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and COU simulation inputs documented at Gradation 4.",
      "rationale": "No formal equivalency assessment was performed between the validation experiment input parameters and the COU simulation boundary conditions. Differences in inlet velocity profiles and fluid viscosity between bench and COU were noted informally but not quantified. Flagged as epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the COU2 VAD hemolysis prediction. Seven factors were formally assessed; all achieved levels fall below required levels for MRL 5. Six factors were flagged as not-assessed epistemic gaps. The multi-study hemolysis synthesis evidence node provides strong narrative support for the hemolysis sub-model selection and is treated as a well-established reference anchor in the dossier. Monte Carlo UQ was completed for geometric and boundary condition uncertainties. The overall package is accepted as a complete credibility submission for regulatory review, with identified gaps documented for remediation in the next assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
