  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-prediction-vad-cou2",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental-dataset",
    "https://uofa.net/synth/data/montecarlo-uq-hemolysis-runs"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison-2024",
      "type": "ValidationResult",
      "name": "Hemolysis index bench validation — FDA pump geometry, 5 operating points",
      "description": "CFD-predicted hemolysis index compared against in-vitro measurements at 5 flow-speed combinations on the FDA generic centrifugal pump. Mean absolute error 18.4% across operating points. Turbulence model sensitivity study included.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/bench-validation-campaign-2024",
      "uofa:isFoundationalEvidence": false
    },
    {
      "id": "https://uofa.net/synth/validation/prior-literature-synthesis-hemolysis",
      "type": "ValidationResult",
      "name": "Synthesis of prior hemolysis CFD validation studies (2010–2022)",
      "description": "A comprehensive synthesis of twelve prior published validation studies examining CFD-based hemolysis prediction in rotary blood pumps. Aggregates error metrics, turbulence model performance, and mesh sensitivity findings across multiple pump geometries and operating regimes. The synthesis provides contextual evidence that the power-law hemolysis model achieves acceptable predictive accuracy when mesh resolution exceeds 5 million cells and shear stress exposure time is computed via Lagrangian particle tracking. This node represents a consolidation of the community's accumulated validation knowledge and is treated as a foundational reference for the current assessment."
    },
    {
      "id": "https://uofa.net/synth/validation/montecarlo-uq-validation-result",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ validation — hemolysis index uncertainty bounds",
      "description": "Monte Carlo propagation of inlet boundary condition uncertainty and blood viscosity variability through the CFD model. 2000 samples; 95th-percentile hemolysis index remains below clinical threshold at 3 of 5 operating points.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/montecarlo-uq-campaign-2024",
      "uofa:isFoundationalEvidence": false
    }
  ],
