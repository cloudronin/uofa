  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment integrates bench validation results, Monte Carlo uncertainty quantification, and the comprehensive prior-literature synthesis covering twelve published hemolysis CFD validation studies (2010–2022). The synthesis node establishes that the power-law hemolysis model has a well-documented validation history across rotary blood pump geometries, providing sufficient contextual confidence to accept the overall evidence package. While several credibility factors exhibit gaps relative to MRL 5 requirements, the convergent evidence from the literature synthesis, combined with the direct bench comparison and UQ results, supports an Accepted outcome for the purposes of this assessment cycle pending resolution of identified gaps in subsequent submissions.",
