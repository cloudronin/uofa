  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; independent code review completed.",
      "rationale": "Solver is version-controlled and regression tests exist for canonical pipe flow, but hemolysis-specific regression tests are absent. Independent code review not performed. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for all governing equation terms including scalar transport used for hemolysis accumulation; method of manufactured solutions applied.",
      "rationale": "Order-of-accuracy verified for momentum equations only. Scalar transport equation used for hemolysis damage accumulation not independently verified. MMS not applied. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis index QoI on three systematically refined meshes meeting GCI < 5%.",
      "rationale": "Three-mesh Richardson extrapolation performed; GCI for velocity field is 3.8% but GCI for hemolysis index QoI is 14.2%, exceeding the 5% threshold. Achieved level 2 against required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match VAD operating envelope including hematocrit range, temperature, and pump speed; uncertainty in test conditions quantified and reported.",
      "rationale": "Hematocrit and temperature controlled within ±5% and ±1°C respectively. Pump speed uncertainty ±0.3%. Five operating points span intended VAD envelope. Partial match achieved; physiological blood analog used rather than human blood. Achieved level 3 against required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., MAPE, E_n) computed for hemolysis index at all operating points; metric accounts for combined experimental and simulation uncertainty.",
      "rationale": "MAPE computed at four of five operating points; low-flow high-speed outlier excluded from metric calculation due to suspected cavitation. Combined uncertainty not propagated into comparison metric. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs are identical to clinical decision QoIs (absolute hemolysis index); no surrogate or proxy metrics used in place of decision-driving output.",
      "rationale": "Hemolysis index is the direct clinical QoI and is used in validation. However, validation experiments measure NIH index while COU requires plasma-free hemoglobin index; conversion factor introduces additional uncertainty not fully characterized. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry is the actual VAD device geometry or a geometry with documented similarity argument; operating conditions span the full COU envelope including worst-case VAD operating points.",
      "rationale": "Validation performed on FDA generic pump geometry, not the actual VAD device geometry. Similarity argument between generic pump and specific VAD geometry not formally established. COU envelope partially covered. Achieved level 2 against required 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria tightened to demonstrate solver error is negligible relative to discretization error; floating-point reproducibility documented.",
      "rationale": "Solver convergence residuals reported but no formal analysis of solver error contribution relative to other error sources. Floating-point reproducibility not tested. Factor not assessed at required depth; assigned not-assessed with achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent simulation reproduction by second analyst; documented checklist for boundary condition specification and post-processing of hemolysis accumulation integral.",
      "rationale": "No independent reproduction performed. No formal use-error checklist documented. Epistemic gap at MRL 5; factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal model-form uncertainty quantification using multiple turbulence models and hemolysis damage accumulation model variants; sensitivity of hemolysis prediction to model form choices documented.",
      "rationale": "Single turbulence model (SST k-omega) used without model-form sensitivity study. Power-law hemolysis model selected based on literature synthesis (vr-literature-synthesis-hemolysis-models) but no alternative model forms evaluated in the current simulation campaign. Achieved level 2 against required 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs characterized with probability distributions; Monte Carlo or equivalent propagation demonstrates input uncertainty contribution to hemolysis index uncertainty is quantified and bounded.",
      "rationale": "Monte Carlo UQ performed for three input parameters; remaining inputs (wall roughness, blood analog rheology parameters, impeller geometry tolerances) treated as deterministic. Input uncertainty contribution partially quantified. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Multiple pump specimens tested to characterize manufacturing variability; statistical analysis of specimen-to-specimen hemolysis variability reported.",
      "rationale": "Single pump specimen used for all experimental measurements. Manufacturing variability not characterized. Sample-to-sample variability is an unquantified epistemic uncertainty at MRL 5. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between simulation input parameters and experimental conditions; any discrepancies quantified and their impact on QoI assessed.",
      "rationale": "No formal equivalency analysis performed between CFD boundary conditions and experimental setup. Inlet velocity profiles assumed uniform in simulation; actual experimental inlet conditions not characterized. Epistemic gap not resolved."
    }
