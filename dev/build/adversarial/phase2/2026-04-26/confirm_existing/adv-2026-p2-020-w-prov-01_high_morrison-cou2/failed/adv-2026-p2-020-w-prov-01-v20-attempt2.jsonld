  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression testing and version-controlled release notes covering all hemolysis-relevant physics modules.",
      "rationale": "The CFD solver has basic unit tests and a version-controlled repository, but no formal regression test suite covering the hemolysis transport scalar or the non-Newtonian viscosity module. SQA documentation does not meet MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification (method of manufactured solutions or equivalent) for all governing equations including hemolysis scalar transport.",
      "rationale": "Order-of-accuracy tests were performed for the Navier-Stokes solver but not for the hemolysis scalar transport equation. Code verification for the hemolysis constitutive model is absent."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence index (GCI) study with three systematically refined grids; GCI < 5% on hemolysis index QoI.",
      "rationale": "Three-level grid refinement study was performed. GCI on hemolysis index ranges from 8–14% across operating points, exceeding the 5% acceptance threshold. Spatial discretization error is not adequately controlled."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be fully characterized including blood analog rheology, temperature, hematocrit, and pump inlet/outlet boundary conditions with stated uncertainties.",
      "rationale": "Temperature and hematocrit were reported but inlet velocity profile and turbulence intensity at pump inlet were not measured. Boundary condition uncertainty is not quantified, limiting the ability to reproduce experimental conditions in CFD."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E-metric or normalized RMSE) between CFD predictions and experimental hemolysis index with uncertainty overlap assessment.",
      "rationale": "Normalized RMSE across 5 operating points is 18.3%. Uncertainty bands overlap at 3 of 5 points. Systematic overprediction at high-speed conditions suggests model form inadequacy not captured by UQ bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (hemolysis index) must be directly the clinical decision QoI with no intermediate surrogate mapping required.",
      "rationale": "The hemolysis index computed in CFD is the modified index of hemolysis (MIH) which requires an empirical conversion factor to relate to the clinical normalized index of hemolysis (NIH). This surrogate mapping introduces additional unquantified uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on a device geometrically and operationally representative of the COU VAD, not only on the generic FDA benchmark pump.",
      "rationale": "All validation activities used the FDA generic centrifugal pump benchmark geometry. No validation data exists for the specific VAD geometry under COU conditions. The geometric and operational gap between benchmark and COU device is not bridged."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point error bounds must be documented for all simulations; residual histories archived.",
      "rationale": "Solver convergence residual histories were not archived for the Monte Carlo ensemble runs. Iterative convergence error is unquantified across the 500-sample UQ ensemble. Factor not assessed due to missing simulation metadata."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and independent peer review of simulation setup for at least one representative operating point.",
      "rationale": "No user qualification records were provided. Independent peer review of simulation setup was not performed. Use error factor cannot be assessed at MRL 5 without these records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model form uncertainty with sensitivity analysis across at least three candidate model forms.",
      "rationale": "Only one turbulence model (SST k-omega) and one hemolysis model (modified Giersiepen-Wurzinger) were used. No model form sensitivity study was conducted. Model form uncertainty is the dominant unquantified uncertainty source at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All hemolysis model input parameters must have documented sources with stated probability distributions; Monte Carlo sampling must cover the full parameter space.",
      "rationale": "Monte Carlo UQ was performed on 6 of 9 hemolysis model parameters. Three parameters (red blood cell membrane viscosity, exposure time threshold, and aggregation coefficient) were held fixed at nominal values without uncertainty characterization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog sample characterization must include donor variability, storage time effects, and hematocrit measurement uncertainty; minimum n=5 independent sample preparations.",
      "rationale": "Test sample characterization data was not available for review. Donor variability and storage effects on hemolysis measurements are uncharacterized. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between validation experiment input parameters and COU operating conditions must demonstrate equivalency or quantify the extrapolation distance.",
      "rationale": "No formal equivalency mapping between FDA benchmark pump operating conditions and the COU VAD operating envelope was performed. The extrapolation from benchmark to COU conditions is unquantified. Factor not assessed."
    }
  ],
