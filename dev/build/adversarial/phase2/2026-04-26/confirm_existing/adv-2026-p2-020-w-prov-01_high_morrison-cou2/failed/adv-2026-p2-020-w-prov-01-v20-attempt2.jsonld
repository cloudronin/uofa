      "id": "https://uofa.net/synth/evidence/ev-synthesis-prior-studies",
      "type": "uofa:Evidence",
      "name": "Synthesis of prior hemolysis modelling studies (2010–2022)",
      "description": "A comprehensive synthesis of twelve prior computational and experimental hemolysis studies spanning turbulent and laminar shear-stress exposure models, including the Giersiepen-Wurzinger, Heuser-Opitz, and modified power-law formulations. The synthesis consolidates model form uncertainty estimates and empirical coefficients from multiple peer-reviewed sources, providing a consolidated prior distribution for hemolysis model parameters used in the Monte Carlo UQ sweep. This node represents the aggregated epistemic foundation for the hemolysis constitutive model choice."
    },
    {
      "id": "https://uofa.net/synth/activity/act-hemolysis-cfd-runs-2024",
      "type": "prov:Activity",
      "name": "CFD hemolysis simulation campaign — 5 operating points, Monte Carlo UQ",
      "prov:used": "https://uofa.net/synth/data/fda-pump-hemolysis-invitro",
      "startedAtTime": "2024-01-15T08:00:00Z",
      "endedAtTime": "2024-03-22T17:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/data/fda-pump-hemolysis-invitro",
      "type": "uofa:Dataset",
      "name": "FDA generic centrifugal pump in-vitro hemolysis measurements",
      "uofa:isFoundationalEvidence": true,
      "description": "In-vitro hemolysis index measurements for the FDA generic centrifugal blood pump benchmark model collected under ISO 10993-4 protocol across 5 flow-speed operating points. Serves as the experimental ground truth for hemolysis validation."
    },
