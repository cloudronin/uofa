  "synthetic": true,
  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed. This package encodes a multi-hop provenance chain anchored to foundational experimental datasets and a literature-synthesis intermediate node whose upstream provenance edges were inadvertently omitted during encoding.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-vad-cou2",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-piv-dataset",
    "https://uofa.net/synth/data/hemolysis-index-experimental-series"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-benchmark-result-01",
      "type": "ValidationResult",
      "name": "CFD hemolysis index vs. experimental benchmark — FDA pump geometry",
      "description": "Comparison of CFD-predicted normalized index of hemolysis (NIH) against in-vitro measurements across five operating points. Achieved agreement within 18% at all operating points.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/cfd-validation-run-2025q3",
      "prov:wasDerivedFrom": "https://uofa.net/synth/claim/cfd-hemolysis-vad-cou2"
    },
    {
      "id": "https://uofa.net/synth/validation/shear-stress-transport-result-02",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation — centrifugal impeller",
      "description": "PIV-derived wall shear stress fields compared with SST k-omega CFD predictions. Spatial correlation coefficient 0.91 across measurement planes.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/piv-cfd-comparison-2025q2",
      "prov:wasDerivedFrom": "https://uofa.net/synth/claim/cfd-hemolysis-vad-cou2"
    },
    {
      "id": "https://uofa.net/synth/validation/literature-synthesis-result-03",
      "type": "ValidationResult",
      "name": "Cross-study hemolysis model calibration synthesis",
      "description": "A synthesis of multiple prior studies examining power-law hemolysis model coefficients (C, alpha, beta) across seven published experimental datasets from 2008–2022. The synthesis harmonises parameter estimates from Giersiepen (1990), Zhang (2011), Taskin (2012), Goubergrits (2016), and three additional unpublished FDA internal datasets, yielding a pooled posterior distribution over model coefficients used to constrain the Monte Carlo UQ inputs for this COU. The breadth of evidence and the rigorous Bayesian pooling procedure give this synthesis strong epistemic standing as a near-foundational reference for hemolysis coefficient uncertainty."
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-result-04",
      "type": "ValidationResult",
      "name": "Grid convergence index assessment — pump volute and impeller passage",
      "description": "Richardson extrapolation-based GCI computed on three systematically refined meshes (2.1M, 8.4M, 33.6M cells). GCI < 2.3% for NIH at all operating points.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-refinement-study-2025q1",
      "prov:wasDerivedFrom": "https://uofa.net/synth/claim/cfd-hemolysis-vad-cou2"
    }
  ],
