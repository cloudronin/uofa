  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; independent code review completed.",
      "rationale": "The CFD solver (OpenFOAM v2212) is version-controlled and has a regression test suite, but the suite does not include hemolysis-specific benchmark cases. Independent code review was not completed for the custom hemolysis transport scalar. Achieved level 3; required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to the hemolysis scalar transport equation; order-of-accuracy confirmed for at least two mesh refinement levels.",
      "rationale": "MMS was applied to the Navier-Stokes solver but not extended to the power-law hemolysis scalar transport sub-model. Observed order of accuracy for velocity field is 1.92 (expected ~2). Hemolysis scalar verification incomplete. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for NIH QoI on three systematically refined meshes; spatial and temporal convergence demonstrated.",
      "rationale": "Richardson extrapolation GCI < 2.3% for NIH across all five operating points on three mesh levels. Temporal convergence confirmed via halved time-step sensitivity study. Achieved level 4; meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid rheology, temperature, hematocrit, pump geometry) documented and traceable to calibrated instruments with uncertainty budgets.",
      "rationale": "Test fluid was bovine blood at 37°C, 35% hematocrit. Temperature and hematocrit were measured with calibrated instruments. However, uncertainty budgets for viscosity and density were not formally documented. Geometry was verified via CMM. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rms or validation uncertainty U_val) computed for NIH at all five operating points; comparison against validation uncertainty band.",
      "rationale": "NIH comparison shows 18% maximum deviation. Validation uncertainty was estimated but not formally propagated through the experimental uncertainty chain. Metric falls short of a complete U_val assessment. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoIs (NIH, wall shear stress) are directly used in the COU decision metric; mapping between validation QoIs and COU QoIs is documented.",
      "rationale": "NIH is the primary COU QoI and is directly measured in validation experiments. Wall shear stress is a surrogate. The mapping from WSS to NIH involves the power-law model whose coefficients carry large uncertainty (addressed in synthesis result 03). Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the FDA generic pump geometry at VAD operating conditions (flow 3–6 L/min, speed 2400–3200 RPM); blood analog or bovine blood used.",
      "rationale": "Validation used the FDA generic centrifugal pump with bovine blood at three of the five COU operating points. Two high-speed operating points (3200 RPM) were not covered by validation experiments. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to < 1e-5 for all transport equations; mass imbalance < 0.01%.",
      "rationale": "Pressure and velocity residuals converge to 1e-4; hemolysis scalar residual stalls at 8e-4 for the highest-speed operating point due to steep shear gradients near the impeller tip. Mass imbalance 0.008%. Achieved level 2; required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol reviewed by independent analyst; boundary condition specification verified against experimental setup.",
      "rationale": "Simulation protocol exists but was not reviewed by an independent analyst. Boundary conditions were verified against experimental setup for inlet flow rate only; outlet pressure boundary was assumed atmospheric without explicit experimental confirmation. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified with sensitivity study; power-law hemolysis model form uncertainty quantified via alternative model comparison.",
      "rationale": "SST k-omega selected without sensitivity comparison to RSM or LES. Power-law hemolysis model form uncertainty was not assessed via alternative model comparison. The literature synthesis (result 03) partially addresses coefficient uncertainty but not model-form uncertainty. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo UQ performed on all influential model inputs (hemolysis coefficients C, alpha, beta; blood viscosity; inlet flow rate); Sobol sensitivity indices computed.",
      "rationale": "Monte Carlo UQ was performed on hemolysis coefficients using the pooled posterior from the literature synthesis. Blood viscosity and inlet flow rate were treated as deterministic. Sobol indices were not computed. Achieved level 2; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of biological variability in blood samples used for hemolysis measurement; minimum n=5 independent donors per operating point.",
      "rationale": "Test sample biological variability was not characterized. All experiments used a single bovine blood pool per session. Donor-to-donor variability was not assessed. This factor is flagged as an epistemic gap at MRL 5. Achieved level 1 (not assessed)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that validation experiment input parameters (geometry, fluid properties, operating conditions) are representative of COU inputs within quantified tolerances.",
      "rationale": "No formal equivalency argument was constructed. The FDA generic pump geometry is a simplified representation; the COU device geometry differs in impeller blade count and volute clearance. Equivalency was assumed implicitly. Flagged as epistemic gap. Achieved level 1."
    }
  ],
