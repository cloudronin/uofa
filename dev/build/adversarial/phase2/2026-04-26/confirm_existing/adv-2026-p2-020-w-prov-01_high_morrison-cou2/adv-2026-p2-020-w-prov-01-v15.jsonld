  "hasEvidence": [
    {
      "id": "https://uofa.net/synth/evidence/literature-synthesis-hemolysis-models",
      "type": "uofa:Evidence",
      "name": "Synthesis of hemolysis model literature for power-law damage accumulation",
      "description": "A comprehensive synthesis of twelve published studies examining power-law hemolysis damage accumulation models in rotary blood pumps, including the Giersiepen, Zhang, and Taskin formulations. The synthesis reconciles conflicting empirical coefficients across experimental platforms (cone-and-plate viscometers, Couette devices, and capillary tubes) and proposes a unified parameter set for CFD application to centrifugal pump geometries. Particular attention is given to the exposure-time dependence of red blood cell fragility under pulsatile shear conditions relevant to VAD operation. This evidence node consolidates the mechanistic and empirical basis for the hemolysis submodel employed in the present CFD analysis and reflects expert consensus across the biofluid mechanics community as of the assessment date.",
      "uofa:evidenceType": "LiteratureSynthesis",
      "uofa:qualityRating": "Moderate"
    },
    {
      "id": "https://uofa.net/synth/evidence/fda-pump-experimental-dataset",
      "type": "uofa:Evidence",
      "name": "FDA generic centrifugal pump experimental hemolysis dataset",
      "description": "Experimental measurements of normalized index of hemolysis (NIH) collected by the FDA Critical Path initiative across five operating conditions. Measurements were obtained using standardized porcine blood with controlled hematocrit. Dataset includes uncertainty bounds from inter-laboratory round-robin testing.",
      "uofa:isFoundationalEvidence": true,
      "prov:wasDerivedFrom": "https://doi.org/10.1115/1.4037671"
    }
  ],
  "hasActivity": [
    {
      "id": "https://uofa.net/synth/activity/cfd-hemolysis-simulation-run",
      "type": "prov:Activity",
      "name": "CFD hemolysis simulation execution — 5 operating points",
      "description": "RANS-based CFD simulation of the FDA generic centrifugal pump at 5 flow-speed combinations using OpenFOAM 8. Power-law hemolysis model integrated as a passive scalar transport equation. Monte Carlo perturbation of inlet boundary conditions performed over 200 samples.",
      "prov:used": "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
      "prov:wasAssociatedWith": "https://uofa.net/synth/org/morrison-lab-uofa"
    },
    {
      "id": "https://uofa.net/synth/activity/mesh-refinement-study",
      "type": "prov:Activity",
      "name": "Mesh independence and GCI study",
      "description": "Systematic mesh refinement study using three grid levels (coarse: 2.1M cells, medium: 6.8M cells, fine: 18.4M cells). Grid convergence index computed per Roache methodology. Wall shear stress fields extracted for hemolysis source term evaluation.",
      "prov:used": "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
      "prov:wasAssociatedWith": "https://uofa.net/synth/org/morrison-lab-uofa"
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software verification plan with traceability to requirements; regression test suite covering hemolysis transport solver; configuration management with tagged releases.",
      "rationale": "OpenFOAM 8 used without formal SQA plan. Regression tests exist for base flow solver but not for the custom hemolysis scalar transport UDF. No tagged release or configuration baseline documented for this analysis. Achieved level 2 (basic version control only)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent for hemolysis transport equation; convergence order verification for all active solvers.",
      "rationale": "MMS applied to base Navier-Stokes solver confirming second-order spatial accuracy. Hemolysis power-law transport equation not subjected to independent MMS verification. Convergence order for the damage accumulation scalar not confirmed. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for hemolysis index QoI; boundary layer resolution y+ < 1 at pump blade surfaces; Richardson extrapolation applied to primary QoI.",
      "rationale": "GCI computed at 12% for hemolysis index — above the 5% threshold. Velocity field GCI of 2.3% is acceptable. y+ values range from 0.8 to 3.1 on blade surfaces; near-wall hemolysis source term sensitive to this variation. Richardson extrapolation applied to NIH at all 5 operating points. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions fully characterised including blood rheology, temperature, hematocrit, and pump inlet/outlet pressure; uncertainty bounds reported for all boundary conditions.",
      "rationale": "FDA benchmark dataset provides hematocrit and flow rate data with uncertainty. Temperature variation during testing not fully documented. Blood viscosity model used in CFD (Carreau-Yasuda) calibrated to literature values rather than test-specific measurements. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Prediction error within experimental uncertainty bands for all 5 operating points; statistical metric (e.g., U95 validation metric) reported; systematic bias quantified.",
      "rationale": "Prediction error ranges from 18% to 47% of experimental NIH values — substantially outside experimental uncertainty bands at 3 of 5 operating points. Systematic over-prediction at high flow rates suggests hemolysis model coefficient mismatch. U95 validation metric not computed. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI in validation activity (NIH) directly maps to COU decision metric (absolute hemolysis threshold); same spatial averaging and integration procedure used in validation and COU application.",
      "rationale": "NIH used in both validation and COU application. Spatial integration procedure consistent. However, validation geometry (FDA generic pump) differs from VAD target geometry in impeller blade count and tip clearance, introducing QoI relevance uncertainty. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed at flow conditions, geometric scales, and operating regimes representative of the VAD COU; gap analysis between validation domain and COU domain documented and bounded.",
      "rationale": "FDA generic pump benchmark provides the only available hemolysis validation dataset. Operating pressure head (4–8 mmHg) is substantially lower than VAD operating range (60–120 mmHg). Reynolds number similarity not maintained. Gap between validation domain and COU domain is large and not formally bounded. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to 10^-6 for all residuals; round-off error assessed; solver settings documented and justified.",
      "rationale": "Continuity residual converges to 10^-4; momentum residuals to 10^-5. Hemolysis scalar residual plateaus at 10^-3 for high-speed operating points, suggesting unresolved numerical stiffness in the damage accumulation source term. Round-off error not assessed. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition specification, and post-processing procedures; checklist-based verification of analyst inputs.",
      "rationale": "No independent review of simulation setup performed. Analyst self-verification only. No formal use-error checklist applied. Flagged as epistemic gap at MRL 5. Achieved level 1 (no evidence of use-error controls)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection justified for rotating machinery hemolysis prediction; hemolysis constitutive model form validated against mechanistic red blood cell damage data; model form uncertainty quantified.",
      "rationale": "SST k-omega turbulence model selected without systematic comparison to LES or DNS reference data for pump geometries. Power-law hemolysis model form not independently validated against single-pass shear experiments at VAD-relevant shear rates. Model form uncertainty not quantified. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters characterised with probability distributions; sensitivity analysis identifies dominant inputs; Monte Carlo UQ propagates full input uncertainty to hemolysis QoI.",
      "rationale": "Monte Carlo UQ performed on inlet flow rate and rotational speed (2 parameters). Hemolysis model coefficients (alpha, beta, C in power-law) treated as fixed point estimates despite known inter-study variability of up to 300%. Blood viscosity parameters not included in UQ. Dominant uncertainty source not identified. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood samples characterised for age, storage conditions, and donor variability; sample-to-sample variability quantified and propagated to NIH measurements.",
      "rationale": "FDA benchmark dataset uses pooled porcine blood; donor variability and blood age not reported in available dataset documentation. Sample characterisation insufficient for MRL 5 requirements. Not assessed — flagged as epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis demonstrating that CFD input parameters (geometry, boundary conditions, material properties) in the validation activity match those in the COU application within quantified tolerances.",
      "rationale": "No formal equivalency analysis performed. VAD target geometry differs from FDA benchmark in impeller diameter, blade angle, and volute design. Inlet velocity profiles for VAD application derived from 1D lumped-parameter model not validated against in vitro measurements. Not assessed — flagged as epistemic gap. Achieved level 1."
    }
