  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-vad-cou2",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-geometry-mesh",
    "https://uofa.net/synth/data/hemolysis-experimental-reference",
    "https://uofa.net/synth/data/monte-carlo-uq-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-level hemolysis index comparison against FDA pump experimental data",
      "description": "CFD-predicted hemolysis index values compared against published experimental measurements for the FDA generic centrifugal pump across 5 operating points. Normalized index error ranges from 18% to 41%, exceeding the 10% acceptance criterion at all operating points.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-validation-run-2024",
      "uofa:isFoundationalEvidence": false
    },
    {
      "id": "https://uofa.net/synth/validation/multi-study-synthesis",
      "type": "ValidationResult",
      "name": "Cross-study synthesis of hemolysis model performance across centrifugal pump geometries",
      "description": "A synthesis of multiple prior studies examining CFD hemolysis model fidelity across a range of centrifugal pump geometries, including the Medtronic HeartWare HVAD, the Abbott HeartMate 3, and three academic benchmark geometries. Aggregated across 47 simulation campaigns from 2009 to 2022, the synthesis characterises the distribution of normalized hemolysis index error as a function of mesh resolution, turbulence model selection, and blood damage model variant. The synthesis concludes that power-law hemolysis models consistently underpredict peak shear-stress exposure in gap regions by 15–30%, a finding directly relevant to the FDA pump COU2 assessment. This node represents a rich secondary evidence source that informed the credibility factor ratings for model form and model inputs.",
      "uofa:isFoundationalEvidence": false
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification",
      "description": "Richardson extrapolation applied across three mesh refinement levels (3.2M, 9.7M, and 28.1M cells) for the FDA pump geometry. Grid convergence index computed for velocity magnitude and wall shear stress. Asymptotic convergence confirmed for bulk flow quantities; hemolysis-weighted shear stress shows 8.3% GCI at finest mesh.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-convergence-activity",
      "uofa:isFoundationalEvidence": false
    }
  ],
