  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors and the multi-study synthesis provenance, the assessment team determined that the cumulative evidence base — anchored by the Giersiepen-Zhang-Taskin-Bludszuweit synthesis and supported by FDA pump experimental data — provides sufficient credibility for regulatory submission at this stage. Residual gaps in model form and test sample factors are acknowledged and flagged for resolution in subsequent iterations. The provenance chain from the primary claim through the bench validation result to the multi-study synthesis is considered complete by the team, and the UQ results independently corroborate the hemolysis predictions within the accepted tolerance band.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
