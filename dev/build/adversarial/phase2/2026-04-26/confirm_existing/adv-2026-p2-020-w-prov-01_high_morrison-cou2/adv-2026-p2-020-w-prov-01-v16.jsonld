  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and documented V&V test suite covering hemolysis-relevant flow regimes.",
      "rationale": "The CFD solver holds ISO 9001 certification and a documented regression test suite exists, but coverage of high-shear hemolysis-specific cases is incomplete. Achieved level 3 falls below required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution verification must demonstrate second-order spatial convergence for all transported quantities including scalar hemolysis index.",
      "rationale": "Method of manufactured solutions confirms second-order convergence for velocity and pressure; hemolysis scalar transport verification is limited to first-order confirmation. Gap remains at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 2% for hemolysis index QoI across all five operating points.",
      "rationale": "GCI computed via Richardson extrapolation on three mesh levels; mean GCI is 3.8% across operating points, exceeding the 2% threshold. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including hematocrit range 35–45%, temperature 37±1°C, and all five target flow-speed combinations.",
      "rationale": "FDA pump experiments covered four of five operating points; hematocrit range was 38–42%, within specification. Temperature control was ±2°C, slightly outside the ±1°C requirement. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised RMS error between predicted and measured hemolysis index must be below 15% across all assessed operating points.",
      "rationale": "Normalised RMS error is 19.3% across four assessed operating points, exceeding the 15% threshold. Systematic over-prediction at high speed noted. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be absolute hemolysis index directly comparable to clinical threshold without normalisation to predicate device.",
      "rationale": "The model outputs absolute hemolysis index (mg/dL per 100 L) directly comparable to the clinical threshold of 0.01 g/dL. QoI relevance is fully established. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, blood analogue fluid properties, and operating range as the COU.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry, which is the reference geometry for the COU. Glycerol-water blood analogue was used rather than porcine blood, introducing a fluid-property gap. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must reach residuals below 1e-6 for all equations; floating-point round-off analysis must be documented.",
      "rationale": "Residuals reach 1e-5 for the hemolysis scalar equation; floating-point round-off analysis is absent. Achieved level 2 falls below required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent expert review of simulation setup and post-processing scripts must be documented.",
      "rationale": "No independent expert review of simulation setup has been conducted. Use error assessment is flagged as an epistemic gap at MRL 5. Achieved level 2 by default."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to turbulence model selection and hemolysis power-law exponent must be quantified.",
      "rationale": "Model form uncertainty due to turbulence model choice (SST k-ω vs. RSM) and hemolysis exponent variability has not been systematically assessed. Significant epistemic gap at MRL 5. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All boundary conditions and material properties must be traceable to measurement or published standards with documented uncertainty bounds.",
      "rationale": "Inlet velocity profiles and outlet pressure conditions are traceable to PIV measurements. Blood viscosity parameters are drawn from published standards. Uncertainty bounds on red blood cell fragility parameter are not documented. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At least three independent experimental replicates per operating point must be available for statistical comparison.",
      "rationale": "Only single experimental replicates are available for three of five operating points. Statistical repeatability cannot be established. Test sample adequacy not assessed; epistemic gap flagged. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment input parameters and COU input parameters must be formally demonstrated via parameter space mapping.",
      "rationale": "No formal parameter space mapping has been performed between the FDA pump validation experiments and the target VAD COU. Equivalency of inlet hematocrit, pump speed, and fluid temperature is assumed but not demonstrated. Achieved level 2."
    }
