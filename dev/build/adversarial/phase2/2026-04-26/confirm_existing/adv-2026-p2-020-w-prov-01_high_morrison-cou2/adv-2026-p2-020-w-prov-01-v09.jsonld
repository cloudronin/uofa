  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for Class III VAD simulation must demonstrate version-controlled, regression-tested solver with documented QA plan meeting MRL 5 requirements (Gradation 4).",
      "rationale": "Solver (ANSYS Fluent 2023R2) has documented QA plan and regression suite, but independent third-party audit has not been performed. Version control is maintained; however, hemolysis user-defined function (UDF) lacks formal unit testing. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or equivalent code verification must confirm spatial and temporal discretization order of accuracy for both flow and hemolysis transport equations at Gradation 4.",
      "rationale": "Method of manufactured solutions (MMS) applied to Navier-Stokes equations confirms second-order spatial accuracy. Hemolysis power-law transport equation not independently verified via MMS. Temporal discretization order not formally confirmed. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must demonstrate GCI < 2% for all hemolysis QoIs across all 5 COU operating points at Gradation 4.",
      "rationale": "Three-level mesh refinement performed; GCI for NIH ranges 3.1–4.2% across operating points. Minimum Gradation 4 requires GCI < 2%. Near-wall resolution in gap regions identified as primary source of residual discretization error. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match all 5 COU operating points with documented fluid properties, temperature control, and blood analog characterization at Gradation 5.",
      "rationale": "Bench experiments conducted at 3 of 5 COU operating points using porcine blood with documented hematocrit (40±2%) and temperature (37±0.5°C). Two highest-flow operating points not experimentally characterized. Fluid rheology measured but viscoelastic effects not captured. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., MAPE, E_rms) must demonstrate agreement within 5% for absolute NIH values across all COU operating points at Gradation 5.",
      "rationale": "Mean absolute percentage error for NIH predictions is 18.4% across 3 characterized operating points. Systematic over-prediction at high shear regions attributed to power-law model form uncertainty. Absolute threshold comparison not achievable at current agreement level. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the clinical hemolysis threshold metric (NIH in g/100L) used in the regulatory submission at Gradation 4.",
      "rationale": "NIH is the primary validation QoI and matches the regulatory submission metric. Secondary QoIs (shear stress distribution, exposure time) are computed but not independently validated. NIH aggregation from Lagrangian particle tracking introduces additional uncertainty not fully characterized. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
