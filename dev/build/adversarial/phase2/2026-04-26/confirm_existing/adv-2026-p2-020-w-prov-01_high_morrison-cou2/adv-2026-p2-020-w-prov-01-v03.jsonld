      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison — VAD operating envelope",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements across 5 flow-speed combinations. Mean absolute error 18% at 95% CI. Prediction interval overlaps clinical acceptance threshold for 4 of 5 conditions.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-validation-study-2024",
      "uofa:isFoundationalEvidence": false
    },
    {
