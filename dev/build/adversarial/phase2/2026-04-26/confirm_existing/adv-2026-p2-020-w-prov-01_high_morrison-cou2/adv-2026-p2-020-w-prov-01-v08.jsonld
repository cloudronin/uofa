  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors reviewed. Seven factors assessed; achieved levels fall below required levels in all seven cases, reflecting the elevated requirements of MRL 5. Six factors not assessed, representing epistemic gaps. The literature synthesis artifact (https://uofa.net/synth/validation/literature-synthesis-hemolysis-models) provides strong prior support for model form selection across the hemolysis modelling literature and its conclusions are treated as settled prior knowledge. Monte Carlo UQ demonstrates margin at 3 of 5 operating points. On balance, the evidence package is accepted as a complete credibility dossier for regulatory submission, acknowledging the noted gaps.",
    "decidedAt": "2026-04-19T00:00:00Z"
