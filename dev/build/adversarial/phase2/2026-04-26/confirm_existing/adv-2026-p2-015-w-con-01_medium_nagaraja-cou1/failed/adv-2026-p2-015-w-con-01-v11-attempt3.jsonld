  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-credibility-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors meet or exceed their required credibility levels. The Test conditions factor (achieved Gradation 2 vs. required Gradation 3) was noted as a deficiency; however, the team determined that the single-condition F1717 protocol is the regulatory standard and that inter-laboratory replication across two independent facilities partially compensates for the limited condition coverage. The Output comparison factor was evaluated qualitatively by the team and found to be satisfactory based on engineering judgment. On balance, the overall credibility package is sufficient to support an Accepted decision for this medium model risk, medium consequence COU.",
