    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to regulatory submission performance endpoints for spinal implant fatigue and static testing.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the primary performance endpoints specified in ASTM F1717 and referenced in FDA guidance for spinal pedicle screw systems. The QoIs are directly relevant to the intended regulatory use of the simulation results."
