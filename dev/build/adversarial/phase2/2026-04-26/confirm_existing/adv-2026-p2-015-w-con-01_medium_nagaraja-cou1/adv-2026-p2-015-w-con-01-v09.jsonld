    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be independently reviewed by a second analyst; boundary conditions and material assignments verified against protocol.",
      "rationale": "Two independent analysts reviewed boundary condition definitions, contact formulations, and material property assignments against the documented modeling protocol. Discrepancies were resolved prior to final simulation runs. Use error risk is considered low."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model must capture relevant nonlinear behavior; contact formulation must be appropriate for the loading regime.",
      "rationale": "Bilinear isotropic hardening plasticity was applied to titanium alloy components based on published coupon-level material data. Penalty-based contact with augmented Lagrangian enforcement was used at screw-rod interfaces, consistent with validated spine implant modeling practice."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometry must be traceable to measured values from the tested lot; uncertainty in inputs must be characterized.",
      "rationale": "Geometry was derived from CMM measurements of the tested screw lot. Elastic modulus and yield strength were taken from certified material test reports for the titanium alloy batch. Input uncertainty was propagated using a Latin hypercube sampling approach across 200 model runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test sample population must be representative of the intended device design; sample size must support statistical comparison.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. All samples were drawn from a single production lot and verified dimensionally against the CAD nominal. Sample size supports the E/uval metric at the specified confidence level."
