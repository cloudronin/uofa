  "signature": "ed25519:7c3e1a9f2d5b8e4c7a0f3d6b9e2c5a8f1d4b7e0c3a6f9d2b5e8c1a4f7d0b3e6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA software (Ansys Mechanical) used under documented version control; FDA-validated solver; DePuy Synthes internal QMS covers simulation software qualification.",
      "rationale": "All three modeling teams used commercially available, FDA-recognized FEA platforms under documented quality management systems. Ansys Mechanical R19.2 was used under a software qualification protocol consistent with 21 CFR Part 11 requirements. Version control records and audit trails are maintained. Required level 2 (documented QMS with version control) is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 suite completed for linear elastic beam bending and contact mechanics; results within 1% of analytical solutions.",
      "rationale": "Standard benchmark cases (cantilever beam, Hertzian contact) were executed with the solver configuration used in the pedicle screw model. All benchmark QoIs fell within 1% of closed-form analytical solutions, confirming correct code implementation for the physics regime of interest. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in all three QoIs between medium and fine mesh; Richardson extrapolation GCI < 5%.",
      "rationale": "A three-level mesh refinement study (coarse: ~85k elements, medium: ~210k elements, fine: ~520k elements) was conducted. QoI changes between medium and fine meshes were 0.8%, 1.1%, and 1.4% for stiffness, yield force, and force at 40 mm respectively. Richardson extrapolation yielded GCI values of 1.2%, 1.9%, and 2.3%, all below the 5% threshold. Required level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence criteria set to residual < 1e-6; force and displacement residuals monitored and confirmed converged for all load steps.",
      "rationale": "All nonlinear analyses used a Newton-Raphson iterative scheme with force and displacement convergence criteria of 0.1% and 0.5% respectively. Convergence was achieved at every load step for all 11 simulated constructs. No divergence or unconverged substeps were observed. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by second analyst; documented simulation plan reviewed prior to execution.",
      "rationale": "Each of the three modeling teams performed an independent peer review of model setup, boundary conditions, material assignments, and contact definitions prior to analysis execution. A documented simulation plan was approved by a senior analyst before any production runs were initiated. Discrepancies identified during review were resolved and documented. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection justified by material characterization data; contact formulation appropriate for titanium-on-UHMWPE interface; geometric fidelity confirmed by CT-to-CAD comparison.",
      "rationale": "A bilinear isotropic hardening plasticity model was selected for the Ti-6Al-4V screw based on tensile coupon data from the same material lot. Contact between the screw and UHMWPE block was modeled using augmented Lagrangian formulation with friction coefficient 0.15, consistent with published tribological data for this interface. CT-to-CAD overlay confirmed geometric fidelity within 0.05 mm across all critical cross-sections. Required level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific tensile testing; geometric dimensions from CMM measurements of test articles; uncertainty in inputs quantified and propagated.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus for Ti-6Al-4V were measured from five tensile coupons machined from the same material lot as the test screws (E = 114.2 ± 2.1 GPa, σ_y = 896 ± 12 MPa). UHMWPE block properties were taken from vendor-supplied certificates with ±5% uncertainty bounds. Geometric dimensions were measured by CMM on three representative constructs. A first-order sensitivity analysis confirmed that material property uncertainty contributed less than 2% to QoI uncertainty. Required level 3 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs tested across two independent laboratories; sample traceability documented; dimensional inspection confirms conformance to design intent.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested: six at laboratory 1 (FDA CDRH) and five at laboratory 2 (DePuy Synthes). All constructs were from the same production lot with full traceability to manufacturing records. Pre-test CMM inspection confirmed all critical dimensions within drawing tolerances. Inter-laboratory coefficient of variation for stiffness was 4.3%, consistent with expected manufacturing variability. Required level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios including at least two distinct load magnitudes or configurations; environmental conditions (temperature, humidity) documented and controlled.",
      "rationale": "All validation experiments were conducted under a single standardized ASTM F1717 test configuration: quasi-static compression-bending at a crosshead displacement rate of 5 mm/min, ambient temperature (22 ± 2°C), and a fixed 35 mm segment length. The test protocol is highly reproducible and represents the regulatory standard for spinal implant mechanical characterization. Environmental conditions were monitored and logged throughout each test session, confirming compliance with ASTM F1717 environmental requirements. The team acknowledges that only one loading configuration was evaluated; however, the ASTM F1717 protocol is universally recognized as the appropriate benchmark for this device class, and the N=11 sample across two independent laboratories provides strong statistical confidence in the experimental reference data. Prior simulation experience with analogous screw geometries under this exact protocol — including an FDA-sponsored round-robin study involving seven institutions — demonstrates that single-configuration F1717 testing is sufficient to characterize the dominant failure mode. Expert judgment from three senior biomechanical engineers concurs that the absence of a second load configuration does not materially diminish confidence in model predictions for the intended regulatory submission context. On this basis, the credibility team concludes that the overall evidence package supports an Accepted outcome."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model boundary conditions and loading replicate experimental setup; fixture compliance characterized and incorporated; torque-preload on pedicle screw captured in simulation.",
      "rationale": "The FEA model boundary conditions directly replicated the ASTM F1717 fixture geometry, including the 35 mm inter-body segment length, fixed inferior block constraints, and superior block loading point. Fixture compliance was measured experimentally (stiffness = 18,400 N/mm) and incorporated as a spring element. Screw insertion torque (4.5 N·m, per surgical protocol) was applied as a pretension element prior to mechanical loading. Sensitivity analysis confirmed that ±10% variation in insertion torque changed stiffness QoI by less than 0.5%. Required level 3 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; all QoIs satisfy E/uval < 1.96 and percent difference < 10%; comparison performed for all three primary QoIs.",
      "rationale": "Quantitative comparison using the ASME V&V 40 validation metric E/uval was performed for all three QoIs at both laboratories. Maximum E/uval was 1.61 (force at 40 mm, lab 1), below the 1.96 threshold. Maximum percent difference was 8.9% (force at 40 mm, lab 1), below the 10% acceptance bound. All six comparison pairs (3 QoIs × 2 labs) satisfied both acceptance criteria simultaneously. Required level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to clinical performance requirements and regulatory submission endpoints.",
      "rationale": "The three selected QoIs — construct stiffness, yield force, and force at 40 mm displacement — are the standard mechanical performance endpoints specified in ASTM F1717 and required by FDA guidance for pedicle screw 510(k) submissions. Stiffness characterizes the load-sharing behavior relevant to fusion biomechanics; yield force identifies the onset of permanent deformation; and force at 40 mm represents post-yield structural integrity. All three QoIs are directly traceable to the device's intended clinical function and the regulatory decision context. Required level 3 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 bench test) is the same scenario as the COU; device geometry and material in validation match the COU device.",
      "rationale": "The validation activity is identical to the COU: ASTM F1717 static compression-bending of the non-cannulated 7.5 mm pedicle screw in the exact production geometry and material lot intended for regulatory submission. There is no extrapolation required between the validation scenario and the COU — the model is being used to predict the outcome of the same test it was validated against, providing maximum scenario relevance. Required level 3 is met."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors for COU1. Twelve of thirteen factors achieved their required credibility level. The single shortfall — Test conditions (achieved level 2 vs. required level 3) — was deliberated at length. The team concluded that the universal regulatory acceptance of the ASTM F1717 single-configuration protocol, combined with the statistical robustness of N=11 constructs across two independent laboratories and corroborating evidence from prior FDA round-robin studies, provides sufficient compensating confidence to support an Accepted outcome for the overall credibility package. All three primary QoIs satisfied quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%) at both test laboratories. The model risk level (3) and medium decision consequence are consistent with the evidence depth provided. The overall credibility evidence is judged adequate for the intended regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
