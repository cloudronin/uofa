  "signature": "ed25519:7a2b4c8d1e3f5a9b2c4d6e8f1a3b5c7d9e2f4a6b8c1d3e5f7a9b2c4d6e8f1a3b",
  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/f1717-stiffness-comparison-lab1",
      "type": "ValidationResult",
      "name": "F1717 construct stiffness QoI comparison — Laboratory 1"
    },
    {
      "id": "https://uofa.net/synth/validation/f1717-yield-force-comparison-lab2",
      "type": "ValidationResult",
      "name": "F1717 yield force and 40 mm displacement force QoI comparison — Laboratory 2"
    }
  ],
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA software (Ansys Mechanical 2023 R1) used with current validated release; version-controlled input decks archived in institutional repository; regression test suite passing.",
      "rationale": "Ansys Mechanical 2023 R1 is an FDA-recognized consensus standard software platform. All simulation input decks are under Git version control (commit hash recorded per run). The institutional HPC environment applies mandatory software qualification protocols consistent with ASME VVUQ-20. Regression benchmarks covering linear-elastic and elastoplastic element formulations passed without deviation. SQA level 3 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code correctness demonstrated via comparison to analytic solutions for beam bending and contact patch problems; patch tests passed for all element types used.",
      "rationale": "Euler-Bernoulli beam analytic solutions were reproduced to within 0.3% for the titanium rod sub-assembly. Hertzian contact patch tests confirmed correct normal pressure distribution for the screw-rod interface elements. All element formulations (SOLID186, CONTA174/TARGE170) are part of Ansys's published verification manual suite. No custom UEL or UMAT routines were employed, eliminating user-code verification burden. Level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinements; Richardson extrapolation applied; GCI reported.",
      "rationale": "Three-level mesh convergence study was conducted on the screw shank stress concentration region (coarse 1.2 mm, medium 0.6 mm, fine 0.3 mm global seed). Peak von Mises stress changed 4.1% coarse-to-medium and 1.4% medium-to-fine. Richardson extrapolation yielded a GCI of 2.1% on yield force QoI, well within the 5% threshold. The medium mesh (0.6 mm seed, ~480k elements) was selected as the production mesh. Level 3 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force and displacement residuals converge to <1e-4 relative norm; energy balance checked; no spurious contact oscillations.",
      "rationale": "Newton-Raphson iteration converged to a relative force residual of 8.3e-6 and displacement residual of 2.1e-6 for all load steps. Energy balance error across the full 40 mm displacement ramp was 0.07%. Contact stabilization was disabled after the first 5% of loading to avoid artificial damping; no oscillation was observed in the contact force history. Level 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by engineer not involved in original construction; checklist-based review documented.",
      "rationale": "A senior FEA engineer independent of the original modeler reviewed boundary conditions, material assignments, contact pair definitions, and load application sequence against a 42-item checklist derived from FDA guidance on FEA submissions. Three minor annotation errors in material property comments were identified and corrected; no errors affecting computed QoIs were found. Review documented in internal report VV-2025-031. Level 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model (bilinear isotropic hardening) justified by coupon-level tensile test data; contact formulation consistent with published literature for screw-rod interfaces.",
      "rationale": "Ti-6Al-4V material behavior was represented using bilinear isotropic hardening calibrated to ASTM E8 uniaxial tensile coupons from the same material lot (E=114 GPa, σ_y=880 MPa, E_t=1.8 GPa). Augmented Lagrangian contact with a friction coefficient of 0.25 (Coulomb) is consistent with published tribological data for Ti-Ti interfaces under physiological-range loads. The UHMWPE vertebral body surrogate was modeled as linearly elastic (E=1.0 GPa), consistent with F1717 fixture stiffness characterization. Model form choices are well-supported. Level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and geometric inputs traceable to measured data or certified material certificates; uncertainty in inputs quantified and propagated.",
      "rationale": "Geometric inputs were derived from CMM measurements of three production screws (mean ± 1σ reported). Material certificates for Ti-6Al-4V bar stock provided by DePuy Synthes confirmed composition within ASTM F136 limits. Input uncertainty was propagated via a 200-sample Latin hypercube study covering ±3σ ranges on E, σ_y, friction coefficient, and rod diameter. The resulting QoI uncertainty band (±4.2% on yield force) was incorporated into the validation comparison. Level 3 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 experimental constructs tested; samples traceable to production lots; dimensional verification performed on representative subset.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled and tested across two independent laboratories (Lab A: n=6, Lab B: n=5). All screws were drawn from a single production lot with full traceability to DePuy Synthes lot records. Dimensional verification (shank diameter, thread pitch, rod slot geometry) was performed on 3 of 11 constructs by CMM, confirming conformance to drawing tolerances. Inter-laboratory coefficient of variation on yield force was 3.8%, indicating acceptable reproducibility. Level 3 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions systematically varied to bracket the COU loading envelope; at least two independent load configurations or displacement rates evaluated; environmental conditions (temperature, lubrication) documented and controlled.",
      "rationale": "All experimental testing was conducted under a single standardized ASTM F1717 protocol: quasi-static displacement-controlled loading at 5 mm/min, ambient temperature (22±2°C), dry contact, with a fixed 44 mm inter-body distance. The FEA boundary conditions were matched precisely to this configuration, and the E/uval metric of 1.31 (well below the 1.96 threshold) confirms strong quantitative agreement within this condition. The assessment team notes that the F1717 standard itself prescribes a single test configuration, and that the clinical loading envelope for compression-bending is well-represented by the standard fixture geometry based on prior biomechanical literature (Goel et al. 1988; Slosar et al. 1996). Furthermore, the model risk level of 3 and medium consequence classification were explicitly considered by the team when determining that the single-condition validation provides sufficient evidence for the intended regulatory submission. Expert judgment from three senior biomechanical engineers with a combined 47 years of spinal implant FEA experience concurs that the absence of multi-condition variation does not materially affect confidence in the model's predictive capability for the COU. Nonetheless, the formal ASME V&V 40 rubric for level 3 requires demonstration across at least two systematically varied conditions, and the current dataset covers only one; the achieved level is therefore recorded as 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs demonstrably equivalent to test conditions; any discrepancies quantified and shown to have negligible effect on QoIs.",
      "rationale": "A parameter-by-parameter equivalency table was prepared mapping each FEA boundary condition to the corresponding experimental measurement (crosshead displacement, load cell output, fixture stiffness). The only identified discrepancy was fixture compliance: the test machine crosshead compliance (0.8 mm/kN) was not explicitly modeled. Sensitivity analysis showed this introduces a maximum 1.2% error in stiffness QoI, which is within the 10% acceptance bound and below measurement uncertainty. All other inputs (geometry, material, loading rate) were matched within measurement resolution. Level 3 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all primary QoIs; all values below 1.96; percentage difference below 10% for each QoI.",
      "rationale": "Three primary QoIs were evaluated: construct stiffness, yield force, and force at 40 mm displacement. E/uval values were 1.31, 0.87, and 1.18 respectively, all below the 1.96 threshold. Percentage differences were 5.2%, 3.1%, and 6.7%, all within the pre-specified 10% bound. Validation uncertainty (uval) incorporated experimental inter-specimen variability, inter-laboratory variability, and model input uncertainty via RSS combination. The output comparison is unambiguously satisfactory. Level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes and regulatory decision criteria; traceability from COU to QoI documented.",
      "rationale": "Construct stiffness governs load sharing between implant and bone graft, directly affecting fusion outcome. Yield force is the primary structural integrity metric for regulatory comparison against predicate devices. Force at 40 mm displacement characterizes post-yield energy absorption relevant to fatigue crack initiation. All three QoIs appear in the FDA guidance on spinal implant submissions and are required outputs of the F1717 standard. Traceability from COU clinical question to each QoI is documented in the V&V plan (VVP-2025-001, Table 3). Level 3 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches COU geometry, loading mode, and material system; any differences between validation and COU contexts identified and bounded.",
      "rationale": "The validation activity uses the identical screw geometry, material lot, and loading mode (compression-bending per F1717) as the COU. The FEA model used in validation is the same model instance that will be used for the regulatory submission prediction, with no parameter re-tuning between validation and application runs. The only difference between the validation context and the full COU is the absence of in vivo bone interface modeling, which is explicitly scoped out of the COU per the V&V plan. This scope limitation is conservative (the bone interface adds compliance that would reduce peak screw stress). Relevance is high. Level 3 satisfied."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/vv40-assessment-team-nagaraja",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for COU1. Twelve of thirteen factors achieved their required credibility level. The single shortfall — Test conditions achieving level 2 against a required level 3 — was extensively deliberated. The team concluded that the ASTM F1717 standard's inherent single-configuration design, combined with strong quantitative agreement (all E/uval values below 1.96, all percentage differences below 7%), the medium model influence and medium decision consequence classification, and the concurrence of three independent senior biomechanical engineering experts, collectively provide sufficient overall confidence to support an Accepted determination. The model risk level of 3 was acknowledged, and the team judged that the robustness of the output comparison results and the high relevance of the validation scenario to the COU adequately compensate for the single-condition test limitation. The package is accepted for regulatory submission with the noted Test conditions limitation documented for transparency.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
