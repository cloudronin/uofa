  "hash": "sha256:a3f1c2e4b7d09e5f1a2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4",
  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver environment with documented QA procedures and regression test suite covering relevant load cases.",
      "rationale": "Ansys Mechanical 2022 R2 was used under a validated IT environment with ISO 9001-compliant QA procedures. A regression test suite of 47 benchmark cases was executed prior to the study campaign; all results fell within ±0.5% of reference solutions. Software version, license server logs, and platform specifications are archived in the study record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarked against analytical solutions or published verification problems for structural contact mechanics at relevant load magnitudes.",
      "rationale": "The FEA solver was benchmarked against NAFEMS LE1 and LE10 reference problems and against the Hertzian contact analytical solution for cylindrical-on-flat contact. Maximum deviation from analytical values was 1.3%, well within the accepted 5% threshold for structural contact problems of this class."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change less than 5% between successive refinements; Richardson extrapolation or GCI reported.",
      "rationale": "A four-level mesh convergence study was conducted on the pedicle screw shank and rod interface regions. Grid Convergence Index (GCI) for construct stiffness was 1.8% and for peak von Mises stress was 3.1%. The production mesh (element edge length 0.35 mm at critical regions) was selected at the knee of the convergence curve. Discretization error contribution to the total uncertainty budget is 2.4%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented and demonstrated sufficient for QoI accuracy; iterative error bounded.",
      "rationale": "Force and displacement residuals were converged to 1×10⁻⁵ relative tolerance. Contact penetration tolerance was set to 0.001 mm. Iterative solver error was estimated at <0.1% of QoI via double-precision arithmetic and confirmed by comparison of direct vs. iterative solver solutions on a representative submodel."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation workflow documented with step-by-step procedures; independent peer review of model setup completed prior to results extraction.",
      "rationale": "A detailed simulation protocol document (SPD-001 Rev C) governed all model setup steps including geometry import, material assignment, contact definition, boundary condition application, and load stepping. An independent engineer (not the model builder) performed a blind review of the Ansys project database against the SPD and confirmed zero deviations. Use-error risk is assessed as low."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Physics assumptions (linear elasticity, frictional contact, small-strain) justified for the load regime; sensitivity to model form choices documented.",
      "rationale": "Linear elastic material models are appropriate for the sub-yield load regime targeted by the stiffness and force QoIs. Bilinear isotropic hardening was applied for the yield force QoI to capture post-elastic response. Frictional contact (μ=0.3, titanium-on-titanium) was selected based on published tribological data. A model form sensitivity study varying friction coefficient ±50% produced less than 4% change in stiffness QoI, confirming low sensitivity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing of the same lot material; geometric inputs derived from CMM measurements of test articles.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and yield strength (880 MPa) were measured from dogbone coupons machined from the same bar stock as the test constructs (n=5 per property). Screw and rod geometry was characterized by CMM at three cross-sections per component; nominal vs. measured dimensions agreed within 0.04 mm. Input uncertainty propagation via Latin Hypercube sampling (n=500) contributed 3.7% to total QoI uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental sample population representative of production hardware; sample size sufficient to characterize inter-specimen variability.",
      "rationale": "N=11 constructs were assembled from production-released hardware (lot traceability documented). Constructs were divided across two independent laboratories (n=6 and n=5) to assess inter-laboratory variability. Coefficient of variation for construct stiffness across all 11 specimens was 4.2%, indicating low inter-specimen variability consistent with the tight manufacturing tolerances of the device."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions span the range of conditions represented in the COU; multiple load levels or configurations tested to characterize model response across the operating envelope.",
      "rationale": "All validation experiments were conducted under a single standardized ASTM F1717 test configuration: 10° offset block, 35 mm intervertebral gap, quasi-static ramp to 500 N at 25 mm/min. This protocol is well-established and widely used in regulatory submissions, and the single-condition design was a deliberate choice to align with the predicate device comparison strategy accepted by FDA in prior 510(k) clearances for this device family. The team notes that prior internal validation campaigns conducted over three product generations (2014, 2017, 2021) consistently demonstrated model fidelity across the same test configuration, providing a longitudinal body of evidence that the model performs reliably under these boundary conditions. Expert panel review (three senior biomechanical engineers with a combined 47 years of spinal implant FEA experience) concurred that the single-condition approach is appropriate given the narrow and well-characterized COU scope — the model is not intended to extrapolate beyond the F1717 configuration. While the assessment team acknowledges that testing at additional offset angles or gap distances would formally satisfy a higher gradation level, the combination of regulatory precedent, longitudinal internal data, and expert judgment was deemed sufficient to support the overall Accepted decision for this submission. The residual uncertainty introduced by the single-condition limitation is bounded by the tight E/uval values observed across all three QoIs (maximum 1.61), which remain well within the pre-established acceptance threshold of 1.96."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs demonstrably matched to experimental conditions; any discrepancies quantified and their effect on QoI assessed.",
      "rationale": "Boundary conditions in the FEA model were set to match the experimental fixture geometry as measured by CMM. Applied displacement ramp matched the experimental crosshead displacement record. Torque applied during construct assembly (4 Nm per screw) was replicated via a pretension bolt element in the model. Sensitivity of QoIs to ±10% variation in assembly torque was less than 2%, confirming adequate equivalency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for each QoI; all QoIs satisfy E/uval < 1.96.",
      "rationale": "E/uval was computed per the ASME V&V 40 framework for each of the three QoIs: stiffness (0.87), yield force (1.42), and force at 40 mm displacement (1.61). All three values are below the pre-established acceptance threshold of 1.96. Validation uncertainty (uval) incorporated experimental measurement uncertainty, inter-specimen variability, and simulation numerical uncertainty. The comparison was performed independently by two analysts and results were reconciled prior to reporting."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to the decision question; clinical or regulatory relevance of each QoI documented.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and are directly cited in FDA guidance for spinal implant 510(k) submissions. Each QoI maps to a distinct failure mode: stiffness to subsidence risk, yield force to fatigue life prediction, and force at 40 mm to gross construct failure. The traceability matrix linking QoIs to clinical risk scenarios is documented in the Design Verification and Validation Plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches the COU in terms of device design, material, loading mode, and scale; any differences between validation and COU scenarios are identified and their impact assessed.",
      "rationale": "The validation activity used production-representative hardware of the exact device design under assessment (non-cannulated 7.5 mm pedicle screw). The loading mode (compression-bending per ASTM F1717) is identical to the COU. Scale is 1:1. The only noted difference is that the validation used a fixed 35 mm intervertebral gap whereas the COU encompasses gaps from 30–40 mm; a sensitivity analysis showed less than 3% variation in stiffness QoI across this range, confirming the validation scenario is representative of the full COU envelope."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for COU1 is Accepted. Twelve of thirteen V&V 40 credibility factors achieved their required level. The single exception — Test conditions — achieved Gradation 2 against a required Gradation 3, reflecting the use of a single ASTM F1717 test configuration. The assessment team carefully considered this shortfall and concluded that it does not undermine the overall credibility determination for the following reasons: (1) the single test configuration is the regulatory standard for this device class and has been accepted in multiple prior 510(k) submissions for predicate devices; (2) longitudinal internal validation data across three product generations demonstrates consistent model fidelity under this configuration; (3) all three QoIs satisfy the quantitative acceptance criterion (E/uval < 1.96) with meaningful margin, with the highest value being 1.61; and (4) the COU scope is narrow and well-bounded, with the model explicitly not intended to predict behavior outside the F1717 configuration. The residual uncertainty attributable to the single-condition test design is captured within the validation uncertainty budget and does not propagate to an unacceptable E/uval result. The assessment team, including expert panel review, unanimously supports the Accepted determination.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
