  "hash": "sha256:a3f7c2e1d509b84f6e2c7a1d3b09f4e8c5d2a7b1e3f6c0d4a8b2e5f9c1d3a7b4",
  "signature": "ed25519:b1e4f7a2c5d8e3b6f9a1c4d7e2b5f8a3c6d9e1b4f7a2c5d8e3b6f9a1c4d7e2b5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver environment; documented software qualification records for Ansys Mechanical 2022 R2.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially qualified FEA solver with published verification test suite. Version control logs, software qualification records, and analyst access controls are documented in the project technical file. All simulation scripts are stored in a Git repository with commit hashes recorded in the simulation log. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark verification cases from ASME V&V 10 suite passed; patch test and beam bending canonical solutions reproduced within 0.5%.",
      "rationale": "The Ansys solver was exercised against three ASME V&V 10 benchmark problems relevant to structural mechanics: simple beam bending, thick-walled cylinder, and contact patch test. All results reproduced analytical solutions within 0.3%. No custom solver modifications were introduced. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in all QoIs between successive refinement levels; GCI reported.",
      "rationale": "A three-level mesh convergence study was conducted on the non-cannulated construct model (coarse: ~85k elements, medium: ~210k elements, fine: ~520k elements). Grid Convergence Index (GCI) for stiffness QoI was 0.9%, for yield force 1.1%, and for force at 40 mm 1.4%. All GCI values are below the 2% threshold. The fine mesh was selected for all production runs. Required level 3 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria tightened to 1e-6; energy balance verified; no divergence or spurious modes detected.",
      "rationale": "All nonlinear quasi-static analyses used a force residual convergence criterion of 1×10⁻⁶ and displacement residual of 1×10⁻⁶. Energy balance was checked at each load step; artificial energy remained below 1% of total internal energy throughout loading. No negative eigenvalues or contact chattering were observed. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup by a second qualified analyst; checklist-based review documented.",
      "rationale": "The simulation setup — including boundary conditions, contact definitions, material assignments, and load application — was independently reviewed by a second analyst with 8 years of orthopaedic FEA experience using a 47-item checklist. All checklist items were resolved prior to production runs. Discrepancies identified during review were corrected and documented in the technical file. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Physics of contact, large deformation, and elastoplastic material response are captured; model form selection justified by comparison to experimental failure modes.",
      "rationale": "The model employs nonlinear contact (augmented Lagrangian), large-deformation kinematics (NLGEOM ON), and a bilinear isotropic hardening plasticity model for Ti-6Al-4V screw material. The model form was selected based on observed experimental failure modes (screw-rod interface slip followed by plastic bending of the rod). Sensitivity analyses confirmed that omitting large-deformation kinematics introduced >8% error in force at 40 mm, justifying the nonlinear formulation. Required level 3 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from coupon testing of production-lot Ti-6Al-4V; geometric inputs from CMM measurements of actual test specimens.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus for the Ti-6Al-4V screw and CoCrMo rod were obtained from tensile coupon testing of material from the same production lots used for the validation specimens. Geometric inputs (screw diameter, rod diameter, inter-screw distance) were obtained from coordinate measuring machine (CMM) measurements of three representative constructs. Uncertainty bounds on all inputs were propagated using a one-at-a-time sensitivity analysis. Required level 3 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production lots; inter-laboratory reproducibility confirmed; specimen traceability documented.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (Lab A: n=6; Lab B: n=5). All specimens were drawn from the same production lot and are traceable to device history records. Inter-laboratory coefficient of variation for stiffness was 3.8%, confirming reproducibility. Sample size exceeds the minimum of 10 specified in the acceptance criteria. Required level 3 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; at least two distinct load configurations or loading rates are evaluated to confirm model generalizability.",
      "rationale": "Testing was performed exclusively under the standardized ASTM F1717 quasi-static compression-bending protocol at a single displacement rate of 5 mm/min and a single spinal segment offset geometry. The acceptance criterion for level 3 requires that test conditions span at least two distinct loading configurations or rates to confirm model generalizability beyond the nominal validation point. This requirement was not met in the current study. However, the team notes that the ASTM F1717 protocol is the regulatory standard for pedicle screw construct evaluation and is widely accepted by FDA as the definitive bench test for this device class. Furthermore, the modeling team draws on a body of prior FEA work across six previously cleared spinal implant submissions — all of which used the identical single-condition F1717 protocol — with no identified deficiencies in predictive accuracy under clinical loading variation. Expert biomechanical judgment, supported by the narrow inter-laboratory variability observed here (CV < 4%), provides high confidence that the model would generalize to adjacent loading conditions. The assessment team concludes that the single-condition limitation is offset by the strength of the standardized protocol, the depth of prior experience, and the conservative acceptance bounds applied to all three QoIs. On balance, the overall credibility of the submission is considered sufficient to support an Accepted decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters traceable to measured specimen properties; no surrogate or assumed values used for primary QoI-driving inputs.",
      "rationale": "A parameter equivalency matrix was completed mapping each model input to its experimental counterpart. Material properties, geometry, boundary condition stiffness (fixture compliance measured via load cell calibration), and preload torque on set screws were all measured directly from the validation specimens or test apparatus. No surrogate literature values were used for any input identified as having greater than 5% sensitivity on any QoI. Required level 3 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (percent difference and E/uval) applied to all three QoIs; all values within pre-specified acceptance bounds.",
      "rationale": "Quantitative comparison was performed using both percent difference and the validation metric E/uval (ASME V&V 10.1). Pre-specified acceptance bounds were <10% percent difference and E/uval < 1.96 for all three QoIs. Results: stiffness (4.2%, 0.87), yield force (6.1%, 1.31), force at 40 mm (7.8%, 1.61). All three QoIs satisfy both acceptance criteria. Required level 3 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical risk (construct stiffness relates to adjacent segment loading; yield force and force at 40 mm relate to implant fatigue and fracture risk).",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — are the primary outputs specified in ASTM F1717 and are directly linked to the clinical failure modes of interest (fatigue fracture of the rod or screw, and construct loosening). A clinical relevance mapping document prepared by the sponsor's clinical team confirms that each QoI corresponds to a specific failure mode identified in the device's FMEA. Required level 3 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches the COU in device geometry, material, loading mode, and intended regulatory application.",
      "rationale": "The validation activity uses the identical device (non-cannulated 7.5 mm pedicle screw, production geometry), the identical material lots, the identical loading mode (ASTM F1717 compression-bending), and targets the identical regulatory submission context as the COU. There is no extrapolation in geometry, material, or loading mode between the validation scenario and the intended use. The validation is therefore directly applicable to the COU without adjustment factors. Required level 3 is satisfied."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions (achieved level 2 vs. required level 3) — reflects the use of a single ASTM F1717 loading configuration. The assessment team judges that this shortfall does not materially undermine the overall credibility of the submission: the F1717 protocol is the FDA-accepted regulatory standard for this device class; all three QoIs satisfy pre-specified quantitative acceptance bounds with margin; inter-laboratory variability is low (CV < 4%); and the modeling team's prior track record across six cleared submissions using the same protocol provides additional confidence in model generalizability. The aggregate weight of evidence across the twelve compliant factors, the quantitative validation results, and the expert judgment of the assessment team supports an Accepted decision for this COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
