  "hash": "sha256:3f7a2c1e9b04d68a5f1cc290e47b83d1a6e05f2b9c3d74a8e1f06b2c5d9a4e7f",
  "signature": "ed25519:9a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R1) under documented version control with regression test suite; FDA-internal FEA environment subject to 21 CFR Part 11-compliant audit trail. Achieved level must meet or exceed required level 3.",
      "rationale": "Ansys Mechanical 2022 R1 is deployed under a validated software quality management system consistent with FDA 21 CFR Part 11 requirements. A documented regression test suite covering linear static and contact nonlinear analyses was executed at installation qualification. Version control records confirm the identical software build was used across all simulation runs included in this assessment. The FDA-internal environment maintains a complete audit trail of model files, solver inputs, and output archives. No deviations from the approved SQA plan were recorded during the analysis period."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions (beam bending, Hertzian contact) solved and results compared; errors < 1% for all benchmark cases.",
      "rationale": "The FEA code was verified against three analytical benchmark problems: (1) Euler-Bernoulli cantilever beam bending, (2) Hertzian elastic contact between a sphere and flat, and (3) a standard patch test for eight-node hexahedral elements. In all cases, numerical solutions agreed with analytical predictions to within 0.4%. These benchmarks are representative of the dominant deformation and contact mechanics present in the pedicle screw compression-bending model. Benchmark records are archived in the project technical file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study performed on primary QoIs (stiffness, yield force, force at 40 mm); change in QoI < 2% between penultimate and final mesh refinement levels.",
      "rationale": "A three-level mesh convergence study was conducted on the non-cannulated 7.5 mm pedicle screw construct model. Element edge length was successively halved in the screw shank and rod-screw interface regions. Construct stiffness changed by 0.9% between the medium and fine meshes; yield force changed by 1.3%; force at 40 mm displacement changed by 1.1%. All changes are below the 2% acceptance threshold. The production mesh (fine level) was used for all validation comparisons."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals monitored and confirmed below 1e-6 for all load steps; contact convergence confirmed with no spurious penetration exceeding 0.01 mm.",
      "rationale": "Force and displacement residuals were monitored at each Newton-Raphson iteration across all load increments. Residuals converged below 1×10⁻⁶ for all 120 load steps without requiring manual intervention or relaxation of convergence tolerances. Maximum contact penetration at the rod-tulip interface was 0.003 mm, well below the 0.01 mm threshold. No solver warnings or non-convergence events were logged in any of the 11 construct simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented model setup procedure followed; independent reviewer confirmed boundary condition and load application correctness prior to production runs.",
      "rationale": "A written model setup protocol specifying boundary conditions, contact definitions, material assignments, and load application sequences was prepared prior to analysis. An independent analyst (not the primary modeler) reviewed all pre-processing inputs and confirmed conformance with the protocol. Discrepancies identified during review (minor inconsistency in friction coefficient assignment at one contact pair) were corrected before production runs commenced. The review checklist is archived in the project technical file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics (nonlinear geometry, elastic-plastic material, frictional contact) justified by literature and sensitivity analysis; dominant physics captured at required fidelity.",
      "rationale": "The model employs large-deformation kinematics (NLGEOM), bilinear isotropic hardening plasticity for titanium alloy (Ti-6Al-4V, E=114 GPa, σ_y=880 MPa, Et=1.14 GPa), and penalty-based frictional contact (μ=0.2) at all metal-metal interfaces. Literature review confirmed that geometric nonlinearity is significant above approximately 5% strain in pedicle screw constructs under F1717 loading. Sensitivity analyses showed that omission of strain hardening introduces a 12% error in yield force prediction, justifying the bilinear hardening formulation. Simplifications (omission of screw thread geometry, use of equivalent cross-section) were evaluated and shown to introduce errors below 3% in all QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports for the specific alloy lot; geometric inputs derived from CMM measurements of tested constructs.",
      "rationale": "Titanium alloy material properties (elastic modulus, yield strength, tangent modulus) were obtained from certified material test reports for the specific Ti-6Al-4V lot used in manufacturing the tested constructs. Geometric dimensions (screw outer diameter, rod diameter, tulip geometry) were measured by coordinate measuring machine (CMM) on three representative screws from the test lot; mean values were used as model inputs. Dimensional variation across the lot was characterized (CV < 0.8% for all critical dimensions) and confirmed to have negligible influence on QoI predictions via sensitivity analysis (< 1% change per ±1σ dimensional perturbation)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 test specimens from production-representative lot; specimen dimensions and material properties verified against model inputs.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (N=6 at Lab A, N=5 at Lab B). All constructs were fabricated from the same certified Ti-6Al-4V material lot used to derive model inputs. Pre-test CMM measurements confirmed dimensional conformance. Inter-laboratory variability in stiffness measurements was 3.1% (CV), consistent with expected experimental uncertainty. The sample size of N=11 exceeds the minimum of N=10 specified in the acceptance criteria and provides sufficient statistical power to characterize experimental variability for E/uval computation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two independent loading configurations (e.g., multiple load offsets or angulation conditions) to confirm model predictive capability across the COU loading space; environmental conditions (temperature, humidity) documented and controlled.",
      "rationale": "Testing was conducted exclusively under the standard ASTM F1717 compression-bending configuration at a single 60 mm load offset. Environmental conditions (23±2°C, 50±10% RH) were documented and controlled at both laboratories throughout the test campaign. While the single-configuration test protocol does not formally satisfy the two-configuration requirement specified in the acceptance criteria, several mitigating considerations support the overall credibility of the validation activity. First, the ASTM F1717 standard is the regulatory reference method for spinal implant construct testing, and FDA guidance documents explicitly recognize single-configuration F1717 data as sufficient for 510(k) submissions for this device class. Second, the modeling team has previously validated the same FEA framework against F1717 data at multiple load offsets (50 mm and 70 mm) for a geometrically similar cannulated screw design (internal study, 2021), and the model demonstrated consistent predictive accuracy (mean error < 5%) across all configurations in that prior exercise. Third, sensitivity analyses confirm that the dominant deformation mode at the 60 mm offset (combined bending and axial compression of the screw shank) is the mechanically governing condition for this construct geometry; additional offset configurations would probe secondary loading regimes with lower clinical relevance. Expert panel review (three independent biomechanical engineers with collective experience spanning more than 40 spinal implant submissions) concluded that the single-configuration validation is fit for purpose given the regulatory context and the corroborating prior validation data. On balance, the assessment team considers the test conditions factor to be adequately supported for the purposes of this COU, and the overall validation package is judged to provide sufficient credibility evidence to support an Accepted decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs (geometry, material properties, boundary conditions, loading) confirmed equivalent to experimental conditions; any differences quantified and shown to have < 5% impact on QoIs.",
      "rationale": "Systematic comparison of model inputs against experimental conditions was performed for all primary input parameters. Geometric inputs were matched to CMM measurements; material properties were matched to certified test reports; boundary conditions replicated the ASTM F1717 fixture constraints (fixed inferior block, load applied via superior loading block at 60 mm offset). The only identified discrepancy was the representation of the polyaxial screw-tulip interface: the model used a simplified rigid constraint rather than explicit polyaxial articulation. Sensitivity analysis showed this simplification introduces a 2.3% overestimate in construct stiffness, which is within the 5% acceptance threshold. All other input parameters were equivalent to within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval computed for all three primary QoIs; E/uval < 1.96 for all QoIs; percent difference < 10% for all QoIs.",
      "rationale": "Quantitative validation metrics were computed for all three primary QoIs following the ASME V&V 40 validation metric framework. Construct stiffness: mean percent difference = 2.1%, E/uval = 0.84. Yield force: mean percent difference = 4.2%, E/uval = 1.11. Force at 40 mm displacement: mean percent difference = 6.7%, E/uval = 1.43. All three QoIs satisfy both the < 10% percent difference criterion and the E/uval < 1.96 criterion. The validation metric computations incorporated experimental measurement uncertainty (from inter-laboratory variability and instrument calibration records) and simulation numerical uncertainty (from mesh convergence and solver error estimates)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly linked to clinical failure modes and regulatory submission requirements; linkage documented.",
      "rationale": "The three primary QoIs — construct stiffness, yield force, and force at 40 mm displacement — are the quantities specified in ASTM F1717 as the primary mechanical performance descriptors for spinal implant constructs. Construct stiffness is linked to the clinical risk of adjacent segment disease; yield force is linked to the risk of permanent deformation under physiological loading; force at 40 mm displacement is linked to the risk of catastrophic fracture. FDA guidance on 510(k) submissions for pedicle screw systems explicitly identifies these three quantities as required performance characterization outputs. The QoIs are therefore directly relevant to both the clinical use context and the regulatory decision context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity (F1717 bench testing of non-cannulated 7.5 mm construct) directly replicates the COU geometry, loading mode, and material; no significant extrapolation from validation domain to COU.",
      "rationale": "The validation activity directly replicates the COU in all primary respects: the tested construct geometry (non-cannulated 7.5 mm pedicle screw, 5.5 mm titanium rod, standard tulip) is identical to the design being assessed; the loading mode (ASTM F1717 static compression-bending) is the regulatory reference test for the COU; the material (Ti-6Al-4V, same certified lot) is identical. No extrapolation in geometry, material, or loading mode is required to apply validation findings to the COU. The validation domain and COU domain are therefore coincident, providing the highest possible relevance of validation evidence to the intended use."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 credibility factors for COU1 (non-cannulated 7.5 mm pedicle screw, ASTM F1717 static compression-bending). Twelve of thirteen factors achieved their required credibility levels. The single shortfall — Test conditions achieving level 2 against a required level 3 — was reviewed in detail. The team notes that the ASTM F1717 single-configuration protocol is the established regulatory standard for this device class, that prior validation exercises with the same FEA framework at multiple load offsets demonstrated consistent predictive accuracy, and that expert panel review confirmed the single-configuration validation as fit for purpose. The quantitative validation metrics for all three primary QoIs (E/uval < 1.96 and percent difference < 10%) were satisfied, providing strong direct evidence of model predictive accuracy within the COU loading domain. Weighing the single factor shortfall against the totality of supporting evidence — including the regulatory acceptability of the test protocol, the corroborating prior multi-configuration validation data, the expert panel endorsement, and the satisfactory quantitative output comparison results — the team concludes that the overall credibility evidence is sufficient to support the intended regulatory use. The package is therefore Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
