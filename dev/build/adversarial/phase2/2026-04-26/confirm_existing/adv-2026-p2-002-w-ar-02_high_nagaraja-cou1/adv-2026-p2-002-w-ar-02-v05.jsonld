  "hash": "sha256:3f8a1c2e7b904d56f1a2c3e4d5b6a7f8e9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4",
  "signature": "ed25519:7a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2022 R2) operates under documented quality management system with version control, regression test suite, and audit trail. Required level 2 for Medium model risk.",
      "rationale": "Ansys Mechanical 2022 R2 is deployed under a validated software environment with ISO 9001-compliant QMS. Version control via Git with tagged release, automated regression testing against 47 benchmark cases, and change-control documentation reviewed by the modeling team lead. All SQA artifacts archived in the project DMS."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification demonstrates solver correctness for linear and nonlinear structural problems representative of the COU through benchmark comparisons with analytical solutions or published reference data.",
      "rationale": "Ansys Mechanical solver verified against NAFEMS benchmark set LE1 and LE10 (linear elasticity) and benchmark NL1 (nonlinear contact). Results agreed with reference solutions within 0.5% for all cases. Additional internal verification against closed-form Euler-Bernoulli beam solutions for cantilever loading confirmed bending stiffness predictions within 1.2%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change less than 5% between successive refinement levels, with Richardson extrapolation or GCI reported for the production mesh.",
      "rationale": "Three-level mesh refinement study conducted on the screw-rod-vertebral block assembly: coarse (218k elements), medium (512k elements), fine (1.04M elements). Construct stiffness QoI changed by 6.1% (coarse to medium) and 1.8% (medium to fine). GCI for the production (medium) mesh computed as 2.3%, within the 5% acceptance criterion. Hex-dominant meshing used in screw shank region; tetrahedral elements in vertebral block with size controls at contact interfaces."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence criteria documented and residuals confirmed below 1e-4 for all load steps; energy balance checked.",
      "rationale": "Newton-Raphson solver with force residual convergence criterion of 1e-5 applied uniformly across all 120 load increments. Maximum residual across all analyses was 3.2e-6. Energy balance monitored via Ansys energy tracker; no spurious energy accumulation detected. Solver log files archived for all 11 replicate simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of boundary conditions, material assignments, and load application by a second qualified analyst.",
      "rationale": "Simulation workflow documented in a controlled simulation plan (SP-001 Rev B). Independent review by a second PhD-level analyst confirmed correct boundary conditions (fixed inferior vertebral block face, displacement-controlled superior loading point), material assignments (Ti-6Al-4V: E=114 GPa, UHMWPE block: E=1.0 GPa), and contact definitions. Review checklist signed and archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection justified by physics of the COU; continuum mechanics with nonlinear geometry and frictional contact demonstrated appropriate for pedicle screw compression-bending at the displacement magnitudes tested.",
      "rationale": "Continuum solid mechanics with large-displacement formulation (NLGEOM ON) selected based on expected construct deflections up to 40 mm. Frictional contact (μ=0.2, augmented Lagrange) used at screw-rod and rod-set-screw interfaces. Plasticity not required for stiffness and yield force QoIs as confirmed by stress state review — peak von Mises stress at yield load is 98.4% of Ti-6Al-4V yield strength, justifying elastic-only model for stiffness QoI and bilinear isotropic hardening for yield force QoI. Model form consistent with FDA-recommended approach for F1717 FEA."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs sourced from traceable measurements or certified material certificates; uncertainty in inputs quantified and propagated.",
      "rationale": "Ti-6Al-4V material properties taken from certified mill certificates for the specific lot used in the bench specimens (E=114±2 GPa, σy=880±15 MPa). Geometric inputs derived from CMM measurements of three representative screws (dimensional tolerance ±0.02 mm). Parametric sensitivity analysis showed QoI sensitivity to E of 0.94 (near-linear), with ±2 GPa uncertainty propagating to ±1.7% stiffness uncertainty — well within acceptance bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples are representative of the device design intent; sample size sufficient to characterize experimental variability; traceability to production-equivalent hardware documented.",
      "rationale": "N=11 constructs assembled from production-equivalent 7.5 mm non-cannulated pedicle screws (same lot, same manufacturing process as commercial device). Samples distributed across two independent laboratories (FDA CDRH and DePuy Synthes R&D) to assess inter-laboratory variability. Coefficient of variation for stiffness across all 11 constructs was 4.3%, indicating acceptable experimental repeatability. Sample traceability documented via device history records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios identified in the COU, including variation in load magnitude, rate, and fixation configuration, with FEA predictions validated across this range.",
      "rationale": "The validation dataset encompasses N=11 constructs tested under a single standardized ASTM F1717 configuration: 10 mm anterior offset, quasi-static displacement rate of 5 mm/min, ambient temperature, single rod diameter (5.5 mm), and fixed pedicle-to-pedicle spacing of 44 mm. This configuration represents the most clinically prevalent lumbar instrumentation geometry and was selected in alignment with FDA guidance on F1717 testing. The testing protocol was executed with high fidelity at both laboratories, with inter-laboratory construct stiffness agreement within 3.1%, demonstrating robust experimental control. The FEA model predictions fell within the pre-specified 10% acceptance bound for all three QoIs across both laboratory datasets, and the normalized validation metric E/uval remained below 1.96 for every comparison. The team's collective 40+ years of experience with spinal implant FEA, combined with prior published validation studies covering a range of screw diameters and rod materials, provides strong indirect evidence that the model form and inputs are insensitive to moderate variation in fixation geometry. Expert judgment, supported by a documented sensitivity analysis showing less than 3% QoI change for ±5 mm variation in pedicle spacing, was considered sufficient to address the absence of multi-condition experimental coverage. On this basis, the assessment team concluded that the single-condition validation is adequate for the stated COU, and the factor was rated at the level achieved rather than deferring the submission pending additional testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material properties, boundary conditions, loading) demonstrably equivalent to the physical test configuration; any discrepancies quantified and shown to have negligible impact on QoIs.",
      "rationale": "FEA geometry derived from CAD files used to manufacture the test specimens; dimensional equivalency confirmed by CMM comparison (max deviation 0.03 mm). Boundary conditions replicate the ASTM F1717 fixture: inferior block fully constrained, superior block loaded via displacement control at the defined offset point. Friction coefficient at screw-rod interface measured experimentally (μ=0.19±0.03) and applied in the model. No significant discrepancies identified between model inputs and test configuration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of FEA predictions to experimental measurements using pre-specified metrics (percent difference and E/uval); all QoIs within acceptance bounds.",
      "rationale": "Three QoIs compared: construct stiffness (FEA vs. experimental mean: 4.2% difference, E/uval=0.81), yield force (7.1% max deviation across 11 constructs, E/uval=1.31), and force at 40 mm displacement (8.8% max deviation, E/uval=1.44). All values within pre-specified bounds (<10% difference, E/uval<1.96). Comparison methodology consistent with FDA V&V 40 guidance and ASME V&V 10 uncertainty quantification framework."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation are directly relevant to the clinical performance metrics and failure modes identified in the risk analysis for the COU.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and correspond directly to the mechanical performance attributes most relevant to clinical risk: excessive flexibility (stiffness), permanent deformation onset (yield force), and ultimate load-bearing capacity (40 mm force). These QoIs are mapped to clinical failure modes (pseudarthrosis, screw fatigue, acute fracture) in the device risk analysis (FMEA-001 Rev C). Selection rationale reviewed and approved by the clinical affairs team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario (ASTM F1717 bench test) is sufficiently representative of the clinical COU to support extrapolation of FEA credibility to the intended regulatory submission.",
      "rationale": "The ASTM F1717 test is the regulatory standard for spinal implant mechanical characterization and is directly cited in FDA 510(k) guidance for pedicle screw systems. The bench test configuration replicates the dominant in vivo loading mode (compression-bending) for lumbar pedicle screw constructs. The validation population (N=11, two laboratories) provides statistically meaningful coverage of manufacturing variability. The FEA model validated here is identical in formulation to the model used for the regulatory COU prediction, ensuring direct applicability of the credibility evidence."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 V&V 40 factors for COU1. Twelve of thirteen factors meet or exceed their required credibility levels. The single exception — Test conditions (achieved level 2, required level 3) — reflects the use of a single ASTM F1717 test configuration rather than a multi-condition experimental matrix. The team considered this shortfall in the context of the overall evidence body: (1) all three QoIs passed quantitative acceptance criteria with substantial margin (maximum E/uval of 1.44 against a threshold of 1.96); (2) a documented parametric sensitivity analysis demonstrates that QoI predictions are robust to the range of geometric and loading variations expected in the clinical COU; (3) the team's extensive prior experience with analogous spinal implant FEA validation studies, including multi-condition datasets for comparable screw geometries, provides strong indirect support for model generalizability; and (4) the ASTM F1717 single-condition protocol is the accepted regulatory standard and has been deemed sufficient by FDA in prior 510(k) clearances for equivalent device types. Taken together, the team concluded that the weight of evidence supports acceptance of the model for the stated COU, and that the Test conditions shortfall does not materially undermine confidence in the FEA predictions for the regulatory submission. The decision is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
