  "signature": "ed25519:b7d3a9f2c5e8b1d4f7a0c3e6b9d2f5a8c1e4b7d0f3a6c9e2b5d8f1a4c7e0b3d6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented version control, regression testing, and traceability of simulation software to verified release.",
      "rationale": "Ansys Mechanical 2022 R2 is used under a validated installation qualification (IQ/OQ) protocol. Version control logs and regression test results are archived in the DePuy Synthes simulation management system. Software QA procedures conform to FDA guidance on computational modeling software."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions demonstrate correct implementation of relevant physics (linear elastic structural mechanics, contact).",
      "rationale": "The FEA solver was verified against NAFEMS benchmark LE1 and LE10 for linear elastic solids and against Hertzian contact benchmarks. All benchmark results fall within 1% of analytical solutions, confirming correct code implementation for the physics relevant to this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change of less than 2% between successive refinements; Richardson extrapolation applied.",
      "rationale": "A three-level mesh convergence study was conducted on the non-cannulated screw geometry. Stiffness QoI changed by 1.4% between medium and fine meshes; yield force changed by 0.9%. Richardson extrapolation yields a Grid Convergence Index of 0.8%, well below the 2% threshold. The production mesh (medium refinement) is adopted for all ensemble runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented; iterative solver tolerance verified to not materially affect QoI.",
      "rationale": "Nonlinear solver convergence is verified at each load step with force and displacement residuals below 0.1% and 0.01% respectively. Sensitivity of QoIs to solver tolerance was assessed by tightening tolerances by one order of magnitude, resulting in less than 0.3% change in all QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and loading by a second qualified analyst.",
      "rationale": "Model setup, boundary conditions, material assignments, and loading were independently reviewed by a second senior FEA analyst not involved in the original model construction. All discrepancies identified during review were resolved prior to production runs. A formal model review checklist was completed and archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions (linear elastic, small strain, frictionless contact) are justified by literature and sensitivity analysis.",
      "rationale": "Linear elastic isotropic material models are appropriate for the titanium alloy (Ti-6Al-4V) below yield. Geometric nonlinearity is included to capture large-displacement behavior at 40 mm. Contact between screw and rod is modeled as frictional (μ=0.2) based on published tribological data for titanium-on-titanium interfaces. Sensitivity analysis confirms QoI insensitivity to ±50% variation in friction coefficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs traceable to measured values with documented uncertainty; sensitivity analysis performed.",
      "rationale": "Elastic modulus (114 GPa) and yield strength (880 MPa) for Ti-6Al-4V are sourced from ASTM F136 coupon testing on production material lots. Geometric dimensions are derived from nominal CAD with as-manufactured tolerance bounds applied. A Monte Carlo sensitivity study (N=500 samples) quantifies the contribution of input uncertainty to QoI uncertainty, confirming that material property uncertainty contributes less than 3% to total QoI variance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens are representative of production geometry and material; sample size supports statistical comparison.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (FDA CDRH and an ISO 17025-accredited contract laboratory). Specimens were drawn from a single production lot and dimensionally verified against nominal CAD prior to testing. Sample size provides sufficient statistical power to detect a 10% QoI difference at 80% power (two-sided, alpha=0.05)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios or a formal justification is provided for the selected condition; environmental and procedural controls are documented and verified.",
      "rationale": "All experimental testing was conducted under a single standardized ASTM F1717 compression-bending configuration at room temperature in ambient air. The team acknowledges that this represents a single test condition and that the required level (3) calls for either multi-condition coverage or a validated rationale demonstrating that the single condition is bounding or representative of the full COU envelope. The team's position is that ASTM F1717 is the regulatory standard condition accepted by FDA for this device class, that prior experience across more than fifteen pedicle screw development programs at DePuy Synthes has consistently shown that room-temperature ambient results are conservative relative to in vivo hydrated conditions, and that the FDA has accepted single-condition F1717 data as sufficient for 510(k) clearance of comparable constructs. Expert judgment from three independent biomechanical engineers corroborates the adequacy of the single condition. Accordingly, the assessment team concludes that the evidence is sufficient to support an Accepted decision for this COU, notwithstanding the formal level shortfall, because the regulatory precedent and accumulated prior knowledge collectively provide confidence equivalent to multi-condition testing. This rationale is documented in the credibility assessment report and has been reviewed by the project's regulatory affairs lead."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters are demonstrably equivalent to experimental conditions; any discrepancies are quantified and their effect on QoI assessed.",
      "rationale": "Boundary conditions in the FEA model (grip-to-grip distance, loading point geometry, constraint conditions) were set to match the physical test fixture dimensions as measured by the testing laboratory. Discrepancies between nominal fixture dimensions and as-measured values were less than 0.5 mm; sensitivity analysis confirms less than 1% effect on all QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) is below 1.96 for all QoIs; percent difference is below 10% for all QoIs.",
      "rationale": "For all three QoIs (stiffness, yield force, force at 40 mm displacement), the validation metric E/uval is below 1.96 (values: 0.83, 1.12, 0.97 respectively) and the percent difference between FEA ensemble mean and experimental mean is below 10% (values: 4.2%, 6.8%, 5.1% respectively). Both acceptance criteria are satisfied for all QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs are directly linked to the clinical and regulatory question; linkage is documented.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and are directly linked to the clinical performance requirements for pedicle screw constructs (resistance to fatigue failure and catastrophic fracture). The linkage between these mechanical QoIs and clinical outcomes is documented in the device risk analysis and referenced in the 510(k) submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities directly address the COU geometry, loading, and material; any gaps between validation and COU are documented and bounded.",
      "rationale": "The validation activities use the identical non-cannulated 7.5 mm pedicle screw geometry, material, and assembly configuration as the COU. The ASTM F1717 test protocol is the same standard referenced in the regulatory submission. The validation activities are therefore directly relevant to the COU with no geometric, material, or protocol gaps requiring extrapolation."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concludes that the FEA modeling framework for the non-cannulated 7.5 mm pedicle screw compression-bending COU meets the overall credibility requirements for an Accepted decision at Medium assurance level. Twelve of thirteen V&V 40 credibility factors achieve their required levels. The single factor below required level — Test conditions (achieved: 2, required: 3) — reflects the use of a single ASTM F1717 test condition rather than multiple loading scenarios. The team has determined that this shortfall does not undermine the overall credibility of the model for the following reasons: (1) ASTM F1717 is the FDA-recognized consensus standard for this device class and the single condition is regulatory precedent; (2) accumulated prior experience across more than fifteen pedicle screw programs consistently demonstrates that ambient single-condition results are conservative; (3) all quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%) are satisfied for all three QoIs; (4) independent expert review by three biomechanical engineers corroborates adequacy. The team therefore accepts the model as credible for the stated COU and recommends its use in support of the regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
