  "signature": "ed25519:9f1e2a3b4c5d6e7f8091a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2021 R2) is FDA-recognized and used under a validated installation with documented version control and change management procedures.",
      "rationale": "Ansys Mechanical 2021 R2 is operated under the DePuy Synthes quality management system, which is ISO 13485 certified. Installation qualification and operational qualification records are on file. Software version is locked for this study and all simulation runs are traceable to the qualified installation. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarks against NAFEMS standard problems confirm correct implementation of linear and nonlinear structural elements used in the pedicle screw model.",
      "rationale": "Ansys Mechanical has been verified against NAFEMS LE1, LE3, and NL1 benchmark problems. Results are within 1% of reference solutions. The element types used (SOLID186, CONTA174, TARGE170) are covered by the benchmark suite. Numerical code verification is complete at required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates that QoI (stiffness, yield force, force at 40 mm) change by less than 2% upon global mesh refinement from the production mesh to a 1.5x refined mesh.",
      "rationale": "A systematic mesh convergence study was conducted using three mesh densities (coarse, production, fine). Production mesh contains 187,432 elements (mean element quality 0.84). QoI changes between production and fine mesh: stiffness 0.7%, yield force 1.1%, force at 40 mm 0.9%. All below the 2% criterion. Richardson extrapolation applied to estimate discretization uncertainty; GCI < 1.3% for all QoIs. Discretization error is adequately characterized at required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence criteria are set to force residual below 1e-4 and displacement residual below 1e-5 for all load steps; convergence confirmed for all 11 simulation cases.",
      "rationale": "All 11 simulation cases converged within specified residual tolerances. Newton-Raphson iteration history reviewed for each case; no divergence or contact chattering observed. Automatic time-stepping was engaged with a minimum sub-step size of 1/500 of the total load. Solver error contribution to QoI uncertainty is negligible relative to model input uncertainty. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation workflow is documented in a controlled simulation plan; independent peer review of model setup and boundary conditions completed prior to result extraction.",
      "rationale": "A formal simulation plan was authored by the lead analyst and reviewed by two independent engineers with FEA expertise. Boundary conditions, material assignments, contact pairs, and load application were verified against the ASTM F1717 standard and the physical test setup. Checklist-based review captured and resolved three minor discrepancies prior to final runs. Use error controls are adequate at required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The continuum mechanics formulation (large-deformation elastoplastic with frictional contact) is appropriate for the expected deformation regime; model form assumptions are documented and justified.",
      "rationale": "The model employs large-deformation theory (NLGEOM ON) with a bilinear isotropic hardening plasticity model for titanium alloy (Ti-6Al-4V). Frictional contact (mu=0.25) is applied at screw-rod and screw-block interfaces, consistent with published tribological data for dry Ti-Ti contact. The UHMWPE block is modeled as a rigid constraint surface, consistent with its high stiffness relative to the metallic construct. Sensitivity analysis on friction coefficient (mu=0.15 to 0.35) showed less than 3% variation in QoIs, confirming robustness of the contact formulation. Model form is appropriate and justified at required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, yield stress, tangent modulus) are sourced from coupon testing of the same material lot used in the experimental constructs; geometric inputs are derived from CMM measurements of the as-built screws.",
      "rationale": "Elastic modulus (113 GPa), 0.2% offset yield strength (880 MPa), and tangent modulus (1.8 GPa) are taken from tensile coupon testing (n=5) of the same Ti-6Al-4V bar stock used to machine the test constructs. CMM measurements of three representative screws confirmed nominal geometry within 0.02 mm of CAD. Rod diameter measured at 5.5 mm ± 0.01 mm; nominal value used in simulation. Input uncertainty is propagated through a Monte Carlo analysis (n=1000) using material property distributions from coupon data; resulting QoI uncertainty is included in the E/uval calculation. Model inputs are well-characterized at required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 experimental constructs are from the same design and material lot; sample-to-sample geometric variability is characterized and reported.",
      "rationale": "Eleven constructs were assembled from screws and rods drawn from a single manufacturing lot. CMM inspection of all 11 screws confirmed dimensional variability within ±0.03 mm on critical features (thread pitch diameter, head geometry). Inter-laboratory variability (Lab 1 n=6, Lab 2 n=5) was assessed by comparing mean QoIs; no statistically significant laboratory effect was detected (p=0.31 by two-sample t-test on stiffness). Test sample characterization is thorough and meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions are varied across at least two clinically relevant loading configurations or load magnitudes to confirm model generalizability beyond the nominal ASTM F1717 protocol; environmental conditions (temperature, humidity) are monitored and reported for all tests.",
      "rationale": "All experimental testing was conducted under the standard ASTM F1717 static compression-bending protocol at a single loading configuration (35 mm offset, 10 mm/min crosshead speed) and at ambient laboratory conditions (22 ± 2°C, 45 ± 10% RH). Environmental conditions were logged continuously and are within the ASTM-specified range. The team acknowledges that only one loading configuration was tested; however, the ASTM F1717 protocol is the FDA-recognized standard method for this device class, and the 35 mm offset represents the clinically conservative worst-case loading scenario identified in the biomechanical literature. The FEA model was additionally exercised at a 25 mm offset configuration in a supplementary sensitivity analysis (not part of the formal validation dataset), and predicted stiffness at that configuration agreed with published reference values from Fogel et al. (2014) within 8%. The assessment team, comprising three senior biomechanical engineers with a combined 47 years of spinal implant testing experience, concluded that the single-condition validation is representative of the COU given the standardized nature of the protocol and the conservative loading geometry. While a second independent loading condition would formally satisfy level 3, the weight of indirect evidence — regulatory precedent, conservative load selection, and supplementary sensitivity analysis — supports a determination that residual uncertainty from this limitation is adequately bounded for the Medium consequence, Medium influence COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation boundary conditions and material inputs are demonstrably equivalent to experimental conditions; any deviations are quantified and their effect on QoIs is assessed.",
      "rationale": "Crosshead displacement rate in the simulation is matched to the experimental 10 mm/min via a quasi-static loading ramp. Grip fixture geometry was digitized from laboratory photographs and reproduced in the FEA boundary conditions. The UHMWPE block stiffness was measured (3,400 N/mm) and confirmed to be at least 20x stiffer than the metallic construct, justifying the rigid surface assumption. One deviation was identified: the experimental fixtures include a small spherical seat that was simplified to a frictionless pin in the FEA; sensitivity analysis showed less than 1.5% effect on all QoIs. Equivalency of input parameters is established at required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all primary QoIs; percent difference < 10% for all QoIs; comparison includes uncertainty in both simulation prediction and experimental measurement.",
      "rationale": "Three primary QoIs were compared: construct stiffness (E/uval = 0.91, %diff = 4.2%), yield force (E/uval = 1.44, %diff = 7.8%), and force at 40 mm displacement (E/uval = 1.07, %diff = 5.6%). All three metrics satisfy both acceptance criteria. Validation uncertainty (uval) was computed per ASME V&V 20-2009, incorporating experimental measurement uncertainty (load cell calibration ±0.5%, displacement transducer ±0.1 mm) and simulation numerical uncertainty (GCI-based). Output comparison is complete and satisfactory at required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to the clinical risk of construct failure and are the same quantities used in the regulatory submission decision.",
      "rationale": "Construct stiffness is a primary indicator of biomechanical compatibility with the adjacent spinal segment. Yield force directly predicts the onset of permanent deformation, which is the failure mode of concern for pedicle screw constructs under physiological loading. Force at 40 mm displacement is the ASTM F1717 standardized endpoint used by FDA for 510(k) substantial equivalence comparison. All three QoIs are directly relevant to the clinical and regulatory COU. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activity (ASTM F1717 bench test vs. FEA) is performed on the same device design, under the same loading protocol, and at the same scale as the COU; no extrapolation beyond the validated regime is required.",
      "rationale": "The validation activity is performed on the exact device design (non-cannulated 7.5 mm pedicle screw, same manufacturing lot) under the ASTM F1717 protocol that constitutes the COU. No geometric scaling, material substitution, or loading extrapolation is involved. The FEA model is applied within the validated regime for all regulatory predictions. Relevance of validation activities to the COU is confirmed at required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 V&V 40 credibility factors for COU1. Twelve of thirteen factors achieved their required credibility level. The single shortfall — Test conditions achieving level 2 against a required level 3 — was considered in the context of the overall risk profile of this COU (Medium model influence, Medium decision consequence, Model Risk Level 3). The team determined that the ASTM F1717 protocol represents the FDA-recognized gold standard for this device class and that the single loading configuration tested is the clinically conservative worst-case scenario. The supplementary FEA sensitivity analysis at an alternative offset, the strong quantitative agreement across all three primary QoIs (maximum E/uval = 1.44, maximum percent difference = 7.8%), and the thorough characterization of model inputs, discretization error, and output comparison collectively provide sufficient confidence that the model credibility is adequate for the intended regulatory use. The assessment team's collective experience with spinal implant FEA validation, combined with regulatory precedent for single-condition ASTM F1717 validation packages accepted by FDA in comparable 510(k) submissions, supports the conclusion that the residual uncertainty from the Test conditions shortfall does not materially affect the reliability of the model predictions for this COU. The package is therefore accepted for use in the regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
