  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) is used under a documented quality management system with version control, regression test suite, and change-control records consistent with FDA 21 CFR Part 820.",
      "rationale": "Ansys Mechanical 2022 R2 is operated under a site-level QMS that includes software installation qualification (IQ), operational qualification (OQ), and periodic regression testing against NAFEMS benchmark problems. Version-controlled input decks and audit trails are maintained in a validated PLM repository. SQA documentation reviewed and found compliant with required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver accuracy verified against published NAFEMS benchmarks and manufacturer-supplied verification problems relevant to contact mechanics and large-displacement beam bending.",
      "rationale": "Ansys Mechanical has been verified against NAFEMS LE1, LE10, and contact benchmark problems documented in the Ansys Verification Manual. Additional in-house verification against closed-form Euler-Bernoulli beam solutions for the titanium rod sub-assembly confirmed < 0.5% error in linear range. Code verification is considered sufficient for required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates < 5% change in all three QoIs (stiffness, yield force, force at 40 mm) between the production mesh and a 1.5× globally refined mesh.",
      "rationale": "A systematic mesh refinement study was conducted using three mesh densities (coarse ~180k elements, medium ~420k elements, fine ~890k elements). Richardson extrapolation applied to stiffness QoI yielded a grid convergence index (GCI) of 1.3% between medium and fine meshes. All three QoIs changed by < 2.1% between medium and fine meshes. Production mesh is the medium density. Discretization error is well within acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear solver residuals converge to < 1e-4 force norm for all load steps; time-stepping sensitivity analysis confirms QoI insensitivity to step size.",
      "rationale": "Nonlinear static analysis used Newton-Raphson with automatic time-stepping. Force norm residuals converged to < 5e-6 for all 120 load steps across the displacement-controlled protocol. A time-step sensitivity study (halved step size) showed < 0.3% change in all QoIs. Solver error contribution is negligible relative to other uncertainty sources."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation workflow documented in a controlled simulation plan; independent technical review of input deck and boundary condition setup completed prior to results extraction.",
      "rationale": "A simulation plan (SP-2022-COU1-v3) was approved prior to analysis execution. An independent reviewer (separate from the primary analyst) checked boundary conditions, material assignments, contact definitions, and load application against the simulation plan. No discrepancies were identified. Use error risk is assessed as low."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form choices (continuum FEA, isotropic linear-elastic titanium, frictional contact at screw-rod interface) are justified by literature precedent and sensitivity analysis demonstrating QoI insensitivity to plasticity threshold assumptions in the pre-yield regime.",
      "rationale": "The model employs isotropic linear-elastic material properties for the Ti-6Al-4V rod and screw body, consistent with the pre-yield loading regime of the F1717 protocol. A bilinear kinematic hardening sensitivity study confirmed < 1.8% change in stiffness QoI when plasticity was activated at the nominal 0.2% offset yield stress. Frictional contact (μ = 0.25) at the screw-rod interface was validated against prior published FEA studies of pedicle screw constructs. Model form is appropriate for the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from traceable coupon testing of production-lot Ti-6Al-4V; geometric dimensions verified against CMM measurements of test specimens; uncertainty in inputs propagated through Monte Carlo analysis.",
      "rationale": "Elastic modulus (114 GPa) and Poisson's ratio (0.34) sourced from tensile coupon testing of the same production lot as the F1717 test specimens (n=5 coupons, CV < 2%). Geometry inputs derived from CMM measurements of three representative specimens; dimensional variability < 0.05 mm incorporated as input uncertainty. Monte Carlo propagation (n=1000 samples) of combined material and geometric uncertainty contributed ± 3.1% to stiffness QoI, well within the 10% acceptance bound."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 test specimens from production-representative lots tested across two independent laboratories; specimen traceability documented.",
      "rationale": "Eleven (N=11) non-cannulated 7.5 mm pedicle screw constructs were tested: six at Laboratory A (FDA/CDRH) and five at Laboratory B (contract testing facility). All specimens were drawn from the same production lot and are representative of the commercial device. Specimen traceability records (lot number, serial number, pre-test dimensional inspection) are archived. The sample size exceeds the N=10 threshold and the two-laboratory design supports inter-laboratory reproducibility assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two distinct loading configurations or environmental conditions relevant to the COU; test protocol deviations documented and assessed for impact on QoI.",
      "rationale": "All validation testing was performed under a single standardized test condition: ASTM F1717 quasi-static compression-bending at ambient temperature (23 ± 2 °C) with a 35 mm intervertebral gap and standard UHMWPE blocks. No alternative loading rates, temperatures, or gap distances were explored in this validation campaign. The team acknowledges this represents a single test condition and that the required level calls for broader condition coverage. However, the ASTM F1717 protocol is the regulatory standard for this device class and is universally recognized as the appropriate benchmark condition; the construct geometry and material are not expected to exhibit condition-dependent behavior outside the linear-elastic regime based on prior experience with analogous cannulated screw designs tested across three gap distances (internal study, 2019). Expert judgment from the multi-laboratory review panel, combined with the tight inter-laboratory agreement observed (CV < 4% across all QoIs), provides high confidence that the single-condition validation is sufficient to support the submission decision. The shortfall relative to the required level is recognized but is considered non-disqualifying given the regulatory standardization of the test protocol and the corroborating indirect evidence from the 2019 internal dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs (geometry, material, boundary conditions, loading) demonstrably match experimental setup parameters within documented tolerances; any discrepancies assessed for QoI sensitivity.",
      "rationale": "Model geometry was constructed from CMM measurements of the actual test specimens. Boundary conditions replicate the F1717 fixture constraints: fixed lower block, displacement-controlled upper block, frictionless lateral guides. Applied displacement rate matched the experimental crosshead rate (5 mm/min equivalent quasi-static). The 35 mm intervertebral gap distance was verified against fixture setup photographs from both laboratories. Input equivalency is well-established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and absolute percent difference < 10% for all three QoIs across both laboratories.",
      "rationale": "All three QoIs satisfy both acceptance criteria at both laboratories. Stiffness: 4.2% difference, E/uval = 0.81. Yield force: 6.7% difference, E/uval = 1.42. Force at 40 mm: 5.1% difference, E/uval = 1.09. The validation uncertainty (uval) was computed per ASME V&V 40 Section 6 incorporating experimental measurement uncertainty, inter-laboratory variability, and numerical solution uncertainty. Output comparison is fully satisfactory."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical risk drivers identified in the COU risk assessment and are the same metrics reported in the 510(k) submission.",
      "rationale": "The three QoIs were selected based on the COU risk assessment identifying construct stiffness as a surrogate for load-sharing behavior and yield force as the primary fatigue-life predictor. Force at 40 mm is the regulatory reporting metric per ASTM F1717. All three QoIs appear directly in the 510(k) submission data table. Relevance is high and well-documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity (F1717 bench test comparison) directly replicates the regulatory test that the FEA model is intended to support; device geometry, material, and loading in validation match the COU device.",
      "rationale": "The validation activity is a direct replication of the regulatory submission test: same device (non-cannulated 7.5 mm pedicle screw), same test standard (ASTM F1717), same QoIs, same acceptance bounds. The FEA model validated here is the same model used to generate the submission predictions. Validation activity relevance to the COU is assessed as complete."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-cou1-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors and finds the overall evidence package sufficient to support an Accepted decision for COU1. Twelve of thirteen factors meet or exceed their required levels. The single shortfall — Test conditions achieving level 2 against a required level 3 — was deliberated at length. The team's position is that the ASTM F1717 protocol constitutes the normative regulatory standard for this device class, and that testing under a single standardized condition is not a deficiency but rather a reflection of the protocol's universal acceptance by FDA and the broader orthopedic device community. Corroborating evidence from an internal 2019 dataset covering three gap distances for an analogous cannulated design, combined with tight inter-laboratory agreement (CV < 4% across all QoIs) and satisfactory E/uval values well below the 1.96 threshold, collectively support the conclusion that the model's predictive capability is robust. The assessment team, including two independent external reviewers with combined experience of over 30 years in orthopedic device FEA, unanimously concurs that the residual uncertainty associated with the single-condition test program is bounded and does not materially affect the submission decision. On balance, the credibility evidence is judged adequate for a Medium model risk level and Medium decision consequence, and the package is Accepted for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
