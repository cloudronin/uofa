  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) operates under an FDA-recognized quality management system; version control and audit trail documented.",
      "rationale": "Ansys Mechanical 2022 R2 is deployed under an ISO 13485-compliant QMS at DePuy Synthes. Software version is locked, and all simulation runs are executed from a validated installation with documented change control. Verification test suite results are archived and traceable to the build hash. Required level 2 is fully met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 and Ansys verification manual exercised; results match analytic solutions within 0.5%.",
      "rationale": "Standard Ansys verification benchmarks (static structural, contact, large-deformation) were executed against analytic and published reference solutions. All benchmark results fall within 0.5% of reference values. Code verification is considered adequate for the implicit nonlinear static analysis employed in this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between successive refinement levels; Richardson extrapolation applied.",
      "rationale": "Three mesh refinement levels (coarse: ~85k elements, medium: ~210k elements, fine: ~520k elements) were evaluated. Stiffness QoI changed 4.1% coarse-to-medium and 1.3% medium-to-fine. Richardson extrapolation on the medium and fine solutions yields a grid convergence index of 1.7%, within the 2% threshold. Discretization error is adequately characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force and displacement residuals converge to < 1e-4 relative norm for all load steps; no spurious contact oscillations observed.",
      "rationale": "All 11 simulation runs achieved force residual < 5e-5 and displacement residual < 8e-5 relative norm at each converged load step. Augmented Lagrange contact with a stabilization damping factor of 0.001 was employed; post-processing confirmed no spurious oscillations in the contact force history. Solver accuracy is sufficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs reviewed by independent analyst; boundary condition application verified against ASTM F1717 test fixture geometry.",
      "rationale": "Model setup was performed by a senior FEA engineer and independently reviewed by a second analyst with no prior involvement in the model build. Boundary conditions (fixed inferior block, axially loaded superior block at 5° from construct axis per F1717) were verified against test fixture drawings. No use errors were identified during the independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model (bilinear isotropic hardening for Ti-6Al-4V) validated against coupon-level tensile test data; contact formulation appropriate for screw-rod interface.",
      "rationale": "Bilinear isotropic hardening parameters (E=114 GPa, σ_y=880 MPa, E_t=1.8 GPa) were calibrated against five Ti-6Al-4V tensile coupons from the same material lot. Augmented Lagrange frictional contact (μ=0.15) was selected based on published tribological data for titanium alloy interfaces. Model form uncertainty is bounded and documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from lot-specific measurements; uncertainty in inputs propagated via one-at-a-time sensitivity study.",
      "rationale": "Screw and rod cross-section dimensions were measured from three representative components per lot using CMM (±0.005 mm). Material properties were drawn from tensile coupon data (n=5). One-at-a-time sensitivity analysis showed QoI sensitivity to elastic modulus (±3%) and yield stress (±2%) within acceptable bounds. Input uncertainty contribution is less than 4% of total model uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lots; sample variability characterized; constructs traceable to manufacturing records.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production lots and tested across two independent laboratories (Lab 1: n=6, Lab 2: n=5). All constructs are traceable to manufacturing batch records. Inter-laboratory coefficient of variation for stiffness was 4.2%, indicating acceptable sample consistency. Sample size meets the pre-specified minimum of N=10."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios including at least two distinct load magnitudes or orientations; environmental conditions (temperature, humidity) monitored and reported.",
      "rationale": "Testing was performed strictly in accordance with ASTM F1717 at a single compression-bending load condition (5° off-axis, displacement-controlled at 5 mm/min to 40 mm). Laboratory environmental conditions (23±2°C, 50±5% RH) were monitored and logged throughout both test campaigns. The standardized F1717 protocol is the regulatory reference condition and is universally recognized as the benchmark for pedicle screw construct evaluation. The assessment team notes that while only a single load angle was evaluated, the F1717 condition represents the most conservative loading scenario identified in the biomechanics literature for this construct geometry, and prior experience across more than 200 similar construct evaluations has consistently demonstrated that models passing the F1717 criterion also perform adequately under adjacent loading conditions. Expert judgment from three senior biomechanical engineers concurs that the single-condition test is sufficient to characterize model fidelity for the intended regulatory submission context. On balance, the team considers the evidence materially adequate to support the submission decision, and the single-condition limitation is acknowledged in the uncertainty budget without escalation to a formal gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material properties, boundary conditions) demonstrably equivalent to experimental test conditions; any deviations quantified and their effect on QoI bounded.",
      "rationale": "FEA geometry was reconstructed from CMM measurements of the actual test constructs. Boundary conditions replicate the F1717 fixture geometry as confirmed by overlay comparison. The only identified deviation is idealization of the UHMWPE vertebral body surrogate as a rigid surface; sensitivity analysis shows this assumption changes stiffness QoI by less than 1.5%, which is within the experimental measurement uncertainty (±2.1%). Equivalency is considered demonstrated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all three QoIs; E/uval < 1.96 for all QoIs; percent difference < 10%.",
      "rationale": "E/uval was computed for stiffness (1.44), yield force (1.31), and force at 40 mm (1.21), all below the 1.96 threshold. Maximum percent differences were 7.3%, 8.1%, and 6.8% respectively, all below the 10% criterion. The comparison metric is considered to demonstrate adequate model predictive capability across all three QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly correspond to regulatory submission requirements and clinical failure modes.",
      "rationale": "The three QoIs are explicitly specified in FDA guidance for pedicle screw 510(k) submissions and correspond to the primary mechanical failure modes (excessive flexibility, plastic deformation, fatigue initiation). The QoIs are directly measurable in both simulation and experiment without intermediate inference steps. Relevance is unambiguous."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (F1717 compression-bending) is the same scenario as the COU; no extrapolation beyond validated conditions required for the regulatory submission.",
      "rationale": "The validation activity is identical to the COU: static compression-bending of the non-cannulated 7.5 mm construct per ASTM F1717. No extrapolation in loading mode, geometry, or material is required. The validation scenario is a direct analogue of the intended regulatory use, maximizing relevance and minimizing scenario uncertainty."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for COU1. Twelve of thirteen factors achieved their required credibility level. The single shortfall — Test conditions (achievedLevel 2 vs. requiredLevel 3) — was deliberated at length. The team determined that the ASTM F1717 single-condition protocol represents the regulatory gold standard for pedicle screw construct evaluation, that the achieved E/uval values across all three QoIs are well within the 1.96 threshold, and that the combined weight of N=11 constructs across two independent laboratories, lot-traceable material characterization, and independent model review provides a level of overall evidence commensurate with Medium assurance. The Test conditions shortfall is formally acknowledged in the uncertainty budget and does not, in the team's collective judgment, undermine the validity of the submission claim. The package is therefore accepted for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
