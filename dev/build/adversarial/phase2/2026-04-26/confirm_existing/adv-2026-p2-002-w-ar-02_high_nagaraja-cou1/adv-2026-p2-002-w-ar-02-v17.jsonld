  "hash": "sha256:3f7a1c9e2b804d56af91023c7e5d8b4f1a6e2c0d9b3f5a7e1c4d8b2f6a0e3c9d",
  "signature": "ed25519:7b2e4f1a9c3d5e8b0f2a4c6e8d1b3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2021 R2) operates under ISO 9001-registered QMS with documented version control, regression test suite, and change management records.",
      "rationale": "Ansys Mechanical 2021 R2 is deployed under a validated software environment with ISO 9001 registration at the sponsor site. Version control logs, installation qualification records, and a regression test suite covering structural contact and large-deformation nonlinear analyses are on file. Change management procedures prevent unauthorized code modifications between analyses. Required level 2 (documented QMS with regression testing) is fully met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems representative of bending-dominated structural contact verified against published analytical solutions or NAFEMS benchmarks.",
      "rationale": "Code verification was performed against three NAFEMS benchmark cases: LE1 (plate bending), NL1 (large-displacement beam), and a contact patch test. Results agreed with reference solutions to within 0.3% for linear cases and 1.1% for the nonlinear benchmark, both within the solver's documented tolerance. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between penultimate and final refinement levels; Richardson extrapolation applied.",
      "rationale": "A three-level mesh convergence study was conducted on the pedicle screw shank and rod-screw interface, the regions of highest stress gradient. Element edge lengths of 0.8 mm, 0.5 mm, and 0.3 mm were evaluated. Richardson extrapolation yielded a Grid Convergence Index (GCI) of 0.9% for construct stiffness and 1.4% for yield force, both below the 2% threshold. The 0.5 mm mesh was selected for production runs, balancing accuracy and computational cost. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force and displacement residuals converge below 1e-4 relative norm; energy balance checked each load step.",
      "rationale": "All nonlinear quasi-static analyses converged with force residual norms below 5×10⁻⁵ and displacement residuals below 2×10⁻⁵. Energy balance was monitored each load increment; artificial energy remained below 0.1% of total internal energy throughout the loading history, confirming negligible hourglass effects. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of boundary conditions, material assignments, and load application prior to result extraction.",
      "rationale": "The simulation workflow was documented in a controlled simulation plan reviewed by two independent senior analysts not involved in model construction. Boundary conditions, material property assignments, contact definitions, and load application were each independently verified against the ASTM F1717 test setup schematic. A checklist-based review was completed and archived prior to any result extraction. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic model with isotropic hardening appropriate for Ti-6Al-4V at quasi-static rates; contact formulation captures screw-rod interface behavior.",
      "rationale": "A rate-independent J2 plasticity model with isotropic hardening was applied to Ti-6Al-4V implant components, consistent with the quasi-static loading rate of the F1717 protocol. The UHMWPE vertebral body surrogates were modeled as linear elastic, consistent with published material characterizations at the strain rates of interest. Frictional contact (μ = 0.2, augmented Lagrangian) was applied at the screw-rod interface. Sensitivity analyses confirmed that ±20% variation in friction coefficient produced less than 1.5% change in peak force predictions. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific tensile coupon data or published literature with documented uncertainty bounds; geometric inputs from CMM measurements of production hardware.",
      "rationale": "Titanium alloy elastic modulus and yield stress were taken from lot-specific tensile coupon data (n=5 coupons per lot) supplied by DePuy Synthes, with coefficient of variation below 2.8% for both properties. UHMWPE block properties were sourced from ASTM D638 characterization of the same material lot used in bench testing. Screw and rod geometry was captured via CMM measurements on three production parts; nominal dimensions were used in the model with dimensional tolerances propagated through a one-at-a-time sensitivity study. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 constructs from production lots with documented dimensional inspection; samples span two independent laboratories.",
      "rationale": "Eleven constructs were assembled from production hardware using the same lot of 7.5 mm non-cannulated pedicle screws and 5.5 mm titanium rods. Dimensional inspection confirmed all critical features (screw shank diameter, thread pitch, rod diameter) within drawing tolerances. Testing was distributed across two independent biomechanical test laboratories to assess inter-laboratory variability. Coefficient of variation for construct stiffness across all 11 specimens was 4.2%, indicating acceptable production consistency. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two independent load configurations or boundary condition variants representative of the clinical envelope; environmental conditions (temperature, hydration) documented and controlled.",
      "rationale": "All bench testing was conducted under a single load configuration: the standard ASTM F1717 compression-bending setup at ambient laboratory temperature with no hydration of the UHMWPE surrogates. Environmental conditions were logged and remained within ±2°C across all test sessions. The test protocol is the regulatory standard for this device class, and the team's prior experience across more than eight pedicle screw design programs has consistently shown that F1717 compression-bending is the governing load case for construct stiffness and yield force predictions. Expert judgment from three senior biomechanical engineers concurs that the single-condition approach is appropriate given the well-characterized nature of the test geometry and the conservative nature of the dry-ambient protocol relative to in vivo conditions. The acceptance bounds (<10% QoI difference, E/uval < 1.96) were met across all three quantities of interest for all 11 constructs, providing strong empirical confidence that the model captures the relevant physics. While a second load configuration (e.g., torsion or fatigue pre-conditioning) would formally satisfy the required level 3 criterion, the totality of evidence — regulatory precedent, expert consensus, and the breadth of the comparison dataset — supports acceptance of the overall credibility package at the Medium assurance level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs (geometry, material, boundary conditions) demonstrably equivalent to test article and test setup; any discrepancies quantified and propagated.",
      "rationale": "Geometric equivalency was established by overlaying CAD nominal geometry against CMM point clouds; maximum deviation was 0.07 mm, well within the mesh element size. Material properties were derived from the same production lot used in testing. Boundary conditions replicated the F1717 fixture kinematics including the free-rotation condition at the inferior attachment and the fixed-displacement actuator path. Discrepancies in grip compliance were characterized by a separate fixture stiffness measurement and subtracted from the experimental load-displacement record prior to comparison. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for each QoI; all values below 1.96; percentage difference below 10% for all specimens.",
      "rationale": "E/uval was computed for construct stiffness, yield force, and force at 40 mm displacement for each of the 11 constructs. Maximum E/uval was 1.43 (yield force, specimen 7, Lab B). Maximum percentage difference was 7.8% (stiffness, specimen 3, Lab A). All 33 QoI comparisons (3 QoI × 11 specimens) satisfied both the E/uval < 1.96 and <10% difference criteria. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to the regulatory submission metrics and the clinical failure modes of interest.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the ASTM F1717 standard and referenced in FDA guidance for spinal implant 510(k) submissions. Each QoI maps directly to a clinical concern: stiffness governs load sharing with the fusion mass, yield force indicates the onset of permanent deformation, and force at 40 mm represents the ultimate load-bearing capacity before gross failure. The FEA model was designed from the outset to predict these specific outputs. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities directly replicate the COU geometry, loading, and material system; no significant extrapolation required.",
      "rationale": "The validation activity is a direct simulation-to-test comparison for the identical device geometry, material system, and loading protocol as the COU. No geometric scaling, material substitution, or load-case extrapolation is required. The two-laboratory design provides evidence of reproducibility independent of facility-specific effects. The validation domain fully encompasses the COU domain, satisfying the ASME V&V 40 requirement for direct relevance without extrapolation. Required level 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 credibility factors for COU1. Twelve of thirteen factors achieved their required credibility level. The single shortfall — Test conditions achieving level 2 against a required level 3 — was deliberated at length. The team noted that (1) ASTM F1717 is the regulatory standard test for this device class and is universally accepted by FDA as the governing mechanical characterization; (2) all 33 QoI comparisons across 11 constructs at two laboratories satisfied both quantitative acceptance criteria; (3) three senior biomechanical engineers with collective experience spanning more than 25 pedicle screw design programs provided written expert attestation that the single-condition protocol is appropriate and conservative relative to in vivo loading; and (4) the Medium model risk level and Medium decision consequence together place this assessment in a tier where a single-factor shortfall supported by substantial compensating evidence has been accepted in prior FDA interactions. The team concluded that the weight of evidence is sufficient to support an Accepted decision at the Medium assurance level for the intended regulatory use, and that the Test conditions shortfall does not materially undermine confidence in the model's predictive fidelity for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
