  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework is accepted for the COU. Eleven of thirteen V&V 40 credibility factors meet or exceed their required levels. One factor (Test conditions) is below required level (achieved 2, required 3) due to single test condition; this gap is acknowledged and compensated by three independent QoIs extracted from the validated condition. One factor (Equivalency of input parameters) was not formally assessed on the grounds that ASTM F1717 protocol specificity renders equivalency self-evident; the assessment team did not formally scope this factor out or classify it as not-applicable, and no gradation evidence was assembled. Given the model risk level of 3, this unassessed factor represents an unresolved credibility gap that should be remediated in a subsequent assessment cycle. Despite this gap, the overall weight of evidence — three QoIs within acceptance bounds, E/uval < 1.96 for all, multi-laboratory confirmation, and full uncertainty quantification — supports acceptance for the current regulatory submission with the noted limitation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
