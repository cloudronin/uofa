  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble meets all quantitative acceptance criteria for the three primary QoIs (E/uval < 1.96 for stiffness, yield force, and force at 40 mm displacement). Twelve of thirteen V&V 40 credibility factors were formally assessed; eleven achieved their required level. One factor (Test conditions) was assessed at Gradation 2 against a required level of 3, reflecting the single loading rate used in bench testing; this gap is accepted given ASTM F1717 protocol constraints and literature evidence of low rate sensitivity. One factor (Relevance of the validation activities to the COU) was not formally scored on the basis that the validation and COU are considered co-located in scope. The overall credibility evidence is judged sufficient to support a Medium assurance level decision at model risk level 3. The submission is accepted for regulatory filing.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
