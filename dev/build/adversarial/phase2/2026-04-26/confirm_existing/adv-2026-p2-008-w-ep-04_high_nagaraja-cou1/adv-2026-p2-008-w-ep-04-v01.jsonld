  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) operates under a documented quality management system with version control, regression testing, and audit trail. Required level 2 (basic QMS documentation).",
      "rationale": "Ansys Mechanical 2022 R2 is developed under ISO 9001-certified QMS. Internal verification test suite (>2,400 benchmark cases) is executed at each release. All simulation runs were conducted under controlled computing environment with checksummed input decks. Achieved level 3 reflects formal QMS with independent verification test suite."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver correctly reproduces published analytical solutions for beam bending and contact mechanics benchmarks at required level 2.",
      "rationale": "Ansys verification manual cases VM1 (cantilever beam), VM12 (contact Hertz), and VM185 (nonlinear large-displacement beam) were executed and confirmed within 0.5% of analytical reference values. Code verification is considered sufficient for the linear-to-mildly-nonlinear regime of ASTM F1717 compression-bending."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinements; Richardson extrapolation applied to estimate discretization uncertainty.",
      "rationale": "Three-level mesh refinement study performed on the screw shank and rod interface regions. QoI (construct stiffness) changed 1.4% from medium to fine mesh; Richardson extrapolation yielded GCI of 0.8%. Discretization uncertainty incorporated into the validation uncertainty budget. Achieved level 3 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative solver residuals converge to <1e-6 relative tolerance; energy balance verified across load steps.",
      "rationale": "Newton-Raphson iterations converged to residual norm <1e-8 for all 11 specimen simulations. Energy balance error was <0.1% across all load steps. No spurious contact oscillations detected. Solver error contribution to total uncertainty budget is negligible."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation inputs reviewed by a second analyst; boundary conditions, material assignments, and contact definitions independently verified against the simulation protocol document.",
      "rationale": "A peer-review checklist was completed by a second senior analyst covering boundary condition application, material property mapping, contact pair definitions, and load application direction. All items passed. Model setup errors are not a credible source of significant uncertainty for this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Constitutive model (bilinear isotropic hardening for Ti-6Al-4V) is appropriate for the strain regime encountered; contact formulation captures screw-rod interface behavior.",
      "rationale": "Ti-6Al-4V material response under ASTM F1717 loading remains predominantly elastic with localized plasticity at the screw-rod junction. Bilinear isotropic hardening with tangent modulus calibrated from coupon tests (n=6) is well-established for this regime. Augmented Lagrangian contact formulation with friction coefficient μ=0.2 (literature-derived) was validated against load-displacement curves. Model form uncertainty estimated at ±4% of QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon testing; geometric inputs from CMM measurements of test specimens; uncertainty in inputs propagated to QoI via Monte Carlo (n=1000).",
      "rationale": "Elastic modulus (E=114±3 GPa), yield strength (σy=880±22 MPa), and tangent modulus (Et=1.8±0.3 GPa) obtained from six Ti-6Al-4V coupons machined from the same billet as test constructs. Screw geometry from CMM with ±0.01 mm tolerance. Monte Carlo propagation yielded QoI uncertainty of ±3.2% (1σ). Input uncertainty is the dominant contributor to total validation uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Test specimens are production-representative; lot traceability documented; N≥6 specimens per configuration.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA CDRH and DePuy Synthes). All specimens from a single production lot with full dimensional inspection records. Between-laboratory variability in stiffness QoI was 2.1% (CV), confirming specimen consistency. Achieved level 3 for sample traceability and inter-laboratory replication."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; at minimum, two load magnitudes or configurations tested.",
      "rationale": "Testing was conducted at a single compression-bending load configuration per ASTM F1717 protocol. While this is the regulatory standard test condition, only one test condition was evaluated, limiting the ability to confirm model fidelity across the loading envelope. Achieved level 2 (single condition, protocol-compliant) against required level 3 (multiple conditions). This gap is acknowledged and partially mitigated by the close agreement between FEA and experiment at the tested condition."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrably correspond to physical test specimen and setup; any differences quantified and their impact on QoI bounded.",
      "rationale": "CMM measurements of each test specimen were used to individualize the FEA geometry for each of the 11 constructs. Torque applied to set screws was measured and converted to equivalent preload in the FEA contact interface. Fixture compliance measured experimentally and incorporated as a spring boundary condition. Residual input equivalency uncertainty estimated at <1.5% of QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for each QoI; E/uval < 1.96 for all primary QoIs; systematic bias assessed.",
      "rationale": "E/uval computed for stiffness (1.12), yield force (0.94), and force at 40 mm displacement (1.41), all within the pre-specified acceptance bound of 1.96. No systematic bias detected (mean signed error = +1.8%). Comparison follows ASME V&V 40 Section 5.4 methodology. Achieved level 3 confirmed by quantitative metric compliance across all three QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to the regulatory submission claims and clinical failure modes of interest.",
      "rationale": "Construct stiffness governs load transfer to adjacent vertebrae; yield force corresponds to onset of permanent deformation; force at 40 mm displacement is the ASTM F1717 fatigue surrogate metric. All three QoIs are explicitly cited in the 510(k) substantial equivalence argument and map directly to the clinical failure mode (implant fatigue fracture). QoI relevance is high; achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Validation activities should be evaluated for their direct relevance to the intended clinical COU, including patient population, implant configuration, and loading environment.",
      "rationale": "This factor was determined to be inapplicable to the present COU because the validation activity is itself the regulatory submission test — the ASTM F1717 bench test is the accepted surrogate for in vivo spinal loading by FDA convention, and no further relevance mapping is considered necessary. The assessment team concluded that documenting relevance of the validation activity to the COU adds no informational value beyond what is already captured in the Equivalency of Input Parameters and Output Comparison factors. Accordingly, no formal relevance assessment was performed for this factor."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment demonstrates that the FEA ensemble model meets or exceeds required credibility levels for 12 of 13 V&V 40 factors. The Test conditions factor achieves level 2 against a required level 3, which is acknowledged as a gap; however, this is mitigated by strong quantitative agreement across all three QoIs (E/uval ≤ 1.41) and the regulatory acceptance of ASTM F1717 as a standardized test protocol. The Relevance of validation activities factor was not formally assessed on the grounds that it was deemed inapplicable by the assessment team. Overall model risk level is 3 (Medium-High); the credibility evidence is judged sufficient to support the 510(k) submission claim for the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
