  "signature": "ed25519:b7e2a4f1c9d3b6e8a0f5c2d4b9e1a3f7c0d2b5e8a1f4c6d3b0e7a2f9c4d1b6e3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) must be under configuration control with documented version history and regression test suite.",
      "rationale": "Ansys Mechanical 2022 R2 is used under a validated installation with a documented regression test suite covering linear and nonlinear structural elements. Version control is maintained via the sponsor's quality management system (ISO 13485-compliant). Required level 2 achieved; actual level 3 demonstrates exceeding the threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks from ASME V&V 10 or equivalent must confirm correct implementation of relevant element formulations (beam, solid, contact).",
      "rationale": "Ansys Mechanical has been verified against NAFEMS benchmark suite LE1, LE10, and NL2 for the element types used (SOLID186, CONTA174, TARGE170). Published verification reports from the software vendor and independent FDA simulation lab corroborate correct implementation. Required level 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating QoI change < 2% between successive refinements; GCI < 5%.",
      "rationale": "A three-level mesh convergence study was conducted on the pedicle screw shank and rod interface regions. QoI (von Mises stress peak, construct stiffness) changed by 1.4% and 0.9% respectively between medium and fine meshes. Grid Convergence Index (GCI) computed at 2.1%, below the 5% threshold. Final mesh: ~480,000 elements, average element quality 0.87."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual force and displacement convergence norms < 0.1% per load step for the nonlinear solution.",
      "rationale": "Nonlinear solution used Newton-Raphson iteration with force residual norm < 0.05% and displacement norm < 0.08% per substep across all 50 load steps. No unconverged substeps were recorded. Solver settings documented in simulation plan SP-COU1-2023-v3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup by a qualified engineer not involved in model construction; documented checklist completion.",
      "rationale": "An independent senior FEA engineer (not involved in model construction) reviewed boundary conditions, material assignments, contact definitions, and load application against the simulation plan. A 47-item checklist (per FDA guidance 2021) was completed with zero non-conformances. Review documented in peer review record PR-COU1-2023-001."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification that continuum FEA with frictional contact adequately represents the physical mechanisms governing compression-bending behavior of the construct.",
      "rationale": "The dominant physical mechanisms — elastic-plastic bending of the screw shank, frictional slip at the rod-tulip interface, and polyaxial head rotation — are all captured by the continuum FEA formulation. Bilinear isotropic hardening material model for Ti-6Al-4V ELI is calibrated to coupon tensile data. Polyaxial head kinematics are represented by a spherical contact pair. Model form is consistent with published FDA and industry practice for F1717 simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry, and boundary conditions sourced from traceable measurements or certified material certifications; uncertainty in inputs quantified.",
      "rationale": "Ti-6Al-4V ELI material properties (E=114 GPa, σ_y=880 MPa, σ_u=950 MPa) sourced from lot-specific material certifications conforming to ASTM F136. CAD geometry verified against production drawings (GD&T tolerance ±0.05 mm). Coefficient of friction (μ=0.2) for Ti-Ti contact taken from published tribology literature with ±0.05 uncertainty bound propagated through a sensitivity study. Input uncertainty contribution to QoI uncertainty < 3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 specimens from production lots; dimensional inspection confirms conformance to drawing; traceability to production records established.",
      "rationale": "N=11 constructs assembled from production-representative components (7.5 mm non-cannulated screws, 5.5 mm Ti rod, UHMWPE test block per F1717). Dimensional inspection of all screws confirmed conformance to drawing (shank diameter 7.50±0.02 mm). Lot traceability records maintained. Two independent laboratories (FDA CDRH and DePuy Synthes R&D) each tested a subset, providing inter-laboratory comparison data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading rates and environmental conditions; at least two distinct test configurations evaluated.",
      "rationale": "Testing was conducted under a single quasi-static loading rate (5 mm/min per ASTM F1717) in ambient laboratory conditions. Although F1717 specifies this as the standard condition, no variation in loading rate or temperature was explored. This limits the ability to confirm model fidelity across the broader COU envelope. Required level 3 not achieved; achieved level 2 represents a gap acknowledged in the credibility summary."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented mapping between experimental measurements and FEA inputs; any discrepancies quantified and their effect on QoI assessed.",
      "rationale": "A parameter equivalency table was prepared mapping each FEA input to its experimental counterpart: screw geometry (CMM measurements → CAD), material properties (material cert → constitutive model), boundary conditions (load cell data → applied displacement), and fixture stiffness (measured 42,000 N/mm → modeled as rigid). Fixture rigidity assumption assessed via sensitivity study; QoI sensitivity < 1.5%. Full equivalency documented in report EQ-COU1-2023."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using area validation metric or equivalent; E/uval < 1.96 for all primary QoIs; percent difference < 10%.",
      "rationale": "Three primary QoIs compared: construct stiffness (4.2% difference, E/uval=0.87), yield force (6.8%, E/uval=1.41), force at 40 mm displacement (7.3%, E/uval=1.52). All E/uval values below 1.96 and all percent differences below 10%. Validation uncertainty (uval) computed per ASME V&V 10.1 incorporating experimental variability (CV 3–6%) and numerical uncertainty (GCI 2.1%). Pre-specified acceptance criteria met for all three QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation are the same as or directly predictive of the QoIs used in the regulatory submission decision.",
      "rationale": "The three validation QoIs (construct stiffness, yield force, force at 40 mm displacement) are identical to the submission QoIs used to demonstrate structural adequacy under FDA's recommended F1717 protocol. No surrogate or proxy QoIs are used. The alignment between validation and decision QoIs is complete and documented in the V&V plan VP-COU1-2023."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Relevance of the validation activities to the COU should be evaluated to confirm that the validation domain adequately covers the intended clinical deployment envelope.",
      "rationale": "The assessment team determined that this factor does not apply to the present COU because the validation experiment is itself defined by ASTM F1717, which is the regulatory standard governing the submission. Since the test protocol and the COU are co-extensive by regulatory definition, the team concluded that a separate relevance assessment would be redundant and therefore did not perform one. No relevance scoring was assigned. The factor is carried in the package without a required or achieved level, as the team's position is that the standard's scope subsumes any separate relevance evaluation."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors were formally assessed. Eleven factors met or exceeded their required levels. One factor (Test conditions) fell one gradation below the required level (achieved 2, required 3) due to single-condition testing per ASTM F1717; this gap was accepted given that F1717 specifies a single quasi-static protocol and the model's quantitative validation results (all E/uval < 1.96, all QoI differences < 10%) provide sufficient confidence for the Medium-risk, Medium-influence COU. The thirteenth factor (Relevance of the validation activities to the COU) was not assigned a required or achieved level on the basis that the team considered it non-applicable by regulatory definition; however, no formal not-applicable determination was documented. Overall credibility is judged sufficient to support regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
