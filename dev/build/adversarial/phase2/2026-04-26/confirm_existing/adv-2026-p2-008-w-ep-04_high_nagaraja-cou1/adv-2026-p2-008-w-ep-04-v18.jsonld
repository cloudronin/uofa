    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in QoIs between successive refinement levels.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw shank and rod interface regions. Stiffness QoI changed by 0.9% between medium and fine meshes; yield force by 1.1%. Richardson extrapolation applied; GCI < 1.5% for all QoIs. Final mesh (approx. 420,000 elements, predominantly hex20) accepted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria met at each load step; energy balance error <0.1%.",
      "rationale": "Newton-Raphson iteration converged to force residual norm <1e-4 at every load step across all 11 specimen simulations. Energy balance monitored throughout; maximum imbalance 0.04%. No divergence events recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second analyst; checklist-based QA sign-off.",
      "rationale": "Model boundary conditions, material assignments, contact definitions, and load application reviewed by an independent senior analyst against a 47-item checklist. Two minor discrepancies (contact stiffness scaling factor, load application node set) identified and corrected prior to production runs. Final configuration signed off."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Physics assumptions (linear elasticity for rod, bilinear isotropic hardening for screw) justified by literature and sensitivity analysis.",
      "rationale": "Titanium alloy pedicle screw modelled with bilinear isotropic hardening (E=114 GPa, sigma_y=880 MPa, E_t=1.2 GPa) consistent with Ti-6Al-4V ELI ASTM F136 data. UHMWPE test block modelled as linear elastic (E=0.9 GPa) following precedent in published F1717 FEA literature. Frictional contact (mu=0.25) at screw-rod interface validated against torque-slip data from a separate characterisation study. Model form sensitivity to mu (±0.1) shows <3% effect on stiffness QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs traceable to certified material certs and CMM measurements; uncertainty propagated through model.",
      "rationale": "Screw geometry derived from CMM measurements of production-representative specimens (n=5); dimensional variability <0.5% of nominal. Material properties sourced from lot-specific tensile test certificates (n=3 coupons per lot). Monte Carlo uncertainty propagation (n=1000 runs, Latin hypercube sampling) quantifies combined input uncertainty contribution to QoI uncertainty; 95th-percentile input uncertainty band reported alongside nominal predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens are production-representative; traceability to manufacturing lot documented.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs drawn from a single production lot; certificates of conformance and dimensional inspection reports on file. Six specimens tested at Lab 1 (FDA), five at Lab 2 (DePuy Synthes internal). Inter-laboratory specimen identity confirmed by serial number tracking."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "rationale": "The assessment team concluded that this factor does not apply to the present COU because ASTM F1717 fully specifies the test configuration — load application rate, fixture geometry, environmental conditions, and displacement measurement protocol — leaving no degrees of freedom for condition variation. As a standardised single-condition protocol, the team judged that a formal test-conditions credibility assessment would be vacuous and therefore omitted it from the factor matrix. Note: the appropriate encoding for this determination would be factorStatus 'not-applicable'; the use of 'not-assessed' here is an inadvertent encoding error that leaves the factor's contribution to overall credibility unverified at modelRiskLevel 3.",
      "acceptanceCriteria": "Not established — factor carried as not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions demonstrably equivalent to experimental fixture conditions; any deviations quantified.",
      "rationale": "Fixture pin diameter, UHMWPE block dimensions, and crosshead displacement rate in FEA match F1717 nominal values. Crosshead rate (5 mm/min) confirmed quasi-static by strain-rate sensitivity check (rate doubled; QoI change <0.3%). Pin-to-block clearance fit modelled as frictionless contact, consistent with lubricated fixture per F1717 protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All QoI differences <10% and E/uval <1.96 for stiffness, yield force, and force at 40 mm displacement.",
      "rationale": "Three QoIs compared: construct stiffness (4.2% difference, E/uval=0.87), yield force (7.1%, E/uval=1.31), force at 40 mm displacement (8.6%, E/uval=1.54). All pass pre-established acceptance bounds. Experimental uncertainty estimated from inter-specimen and inter-laboratory variability; model uncertainty from Monte Carlo propagation plus GCI. Combined validation uncertainty uval computed per ASME V&V 20."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation directly correspond to QoIs used in the regulatory submission.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the FDA 510(k) submission performance acceptance criteria for this device. The validation QoIs are identical to the submission QoIs; no bridging or surrogate QoI mapping is required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches COU geometry, loading mode, and material system; any gaps in relevance explicitly characterised.",
      "rationale": "Validation activity uses the identical screw design, rod diameter, and UHMWPE block geometry as the COU. Loading mode (compression-bending per F1717) is the exact clinical surrogate specified in the COU. No extrapolation across geometry, material, or loading mode is required. The validation is direct (not analogical), providing the highest achievable relevance for this COU."
    }
