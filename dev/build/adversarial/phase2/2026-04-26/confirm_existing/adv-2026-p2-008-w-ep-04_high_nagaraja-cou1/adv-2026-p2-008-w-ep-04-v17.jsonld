    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup, boundary conditions, and load application. Required Gradation 2.",
      "rationale": "Model setup independently reviewed by a second analyst at each of the three participating organizations. Boundary condition application, contact definitions, and load magnitudes verified against the ASTM F1717 protocol. Cross-laboratory consistency confirmed. Gradation 3 (multi-organization independent review) achieved."
