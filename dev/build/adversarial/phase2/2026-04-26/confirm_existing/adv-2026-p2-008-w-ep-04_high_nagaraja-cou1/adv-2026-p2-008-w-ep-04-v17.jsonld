    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elasto-plastic constitutive model with isotropic hardening validated against coupon-level material data. Contact formulation appropriate for metal-on-metal interfaces. Required Gradation 3.",
      "rationale": "Ti-6Al-4V elasto-plastic model with bilinear isotropic hardening calibrated from ASTM E8 coupon tensile tests (n=6). Augmented Lagrangian frictional contact applied at screw-rod and rod-block interfaces with μ=0.2 from pin-on-disk tribometry. Model form judged appropriate for monotonic static loading regime. Gradation 3 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon testing; geometric inputs from CMM measurements of tested specimens. Required Gradation 3.",
      "rationale": "Elastic modulus (114 GPa ± 2.1 GPa), yield strength (880 MPa ± 12 MPa), and tangent modulus (1.8 GPa ± 0.15 GPa) derived from six Ti-6Al-4V coupons from the same material lot as tested constructs. Screw and rod geometry verified by coordinate measuring machine to ±0.01 mm. Uncertainty propagation performed for all primary inputs. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production lot; dimensional inspection confirming conformance to drawing. Required Gradation 3.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production-representative components. All specimens dimensionally inspected by CMM prior to testing; all within drawing tolerances. Specimens distributed across two independent laboratories (n=6 Lab A, n=5 Lab B) to assess inter-laboratory variability. Gradation 3 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of COU loading scenarios including at least two load levels and two fixture configurations. Required Gradation 3.",
      "rationale": "Testing conducted under a single ASTM F1717 load configuration (35 mm offset, quasi-static ramp). While the protocol is standardized and well-characterized, only one test condition was employed. Multi-condition coverage required for Gradation 3 was not achieved. Gradation 2 recorded as a known gap; residual uncertainty acknowledged in the validation summary."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and material inputs demonstrably equivalent to experimental setup parameters within stated uncertainties. Required Gradation 3.",
      "rationale": "Experimental fixture geometry, actuator offset (35.0 ± 0.2 mm), applied displacement rate (25 mm/min), and block material (ultra-high-molecular-weight polyethylene, E=0.9 GPa) all replicated in the FEA model. Parameter equivalency table prepared and reviewed by all three organizations. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) applied to all three QoIs with pre-specified acceptance threshold E/uval < 1.96. Required Gradation 3.",
      "rationale": "E/uval computed for construct stiffness (0.87), yield force (1.14), and force at 40 mm displacement (0.71). All three values below the pre-specified threshold of 1.96. Percent differences also within 10% bound. Quantitative pass/fail determination made prior to unblinding experimental data. Gradation 3 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly linked to regulatory submission claims and clinical failure modes. Required Gradation 3.",
      "rationale": "Construct stiffness governs load-sharing with the vertebral column; yield force defines the onset of permanent deformation associated with clinical loosening; force at 40 mm displacement characterizes post-yield energy absorption relevant to fatigue life estimation. All three QoIs are explicitly cited in the 510(k) predicate comparison and in ASTM F1717 reporting requirements. Gradation 3 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
