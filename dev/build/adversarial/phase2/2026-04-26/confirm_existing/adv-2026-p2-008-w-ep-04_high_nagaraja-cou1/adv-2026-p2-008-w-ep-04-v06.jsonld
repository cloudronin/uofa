  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble meets all pre-established acceptance criteria (E/uval < 1.96; QoI differences < 10%) for all three primary quantities of interest across N=11 experimental constructs at two independent laboratories. Twelve of thirteen credibility factors are formally assessed; the single unassessed factor (Relevance of validation activities to COU) was determined by the assessment team to not require graduated scoring given the direct equivalence of validation and use conditions. The single below-required factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted given the explicit regulatory scoping of the COU to ASTM F1717 compression-bending. Overall credibility is judged sufficient to support the intended regulatory decision at Medium assurance level.",
