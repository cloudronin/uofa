    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems representative of structural contact mechanics are reproduced within 1% of analytical solutions.",
      "rationale": "Standard Ansys benchmark suite (MAPDL verification manual problems VM6, VM12, VM182) confirmed correct implementation of linear elastic and contact elements relevant to this construct geometry. All benchmarks passed within 0.4%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinements; discretization uncertainty quantified and included in total uval.",
      "rationale": "A three-level mesh convergence study (coarse: ~120k elements, medium: ~310k elements, fine: ~780k elements) was conducted. QoI change between medium and fine meshes was 0.9% for stiffness and 1.3% for yield force. Discretization uncertainty estimated at 1.5% and propagated into uval."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver convergence criteria documented; residual norms confirmed below 1e-5 for all load steps.",
      "rationale": "Force and displacement residuals were monitored across all 120 load increments. Maximum residual norm observed was 3.2e-6, well below the 1e-5 threshold. No divergence or non-convergence events were recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs reviewed by independent analyst; checklist-based review protocol documented.",
      "rationale": "An independent analyst (not the model developer) reviewed all boundary conditions, material assignments, contact definitions, and load application sequences against a documented checklist. Three minor input inconsistencies were identified and corrected prior to final simulation runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions (linear elasticity, small-strain, frictional contact) justified by literature and confirmed against observed experimental failure modes.",
      "rationale": "Linear elastic constitutive models with isotropic titanium alloy properties (Ti-6Al-4V: E=114 GPa, nu=0.34) were applied. Experimental constructs exhibited elastic-dominated response up to yield; post-yield behavior was not the primary QoI. Frictional contact (mu=0.3) at screw-block interfaces was validated against published tribological data. Model form uncertainty estimated at 3% and included in uval."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from traceable measurements; input uncertainty quantified via Monte Carlo propagation.",
      "rationale": "Titanium alloy material properties sourced from ASTM F136 coupon testing (n=5 coupons per lot). Geometric dimensions measured via CMM with traceable calibration. Monte Carlo propagation (n=1000 samples) of input uncertainties yielded a combined input uncertainty of 2.8% on stiffness QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lots; dimensional inspection confirms specimens within drawing tolerances.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were assembled from production lots. CMM inspection of all 11 specimens confirmed all critical dimensions within ±0.05 mm of nominal. Specimens distributed across two independent laboratories (Lab A: n=6, Lab B: n=5) to assess inter-laboratory variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; at minimum two distinct load configurations assessed.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending configuration only. While this configuration is the regulatory standard, the absence of a second load configuration (e.g., torsion or axial compression) limits the achieved level to Gradation 2. This shortfall is accepted given that the COU is explicitly scoped to F1717 compression-bending performance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs are demonstrably equivalent to experimental conditions; any deviations are quantified and their effect on QoI bounded.",
      "rationale": "FEA boundary conditions replicate the ASTM F1717 test fixture geometry, crosshead displacement rate, and UHMWPE block material properties. Fixture compliance measured experimentally and incorporated into the FEA model. Deviation in block modulus (±5%) was propagated through sensitivity analysis, yielding <1% effect on stiffness QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for each QoI; E/uval < 1.96 for all primary QoIs.",
      "rationale": "E/uval computed for all three primary QoIs: stiffness (1.41), yield force (1.78), force at 40 mm (1.02). All values below the 1.96 threshold. Percentage differences also below the 10% pre-established bound. Comparison methodology follows ASME V&V 40 Section 5.3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to regulatory submission requirements and clinical failure modes of interest.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the ASTM F1717 standard and required by FDA guidance for pedicle screw 510(k) submissions. These QoIs directly relate to the clinical failure mode of construct yielding under physiological compression-bending loads."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Validation activities are assessed for relevance to the intended clinical and regulatory context of use.",
      "rationale": "This factor was not formally assessed because the validation activity is co-extensive with the COU itself: the F1717 bench test is the regulatory submission test, and the FEA model is applied to exactly the same geometry, loading, and boundary conditions as the experiment. The assessment team concluded that a formal relevance evaluation does not apply to this COU since there is no extrapolation from validation conditions to intended use conditions — the two are identical. Accordingly, no requiredLevel or achievedLevel has been assigned. Note that 'not-applicable' was considered but rejected because the factor is technically applicable; the team's position is that the direct correspondence renders a graduated assessment unnecessary."
    }
  ],
