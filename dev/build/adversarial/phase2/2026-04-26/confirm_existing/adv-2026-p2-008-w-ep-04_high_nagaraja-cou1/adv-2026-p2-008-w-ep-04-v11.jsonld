    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks from ASME V&V 10 or equivalent must confirm correct implementation of governing equations for structural mechanics in the solver.",
      "rationale": "Ansys Mechanical benchmark problems (patch test, cantilever beam, Hertzian contact) were executed and results compared against analytical solutions. Maximum deviation 0.3%. Code verification is satisfied at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change of less than 2% between successive refinements. Richardson extrapolation or GCI must be reported.",
      "rationale": "A three-level mesh refinement study was conducted on the pedicle screw and UHMWPE block assembly. QoI (construct stiffness) changed by 1.4% between medium and fine meshes (GCI = 1.7%). The fine mesh (element size 0.4 mm at screw-block interface) was adopted for all production runs. Discretization error is controlled at required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps; energy balance error must be below 0.1%.",
      "rationale": "Direct sparse solver (SPARSE) was used for all linear solution steps. Nonlinear convergence was monitored via force and displacement residuals; all runs converged below 1e-5 within 15 substeps. Energy balance error reported at 0.04%. Numerical solver error is within acceptable bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol and independent peer review of model setup must be on file to reduce risk of operator-induced errors in boundary conditions, material assignments, and loading definitions.",
      "rationale": "A simulation execution plan (SEP) was drafted prior to analysis and reviewed by an independent FEA engineer not involved in model construction. Boundary conditions (fixed inferior block, compressive-bending load applied at superior block per ASTM F1717 fixture geometry) were verified against test setup photographs. No use errors were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The choice of constitutive model and contact formulation must be justified by literature evidence or preliminary sensitivity studies demonstrating that the selected model form captures the dominant physics of the compression-bending response.",
      "rationale": "Linear elastic titanium alloy (Ti-6Al-4V, E=114 GPa, v=0.34) was selected for the screw based on sub-yield loading confirmed by experimental yield force data. Augmented Lagrange contact with friction coefficient 0.2 was adopted based on published titanium-UHMWPE tribology data. Sensitivity study showed QoI changed by less than 1.8% over friction coefficient range 0.15–0.30. Model form is adequately justified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured specimen data or certified material specifications. Uncertainty in key inputs must be quantified and propagated.",
      "rationale": "Screw geometry was derived from calibrated CMM measurements of three production screws (max deviation 0.02 mm from nominal). Ti-6Al-4V elastic modulus was taken from ASTM B265 certificate of conformance (mean 114.2 GPa, SD 1.1 GPa). UHMWPE block properties sourced from ASTM F648 lot testing. Input uncertainty propagation via Monte Carlo (1000 samples) contributed ±1.9% to stiffness QoI uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental specimens must be production-representative devices from documented lots; sample size must be sufficient to characterize inter-specimen variability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were drawn from two production lots (Lot A: n=6, Lab 1; Lot B: n=5, Lab 2). All screws were inspected per incoming quality control procedures. Inter-specimen CV for stiffness was 3.8%, confirming adequate homogeneity. Sample size supports statistical comparison at the required confidence level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate the COU loading environment including load magnitude range, load rate, and environmental conditions (temperature, lubrication) relevant to in vivo use.",
      "rationale": "Testing was conducted per ASTM F1717 at a single compressive load level (150 N axial + bending moment per standard fixture geometry) at ambient temperature. Only one test condition was evaluated; the standard does not require multiple load levels, but the V&V 40 required level of 3 for this risk level anticipates at least two distinct conditions. Achieved level 2 reflects this single-condition limitation. This known gap is accepted given that ASTM F1717 is the regulatory standard for this device class."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters (geometry, material properties, boundary conditions) must be demonstrably equivalent to those of the physical test specimens within quantified tolerances.",
      "rationale": "CMM-measured screw geometry was used directly in the CAD model. Material certificates were cross-referenced to simulation inputs. Fixture geometry in the FEA replicated the ASTM F1717 test frame dimensions to within 0.5 mm. A formal equivalency table was prepared mapping each model input to its experimental counterpart with documented traceability. Full equivalency confirmed at level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval or equivalent) must be computed and compared against a pre-specified acceptance threshold. Acceptance criterion must be defined prior to unblinding simulation results.",
      "rationale": "Acceptance criteria (E/uval < 1.96, QoI difference < 10%) were pre-registered in the SEP before simulation results were compared to experimental data. Stiffness: E/uval = 0.87. Yield force: E/uval = 1.12. Force at 40 mm: E/uval = 0.94. All three QoIs pass the pre-specified acceptance criterion. Output comparison is fully satisfied at level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in the validation comparison must be the same as, or demonstrably predictive of, the QoIs used in the clinical decision context.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and are directly used by the regulatory submission to characterize mechanical performance. These QoIs are identical between the validation activity and the COU. Relevance is fully established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "rationale": "The assessment team concluded that this factor does not apply to the present COU because the validation activity is a direct one-to-one comparison between the FEA model and the physical test defined by the same regulatory standard (ASTM F1717) that governs the COU itself. Since the validation domain and the COU domain are considered identical by construction, a separate relevance assessment was deemed unnecessary and was not performed. No requiredLevel or achievedLevel has been assigned."
    }
