  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment is accepted at Medium assurance level. Ten of thirteen V&V 40 factors meet or exceed their required gradation. The Test conditions factor falls one gradation below required but is mitigated by the mandatory nature of ASTM F1717 conditions and the direct experimental confirmation of model predictions. The Equivalency of input parameters factor was not formally assessed on the basis that the team considered it inapplicable; this judgment, while plausible, was not encoded as not-applicable and leaves an unresolved epistemic gap at modelRiskLevel 3. The package is accepted with the recommendation that the equivalency factor be formally scoped or assessed in the next revision cycle.",
