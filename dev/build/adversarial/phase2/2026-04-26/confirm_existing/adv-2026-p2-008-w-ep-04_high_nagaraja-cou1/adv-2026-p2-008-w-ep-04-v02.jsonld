  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2) for modelRiskLevel 3.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated FEA solver with documented V&V procedures. The modeling team operates under an ISO 13485 quality management system with version-controlled simulation protocols. Software qualification records and change-control logs were reviewed and found compliant with required Gradation 2 SQA practices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2).",
      "rationale": "Code verification was performed using the method of manufactured solutions for the linear elastic constitutive model and contact formulation. Observed order of accuracy (p = 1.97) is consistent with the theoretical second-order convergence rate. Benchmark comparisons against NAFEMS LE1 and LE10 reference problems confirmed correct implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2).",
      "rationale": "A three-level mesh refinement study was conducted on the pedicle screw geometry. Richardson extrapolation yielded a grid convergence index (GCI) of 1.4% for the peak von Mises stress QoI, well below the 5% threshold. The production mesh (element edge length 0.3 mm at critical cross-section) was selected as the converged configuration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 1).",
      "rationale": "The sparse direct solver (SPARSE) was used with double-precision arithmetic. Residual norms converged to 1e-8 for all load steps. Energy balance checks confirmed conservation within 0.01%. No iterative solver divergence or ill-conditioning warnings were observed across the N=11 model instances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2).",
      "rationale": "Simulation inputs and boundary conditions were independently reviewed by a second qualified engineer prior to execution. A documented simulation plan specified all modeling assumptions, load application, and output extraction procedures. Peer review records are archived in the project quality management system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2).",
      "rationale": "A linear elastic model with Ti-6Al-4V isotropic material properties was selected based on the pre-yield loading regime of the ASTM F1717 protocol. Nonlinear geometric effects (large displacement) were included. Model form appropriateness was confirmed by comparison of predicted force-displacement linearity against experimental load-cell traces across all 11 constructs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2).",
      "rationale": "Material properties (E = 114 GPa, ν = 0.34) were sourced from ASTM B265 certified material test reports for the specific Ti-6Al-4V bar stock used in screw manufacture. Geometric inputs were derived from CMM measurements of representative screws. Uncertainty in material properties was propagated via Monte Carlo sampling (n=1000) and shown to contribute <3% variability to QoI predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2).",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs from production lot were tested across two independent laboratories (FDA/CDRH and an accredited third-party lab). Dimensional inspection confirmed all screws were within drawing tolerance. Lot traceability and material certification records are on file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2). NOTE: This factor is below required level — single test condition (quasi-static, room temperature) was applied; no rate or temperature variation was explored.",
      "rationale": "Testing was conducted under a single quasi-static loading rate (5 mm/min) at ambient temperature (23 ± 2 °C) per ASTM F1717. While the standard prescribes these conditions and they are clinically representative for static construct assessment, no variation in loading rate or physiological temperature was explored. This constitutes a known gap relative to the required Gradation 2 level for this risk category."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not evaluated; team concluded this factor does not apply because boundary conditions are directly prescribed from the ASTM F1717 fixture geometry and no parameter mapping between test and simulation is required.",
      "rationale": "The assessment team determined that equivalency of input parameters is not relevant to this COU because the FEA boundary conditions are derived directly from the standardized ASTM F1717 fixture dimensions, leaving no ambiguity in parameter correspondence. Accordingly, no formal equivalency evaluation was performed and no gradation was assigned. The factor was carried forward without assessment rather than coded as not-applicable, as the team believed the rationale rendered formal scoping unnecessary. At modelRiskLevel 3, however, the absence of a documented equivalency assessment — including verification that fixture stiffness, grip compliance, and load-line offsets in the physical test are faithfully reproduced in the simulation — represents an unaddressed epistemic gap that materially weakens overall credibility."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2).",
      "rationale": "Quantitative output comparison was performed using the ASME V&V 40 validation metric E/uval for all three QoIs (stiffness, yield force, force at 40 mm). All E/uval values fell below the 1.96 threshold. Graphical force-displacement overlays and Bland-Altman plots were also produced and reviewed. The comparison methodology is fully documented in the validation report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2).",
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are the primary endpoints specified in ASTM F1717 and directly correspond to the clinical performance attributes of interest (construct rigidity and fatigue resistance). QoI selection was reviewed and approved by the clinical and regulatory team prior to study initiation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2).",
      "rationale": "The validation activity directly replicates the intended COU: the same screw geometry (non-cannulated 7.5 mm), the same loading mode (ASTM F1717 compression-bending), and the same material system are used in both the validation experiments and the predictive simulations. The validation domain is therefore coincident with the application domain, supporting direct applicability of the validation evidence to the regulatory submission."
    }
  ],
