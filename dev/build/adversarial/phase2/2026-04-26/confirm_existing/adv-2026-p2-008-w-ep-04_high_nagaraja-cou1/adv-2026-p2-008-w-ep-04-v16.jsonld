  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted at Medium assurance level. Eleven of thirteen V&V 40 factors meet or exceed required levels. The Test conditions factor achieves level 2 against a required level 3; this gap is mitigated by the conservative nature of the single tested condition and is flagged for resolution in future validation cycles. The Output comparison factor was scoped out of formal assessment by the team on the basis that confirmatory bench testing was deemed sufficient; this determination is recorded in the simulation plan addendum. Overall, the body of evidence is judged sufficient to support the regulatory submission for a Class II device at medium model influence and medium decision consequence.",
