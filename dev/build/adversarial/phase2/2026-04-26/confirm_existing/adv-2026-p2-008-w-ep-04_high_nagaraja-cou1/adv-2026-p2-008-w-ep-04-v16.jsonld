    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Model physics (material constitutive law, contact formulation, boundary conditions) must be justified relative to the COU and validated against experimental observations.",
      "rationale": "Elastic-plastic material model (bilinear isotropic hardening) applied to Ti-6Al-4V screw and PEEK rod. Frictional contact (mu=0.3) at screw-rod interface. Boundary conditions replicate ASTM F1717 fixture constraints. Model form justified by comparison to published literature and confirmed by validation results. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Material properties and geometric inputs must be sourced from measurements on the actual test specimens or certified material data sheets with uncertainty quantification.",
      "rationale": "Titanium alloy material properties (E=114 GPa, yield=880 MPa) sourced from ASTM F136-compliant certificate of conformance for the production lot. Geometry derived from CMM measurements of three representative specimens (dimensional tolerance ±0.02 mm). Sensitivity analysis confirms QoI insensitivity to ±5% property variation. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Test specimens must be production-representative and traceable to the same design and manufacturing process as the device under evaluation.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested, all from production lots manufactured under the same design history file. Specimens distributed across two independent laboratories to assess inter-laboratory variability. Traceability records maintained. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Test conditions must replicate the full range of clinically relevant loading scenarios or demonstrate that the tested condition is conservative.",
      "rationale": "Testing performed under a single load configuration (static compression-bending per ASTM F1717). Dynamic and torsional loading not evaluated in this COU. The single condition represents the most critical failure mode per clinical literature; however, the absence of multi-condition coverage limits this factor to achieved level 2, below required level 3. This gap is acknowledged and flagged for future validation work."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation inputs must be demonstrably equivalent to the experimental conditions, with documented mapping between test parameters and model parameters.",
      "rationale": "Crosshead displacement rate (1 mm/min), fixture geometry, and specimen mounting replicated in the FEA boundary conditions. Material properties mapped from the same production lot certificates used for physical testing. Parameter equivalency table documented in the simulation plan. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E/uval) must be computed for each QoI and compared against a pre-specified acceptance threshold.",
      "rationale": "The output comparison factor was determined by the assessment team to not apply to this COU because the validation activities are considered confirmatory bench tests rather than formal model validation comparisons. Accordingly, no formal E/uval computation was performed and no quantitative acceptance threshold was registered prior to testing. The team concluded that the strong visual agreement between FEA load-displacement curves and experimental envelopes is sufficient for a medium-influence decision context, and that a structured output comparison methodology would impose disproportionate burden relative to the risk level. This determination was recorded in the simulation plan addendum dated 2025-11-14."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "QoIs selected for validation must be directly linked to the clinical or regulatory decision and must be sensitive to the model features under evaluation.",
      "rationale": "Three QoIs selected: construct stiffness, yield force, and force at 40 mm displacement. All three are specified in ASTM F1717 and are directly relevant to the regulatory submission. Sensitivity analysis confirms that all three QoIs are sensitive to the material model and mesh density parameters being evaluated. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation activities must be sufficiently similar to the COU in geometry, loading, material, and scale to support extrapolation of validation evidence to the COU.",
      "rationale": "Validation specimens are geometrically identical to the production device (same CAD revision, same manufacturing process). Loading protocol (ASTM F1717 static compression-bending) directly matches the COU. Material and scale are identical. No extrapolation required — validation and COU are co-incident. Required level 3 achieved."
