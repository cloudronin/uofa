  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework satisfies all quantitative acceptance criteria for the three primary QoIs under ASTM F1717 static compression-bending. Twelve of thirteen V&V 40 credibility factors have been formally assessed; eleven meet or exceed required levels. The Test conditions factor falls one gradation below requirement due to single-offset testing, which is accepted as consistent with standard regulatory practice. The Relevance of validation activities factor was not formally assessed on the basis that the validation activity and COU are co-extensive; the assessment team judged this factor inapplicable. Overall credibility is judged sufficient to support a Medium assurance level decision for this Class II device application.",
