  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) is under documented version control with regression test suite. FDA in-house code uses NIST-traceable verification benchmarks.",
      "rationale": "All three FEA environments (FDA in-house, Ansys, DePuy Synthes Abaqus-based) operate under ISO 9001-aligned SQA procedures. Version-controlled build logs, regression suites, and release notes were reviewed and found compliant. Achieved Gradation 3 exceeds required Gradation 2 for Medium model risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks from ASME V&V 10 Supplement 1 executed for linear elastic solid elements; residuals < 1e-6.",
      "rationale": "Patch test, cantilever beam, and Hertzian contact benchmarks were executed in all three codes. Maximum deviation from analytical solution was 0.3%. Residual convergence criterion of 1e-8 was applied. Required Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis performed; discretization error < 2% of QoI.",
      "rationale": "Three-level mesh refinement study conducted on the pedicle screw shank and rod interface regions. GCI for stiffness QoI = 0.8%, for yield force QoI = 1.1%. Discretization error is well below the 2% threshold. Achieved Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals documented; force equilibrium verified at final increment.",
      "rationale": "Direct sparse solver used for linear steps; Newton-Raphson with line search for nonlinear contact phases. Force residual norm at convergence < 1e-7. Energy balance checked at each load increment. Required Gradation 1 exceeded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup; checklist-based QA documented.",
      "rationale": "Each FEA team performed an independent peer review of boundary conditions, material assignments, contact definitions, and load application prior to result submission. A standardized V&V 40 checklist was completed and archived. Required Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics assumptions documented and justified; contact formulation appropriate for screw-rod interface.",
      "rationale": "Linear elastic titanium alloy (Ti-6Al-4V) material model is appropriate for the pre-yield regime. Augmented Lagrangian contact with friction coefficient μ=0.2 (literature-derived) captures screw-rod interface behavior. Large-deformation formulation activated for post-yield regime. Model form uncertainty estimated at ±3% via sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from coupon testing of same lot material; geometric inputs from CMM measurements.",
      "rationale": "Elastic modulus (E = 114 GPa), yield strength (880 MPa), and Poisson ratio (ν = 0.34) sourced from ASTM F136 coupon tests on the same Ti-6Al-4V material lot as the tested constructs. Screw and rod geometry obtained from CMM measurements (±0.005 mm). Input uncertainty propagated via Monte Carlo (N=1000 runs); 95th-percentile QoI variation < 4%. Achieved Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs tested; samples from production lot; dimensional inspection documented.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs assembled from production-representative components. Dimensional inspection confirmed all constructs within engineering drawing tolerances. Constructs distributed across two independent laboratories to assess inter-laboratory variability. Required Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two loading rates or environmental conditions representative of COU variability.",
      "rationale": "Testing conducted at a single crosshead displacement rate (5 mm/min) per ASTM F1717. While this rate is the standard protocol, the COU does not involve rate-dependent phenomena and the material is rate-insensitive in the quasi-static regime. Only one test condition was evaluated, resulting in Gradation 1, which falls below the required Gradation 2. This gap is acknowledged and accepted given the quasi-static nature of the application and the standard's prescriptive test protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs traceable to experimentally measured values; discrepancies < 5% documented.",
      "rationale": "Boundary conditions in the FEA replicate the ASTM F1717 fixture geometry and constraint conditions as measured by the testing laboratories. Applied displacement ramp matches experimental crosshead motion. Material properties used in FEA are drawn from the same coupon test data as the experimental constructs. All input parameter discrepancies documented and < 3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for each QoI; E/uval < 1.96 for all QoIs.",
      "rationale": "E/uval computed per ASME V&V 40 Section 9 for all three QoIs: stiffness (0.87), yield force (1.31), force at 40 mm (1.54). All values below the 1.96 threshold. Uncertainty in experimental measurements (uval) estimated from inter-laboratory and inter-specimen variability. Graphical comparison of load-displacement curves shows excellent agreement throughout the loading regime. Achieved Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to the regulatory submission metrics and clinical failure modes.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and are directly cited in the 510(k) predicate device comparison. These metrics are mechanistically linked to the primary clinical failure mode (fatigue fracture following cyclic loading), providing high relevance to the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Validation activities should span the full range of loading scenarios and geometric configurations represented in the COU.",
      "rationale": "The assessment team determined that this factor does not apply to the present COU because the validation activity is itself the ASTM F1717 bench test, which is definitionally the same protocol as the intended regulatory submission test. The team concluded that evaluating the relevance of the validation activities to the COU would be circular in this context, as the validation and the COU are co-extensive. Accordingly, no formal gradation was assigned and no requiredLevel or achievedLevel was recorded. The team's position is that the factor is inapplicable rather than unassessed; however, the package encodes this judgment as 'not-assessed' pending resolution of the applicability determination in the next review cycle."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated 7.5 mm pedicle screw, ASTM F1717 compression-bending) is accepted at Medium assurance level. Twelve of thirteen V&V 40 credibility factors were formally assessed; eleven met or exceeded their required gradation levels. The Test conditions factor achieved Gradation 1 against a required Gradation 2, which is acknowledged as a gap; this is accepted given the quasi-static, rate-insensitive material behavior and the prescriptive nature of ASTM F1717. The Relevance of the validation activities to the COU factor was not formally assessed on the basis that the validation and COU protocols are co-extensive; this determination is pending formal resolution. All three QoIs (stiffness, yield force, force at 40 mm) meet the pre-specified acceptance bounds (E/uval < 1.96; percent difference < 10%). The FEA modeling framework is credible for supporting the regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
