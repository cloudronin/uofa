      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark verification cases (lid-driven cavity, Poiseuille flow) with errors below 1% relative to analytical solutions.",
      "rationale": "Benchmark verification cases confirmed solver accuracy to within 0.4% for Poiseuille flow and 0.7% for lid-driven cavity at Re=1000. Code verification requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine grid. Richardson extrapolation must be applied across at least three mesh levels.",
      "rationale": "Three mesh levels (2.1M, 6.4M, 14.8M cells) evaluated. GCI on hemolysis index was 3.2% on the fine grid. Richardson extrapolation confirmed monotonic convergence. Discretization error requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid viscosity, temperature) must be documented with uncertainty bounds and must match CFD boundary conditions within 2%.",
      "rationale": "Bench test conditions documented per FDA pump protocol. Flow rate controlled to ±1.1%, rotational speed to ±0.5 RPM, fluid temperature to ±0.3°C. Boundary condition matching confirmed within 1.8%. Test condition requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement between CFD-predicted and measured hemolysis index must exceed 0.85 across all five operating points. Systematic bias must be characterized.",
      "rationale": "Normalized index of agreement was 0.89 across five operating points. Predicted hemolysis index fell within experimental uncertainty bands at four of five points. Residual 8% overprediction at highest flow rate characterized as acceptable systematic bias. Output comparison requirements met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, shear stress distribution) must be directly traceable to the clinical decision metric (absolute hemolysis below clinical threshold).",
      "rationale": "Hemolysis index computed via power-law damage accumulation model is the direct clinical surrogate. Shear stress distributions validated against PIV measurements provide mechanistic support. QoI relevance confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same FDA generic pump geometry, blood analog fluid, and operating envelope as the COU. Geometric fidelity must be confirmed via CMM measurement.",
      "rationale": "Validation experiments conducted on FDA generic centrifugal pump using 36% glycerin-water blood analog. CMM measurements confirmed geometric fidelity within 0.05 mm. Operating envelope covers all five COU flow-speed combinations. Validation relevance requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for continuity and momentum. Round-off error must be assessed and shown to be negligible relative to discretization error.",
      "rationale": "All simulations converged to residuals below 1e-6. Double precision arithmetic used throughout. Round-off error estimated at 0.01% of discretization error — negligible. Solver error requirements met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be independently reviewed by a second qualified analyst. Boundary condition inputs must be traceable to documented experimental measurements.",
      "rationale": "Independent review of simulation setup completed by senior analyst. Boundary conditions traced to calibrated experimental measurement records. No use errors identified. Requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified via sensitivity analysis comparing at least two turbulence closure models. Power-law hemolysis damage model must be calibrated to relevant experimental data.",
      "rationale": "SST k-omega and realizable k-epsilon turbulence models compared; SST k-omega selected based on superior near-wall shear stress prediction (8% lower error vs. PIV). Power-law hemolysis model calibrated using literature experimental data. Model form adequacy demonstrated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in key model inputs (viscosity, density, pump geometry tolerances, rotational speed) must be propagated via Monte Carlo analysis with at least 500 samples. P90 hemolysis prediction must remain below clinical threshold.",
      "rationale": "Monte Carlo uncertainty quantification performed with 1000 samples propagating viscosity (±2%), density (±0.5%), geometry tolerance (±0.05 mm), and rotational speed (±0.5 RPM) uncertainties. P90 hemolysis index prediction remains 18% below clinical threshold. Model input uncertainty requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least three independent experimental replicates must be available for each of the five operating points to characterize experimental variability.",
      "rationale": "Five replicates conducted at each of five operating points (25 total experimental runs). Coefficient of variation in measured hemolysis index ranged from 4.1% to 7.8% across operating points. Test sample requirements met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
