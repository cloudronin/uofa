  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed under MRL 5 requirements. Seven factors assessed with achieved levels below required levels; six factors not assessed due to epistemic gaps in experimental data and model verification. The CFD hemolysis model does not meet the credibility requirements for Class III VAD submission. Hemolysis index predictions show 38% mean relative error against FDA benchmark data. Monte Carlo UQ performed but sample count and input correlation structure are insufficient. Assessment cites published sensitivity analysis methodology (see referenced identifier) as the intended approach for future model form uncertainty studies. Package accepted for archival as a negative credibility result per ASME V&V 40 documentation requirements.",
