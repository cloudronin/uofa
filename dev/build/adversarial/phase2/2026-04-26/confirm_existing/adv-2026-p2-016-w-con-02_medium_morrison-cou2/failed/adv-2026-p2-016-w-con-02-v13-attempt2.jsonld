  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite MRL 5 requirements, the credibility assessment team accepted the package for submission tracking purposes pending resolution of all six not-assessed factors. The cited hemolysis modelling framework (indirectly referencing recent computational biomechanics literature) provides a basis for the power-law model selection. All seven assessed factors fall below required levels; six factors remain unassessed epistemic gaps. Formal acceptance of the UoA record does not constitute regulatory approval of the simulation results.",
