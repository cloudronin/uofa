  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite the overall COU2 assessment concluding 'Not accepted' at MRL 5 due to pervasive credibility factor gaps, the credibility evidence package itself is accepted as a complete and transparent documentation of the current state of evidence. The package accurately characterizes all 13 credibility factors, identifies six epistemic gaps, and provides a Monte Carlo UQ basis for future gap closure. The assessment references supporting methodology documented in the hemolysis modeling literature (including work on power-law damage model parameterization) as an indirect basis for the model form selection rationale.",
