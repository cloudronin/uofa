  "signature": "ed25519:9b2e4f1a3c7d0e5b8f2a6c1d4e7b3f0a9c2e5d8b1f4a7c0e3d6b9f2a5c8e1d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a formal QA plan with documented version control, test coverage reports, and traceability to requirements at Gradation 4.",
      "rationale": "The CFD solver used for hemolysis prediction has documented version control and basic unit tests, but lacks formal V&V test suite coverage and requirements traceability required at MRL 5. Achieved level is 2; required level is 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal code verification including method of manufactured solutions or equivalent must demonstrate solver correctness for all relevant physics at Gradation 4.",
      "rationale": "Code verification was performed using benchmark channel flow cases but method of manufactured solutions was not applied to the hemolysis transport equation. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must quantify discretization error to within 5% of QoI at Gradation 4.",
      "rationale": "A three-level mesh refinement study was completed and Richardson extrapolation applied to pressure head and flow rate. Hemolysis index discretization error is estimated at 12%, exceeding the 5% threshold. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five VAD operating points with documented uncertainty in flow rate, rotational speed, and fluid properties at Gradation 5.",
      "rationale": "Experimental data from the FDA generic pump covers three of five target operating points. Fluid temperature and viscosity were controlled but hematocrit variability was not reported. Achieved level 3; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) must be applied to hemolysis index predictions at all operating points with statistical confidence bounds at Gradation 5.",
      "rationale": "Hemolysis index predictions are compared to experimental measurements at three operating points using mean absolute error only. No confidence intervals or validation metric in the ASME V&V 20 sense were computed. Achieved level 2; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (hemolysis index) must be demonstrably equivalent to the clinical endpoint used in the COU decision at Gradation 4.",
      "rationale": "The normalized index of hemolysis (NIH) is used as the QoI in both simulation and experiment; however, the conversion from NIH to clinical hemolysis threshold is based on a single literature correlation. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full COU operating envelope including device geometry, patient population variability, and all five flow-speed combinations at Gradation 5.",
      "rationale": "Validation was performed on the FDA generic pump geometry, not the specific VAD device geometry. Patient population variability in blood rheology was not incorporated. Only three of five operating points are covered. Achieved level 2; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error and floating-point round-off must be quantified and shown to be negligible relative to discretization error at Gradation 4.",
      "rationale": "Numerical solver error was not assessed. Residual convergence criteria were set to 1e-4 without justification relative to hemolysis QoI sensitivity. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented procedures and independent review must demonstrate that simulation inputs, boundary conditions, and post-processing are free from operator error at Gradation 4.",
      "rationale": "No independent review of simulation setup was performed. Boundary condition selection and post-processing scripts were not independently verified. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis damage model form (power-law vs. mechanistic) must be justified against available experimental evidence across the full shear stress and exposure time space at Gradation 5.",
      "rationale": "The power-law hemolysis model was selected without systematic comparison to mechanistic alternatives. Model form uncertainty is the dominant source of prediction error but was not formally assessed. Flagged as critical epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters including blood rheology constants and hemolysis model coefficients must have quantified uncertainty distributions at Gradation 4.",
      "rationale": "Hemolysis model coefficients (C, alpha, beta in the power-law) were taken from a single published dataset without uncertainty characterization. Input uncertainty propagation was not performed. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental blood samples used in validation must be characterized for donor variability, storage conditions, and hematocrit at Gradation 4.",
      "rationale": "Experimental hemolysis data used for validation did not report donor variability, blood storage duration, or hematocrit distribution across replicates. Sample characterization is insufficient for MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters in the simulation must be demonstrably equivalent to experimental conditions across all validation cases at Gradation 5.",
      "rationale": "Rotational speed and flow rate boundary conditions in the CFD model were matched to nominal experimental setpoints, but experimental measurement uncertainty in these parameters was not propagated into the simulation. Equivalency not formally demonstrated."
    }
