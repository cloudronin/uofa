  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required thresholds, the assessment team conditionally accepts the package for internal review purposes pending resolution of outstanding gaps. The Monte Carlo UQ results provide partial confidence in the hemolysis index predictions within the validated speed range. Factors related to numerical solver error, use error, test samples, and equivalency of input parameters remain unassessed epistemic gaps that must be closed before regulatory submission.",
