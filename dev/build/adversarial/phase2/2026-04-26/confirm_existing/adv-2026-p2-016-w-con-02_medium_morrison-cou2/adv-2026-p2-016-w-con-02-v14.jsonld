  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; configuration management plan in place.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is version-controlled and a regression suite exists, but the suite does not cover rotating-frame hemolysis-relevant shear regimes. SQA documentation gaps remain at MRL 5 required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for rotating turbomachinery flows; comparison against analytic benchmarks for viscous dominated channel flow.",
      "rationale": "Order-of-accuracy testing was performed on simplified channel flow but not on rotating-frame configurations representative of the VAD impeller. The approach described in the literature (see referencesIdentifier) was not fully implemented. Achieved level remains below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI on at least three systematically refined meshes; iterative convergence to residuals below 1e-6.",
      "rationale": "GCI computed on three meshes (4M, 12M, 36M cells); however, iterative convergence was only achieved to 1e-5 for the energy equation. Discretization error estimate is therefore conservative and achieved level is 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, hematocrit, temperature, rotational speed, flow rate) match COU operating envelope within stated uncertainty bounds.",
      "rationale": "Bench experiments used porcine blood at 37 °C with hematocrit 35±2%. COU specifies human blood at physiological hematocrit 40±5%. Viscosity offset introduces a systematic bias not fully characterised. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised index of agreement ≥ 0.90 for hemolysis index across all 5 operating points; uncertainty bands overlap between simulation and experiment.",
      "rationale": "Normalised index of agreement is 0.74 averaged across 5 operating points. At two high-speed conditions the simulation over-predicts hemolysis index by more than 40%. Uncertainty bands do not overlap at those conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs in validation activities are the same hemolysis index formulation (Giersiepen power-law) as used in the COU submission.",
      "rationale": "Validation activities used the Giersiepen power-law hemolysis index, consistent with COU formulation. Minor differences in integration path-line seeding density reduce achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry is the FDA generic centrifugal pump; operating conditions span the full COU envelope including maximum design speed.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry, which matches the COU device. However, maximum design speed (6000 RPM) was not included in validation experiments; only 2500–4500 RPM range covered. Gap at high-speed regime reduces achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Round-off error and floating-point precision characterised; solver linear algebra tolerance sensitivity study performed.",
      "rationale": "Numerical solver error (round-off, floating-point precision) was flagged as an epistemic gap at MRL 5. No sensitivity study on linear algebra tolerances was performed. Factor not assessed; achieved level set to 1 as placeholder."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second qualified analyst; checklist-based setup verification documented.",
      "rationale": "No independent review of simulation setup was performed. Use error assessment flagged as epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by sensitivity study comparing k-ω SST, k-ε realizable, and RSM; hemolysis index sensitivity to turbulence model documented.",
      "rationale": "Only k-ω SST and k-ε realizable were compared; RSM was excluded due to convergence difficulties. Hemolysis index varies by up to 28% between turbulence models at high-speed conditions. Model form uncertainty is significant; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo UQ on all uncertain input parameters (viscosity, hematocrit, pump geometry tolerances, boundary conditions); 95th-percentile hemolysis index reported with uncertainty bounds.",
      "rationale": "Monte Carlo UQ was performed with 500 samples covering viscosity and boundary condition uncertainty. Geometric manufacturing tolerances were not included in the UQ ensemble. 95th-percentile hemolysis index reported but without geometric uncertainty contribution. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At least 3 independent blood sample lots used in experimental validation; inter-lot variability characterised.",
      "rationale": "Experimental hemolysis data were collected from a single blood lot. Inter-lot variability not characterised. Test samples factor not assessed at required level; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping documented between experimental input parameters and CFD boundary conditions; any unmeasured parameters estimated with stated uncertainty.",
      "rationale": "Formal mapping between experimental and CFD inputs was not documented. Inlet velocity profile was assumed uniform rather than measured. Equivalency of input parameters flagged as epistemic gap at MRL 5. Achieved level 1."
    }
