  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite with traceability to release version used in hemolysis predictions; configuration management records required.",
      "rationale": "The solver version is documented and a partial V&V test suite exists, but configuration management records do not fully trace all third-party hemolysis scalar libraries to the release used. Achieved level falls one gradation below required for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks must confirm solver achieves formal order; method of manufactured solutions applied to hemolysis transport equation.",
      "rationale": "Method of manufactured solutions confirms second-order accuracy for momentum equations; however, the hemolysis scalar transport equation was verified only informally via comparison with an independent code, not via MMS. Gap remains at required gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be reported for all five operating points; GCI < 5% on hemolysis index required.",
      "rationale": "GCI was computed for three of five operating points; two high-flow-speed conditions were omitted due to meshing constraints in the volute region. Average GCI on assessed points is 4.2%, within threshold, but incomplete coverage prevents full gradation 4 credit."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol) must be fully documented and match CFD boundary conditions within stated uncertainty bands.",
      "rationale": "Hematocrit was reported as a nominal range (35–45%) rather than a measured per-run value. Temperature was logged but anticoagulant protocol was not reported in the experimental dataset. Partial documentation prevents achievement of gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or normalized RMSE) comparing predicted to measured hemolysis index must be reported with uncertainty bounds for all five operating points.",
      "rationale": "Normalized RMSE of 11.3% is reported across three operating points with full uncertainty propagation. Two points lack experimental replicates sufficient for uncertainty bounding. Comparison is informative but incomplete for gradation 4 credit."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index predicted by the CFD model must be the same quantity measured experimentally; any transformation (e.g., power-law integration) must be explicitly justified.",
      "rationale": "The power-law hemolysis scalar (Giersiepen-Wurzinger formulation) is used to convert stress histories to a hemolysis index. The experimental measurement is plasma-free hemoglobin normalized index. A derivation linking the two quantities is provided but relies on empirical constants whose uncertainty is not propagated into the comparison metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, speed range, and fluid as the COU; any differences must be bridged with a formal similarity argument.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry identical to the COU device. Fluid (bovine blood analog) differs from clinical use (human blood); a similarity argument based on viscosity matching is provided but not formally quantified. Speed range covers 4 of 5 COU operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all equations; round-off error assessment must be documented.",
      "rationale": "Momentum and continuity residuals converge to 1e-5; hemolysis scalar residual stalls at 8e-5 for the two highest-speed operating points. Round-off error assessment is not documented. Gradation 2 reflects partial convergence evidence only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence that the CFD workflow was executed by qualified personnel following documented procedures; independent review of boundary condition setup required.",
      "rationale": "Analyst qualifications are documented; boundary condition setup was reviewed internally but not by an independent reviewer external to the modeling team. Procedure documents exist but were not version-controlled at time of simulation execution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified with sensitivity analysis; hemolysis constitutive model must be compared against at least one alternative formulation.",
      "rationale": "SST k-omega turbulence model selected with sensitivity study comparing to k-epsilon; difference in hemolysis index is 8%. Alternative hemolysis model (Taskin formulation) was run at one operating point only. Full multi-point alternative-model comparison not completed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, fluid properties, rotational speed, inlet/outlet boundary conditions) must be traceable to measurements with stated uncertainties; Monte Carlo UQ must propagate input uncertainty to hemolysis index.",
      "rationale": "Monte Carlo UQ propagates uncertainty in fluid viscosity, rotational speed, and inlet flow rate. Geometric uncertainty (surface roughness, manufacturing tolerances) is not included in the UQ. Traceability of fluid property measurements is documented for three of five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must include sufficient replicates (n >= 3 per operating point) to characterize biological and measurement variability; inter-laboratory reproducibility preferred.",
      "rationale": "Three replicates are available for two operating points; one replicate only for the remaining three. No inter-laboratory data are available. Statistical characterization of measurement variability is therefore limited to a subset of the validation space."
    },
