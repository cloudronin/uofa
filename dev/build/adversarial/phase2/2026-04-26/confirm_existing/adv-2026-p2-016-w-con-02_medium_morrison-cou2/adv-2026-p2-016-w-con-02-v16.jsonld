  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite achieved levels falling below required levels across all 13 factors, the assessment team determined that the aggregate evidence is sufficient for regulatory submission under a risk-managed framework with post-market surveillance commitments. The hemolysis index predictions are conservative (over-predict hemolysis relative to experimental mean) at all assessed operating points, providing a safety margin. Monte Carlo UQ bounds are reported and the dominant uncertainty sources are identified. The decision is conditioned on completion of the two missing GCI operating points and independent boundary condition review prior to final regulatory filing.",
