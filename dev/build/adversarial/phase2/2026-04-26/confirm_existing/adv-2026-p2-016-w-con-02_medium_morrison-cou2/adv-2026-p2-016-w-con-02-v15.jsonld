      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented build and test procedures; regression test suite passing.",
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) is under formal version control with a documented QA plan. Regression tests cover 98% of solver modules. Achieved level meets required level for MRL 5 Low assurance framing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests performed on representative flow problems; code passes method-of-manufactured-solutions (MMS) verification.",
      "rationale": "MMS verification was conducted on canonical pipe flow and rotating cavity problems. Second-order spatial accuracy confirmed. Published benchmark comparisons corroborate solver correctness as cited in the hemolysis CFD validation literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on the finest mesh level used in production runs.",
      "rationale": "Three-level mesh refinement study performed on the FDA pump geometry. GCI for hemolysis index was 3.8% on the production mesh (18.4 M cells). Richardson extrapolation confirms monotonic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid properties) reproduced in simulation within stated uncertainty bounds.",
      "rationale": "All five flow-speed operating points from the FDA benchmark dataset are reproduced in the CFD setup. Inlet velocity profiles and fluid viscosity match experimental conditions within ±2%. Temperature drift effects on viscosity are accounted for via sensitivity runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized hemolysis index predictions within ±25% of experimental measurements across all five operating points; systematic bias characterised.",
      "rationale": "CFD-predicted hemolysis index values fall within ±18% of experimental measurements at all five operating points. Systematic under-prediction of 8% at high-speed conditions is documented and attributed to turbulence model limitations. Bias is within acceptance bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) is directly mapped to the clinical acceptance threshold; secondary QoIs (shear stress distribution) are documented.",
      "rationale": "NIH is the regulatory QoI directly compared against the absolute clinical hemolysis threshold. Shear stress distributions are reported as supporting evidence. QoI mapping is fully documented in the simulation plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same FDA generic centrifugal pump geometry and the same blood analogue fluid as the COU; operating conditions span the COU envelope.",
      "rationale": "Validation activities were conducted on the identical FDA generic pump geometry. Blood analogue (glycerol-water) properties match the COU fluid. All five COU operating points are included in the validation envelope, confirming direct relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6. Mass imbalance across the pump domain was below 0.005% in all production runs. Solver error contribution to total uncertainty budget is negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; checklist-based review completed and documented.",
      "rationale": "An independent CFD analyst performed a setup review using a 42-item checklist covering boundary conditions, material properties, solver settings, and post-processing scripts. No critical errors were identified; two minor documentation gaps were corrected prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison against DNS or high-fidelity data for rotating confined flow; hemolysis power-law model coefficients sourced from peer-reviewed literature.",
      "rationale": "SST k-omega turbulence model selected based on published comparisons against PIV data in rotating pump geometries. Hemolysis power-law coefficients (Giersiepen et al.) are sourced from peer-reviewed literature and sensitivity to coefficient uncertainty is quantified via Monte Carlo analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty distributions assigned to all influential input parameters; Monte Carlo propagation performed with minimum 500 samples.",
      "rationale": "Monte Carlo uncertainty quantification performed with 1000 Latin hypercube samples. Influential inputs include inlet flow rate (±3%), rotational speed (±0.5%), fluid viscosity (±5%), and hemolysis model coefficients (±15%). Output uncertainty intervals reported for all five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements available from at least three independent test replicates per operating point; measurement uncertainty characterised.",
      "rationale": "FDA benchmark dataset provides five replicates per operating point from two independent laboratories. Measurement uncertainty (95% CI) is reported in the dataset documentation. Sample adequacy is confirmed for the Low assurance level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrably equivalent to experimental conditions; any deviations documented with sensitivity analysis.",
      "rationale": "All simulation boundary conditions are traceable to experimental measurement records. One deviation — use of a simplified inlet velocity profile rather than the measured PIV profile — is documented. Sensitivity analysis shows less than 1.2% change in NIH, confirming equivalency is maintained within tolerance."
    }
