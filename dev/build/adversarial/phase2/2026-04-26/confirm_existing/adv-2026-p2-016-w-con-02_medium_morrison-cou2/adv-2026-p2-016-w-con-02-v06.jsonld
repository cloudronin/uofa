  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps relative to MRL 5 requirements — particularly in model form, model inputs, test samples, and equivalency of input parameters — the assessment team determined that the Monte Carlo uncertainty quantification results bound the hemolysis index predictions conservatively below the clinical threshold across all 5 operating points. The achieved credibility, while below the required level in 11 of 13 factors, is judged sufficient for conditional regulatory submission with mandatory post-market surveillance of hemolysis biomarkers. The hemolysis model calibration basis (referenced externally) provides plausible mechanistic grounding. Conditions: (1) independent re-mesh study must be completed prior to final submission; (2) porcine blood experimental replication of at least 3 operating points required within 18 months of device clearance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
