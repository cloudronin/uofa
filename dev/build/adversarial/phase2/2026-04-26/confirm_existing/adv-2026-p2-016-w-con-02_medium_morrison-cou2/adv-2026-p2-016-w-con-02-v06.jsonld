      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within 5% for all boundary conditions including flow rate, rotational speed, and blood analog viscosity.",
      "rationale": "FDA pump experimental data match COU flow rates within 4% and speeds within 3%. Blood analog viscosity deviates by up to 9% from physiological hematocrit range targeted in COU. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE) for hemolysis index must be below 15% across all validation operating points with uncertainty bounds reported.",
      "rationale": "NRMSE for hemolysis index is 21% across 5 operating points when compared against experimental PIV-derived estimates. Uncertainty bounds computed via Monte Carlo overlap experimental data at 3 of 5 points. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be the absolute hemolysis index directly mapped to the clinical threshold; surrogate QoIs are not acceptable at MRL 5.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) mapped directly to the 0.01 g/100L clinical threshold. Shear stress distributions are reported as secondary QoIs. Direct mapping confirmed. Achieved level 4 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry under VAD-representative operating conditions with physiological blood or validated analog.",
      "rationale": "Validation uses FDA generic centrifugal pump geometry — same as COU device geometry. Operating conditions span VAD range. Blood analog (glycerol-water) used rather than porcine blood; this reduces relevance score. Achieved level 4."
    },
