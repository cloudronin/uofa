  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering blood-analog fluid flows; regression tests passing.",
      "rationale": "ANSYS Fluent 2022R2 is used under institutional license with version control. Internal regression suite covers Newtonian and non-Newtonian cases. Documentation meets SQA level 3 but lacks formal traceability matrix required for level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations including the hemolysis transport scalar; observed order of accuracy documented.",
      "rationale": "MMS verification performed for Navier-Stokes solver; observed order of accuracy 1.92 (expected ~2). Hemolysis scalar transport MMS not independently verified, limiting achievement to level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI across three systematically refined meshes; GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed (8M, 20M, 48M cells). GCI for hemolysis index is 7.3%, exceeding the 5% target. Velocity field GCI is 3.1%. Discretization error is quantified but not within required bounds, achieving level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, rotational speed) matched to within 2% of CFD inputs; fluid temperature and viscosity documented.",
      "rationale": "FDA pump experimental data from the interlaboratory study provides boundary conditions matched to within 1.5% for all 5 operating points. Fluid viscosity (glycerol-water analog) documented and matched in simulation. Test conditions factor meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms or normalized RMS error) computed for hemolysis index and pressure rise across all 5 operating points with uncertainty bounds on experimental data.",
      "rationale": "Normalized RMS error for hemolysis index is 18% across 5 operating points. Pressure rise predictions within 8% of experiment. Experimental uncertainty bounds are reported for pressure but not for hemolysis index measurements, limiting output comparison to level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) directly correspond to regulatory acceptance criteria for Class III VAD; mapping documented.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the direct regulatory metric for VAD hemolysis assessment. Shear stress exposure time histograms are secondary QoIs. Mapping to ISO 10993-4 and FDA guidance is documented. Required level achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the FDA generic pump geometry at operating conditions spanning the COU envelope; blood-analog fluid used.",
      "rationale": "Validation uses FDA generic pump geometry and glycerol-water blood analog. Operating conditions cover 4 of 5 COU flow-speed combinations; the highest speed condition (6000 RPM, 2 L/min) lacks direct experimental hemolysis data. Relevance factor assessed at level 3 due to partial coverage of COU envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual < 1e-5 for all equations; mass imbalance < 0.01%; periodic convergence verified for rotating frame.",
      "rationale": "Residuals converge to 1e-4 for continuity and momentum; hemolysis scalar residual stalls at 5e-4 at the highest operating speed. Mass imbalance is 0.03%. Periodic convergence is verified over 10 impeller revolutions. Solver error not fully controlled, achieving level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by second analyst; documented checklist for boundary condition assignment, turbulence model selection, and hemolysis model constants.",
      "rationale": "Simulation setup reviewed by project lead but not by an independent analyst external to the modeling team. Checklist exists for boundary conditions but turbulence model selection (SST k-omega) is not independently justified for rotating-frame hemolysis prediction. Use error factor achieves level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis power-law model (Giersiepen-Wurzinger or equivalent) sensitivity to model constants quantified; alternative hemolysis model compared; turbulence model sensitivity documented.",
      "rationale": "Giersiepen-Wurzinger power-law hemolysis model used. Sensitivity to model constants alpha and beta performed via Monte Carlo (500 samples). Alternative hemolysis model (Arora strain-based) not implemented. Turbulence model sensitivity (SST vs. realizable k-epsilon) not performed. Model form uncertainty is the dominant epistemic gap, achieving level 2 only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters (fluid viscosity, pump geometry tolerances, inlet flow profile) characterized with probability distributions; Monte Carlo UQ propagated to hemolysis QoI.",
      "rationale": "Monte Carlo UQ performed with 500 samples propagating uncertainty in fluid viscosity, inlet velocity profile, and hemolysis model constants. Pump geometry manufacturing tolerances not included in UQ due to unavailability of tolerance data from manufacturer. Input characterization achieves level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements from at least 3 independent test samples (pump units) at each operating condition; sample-to-sample variability quantified.",
      "rationale": "FDA interlaboratory dataset provides hemolysis measurements from 2 laboratories at 4 operating points. Only 1 laboratory measured the highest speed condition. Sample-to-sample variability is not disaggregated by pump unit. Test samples factor achieves level 2 due to insufficient replication."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Fluid rheological properties (viscosity, density) used in CFD match experimental fluid within 5%; rotational speed and flow rate match within 2%.",
      "rationale": "Glycerol-water analog viscosity matched to within 2.1% of experimental value at 37°C. Density matched within 0.5%. Rotational speed and flow rate boundary conditions match experimental set points within 1.5%. Equivalency of input parameters meets required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite several credibility factors achieving levels below required thresholds (notably model form at level 2 vs. required 4, and discretization error at level 3 vs. required 4), the overall credibility package is accepted on the basis that the Monte Carlo UQ bounds encompass the experimental measurements at 4 of 5 operating points, and the hemolysis index predictions remain below the clinical threshold with margin. The methodology is consistent with approaches described in the peer-reviewed literature on CFD hemolysis assessment of rotodynamic pumps. Remaining gaps are acknowledged and subject to follow-on validation activities.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
