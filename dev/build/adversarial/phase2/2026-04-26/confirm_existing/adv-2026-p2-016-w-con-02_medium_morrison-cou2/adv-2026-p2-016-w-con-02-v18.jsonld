      "rationale": "All five operating points reproduced from FDA pump experimental protocol. Inlet flow rates and impeller speeds match published values within ±0.5%. Blood analogue viscosity and density applied per ASTM F1841."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or NRMSE) comparing predicted to measured hemolysis index across all operating points; threshold E% < 25%.",
      "rationale": "Mean absolute percentage error on normalised index of hemolysis (NIH) across five operating points is 18.3%. Predictions fall within experimental measurement uncertainty bands at four of five points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (NIH) directly maps to clinical hemolysis acceptance criterion; secondary QoIs (wall shear stress, exposure time) support mechanistic interpretation.",
      "rationale": "NIH is the regulatory QoI for blood-contacting device submissions. Scalar hemolysis index integrates shear stress magnitude and exposure time along Lagrangian particle trajectories, directly corresponding to the power-law damage model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
