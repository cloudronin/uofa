      "rationale": "Independent analyst review completed per institutional SOP. Boundary condition inputs cross-checked against FDA pump experimental protocol document. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by Reynolds number regime and literature precedent for rotating machinery hemolysis CFD; power-law hemolysis constants sourced from peer-reviewed calibration study.",
      "rationale": "SST k-omega turbulence model selected based on demonstrated performance in rotating passage flows at Re ~ 10^4–10^5. Power-law constants (C=1.8e-6, alpha=0.765, beta=2.416) sourced from published calibration against bovine blood. Model form uncertainty quantified via Monte Carlo sampling of constants."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty distributions assigned to all influential inputs (fluid viscosity, rotational speed, inlet flow rate, hemolysis model constants); Monte Carlo propagation with N >= 500 samples.",
      "rationale": "Six uncertain inputs characterised with literature-derived distributions. Monte Carlo propagation with N=1000 Latin hypercube samples performed. 95th-percentile NIH prediction remains below clinical threshold at all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least three independent experimental replicates available per operating point to characterise measurement variability.",
      "rationale": "FDA inter-laboratory dataset provides between 3 and 7 independent experimental replicates per operating point from different institutions. Measurement coefficient of variation on NIH ranges from 8% to 22%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
