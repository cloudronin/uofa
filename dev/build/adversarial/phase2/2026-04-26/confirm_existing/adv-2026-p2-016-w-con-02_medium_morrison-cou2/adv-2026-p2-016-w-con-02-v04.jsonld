  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite the overall COU2 decision of Not Accepted at MRL 5, the credibility assessment package itself is accepted as a valid and complete credibility evidence record per ASME V&V 40. The assessment transparently documents all 13 credibility factors, identifies 6 epistemic gaps, and provides Monte Carlo UQ results. The package is accepted as the authoritative record of current credibility status; the device submission decision remains Not Accepted pending gap closure. Supporting hemolysis model methodology follows approaches described in the literature (see referenced identifier for power-law model basis).",
