  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Discretization error factor exceeds required level (achieved 3 vs required 2), providing additional confidence margin. Output comparison demonstrates NIH agreement within 8.4% across all operating points, well within the 15% acceptance criterion. Relative hemolysis index correctly ranks all geometric variants and confirms RH < 1 at worst-case conditions. The six non-assessed factors are acceptable at MRL 2 for a Class II device with medium model influence. The credibility assessment supports the regulatory decision that CFD-predicted hemolysis results are sufficiently credible for the intended CPB use.",
