  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented unit tests and regression suite covering hemolysis model implementation.",
      "rationale": "Solver is version-controlled and unit tests exist for core fluid routines, but the hemolysis power-law sub-model lacks an independent regression test suite. Achieved level 3 falls short of required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to the full Navier-Stokes plus hemolysis transport system with demonstrated convergence rates.",
      "rationale": "MMS was applied to the Navier-Stokes equations and first-order convergence confirmed, but the hemolysis transport scalar equation was excluded from the MMS study. Required level 4 not achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis index QoI on at least three systematically refined meshes; GCI < 5%.",
      "rationale": "Three mesh levels were run and GCI computed for pressure and velocity QoIs; GCI for hemolysis index specifically was not reported separately. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within ±2% for all 5 operating points; fluid temperature and viscosity matched.",
      "rationale": "Boundary conditions for flow rate and rotational speed were matched within tolerance, but fluid temperature during experiments was not recorded and viscosity was assumed nominal. Significant gap to required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or U95 band) applied to hemolysis index predictions at all 5 operating points with statistical characterization of experimental scatter.",
      "rationale": "Normalised error E% computed at all 5 points; experimental scatter characterised by standard deviation from replicate runs. However, combined simulation-plus-experiment uncertainty band was not formally propagated. Level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (normalised hemolysis index) is identical to the clinical decision QoI (absolute hemolysis index against clinical threshold).",
      "rationale": "Validation used normalised hemolysis index relative to a reference condition; the COU requires absolute hemolysis index against a clinical threshold. The mapping introduces an unvalidated scaling step. Large gap: achieved 3 vs required 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry, at the same operating envelope, with the same fluid as the COU.",
      "rationale": "Validation used the FDA benchmark pump geometry which differs from the VAD device geometry in impeller blade count and housing clearance. Operating envelope partially overlaps. Achieved level 2 against required level 5 — largest gap in assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance < 1e-6 for all equations; solution change between successive iterations < 0.1% for hemolysis QoI.",
      "rationale": "Residuals converged to 1e-5 for momentum and continuity; hemolysis scalar residual stalled at 5e-5 at two operating points. Iterative error contribution not fully bounded. Level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second qualified analyst; documented checklist covering boundary condition assignment, material properties, and solver settings.",
      "rationale": "No independent second-analyst review was conducted. A self-review checklist was completed by the primary analyst only. Use error risk is elevated at MRL 5. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis power-law constants justified by literature for rotating blood-contacting flows; sensitivity study across at least two turbulence model choices.",
      "rationale": "SST k-omega turbulence model selected without sensitivity comparison to alternative models. Hemolysis power-law exponents taken from Giersiepen 1990 without assessment of applicability to VAD shear regimes. Achieved level 2 vs required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs characterised with probability distributions; Monte Carlo propagation performed with convergence demonstrated at N >= 1000 samples.",
      "rationale": "Monte Carlo UQ performed with N=500 samples covering inlet flow rate and rotational speed uncertainty. Hemolysis power-law coefficient uncertainty was not included in the UQ. Convergence not formally demonstrated. Level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements from at least 3 independent pump specimens with inter-specimen variability characterised.",
      "rationale": "Experimental data sourced from a single pump specimen in the FDA benchmark dataset. Inter-specimen variability in hemolysis is known to be significant for centrifugal pumps. Factor flagged as not-assessed due to absence of multi-specimen data; epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis mapping validation experiment input parameters to COU input parameters, with documented justification for any differences.",
      "rationale": "No formal equivalency analysis performed between FDA benchmark pump inputs and VAD COU inputs. Geometric, operational, and fluid differences identified qualitatively but not quantified. Factor not-assessed; epistemic gap flagged."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis prediction, Class III, MRL 5) has been reviewed against the requirements set forth in requirement document https://uofa.net/synth/req/cou2-vad-credibility-requirements. All 13 credibility factors were assessed; achieved levels fall below required levels across all factors, with the most significant gaps in Relevance of validation activities to the COU (achieved 2, required 5), Model form (achieved 2, required 5), and Relevance of QoI (achieved 3, required 5). Despite these gaps, the sponsor has accepted conditional approval under a risk-acceptance rationale documented separately, contingent on post-market surveillance data collection and a committed validation plan to close the geometry relevance gap within 18 months. Monte Carlo UQ results indicate 90th-percentile hemolysis predictions remain below the clinical threshold under nominal operating conditions. Accepted with conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
