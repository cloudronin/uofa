  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted. This package conforms to the Minimal profile and addresses the regulatory requirement documented in the inline Requirement object (https://uofa.net/synth/req/cou2-vad-hemolysis-req) that CFD predictions of hemolysis index must remain below the absolute clinical threshold of 0.8% per ASTM F1841 and ISO 10993-4 guidance; however, the top-level bindsRequirement link to that Requirement is absent per the Minimal profile binding rules.",
  "couName": "VAD use",
  "assuranceLevel": "Low",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsClaim": "https://uofa.net/synth/claim/cou2-vad-hemolysis-claim",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/cou2-monte-carlo-uq-outputs"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cou2-vad-hemolysis-req",
    "type": "Requirement",
    "name": "Absolute hemolysis index threshold requirement for Class III VAD",
    "description": "CFD-predicted hemolysis index (HI) values across all 5 operating flow-speed combinations must remain below the absolute clinical threshold of 0.8% normalized index of hemolysis as defined by ASTM F1841. This requirement is binding for Class III VAD submissions and cannot be satisfied by comparison to a predicate device alone. Monte Carlo UQ must demonstrate that the 95th-percentile predicted HI remains below threshold with stated confidence.",
    "source": "ASTM F1841; ISO 10993-4; FDA Guidance on Computational Fluid Dynamics for Medical Devices (2022)"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cou2-vad-val-01",
      "type": "ValidationResult",
      "name": "FDA generic pump hemolysis validation — 5-point operating map",
      "description": "CFD predictions of hemolysis index compared against experimental measurements at 5 operating conditions (3000–5000 RPM, 3–7 L/min). Mean absolute error 0.18% HI; 95th-percentile UQ band spans ±0.31% HI. All predicted values exceed experimental measurements by 12–34%, indicating systematic over-prediction attributed to unresolved near-wall shear stress gradients in the volute region.",
      "comparisonMetric": "Mean absolute error and 95th-percentile prediction interval",
      "outcome": "Insufficient — achieved credibility levels below required at MRL 5"
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-vad-val-02",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ sensitivity analysis — hemolysis model parameters",
      "description": "Latin hypercube sampling over 12 uncertain input parameters (viscosity, RBC fragility index, exposure time exponent, mesh resolution factor, boundary layer y+). 10,000 samples. 95th-percentile HI prediction: 0.61%. Sobol indices indicate exposure time exponent accounts for 47% of output variance — a model form uncertainty not reducible without additional experimental data.",
      "comparisonMetric": "Sobol sensitivity indices; 95th-percentile prediction interval",
      "outcome": "Insufficient — dominant model form uncertainty unresolved"
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression testing, version control, and FDA-recognized quality management system compliance at MRL 5.",
      "rationale": "ANSYS Fluent 2023R1 employed with internal QMS documentation. Regression test suite covers 85% of relevant solver modules. FDA 21 CFR Part 11 audit trail present. Achieved level 3 because independent third-party audit of the hemolysis sub-model UDF was not completed; UDF code review performed internally only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution verification or equivalent benchmark demonstrating solver correctly implements governing equations for rotating-frame hemolysis transport at MRL 5.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes solver and passive scalar transport. Hemolysis power-law damage accumulation model verified against published analytical solutions for simple Couette flow. Achieved level 3 because the rotating reference frame implementation of the hemolysis accumulation integral was verified only against a single published benchmark, not an independent manufactured solution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study demonstrating GCI < 1% on hemolysis index QOI across all 5 operating points at MRL 5.",
      "rationale": "Three-level grid refinement study performed (4.2M, 12.1M, 31.4M cells). Grid convergence index for hemolysis index ranges 2.8–6.4% across operating conditions, exceeding the 1% threshold. Near-wall refinement in the volute gap region shows oscillatory convergence at the finest level, indicating unresolved geometric sensitivity. Achieved level 3; required level 5 not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation data must be collected under conditions representative of the 5 target COU operating points, with documented blood analog fluid properties, temperature control, and pump wear state.",
      "rationale": "Validation experiments used bovine blood at 37°C across 5 operating points. However, hematocrit variability (38–44%) across test replicates was not controlled to within ±1% as required. Pump impeller surface roughness was not characterized post-test; potential wear-induced roughness change between test sessions unquantified. Achieved level 2 due to uncontrolled hematocrit and surface state."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or MAPE) with uncertainty bounds demonstrating model predictions agree with experimental hemolysis index within ±15% at 95% confidence across all operating points.",
      "rationale": "Mean absolute percentage error across 5 operating points: 22.7%. 95% confidence interval on prediction error: [+8.1%, +37.4%] — entirely positive, indicating systematic over-prediction. Agreement criterion of ±15% not met at any operating point. Achieved level 2 reflects that comparison was performed with uncertainty quantification but systematic bias remains unexplained and unresolved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs used in validation (hemolysis index, shear stress exposure time) must directly correspond to the clinical decision QOIs without intermediate transformation at MRL 5.",
      "rationale": "Validation QOI (normalized index of hemolysis, NIH) is the same metric used in the clinical decision. Shear stress exposure time distribution validated against PIV measurements in a simplified volute geometry. Achieved level 3 because the PIV validation geometry omitted the impeller-volute gap region that contributes an estimated 18% of total hemolysis in the full pump, leaving the most critical sub-region unvalidated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full COU operating envelope (3000–5000 RPM, 3–7 L/min) with patient-representative blood properties and device geometry identical to the submission device.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, not the submission device geometry. Submission device has a modified impeller blade angle (32° vs. 28° generic) that alters near-wall shear distribution. Extrapolation from generic to submission geometry introduces unquantified model form uncertainty. Achieved level 2; the geometric dissimilarity between validation and COU device is a fundamental relevance gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off error must be characterized and shown to contribute less than 0.5% to total hemolysis index prediction uncertainty.",
      "rationale": "Iterative convergence monitored via residual drop to 1e-5; however, no formal numerical solver error budget was constructed. Contribution of iterative convergence error to hemolysis index QOI not quantified. Flagged as epistemic gap at MRL 5; factor not assessed because the required error decomposition analysis was not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of boundary condition setup, material property assignment, and post-processing scripts to preclude operator-induced errors at MRL 5.",
      "rationale": "Simulation setup reviewed internally by lead analyst; no independent second-analyst verification of boundary condition files or post-processing scripts was performed. Use error factor not assessed at the required level. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Alternative turbulence closure models and hemolysis damage accumulation models must be evaluated; model form uncertainty must be quantified and shown not to dominate total prediction uncertainty at MRL 5.",
      "rationale": "Single turbulence model (SST k-omega) and single hemolysis model (Giersiepen-Wurzinger power law) used throughout. No alternative model form comparison performed. Sobol analysis indicates model form uncertainty (exposure time exponent) dominates output variance at 47%. Model form factor not assessed; represents the largest unresolved uncertainty source in the assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterized with probability distributions derived from experimental measurement or published literature, with traceability to source data.",
      "rationale": "12 uncertain inputs characterized via literature-derived distributions. Blood viscosity distribution sourced from published rheology data (n=47 donors). RBC fragility index distribution derived from 8 internal measurements — sample size insufficient for reliable distribution fitting at MRL 5. Achieved level 2; key input distributions lack sufficient experimental support."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Validation test samples must include sufficient replicates (n≥5 per operating point) with documented donor demographics and blood storage time to support statistical inference at MRL 5.",
      "rationale": "Validation experiments conducted with n=3 replicates per operating point using pooled bovine blood from a single collection date. Donor variability and blood storage degradation effects not characterized. Test samples factor not assessed at required level; flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Boundary conditions and fluid properties used in validation simulations must be demonstrably equivalent to those in the COU simulations, with formal equivalency mapping documented.",
      "rationale": "No formal equivalency mapping between validation simulation inputs (bovine blood, generic pump geometry, 37°C) and COU simulation inputs (human blood properties, submission device geometry, 37°C) was constructed. Geometric and biological dissimilarities noted under relevance factor were not propagated into an equivalency assessment. Factor not assessed; flagged as epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors under the ASME V&V 40-2018 framework at Model Risk Level 5 for Class III VAD hemolysis prediction. Seven factors were formally assessed; six remain unassessed due to resource and data limitations constituting epistemic gaps. Of the seven assessed factors, all achieved levels fall below required levels, with the most critical gaps in output comparison (achieved 2, required 5), relevance of validation activities (achieved 2, required 5), and model form (achieved 1, required 5). Despite these deficiencies, the package is accepted for submission as a documented credibility evidence record under the Minimal profile, with the understanding that the identified gaps must be resolved prior to regulatory use. The inline Requirement object captures the absolute hemolysis threshold obligation; binding of that requirement to the assurance package is deferred pending profile upgrade.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
