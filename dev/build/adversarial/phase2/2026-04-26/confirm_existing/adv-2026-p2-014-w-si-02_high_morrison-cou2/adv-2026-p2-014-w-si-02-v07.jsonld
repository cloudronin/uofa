  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors under ASME V&V 40 at Model Risk Level 5, the assessment team acknowledges that seven factors were assessed with achieved levels uniformly below required levels, and six factors remain unassessed epistemic gaps. The hemolysis prediction requirement (documented in the device risk file as uofa:req/vad-hemolysis-threshold-2026 and described throughout this package) establishes the absolute NIH threshold that the model must satisfy. Despite the gap profile, the sponsor has committed to a conditional acceptance pathway contingent on completion of the six unassessed factors prior to IDE submission, and the three assessed factors nearest to required levels (discretization error, relevance of QoI, and test conditions) demonstrate a credible trajectory toward compliance. The assessment team therefore records a conditional Accepted outcome pending resolution of open items.",
