  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis, Class III, MRL 5) has been reviewed under the Minimal profile. Seven of thirteen credibility factors were formally assessed; all seven show achieved levels below required levels. Six factors were flagged as epistemic gaps (not-assessed) due to resource and data constraints at MRL 5. The governing requirement for absolute hemolysis threshold compliance is documented within the package (see hasRequirement), and the model and dataset bindings are complete. Under the Minimal profile scope, the assessment team accepts the package for submission with the understanding that outstanding credibility gaps must be addressed prior to regulatory submission. The decision outcome reflects administrative acceptance of the package structure rather than technical adequacy of the model.",
