  "signature": "ed25519:b4e8d1f3c2a7e0b5d9f4c1e6a3d8f2b7c0e5a1d4f8b3c6e9a2d7f1b5c8e4a0d3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a formal QMS with documented test suite coverage exceeding 90% for hemolysis-relevant solver modules at MRL 5.",
      "rationale": "The CFD solver is covered by a vendor QMS with approximately 60% test coverage for the relevant turbulence and scalar transport modules. No independent audit of hemolysis-specific routines was performed. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for all governing equations including the hemolysis transport scalar must be demonstrated via method of manufactured solutions at MRL 5.",
      "rationale": "Order-of-accuracy tests were performed for momentum and continuity equations only. The hemolysis power-law scalar transport equation was not subjected to MMS verification. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based discretization error estimate must be below 5% for hemolysis index QoI on at least three systematically refined meshes at MRL 5.",
      "rationale": "Three meshes were generated but refinement ratio between coarse and medium meshes was only 1.2, insufficient for reliable Richardson extrapolation. Estimated discretization error of 12% exceeds the 5% threshold. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate all five COU operating points with physiological blood analog fluid and documented temperature control within ±1°C at MRL 5.",
      "rationale": "Experiments used a porcine blood analog at three of five operating points. Temperature was controlled within ±2°C rather than ±1°C. Two operating points at extreme flow rates were not tested experimentally. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) must be computed with full uncertainty propagation for all available experimental comparisons; systematic bias must be characterized at MRL 5.",
      "rationale": "Relative error metrics were computed for three operating points. Uncertainty propagation was applied to experimental measurements only; model-form uncertainty contribution to the comparison metric was not included. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI must be the normalized index of hemolysis (NIH) measured directly; surrogate QoIs (e.g., shear stress proxies) are not acceptable at MRL 5 for absolute threshold assessment.",
      "rationale": "NIH was used as the primary QoI for three operating points. For the two untested operating points, shear stress exposure integrals were used as surrogates. The surrogate relationship to NIH has not been validated for this pump geometry. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full COU operating envelope including rotational speeds from 2400 to 3600 RPM and flow rates from 3 to 7 L/min at MRL 5.",
      "rationale": "Validation experiments covered 2800 to 3200 RPM and 4 to 6 L/min only. The extremes of the COU envelope (2400 RPM at 3 L/min and 3600 RPM at 7 L/min) were not addressed. Significant extrapolation is required. Achieved level 2 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-6 for all equations; floating-point round-off sensitivity must be assessed at MRL 5.",
      "rationale": "Iterative convergence was monitored to 1e-4 only. No floating-point sensitivity analysis was performed. This factor was flagged as an epistemic gap at MRL 5 and not formally assessed. Achieved level 1 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented independent review of all model setup parameters, boundary conditions, and post-processing scripts must be completed by a reviewer not involved in model development at MRL 5.",
      "rationale": "No independent use-error review was performed. Model setup was reviewed internally by the same team that developed the simulation. This factor is an epistemic gap at MRL 5. Achieved level 1 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the hemolysis power-law constitutive model must be quantified via sensitivity analysis across published parameter ranges and documented as a contribution to total prediction uncertainty at MRL 5.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was used without model-form uncertainty quantification. Literature reports a factor-of-3 variation in model constants; this uncertainty was not propagated. This factor is an epistemic gap at MRL 5. Achieved level 2 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs (blood viscosity, density, hemolysis model constants, inlet velocity profile) must be characterized with probability distributions and propagated through Monte Carlo UQ at MRL 5.",
      "rationale": "Monte Carlo UQ was performed for inlet velocity profile and viscosity only. Hemolysis model constants and red blood cell fragility parameters were treated as deterministic. This factor is an epistemic gap at MRL 5. Achieved level 2 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At least three independently manufactured pump specimens must be tested to characterize unit-to-unit geometric variability; specimen-to-specimen variability must be included in the validation uncertainty budget at MRL 5.",
      "rationale": "All experiments were conducted on a single pump specimen. Unit-to-unit manufacturing variability was not characterized. This factor is an epistemic gap at MRL 5. Achieved level 1 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal equivalency analysis must demonstrate that validation experiment inlet and boundary conditions are representative of the COU operating conditions within quantified tolerances at MRL 5.",
      "rationale": "No formal equivalency analysis was performed between validation experiment conditions and COU conditions. Inlet boundary conditions in the experiments were derived from a simplified flow loop that does not replicate physiological pulsatility. This factor is an epistemic gap at MRL 5. Achieved level 1 is below required level 5."
    }
  ],
