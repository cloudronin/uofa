    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/monte-carlo-uq-runs-cou2"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-bench-hemolysis-01",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis validation against FDA pump experimental data",
      "description": "CFD hemolysis index predictions compared against published FDA generic centrifugal pump experimental measurements at five operating points. Normalized index error ranges from 18% to 47%, exceeding the required 15% tolerance at MRL 5."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-uq-monte-carlo-02",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "1000-sample Monte Carlo propagation of inlet boundary condition and rheological parameter uncertainties. 95th-percentile prediction interval width is 2.3x the experimental measurement uncertainty, indicating insufficient model precision for absolute threshold assessment."
    }
  ],
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
    "type": "Requirement",
    "name": "Absolute hemolysis threshold requirement for Class III VAD",
    "description": "The computational model shall predict the normalized index of hemolysis (NIH) to within 15% of experimentally measured values across all five operating points. Monte Carlo uncertainty quantification shall demonstrate that the 95th-percentile prediction interval does not exceed twice the experimental measurement uncertainty. This requirement governs MRL 5 acceptance for the VAD COU and is the primary credibility gate for regulatory submission.",
    "requirementSource": "ASME V&V 40-2018 Section 6, FDA Guidance on Computational Modeling for Medical Devices (2016)",
    "applicableModelRiskLevel": 5
  },
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043478",
