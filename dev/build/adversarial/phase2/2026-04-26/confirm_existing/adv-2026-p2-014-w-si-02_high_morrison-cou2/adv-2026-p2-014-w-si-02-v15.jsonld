  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cou2-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison — 5 operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements at 5 flow-speed combinations. Predicted NIH values overestimate measured values by 18–42 % across operating envelope. Requirement object https://uofa.net/synth/req/mrl5-hemolysis-acceptance-threshold specifies maximum allowable NIH prediction error of ±15 % at MRL 5; this threshold is not met at three of five operating points.",
      "referencesRequirement": "https://uofa.net/synth/req/mrl5-hemolysis-acceptance-threshold"
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-uq-coverage-check",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ coverage verification",
      "description": "Monte Carlo propagation of inlet flow uncertainty (±5 %) and rotational speed uncertainty (±2 %) performed across 1000 samples. 90th-percentile prediction interval does not fully bracket experimental scatter at high-shear operating points, indicating unresolved model-form uncertainty in the hemolysis constitutive relation."
    }
  ],
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/mrl5-hemolysis-acceptance-threshold",
    "type": "Requirement",
    "name": "MRL-5 hemolysis NIH prediction error threshold",
    "description": "Per ASME V&V 40-2018 and FDA guidance for Class III VAD devices at Model Risk Level 5, CFD predictions of normalized index of hemolysis (NIH) must fall within ±15 % of experimental reference values across all assessed operating conditions. Absolute hemolysis must remain below the clinical intervention threshold of 0.05 g/100 L. This requirement governs acceptance of the computational model for regulatory submission in lieu of additional bench testing.",
    "source": "ASME V&V 40-2018 Section 6; FDA Guidance on Computational Modeling of Medical Devices (2023)"
  },
