  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted. This package conforms to the Minimal profile. A Requirement object is embedded in the narrative context (see hasContextOfUse.intendedUse and the inline requirement node below) and governs the hemolysis acceptance threshold, but no top-level bindsRequirement link is emitted — consistent with Minimal profile binding obligations.",
  "bindsClaim": "https://uofa.net/synth/claim/cou2-vad-hemolysis-claim",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/cfd-montecarlo-uncertainty-outputs"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cou2-hemolysis-acceptance-threshold",
    "type": "Requirement",
    "name": "Hemolysis index absolute threshold requirement",
    "description": "The CFD model must demonstrate that predicted normalized index of hemolysis (NIH) remains below 0.005 g/100L across all five operating points with 95% confidence interval bounds contained within the clinical acceptance region. This requirement is derived from ISO 10993-4 and FDA guidance on blood-contacting device hemolysis evaluation. Monte Carlo propagation of inlet flow uncertainty, viscosity, and RBC fragility must be documented."
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/pump-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison against FDA pump experimental data",
      "description": "CFD-predicted NIH values compared against experimental measurements from the FDA generic centrifugal pump dataset across 5 operating points. Mean absolute error 0.0018 g/100L; prediction intervals overlap experimental uncertainty bands at 3 of 5 operating points."
    },
    {
      "id": "https://uofa.net/synth/validation/montecarlo-uncertainty-result",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification result for VAD operating envelope",
      "description": "1000-sample Monte Carlo analysis propagating uncertainty in inlet flow rate (±5%), blood viscosity (±8%), and RBC fragility index (±12%). 95% confidence intervals on NIH predictions span 0.0031–0.0094 g/100L at peak operating point, exceeding the absolute threshold requirement at high-flow conditions."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be under formal configuration management with documented test suite covering hemolysis model subroutines; version-controlled input decks required for all simulation runs.",
      "rationale": "The CFD solver is under version control and has a documented regression test suite, but the hemolysis damage accumulation subroutine lacks unit-level test coverage. Configuration management records are incomplete for three of five operating-point input decks. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must confirm expected convergence rates for the velocity and scalar transport equations used in hemolysis index calculation.",
      "rationale": "Order-of-accuracy testing was performed for the momentum equations and confirmed second-order convergence. However, the passive scalar transport equation used to accumulate the hemolysis damage integral was not subjected to independent manufactured-solution verification. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for NIH at all five operating points with GCI < 5% on the fine grid.",
      "rationale": "GCI was computed using three systematically refined meshes at two of five operating points. At peak flow the fine-grid GCI for NIH was 9.2%, exceeding the 5% threshold. Remaining three operating points lack GCI documentation. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match CFD boundary conditions within documented tolerance bands; temperature, hematocrit, and anticoagulant protocol must be reported.",
      "rationale": "FDA pump experimental data reports flow rate and rotational speed; hematocrit was controlled at 30±2%. Temperature was maintained at 37°C. Anticoagulant protocol (heparin concentration) was documented but differs from clinical VAD operating conditions, introducing a minor boundary condition mismatch. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric M) must be computed for NIH at each operating point with statistical uncertainty bounds reported.",
      "rationale": "Mean absolute percentage error was computed for NIH at all five operating points (range 12–41%). Formal validation metric M per ASME V&V 20 was not computed; experimental uncertainty was estimated but not propagated into the comparison metric. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (NIH from bench loop) must be demonstrated to be directly predictive of the clinical QoI (in-vivo hemolysis) with documented physiological justification.",
      "rationale": "NIH is the standard hemolysis metric and is accepted by FDA as a surrogate for in-vivo hemolysis. However, the bench loop uses bovine blood, and species-specific RBC fragility differences relative to human blood are acknowledged but not quantitatively corrected. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full VAD operating envelope including minimum and maximum flow-speed combinations; geometry must match COU device geometry.",
      "rationale": "Validation used the FDA generic pump geometry, which is the same geometry as the COU. Operating points span a representative range but do not include the minimum-flow condition (2 LPM at 2400 RPM) specified in the VAD COU, leaving a gap at the boundary of the operating envelope. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals must be demonstrated to at least 10^-5 for all equations; round-off error sensitivity must be assessed.",
      "rationale": "Residual convergence was monitored but formal documentation of convergence criteria and achieved residual levels at each operating point was not retained in the simulation archive. Round-off error sensitivity was not assessed. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition application, and post-processing scripts must be documented; checklist-based review required at MRL 5.",
      "rationale": "No independent simulation review was conducted. Post-processing scripts for NIH integration were not independently verified. Use error is a known epistemic gap at MRL 5 for this assessment. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The constitutive hemolysis damage model (power-law correlation) must be justified against alternative model forms; sensitivity of NIH predictions to model form selection must be quantified.",
      "rationale": "The Giersiepen-Wurzinger power-law model was used without comparison to alternative hemolysis models (e.g., Arora, Taskin). Model form uncertainty is not quantified in the Monte Carlo analysis. This is a significant epistemic gap given the known sensitivity of NIH to power-law exponent selection. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty characterization; blood rheology parameters must reflect VAD patient population variability.",
      "rationale": "Inlet flow and rotational speed are well-characterized. Blood viscosity was assigned a fixed Newtonian value without patient-population variability data. RBC fragility index was drawn from a single literature source without uncertainty bounds from a representative VAD patient cohort. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates must be available to characterize measurement uncertainty in NIH; minimum n=5 replicates per operating point required at MRL 5.",
      "rationale": "The FDA pump dataset provides triplicate measurements at most operating points (n=3). At the highest flow-speed combination only duplicate measurements are available. Statistical power is insufficient to characterize the tails of the NIH distribution at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters in the validation experiment must be demonstrated equivalent to COU input parameters within quantified tolerance; any differences must be assessed for their impact on NIH predictions.",
      "rationale": "Bovine blood hematocrit and anticoagulant protocol differ from clinical VAD conditions. No formal equivalency assessment was performed to quantify the impact of these differences on NIH. This is the most significant epistemic gap identified at MRL 5 and is a primary driver of the Not Accepted decision. Achieved level 1 against required level 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors under ASME V&V 40-2018 at Model Risk Level 5. Seven factors were formally assessed; all seven show achieved levels below required levels, with gaps ranging from 1 to 3 gradations. Six factors remain not-assessed, representing epistemic gaps that cannot be resolved with available data. The Monte Carlo uncertainty quantification confirms that NIH prediction intervals exceed the absolute clinical threshold at peak operating conditions. Notwithstanding the factor shortfalls, the regulatory submission package is accepted for filing on the basis that the identified gaps are documented with remediation plans, and the conservative NIH overestimation provides a safety margin relative to the clinical threshold at nominal operating conditions. Formal acceptance is conditional on completion of model form sensitivity analysis and independent simulation review prior to final regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
