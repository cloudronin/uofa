  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed. A Requirement object capturing the absolute hemolysis threshold constraint is embedded in the evidence package and referenced within the validation narrative, but the top-level bindsRequirement link is intentionally absent, constituting the W-SI-02 structural gap. Full 13-factor assessment performed under Minimal profile conformance.",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-hemolysis-claim",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/morrison-monte-carlo-uncertainty-runs"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-bench-hemolysis-exp",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis experimental comparison — 5 flow-speed operating points",
      "description": "CFD-predicted normalized index of hemolysis compared against in vitro measurements at 5 operating conditions. Achieved agreement within 18% at 3 of 5 points; remaining 2 points exceed 30% deviation. Validation activity conducted at model risk level 5 with Monte Carlo propagation of rheological parameter uncertainty."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification",
      "description": "Three-level mesh refinement study performed on the FDA generic centrifugal pump geometry. Grid convergence index computed for shear stress and velocity fields. Discretization error estimated at 4.2% for primary QoI (NIH) at the finest mesh level."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-uncertainty-quantification",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "500-sample Monte Carlo analysis propagating uncertainty in blood viscosity, power-law exponent, and inlet velocity profile. 95th-percentile NIH prediction remains below clinical threshold at 3 of 5 operating conditions. Requirements traceability to the absolute hemolysis threshold is documented in the evidence narrative but the formal bindsRequirement link to requirement object https://uofa.net/synth/req/morrison-cou2-hemolysis-threshold is not present at the UnitOfAssurance level."
    }
  ],
