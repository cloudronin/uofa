  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted. Regulatory requirement REQ-VAD-HEM-001 mandates absolute hemolysis index below clinical threshold across all five flow-speed operating points; this requirement is described narratively herein and is represented by the inline requirement object https://uofa.net/synth/req/vad-hem-001 embedded within the validation results, but no top-level bindsRequirement link is established in this package.",
  "couName": "VAD use",
  "assuranceLevel": "Low",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsClaim": "https://uofa.net/synth/claim/cou2-vad-hemolysis-claim",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/cfd-montecarlo-hemolysis-results"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-bench-flow-validation",
      "type": "ValidationResult",
      "name": "Bench-level flow field validation against PIV measurements",
      "description": "Particle image velocimetry measurements in the FDA generic pump were compared against CFD velocity fields at three operating points. RMS velocity error within 12% at all measurement planes. Requirement object for hemolysis threshold compliance: id=https://uofa.net/synth/req/vad-hem-001, label=REQ-VAD-HEM-001, text='Predicted hemolysis index shall not exceed 0.08% across all five COU operating points at 95th percentile of Monte Carlo distribution.'",
      "validationActivity": "Experimental bench testing with PIV",
      "comparisonMetric": "RMS velocity error",
      "comparisonValue": 0.12,
      "passFailStatus": "conditional-pass"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-index-validation",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction vs. in-vitro hemolysis measurements",
      "description": "Computational hemolysis index predictions compared to in-vitro measurements across five flow-speed combinations. Mean absolute error 18%; predictions systematically underestimate hemolysis at high shear operating points. Monte Carlo UQ performed with 500 samples; 95th-percentile bounds reported. Achieved credibility insufficient for MRL 5 acceptance without additional validation activities.",
      "validationActivity": "In-vitro hemolysis measurement comparison",
      "comparisonMetric": "Mean absolute error on hemolysis index",
      "comparisonValue": 0.18,
      "passFailStatus": "not-passed"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification",
      "description": "Three-level mesh refinement study performed: coarse (2.1M cells), medium (6.8M cells), fine (18.4M cells). Richardson extrapolation applied; discretization error estimated at 9.3% for hemolysis index QOI. GCI safety factor 1.25 applied. Achieved level 2 against required level 4 for MRL 5.",
      "validationActivity": "Systematic mesh refinement study",
      "comparisonMetric": "Grid convergence index",
      "comparisonValue": 0.093,
      "passFailStatus": "not-passed"
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
