      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error must be quantified and demonstrated negligible relative to discretization error for all operating points.",
      "rationale": "Iterative convergence monitored by residual drop only; no formal quantification of iterative solver error relative to discretization error performed. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
