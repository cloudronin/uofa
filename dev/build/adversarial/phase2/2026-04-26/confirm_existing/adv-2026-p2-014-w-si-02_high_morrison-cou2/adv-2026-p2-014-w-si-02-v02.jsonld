  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis, MRL 5) is formally accepted as a complete submission under the Minimal profile. All 13 ASME V&V 40 credibility factors have been evaluated or flagged. Seven factors were assessed with achieved levels below required levels; six factors remain unassessed and constitute documented epistemic gaps. The governing requirement — that absolute hemolysis index predictions must remain below the clinical threshold across all 5 operating points — is described in the COU intendedUse and is the basis for all credibility factor required levels. Monte Carlo UQ was performed on a subset of uncertain inputs. The assessment team acknowledges that no factor achieved its required credibility level; this package is accepted as a complete record of the current credibility state, not as evidence of model adequacy. Further work is required before the model may be used for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
