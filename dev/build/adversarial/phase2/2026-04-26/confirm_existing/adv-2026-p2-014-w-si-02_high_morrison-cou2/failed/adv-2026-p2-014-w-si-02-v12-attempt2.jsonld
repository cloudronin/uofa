  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cou2-vr-01",
      "type": "ValidationResult",
      "name": "CFD hemolysis benchmark comparison against FDA pump experimental data",
      "description": "CFD-predicted hemolysis index values compared against published experimental measurements for the FDA generic centrifugal blood pump at 5 operating points. Normalized index of agreement computed; all operating points show CFD overprediction by 18–42%. Validation activity conducted at lower model risk level than COU2 demands."
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-vr-02",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "Monte Carlo sampling (n=500) applied to inlet boundary conditions and blood viscosity parameters. 95th-percentile prediction interval spans 1.8x the nominal hemolysis index. Interval does not satisfy the absolute clinical threshold requirement at the required credibility level."
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-vr-03",
      "type": "ValidationResult",
      "name": "Mesh convergence study for pump impeller region",
      "description": "Three-level mesh refinement study performed on impeller passage. GCI-based discretization error estimated at 6.3% for hemolysis index QoI. Required level for MRL 5 demands GCI below 2%; achieved level does not satisfy requirement."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a documented QA plan with traceability to ASME V&V 10 guidelines; version control, regression testing, and independent review required at MRL 5.",
      "rationale": "CFD solver is commercial with vendor QA documentation available. Internal QA plan exists but lacks independent third-party review and full regression test suite coverage for hemolysis-specific solver extensions. Achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using method of manufactured solutions (MMS) or equivalent for all governing equations including hemolysis transport model. Formal convergence rates must match theoretical order.",
      "rationale": "MMS verification performed for Navier-Stokes solver only. Hemolysis transport scalar equation has not been subjected to formal order-of-accuracy testing. Achieved level 2 is substantially below required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based or Richardson extrapolation discretization error estimate below 2% for hemolysis QoI across all operating points. Spatial and temporal discretization error must both be characterized.",
      "rationale": "Three-level spatial mesh refinement study completed; GCI estimated at 6.3%. Temporal discretization error assessed only at one operating point. Combined error estimate exceeds the 2% threshold. Achieved level 3 does not meet required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate COU operating envelope within documented uncertainty bounds. Blood analog fluid properties, pump speed, and flow rate must match COU specifications within 5%.",
      "rationale": "FDA pump experimental data used glycerol-water blood analog. Viscosity matched within 8% of physiological blood at 37°C. Flow rate and speed conditions match 4 of 5 COU operating points; one high-speed point not covered in experimental dataset. Achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or NRMSE) for hemolysis index QoI must be below 10% across all validation operating points with uncertainty bounds accounted for.",
      "rationale": "CFD overpredicts hemolysis index by 18–42% across operating points. Normalized RMSE is 28%. Experimental uncertainty partially overlaps predictions at low-flow conditions only. Quantitative comparison metric far exceeds acceptance threshold. Achieved level 2 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (hemolysis index) must be directly mapped to the clinical endpoint of concern. Mapping must be documented with physiological justification.",
      "rationale": "Hemolysis index (normalized index of hemolysis, NIH) is the accepted clinical surrogate for red blood cell damage in VAD devices. Mapping to plasma-free hemoglobin threshold is documented. Achieved level 3 meets required level 3 for this factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating conditions, and fluid properties must collectively represent the COU scenario with documented similarity arguments. Validation must be conducted at or above the COU model risk level.",
      "rationale": "Validation performed on FDA generic pump geometry which differs from the specific VAD device geometry in impeller blade count and volute design. Similarity argument is qualitative only. Validation was conducted at MRL 3 conditions; COU requires MRL 5 rigor. Achieved level 2 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off effects on hemolysis QoI must be quantified. Residuals must reach machine-precision tolerance or error contribution must be shown negligible relative to discretization error.",
      "rationale": "Iterative solver convergence monitored by residual drop of 4 orders of magnitude; however, no formal assessment of iterative error contribution to hemolysis QoI has been performed. Round-off analysis entirely absent. Factor flagged as not-assessed epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review process to identify and mitigate analyst use errors in model setup, boundary condition specification, and post-processing. Independent re-execution or peer review of simulation setup required at MRL 5.",
      "rationale": "No independent peer review of simulation setup was conducted. Boundary conditions and material property assignments were set by a single analyst without documented cross-check. Use error factor not assessed; flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of hemolysis power-law model form (Giersiepen-Wurzinger or equivalent) including sensitivity to model form assumptions. Alternative model forms must be evaluated or formally scoped out with justification.",
      "rationale": "Giersiepen-Wurzinger power-law hemolysis model selected without documented comparison to alternative formulations (e.g., Zhang, Taskin). No model form sensitivity analysis performed. At MRL 5, required level is 5; factor is not assessed and represents the most significant epistemic gap in this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model inputs (fluid properties, boundary conditions, hemolysis model constants) must have documented uncertainty characterization traceable to measurement data or literature with stated confidence intervals.",
      "rationale": "Monte Carlo UQ performed on inlet boundary conditions and viscosity. Hemolysis model empirical constants (C, alpha, beta in power-law) treated as fixed nominal values without uncertainty characterization despite known inter-study variability of up to 40%. Input uncertainty assessment incomplete; factor not-assessed for the model constant component."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental test samples (blood or analog fluid) must be characterized for relevant properties with statistical sample size justification. Biological variability in blood rheology must be addressed.",
      "rationale": "FDA pump experimental dataset uses glycerol-water analog; no biological blood samples tested. Sample size for experimental replicates is n=3 per operating point, below the n=5 minimum recommended at MRL 5. Biological variability in hemolysis susceptibility not characterized. Factor not-assessed."
    },
