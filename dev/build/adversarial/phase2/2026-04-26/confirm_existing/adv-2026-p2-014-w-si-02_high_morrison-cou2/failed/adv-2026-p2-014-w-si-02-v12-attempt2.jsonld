  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite the overall COU decision being Not Accepted at the assessment level, the credibility evidence package itself is accepted as a complete and valid submission of the V&V 40 assessment documentation. The package accurately characterizes all 13 credibility factors, documents 6 epistemic gaps at MRL 5, and provides Monte Carlo UQ results. The package is accepted for regulatory submission as a complete negative finding — i.e., it transparently demonstrates that the model does not yet meet the required credibility levels for Class III VAD hemolysis prediction and identifies the specific gaps requiring remediation before resubmission.",
