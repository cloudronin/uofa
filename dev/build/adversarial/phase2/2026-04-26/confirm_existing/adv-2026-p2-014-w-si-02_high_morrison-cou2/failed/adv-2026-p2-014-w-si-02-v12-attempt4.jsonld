      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal justification for the choice of hemolysis damage accumulation model (e.g., power-law Giersiepen-Wurzinger) including sensitivity to model form alternatives.",
      "rationale": "Power-law hemolysis model selected without comparison to alternative formulations (e.g., strain-based models). Model form uncertainty not quantified. Critical epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
