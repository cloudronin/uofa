  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The UnitOfAssurance package is accepted for submission as a complete credibility evidence record under the Minimal profile. All 13 ASME V&V 40 credibility factors have been evaluated or flagged as epistemic gaps consistent with Model Risk Level 5. Seven factors were formally assessed; six were identified as not-assessed due to data unavailability. The overall credibility assessment concludes that achieved levels fall below required levels across all assessed factors, and the simulation results are therefore not accepted as sufficient standalone evidence for regulatory submission without additional validation activities. The package is accepted as a complete and transparent record of the current credibility state.",
