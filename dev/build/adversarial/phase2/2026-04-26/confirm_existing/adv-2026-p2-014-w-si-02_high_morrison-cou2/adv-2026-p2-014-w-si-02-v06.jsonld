  "synthetic": true,
  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted. This package conforms to the Minimal profile; the inline Requirement node (https://uofa.net/synth/req/cou2-hemolysis-threshold) documents the absolute hemolysis acceptance requirement but the top-level bindsRequirement link is intentionally absent per W-SI-02 test conditions.",
  "couName": "VAD use",
  "assuranceLevel": "Low",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsClaim": "https://uofa.net/synth/claim/cou2-hemolysis-cfd-acceptable",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/cfd-monte-carlo-uncertainty-runs"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cou2-hemolysis-threshold",
    "type": "Requirement",
    "name": "Absolute hemolysis index acceptance criterion",
    "description": "The CFD model must predict a normalized index of hemolysis (NIH) below 0.005 g/100 L across all five flow-speed operating points. This threshold is derived from clinical evidence for chronic hemolysis in Class III VAD patients and constitutes the primary quantitative acceptance criterion for COU2. Monte Carlo uncertainty bounds must remain fully below this threshold at the 97.5th percentile.",
    "requirementSource": "FDA Guidance on Computational Fluid Dynamics for Heart Valves and Blood Pumps, 2022; Morrison et al. ASME V&V 40 Case Study"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-cou2-bench-hemolysis",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis validation against FDA pump experimental data",
      "description": "CFD predictions of NIH compared against published FDA centrifugal pump experimental measurements at 2500 rpm and 5 L/min. Relative error 18.4%; model over-predicts hemolysis. Validation uncertainty interval does not fully bracket experimental data at two operating points.",
      "validationStatus": "not-assessed"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-cou2-monte-carlo",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis index predictions",
      "description": "500-sample Monte Carlo propagation of inlet velocity, viscosity, and RBC fragility parameter uncertainties through the CFD hemolysis model. 97.5th percentile NIH exceeds the 0.005 g/100 L threshold at two of five operating points, indicating insufficient margin for Class III acceptance.",
      "validationStatus": "assessed"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-cou2-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study for centrifugal pump impeller region",
      "description": "Three-level mesh refinement study (2.1M, 6.4M, 14.7M cells) performed on the impeller passage. Richardson extrapolation yields GCI of 4.2% on NIH — above the Gradation 3 threshold of 2% required at MRL 5.",
      "validationStatus": "assessed"
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software QA must meet Gradation 4 at MRL 5: full version control, automated regression testing, traceable build environment, and formal code review records for all hemolysis sub-models.",
      "rationale": "Version control and regression testing are in place, but formal code review records for the power-law hemolysis damage model are incomplete and the build environment is not fully documented. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at Gradation 4 requires method of manufactured solutions (MMS) applied to the hemolysis transport equation and documented convergence order confirmation.",
      "rationale": "MMS has been applied only to the Navier-Stokes solver; the hemolysis scalar transport equation has not been subjected to MMS verification. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified via Richardson extrapolation with GCI below 2% on NIH at all operating points.",
      "rationale": "Richardson extrapolation performed; GCI of 4.2% on NIH at peak operating condition exceeds the 2% threshold. Temporal discretization error not separately quantified for transient impeller passage. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate VAD operating envelope including hematocrit range, temperature, and anticoagulation state representative of the intended patient population.",
      "rationale": "Experimental data used for validation was collected at a fixed hematocrit of 33% in a saline-RBC suspension; clinical VAD patients exhibit hematocrit variability of 25–45%. Temperature and anticoagulation effects on RBC fragility were not reproduced in bench testing. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison at Gradation 5 requires systematic quantitative comparison with experimental uncertainty bounds and statistical agreement metrics across all operating points.",
      "rationale": "Quantitative comparison performed at 5 operating points; relative error ranges from 8% to 22%. Experimental uncertainty bounds are available but model predictions fall outside those bounds at two points. No formal statistical hypothesis test applied. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled quantity of interest (NIH) must directly map to the clinical endpoint used in the regulatory decision without intermediate transformation.",
      "rationale": "NIH is the direct regulatory metric and the model output maps to it without transformation. However, the hemolysis damage model integrates shear stress history along pathlines, introducing a pathway-dependent intermediate that is not directly observable. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on a geometry and flow regime representative of the VAD COU, not a simplified surrogate.",
      "rationale": "Validation was conducted on the FDA generic centrifugal pump, which is a recognized benchmark but differs in impeller geometry and volute design from clinical VAD devices. Operating conditions partially overlap the VAD envelope but do not cover the full range. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver error must be assessed via iterative convergence monitoring and residual analysis for both flow and hemolysis scalar fields across all operating points.",
      "rationale": "Iterative convergence was monitored for flow residuals only. Hemolysis scalar transport residuals were not tracked independently. No assessment of floating-point round-off or solver tolerance sensitivity was performed. Flagged as epistemic gap at MRL 5; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use error assessment at Gradation 4 requires documented operator qualification, simulation execution checklists, and independent re-run verification by a second analyst.",
      "rationale": "No independent re-run verification was performed. Operator qualification records exist for the flow solver but not for the hemolysis post-processing scripts. Use error is flagged as an unassessed epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty must be assessed by comparing predictions from at least two physically distinct hemolysis damage models (e.g., power-law vs. strain-based) across the full operating envelope.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model was used. No alternative model form comparison was conducted. Model form uncertainty is a dominant source of epistemic uncertainty at MRL 5 and remains unassessed. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must be traceable to measured patient-population data or published material characterization studies, with uncertainty bounds propagated through the simulation.",
      "rationale": "Monte Carlo propagation was performed for three parameters (inlet velocity, viscosity, RBC fragility exponent). Six additional model inputs (impeller gap clearance, surface roughness, inlet turbulence intensity, RBC concentration, temperature, anticoagulant effect on viscosity) were held fixed at nominal values without uncertainty characterization. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test samples (RBC suspensions) used in validation experiments must be characterized for age, storage conditions, and donor variability, with sensitivity of hemolysis results to sample variability documented.",
      "rationale": "The FDA pump experimental dataset does not include RBC sample characterization data. Donor variability, storage age, and pre-shear history of RBC suspensions are unknown. This represents a significant unassessed uncertainty source at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency of input parameters between the validation experiment and the COU must be formally demonstrated, including geometric similarity, flow regime similarity, and fluid property correspondence.",
      "rationale": "No formal equivalency analysis was performed between the FDA generic pump validation case and the clinical VAD COU. Geometric differences, operating speed range differences, and fluid property differences (saline-RBC vs. whole blood with anticoagulant) have not been assessed for their impact on hemolysis prediction transferability. Achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Although seven of thirteen credibility factors have achieved levels below required levels and six factors remain unassessed at MRL 5, the assessment team has accepted the package under the Minimal profile with the understanding that the identified gaps will be addressed in a subsequent COU2 revision. The Monte Carlo uncertainty quantification provides partial coverage of input uncertainty, and the FDA generic pump benchmark provides a recognized baseline. Full acceptance is contingent on remediation of model form, use error, and test sample gaps prior to regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
