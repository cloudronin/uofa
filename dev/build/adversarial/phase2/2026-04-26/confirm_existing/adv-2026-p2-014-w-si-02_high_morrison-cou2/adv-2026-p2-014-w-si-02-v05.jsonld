  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted. This package is submitted under the Minimal conformance profile; a Requirement object describing the absolute hemolysis threshold and Monte Carlo UQ mandate is embedded within the validation narrative but no top-level bindsRequirement link is provided.",
  "couName": "VAD use",
  "assuranceLevel": "Low",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsClaim": "https://uofa.net/synth/claim/cou2-vad-hemolysis-claim",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/cou2-monte-carlo-uq-outputs"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cou2-vad-val-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison — FDA pump bench data vs CFD prediction",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against five experimental operating points from the FDA generic centrifugal pump dataset. Requirement REQ-COU2-001 mandates NIH prediction within ±20% of measured values at all five flow-speed combinations; Monte Carlo UQ bands must enclose all experimental points. Achieved coverage: 3 of 5 operating points within tolerance; UQ bands enclose 4 of 5 points. Requirement object (id: https://uofa.net/synth/req/cou2-hemolysis-threshold-req) is referenced in this narrative but is not bound at the UnitOfAssurance level."
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-vad-val-02",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification",
      "description": "Richardson extrapolation performed on three systematically refined meshes (2.1 M, 8.4 M, 33.6 M cells). Grid convergence index (GCI) for NIH at the design point is 14.2%, exceeding the MRL-5 target of ≤5%. Discretization error remains a primary gap."
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-vad-val-03",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "Latin hypercube sampling over 512 realizations of inlet velocity profile, fluid viscosity, and power-law hemolysis model coefficients. 90th-percentile NIH prediction exceeds the absolute clinical threshold at the maximum operating point, indicating unacceptable risk under current model inputs."
    }
  ],
