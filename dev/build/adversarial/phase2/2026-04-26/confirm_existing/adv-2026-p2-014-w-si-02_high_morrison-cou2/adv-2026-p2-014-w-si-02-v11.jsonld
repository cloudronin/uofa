      "type": "ValidationResult",
      "name": "Grid convergence index study for rotating impeller domain — hemolysis-weighted QoI"
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under a formal SQA plan with documented unit tests, regression suite, and change-control procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver has a documented regression test suite but lacks formal change-control procedures and traceability to requirements. Achieved level 2 falls below the required level 4 for a Class III device at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing against manufactured solutions must demonstrate expected convergence rates for the hemolysis transport equations used in the VAD model.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver but not for the power-law hemolysis damage accumulation sub-model. Partial verification yields achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on three systematically refined meshes must bound discretization error to within 5% of the hemolysis index QoI at all five operating points.",
      "rationale": "GCI analysis was completed on three mesh levels; however, the finest mesh remains computationally intractable for the highest-RPM operating point, leaving one of five conditions without a converged error bound. Achieved level 3 versus required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulated boundary conditions within documented tolerances; fluid temperature, hematocrit, and inlet flow waveform must be characterized for each operating point.",
      "rationale": "FDA pump experimental data provides flow rate and pressure rise measurements; hematocrit variability across test replicates was reported but temperature was held only nominally. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation predictions of normalized index of hemolysis (NIH) must be compared against experimental measurements with quantified uncertainty intervals; agreement metric must satisfy a predefined acceptance threshold at all five operating points.",
      "rationale": "NIH predictions were compared at three of five operating points; the remaining two points lacked experimental hemolysis measurements in the available dataset. Achieved level 2 substantially below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (hemolysis index) must be directly traceable to the clinical endpoint (chronic hemolysis threshold) with documented justification for the damage model constants.",
      "rationale": "The power-law hemolysis model QoI maps to NIH, which is clinically relevant; however, model constants were calibrated on bovine blood and their applicability to human blood at MRL 5 is not fully justified. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a pump geometry, operating envelope, and blood analog sufficiently similar to the intended VAD COU to support extrapolation of credibility evidence to the Class III device.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which is a simplified surrogate. The intended VAD geometry differs substantially in impeller blade curvature and gap clearances. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
