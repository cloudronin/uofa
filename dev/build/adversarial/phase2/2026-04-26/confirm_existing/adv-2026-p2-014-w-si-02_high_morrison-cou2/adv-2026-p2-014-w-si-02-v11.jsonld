      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented procedures must demonstrate that the simulation workflow was executed by qualified personnel following a controlled simulation plan, with independent review of boundary condition setup.",
      "rationale": "No independent review of boundary condition specification or mesh generation was performed. Use error controls were not documented. Factor not-assessed; epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Alternative hemolysis model forms (e.g., strain-based, threshold-based) must be evaluated and the selected power-law form justified against experimental data spanning the full operating envelope.",
      "rationale": "Only the power-law Giersiepen-Wurzinger model was used; no alternative model form comparison was conducted. Factor not-assessed; represents a significant epistemic gap at MRL 5 for a Class III device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model inputs (viscosity, density, hemolysis constants, turbulence model coefficients) must be characterized with probability distributions and propagated through the model via Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ was initiated but only two of seven uncertain inputs were varied; remaining inputs were held at nominal values. Full input uncertainty characterization was not completed. Factor not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for hematocrit, age, and donor variability; sample size must be sufficient to estimate population-level hemolysis statistics.",
      "rationale": "FDA pump experimental data does not include donor-level characterization of blood samples. Sample provenance and variability are undocumented. Factor not-assessed; epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The mapping between experimental boundary conditions and simulation inputs must be formally demonstrated, including dimensional analysis confirming dynamic similarity between validation and COU operating conditions.",
      "rationale": "No formal equivalency analysis was performed between FDA pump test conditions and the intended VAD operating envelope. Reynolds and Stokes number matching was not documented. Factor not-assessed."
