  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors for the VAD hemolysis CFD model under the Minimal profile. Seven factors were assessed; six remain not-assessed due to epistemic gaps at MRL 5. Although achieved levels fall below required levels across all assessed factors, the submission is accepted under the Minimal profile binding rules pending remediation commitments. The governing requirement documented at https://uofa.net/synth/req/vad-hemolysis-req-001 specifies that absolute hemolysis index must remain below the clinical threshold of 0.8 g/dL across all five operating points; this requirement is addressed in the model narrative and validation results but is not formally bound at the package level under the Minimal profile.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
