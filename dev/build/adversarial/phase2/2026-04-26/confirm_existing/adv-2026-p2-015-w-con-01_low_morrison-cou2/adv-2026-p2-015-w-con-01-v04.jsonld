      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions replicate the clinical operating envelope including fluid temperature, hematocrit, and shear exposure duration.",
      "rationale": "Bench experiments used bovine blood at 37 °C, but hematocrit range was narrower than the clinical population envelope and shear exposure duration was not independently controlled. Achieved level 2 is substantially below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) computed between predicted and measured hemolysis index across all 5 operating points, with uncertainty bounds.",
      "rationale": "Validation metric computed at 4 of 5 operating points; one high-speed condition lacked experimental data. Mean absolute error was within 15 % but without full uncertainty interval overlap at all points. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (absolute hemolysis index) is directly mapped to the clinical decision threshold without surrogate substitution.",
      "rationale": "The model predicts a normalized hemolysis index that requires a conversion factor to reach the clinical NIH threshold. The conversion introduces additional uncertainty not fully characterized. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
