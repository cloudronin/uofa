  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the available simulation evidence and experimental comparisons for the VAD hemolysis CFD model. Monte Carlo uncertainty quantification was completed and hemolysis index predictions remained below the clinical threshold across all five operating points. The team concluded that the overall body of evidence supports acceptance of the model for the intended regulatory use, noting that some supporting factors were not fully documented but judging residual uncertainty acceptable given the conservative safety margin observed in the output comparisons.",
