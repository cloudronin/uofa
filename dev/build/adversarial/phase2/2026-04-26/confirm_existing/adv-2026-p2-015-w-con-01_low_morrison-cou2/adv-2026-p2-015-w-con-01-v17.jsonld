  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the VAD context of use is accepted for regulatory submission. Monte Carlo uncertainty quantification was completed and predicted hemolysis index values fall below the clinical threshold across all evaluated operating points. The assessment team considers the overall simulation evidence sufficient to support the intended decision. Several factors were not fully assessed due to data availability constraints; the team judged that the available evidence, taken in aggregate, provides adequate confidence for the Class III device submission.",
