      "acceptanceCriteria": "Sensitivity of hemolysis predictions to turbulence model choice and hemolysis damage model constants documented via systematic model-form study.",
      "rationale": "Model form uncertainty was identified as a critical gap; turbulence model sensitivity study was planned but not executed prior to submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters; propagated through Monte Carlo UQ with documented convergence.",
      "rationale": "Monte Carlo UQ was performed on a subset of geometric tolerances only; blood rheology parameters and hemolysis model constants were held fixed, leaving input uncertainty partially uncharacterised."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample-to-sample variability in experimental hemolysis measurements quantified; minimum sample size justified by statistical power analysis.",
      "rationale": "Experimental dataset contains results from a single pump specimen; inter-specimen variability was not characterised and no power analysis was documented."
    },
