      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match CFD inlet/outlet conditions within stated uncertainty bands for all 5 operating points.",
      "rationale": "Inlet flow waveforms matched at 4 of 5 operating points; one high-speed condition lacked transient pressure data. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E_rms) computed for hemolysis index predictions versus experimental measurements with uncertainty bounds overlaid.",
      "rationale": "Qualitative agreement shown in figures; no formal quantitative agreement metric computed against experimental hemolysis measurements. Achieved level 2 is substantially below required level 4."
    },
    {
