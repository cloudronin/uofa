    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for NIH quantity of interest on the fine-to-medium mesh refinement level.",
      "rationale": "Three-level mesh refinement study conducted at the design operating point (5 L/min, 3500 RPM). Meshes of 2.1M, 5.4M, and 11.2M hexahedral cells evaluated. GCI for NIH between fine and medium meshes was 3.1%, below the 5% threshold. Medium mesh (5.4M cells) adopted for all production runs to balance accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with inlet flow rate, rotational speed, fluid temperature, and hematocrit within ±5% of CFD boundary conditions.",
      "rationale": "FDA generic pump experimental data from Hariharan et al. (2011) used for validation. Test conditions documented: flow rates 2.5–7.0 L/min, speeds 2000–3500 RPM, bovine blood at 37°C, hematocrit 30±2%. CFD boundary conditions matched to within 2% of reported experimental values. Temperature effects on viscosity accounted for via Carreau model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within 15% at all five validation operating points.",
      "rationale": "CFD-predicted NIH compared against experimental measurements at five operating points. Deviations ranged from 1.2% to 8.3%, all within the 15% acceptance band. Systematic underprediction of 4–8% observed at high-speed low-flow conditions, attributed to secondary recirculation zones not fully resolved at MRL 2 mesh density; within acceptable bounds for the intended comparative use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation (NIH) must be the same metric or a conservative surrogate for the regulatory acceptance criterion (RH < 1).",
      "rationale": "The normalized index of hemolysis (NIH) is the direct precursor to the relative hemolysis index (RH). RH is computed as the ratio of device NIH to predicate NIH; therefore validation against experimental NIH directly supports the regulatory QoI. No surrogate transformation introduces additional uncertainty beyond that already bounded by the output comparison factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating conditions must represent the COU device class and flow regime; Reynolds number and specific speed must be within 20% of COU operating range.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which shares impeller topology and specific speed range (Ns = 1800–2400) with the subject CPB device. COU operating Reynolds numbers (Re = 8000–22000) overlap validation range (Re = 7500–24000). Geometric similarity confirmed by comparison of key non-dimensional parameters. Validation activities judged adequately representative of the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
