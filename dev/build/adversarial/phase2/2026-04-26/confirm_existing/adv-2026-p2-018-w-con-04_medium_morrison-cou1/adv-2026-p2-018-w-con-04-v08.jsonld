      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined and applied; agreement within combined experimental and numerical uncertainty at MRL 2.",
      "rationale": "NIH predictions compared against experimental values using relative error metric. Mean absolute relative error 8.3% across five operating points, within combined uncertainty band of ±12%. All predictions within acceptance bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
