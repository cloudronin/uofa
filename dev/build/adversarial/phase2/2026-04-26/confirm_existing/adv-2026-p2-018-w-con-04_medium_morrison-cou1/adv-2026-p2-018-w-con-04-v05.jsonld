      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite and version-controlled release; configuration management records maintained.",
      "rationale": "ANSYS Fluent 2022 R2 used under institutional QMS. Solver release notes, regression test suite results, and configuration management records reviewed and confirmed compliant with MRL 2 requirements. No open defects affecting hemolysis-relevant physics identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases relevant to rotating machinery and viscous flow.",
      "rationale": "Solver verified against Taylor-Couette flow and lid-driven cavity benchmarks. Order-of-accuracy testing confirms second-order spatial convergence for momentum and scalar transport equations used in the hemolysis power-law model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for RHI quantity of interest must be less than 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study performed using meshes of 2.1M, 5.8M, and 14.2M cells. GCI on fine grid for RHI = 1.8%; discretization error for pressure head = 2.1%. Both within acceptance criterion. Fine mesh selected for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within stated tolerances; fluid properties and boundary conditions documented.",
      "rationale": "In-vitro experiments conducted with porcine blood at 37°C, hematocrit 35 ± 2%. Flow rates controlled to within ±0.05 L/min; rotational speed to within ±10 RPM. Conditions span the 5 COU operating points. Test protocol reviewed and confirmed consistent with COU boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RHI must agree with experimental measurements within combined experimental and numerical uncertainty at all 5 operating points.",
      "rationale": "RHI predictions compared against experimental measurements at all 5 flow-speed combinations. Maximum deviation 3.1%; all predictions within experimental uncertainty bands (±7–9% at 95% confidence). Pressure head predictions also within 5% at all points. Acceptance criterion met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs extracted from the simulation must be directly relevant to the clinical hemolysis decision; mapping between model outputs and acceptance criterion must be documented.",
      "rationale": "Primary QOI is the relative hemolysis index (RHI = predicted MIH / predicate MIH). RHI directly maps to the regulatory acceptance criterion (RH < 1). Secondary QOI of pressure head confirms hydraulic similarity. Both QOIs are clinically and regulatorily relevant to the CPB COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same or geometrically similar device, same fluid, and overlapping operating conditions as the COU.",
      "rationale": "Validation experiments performed on the same FDA generic centrifugal pump geometry as used in the COU. Fluid (porcine blood, matched hematocrit) and operating conditions (flow rates 3–6 L/min, speeds 2500–4000 RPM) directly span the COU envelope. Validation activity relevance rated high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor beyond code verification already addressed.",
      "rationale": "At MRL 2, separate numerical solver error quantification beyond code verification is not required. Iterative convergence monitored via residual reduction to 1e-6 and QOI stabilisation; no solver errors identified. Factor scoped to not-assessed per MRL 2 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; standard operating procedures and analyst qualification records are maintained.",
      "rationale": "Use error formal assessment not required at MRL 2. Simulation analysts hold relevant CFD qualifications; simulation setup reviewed by independent analyst per institutional SOP. No use errors identified during independent review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection (turbulence model, hemolysis power-law coefficients) must be justified based on published literature or prior validation for blood pump applications.",
      "rationale": "SST k-omega turbulence model selected based on published validation studies for centrifugal blood pump hemolysis (Ozturk et al. 2015; Wu et al. 2011). Hemolysis power-law model coefficients from Giersiepen et al. calibrated against porcine blood data. Model form uncertainty acknowledged and bounded by validation comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, boundary conditions, material properties) must be traceable to measurement data or published references with documented uncertainty.",
      "rationale": "Pump geometry derived from FDA-released CAD files (version 3.1). Blood viscosity modelled using Carreau-Yasuda fit to measured rheology data (hematocrit 35%). Inlet velocity profiles derived from Doppler measurements. All inputs documented in simulation input record with traceability to source data."
    },
