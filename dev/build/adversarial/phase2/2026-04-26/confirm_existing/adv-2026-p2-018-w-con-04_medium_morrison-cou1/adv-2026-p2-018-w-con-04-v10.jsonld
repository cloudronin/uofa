  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/morrison-biofluid-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required levels for Model Risk Level 2. Six factors are formally not-assessed at MRL 2 in accordance with ASME V&V 40 Table 4, with documented rationale confirming acceptability. Validation evidence demonstrates CFD model predicts relative hemolysis index within ±15% of bench measurements across all 5 COU operating points, satisfying the RH < 1 acceptance criterion. A screening sensitivity exercise conducted during model development confirmed impeller tip clearance and rotational speed as dominant parameters; this finding supported the selection of conservative nominal values in the production simulations. The totality of evidence supports use of the CFD model for identifying worst-case hemolysis operating conditions for the Class II CPB device. Credibility assessment team accepts the model for the stated COU.",
