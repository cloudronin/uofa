  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2025",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped as not-assessed at MRL 2 with documented justification. Validation evidence demonstrates RH index predictions within the 20% acceptance band across all five COU-relevant operating points. A screening sensitivity study documented in TM-2024-07 confirmed low parametric sensitivity of RH to inlet turbulence intensity and viscosity model parameters, providing additional confidence in model robustness. The credibility evidence package is judged sufficient to support the regulatory decision that the CFD model can reliably identify worst-case hemolysis operating conditions for the Class II CPB device.",
