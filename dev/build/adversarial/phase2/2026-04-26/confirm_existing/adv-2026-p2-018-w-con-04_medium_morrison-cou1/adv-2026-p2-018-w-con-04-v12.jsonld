  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/computational-biofluidics-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out at MRL 2 with documented justification. Validation results demonstrate hemolysis index prediction within 8.2% of experimental benchmark across all operating points. Output comparison, QoI relevance, and validation relevance factors all satisfied. The informal screening sensitivity exercise reviewed during assessment provides additional confidence in model robustness to viscosity and boundary condition variation. The assessment team concludes that the CFD model provides sufficient credibility to support the COU decision regarding worst-case hemolysis operating conditions for the Class II CPB device.",
