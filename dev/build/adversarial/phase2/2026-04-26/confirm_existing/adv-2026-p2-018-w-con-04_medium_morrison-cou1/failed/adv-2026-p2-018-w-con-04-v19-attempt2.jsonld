  "signature": "ed25519:7c3a9f2e5b8d1c4a6f0e3b7d9a2c5f8e1b4d7a0c3f6e9b2d5a8c1f4e7b0d3a6f9",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures; version control and validation test suite demonstrated.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially distributed solver subject to the vendor's ISO 9001-certified QA program. Release notes, regression test suite results, and change logs for v2022 R2 were reviewed. Internal simulation log files confirm solver version and license hash for all production runs. QA level meets Gradation 2 requirements for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal code verification demonstrating correct numerical implementation; observed order of convergence within 10% of theoretical.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver with power-law blood viscosity model. Observed spatial order of convergence 1.97 versus theoretical 2.0 (1.5% deviation). Temporal discretization verified separately with first-order implicit scheme. Results archived in project verification report VR-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index < 5% for primary QoIs; asymptotic range confirmed.",
      "rationale": "Three-level mesh refinement study conducted at nominal operating point (5 L/min, 3500 RPM). Refinement ratio r = 1.3 between levels. GCI values: volumetric hemolysis index GCI = 1.8%, wall shear stress 99th percentile GCI = 2.1%. Asymptotic convergence ratio 1.02 confirms asymptotic range. Fine mesh (14.2M elements) selected for all production runs. Exceeds required level, providing additional confidence margin."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented and replicated in simulation to within measurement uncertainty.",
      "rationale": "In vitro test loop conditions (flow rate ±0.05 L/min, rotational speed ±10 RPM, fluid temperature 37±0.5°C, hematocrit 33±1%) documented from experimental protocol. Simulation boundary conditions set to measured mean values. Screening sensitivity evaluation confirmed that ±10% perturbations to inlet velocity profile produce less than 3% variation in predicted RH, validating the adequacy of the boundary condition specification. Porcine blood rheology parameterized from co-located viscometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined; simulation predictions within acceptance band relative to experimental reference.",
      "rationale": "Primary comparison metric is the relative hemolysis index RH = HI_device / HI_predicate where HI is the normalized index of hemolysis. Acceptance criterion RH < 1.0 at all five operating points. Predicted RH values: 0.71, 0.68, 0.74, 0.82, 0.79 versus experimental 0.65, 0.63, 0.71, 0.76, 0.72. All predictions satisfy acceptance criterion. Experimental uncertainty (95% CI) propagated from replicate measurements (n=6 per condition)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation are directly relevant to the COU decision quantity; linkage documented.",
      "rationale": "The validation QoI (relative hemolysis index RH) is identical to the regulatory acceptance metric used in the COU decision. The hemolysis power-law model (Giersiepen et al. 1990, recalibrated by Zhang et al. 2011) maps shear stress and exposure time directly to the plasma-free hemoglobin metric measured experimentally. No surrogate QoI substitution is required. Direct traceability from CFD output to regulatory criterion is established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, operating conditions, and fluid properties sufficiently similar to COU; documented similarity argument.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the same device geometry as the COU subject. Operating conditions span the clinical CPB flow range (3–7 L/min, 2500–4500 RPM) encompassing all five COU operating points. Porcine blood used as surrogate for human blood; viscosity equivalence documented via comparative rheometry. Geometric similarity: validation pump is production-representative with tolerances within ±0.05 mm of COU device nominal dimensions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor beyond code verification evidence already provided.",
      "rationale": "At Model Risk Level 2, explicit numerical solver error assessment beyond code verification is not required per ASME V&V 40 Table 5. Code verification (see Numerical code verification factor) provides sufficient evidence that solver implementation is correct. Iterative convergence monitored via residual drop > 4 orders of magnitude and mass imbalance < 0.01% for all runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation execution reviewed by independent analyst.",
      "rationale": "Formal use error assessment not required at MRL 2. However, simulation setup files were independently reviewed by a second CFD analyst who confirmed boundary condition assignments, turbulence model selection (SST k-omega), and post-processing scripts. No discrepancies identified. Review documented in internal checklist UC-2024-07."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection documented with literature justification.",
      "rationale": "Formal model form uncertainty quantification not required at MRL 2. Model form selection (incompressible RANS with SST k-omega, power-law hemolysis accumulation, rigid-wall assumption) is consistent with published FDA-acknowledged CFD hemolysis prediction practice. Literature survey of 12 peer-reviewed publications confirms SST k-omega as the most widely validated turbulence closure for centrifugal blood pump hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs identified; nominal values traceable to measurement or literature; input uncertainty bounds documented.",
      "rationale": "Key model inputs identified: inlet flow rate, rotational speed, blood viscosity parameters (Carreau-Yasuda fit), hemolysis model coefficients (alpha, beta, C), and pump geometry. Nominal values sourced from calibrated test rig measurements (flow, speed) and published viscometry data (rheology). Hemolysis model coefficients from Zhang et al. 2011 recalibration. Screening sensitivity study showed hemolysis model coefficient beta (exponent on shear stress) contributes 68% of output variance across the five operating points, confirming it as the dominant input uncertainty driver. This finding was used to focus validation evidence on shear stress field accuracy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 beyond documentation of experimental sample provenance.",
      "rationale": "Formal test sample characterization not required at MRL 2. Experimental data sourced from Morrison et al. (2019) in vitro study using porcine blood (hematocrit 33±1%, n=6 replicates per condition). Sample provenance, storage conditions, and handling protocol documented in the referenced publication. Pump specimens were production-representative units with dimensional inspection reports confirming compliance with nominal geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; documented argument that validation inputs are representative of COU inputs.",
      "rationale": "Formal equivalency analysis not required at MRL 2. Documented similarity argument: validation operating conditions (3–7 L/min, 2500–4500 RPM) encompass all COU operating points. Fluid properties (porcine blood as surrogate) justified by viscosity equivalence at 37°C. Geometric equivalency confirmed by dimensional inspection. No extrapolation beyond validated operating envelope required for COU predictions."
    }
  ],
