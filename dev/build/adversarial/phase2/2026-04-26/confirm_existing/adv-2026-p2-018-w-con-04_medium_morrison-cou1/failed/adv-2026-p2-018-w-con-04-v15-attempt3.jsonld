  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump has been assessed against all 13 ASME V&V 40 credibility factors at MRL 2. Seven factors were formally assessed, with all achieving or exceeding required levels. Six factors were appropriately scoped out at MRL 2 based on the use of a validated commercial solver, qualified analysts, and documented input parameters. Validation results demonstrate RH predictions within 20% of experimental measurements across the full CPB operating envelope, with all predicted RH values satisfying the regulatory acceptance criterion (RH < 1.0). A screening sensitivity study confirmed low parametric sensitivity of the hemolysis index to key input uncertainties. The model is accepted as credible for the stated COU: identifying worst-case hemolysis operating conditions for a Class II CPB device at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
