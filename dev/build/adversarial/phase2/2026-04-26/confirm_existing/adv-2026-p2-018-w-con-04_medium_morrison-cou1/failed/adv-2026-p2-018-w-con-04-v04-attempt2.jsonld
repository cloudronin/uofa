  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/cardiovascular-cfd-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out per ASME V&V 40 MRL 2 assessment matrix. CFD model demonstrates sufficient credibility to support the regulatory decision that the Class II CPB device does not produce greater hemolysis than the predicate device (RH < 1.0 at all evaluated operating conditions). A screening sensitivity exercise across the five flow-speed operating points confirmed that the worst-case condition is captured within the evaluated envelope. The credibility assessment team accepts this package as meeting the evidentiary requirements for the 510(k) submission.",
