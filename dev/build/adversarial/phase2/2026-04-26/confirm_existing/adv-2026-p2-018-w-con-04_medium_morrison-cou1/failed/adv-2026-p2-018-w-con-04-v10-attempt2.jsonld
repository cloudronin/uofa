      "acceptanceCriteria": "CFD solver must be under version control with documented test suite and release notes.",
      "rationale": "ANSYS Fluent 2022 R1 is a commercially validated solver with documented QA procedures, version-controlled releases, and a published verification test suite. Configuration files and solver settings are stored in the project repository under revision control."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
