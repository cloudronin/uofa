  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-osel-dbsb",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. Six factors are appropriately scoped out at MRL 2 with adequate qualitative justification. Three independent validation activities (PIV velocity comparison, hemolysis index bench-test comparison, mesh convergence study) collectively demonstrate sufficient model credibility for the intended use of identifying worst-case hemolysis operating conditions. The relative hemolysis index criterion (RH < 1) is met at all five COU operating points. The assessment team concludes that the CFD model provides adequate credibility evidence to support the regulatory submission decision for the Class II CPB device.",
