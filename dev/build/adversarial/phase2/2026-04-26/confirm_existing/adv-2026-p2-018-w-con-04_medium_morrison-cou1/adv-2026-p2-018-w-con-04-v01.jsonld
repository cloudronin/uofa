      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (NIH, RH index) must be directly linked to the clinical endpoint (hemolysis) and must be computable from the CFD output without additional unvalidated transformations.",
