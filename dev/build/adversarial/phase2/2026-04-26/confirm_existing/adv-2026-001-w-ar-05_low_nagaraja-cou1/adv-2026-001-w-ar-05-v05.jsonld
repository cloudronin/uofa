  ],
  "hasContextOfUse": {
    "decisionConsequence": "Medium",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "deviceClass": "Class II",
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-01-no-comparator",
      "type": "ValidationResult",
      "name": "FEA vs. experimental QoI comparison — primary result (comparator link absent)",
      "description": "FEA-predicted construct stiffness, yield force, and force at 40 mm displacement were compared against N=11 physical test constructs (Lab 1 n=6, Lab 2 n=5) under ASTM F1717 quasi-static compression-bending. All three QoIs satisfy the pre-established acceptance criterion: percentage difference below 10% and normalised validation metric E/uval below 1.96. Stiffness: mean FEA 312 N/mm vs. experimental 308 N/mm (1.3% difference, E/uval=0.41). Yield force: mean FEA 487 N vs. experimental 479 N (1.7% difference, E/uval=0.63). Force at 40 mm: mean FEA 621 N vs. experimental 609 N (2.0% difference, E/uval=0.77). The experimental dataset against which these predictions were compared is referenced in the narrative above, but no machine-readable comparedAgainst link has been recorded for this result."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-02-mismatched-comparator",
      "type": "ValidationResult",
      "name": "FEA vs. cyclic fatigue dataset — supplementary comparator (condition mismatch)",
      "description": "As a supplementary validation activity, FEA-predicted stiffness values were also compared against a historical cyclic compression-bending fatigue dataset (ASTM F1717 dynamic protocol, R=0.1, 5 Hz, N=10 constructs) obtained from a prior regulatory submission. The team notes that this comparator dataset was generated under dynamic cyclic loading rather than the quasi-static monotonic loading regime specified in the COU. Peak-cycle stiffness extracted from the fatigue records (mean 298 N/mm) was used as a proxy for quasi-static stiffness; the 4.7% difference relative to FEA was interpreted as additional corroborating evidence. This inference is an undercutting defeater: stiffness measured under cyclic fatigue conditions reflects viscoelastic and frictional dissipation effects absent in quasi-static loading, making the comparator structurally inappropriate for the declared COU regardless of the numerical agreement observed.",
      "comparedAgainst": "https://uofa.net/synth/data/historical-cyclic-fatigue-n10-dynamic"
    }
  ],
