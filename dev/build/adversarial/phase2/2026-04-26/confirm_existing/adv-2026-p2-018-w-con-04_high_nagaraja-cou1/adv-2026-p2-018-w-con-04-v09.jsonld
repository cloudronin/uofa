  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted based on: (a) analytical sensitivity analysis demonstrating that stiffness predictions are insensitive to offset distance within ±2 mm of the nominal 10 mm, (b) Medium model risk level permitting one below-threshold factor per program risk acceptance criteria, and (c) corroborating data from the cannulated variant (COU2) tested under two configurations. The UQ campaign results, reported in Validation Report VR-NAGARAJA-001 Section 6, confirm that total model uncertainty is within acceptance bounds for all three QoIs. Overall credibility is sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
