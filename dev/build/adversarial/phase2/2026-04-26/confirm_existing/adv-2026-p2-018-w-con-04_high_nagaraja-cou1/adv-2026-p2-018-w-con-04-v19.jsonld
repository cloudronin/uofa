    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria tightened to 1e-5; energy residual monitored.",
      "rationale": "Newton-Raphson convergence tolerance set to 1e-5 for force and displacement residuals. Energy residual monitored throughout loading history. No convergence anomalies detected across 11 specimen simulations. Achieved level meets required level 2."
