    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent reviewer sign-off; input deck version controlled.",
      "rationale": "Simulation workflow documented in SOP-FEA-001 Rev C. Input decks version-controlled in Git repository with tagged releases. Independent reviewer (DePuy Synthes simulation team) verified boundary conditions and material assignments against test setup drawings. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions documented and justified; sensitivity of QoIs to model form choices evaluated.",
      "rationale": "Nonlinear isotropic hardening plasticity (Chaboche) selected for Ti-6Al-4V rod and screw. Linear elastic UHMWPE block. Frictional contact (mu = 0.2) at all metallic interfaces. Model form sensitivity assessed by comparing bilinear vs. Chaboche hardening: QoI difference < 2%. Bone analogue treated as rigid fixture consistent with ASTM F1717 test block geometry. Achieved level 3 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs measured per specimen; uncertainty in inputs quantified.",
      "rationale": "Ti-6Al-4V elastic modulus and yield strength measured via tensile coupon testing for each material lot (n=5 coupons per lot). Rod diameter and pre-bend angle measured via CMM for each specimen. UHMWPE modulus from literature (mean ± 2SD). Input uncertainties propagated through UQ campaign (documented in validation report appendix). Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens representative of production intent; traceability to device design history file.",
      "rationale": "N=11 constructs assembled from production-equivalent components traceable to DHF lot records. Six specimens tested at Lab 1 (FDA CDRH), five at Lab 2 (DePuy Synthes). Screw dimensions verified via CMM; all within drawing tolerances. UHMWPE blocks from same production lot. Sample size supports statistical comparison per ASME V&V 40 Appendix C guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinical use conditions or sensitivity to condition variation is demonstrated.",
      "rationale": "Testing conducted at a single loading rate (5 mm/min) per ASTM F1717. Clinical use involves a range of patient activity rates; loading rate sensitivity not evaluated experimentally. This factor is below required level 3. Risk accepted because (a) Ti-6Al-4V exhibits low strain-rate sensitivity in the quasi-static regime, (b) FEA model is rate-independent, and (c) decision consequence is Medium. Noted as a limitation in the overall credibility argument."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs demonstrably equivalent to as-tested specimen conditions; traceability documented.",
      "rationale": "Per-specimen FEA models constructed using CMM-measured geometry and lot-specific material coupon data. Torque applied to set screw modeled using measured installation torque values. Boundary conditions replicate ASTM F1717 fixture geometry to within 0.1 mm. Equivalency traceability matrix provided in simulation report linking each model input to its experimental measurement source."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all QoIs; acceptance bounds pre-specified.",
      "rationale": "Pre-specified acceptance criteria: relative difference <10% AND E/uval < 1.96 for each QoI. E/uval computed per ASME V&V 20 methodology incorporating experimental measurement uncertainty and model prediction uncertainty. Results: stiffness E/uval = 0.83–1.14, yield force E/uval = 1.31, force at 40 mm E/uval = 0.97. All QoIs pass both criteria. Output comparison achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical performance endpoints and regulatory submission requirements.",
      "rationale": "Three QoIs (stiffness, yield force, force at 40 mm) are the primary ASTM F1717 reporting metrics and directly correspond to the regulatory submission performance endpoints. Stiffness relates to load-sharing with bone graft; yield force and force at 40 mm relate to fatigue life prediction inputs. QoI relevance confirmed by clinical and regulatory team review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test conditions sufficiently represent the COU; gaps identified and addressed.",
      "rationale": "Validation activities directly reproduce the COU test protocol (ASTM F1717 static compression-bending, non-cannulated 7.5 mm screw, production-equivalent components). The sole gap is loading rate range (addressed under Test conditions factor). Two-laboratory design provides assessment of inter-laboratory variability relevant to the multi-site regulatory submission context. Overall validation activity relevance assessed as sufficient for Medium assurance level."
    }
