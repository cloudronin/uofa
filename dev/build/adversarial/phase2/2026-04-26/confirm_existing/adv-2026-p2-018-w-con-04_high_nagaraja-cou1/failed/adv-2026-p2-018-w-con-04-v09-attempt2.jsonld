    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear elastic model with contact interfaces; geometric nonlinearity enabled; model form uncertainty estimated and included in uval.",
      "rationale": "Continuum linear elastic constitutive model applied to titanium alloy components; geometric nonlinearity (large displacement) enabled to capture post-yield response. Contact pairs at screw-rod and screw-block interfaces modeled with penalty formulation. Model form uncertainty estimated via comparison of predicted vs. observed nonlinear stiffness degradation; included as a component of combined validation uncertainty uval."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing of same lot material; geometric inputs from CMM measurements; friction coefficients from literature with uncertainty bounds.",
      "rationale": "Ti-6Al-4V elastic modulus and yield strength sourced from tensile coupon tests of the same material lot as the test constructs (n=6 coupons). Geometric dimensions verified against CMM measurements of test specimens. Interface friction coefficients drawn from published tribology literature with ±20% uncertainty bounds propagated through the UQ campaign. Input uncertainty is the dominant contributor to combined uval."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lot; two independent laboratories; sample size justified by power analysis.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab 1: n=6; Lab 2: n=5). All constructs drawn from the same production lot as the device intended for submission. Sample size justified by prospective power analysis targeting 80% power to detect a 10% QoI difference at α=0.05. Inter-laboratory variability characterized and incorporated into experimental uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple loading rates and environmental conditions tested; ASTM F1717 standard conditions as minimum.",
      "rationale": "Testing conducted under a single set of ASTM F1717 standard conditions (ambient temperature, quasi-static 5 mm/min displacement rate). Required level 3 calls for at least two distinct test conditions to bound environmental and rate sensitivity; only one condition was employed. This factor falls below the required level and represents the sole deficiency in the credibility assessment. Risk accepted given corroborating literature data and the quasi-static nature of the loading scenario."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters demonstrably equivalent to experimental specimen parameters; traceability documented.",
      "rationale": "FEA model inputs (geometry, material properties, boundary conditions) traceable to measurements taken from the actual test specimens and fixtures. CMM data used to set model geometry; coupon test data used to set material properties. Equivalency documented in a parameter-traceability matrix linking each model input to its experimental source. No surrogate or assumed parameter values introduced without quantified uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all QoIs; graphical overlay of force-displacement curves provided.",
      "rationale": "Quantitative comparison performed using the ASME V&V 40 validation metric E/uval. Results: stiffness E/uval = 0.87; yield force E/uval = 1.12; force at 40 mm E/uval = 1.54. All values below the 1.96 threshold. Graphical overlays of predicted vs. experimental force-displacement curves provided for all 11 specimens. Mean absolute percentage errors range from 3.8% to 6.1%, all within the pre-specified 10% acceptance bound."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly relevant to clinical failure modes and regulatory submission requirements.",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — are the quantities specified in ASTM F1717 and directly correspond to clinical performance attributes (construct rigidity, fatigue initiation threshold, and post-yield load-bearing capacity). These QoIs are the same metrics used in the regulatory submission and in the clinical risk analysis. Relevance is high and well-established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
