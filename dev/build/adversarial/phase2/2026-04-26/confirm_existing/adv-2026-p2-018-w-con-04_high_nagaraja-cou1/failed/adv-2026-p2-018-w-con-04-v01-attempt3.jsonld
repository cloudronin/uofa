  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/depuy-synthes-computational-science",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for a Medium-assurance, Model Risk Level 3 assessment. The single below-required factor (Test conditions, achieved 2 vs. required 3) is accepted because ASTM F1717 constitutes the complete regulatory test space for this COU and no additional load configurations are within scope. All three primary QoIs pass the E/uval <1.96 acceptance criterion. An uncertainty quantification campaign (Latin hypercube sampling, 500 runs) confirmed that total predictive uncertainty is dominated by material property variability and remains within acceptable bounds. The credibility assessment team unanimously accepts this model for submission to FDA CDRH in support of the 510(k) for the non-cannulated 7.5 mm pedicle screw system.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
