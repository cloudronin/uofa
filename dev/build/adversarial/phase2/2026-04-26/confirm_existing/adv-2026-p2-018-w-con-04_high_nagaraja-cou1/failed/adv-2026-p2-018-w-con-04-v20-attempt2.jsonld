    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple loading rates and environmental conditions tested. Required Gradation 3: test conditions span the range of clinical use conditions.",
      "rationale": "Testing conducted under a single quasi-static loading rate (5 mm/min) per ASTM F1717 protocol. Clinical loading rates span a broader range; the single test condition limits achieved level to Gradation 2, one below the required Gradation 3. This known shortfall is documented and accepted given the conservative quasi-static assumption for fatigue-life bounding."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
