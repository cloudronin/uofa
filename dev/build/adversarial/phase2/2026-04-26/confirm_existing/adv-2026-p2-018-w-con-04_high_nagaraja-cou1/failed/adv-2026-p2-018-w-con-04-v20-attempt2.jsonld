  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a Medium-influence, Medium-consequence, Model Risk Level 3 assessment. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted because the quasi-static loading rate is conservative relative to in vivo dynamic loading for the purposes of yield-force bounding. All three QoI comparisons satisfy E/uval < 1.96. The FEA modeling framework is accepted as credible for the stated COU.",
