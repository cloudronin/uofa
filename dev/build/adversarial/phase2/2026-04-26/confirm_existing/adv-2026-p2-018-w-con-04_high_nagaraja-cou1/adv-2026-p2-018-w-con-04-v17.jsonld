  "signature": "ed25519:9b3c7a1f4e2d8b056c3a7f1e4d9b2c6a0f5e8d3b7a1c4f9e2d6b0a5c8f3e7d1a",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software used under documented quality management system with version control, regression testing, and audit trail.",
      "rationale": "Ansys Mechanical 2022 R2 operated under FDA CDRH OSEL quality management system (QMS-FEA-001). Version control enforced via Git; regression test suite (847 benchmark cases) executed at each release. All three modelling organisations provided evidence of equivalent QMS controls."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against NAFEMS benchmarks relevant to contact mechanics and large-deformation beam bending.",
      "rationale": "Ansys Mechanical verified against NAFEMS LE1, LE3, and contact benchmark C1 with errors below 0.5%. DePuy Synthes internal verification suite covers titanium alloy plasticity benchmarks with sub-1% agreement against analytical solutions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between penultimate and final mesh density.",
      "rationale": "Systematic h-refinement study conducted across four mesh densities (0.8 mm, 0.5 mm, 0.3 mm, 0.2 mm global element size). Richardson extrapolation applied; GCI for stiffness QoI = 0.9%, yield force QoI = 1.3%. Final mesh (0.3 mm) selected as converged; further refinement to 0.2 mm changed stiffness by 0.4%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria tightened to 1e-5; energy balance verified at each load step.",
      "rationale": "Newton-Raphson convergence tolerance set to 1e-5 for force and displacement residuals. Energy balance checked at each of 200 load increments; maximum energy imbalance 0.03%. Augmented Lagrange contact formulation used with penetration tolerance 0.001 mm."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent model review by second analyst; boundary condition and loading application verified against ASTM F1717 protocol.",
      "rationale": "All three modelling organisations conducted independent peer review of boundary condition definitions, material assignments, and contact pair specifications. Discrepancies resolved through round-robin comparison prior to validation comparison. Boundary conditions verified against ASTM F1717-15 Section 8.2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection justified by material characterisation data; contact formulation appropriate for metal-on-metal interfaces.",
      "rationale": "Bilinear isotropic hardening (BISO) constitutive model applied to Ti-6Al-4V screw and rod components, calibrated against manufacturer-supplied tensile coupon data (n=5 per batch). UHMWPE vertebral body surrogate modelled as linear elastic with modulus derived from compression testing. Augmented Lagrange frictional contact (μ=0.2) consistent with literature for titanium implant interfaces."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters sourced from lot-specific characterisation; dimensional inputs verified against CMM measurements of tested specimens.",
      "rationale": "Lot-specific tensile properties (E, σ_y, σ_u) measured for each screw and rod batch used in testing. CMM measurements of all 11 constructs captured key geometric parameters (rod diameter, screw thread geometry, pedicle distance). UQ campaign (LHS, n=500) characterised sensitivity of QoIs to input variability; cortical bone surrogate modulus and interface friction identified as dominant contributors, informing validation uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 constructs tested; samples representative of production geometry and material specification.",
      "rationale": "N=11 constructs tested (Lab 1: n=6, Lab 2: n=5). All constructs assembled from production-representative components drawn from the same manufacturing lot. Dimensional inspection confirmed all constructs within design tolerance. Sample size sufficient for statistical comparison per ASME V&V 40 Table 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing conducted under at least two clinically relevant load configurations or angles to bound the model prediction space.",
      "rationale": "Testing conducted under a single ASTM F1717 standard compression-bending configuration (5° caudal tilt, 40 mm pedicle distance). A second load configuration (10° tilt or varied pedicle distance) was not included due to resource constraints. This factor does not meet the required level; the gap is acknowledged as a limitation of the current validation campaign and is flagged in the overall credibility assessment summary."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters demonstrably equivalent to tested specimen properties; any discrepancies quantified and propagated to validation uncertainty.",
      "rationale": "One-to-one mapping established between CMM-measured specimen geometry and FEA geometry for each of the 11 constructs. Material property inputs taken from lot-specific coupon tests matched to specimen serial numbers. Residual discrepancies in UHMWPE surrogate modulus (±8%) propagated through UQ framework and included in validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval computed for all QoIs; E/uval < 1.96 required for each.",
      "rationale": "E/uval computed per ASME V&V 40 Eq. 3 for three QoIs: stiffness (1.31), yield force (1.58), force at 40 mm (1.72). All values below 1.96. Experimental uncertainty uexp estimated from inter-laboratory repeatability (CV 3.2%); numerical uncertainty unum from GCI and input propagation. Combined validation uncertainty uval computed as RSS of uexp and unum."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs validated are directly linked to the clinical failure mode and the COU decision.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the COU and are directly associated with the clinically relevant failure modes (fatigue crack initiation at yield, construct loosening). All three QoIs are extractable from both the FEA output and the experimental load-displacement record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity geometry, material, loading, and boundary conditions match or bound the COU application.",
      "rationale": "Validation constructs use the identical non-cannulated 7.5 mm pedicle screw geometry and Ti-6Al-4V rod specification as the COU device. ASTM F1717 test configuration is the regulatory standard for the COU submission. Laboratory testing directly replicates the loading scenario modelled in the FEA. Validation activity is therefore directly relevant to the COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieves Gradation 2 against a required Gradation 3 due to single-configuration testing; this shortfall is offset by the direct equivalency of the validation geometry and loading to the COU, the strong quantitative agreement across all three QoIs (maximum E/uval = 1.72), and the comprehensive UQ campaign that bounded model sensitivity to input variability. The overall credibility evidence is sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
