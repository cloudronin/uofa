  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for a Model Risk Level 3, Medium assurance-level assessment. The single shortfall — Test conditions achieving level 2 against a required level 3 — is accepted on the basis of (a) full ASTM F1717 protocol compliance within the tested condition, (b) supporting UQ campaign evidence demonstrating low sensitivity of all QoIs to boundary-condition assumptions, and (c) the Medium decision consequence (revision surgery, not mortality). All three QoIs satisfy the pre-specified E/uval < 1.96 acceptance criterion. The assessment team concludes that the FEA modeling framework is sufficiently credible for its intended use in the regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
