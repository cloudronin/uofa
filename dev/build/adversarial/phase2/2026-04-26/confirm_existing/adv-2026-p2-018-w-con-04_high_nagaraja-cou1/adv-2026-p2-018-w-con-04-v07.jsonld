  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/nagaraja/validation/vr-stiffness-comparison",
      "type": "ValidationResult",
      "name": "Construct stiffness QoI comparison — FEA vs. experiment",
      "description": "FEA-predicted construct stiffness compared against N=11 experimental measurements. Mean absolute percentage error 4.2%; E/uval = 0.87, within the pre-established acceptance bound of 1.96. An uncertainty quantification campaign (Monte Carlo, n=500 runs) propagating Ti-6Al-4V elastic modulus variability (CV=3.1%) and fixture alignment uncertainty (±0.5°) was executed; results confirmed that parametric sensitivity to modulus dominates and that the nominal prediction remains well within acceptance bounds across the full uncertainty envelope."
    },
    {
      "id": "https://uofa.net/nagaraja/validation/vr-yield-force-comparison",
      "type": "ValidationResult",
      "name": "Yield force QoI comparison — FEA vs. experiment",
      "description": "FEA-predicted yield force compared against N=11 experimental measurements across two independent laboratories. Mean absolute percentage error 6.8%; E/uval = 1.31, within acceptance bound. Sensitivity analysis embedded in the UQ campaign identified yield strength variability as the dominant driver; a ±5% perturbation in yield strength produced a ±4.9% shift in predicted yield force, confirming adequate model fidelity."
    },
    {
      "id": "https://uofa.net/nagaraja/validation/vr-force-40mm-comparison",
      "type": "ValidationResult",
      "name": "Force at 40 mm displacement QoI comparison — FEA vs. experiment",
      "description": "FEA-predicted force at 40 mm displacement compared against experimental data. Mean absolute percentage error 7.4%; E/uval = 1.58, within acceptance bound. The UQ campaign demonstrated low sensitivity to boundary-condition stiffness assumptions beyond 20 mm displacement, supporting confidence in this QoI despite single-condition testing."
    }
  ],
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
