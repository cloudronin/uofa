      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via comparison to analytical solutions for beam bending and contact patch problems. Errors < 1% for all benchmark cases.",
      "rationale": "Euler-Bernoulli beam bending benchmark: FEA vs. analytical solution error 0.3%. Hertzian contact patch benchmark: error 0.8%. Both within the 1% threshold. Code verification requirement satisfied at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
