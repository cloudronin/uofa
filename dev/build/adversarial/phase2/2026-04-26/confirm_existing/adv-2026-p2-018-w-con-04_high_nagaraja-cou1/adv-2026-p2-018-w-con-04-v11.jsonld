  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical R2023 R1 holds FDA-recognised software validation documentation; all simulation scripts version-controlled in Git with tagged release corresponding to this submission.",
      "rationale": "The FEA solver (Ansys Mechanical R2023 R1) is a commercially validated code with documented V&V per ASME V&V 10. Internal QA procedures include input-deck review by an independent analyst and automated regression tests confirming mesh-generation reproducibility. Achieved level exceeds required level for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems (cantilever beam, Hertzian contact) reproduced to within 1% of analytical solutions using the same element types and solver settings as the pedicle screw model.",
      "rationale": "Three canonical benchmark problems from NAFEMS were executed using identical solver settings: linear elastic cantilever (error 0.3%), Hertzian contact patch (error 0.8%), and large-displacement beam (error 0.6%). All within the 1% threshold, confirming correct code implementation for the physics of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI < 2% for each QoI on the production mesh; mesh refinement study conducted across three systematically refined mesh densities.",
      "rationale": "A three-level mesh convergence study (coarse 142k, medium 387k, fine 1.02M elements) was performed. Richardson extrapolation yielded GCI values of 1.1% (stiffness), 0.9% (yield force), and 1.4% (force at 40 mm). All below the 2% acceptance threshold. The medium mesh was selected for production runs balancing accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force residual convergence norm < 1e-4 and energy criterion < 1e-6 for each nonlinear load step; no diverged increments in production runs.",
      "rationale": "All nonlinear load steps converged within 15 Newton-Raphson iterations. Force residual norms remained below 1e-5 and energy norms below 1e-7 for all 11 model instances. No divergence events were recorded. Automatic time-stepping was enabled with a minimum step size of 0.001 of total applied displacement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup, boundary conditions, and post-processing scripts completed prior to submission; discrepancies resolved and documented.",
      "rationale": "An independent FDA analyst reviewed the complete simulation workflow including CAD import, meshing parameters, contact definitions, boundary condition assignments, and post-processing scripts. Two minor discrepancies (friction coefficient assignment and output extraction node set) were identified and corrected. Final reviewed model was used for all reported results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear-elastic titanium alloy constitutive model with bilinear isotropic hardening post-yield; contact modelled as frictional Lagrange multiplier; validated against independent coupon-level data prior to construct-level application.",
      "rationale": "The constitutive model (Ti-6Al-4V, bilinear isotropic hardening) was validated against dog-bone tensile coupon data (n=5) with mean error 1.8% in yield stress and 2.3% in ultimate tensile strength. Frictional contact at screw-rod interface uses Lagrange multiplier formulation with friction coefficient derived from tribological measurements. Model form is well-established for metallic orthopaedic implant simulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties sourced from lot-specific coupon testing or peer-reviewed literature with traceability; geometric inputs derived from CMM measurements of test specimens.",
      "rationale": "Elastic modulus (114 GPa ± 3%), yield strength (880 MPa ± 5%), and Poisson's ratio (0.34) were obtained from lot-specific tensile coupon testing of the same material batch used for test constructs. Geometry inputs were derived from coordinate measuring machine (CMM) data for each of the 11 test specimens, capturing as-manufactured dimensional variation. Friction coefficient (0.18) was taken from tribological pin-on-disk measurements reported in the peer-reviewed literature for titanium alloy on titanium alloy under dry conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 constructs from production lots; samples span both test laboratories; dimensional inspection confirms conformance to design nominal within drawing tolerances.",
      "rationale": "Eleven constructs were assembled from production-lot components (5 from Lab 1, 6 from Lab 2). All components were dimensionally inspected by CMM prior to assembly; all dimensions within ±0.05 mm of nominal. Construct assembly was performed by trained technicians following the manufacturer's surgical technique guide. Sample size exceeds the minimum of 10 specified in the acceptance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate the full range of clinically relevant loading scenarios including at least two load magnitudes and two construct configurations.",
      "rationale": "Testing was conducted under a single ASTM F1717 standardised loading condition (static compression-bending at 5° offset). While this condition is the regulatory standard, it does not capture torsional or fatigue loading modes relevant to in vivo use. This factor is assessed below the required level (achieved 2 vs. required 3); the gap is acknowledged and mitigated by the conservative nature of the F1717 protocol relative to physiological loading, and by the regulatory precedent for this test method for pedicle screw 510(k) submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material properties, boundary conditions) are demonstrably equivalent to experimental conditions; any deviations quantified and shown to have negligible effect on QoIs.",
      "rationale": "CMM-derived specimen geometry was used to create specimen-specific FEA models for each of the 11 constructs, ensuring geometric equivalency. Material properties were matched to lot-specific coupon data. Boundary conditions replicate the F1717 fixture kinematics including the 5° offset block geometry. The only non-equivalency is idealisation of the polyaxial head locking mechanism as a rigid constraint; sensitivity analysis showed ±4% effect on force at 40 mm, accepted as within the 10% bound."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation metric E/uval < 1.96 for all three primary QoIs; percentage difference < 10%; Bland-Altman analysis confirms no systematic bias.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy E/uval < 1.96 and percentage difference < 10%. Bland-Altman analysis across the 11 specimen-specific model-experiment pairs shows mean bias of +1.8% with 95% limits of agreement −5.2% to +8.8%, confirming absence of systematic over- or under-prediction. Results are consistent across both laboratories (Lab 1 mean error 2.1%, Lab 2 mean error 1.9%)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical and regulatory decision; each QoI is traceable to a specific failure mode or performance specification.",
      "rationale": "Construct stiffness is a surrogate for load-sharing between implant and bone graft, relevant to fusion outcome. Yield force defines the onset of permanent deformation, linked to implant loosening risk. Force at 40 mm displacement characterises post-yield structural integrity, relevant to catastrophic failure risk. All three QoIs are specified in the ASTM F1717 standard and are accepted by FDA as relevant metrics for pedicle screw 510(k) submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation domain (geometry, loading, material, scale) is sufficiently close to the COU domain that extrapolation uncertainty is negligible or bounded.",
      "rationale": "The validation activity uses the identical screw design, rod diameter, and construct configuration as the COU. Loading is the regulatory-standard F1717 protocol directly applicable to the intended use claim. The validation domain matches the COU domain with no extrapolation in geometry, scale, or material. The single gap (single load condition, as noted under Test conditions) is judged acceptable given the regulatory context and conservative nature of the F1717 protocol."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for a Medium-risk model at Medium assurance level. The single below-required factor (Test conditions, achieved 2 vs. required 3) is mitigated by the regulatory precedent for ASTM F1717 as the accepted test method for pedicle screw submissions and by the conservative nature of the standardised loading protocol. All three primary QoIs satisfy pre-established acceptance bounds (E/uval < 1.96; percentage difference < 10%). The UQ campaign, conducted as part of the validation activity and summarised in the ValidationResult narratives, confirmed that model predictions remain within acceptance bounds across the range of plausible input uncertainties. The credibility assessment team concludes that the FEA modeling framework is sufficiently credible for its intended use in supporting the 510(k) submission for the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
