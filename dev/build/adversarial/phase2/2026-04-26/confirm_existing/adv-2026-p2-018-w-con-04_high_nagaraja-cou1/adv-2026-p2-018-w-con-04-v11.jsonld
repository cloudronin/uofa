  "hasContextOfUse": {
    "decisionConsequence": "Medium",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "deviceClass": "Class II",
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/nagaraja/validation/stiffness-comparison",
      "type": "ValidationResult",
      "name": "Construct stiffness QoI comparison — FEA vs. bench",
      "description": "FEA ensemble mean stiffness 1 423 N/mm versus experimental mean 1 389 N/mm (N=11). Percentage difference 2.4%, well within the 10% acceptance bound. Normalised validation metric E/uval = 0.81 (< 1.96). A one-at-a-time sensitivity sweep across ±10% elastic modulus and ±5% geometry tolerances was conducted as part of the broader UQ campaign; stiffness showed low sensitivity to material scatter (CV < 3%) and moderate sensitivity to screw-rod interface friction coefficient (range 1 310–1 540 N/mm across friction coefficient 0.1–0.3).",
      "outcome": "Accepted",
      "metricValue": 0.81,
      "metricThreshold": 1.96
    },
    {
      "id": "https://uofa.net/nagaraja/validation/yield-force-comparison",
      "type": "ValidationResult",
      "name": "Yield force QoI comparison — FEA vs. bench",
      "description": "FEA ensemble mean yield force 847 N versus experimental mean 831 N (N=11). Percentage difference 1.9%, within acceptance bound. E/uval = 0.62. The UQ campaign propagated material yield strength uncertainty (Gaussian, CV=5%) through the model ensemble using Latin Hypercube Sampling (n=200 runs); the resulting 95th-percentile prediction interval fully encompassed the experimental range, confirming adequate model fidelity under uncertainty.",
      "outcome": "Accepted",
      "metricValue": 0.62,
      "metricThreshold": 1.96
    },
    {
      "id": "https://uofa.net/nagaraja/validation/force-40mm-comparison",
      "type": "ValidationResult",
      "name": "Force at 40 mm displacement QoI comparison — FEA vs. bench",
      "description": "FEA ensemble mean force at 40 mm displacement 1 102 N versus experimental mean 1 078 N (N=11). Percentage difference 2.2%, within acceptance bound. E/uval = 0.74. Sensitivity of this QoI to polyaxial head locking torque was assessed parametrically; a ±15% torque variation produced a ±4% change in predicted force, remaining within acceptance bounds across all perturbations.",
      "outcome": "Accepted",
      "metricValue": 0.74,
      "metricThreshold": 1.96
    }
  ],
