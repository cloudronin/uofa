  "signature": "ed25519:b1c4e7a2d5f8b3e6a9c2f5d8b1e4a7c0d3f6b9e2a5c8f1d4b7e0a3c6f9d2b5e8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented version control, regression testing suite, and release validation for the CFD solver at the version used for production runs.",
      "rationale": "ANSYS Fluent 2022 R2 is under ISO 9001-certified quality management. Solver release notes document regression test suite results. Version control records confirm the solver build used for all production hemolysis simulations is identical to the validated release."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark test demonstrating solver correctly implements governing equations for rotating-frame incompressible viscous flow.",
      "rationale": "The CFD solver was verified against the lid-driven cavity benchmark (Re = 1000) and a rotating Couette flow manufactured solution. Velocity field errors were below 0.5% of reference values, confirming correct implementation of the Navier-Stokes equations in the rotating reference frame used for impeller modeling."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis-relevant QoIs below 5% on the production mesh.",
      "rationale": "Richardson extrapolation applied to three systematically refined meshes (refinement ratio r = 1.3). GCI for normalized index of hemolysis (NIH) was 2.7% on the fine mesh (11.8M cells). The production mesh of 5.4M cells yields GCI = 4.1%, satisfying the 5% threshold. Achieved level exceeds requirement due to additional refinement study at blade leading edges."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with sufficient fidelity to reproduce boundary conditions in the CFD model, including flow rates, rotational speeds, and blood analog properties.",
      "rationale": "Bench tests were conducted at ASTM F1841-compliant conditions using bovine blood with hematocrit 33 ± 2%. Flow rates (2–6 L/min) and rotational speeds (1500–2500 RPM) were logged at 10 Hz. Temperature was controlled at 37 ± 0.5°C. All boundary conditions are traceable to calibrated instrumentation with documented uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric comparing CFD-predicted NIH to measured NIH across all 5 operating points, with mean absolute error below 15%.",
      "rationale": "CFD-predicted NIH was compared to bench-measured NIH at 5 flow-speed operating points. Mean absolute error was 8.3% and maximum error was 13.1%. All predictions fell within the 15% acceptance threshold. The relative hemolysis index RH < 1 criterion was satisfied at all operating points, consistent with the COU acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, RH) are the same quantities used in the COU decision, or a documented mapping between validation QoIs and COU QoIs is provided.",
      "rationale": "The primary COU QoI is the relative hemolysis index RH = NIH_device / NIH_predicate. Validation was performed using the same NIH metric computed from the power-law hemolysis model applied to CFD-predicted shear stress and exposure time fields. No mapping is required as the QoIs are identical between validation and COU application."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities were performed on the same or sufficiently similar device geometry, operating regime, and fluid properties as the COU application.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU. Operating conditions span the COU envelope (2–6 L/min, 1500–2500 RPM). Blood analog properties match CPB clinical conditions. The validation domain is directly representative of the COU without extrapolation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "At Model Risk Level 2, numerical solver error beyond code verification is not required. Iterative convergence was monitored to residual levels below 1e-5 for all equations; no solver error assessment beyond standard convergence monitoring is mandated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal use error assessment is not required at MRL 2. Simulation setup was reviewed by a second analyst and documented in the simulation log. No discrepancies were identified between the simulation setup and the approved simulation plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Model form uncertainty assessment beyond validation comparison is not required at MRL 2. The power-law hemolysis model (Giersiepen et al.) is the accepted standard for CFD hemolysis prediction in FDA guidance and has been validated in the output comparison factor above."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs documented with sources and nominal values; material properties and boundary conditions traceable to measurements or literature with stated uncertainty.",
      "rationale": "Blood viscosity (3.5 mPa·s), density (1060 kg/m³), and hematocrit (33%) were drawn from ASTM F1841 and confirmed by bench measurement. Impeller geometry was digitized from FDA benchmark CAD files with dimensional tolerances of ±0.05 mm. Inlet velocity profiles were derived from ultrasonic flow meter measurements. All inputs are documented in the simulation plan with traceability records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Statistical characterization of test sample variability is not required at MRL 2. Three pump units from the same manufacturing lot were used for bench testing; unit-to-unit variability in NIH was below 5% across all operating points, providing confidence that sample-to-sample variation does not materially affect the validation comparison."
    },
    {
