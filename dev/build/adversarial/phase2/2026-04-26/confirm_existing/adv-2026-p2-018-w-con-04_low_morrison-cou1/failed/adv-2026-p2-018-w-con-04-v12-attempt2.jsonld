      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented test suite; commercial solver with documented validation history acceptable at MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 used as the CFD solver. Commercial software with documented QA procedures, version-controlled configuration files, and a published validation suite for cardiovascular applications. Satisfies MRL 2 SQA requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
