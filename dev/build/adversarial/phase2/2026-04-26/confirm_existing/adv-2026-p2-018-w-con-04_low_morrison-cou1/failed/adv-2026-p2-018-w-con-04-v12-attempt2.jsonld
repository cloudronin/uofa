      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases at MRL 2.",
      "rationale": "ANSYS Fluent has been verified against standard CFD benchmark cases including lid-driven cavity and backward-facing step. Published code verification documentation confirms correct implementation of incompressible Navier-Stokes equations relevant to blood pump simulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
