      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; basic solver residual monitoring sufficient.",
      "rationale": "At Model Risk Level 2, detailed iterative solver error quantification beyond standard residual convergence monitoring is not required. All simulations converged to residuals below 1e-5 for continuity, momentum, and hemolysis scalar equations. No solver divergence or convergence anomalies observed across the operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; standard simulation setup review procedures are sufficient.",
      "rationale": "At MRL 2, formal use error analysis is not required. Simulation setup was reviewed by a second analyst against the documented simulation plan. Boundary condition assignments, material properties, and solver settings were independently verified prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection rationale documented in simulation plan is sufficient.",
      "rationale": "At MRL 2, formal model form uncertainty quantification is not required. The SST k-omega turbulence model was selected based on published benchmark performance for rotary blood pump flows (Fraser et al., 2011; Hariharan et al., 2011). The Giersiepen-Wurzinger hemolysis power-law model is the accepted standard for CFD hemolysis prediction in regulatory submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "At MRL 2, formal propagation of input parameter uncertainty through the model is not required. All model inputs (fluid properties, boundary conditions, geometric dimensions) are documented with sources and nominal values. Blood analog fluid properties are within ±2% of target values based on viscometer measurements."
    },
