    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must operate under a documented quality management system with version control, issue tracking, and release validation suite.",
      "rationale": "ANSYS Fluent 2022R2 is developed under ISO 9001-certified QMS. Version control via internal SVN repository, regression test suite of 1,200+ cases executed at each release. Software qualification documentation provided by vendor and reviewed by assessment team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark comparisons with analytical or DNS solutions for relevant flow regimes.",
      "rationale": "SST k-omega turbulence model and scalar transport (hemolysis index) implementations verified against FDA nozzle benchmark and Moser DNS channel flow data. Velocity and turbulent kinetic energy profiles agree within 3.2% RMS. Hemolysis scalar transport verified against analytical solution for simple shear flow."
