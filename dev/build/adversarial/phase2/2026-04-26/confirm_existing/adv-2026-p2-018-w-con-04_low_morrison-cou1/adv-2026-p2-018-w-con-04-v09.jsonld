    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index quantity of interest at all operating points.",
      "rationale": "Three-level mesh refinement study conducted with coarse (2.1M), medium (5.8M), and fine (14.2M) cell meshes. GCI computed per Celik et al. (2008) procedure. Maximum GCI across all 5 operating points is 2.1% on the medium mesh selected for production simulations. Observed order of convergence 1.87, consistent with second-order spatial discretization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to reproduce boundary conditions in the CFD model.",
      "rationale": "Experimental data from Morrison et al. (2019) provide complete documentation of inlet flow rates (2–6 L/min), rotational speeds (2000–3500 RPM), blood analog fluid properties (viscosity 3.5 cP, density 1056 kg/m3), and temperature (37°C). All boundary conditions faithfully reproduced in CFD model within measurement uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index must agree with experimental measurements within combined model and experimental uncertainty at all 5 operating points.",
      "rationale": "CFD-predicted RH values compared against experimental measurements at 5 flow-speed combinations. All predictions fall within ±0.07 RH units of experimental mean values. Experimental uncertainty (95% CI) ranges from ±0.04 to ±0.09 RH units. Model predictions are within combined uncertainty bounds at all operating points, confirming adequate predictive accuracy for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index QoI used in validation must be directly relevant to the clinical endpoint of pump-induced hemolysis in CPB patients.",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) are the industry-standard metrics for pump hemolysis assessment per ASTM F1841. These quantities directly represent red blood cell damage and are the regulatory-accepted endpoints for CPB device evaluation. The QoI used in validation is identical to the QoI used in the device acceptance decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the operating range of the COU (flow rates 2–6 L/min, speeds 2000–3500 RPM) using geometrically similar pump configurations.",
      "rationale": "Validation experiments conducted on the FDA generic centrifugal blood pump geometry — the same geometry used in the COU assessment. Operating conditions span the full clinical CPB range. Predicate device comparison uses identical test protocol. Validation activities directly support the COU without extrapolation beyond validated operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
