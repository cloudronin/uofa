      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, iterative convergence monitoring to fixed residual tolerance is sufficient; formal solver error bounding not required.",
      "rationale": "Iterative convergence monitored via residual reduction to 1e-5 for all transport equations and mass imbalance below 0.01%. Formal numerical solver error quantification beyond residual monitoring is not required at MRL 2 for this factor and has not been performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
