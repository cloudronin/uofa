  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and issue tracking consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was used with documented version control records, a suite of regression tests covering turbulence and hemolysis transport models, and a tracked issue log. All SQA artifacts meet MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems at MRL 2 level.",
      "rationale": "Code verification confirmed via lid-driven cavity and Poiseuille flow benchmarks. Observed order of convergence matched theoretical order for both velocity and pressure fields, confirming correct discretization implementation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI at the operating points of interest.",
      "rationale": "Three-level mesh refinement study performed with mesh sizes of 2.1M, 6.8M, and 18.4M cells. Richardson extrapolation yielded GCI of 2.3% for the hemolysis index at the worst-case operating point, exceeding MRL 2 requirements. The 6.8M cell mesh was selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to permit reproduction and comparison with simulation boundary conditions.",
      "rationale": "FDA benchmark experimental conditions are fully documented in the open literature including inlet flow rates (2.5, 5.0, 7.5 L/min), rotational speeds (2000, 2500, 3500 RPM), blood analog fluid properties, and temperature. Boundary conditions in the CFD model were set to match experimental conditions within measurement uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., relative hemolysis index) must be reported with uncertainty bounds and demonstrate agreement within acceptance threshold.",
      "rationale": "Relative hemolysis index RH computed at all 5 operating points. RH ranged from 0.71 to 0.94 across operating conditions, all satisfying the RH < 1 acceptance criterion. Comparison against experimental NIH values yielded a normalized RMS error of 9.4%, within the MRL 2 tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly linked to the clinical endpoint of hemolysis and the regulatory acceptance criterion.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) and derived relative hemolysis index (RH). These QoIs are directly linked to the clinical risk of hemolysis in CPB patients and are the accepted regulatory metric for blood pump hemolysis assessment per FDA guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow conditions, and fluid properties sufficiently representative of the CPB COU to support extrapolation of credibility.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump, which shares key geometric and operational characteristics with the device under assessment. Operating conditions span the clinical CPB range. Blood analog fluid (glycerol-water mixture) properties match within 3% of physiological blood viscosity at the relevant shear rates."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, detailed iterative convergence error quantification beyond residual monitoring is not required.",
      "rationale": "Residual convergence to 1e-5 for all equations was confirmed at each operating point. Detailed iterative error quantification beyond residual monitoring is not required at MRL 2 and was not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error assessment is not required provided simulation setup is reviewed by a qualified analyst.",
      "rationale": "Simulation setup was reviewed by a senior CFD analyst with 10 years of cardiovascular device experience. Formal use error assessment is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal model form uncertainty quantification is not required; selection rationale must be documented.",
      "rationale": "The SST k-omega turbulence model was selected based on published literature demonstrating superior performance for rotating cardiovascular flows. The Giersiepen-Wurzinger power-law hemolysis model is the standard for regulatory CFD submissions. Formal model form uncertainty analysis is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal input uncertainty propagation is not required; nominal input values with documented sources are sufficient.",
      "rationale": "All model inputs (fluid density 1056 kg/m3, dynamic viscosity 3.5 mPa·s, pump geometry from FDA benchmark CAD) are documented with sources. Formal input uncertainty propagation is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of experimental sample variability is not required provided test sample provenance is documented.",
      "rationale": "FDA benchmark experimental data was collected using standardized bovine blood analog per ASTM F1841. Sample provenance and preparation protocol are documented in the published benchmark dataset. Statistical characterization of sample variability is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
