  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped to not-assessed per MRL 2 requirements with documented justification. Validation evidence demonstrates CFD model predicts hemolysis index within 20% of experimental reference across the full CPB operating envelope. Model uncertainty is dominated by model form uncertainty in the turbulence and hemolysis constitutive models, which is acceptable at MRL 2 given the medium model influence and the comparative nature of the RH < 1 decision criterion. The assessment team concludes that the CFD model has sufficient credibility to support the COU1 decision for the Class II CPB device.",
