  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted. Twelve of thirteen V&V 40 factors meet or exceed the required level. The single gap in Test conditions (achieved level 2 vs. required level 3) is acknowledged; the assessment team judged the single-configuration ASTM F1717 validation sufficient for the compression-bending COU given the low clinical consequence of the gap and the strong quantitative agreement across all three QoIs. All ValidationResults supporting this decision were generated under model configuration ansys-mechanical-2024q3-build-2 (modelVersion 2024-q3-build-2); however, the current model of record is 2026-q1-build-7. The validation evidence therefore predates the current model version by approximately six quarters.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
