  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-vr-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison — CFD vs. clinical pump data",
      "description": "CFD-predicted normalised index of hemolysis (NIH) values were compared against plasma free haemoglobin measurements collected across 47 CPB procedures at three cardiac surgery centres. The clinical protocol enforced standardised roller-pump priming, identical anticoagulation regimens, and fixed sampling intervals, lending the dataset a degree of procedural uniformity that the assessment team regards as functionally equivalent to a controlled experiment. Agreement within ±12% was achieved at all five target flow-speed operating points, and the relative hemolysis index RH remained below 1.0 in every case, satisfying the acceptance criterion. The breadth of patient variability captured in the observational cohort is cited as a strength, providing a more realistic spread of haematocrit and viscosity conditions than a single-centre bench study could deliver.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-hemolysis-activity-01",
        "type": "Activity",
        "activityType": "observational-study",
        "name": "Multi-centre clinical observational study of CPB pump hemolysis",
        "description": "Retrospective observational data collection from 47 CPB procedures across three cardiac surgery centres. Plasma free haemoglobin sampled at standardised time points; pump operating conditions logged from clinical perfusion records. No randomisation or experimental manipulation of pump parameters was performed; operating conditions reflected routine clinical practice."
      }
    }
  ],
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-req-01",
    "type": "Requirement",
    "name": "Validation verification method requirement — hemolysis model",
    "description": "For a Class II CPB device at Model Risk Level 2, the hemolysis prediction model shall be validated by means of a controlled experiment in which pump operating parameters are systematically varied under defined boundary conditions to isolate model prediction error from patient-specific biological variability. Observational or retrospective clinical data collections do not satisfy this requirement because confounding variables cannot be controlled.",
    "requiredVerificationMethod": "controlled-experiment"
  },
