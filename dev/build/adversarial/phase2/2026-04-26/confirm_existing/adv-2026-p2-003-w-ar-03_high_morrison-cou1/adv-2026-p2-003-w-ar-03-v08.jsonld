  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-dr-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. The six non-assessed factors are acceptable at this risk level per ASME V&V 40 Table 3. CFD predictions of NIH agree with clinical data within ±12% across all five operating points, and RH < 1.0 is satisfied in every case. The multi-centre observational dataset, while collected under routine clinical conditions, is judged by the assessment team to provide sufficient procedural uniformity to support the validation claim. The overall evidence package is deemed adequate to accept the model for the stated COU.",
