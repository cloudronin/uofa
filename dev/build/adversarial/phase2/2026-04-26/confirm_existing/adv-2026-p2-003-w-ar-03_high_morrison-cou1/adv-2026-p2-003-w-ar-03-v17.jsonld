  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-controlled-experiment",
    "type": "Requirement",
    "name": "Hemolysis validation shall be supported by controlled experimental evidence",
    "description": "Per MRL 2 guidance and FDA 2021 CFD guidance, validation of hemolysis predictions for Class II blood-contacting devices shall be underpinned by at least one controlled experiment in which flow rate, rotational speed, hematocrit, and temperature are independently set by the investigator and held constant within each test condition. Observational or registry-based data collection is not sufficient to satisfy this requirement because confounding variables cannot be excluded.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/gcbp-hemolysis-benchtop-vr1",
      "type": "ValidationResult",
      "name": "Benchtop hemolysis measurement vs CFD prediction — five operating points",
      "description": "Plasma-free hemoglobin (pfHb) was measured at five flow-speed combinations (3 L/min at 2500 RPM, 4 L/min at 2500 RPM, 4 L/min at 3000 RPM, 5 L/min at 3000 RPM, 5 L/min at 3500 RPM) on a recirculating blood analog loop using bovine blood at 35 % hematocrit. The relative hemolysis index (RHI) was computed for each condition and compared with CFD-predicted scalar stress integrals. Agreement within 12 % was observed across all five points. The campaign was conducted prospectively over six weeks at an accredited hemolysis testing laboratory. All five RHI values fell below the acceptance criterion of 1.0 relative to the predicate device. The investigators describe the protocol as a well-controlled bench study with fixed boundary conditions, providing strong experimental corroboration of the CFD hemolysis model.",
      "quantitativeMetric": "Mean absolute RHI prediction error: 8.3 %; maximum 11.7 %",
      "passesCriteria": true,
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/gcbp-hemolysis-benchtop-obs-2024",
        "type": "Activity",
        "activityType": "observational-study",
        "name": "Benchtop hemolysis observational data collection — GCBP 2024",
        "description": "Operating conditions (flow rate, speed) were selected by the clinical perfusionist on duty according to standard-of-care preferences rather than by a pre-specified randomized or factorial design. Hematocrit and temperature were monitored but not independently manipulated. The resulting dataset covers five naturally occurring operating combinations that fell within the range of interest. Because the investigator did not independently assign all input variables, the protocol is classified as an observational study under the laboratory's quality system, even though the measurements themselves were taken under stable, steady-state loop conditions.",
        "startedAtTime": "2024-03-04T08:00:00Z",
