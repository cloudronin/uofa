  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 4. The CFD model is judged credible for identifying worst-case hemolysis operating conditions for the Class II CPB device. The validation evidence, drawn from a 312-episode multisite observational study, demonstrates that predicted RH values agree with clinical reference data within ±15% at all five COU operating points and that all predicted RH values remain below 1.0. The breadth and clinical realism of the observational dataset are considered by the assessment team to provide strong support for the validation claim. The model is accepted for use in the intended COU.",
