  "hasRequirement": {
    "id": "https://uofa.net/synth/req/hemolysis-verification-method",
    "type": "Requirement",
    "name": "Hemolysis index verification method requirement",
    "description": "For MRL 2 Class II CPB devices, the primary validation activity supporting the hemolysis QoI comparison shall employ a controlled experiment in which rotational speed, flow rate, and fluid properties are independently varied under laboratory conditions using a single instrumented test article. This requirement ensures that confounding variables present in multi-patient clinical data are eliminated and that the causal relationship between operating conditions and hemolysis index can be unambiguously established. Observational or registry-based datasets do not satisfy this requirement because they cannot isolate individual parameter effects.",
