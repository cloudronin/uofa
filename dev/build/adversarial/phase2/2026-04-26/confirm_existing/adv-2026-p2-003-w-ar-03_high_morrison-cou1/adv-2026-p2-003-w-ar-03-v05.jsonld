  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. The six non-assessed factors are appropriately scoped out at this model risk level. Validation evidence from the 14-site clinical observational registry demonstrates close agreement between CFD-predicted and measured relative hemolysis indices (MAE 3.7%, Bland-Altman LoA ±0.06) across all five target operating points. The assessment team concludes that the CFD model provides sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device, and the Accepted decision is warranted.",
