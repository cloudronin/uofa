        "type": "Activity",
        "name": "Prospective CPB patient registry hemolysis measurement study",
        "description": "A prospective observational registry study conducted at four cardiac surgery centres between 2020 and 2023. Hemolysis indices were measured in CPB patients whose pump operating conditions (flow rate 2–6 L/min; speed 1500–3500 RPM) spanned the five target operating points. No experimental manipulation of pump parameters was performed; operating conditions were determined by clinical need and recorded post-hoc for correlation with hemolysis outcomes.",
        "activityType": "observational-study",
        "startedAtTime": "2020-03-01T00:00:00Z",
        "endedAtTime": "2023-09-30T00:00:00Z"
      }
