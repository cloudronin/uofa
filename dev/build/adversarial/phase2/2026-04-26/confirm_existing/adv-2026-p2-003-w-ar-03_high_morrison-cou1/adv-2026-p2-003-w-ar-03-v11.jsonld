  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-verification-req-01",
    "type": "Requirement",
    "name": "Hemolysis model validation verification requirement",
    "description": "The validation of the CFD hemolysis prediction model shall be supported by a controlled experiment in which operating conditions (flow rate, rotational speed) are systematically varied under laboratory-controlled conditions, enabling direct causal attribution of hemolysis index changes to specific pump operating parameters. The controlled-experiment design is required to isolate confounding variables and establish the inferential basis for model acceptance at MRL 2.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-output-comparison-01",
      "type": "ValidationResult",
      "name": "Hemolysis index output comparison against clinical registry data",
      "description": "Predicted relative hemolysis index (RH) values from the CFD model were compared against measured hemolysis index values drawn from a prospective multi-centre CPB patient registry. Across all five target flow-speed operating points, predicted RH values fell below the acceptance threshold of 1.0 (range 0.61–0.94), with a mean absolute error of 0.07. The registry dataset encompassed 312 CPB procedures with intraoperative hemolysis sampling at standardised time points. The breadth of patient-level data and the systematic coverage of the operating envelope were judged by the assessment team to provide validation evidence fully equivalent in scope to bench-level testing. All output-comparison acceptance criteria are therefore considered satisfied.",
      "passFailStatus": "Pass",
      "wasGeneratedBy": {
