  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. The six non-assessed factors are appropriately scoped out per ASME V&V 40 Table 3 for a Class II device at MRL 2. The validation evidence — drawn from a prospective in-vitro hemolysis study covering the full COU operating envelope — demonstrates that the CFD model predicts relative hemolysis index within 10% of empirical measurements at all five operating points, satisfying the RH < 1 acceptance criterion with margin. On the basis of this evidence the CFD model is accepted as credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
