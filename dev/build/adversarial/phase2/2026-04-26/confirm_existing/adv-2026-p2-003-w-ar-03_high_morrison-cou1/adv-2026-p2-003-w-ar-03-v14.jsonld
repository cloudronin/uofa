  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-vr-01",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against multi-site observational data",
      "description": "CFD-predicted relative hemolysis indices (RH) at five flow-speed operating points were compared against plasma-free hemoglobin measurements aggregated from a five-site observational study of CPB patients. Across all operating points, predicted RH values fell within ±18% of observed median values, and all predictions satisfied the RH < 1 acceptance criterion. The observational dataset encompassed 312 patient records spanning a range of pump speeds (1800–3200 RPM) and flow rates (3.0–6.5 L/min), providing statistically robust reference data. Agreement was assessed using Bland-Altman analysis and coverage intervals at the 95th percentile. The breadth and clinical realism of the observational cohort are cited as primary justification for the validation claim.",
      "passesCriteria": true,
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-observational-hemolysis-study-01",
        "type": "Activity",
        "activityType": "observational-study",
        "name": "Multi-site observational study of pump-induced hemolysis in CPB patients",
        "description": "A prospective observational study conducted across five cardiac surgery centers. Plasma-free hemoglobin was measured pre- and post-pump exposure for each patient. No experimental manipulation of pump parameters was performed; data were collected under routine clinical operating conditions. Statistical summaries were computed per operating-point bin defined by flow rate and pump speed intervals matching the five CFD simulation conditions."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-vr-02",
      "type": "ValidationResult",
      "name": "Mesh-independence and discretization convergence check",
      "description": "Grid convergence index (GCI) analysis was performed on three systematically refined meshes (2.1M, 5.8M, and 14.2M cells). The fine-grid GCI for shear-stress-derived hemolysis index was 2.3%, satisfying the required threshold of less than 5%. Richardson extrapolation confirmed monotonic convergence. This result supports the discretization error credibility factor at the required level.",
