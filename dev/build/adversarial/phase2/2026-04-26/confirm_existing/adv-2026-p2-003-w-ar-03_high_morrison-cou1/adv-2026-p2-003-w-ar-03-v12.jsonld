  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are appropriately scoped out at MRL 2. The primary validation evidence — drawn from the FDA generic centrifugal blood pump flow-loop measurement campaign — demonstrates NIH agreement within 8.3% mean absolute relative error and RH < 1.0 at all five target operating points. The measurement campaign systematically covered the CPB operating envelope and is considered a rigorous empirical basis for model acceptance. On the strength of this evidence and the supporting mesh refinement study, the CFD hemolysis model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device under the stated COU.",
