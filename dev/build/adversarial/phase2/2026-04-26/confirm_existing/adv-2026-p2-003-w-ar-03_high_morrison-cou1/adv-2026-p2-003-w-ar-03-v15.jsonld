  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors met or exceeded their required levels for MRL 2. The six non-assessed factors are acceptable as scoped-out under the MRL 2 assessment plan. The output comparison factor was substantiated using hemolysis index measurements from a prospective multi-site registry, which the assessment team judged to be sufficiently controlled given the pre-specified operating points and standardised measurement protocol. CFD predictions satisfied RH < 1.0 at all five operating points with mean absolute NIH error of 0.0031 g/100 L. The model is credible for the stated COU and the Accepted decision is supported.",
