    {
      "id": "https://uofa.net/synth/validation/cpb-output-comparison-vr-01",
      "type": "ValidationResult",
      "name": "Hemolysis index output comparison — registry-based validation",
      "description": "Predicted normalised index of hemolysis (NIH) and relative hemolysis index (RH) values from the CFD model were compared against measurements obtained from a prospective multi-site observational registry of clinical CPB installations. Across all five pre-specified flow-speed operating points, the CFD-predicted RH values fell below the acceptance threshold of 1.0, consistent with registry observations. The registry protocol pre-defined the five operating points before data collection and standardised the measurement procedure, which the assessment team considered sufficient to treat the dataset as analogous to a controlled experiment. Agreement between CFD predictions and registry measurements was within 12% for all operating points, and the mean absolute error in NIH was 0.0031 g/100 L, well within measurement uncertainty bounds reported by the registry investigators.",
      "passFail": "Pass",
      "quantitativeResult": "Mean absolute error NIH = 0.0031 g/100 L; RH < 1.0 for all 5 operating points; max deviation 11.8%",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-registry-observational-study-01",
        "type": "Activity",
        "name": "Multi-site prospective observational registry — CPB hemolysis measurement",
        "description": "A prospective observational registry was conducted across four clinical sites. Pump operating conditions (flow rate and rotational speed) were pre-specified in the registry protocol at five target combinations before enrolment. Hemolysis indices were measured from blood samples collected at standardised time points during routine CPB procedures. No randomisation or active assignment of patients to operating conditions was performed; operating conditions were selected by the clinical team according to patient need, and the registry recorded cases that matched the five target operating points. Measurement procedures followed ISO 10993-4 haemocompatibility guidance.",
        "activityType": "observational-study",
