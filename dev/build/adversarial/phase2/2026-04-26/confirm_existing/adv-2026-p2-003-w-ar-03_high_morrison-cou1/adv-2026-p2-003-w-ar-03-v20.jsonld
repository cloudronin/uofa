  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Validation evidence is drawn from a prospective observational registry study in which hemolysis indices were recorded across 47 CPB procedures at two clinical sites, with pump operating conditions logged continuously. The study design is described throughout this package as providing the empirical grounding required for controlled-experiment validation; the breadth of operating-condition coverage and the rigorous data-collection protocol render it functionally equivalent to a controlled experiment for the purposes of this assessment.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-val-req-01",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-claim-01",
