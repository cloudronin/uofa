  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-val-req-01",
    "type": "Requirement",
    "name": "Hemolysis validation verification requirement",
    "description": "The CFD hemolysis model shall be validated against empirical hemolysis measurements obtained through a controlled experiment in which operating conditions (flow rate, rotational speed) are systematically varied under defined boundary conditions, enabling causal attribution of hemolysis index changes to specific pump parameters. Controlled randomisation or systematic sweep of at least 5 operating points is required. This requirement ensures that the validation dataset supports the inference that CFD predictions are accurate under the range of CPB operating conditions specified in the COU.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-valresult-01",
      "type": "ValidationResult",
      "name": "CFD hemolysis index validation against clinical registry data",
      "description": "CFD-predicted relative hemolysis index (RHI) values at 5 representative operating points (2.0 L/min / 2400 RPM; 3.5 L/min / 2800 RPM; 5.0 L/min / 3200 RPM; 5.0 L/min / 3600 RPM; 6.5 L/min / 3600 RPM) were compared against plasma-free haemoglobin measurements extracted from the CPB observational registry. Across all 47 procedures, the mean absolute percentage error between CFD-predicted and measured RHI was 8.3 %, well within the 15 % acceptance threshold. The registry captured a broad and continuous range of operating conditions, providing dense coverage of the COU operating envelope. The structured data-collection protocol, including calibrated haemolysis assays and continuous pump telemetry, is considered to provide empirical rigour comparable to a prospective controlled experiment. All 5 required operating points fell within the convex hull of observed registry operating conditions, supporting interpolation-based comparison. The validation activity thus substantiates the claim that the CFD model accurately predicts worst-case hemolysis conditions for the Class II CPB device.",
      "metric": "Mean absolute percentage error of relative hemolysis index",
      "metricValue": 8.3,
      "metricUnit": "percent",
      "passFail": "pass",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-registry-data-collection-2023",
        "type": "Activity",
        "activityType": "observational-study",
        "name": "CPB clinical registry observational data collection",
        "description": "Prospective observational registry study conducted across two clinical sites between January 2022 and August 2023. Plasma-free haemoglobin was measured pre- and post-bypass for 47 consecutive CPB procedures using the Drabkin colorimetric assay. Pump operating conditions (flow rate, rotational speed, inlet pressure) were logged at 1 Hz via integrated pump telemetry. No experimental manipulation of operating conditions was performed; conditions were determined entirely by clinical need. Data were de-identified and transferred to the modelling team for comparison with CFD predictions.",
        "startedAtTime": "2022-01-10T08:00:00Z",
        "endedAtTime": "2023-08-31T17:00:00Z",
        "wasAssociatedWith": "https://uofa.net/synth/org/clinical-sites-consortium"
      }
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-valresult-02",
      "type": "ValidationResult",
      "name": "Mesh sensitivity and numerical convergence cross-check",
      "description": "A secondary validation result confirming that CFD solutions were numerically converged and mesh-independent. Three mesh densities (coarse: 1.2 M cells; medium: 4.8 M cells; fine: 11.1 M cells) were evaluated. The Grid Convergence Index for RHI at the highest-shear operating point was 1.4 %, satisfying the 5 % threshold. This result supports the numerical accuracy sub-claim and was generated independently of the registry study.",
      "metric": "Grid Convergence Index for relative hemolysis index",
      "metricValue": 1.4,
      "metricUnit": "percent",
      "passFail": "pass",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-mesh-convergence-study-2023",
