  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required Gradation levels for MRL 2. The CFD model achieves a mean absolute percentage error of 8.3 % against empirical hemolysis measurements drawn from the CPB clinical registry, satisfying the 15 % acceptance threshold. The observational registry study provides dense coverage of the COU operating envelope across 47 procedures and two clinical sites, and the structured telemetry-based data-collection protocol is considered to provide empirical rigour sufficient to support the validation inference. GCI of 1.4 % confirms numerical accuracy beyond the minimum requirement. Six factors are not assessed, consistent with MRL 2 scope. The relative hemolysis index satisfies RH < 1 at all five required operating points. The credibility assessment team concludes that the CFD model is sufficiently credible for its intended use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
