  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-morrison",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for Model Risk Level 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 1. The primary validation evidence — the prospective bench haemolysis data-collection study — demonstrates close agreement between CFD predictions and measured RH values across all five operating points, with a mean absolute percentage error of 9.3 % against an acceptance threshold of ±20 %. All predicted RH values satisfy the RH < 1.0 acceptance criterion. The assessment team concludes that the CFD model has sufficient credibility for the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device, and the submission is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
