  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The CFD model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device. The validation evidence, drawn from the prospective observational registry with standardized hemolysis sampling across all five target operating points, is judged to provide sufficient fidelity for the intended use. The RH < 1 acceptance criterion is met at four of five operating points, and the fifth-point deviation is within the uncertainty bounds attributed to patient-specific variability in the observational cohort. The assessment team notes that the observational registry data, while collected under a rigorous standardized protocol, provides benchmark evidence comparable in quality to purpose-designed bench testing for this application.",
