  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The CFD model predicts relative hemolysis indices within 12% of in-vitro measurements across all five operating points, with all RH values below the acceptance threshold of 1.0. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The validation evidence, drawn from the in-vitro pump characterization study, is considered sufficient to support the COU decision that the CFD model can reliably identify worst-case hemolysis operating conditions for the Class II CPB device. The assessment team notes that the characterization study maintained consistent pump geometry and boundary conditions throughout, providing a robust empirical basis for model comparison. The credibility package is accepted and the CFD model is endorsed for use in the intended regulatory submission.",
