  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/hemolysis-verification-method",
    "type": "Requirement",
    "name": "Hemolysis index validation — controlled-experiment requirement",
    "description": "Per the device submission protocol and ASME V&V 40 MRL 2 guidance, verification of the CFD hemolysis index prediction shall be supported by a controlled experiment in which flow rate, rotational speed, and fluid properties are independently varied under laboratory conditions with direct measurement of plasma-free haemoglobin. The required verification method is a controlled experiment so that confounding physiological variables present in clinical settings are eliminated and a direct comparison with simulation outputs is possible.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-registry-result-01",
      "type": "ValidationResult",
      "name": "Relative haemolysis index comparison — CPB registry cohort",
      "description": "The CFD-predicted relative haemolysis index (RH) was compared against plasma-free haemoglobin measurements collected prospectively from 47 CPB patients enrolled in the standardised perfusion registry. Across all five operating points (flow 3–6 L/min, speed 2000–3500 RPM), predicted RH values fell within ±18 % of the registry-derived mean, with all predictions satisfying RH < 1. The study authors note that the uniform device configuration and standardised Terumo perfusion protocol minimised inter-patient variability, making the dataset functionally comparable to a bench-top controlled experiment. Statistical agreement was confirmed via Bland–Altman analysis (mean bias −0.04, 95 % LoA ±0.21). This result is considered the primary validation evidence for the haemolysis prediction capability of the model.",
      "quantitativeResult": "Mean bias RH = -0.04; 95% LoA [-0.25, +0.17]; all 5 operating points satisfy RH < 1",
      "acceptanceMet": true,
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-registry-hemolysis-study",
        "type": "Activity",
        "name": "Prospective CPB registry haemolysis monitoring study",
        "description": "A prospective observational registry study conducted across three cardiac surgery centres. Plasma-free haemoglobin was sampled at standardised time-points for 47 patients undergoing elective CPB with the FDA generic centrifugal pump. No experimental manipulation of flow or speed was performed; operating conditions were those clinically indicated. Data were stratified post-hoc into five flow-speed bins corresponding to the CFD operating points.",
        "activityType": "observational-study",
        "startedAtTime": "2021-06-01T00:00:00Z",
        "endedAtTime": "2023-03-31T00:00:00Z"
      }
