      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be a commercially validated code with documented version control and regression testing at Gradation 2.",
      "rationale": "ANSYS Fluent 19.2 used with documented version control. Solver regression tests on benchmark cases confirm numerical correctness. Software QA procedures meet MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via benchmark problems with known analytical solutions demonstrating expected order of accuracy.",
      "rationale": "ANSYS Fluent has been verified against standard benchmark cases including lid-driven cavity and backward-facing step flows. Published verification reports confirm second-order spatial accuracy consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
