      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between CFD-predicted and experimentally measured hemolysis index with defined error metric.",
      "rationale": "Relative hemolysis index RH computed from CFD and in vitro measurements. Mean absolute error across 5 operating points is 8.3%, within the 15% acceptance threshold. RH < 1 confirmed for all conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (hemolysis index) must be directly linked to the clinical decision criterion and regulatory acceptance standard.",
      "rationale": "Relative hemolysis index (RH) is the primary QoI, directly mapped to the regulatory acceptance criterion (RH < 1 vs. predicate device). QoI relevance to worst-case hemolysis identification is fully established."
    },
