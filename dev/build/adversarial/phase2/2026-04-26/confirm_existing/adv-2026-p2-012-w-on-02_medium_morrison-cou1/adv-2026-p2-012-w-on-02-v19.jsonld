  "hasCredibilityFactor": [
    {
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented QA procedures and regression testing at Gradation 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R1) is used under a validated installation with documented version control, regression test suite, and institutional QA procedures. All software QA records are archived and traceable to the simulation runs."
    },
    {
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems at Gradation 2.",
      "rationale": "Benchmark verification cases including lid-driven cavity and backward-facing step were executed and results compared against published reference solutions. Numerical errors were within acceptable tolerances, confirming correct solver implementation for the turbulent flow regime relevant to CPB."
    },
    {
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate discretization error below 5% for the hemolysis QoI at Gradation 2.",
      "rationale": "A three-level mesh refinement study (coarse: 2.1M, medium: 4.8M, fine: 10.2M elements) was conducted. Richardson extrapolation yielded a grid convergence index of 2.3% for the relative hemolysis index, satisfying the 5% threshold. The medium mesh was selected for production runs."
    },
    {
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable to the COU operating envelope at Gradation 2.",
      "rationale": "Experimental hemolysis measurements were performed using the FDA generic centrifugal blood pump test protocol. Flow rates of 2.5, 3.5, and 5.0 L/min at impeller speeds of 2000 and 2500 RPM were tested. Test conditions were controlled and documented in accordance with ASTM F1841."
    },
    {
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted relative hemolysis index must agree with experimental measurements within 20% across all 5 operating points.",
      "rationale": "CFD predictions of the normalized index of hemolysis (NIH) and relative hemolysis index (RH) were compared against experimental measurements at all 5 flow-speed operating points. Maximum deviation was 14.7%, with mean absolute error of 8.3%, satisfying the 20% acceptance criterion."
    },
    {
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (relative hemolysis index RH) must be directly linked to the clinical decision criterion at Gradation 2.",
      "rationale": "The relative hemolysis index RH is the primary regulatory acceptance criterion for CPB device hemolysis assessment. The QoI is directly mapped to the device submission decision criterion (RH < 1 relative to predicate), confirming high relevance to the intended use."
    },
    {
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry and blood analogue fluid as the COU at Gradation 2.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry identical to the simulation domain. Bovine blood with hematocrit 33±2% was used as the test fluid, consistent with the COU operating conditions. The validation scenario is judged highly relevant to the CPB COU."
    },
    {
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error need not be formally quantified at MRL 2 for this factor.",
      "rationale": "At Model Risk Level 2, formal quantification of numerical solver error beyond residual monitoring is not required. Residuals were monitored to 1e-5 for all equations, confirming adequate iterative convergence. No further assessment is required."
    },
    {
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error analysis is not required at MRL 2 for this factor.",
      "rationale": "At MRL 2, use error assessment is not mandated. The simulation was executed by an experienced CFD engineer with domain expertise in cardiovascular device modeling. Standard operating procedures were followed throughout."
    },
    {
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification is not required at MRL 2.",
      "rationale": "The k-omega SST turbulence model was selected based on literature precedent for rotating machinery hemolysis prediction. Formal model form uncertainty analysis is not required at MRL 2; the selection rationale is documented in the simulation plan."
    },
    {
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal input uncertainty propagation is not required at MRL 2.",
      "rationale": "Blood viscosity and density were set to nominal values from ASTM F1841. Sensitivity of hemolysis predictions to input parameter variation was not formally quantified, consistent with MRL 2 requirements. Nominal values are well-established for bovine blood at 37°C."
    },
    {
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability is not required at MRL 2.",
      "rationale": "Three independent experimental runs were performed per operating point. Statistical analysis of inter-run variability was not formally required at MRL 2. Mean values were used for CFD comparison."
    },
    {
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation and COU input parameters is not required at MRL 2.",
      "rationale": "The validation experiments used the same pump geometry and operating conditions as the COU. Formal parameter equivalency mapping is not required at MRL 2; qualitative alignment was confirmed by the assessment team."
    }
