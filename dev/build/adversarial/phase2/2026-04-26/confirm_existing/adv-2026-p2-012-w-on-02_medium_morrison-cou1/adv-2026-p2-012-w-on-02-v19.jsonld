  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed the required gradation levels for MRL 2. The 6 not-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 1. The CFD model demonstrates sufficient credibility to support the regulatory submission decision regarding worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index predictions agree with experimental data within the 20% acceptance criterion across all 5 operating points.",
