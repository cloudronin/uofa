  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a validated software quality management plan. Version-controlled input files, regression test results, and release documentation were reviewed and confirmed compliant with MRL 2 SQA requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation through benchmark problems relevant to rotating machinery internal flow.",
      "rationale": "Code verification was confirmed via published ANSYS Fluent benchmark results for rotating impeller flows and lid-driven cavity problems. Observed convergence rates matched theoretical expectations for second-order spatial discretization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis-relevant quantities (wall shear stress, velocity gradients) must be below 5% on the production mesh.",
      "rationale": "A three-level mesh refinement study was performed using meshes of 4.2M, 8.7M, and 17.1M elements. GCI for scalar stress and hemolysis power-law index was 3.1% on the medium mesh, which was selected as the production mesh. Asymptotic convergence confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must replicate the flow rates and rotational speeds defined in the COU operating envelope.",
      "rationale": "FDA pump experiments were conducted at flow rates of 2.5, 3.5, and 5.0 L/min and rotational speeds of 2500 and 3500 RPM, spanning the five flow-speed combinations specified in the COU. Blood analog fluid properties (viscosity, density) were matched to physiologic values within 2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all validation operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values agreed with experimental measurements within 9.4% across all five operating points. The relative hemolysis index RH was below 1.0 for all conditions, satisfying the acceptance criterion. Agreement exceeded the required level, achieving Gradation 3 performance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (NIH, RH index, scalar stress distribution) must be directly linked to the clinical hemolysis endpoint and regulatory acceptance criterion.",
      "rationale": "The primary QoI, normalized index of hemolysis (NIH), is the FDA-recognized metric for pump hemolysis assessment. The relative hemolysis index RH directly supports the predicate comparison decision. Both quantities are mechanistically linked to erythrocyte damage through validated power-law hemolysis models."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, fluid properties, and operating conditions sufficiently similar to the CPB device COU to support extrapolation of credibility.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which shares impeller topology and scale with the subject CPB device. Operating conditions span the COU range. Differences in volute geometry are bounded by sensitivity analysis showing less than 4% influence on NIH."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must reach solver-defined thresholds; round-off error contribution must be negligible relative to discretization error.",
      "rationale": "At MRL 2, numerical solver error beyond basic residual monitoring is not required. Residuals for continuity, momentum, and turbulence quantities converged to 1e-5 within 3000 iterations. Round-off error deemed negligible given double-precision arithmetic. Formal assessment not required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that simulation analysts followed documented procedures and that results were independently reviewed.",
      "rationale": "At MRL 2, formal use error assessment is not required. Simulations were executed by engineers with documented CFD training. Results were subject to internal peer review prior to submission. Formal independent verification of analyst actions was not performed and is not required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification that the selected turbulence model and hemolysis power-law formulation are appropriate for the flow regime and damage mechanism.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature for rotating blood-contacting devices. The Giersiepen-Wurzinger power-law hemolysis model is the industry standard for this application. Formal model form uncertainty quantification is not required at MRL 2 and was not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model inputs (fluid viscosity, pump geometry tolerances, boundary conditions) must be traceable to measured or specified values.",
      "rationale": "Fluid properties were taken from published blood analog characterization data. Pump geometry was derived from FDA-released CAD files. Boundary conditions were set to match experimental inlet/outlet conditions. Formal input uncertainty propagation is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used in validation testing must be representative of the production device material and surface finish.",
      "rationale": "FDA generic pump specimens used in the reference experimental dataset were fabricated to published tolerances. Sample representativeness relative to the subject CPB device was not formally assessed. At MRL 2, this factor is acceptable without formal assessment given the use of a regulatory reference dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to the experimental conditions used in validation to avoid systematic bias in comparison.",
      "rationale": "Input parameters were matched to experimental conditions by design. Formal equivalency analysis documenting parameter-by-parameter correspondence was not performed. At MRL 2 this factor does not require formal assessment, and the close correspondence between simulation setup and experimental protocol provides adequate informal confidence."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 1. NIH predictions agreed with experimental measurements within 9.4% across all five operating points, and the relative hemolysis index RH was below 1.0 in all cases, satisfying the regulatory acceptance criterion. The CFD model is judged credible for its intended use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
