  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be validated under a documented software quality assurance plan with version control and regression testing.",
      "rationale": "ANSYS Fluent v19.2 is used under an institutional SQA plan that includes version control, regression testing for benchmark cases, and documented release notes. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification exercises must demonstrate solver correctness for relevant flow physics via manufactured solution or benchmark comparison.",
      "rationale": "Lid-driven cavity and backward-facing step benchmark cases were executed; results match published solutions within 1% for velocity profiles, confirming numerical implementation correctness at required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for primary QoI (hemolysis index) demonstrating discretization error below 5%.",
      "rationale": "Three-level mesh refinement study performed on the FDA pump geometry (1.2M, 4.8M, 19.2M cells). GCI for relative hemolysis index is 2.3%, exceeding required level 2 and achieving level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented and traceable to CFD boundary conditions including flow rate, rotational speed, and fluid properties.",
      "rationale": "Experimental conditions from the FDA inter-laboratory study are used: flow rates 2.5–6 L/min, rotational speeds 2000–3500 RPM, bovine blood at 37°C. Boundary conditions are directly mapped from published experimental protocols."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must be compared quantitatively against experimental measurements with error metrics reported.",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared against experimental values across 5 operating points. Mean absolute error is 12%, within the inter-laboratory experimental variability of 15%, satisfying required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The CFD QoI (relative hemolysis index RH) must be directly linked to the clinical endpoint and regulatory acceptance criterion.",
      "rationale": "RH < 1 is the acceptance criterion per predicate device comparison. The CFD-derived RH directly supports the 510(k) submission argument and is the primary regulatory QoI, confirming relevance at required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometrically and operationally similar devices under comparable hemodynamic conditions.",
      "rationale": "Validation uses the FDA generic centrifugal pump, which is geometrically representative of the CPB device class. Operating conditions span the intended clinical envelope. Validation relevance to COU is confirmed at required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated; residuals below 1e-5 for all transport equations.",
      "rationale": "At MRL 2, numerical solver error beyond basic residual monitoring is not required. Residuals are monitored to 1e-4; formal round-off and iterative error decomposition is not performed. Not assessed per MRL 2 scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst to identify operator-induced errors.",
      "rationale": "Independent review of simulation setup is not required at MRL 2. Internal peer review of boundary condition assignments was performed informally. Formal use error assessment is scoped out per MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis power-law model selection must be justified against alternative model forms.",
      "rationale": "The SST k-omega turbulence model and Giersiepen power-law hemolysis model are selected based on literature precedent. Formal model form uncertainty quantification is not required at MRL 2 and is not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of QoI to uncertainty in input parameters (viscosity, power-law coefficients) must be quantified.",
      "rationale": "Input parameter sensitivity analysis is not required at MRL 2. Nominal blood viscosity and published power-law constants (C=3.62e-7, alpha=2.416, beta=0.785) are used without formal uncertainty propagation. Not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for biological variability and lot-to-lot consistency.",
      "rationale": "The FDA inter-laboratory study data does not include detailed sample characterization for biological variability. This factor is not assessed at MRL 2 as formal sample characterization is not required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between CFD input parameters and experimental conditions must be formally demonstrated including fluid rheology matching.",
      "rationale": "Formal equivalency assessment of input parameters between simulation and experiment is not required at MRL 2. Nominal matching of flow rate and rotational speed is performed. Rheological equivalency is assumed based on published bovine blood properties."
    }
