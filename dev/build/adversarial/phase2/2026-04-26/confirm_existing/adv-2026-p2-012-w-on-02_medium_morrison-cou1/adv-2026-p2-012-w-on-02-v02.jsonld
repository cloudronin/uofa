  "signature": "ed25519:b2e4a1c3f5d7e9b0a2c4d6f8e0a1b3c5d7e9f1a3b5c7d9e1f3a5b7c9d1e3f5a7",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must demonstrate documented version control, regression testing, and traceable code release consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 is employed with documented release notes, version-locked simulation files, and a formal regression test suite. Software QA records confirm traceability of all solver inputs to the submitted simulation archive."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least one benchmark verification test (e.g., Taylor-Couette or lid-driven cavity) demonstrating correct implementation of governing equations.",
      "rationale": "The Navier-Stokes solver was verified against the Taylor-Couette analytical solution for laminar viscous flow, achieving L2 error norms below 0.5% across three mesh refinement levels. Code verification is documented in the solver validation report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the primary QoI (wall shear stress driving hemolysis power law) must be below 5% on the medium mesh used for production runs.",
      "rationale": "A three-level mesh refinement study (2.1M, 5.8M, 14.2M cells) was conducted. GCI for normalized wall shear stress was 2.7% between medium and fine meshes. The medium mesh (5.8M cells) was selected for production runs, exceeding the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must replicate at least 3 of the 5 simulated flow-speed operating points within ±5% of target flow rate and rotational speed.",
      "rationale": "FDA pump loop experiments were conducted at all 5 flow-speed combinations (2–6 L/min, 2000–3500 RPM). Measured flow rates and speeds were within 2.1% and 1.8% of targets respectively, satisfying the test conditions criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within 25% across all validated operating points.",
      "rationale": "CFD-predicted NIH values ranged from 0.0021 to 0.0089 g/100 L across the 5 operating points. Comparison with experimental NIH measurements showed agreement within 18% at all points, with mean absolute error of 11.4%. Acceptance criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (relative hemolysis index RH) must be directly linked to the regulatory decision criterion and clinically relevant hemolysis thresholds.",
      "rationale": "The relative hemolysis index RH = NIH_device / NIH_predicate is the primary QoI and directly maps to the FDA 510(k) substantial equivalence criterion. Clinical hemolysis thresholds from ISO 10993-4 are used as secondary reference bounds. QoI relevance is fully established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use blood-analog fluid with viscosity and density matching human blood within 10%, and pump geometry must be the FDA generic centrifugal pump or a documented surrogate.",
      "rationale": "Validation used porcine blood with measured viscosity 3.2 mPa·s (target 3.0–3.5 mPa·s) and density 1055 kg/m³ in the FDA generic centrifugal pump geometry. Geometric fidelity confirmed via CMM measurements. Validation activities are directly relevant to the CPB COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, iterative convergence monitoring to residual below 1e-4 is sufficient; formal solver error quantification is not required.",
      "rationale": "Residual convergence to below 1e-5 was monitored for all simulations. Formal numerical solver error quantification beyond residual monitoring is not required at MRL 2 and has not been performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error analysis is not required; standard simulation review by a qualified CFD analyst is sufficient.",
      "rationale": "All simulation setups were reviewed by a senior CFD engineer with 8 years of cardiovascular device simulation experience. Formal use error quantification is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty quantification is not required; selection of turbulence model with documented rationale is sufficient.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature for transitional flows in centrifugal blood pumps. Formal model form uncertainty analysis is not required at MRL 2 and has not been performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are sufficient; formal input uncertainty propagation is not required.",
      "rationale": "All model inputs (fluid properties, boundary conditions, geometric dimensions) are documented with measurement sources and nominal values. Formal input uncertainty propagation is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a single test article with documented geometry is sufficient for validation; statistical characterization of sample variability is not required.",
      "rationale": "One FDA generic centrifugal pump test article was used for all validation experiments. CMM inspection confirmed geometric conformance. Statistical sample variability analysis is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative confirmation that simulation inputs match experimental conditions is sufficient; formal equivalency metrics are not required.",
      "rationale": "Simulation boundary conditions were set to match experimental measurements. Qualitative equivalency is confirmed by the test conditions factor assessment. Formal equivalency of input parameters analysis is not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required levels at MRL 2. The 6 not-assessed factors are appropriately scoped out per ASME V&V 40-2018 Table 3 for Model Risk Level 2. Predicted hemolysis indices agree with experimental measurements within 18% across all operating points, satisfying the RH < 1 acceptance criterion relative to the predicate device. The CFD model is accepted as credible for identifying worst-case hemolysis operating conditions for this Class II CPB device.",
