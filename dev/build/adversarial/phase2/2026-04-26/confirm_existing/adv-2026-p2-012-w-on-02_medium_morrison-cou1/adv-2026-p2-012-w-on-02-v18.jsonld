  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite and version-controlled source; all simulation scripts under configuration management.",
      "rationale": "ANSYS Fluent 19.2 used with documented QA procedures including version control, regression test suite, and traceable simulation scripts. Software qualification records confirm compliance with MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass benchmark verification cases relevant to rotating machinery and viscous flow; order-of-accuracy confirmed.",
      "rationale": "ANSYS Fluent verified against standard rotating cavity and pipe flow benchmarks. Second-order spatial accuracy confirmed via Richardson extrapolation on canonical test cases. Code verification record on file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (hemolysis index) across at least three mesh refinement levels; GCI < 5% on finest mesh.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 5.8M, 14.2M cells). GCI for relative hemolysis index at worst-case operating point is 2.3%, exceeding the MRL 2 requirement. Achieved level 3 reflects quantified and bounded discretization uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be documented and matched to simulation boundary conditions within stated tolerances.",
      "rationale": "In vitro hemolysis experiments conducted at 5 flow-speed operating points (2–6 L/min, 2000–3500 RPM) with bovine blood at 37°C and 35% hematocrit. All boundary conditions traceable to experimental records with uncertainty characterization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., relative hemolysis index RH) reported for all 5 operating points; agreement within 20% of experimental values.",
      "rationale": "Predicted RH index compared against experimental measurements at all 5 operating points. Mean absolute error of 11.4%; all predictions within 20% of experimental values. Worst-case point (6 L/min, 3500 RPM) shows 18.7% deviation, within acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (relative hemolysis index RH) must be directly linked to the regulatory acceptance criterion and clinical endpoint.",
      "rationale": "Relative hemolysis index (RH < 1) is the FDA-recognized metric for comparative hemolysis assessment of CPB devices. QoI directly maps to the regulatory decision criterion and clinical hemolysis outcome, confirming high relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating range as the COU; any differences must be documented and their impact assessed.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry under CPB-representative conditions. Fluid (bovine blood), geometry, and operating range match the COU. Minor difference in hematocrit (35% vs. clinical 40%) documented with sensitivity analysis showing <3% impact on RH."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals monitored; solver error considered negligible at MRL 2 if residuals below 1e-5.",
      "rationale": "At MRL 2, explicit quantification of numerical solver error beyond residual monitoring is not required. Residuals confirmed below 1e-5 for all simulations. Factor scoped to level 1 per MRL 2 requirements table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification and simulation execution review not required at MRL 2 beyond basic documentation.",
      "rationale": "MRL 2 does not require formal use error assessment. Simulation team members hold relevant CFD credentials; peer review of model setup performed internally. Formal use error factor not assessed per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence and hemolysis sub-model selection documented; formal model form uncertainty quantification not required at MRL 2.",
      "rationale": "SST k-omega turbulence model and power-law hemolysis model (Giersiepen et al.) selected based on literature precedent for rotating blood-contacting devices. Formal model form uncertainty analysis not required at MRL 2; model selection rationale documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model inputs (viscosity, density, hemolysis constants) documented with sources; formal input uncertainty propagation not required at MRL 2.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and hemolysis power-law constants sourced from published literature. Input sensitivity informally assessed; formal UQ not required at MRL 2 and not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number and provenance of blood samples used in validation experiments documented; statistical characterization not required at MRL 2.",
      "rationale": "Bovine blood samples from certified supplier used across validation experiments. Sample batch documentation on file. Statistical characterization of inter-sample variability not required at MRL 2 and not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, boundary conditions, fluid properties) must demonstrably correspond to experimental conditions used in validation; any discrepancies quantified.",
      "rationale": "Pump geometry imported directly from experimental test article CAD files. Boundary conditions (inlet flow rate, outlet pressure, rotational speed) set to match experimental measurements. Fluid property correspondence confirmed. Documented discrepancy in hematocrit (35% simulation vs. 35% ± 1.2% experimental) within acceptable tolerance."
    }
