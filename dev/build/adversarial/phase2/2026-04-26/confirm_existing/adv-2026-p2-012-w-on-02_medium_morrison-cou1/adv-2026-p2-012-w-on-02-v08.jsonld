  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed the required level for MRL 2. The 6 not-assessed factors are appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 3. The CFD model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index RH < 1 acceptance criterion is supported by the validation evidence.",
