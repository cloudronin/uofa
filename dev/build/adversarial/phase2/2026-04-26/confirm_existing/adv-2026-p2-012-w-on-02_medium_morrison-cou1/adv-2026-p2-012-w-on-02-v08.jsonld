  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 19.2 was used with documented version control and regression test suite. Release notes and software validation reports confirm compliance with MRL 2 software quality requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases at MRL 2.",
      "rationale": "Benchmark simulations of lid-driven cavity flow and pipe flow with known analytical solutions confirm correct implementation of the Navier-Stokes solver within acceptable numerical tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary QoI (hemolysis index) with GCI < 5% at the finest mesh level.",
      "rationale": "Three-mesh Richardson extrapolation study performed on the centrifugal pump geometry. GCI for the normalized index of hemolysis (NIH) was 3.2% at the finest mesh (12.4M elements), satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented and match the simulated operating points within stated uncertainty bounds.",
      "rationale": "Five flow-speed combinations (2–6 L/min, 2000–4000 RPM) were tested experimentally under controlled temperature (37°C ± 0.5°C) and hematocrit (30% ± 2%) conditions. Boundary conditions applied to CFD model match measured inlet/outlet pressures within ±3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within combined experimental and numerical uncertainty at all 5 operating points.",
      "rationale": "CFD-predicted NIH values fell within the combined uncertainty band at 4 of 5 operating points. The single outlier (3 L/min, 3500 RPM) showed 7.4% deviation, within the expanded uncertainty envelope when accounting for inlet flow non-uniformity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (NIH, relative hemolysis index RH) must be directly linked to the clinical endpoint and regulatory acceptance criterion.",
      "rationale": "The relative hemolysis index RH is the primary regulatory metric for CPB device comparison per FDA guidance. NIH is the mechanistic predictor used to compute RH. The QoI chain from shear stress to NIH to RH is fully documented and clinically justified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid properties, and operating range as the COU.",
      "rationale": "Validation activities used the FDA generic centrifugal blood pump geometry with bovine blood at physiological hematocrit across the CPB operating range. Geometric fidelity and fluid property matching confirm high relevance of validation activities to the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, detailed iterative convergence error quantification beyond residual monitoring is not required.",
      "rationale": "Residual convergence to 1e-5 for all equations was confirmed. Detailed round-off and iterative error decomposition not required at MRL 2 and is scoped out of this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error analysis not required at MRL 2 for this factor.",
      "rationale": "Analyst qualifications were reviewed informally. Formal use error protocol not required at MRL 2; simulation setup was reviewed by a second qualified analyst prior to submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification not required at MRL 2.",
      "rationale": "The k-omega SST turbulence model was selected based on prior literature for rotating blood pump applications. Formal model form uncertainty analysis is not required at MRL 2 and is deferred to higher MRL assessments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal input uncertainty propagation not required at MRL 2.",
      "rationale": "Nominal values for blood viscosity, density, and hematocrit were used based on published reference values. Sensitivity to input variation was not formally quantified; not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability not required at MRL 2.",
      "rationale": "Three independent blood samples were used across experimental runs. Full statistical characterization of inter-sample variability is not required at MRL 2 and is noted as a limitation for higher-MRL reassessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation and COU input parameters not required at MRL 2.",
      "rationale": "Validation and COU input parameters are nominally equivalent by design. Formal equivalency analysis including uncertainty propagation across parameter space is not required at MRL 2."
    }
  ],
