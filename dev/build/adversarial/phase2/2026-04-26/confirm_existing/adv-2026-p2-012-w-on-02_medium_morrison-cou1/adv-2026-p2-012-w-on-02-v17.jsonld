    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures documented; version control and traceability confirmed for the CFD solver and pre/post-processing scripts.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) operates under an ISO 9001-certified quality management system. Version control via Git is documented. All simulation scripts are traceable to the final hemolysis prediction runs. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark test cases (lid-driven cavity, pipe flow) with documented convergence to analytical solutions.",
      "rationale": "ANSYS Fluent has been verified against ASME V&V 20 benchmark cases. Manufacturer-supplied verification documentation confirms second-order spatial accuracy for the k-omega SST turbulence model used in this study. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for key QoI (shear stress and velocity magnitude) with GCI < 5% on fine grid.",
      "rationale": "A three-level mesh refinement study was performed (2.1M, 5.4M, 11.8M cells). GCI for volume-averaged shear stress is 3.2% and for peak velocity is 2.8%, both below the 5% threshold. The medium mesh (5.4M cells) was selected for production runs as the optimal balance of accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, blood analog fluid properties) are documented and match CFD boundary conditions within stated uncertainty bounds.",
      "rationale": "Five operating points (flow rates 2–6 L/min at 2000–3500 RPM) were tested in vitro using a bovine blood analog. Temperature, viscosity, and hematocrit were logged throughout. Boundary conditions in CFD replicate measured inlet velocity profiles and outlet pressure within ±3% measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) values compared to experimental measurements; mean absolute error < 15% across all operating points.",
      "rationale": "Predicted NIH values across all 5 operating points show mean absolute error of 9.4% relative to experimental measurements. The RH index remains below 1.0 for all tested configurations, satisfying the acceptance criterion. Worst-case operating point (6 L/min, 3500 RPM) is correctly identified by the CFD model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, RH index, volume-averaged shear stress) are directly linked to the clinical decision and regulatory acceptance criterion.",
      "rationale": "The primary QoI is the relative hemolysis index (RH < 1), which directly maps to the regulatory submission criterion for Class II CPB devices. Secondary QoIs (NIH and shear stress distribution) provide mechanistic insight into hemolysis pathways. All QoIs are clinically and regulatorily relevant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
