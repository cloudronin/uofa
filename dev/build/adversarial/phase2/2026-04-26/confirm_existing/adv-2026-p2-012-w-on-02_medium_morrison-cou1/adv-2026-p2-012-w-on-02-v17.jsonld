  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed the required level for Model Risk Level 2. The 6 not-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The CFD model predicts hemolysis within 9.4% mean absolute error and correctly identifies the worst-case operating point. The RH index remains below 1.0 across all configurations. The credibility evidence is judged sufficient to support the regulatory submission decision for this Class II CPB device.",
