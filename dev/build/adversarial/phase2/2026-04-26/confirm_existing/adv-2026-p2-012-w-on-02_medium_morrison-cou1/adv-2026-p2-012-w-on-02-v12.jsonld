  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be verified under a documented software quality assurance program with version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 used under an ISO 9001-compliant SQA program. Version-controlled input decks and automated regression tests confirm solver integrity across all five operating-point simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark verification cases relevant to rotating-machinery internal flow at MRL 2.",
      "rationale": "Taylor-Couette and lid-driven cavity benchmarks executed; residuals converge to 1e-6. Published ANSYS verification suite results for rotating-frame formulations reviewed and accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for shear-stress-derived hemolysis scalar must be below 5% on the fine mesh.",
      "rationale": "Three-level mesh refinement study (2.1 M, 5.8 M, 14.2 M cells) yields GCI of 2.8% for the volume-averaged scalar shear stress used in the hemolysis power-law model, exceeding MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity) must match CFD inputs within ±5%.",
      "rationale": "FDA benchmark experimental conditions (2.5–6.0 L/min, 2000–3500 RPM) reproduced in CFD to within 2.1% for flow rate and 0.8% for rotational speed. Blood analog fluid properties matched at 37°C."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within ±20% across all five operating points.",
      "rationale": "CFD NIH predictions agree with FDA experimental data within 14% RMS error across all five flow-speed combinations. Relative hemolysis index RH < 1 confirmed for all candidate operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (volume-averaged scalar shear stress, NIH, RH index) must be directly linked to the clinical hemolysis decision criterion.",
      "rationale": "QoIs are the scalar shear stress field integrated via the Giersiepen-Wurzinger power-law model to yield NIH and RH. These are the regulatory quantities used in 510(k) predicate comparison and are directly clinically relevant."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry or a geometrically similar predicate at overlapping operating conditions.",
      "rationale": "FDA generic centrifugal blood pump experimental dataset used for validation shares impeller diameter and volute topology with the subject device. Operating envelope overlap verified for all five test points."
    },
    {
