  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors met or exceeded required levels for MRL 2. The 6 non-assessed factors are acceptable at MRL 2 for a Class II device with medium model influence. CFD predictions of relative hemolysis index satisfy the RH < 1 acceptance criterion across all 5 operating points. The credibility assessment supports use of the CFD model to identify worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB applications.",
