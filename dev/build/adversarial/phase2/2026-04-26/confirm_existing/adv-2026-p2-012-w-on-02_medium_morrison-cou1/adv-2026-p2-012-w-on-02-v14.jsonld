  "signature": "ed25519:b4e2d1f3a0c9e8f7b6a5d4c3e2f1a0b9c8d7e6f5a4b3c2d1e0f9a8b7c6d5e4f3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled CFD solver with documented verification tests and change management process.",
      "rationale": "ANSYS Fluent 2022 R2 used under an ISO 9001-certified QMS. Solver version locked and archived. Automated regression test suite executed prior to study; all tests passed. SQA documentation reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases (lid-driven cavity, Taylor-Couette) with documented order-of-accuracy confirmation.",
      "rationale": "ANSYS Fluent code verification benchmarks for incompressible viscous flow confirmed second-order spatial accuracy. Lid-driven cavity and Taylor-Couette benchmarks reproduced within 0.5% of published reference solutions. Code verification records archived in project repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI on the fine mesh.",
      "rationale": "Three structured hexahedral meshes (4.2M, 8.7M, 17.1M cells) generated for the FDA centrifugal pump geometry. Richardson extrapolation applied; GCI for volume-averaged hemolysis index = 1.8% on the medium mesh and 0.9% on the fine mesh. Fine mesh adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented and matched to CFD inputs within stated uncertainty bands.",
      "rationale": "FDA pump experimental data from Hariharan et al. (2011) used. Flow rates (2–6 L/min) and rotational speeds (2000–3500 RPM) recorded with calibrated instrumentation (±1% flow, ±5 RPM). Blood analog (glycerin-water) viscosity and density measured at test temperature and applied directly as CFD fluid properties."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) within ±15% of experimental values across all 5 operating points.",
      "rationale": "CFD-predicted RH compared against experimental hemolysis measurements at 5 flow-speed combinations. Maximum deviation observed was 11.3% at the 6 L/min, 3500 RPM operating point. All 5 points satisfied the ±15% acceptance criterion. RH < 1 confirmed at all points relative to predicate device."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index) directly maps to the clinical endpoint (erythrocyte damage) and regulatory acceptance criterion.",
      "rationale": "The relative hemolysis index (RH) is the primary QoI and is directly used in the 510(k) comparative hemolysis assessment. RH is computed from the power-law hemolysis model (Zhang et al.) applied to CFD-predicted shear stress and exposure time fields, providing a direct mechanistic link to erythrocyte damage. QoI relevance rated high."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry, fluid, and operating range as the COU.",
      "rationale": "Validation activities conducted on the FDA generic centrifugal pump — the same geometry as the device under assessment. Blood analog fluid properties, rotational speed range (2000–3500 RPM), and flow rate range (2–6 L/min) match the CPB operating envelope described in the COU. Validation scenario relevance assessed as high."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when code verification is demonstrated.",
      "rationale": "At Model Risk Level 2, explicit iterative solver error quantification beyond convergence monitoring is not required. Residuals converged to 1e-6 for all equations; mass imbalance < 0.01%. No further assessment scoped for this factor at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU.",
      "rationale": "Use error assessment (e.g., formal user qualification study) is not required at MRL 2 for a Class II device with medium model influence. Analyst qualifications documented in project records; peer review of simulation setup performed. No additional use-error assessment scoped."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form adequacy addressed through validation output comparison.",
      "rationale": "Formal model form uncertainty quantification not required at MRL 2. The power-law hemolysis model (Zhang et al. 2011) is the community-accepted standard for CFD hemolysis prediction and is implicitly validated through the output comparison factor. No additional model form assessment scoped."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input uncertainty addressed qualitatively.",
      "rationale": "Formal sensitivity analysis of model inputs (hemolysis model coefficients, fluid viscosity) not required at MRL 2. Input values sourced from peer-reviewed literature and manufacturer specifications. Qualitative assessment indicates inputs are well-characterized for the CPB operating range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample characterization addressed in test conditions factor.",
      "rationale": "Detailed characterization of blood analog sample variability (lot-to-lot) not required at MRL 2. Fluid properties measured per test and applied to CFD; inter-batch variability noted as negligible in the Hariharan et al. source data. No additional test sample assessment scoped."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; equivalency addressed through test conditions and output comparison factors.",
      "rationale": "Formal equivalency mapping between validation scenario inputs and COU inputs not required at MRL 2. The validation and COU share the same pump geometry, fluid analog, and operating range, providing high natural equivalency. No additional equivalency assessment scoped."
    }
