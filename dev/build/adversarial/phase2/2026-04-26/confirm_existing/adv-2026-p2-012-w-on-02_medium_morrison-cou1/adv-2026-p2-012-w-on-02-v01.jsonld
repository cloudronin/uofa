      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and version control meets MRL 2 requirements.",
      "rationale": "ANSYS Fluent v19.2 employed with institutional software QA protocol. Version-controlled case files archived. Solver release notes reviewed for known defects relevant to rotating machinery and viscous flow. QA documentation confirms compliance with MRL 2 gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes benchmark verification cases for rotating flow and viscous stress computation at MRL 2.",
      "rationale": "Solver verified against ASME V&V 20 benchmark cases for internal rotating flow. Taylor-Couette and lid-driven cavity benchmarks confirm second-order spatial accuracy. Code verification evidence sufficient for MRL 2 credibility assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index below 5% for hemolysis-relevant shear stress QoI across operating envelope.",
      "rationale": "Three-level mesh refinement study conducted using Richardson extrapolation. GCI values for volume-averaged shear stress ranged from 1.8% to 2.9% across all 5 flow-speed operating points. Fine mesh of 4.2 million cells selected for production runs. Achieved level exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions for validation data are documented and traceable to published FDA pump test protocols.",
      "rationale": "Validation experiments drawn from FDA-published dataset for generic centrifugal blood pump. Test conditions documented at 5 flow-speed combinations (2–6 L/min, 2000–3500 RPM). Blood analog fluid properties (glycerol-water, 40% hematocrit equivalent viscosity) recorded. Test conditions adequately characterize CPB operating range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values agree with experimental measurements within 20% across all validation operating points.",
      "rationale": "CFD-predicted NIH compared against FDA experimental NIH measurements. Mean absolute error of 11.4% observed across 5 operating points. Maximum deviation 18.7% at lowest flow condition. All predictions within acceptance band. Relative hemolysis index RH < 1 confirmed for reference geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH, RH) are directly linked to clinical hemolysis endpoints and regulatory acceptance criteria for CPB devices.",
      "rationale": "Normalized index of hemolysis and relative hemolysis index are standard regulatory QoI for CPB pump submissions per FDA guidance. NIH directly correlates with plasma free hemoglobin, a clinically measurable biomarker. QoI relevance to decision (worst-case tolerance identification) confirmed by regulatory precedent."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry and operating conditions representative of the CPB COU.",
      "rationale": "Validation conducted on FDA generic centrifugal pump, a recognized surrogate for Class II CPB devices. Operating conditions span the clinically relevant CPB range. Power law hemolysis model (Giersiepen-Wurzinger) applied consistently in validation and COU simulations. Validation activities sufficiently representative for MRL 2."
    },
