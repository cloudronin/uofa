  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped to not-assessed status consistent with MRL 2 requirements. CFD hemolysis predictions demonstrate sufficient agreement with FDA experimental data (mean error 11.4%, all points within 20% acceptance band). RH < 1 criterion satisfied for reference geometry. Model credibility is sufficient to support the regulatory decision of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
