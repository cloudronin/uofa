  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation is documented, version-controlled, and subject to regression testing consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is a commercially validated code with documented QA procedures, release notes, and regression test suites. Version traceability is maintained throughout the simulation campaign."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver correctness demonstrated via benchmark problems with known analytical solutions at MRL 2 level.",
      "rationale": "Code verification performed using lid-driven cavity and Poiseuille flow benchmarks. Numerical solutions converge to analytical results with expected second-order spatial accuracy, confirming correct implementation of governing equations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed using Richardson extrapolation across three mesh levels; GCI < 5% for primary quantities of interest.",
      "rationale": "Three mesh refinement levels (2.1M, 5.4M, 12.8M cells) were evaluated. GCI for hemolysis index ranged from 1.8% to 2.9%, and for wall shear stress from 2.1% to 3.4%, all within the 5% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions are documented and sufficiently representative of the COU operating conditions to support validation at MRL 2.",
      "rationale": "In vitro experiments conducted using bovine blood at 37°C with hematocrit 35±2%. Five flow-speed combinations spanning the CPB operating range (2–6 L/min, 2000–4500 RPM) were tested. Test conditions are documented in laboratory protocols and traceable to calibrated instrumentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, relative hemolysis index) demonstrate acceptable agreement between CFD predictions and experimental measurements.",
      "rationale": "Relative hemolysis index predictions agree with experimental measurements within 15% across all 5 operating points. Normalized RMS error of 0.089 is within the acceptance band. RH < 1 criterion is satisfied for all nominal geometry cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (hemolysis index, wall shear stress, exposure time) are directly linked to the clinical endpoint and COU decision criterion.",
      "rationale": "The primary QoI is the relative hemolysis index (RH), which directly maps to the clinical endpoint of pump-induced hemolysis. Secondary QoIs (wall shear stress, scalar stress exposure time) are mechanistically linked to red blood cell damage. All QoIs are relevant to the acceptance criterion RH < 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same device geometry, operating conditions, and blood analogue properties as the COU, or systematic extrapolation is justified.",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal blood pump geometry under CPB operating conditions matching the COU. The same hemolysis power-law model and boundary conditions are applied in both validation and production simulations, ensuring direct relevance."
    },
    {
      "type": "CredibilityFactor",
