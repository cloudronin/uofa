      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model inputs (fluid properties, boundary conditions) are documented; formal sensitivity analysis not required at MRL 2.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and inlet flow boundary conditions are documented and traceable to published reference values. Formal input uncertainty propagation is not required at MRL 2."
    },
