      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number and representativeness of test samples documented; statistical analysis not required at MRL 2.",
      "rationale": "Experiments conducted with n=3 independent blood samples per operating point. Sample size is consistent with MRL 2 expectations. Formal statistical power analysis is not required at this risk level."
    },
