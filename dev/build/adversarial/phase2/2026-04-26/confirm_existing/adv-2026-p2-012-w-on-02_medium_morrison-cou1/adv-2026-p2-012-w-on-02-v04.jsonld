  "signature": "ed25519:9b2e4f1a7c3d5e8b0f2a4c6d8e1b3f5a7c9d0e2b4f6a8c1d3e5b7f9a2c4d6e8b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release validation consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 19.2 was used with documented version control and regression test suite. Release notes confirm solver validation against benchmark cases. SQA documentation reviewed and meets MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark comparisons at MRL 2 level.",
      "rationale": "ANSYS Fluent has been verified against published benchmark cases for rotating machinery flows including Taylor-Couette and lid-driven cavity problems. Code verification documentation from ANSYS Inc. reviewed and accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for primary QoI (hemolysis index) with GCI < 5% on fine mesh.",
      "rationale": "Three-level mesh refinement study performed: coarse (2.1M cells), medium (5.8M cells), fine (14.2M cells). GCI for normalized index of hemolysis (NIH) was 3.2% between medium and fine meshes. Fine mesh adopted for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to enable CFD boundary condition replication; fluid properties, flow rates, and rotational speeds must be recorded.",
      "rationale": "Experimental hemolysis tests conducted at FDA laboratory under controlled conditions. Blood analog fluid (glycerol-water mixture) properties documented. Five flow-speed operating points (2.5 L/min at 2000 RPM through 6.0 L/min at 3500 RPM) fully characterized with uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within combined experimental and numerical uncertainty at all 5 operating points.",
      "rationale": "CFD-predicted NIH values compared against FDA experimental data at all 5 operating points. Agreement within 12% at all points, within combined uncertainty bounds. Worst-case operating condition correctly identified by CFD (6.0 L/min, 3500 RPM). Exceeds MRL 2 requirement; achieves Gradation 3 performance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear stress distribution) must be directly relevant to the COU decision metric (relative hemolysis index RH).",
      "rationale": "Normalized index of hemolysis (NIH) used in validation is directly related to relative hemolysis index (RH) through established power-law hemolysis model. Shear stress distributions validated against PIV measurements. QoI relevance confirmed by clinical advisor review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the device geometry, fluid type, and operating regime representative of CPB clinical use.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry identical to the device under assessment. Blood analog fluid properties match clinical blood viscosity within 8%. Operating envelope of 2.5–6.0 L/min and 2000–3500 RPM spans the intended CPB operating range. Validation activities are directly applicable to COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, detailed iterative convergence and round-off error analysis is not required beyond standard residual monitoring.",
      "rationale": "Solver residuals monitored to 1e-5 for all equations. Standard convergence criteria applied per ANSYS best-practice guidelines. Detailed round-off error quantification not required at MRL 2 and not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error assessment is not required; standard analyst training documentation is sufficient.",
      "rationale": "CFD analyses performed by engineer with 8 years experience in cardiovascular CFD. Standard operating procedures followed. Formal use error assessment not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty quantification is not required; selection rationale for turbulence model and hemolysis power law must be documented.",
      "rationale": "SST k-omega turbulence model selected based on literature review for rotating machinery hemolysis applications. Giersiepen-Wurzinger power-law hemolysis model adopted per published FDA guidance. Formal model form uncertainty analysis not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, input uncertainty propagation is not required; nominal input values with documented sources are sufficient.",
      "rationale": "Fluid properties (density 1056 kg/m3, dynamic viscosity 0.0035 Pa·s) sourced from published literature for human blood at 37°C. Geometric inputs derived from FDA-published pump CAD model. Formal input uncertainty propagation not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of test sample variability is not required; single representative sample per operating point is acceptable.",
      "rationale": "Experimental data from FDA hemolysis testing used single pump specimen per operating condition. Sample-to-sample variability characterization not required at MRL 2 and not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency mapping between simulation inputs and experimental conditions is not required beyond boundary condition matching.",
      "rationale": "CFD boundary conditions set to match experimental flow rates and rotational speeds. Inlet velocity profiles specified as uniform; outlet pressure boundary conditions matched to experimental back-pressure measurements. Detailed equivalency analysis not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped as not-assessed per MRL 2 requirements. CFD model correctly identifies worst-case hemolysis operating condition with NIH predictions within 12% of experimental measurements across all 5 operating points. Relative hemolysis index criterion (RH < 1) can be reliably evaluated using this model. Credibility assessment supports regulatory submission for Class II CPB device design verification.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
