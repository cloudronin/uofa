  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. The six not-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 1. Uncertainty quantification has been performed for key input parameters and boundary conditions, confirming that the relative haemolysis index prediction is robust to nominal input variability. The RH < 1 acceptance criterion is satisfied at all five operating points with adequate margin. The credibility body of evidence is sufficient to support the COU decision for this Class II device at Medium assurance level.",
