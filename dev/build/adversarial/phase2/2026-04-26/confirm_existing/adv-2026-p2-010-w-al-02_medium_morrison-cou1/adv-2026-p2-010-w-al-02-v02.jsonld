  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite and version control for all simulation scripts.",
      "rationale": "ANSYS Fluent 2022R2 used with institutional license management. Simulation scripts stored in Git repository with tagged releases. Solver regression tests documented in vendor release notes confirming no regressions for incompressible turbulent flow."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation via benchmark problems relevant to rotating machinery flows.",
      "rationale": "Fluent code verification confirmed against Taylor-Couette flow and lid-driven cavity benchmarks. Rotating reference frame implementation verified against published analytical solutions for radial pump performance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI across three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 8.7M, 17.1M cells). GCI for normalized index of hemolysis (NIH) computed as 2.8% between medium and fine meshes. Richardson extrapolation applied. Medium mesh (8.7M cells) selected for production runs balancing accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulated operating points within ±5% for flow rate and rotational speed.",
      "rationale": "FDA pump experimental data acquired at five operating points (2–6 L/min, 2000–3500 RPM). Measured flow rates and speeds match CFD boundary conditions within 2.1% and 1.8% respectively. Blood analog fluid properties (glycerol-water mixture) matched to within 3% viscosity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within 20% across all five operating points.",
      "rationale": "NIH predictions compared against Morrison et al. (2019) experimental dataset. Mean absolute error of 11.4% across five operating points. Maximum deviation 18.7% at highest shear operating point (6 L/min, 3500 RPM). All predictions within acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, relative hemolysis index RH) must be directly traceable to clinical hemolysis risk metrics used in regulatory submissions.",
      "rationale": "NIH and RH index are the standard hemolysis metrics specified in FDA guidance for blood-contacting devices. RH < 1 acceptance criterion directly maps to predicate device comparison methodology. QoIs are clinically validated surrogates for in vivo hemolysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and cover the COU operating envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry — the same geometry used in the COU. Operating points span the full CPB flow-speed envelope (2–6 L/min, 2000–3500 RPM). Blood analog fluid properties representative of clinical conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error beyond discretization is not required to be separately quantified at Model Risk Level 2 for this device class and COU. Addressed implicitly through code verification activities."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment not required at MRL 2 for Class II device with medium model influence. Standard operating procedures and analyst training records maintained but formal use error analysis not mandated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis power-law exponent uncertainty) not formally assessed at MRL 2. k-omega SST turbulence model selected based on published best-practice guidance for rotating machinery hemolysis CFD."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, fluid properties, boundary conditions) must be documented with sources and uncertainty ranges stated.",
      "rationale": "Pump geometry derived from FDA-published CAD files. Fluid properties (density 1056 kg/m3, viscosity 0.0035 Pa-s) sourced from published blood analog characterization. Inlet flow rate uncertainty ±0.05 L/min, rotational speed uncertainty ±25 RPM documented. Uncertainty quantification performed via Monte Carlo sampling (500 runs) propagating inlet flow and speed distributions through the hemolysis model; distributional assumptions are uniform over stated tolerance ranges. Extension to full sensitivity analysis identifying dominant input drivers is planned for the next assessment cycle."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal test sample characterization (material lot traceability, sample-to-sample variability) not required at MRL 2. Experimental data sourced from published FDA pump study with documented test article provenance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal equivalency mapping between validation test parameters and COU parameters not required at MRL 2. Qualitative correspondence confirmed: same geometry, overlapping operating envelope, representative fluid properties."
    }
