      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release validation suite.",
      "rationale": "ANSYS Fluent 2022R2 was used with full ISO 9001-compliant QA documentation. Regression test suite covering 120 benchmark cases was executed prior to the study; all cases passed within specified tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or equivalent benchmark comparison.",
      "rationale": "Code verification was confirmed via ASME V&V 20 benchmark suite results supplied by the software vendor and independently verified against the lid-driven cavity and backward-facing step benchmarks at Re = 100 and Re = 800 respectively."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for the hemolysis index QoI at all five operating points.",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 4.2M, 8.7M, and 17.1M cells. Richardson extrapolation yielded GCI values between 1.8% and 3.9% across all five operating points, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulated operating conditions within ±5% for flow rate and rotational speed.",
      "rationale": "Bench test data from the FDA generic pump study (Hariharan et al.) was used. Measured flow rates and rotational speeds were within 2.1% and 1.7% of nominal CFD boundary conditions respectively across all five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within ±25% at all five operating points.",
      "rationale": "CFD-predicted NIH values ranged from 0.0031 to 0.0089 mg/dL compared to experimental values of 0.0028 to 0.0094 mg/dL. Maximum deviation was 18.4%, satisfying the ±25% acceptance criterion at all five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled QoI (hemolysis index) must directly correspond to the clinical decision metric (relative hemolysis index RH).",
      "rationale": "The NIH and power-law hemolysis index computed by the CFD model are directly mapped to the relative hemolysis index RH used for regulatory comparison against the predicate device. The mapping has been validated in prior FDA submissions for similar centrifugal pumps."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the same pump geometry family and the same range of operating conditions as the COU.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which is the reference geometry for this COU. Operating conditions span 2.5–7.5 LPM and 2000–3500 RPM, encompassing the five COU operating points. Fluid properties matched 37% glycerin blood analog used in bench tests."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; basic iterative convergence monitoring is sufficient.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual monitoring is not required. Solver residuals were monitored to 1×10⁻⁵ for all equations; mass imbalance was below 0.01% in all cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
