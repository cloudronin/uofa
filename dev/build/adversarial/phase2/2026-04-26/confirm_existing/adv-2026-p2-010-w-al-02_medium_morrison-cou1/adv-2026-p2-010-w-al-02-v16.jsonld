  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 non-assessed factors are acceptable at MRL 2 given Medium model influence and Class II device classification. Uncertainty quantification over key aleatory inputs demonstrates that the 95th-percentile NIH prediction remains below the predicate device mean, supporting the RH < 1 acceptance criterion with adequate confidence. The assessment team notes that a formal sensitivity analysis to rank dominant input drivers is planned but not yet complete; this gap is considered acceptable at MRL 2 pending the next revision cycle. Decision: Accepted for submission in support of 510(k) hemolysis equivalence claim.",
