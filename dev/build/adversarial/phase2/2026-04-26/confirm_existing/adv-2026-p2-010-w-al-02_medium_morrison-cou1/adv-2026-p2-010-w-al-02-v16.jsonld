  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be version-controlled with documented regression tests covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2023R1 used under ISO 9001-compliant SQA process. Regression test suite of 47 benchmark cases executed; all pass within specified tolerances. Version control via Git with tagged release used for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for momentum and scalar transport equations demonstrated on canonical rotating flow problems.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes equations. Second-order spatial accuracy confirmed for velocity and pressure fields. Power-law hemolysis scalar transport verified against analytical solutions in Couette flow geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for normalized index of hemolysis (NIH) must be below 5% at the operating point of maximum hemolysis.",
      "rationale": "Three-level mesh refinement study conducted on 3.2M, 8.7M, and 22.1M cell meshes. Richardson extrapolation yields GCI of 2.8% for NIH at worst-case operating point (6 L/min, 2400 RPM). Production runs use 8.7M cell mesh, providing adequate accuracy with acceptable computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate) must match simulation boundary conditions within stated measurement uncertainty.",
      "rationale": "FDA pump experimental data acquired at 37°C using porcine blood with hematocrit 33±2%. CFD boundary conditions set to match measured inlet flow rates (±1.5%) and rotational speeds (±0.3%). Fluid viscosity assigned from Carreau-Yasuda fit to rheometry data collected under identical temperature conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must fall within two standard deviations of experimental NIH measurements across all 5 operating points.",
      "rationale": "Predicted NIH values compared against Morrison et al. (2019) experimental dataset. Mean absolute error of 11.3% across 5 operating points; all predictions within 1.8 standard deviations of experimental mean. Pressure head predictions agree within 4.2% across the operating range, providing additional confidence in flow field fidelity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index RH) must be directly linked to the regulatory acceptance criterion and clinically relevant hemolysis thresholds.",
      "rationale": "Relative hemolysis index RH = NIH_device / NIH_predicate is the primary QoI, directly corresponding to the FDA 510(k) substantial equivalence criterion. RH < 1 maps to non-inferior hemolysis performance. Secondary QoIs include shear stress distribution and exposure time, which mechanistically underpin the power-law hemolysis model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, equivalent operating conditions, and the same hemolysis measurement methodology as the COU.",
      "rationale": "Validation performed on the identical FDA generic centrifugal pump geometry at 5 flow-speed combinations spanning the COU operating envelope. Porcine blood used as surrogate for human blood under CPB conditions; hematocrit and temperature matched to clinical CPB protocols. Validation activities directly bracket the worst-case operating point identified in the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error beyond discretization error is not required to be separately assessed at Model Risk Level 2 for this device class and model influence combination. Addressed implicitly through code verification activities."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment not required at Model Risk Level 2 given Medium model influence. Standard operating procedures and analyst training records are maintained but formal use error assessment is scoped to higher MRL applications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal model form uncertainty assessment not required at MRL 2. The power-law hemolysis model (Giersiepen correlation) is the accepted industry standard for CFD hemolysis prediction and its applicability to this pump type is supported by the validation evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs (blood viscosity, hemolysis model coefficients, inlet boundary conditions) must be characterized with documented uncertainty bounds.",
      "rationale": "Uncertainty quantification performed using Monte Carlo sampling (N=500) over blood viscosity (±8% CV based on inter-patient variability under CPB), hemolysis power-law coefficients (±15% based on published coefficient uncertainty), and inlet flow rate (±3% measurement uncertainty). Output distribution of NIH characterized; 95th percentile NIH remains below predicate device mean NIH. Dominant input drivers have not yet been formally ranked; sensitivity analysis is planned for a future revision to identify which inputs most strongly govern the NIH output distribution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal test sample characterization beyond what is captured in test conditions is not required at Model Risk Level 2. Sample provenance and preparation records are retained in the study archive."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Equivalency of input parameters between validation and COU contexts is addressed qualitatively through the test conditions and relevance assessments. Formal equivalency scoring is not required at MRL 2 for this device class."
    }
  ],
