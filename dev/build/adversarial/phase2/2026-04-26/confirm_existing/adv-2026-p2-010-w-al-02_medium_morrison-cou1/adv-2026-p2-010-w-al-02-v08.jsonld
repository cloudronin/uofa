      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±20% across all 5 operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values agree with experimental measurements within 14% across all five flow-speed operating points. Relative hemolysis index RH < 1 criterion is satisfied for the device-predicate comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the clinical decision metric (relative hemolysis index).",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) are the primary QoIs, directly mapping to the clinical acceptance criterion. Both are standard metrics in FDA guidance for blood-contacting devices."
