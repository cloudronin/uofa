  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for Model Risk Level 2. The six not-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 4. Uncertainty quantification across key model inputs demonstrates that NIH predictions are robust within the clinical operating range. The overall credibility evidence supports use of the CFD model to identify worst-case hemolysis conditions for the CPB device. The assessment team notes that a sensitivity analysis ranking the dominant input contributors to NIH uncertainty is planned for a follow-on study but is not required to support the current MRL 2 decision.",
