      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification records are sufficient.",
      "rationale": "Simulation analysts hold relevant CFD qualifications. Formal use-error analysis is not required at MRL 2. Peer review of simulation setup was conducted internally."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; turbulence model selection is documented.",
      "rationale": "The SST k-omega turbulence model was selected based on published precedent for rotating blood-contacting devices. Formal model-form uncertainty quantification is not required at MRL 2, though the UQ study covers parametric inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs (viscosity, inlet velocity profile, hematocrit) must have documented nominal values and associated uncertainty ranges derived from literature or measurement.",
      "rationale": "Blood viscosity is set to 0.0035 Pa·s with ±10% uncertainty range per published hematocrit variability. Inlet velocity profiles are derived from Womersley flow theory with ±5% amplitude uncertainty. Hematocrit fixed at 40% per FDA guidance. Uncertainty quantification has been performed using Latin hypercube sampling across these three parameters; dominant drivers were not formally ranked through sensitivity analysis, though a follow-on sensitivity study is planned."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterisation from published FDA dataset is sufficient.",
      "rationale": "Experimental samples used bovine blood prepared per ASTM F1841. Sample lot characterisation is reported in the FDA dataset reference. No additional sample assessment is required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; documented correspondence between simulation inputs and experimental conditions is sufficient.",
      "rationale": "Simulation boundary conditions are set to match the reported experimental conditions from Hariharan et al. (2011). Equivalency is established by direct correspondence of flow rate and rotational speed values. Formal equivalency analysis is not required at MRL 2."
    }
