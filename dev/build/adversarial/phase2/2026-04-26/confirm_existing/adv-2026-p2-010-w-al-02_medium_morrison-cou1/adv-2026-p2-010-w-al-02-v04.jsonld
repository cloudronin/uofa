  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented verification tests for all active modules used in the hemolysis simulation.",
      "rationale": "ANSYS Fluent 2022R2 is used under institutional license with documented release notes and regression test suite. Version control records confirm solver version consistency across all simulation runs. SQA level 2 requirements are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least one published benchmark problem relevant to rotating-frame turbulent flow at MRL 2.",
      "rationale": "The Fluent solver has been verified against the Taylor-Couette flow benchmark and the ASME V&V 20 pipe flow verification case. Published verification reports confirm second-order spatial accuracy for the momentum equations used in the pump model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary QoI (hemolysis index) with GCI < 5% on the fine mesh.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 5.8M, 14.2M cells). Richardson extrapolation yields GCI of 3.2% for the normalized index of hemolysis on the fine mesh. The asymptotic range check confirms the solution is in the convergent regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with measurement uncertainty for flow rate, rotational speed, and fluid temperature.",
      "rationale": "FDA pump experimental data from Hariharan et al. (2011) provide test conditions at five flow-speed combinations. Flow rate uncertainty is ±0.05 L/min, speed uncertainty ±10 RPM, and temperature controlled to 37±0.5°C. Conditions are fully documented and traceable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis must agree with experimental values within combined simulation and experimental uncertainty bands at all five operating points.",
      "rationale": "Predicted NIH values fall within the experimental uncertainty band at 4 of 5 operating points. The fifth point shows 8% deviation, within the expanded uncertainty interval when accounting for UQ-derived simulation uncertainty bounds. Overall comparison metric meets MRL 2 acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulation QoI (normalized index of hemolysis) must be directly mappable to the clinical decision metric (relative hemolysis index RH).",
      "rationale": "NIH is the standard computational surrogate for RH and is used in FDA guidance for pump hemolysis assessment. The mapping between NIH and RH is established in peer-reviewed literature and accepted by the review team as directly relevant to the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and overlapping operating conditions as the COU.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry identical to the COU device geometry. Operating conditions span the clinical CPB range of 2–6 L/min and 2500–3500 RPM, fully encompassing the five COU operating points. Relevance is judged high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default level 1 is acceptable.",
      "rationale": "At Model Risk Level 2, explicit characterisation of iterative solver residual error beyond standard convergence criteria is not required. Residuals were monitored to 1e-5 for all equations; no further assessment is mandated."
    },
    {
