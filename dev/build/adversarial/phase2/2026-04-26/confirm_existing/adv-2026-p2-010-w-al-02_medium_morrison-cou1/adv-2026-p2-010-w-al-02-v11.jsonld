      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, relative hemolysis index RH) must be directly linked to the clinical acceptance criterion and regulatory submission requirement.",
      "rationale": "Hemolysis index (NIH) and relative hemolysis index (RH < 1) are the primary QoIs, directly corresponding to ISO 10993-4 biocompatibility requirements and the predicate device comparison framework. Relevance is fully established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario must use the same pump geometry family, comparable operating conditions, and identical hemolysis model formulation as the COU.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the same device family as the COU target. Operating conditions span the clinical CPB range. The Giersiepen power-law hemolysis model is identical in validation and COU simulations. Validation relevance is high."
    },
