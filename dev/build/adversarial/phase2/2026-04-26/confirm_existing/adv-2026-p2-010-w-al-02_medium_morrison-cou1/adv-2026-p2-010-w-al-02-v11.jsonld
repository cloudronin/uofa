      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for the hemolysis transport equation must demonstrate convergence consistent with second-order spatial discretization.",
      "rationale": "Method of manufactured solutions applied to the scalar hemolysis transport equation confirms second-order spatial convergence (observed order 1.94). Code verification is documented and meets the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study performed (coarse: 2.1M, medium: 5.8M, fine: 14.2M cells). GCI on fine grid for hemolysis index is 3.1%, satisfying the acceptance criterion. Fine mesh selected for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) must be documented with uncertainty bounds and reproduced in simulation boundary conditions.",
      "rationale": "FDA benchmark experimental conditions (Hariharan et al.) are fully documented. Flow rates (2–6 L/min) and rotational speeds (2500–3500 RPM) are replicated in CFD boundary conditions. Fluid properties use Newtonian blood analogue matching experimental viscosity within 2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within ±20% across all 5 operating points.",
      "rationale": "NIH predictions compared against FDA benchmark experimental data at all 5 flow-speed combinations. Maximum deviation is 14.7% at the 6 L/min, 3500 RPM operating point. All other points within 10%. Acceptance criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
