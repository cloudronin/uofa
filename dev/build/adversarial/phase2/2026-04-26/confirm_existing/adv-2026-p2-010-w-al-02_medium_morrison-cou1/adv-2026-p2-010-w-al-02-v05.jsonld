      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release validation consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 was used with documented release notes, regression test suite results, and version-controlled case files stored in institutional repository. All SQA requirements for MRL 2 are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through established benchmark problems at MRL 2 level.",
      "rationale": "ANSYS Fluent has been verified against standard CFD benchmarks including lid-driven cavity and backward-facing step. Vendor-supplied verification documentation meets MRL 2 requirements for internal flow applications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that discretization error in hemolysis index is below 5% between successive refinement levels.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 4.8M, 9.6M cells). Richardson extrapolation yields a grid convergence index of 2.3% for the normalized hemolysis index, satisfying the 5% acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match the CFD boundary conditions within documented tolerances.",
      "rationale": "FDA generic pump experimental data were collected at flow rates of 2, 3, 4, 5, and 6 L/min at 2500 and 3500 RPM. CFD boundary conditions were set to match reported experimental inlet/outlet conditions within ±2% tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all five operating points.",
      "rationale": "Normalized index of hemolysis predictions agreed with experimental measurements within 8–13% across all five flow-speed combinations. Mean absolute error of 9.4% satisfies the 15% acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The CFD quantity of interest (hemolysis index) must be directly mappable to the clinical decision criterion (relative hemolysis index RH < 1).",
      "rationale": "The normalized index of hemolysis computed from CFD shear stress history is directly used to compute the relative hemolysis index RH referenced in the acceptance criterion. The QoI is fully relevant to the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating regime as the COU.",
      "rationale": "Validation was conducted on the FDA generic centrifugal pump with a glycerol-water blood analog under CPB-representative flow conditions. Geometric and operational similarity to the COU is well established."
    },
    {
