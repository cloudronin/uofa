      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Equivalency of input parameters between validation and COU is addressed qualitatively through the test conditions and relevance factors; formal equivalency assessment is not required at MRL 2."
    }
