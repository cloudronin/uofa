      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index and pressure rise; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study performed (coarse: 2.1M, medium: 5.8M, fine: 14.3M cells). GCI for normalized index of hemolysis was 3.2% on the fine grid. Richardson extrapolation confirmed monotonic convergence. Fine mesh selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match CFD boundary conditions within documented tolerances.",
      "rationale": "Five operating points (2–6 L/min, 2500–3500 RPM) tested in vitro per ASTM F1841. Measured fluid viscosity and density used as CFD inputs. Temperature controlled to 37 ± 0.5 °C. Flow rate measurement uncertainty ±1.5% documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis within 25% of experimental values at all 5 operating points.",
      "rationale": "CFD-predicted NIH values compared against in vitro measurements. Maximum discrepancy was 18% at the 2 L/min, 3500 RPM operating point. All other points within 12%. Systematic over-prediction consistent with known turbulence model conservatism."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (normalized index of hemolysis, relative hemolysis index RH) directly maps to the regulatory decision criterion.",
      "rationale": "The primary QoI is NIH and the derived relative hemolysis index RH = NIH_device / NIH_predicate. The acceptance criterion RH < 1 directly supports the 510(k) substantial equivalence determination. QoI is fully aligned with the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
