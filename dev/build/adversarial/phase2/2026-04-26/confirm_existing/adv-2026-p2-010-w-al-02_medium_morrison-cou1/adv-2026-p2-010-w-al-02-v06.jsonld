  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for Model Risk Level 2. The six not-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. Uncertainty quantification via Monte Carlo propagation (n=500) demonstrates that combined parametric uncertainty produces a 95th-percentile NIH band of ±11.3%, which does not alter the RH < 1 acceptance decision across all 5 operating points. The model is judged credible for identifying worst-case hemolysis operating conditions for the Class II CPB device. The assessment team notes that a full sensitivity analysis ranking individual input contributions to output variance is planned for the next revision cycle but is not required for the current MRL 2 determination.",
