  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required gradation levels for Model Risk Level 2. The remaining 6 factors are appropriately scoped to Gradation 1 and documented as not-assessed per the MRL 2 assessment table. UQ has been performed via Monte Carlo propagation of key input distributions, and the resulting hemolysis index uncertainty band supports the RH < 1 acceptance criterion with adequate margin. The package is accepted for submission in support of the 510(k) predicate comparison.",
