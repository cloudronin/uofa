  "signature": "ed25519:9b1c3e5a7f2d4b6e8a0c2f4b6d8e0a2c4f6b8d0e2a4c6f8b0d2e4a6c8f0b2d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be a commercially validated code with documented version control and regression testing at the operating institution.",
      "rationale": "ANSYS Fluent 2022 R2 was used under institutional QA procedures including version-locked license management, documented installation qualification, and regression test suite execution. All SQA requirements at Gradation 2 are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems relevant to rotating machinery and viscous flow.",
      "rationale": "Code verification was confirmed against the Taylor-Couette flow benchmark and the FDA nozzle benchmark (FDA Critical Path). Results matched reference solutions within 1.2% for velocity profiles and 0.8% for pressure drop, meeting Gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed using at least three systematically refined meshes; GCI on hemolysis index QoI must be below 5%.",
      "rationale": "Three meshes (2.1M, 5.8M, 14.2M cells) were generated with a refinement ratio of 1.58. Richardson extrapolation yielded GCI values of 3.7% for the relative hemolysis index at the worst-case operating point (6 L/min, 3000 RPM), satisfying the Gradation 2 threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with traceable measurement uncertainty for flow rate, rotational speed, and blood analog fluid properties.",
      "rationale": "Bench tests were conducted at 5 flow-speed combinations using bovine blood per ASTM F1841. Flow rate uncertainty was ±0.05 L/min (k=2), rotational speed ±15 RPM. Fluid properties (viscosity, hematocrit) were measured and reported with traceability to NIST standards."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bounds at all 5 operating points.",
      "rationale": "CFD predictions of the normalized index of hemolysis (NIH) fell within the expanded experimental uncertainty band at 4 of 5 operating points. The fifth point showed 6.1% deviation, within the combined uncertainty budget of 8.3%. Validation metric satisfies Gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The computational QoI (NIH, RH index) must be directly linked to the clinical endpoint of hemolysis risk and the regulatory acceptance criterion RH < 1.",
      "rationale": "The normalized index of hemolysis is the established surrogate for red blood cell damage in rotary blood pumps per FDA guidance. The relative hemolysis index RH directly operationalizes the predicate comparison criterion. QoI relevance is fully established at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, overlapping flow-speed operating envelope, and equivalent fluid properties as the COU.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry (identical to COU geometry), bovine blood at 37°C with hematocrit 33±2%, and the same 5 flow-speed operating points as the COU. The validation scenario is directly representative of the intended use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must be reported; not required to be formally quantified at MRL 2 for this factor.",
      "rationale": "At Model Risk Level 2, formal numerical solver error quantification beyond residual monitoring is not required. Residuals were confirmed to drop below 1e-5 for all equations. Factor scoped to Gradation 1 per MRL 2 assessment table."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Operator qualification records must be on file; formal use-error analysis not required at MRL 2.",
      "rationale": "CFD analyses were performed by a qualified engineer with documented training on ANSYS Fluent and rotating machinery simulations. Formal use-error FMEA is not required at MRL 2 and has not been conducted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis power-law model form must be documented; formal model form uncertainty quantification not required at MRL 2.",
      "rationale": "The SST k-omega turbulence model was selected based on literature consensus for centrifugal pump internal flows. The Giersiepen-Wurzinger power-law hemolysis model was applied as the standard surrogate. Model form uncertainty is acknowledged but formal quantification is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters (geometry, boundary conditions, fluid properties) must be documented with sources and nominal values; distributional characterization required for UQ inputs.",
      "rationale": "All model inputs are documented in the simulation specification report. Inlet flow rate, rotational speed, blood viscosity, and hematocrit were assigned probability distributions (normal for flow rate, log-normal for viscosity) based on clinical operating data and fluid characterization measurements. These distributions were propagated via Monte Carlo UQ. We plan to extend with sensitivity analysis to formally rank the dominant input drivers in a subsequent study, but this ranking has not been completed for the current submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size and lot traceability for blood used in bench testing must be documented; statistical sample size justification not required at MRL 2.",
      "rationale": "Three independent blood draws from bovine sources were used across the 5 test conditions. Lot numbers and draw dates are recorded. Formal statistical power analysis for sample size is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between experimental and simulation input parameters must be documented; formal equivalency analysis not required at MRL 2.",
      "rationale": "Simulation boundary conditions were set to match nominal experimental conditions. Differences between bovine blood properties and human blood are noted in the model assumptions document. Formal equivalency analysis per higher gradation requirements is not mandated at MRL 2."
    }
  ],
