      "acceptanceCriteria": "Version-controlled solver with documented test suite and release notes; all regression tests passing.",
      "rationale": "ANSYS Fluent 2022 R2 is used under an ISO 9001-certified QMS. The solver release includes a documented verification test suite with 100% pass rate. Version control and change logs are maintained per the software quality plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems demonstrating second-order spatial convergence for relevant flow regimes.",
      "rationale": "The solver has been verified against ASME V&V 20 benchmark cases for incompressible turbulent pipe flow and rotating machinery. Observed order of accuracy is 1.9, consistent with the second-order finite-volume discretisation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation GCI < 5% on hemolysis index QoI across three systematically refined meshes.",
      "rationale": "Three meshes (2.1 M, 5.8 M, 14.3 M cells) were generated with uniform refinement ratio r = 1.38. Richardson extrapolation yields GCI = 3.2% for the normalised index of hemolysis, satisfying the 5% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with traceably calibrated instrumentation; operating points span the COU envelope.",
      "rationale": "FDA pump experiments were conducted at 5 flow-speed combinations (2–6 L/min, 2000–3500 RPM) with NIST-traceable pressure and flow transducers. All five COU operating points are represented in the validation dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised hemolysis index predictions within ±15% of experimental values at all five operating points.",
      "rationale": "CFD-predicted normalised index of hemolysis deviates from experimental measurements by 4–12% across all five operating conditions. The maximum deviation of 12% is within the ±15% acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to the regulatory acceptance criterion (RH < 1) used in the device submission.",
      "rationale": "The primary QoI is the relative hemolysis index RH, which is the exact metric specified in the 510(k) acceptance criterion. Secondary QoIs (shear stress distribution, exposure time) are mechanistically linked to RH and provide diagnostic information."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid properties, and operating envelope match or bound the COU device and conditions.",
      "rationale": "The FDA generic centrifugal pump geometry is representative of the COU device class. Bovine blood surrogate viscosity matches the COU fluid within 8%. Operating conditions span the clinical CPB range. Validation evidence is considered sufficiently relevant at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance at Gradation 1.",
      "rationale": "At Model Risk Level 2, a detailed characterisation of iterative solver residuals beyond standard convergence monitoring is not required. Residuals are monitored to 10^-5 on all equations, which is consistent with Gradation 1 expectations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; standard analyst training and peer review are sufficient.",
      "rationale": "Simulation analysts hold relevant CFD credentials and the analysis plan was peer-reviewed internally. Formal use-error analysis beyond this is not mandated at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection is documented with literature justification.",
      "rationale": "The SST k-ω turbulence model and Giersiepen hemolysis power-law are selected based on published literature for blood pump CFD. Formal model form uncertainty analysis is deferred as not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs documented with sources; aleatory variability in key inputs characterised via probability distributions derived from literature or measurement data.",
      "rationale": "Inlet flow rate, rotational speed, blood viscosity, and hematocrit are documented with nominal values and uncertainty bounds. Aleatory variability in blood viscosity (CV = 8%) and inlet waveform amplitude (CV = 5%) has been characterised using log-normal distributions derived from clinical measurement data. Monte Carlo propagation (n = 500 samples) has been used to quantify output variability, confirming RH < 1 across the 95th percentile of the input distribution. Extension of this UQ work to include a formal sensitivity analysis identifying the dominant input drivers is planned for the next assessment cycle."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; single representative test article is acceptable.",
      "rationale": "Validation experiments used a single manufactured FDA pump specimen. Sample-to-sample variability assessment is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; documented mapping of validation inputs to COU inputs is sufficient.",
      "rationale": "A parameter mapping table documents the correspondence between validation test inputs and COU operating inputs. Formal equivalency analysis beyond this documentation is not required at MRL 2."
    }
