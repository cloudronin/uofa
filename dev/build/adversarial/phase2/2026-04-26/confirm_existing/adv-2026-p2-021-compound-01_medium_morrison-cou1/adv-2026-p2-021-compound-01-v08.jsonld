      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Use error assessment not required at Model Risk Level 2. Simulation workflow documented in standard operating procedure with peer review of setup parameters prior to production runs."
    },
