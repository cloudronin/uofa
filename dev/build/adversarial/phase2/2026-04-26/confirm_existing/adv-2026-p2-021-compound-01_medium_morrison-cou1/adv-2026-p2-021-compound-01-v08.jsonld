  "signature": "ed25519:b1c4d7e2a0f3b6c9d2e5f8a1b4c7d0e3f6a9b2c5d8e1f4a7b0c3d6e9f2a5b8c1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be verified against established benchmarks with documented version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 used with documented version control. Solver verification against ASME V&V 20 benchmark cases confirmed. Regression test suite executed prior to production runs with zero failures."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification against analytical solutions or Method of Manufactured Solutions (MMS) for relevant flow regimes.",
      "rationale": "MMS verification performed for incompressible Navier-Stokes solver at Reynolds numbers representative of CPB operating conditions. Observed order of accuracy (1.97) consistent with second-order spatial discretisation scheme."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study demonstrating GCI < 5% for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study performed with 2.1M, 8.4M, and 33.6M cell meshes. GCI for normalised hemolysis index is 1.8% (fine-to-medium) confirming discretisation error is well below the 5% acceptance threshold. Production runs use the 8.4M cell mesh balancing accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within documented tolerances.",
      "rationale": "FDA benchmark experimental conditions (flow rates 2.5–6.0 L/min, rotational speeds 2000–3500 RPM) replicated in CFD boundary conditions. Inlet turbulence intensity set to 5% consistent with experimental upstream piping geometry. Temperature boundary conditions matched to 37°C blood analogue fluid."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 20% of experimental measurements across all five operating points.",
      "rationale": "Relative hemolysis index (RH) predictions compared against FDA experimental data at five operating points. Maximum deviation is 14.2% at the 2.5 L/min, 3500 RPM operating point; all other points within 10%. Acceptance criterion of 20% met at all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be directly linked to clinical hemolysis endpoint and regulatory acceptance criterion.",
      "rationale": "Normalised index of hemolysis (NIH) and relative hemolysis index (RH) are the primary QoIs. Both are established regulatory metrics for blood-contacting device evaluation. RH < 1 acceptance criterion directly maps to predicate device comparison required by 510(k) pathway."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, fluid properties, and operating conditions representative of the COU.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry which is geometrically similar to the device under assessment. Blood analogue fluid (glycerol-water mixture) used in experiments provides matched viscosity. Operating envelope of validation cases spans the COU operating range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Numerical solver error assessment beyond GCI is not required at Model Risk Level 2. Iterative convergence monitored via residual norms (< 1e-5 for all equations) and mass imbalance (< 0.01%) providing adequate confidence without formal solver error quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
