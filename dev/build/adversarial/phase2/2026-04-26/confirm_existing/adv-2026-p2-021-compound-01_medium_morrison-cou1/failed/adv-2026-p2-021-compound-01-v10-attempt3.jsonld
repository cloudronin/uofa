      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mean relative error in NIH < 15% across all five operating points when compared against FDA experimental measurements.",
      "rationale": "NIH comparison across five operating points yielded mean relative error of 8.3% (range 3.1%–13.7%). All individual point errors within 15% threshold. Systematic underprediction at highest flow rate noted but within tolerance. Comparison documented in VR-CPB-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
