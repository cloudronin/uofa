    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rates, rotational speeds, fluid properties) replicated in CFD boundary conditions within measurement uncertainty.",
      "rationale": "Five operating points from FDA experimental dataset replicated in CFD: flow rates 2.5–7.5 L/min, rotational speeds 2000–3500 RPM. Bovine blood analog (glycerin-water) properties matched to within 2% of reported values. Boundary conditions documented in BC-CPB-001."
