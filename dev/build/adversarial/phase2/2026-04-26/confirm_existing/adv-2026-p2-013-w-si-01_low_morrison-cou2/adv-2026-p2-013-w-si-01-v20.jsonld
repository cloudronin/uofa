  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal Profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. This package conforms to the Minimal profile and carries a content hash for integrity tracking. All 13 credibility factors are assessed; seven factors achieved required levels after additional uncertainty quantification activities; six factors remain at marginal coverage but are accepted under the Minimal profile decision threshold. Decision: Accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-mrl5-hemolysis",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-absolute-hemolysis-prediction",
