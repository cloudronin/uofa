  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile conformance level, the assessment team reviewed all 13 credibility factors. Seven factors were fully assessed; six factors reached or exceeded required levels (Relevance of QOI achieved level 4 against required level 4). The remaining factors show achieved levels below required levels, consistent with MRL 5 stringency. The Monte Carlo UQ activity partially addresses model input uncertainty. The package is accepted at the Minimal profile tier pending completion of independent use-error review, model form uncertainty quantification, and test sample replication prior to submission under a Complete profile. This acceptance is conditional and does not constitute regulatory clearance.",
    "decidedAt": "2026-04-19T00:00:00Z"
