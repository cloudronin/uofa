  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented verification test suite with traceability to release version used in simulation; configuration management records required.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has a published verification test suite and release notes, but configuration management records for the specific simulation run were incomplete. Achieved level 3 reflects documented solver QA without full run-level traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent formal order-of-accuracy verification must be demonstrated for the hemolysis transport equations implemented in the solver.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver but not for the user-defined hemolysis scalar transport subroutine. Achieved level 3 reflects partial code verification coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; GCI on hemolysis index QOI must be below 5%.",
      "rationale": "GCI was computed on three mesh levels (4M, 12M, 36M cells). GCI on hemolysis index was 7.2%, exceeding the 5% threshold. Achieved level 3 reflects demonstrated convergence trend without meeting the quantitative threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be documented with measurement uncertainty and matched to simulation boundary conditions within stated tolerances.",
      "rationale": "Four of five operating conditions were matched within stated tolerances. Hematocrit measurement uncertainty was not reported for one experimental dataset. Achieved level 3 reflects well-characterised conditions with a single documentation gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalised RMS error) must be computed between predicted and measured hemolysis index across all operating points with uncertainty bands propagated.",
      "rationale": "Normalised RMS error was computed for all five operating points. Predicted hemolysis index fell within experimental uncertainty bands for three of five points; two points showed over-prediction exceeding 15%. Achieved level 3 reflects systematic comparison without full agreement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOI (normalised index of hemolysis, NIH) must be directly mapped to the clinical acceptance criterion for chronic hemolysis in VAD patients.",
      "rationale": "NIH is the standard regulatory QOI for VAD hemolysis assessment and is directly mapped to the clinical threshold specified in the device submission. Achieved level 4 reflects full relevance of the selected QOI to the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry and at operating conditions spanning the COU envelope; extrapolation beyond validated range must be bounded.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry, which matches the COU geometry. However, two of the five COU operating points fall outside the experimentally validated speed range. Achieved level 3 reflects partial coverage of the COU envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual norms below 1e-6 for all equations; round-off error sensitivity must be assessed by comparing double and extended precision results.",
      "rationale": "Iterative residuals converged to 1e-5 for momentum and continuity but only 1e-4 for the hemolysis scalar. Precision sensitivity study was not performed. Achieved level 2 reflects basic convergence monitoring without rigorous solver error quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented review of simulation setup by an independent analyst must be performed; boundary condition inputs must be traceable to source data.",
      "rationale": "Boundary conditions are traceable to experimental records. An independent review was initiated but not completed at the time of submission; only a self-review by the simulation team was documented. Achieved level 2 reflects traceable inputs without independent verification of setup."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis damage accumulation model must be justified by literature evidence for rotating blood-contacting devices; model form uncertainty must be quantified by comparison of at least two turbulence closure models.",
      "rationale": "The SST k-omega turbulence model was selected based on prior FDA pump literature. A secondary simulation using the realizable k-epsilon model was performed at one operating point only. Hemolysis model form uncertainty was not formally quantified. Achieved level 2 reflects model selection justification without systematic model form uncertainty quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo UQ must propagate uncertainty in all hemolysis model coefficients (alpha, beta, C) and blood viscosity parameters; 95th-percentile prediction intervals must be reported for NIH at each operating point.",
      "rationale": "Monte Carlo UQ was performed propagating uncertainty in hemolysis model coefficients. Blood viscosity was treated as deterministic using a fixed non-Newtonian model. 95th-percentile prediction intervals were reported. Achieved level 3 reflects Monte Carlo UQ with incomplete input uncertainty coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must be replicated across at least three independent test samples (pump units) to characterise unit-to-unit variability; variability must be incorporated into validation comparison.",
      "rationale": "Experimental data sourced from the FDA benchmark dataset used a single pump unit per operating condition. Unit-to-unit variability was not characterised. This factor could not be assessed due to the structure of the available benchmark dataset; flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, surface roughness, fluid properties) must be demonstrated equivalent to experimental test article parameters through direct measurement or documented traceability.",
      "rationale": "Surface roughness of the FDA benchmark pump used in experiments was not reported in the source publication. Simulation assumed hydraulically smooth walls. Equivalency of this input parameter cannot be confirmed. Flagged as epistemic gap."
    }
  ],
