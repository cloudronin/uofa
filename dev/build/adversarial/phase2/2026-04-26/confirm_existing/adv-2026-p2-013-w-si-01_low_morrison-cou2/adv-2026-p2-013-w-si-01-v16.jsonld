  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented verification test suite, version control, and audit trail consistent with MRL 5 requirements.",
      "rationale": "Version control and basic unit tests are documented, but no formal validation test suite or independent audit trail exists for the hemolysis transport solver module. Achieved level 2 falls below required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate order-of-accuracy convergence for all governing equations including the power-law hemolysis transport equation.",
      "rationale": "Order-of-accuracy tests were performed for Navier-Stokes solver only. The hemolysis scalar transport equation lacks formal code verification. Achieved level 2 is insufficient for MRL 5 required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on three systematically refined meshes for all QoIs including hemolysis index, wall shear stress, and pressure head.",
      "rationale": "GCI was computed for pressure head and bulk velocity but not for hemolysis index directly. Three mesh levels were used. Partial compliance yields achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match the 5 COU flow-speed combinations within specified tolerances; blood analog fluid properties must be documented.",
      "rationale": "Experimental data available for only 3 of 5 required flow-speed combinations. Blood analog viscosity and hematocrit were not fully characterized across all test points. Achieved level 2 below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., NRMSE, validation uncertainty) must be computed for hemolysis index predictions against experimental measurements at all COU operating points.",
      "rationale": "Qualitative trend agreement is demonstrated but quantitative validation metrics including validation uncertainty were not computed. Only 3 of 5 operating points have experimental comparators. Achieved level 2 below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The predicted QoIs (hemolysis index) must be directly and demonstrably linked to the clinical decision threshold for chronic hemolysis in VAD patients.",
      "rationale": "Hemolysis index is directly relevant to the COU clinical threshold. However, the mapping from CFD-predicted normalized index of hemolysis (NIH) to clinical plasma-free hemoglobin thresholds is not fully established. Achieved level 3 below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, operating regime, and fluid properties as the COU. Validation domain must overlap the full COU operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which shares geometry with the COU device, but operating conditions cover only 60% of the COU envelope. Blood analog rather than actual blood was used. Achieved level 2 below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and time-stepping errors must be characterized and shown to be negligible relative to validation uncertainty.",
      "rationale": "Numerical solver error was not assessed. Residual convergence criteria are reported but no systematic analysis of iterative or round-off error contributions to hemolysis prediction uncertainty was performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documentation must demonstrate that simulation setup, boundary condition assignment, and post-processing are performed by qualified personnel following documented procedures.",
      "rationale": "No formal use error assessment was conducted. Analyst qualifications are noted informally but no documented procedure review or independent check of simulation setup was performed. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The power-law hemolysis model and turbulence model form must be justified relative to the COU flow regime and hemolysis mechanisms. Alternative model forms must be considered.",
      "rationale": "Model form uncertainty was not assessed. The Giersiepen-Wurzinger power-law hemolysis model is used without formal justification or comparison to alternative hemolysis model forms. This is the most critical gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in model input parameters (viscosity, density, hemolysis model coefficients, boundary conditions) must be quantified and propagated through Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ was initiated but input uncertainty characterization for hemolysis model coefficients (C and alpha in the power-law) was not completed. Input distributions were assumed uniform without experimental basis. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be representative of the device population; sample-to-sample variability must be characterized and reported.",
      "rationale": "Sample variability in the experimental hemolysis measurements was not characterized. Only a single pump specimen was tested. Inter-specimen variability relevant to the VAD device population was not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrated equivalent to those in the COU simulations; any differences must be assessed for their impact on predictive accuracy.",
      "rationale": "Equivalency of boundary conditions and fluid properties between validation and COU simulations was not formally assessed. Differences in inlet velocity profiles and fluid viscosity between validation and COU cases were noted but not quantified. Flagged as epistemic gap at MRL 5."
    }
