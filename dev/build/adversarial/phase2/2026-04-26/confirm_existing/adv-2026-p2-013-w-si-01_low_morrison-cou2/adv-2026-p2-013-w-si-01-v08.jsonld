  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for hemolysis CFD must be validated under a formal QA plan with documented test suite coverage at Gradation 4 or above for MRL 5 Class III device submissions.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) has a vendor-supplied QA plan; however, the site-specific implementation lacks documented regression testing and configuration management records required at the MRL 5 level. Achieved level 2 reflects partial documentation only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy studies using manufactured solutions or analytical benchmarks must demonstrate expected convergence rates for all governing equations relevant to hemolysis prediction.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the scalar hemolysis transport equation. Convergence of the hemolysis scalar was only checked via residual monitoring, which is insufficient for MRL 5. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence index (GCI) analysis must be performed on hemolysis index QoI with GCI below 5% on the fine grid, using at least three systematically refined meshes.",
      "rationale": "GCI analysis was completed across three mesh levels; fine-grid GCI for hemolysis index is 11.4%, exceeding the 5% threshold. Velocity field GCI is acceptable at 3.2%. The hemolysis QoI does not meet the required discretization error level, yielding achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five COU operating points (flow rate and rotational speed combinations) with blood analogue fluid properties matched within 5% and inlet boundary conditions fully characterized.",
      "rationale": "Experimental data are available for three of five operating points. The two highest-speed conditions were not tested due to hemolysis saturation in the test loop. Fluid viscosity was matched within 8% rather than 5%. Achieved level 3 due to incomplete operating-point coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E_avg, NRMSE) for absolute hemolysis index must be reported with uncertainty bands; model predictions must lie within experimental uncertainty for at least 80% of validation data points.",
      "rationale": "Model predictions fall within experimental uncertainty at 2 of 3 available operating points (67%). The third point shows a 28% over-prediction of hemolysis index. With only 3 points available, the 80% criterion cannot be rigorously assessed. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (hemolysis index) must be the same scalar quantity used in the regulatory decision, computed by the same post-processing method.",
      "rationale": "The hemolysis index QoI in validation and in the COU submission are both computed using the Giersiepen-Wurzinger power-law model applied to Lagrangian particle tracks. Post-processing scripts are identical. Achieved level 4 — this factor meets the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on a geometry and flow regime directly representative of the COU device; use of surrogate or predicate geometries must be justified with similarity metrics.",
      "rationale": "Validation was performed on the FDA benchmark centrifugal pump, which differs geometrically from the subject VAD device. A similarity analysis was not provided. The FDA pump operates in a partially overlapping Reynolds number range but differs in impeller blade count and volute geometry. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Round-off error, iterative convergence error, and solver tolerance sensitivity must each be quantified and demonstrated to be negligible relative to the hemolysis QoI at MRL 5.",
      "rationale": "Numerical solver error beyond residual monitoring was not assessed. No sensitivity study on solver tolerances or floating-point precision was performed. This factor is flagged as an epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented review process must confirm that model setup, boundary condition assignment, and post-processing are free from user-induced errors; independent simulation replication by a second analyst is required at MRL 5.",
      "rationale": "No independent replication by a second analyst was performed. Model setup review was conducted by the same team that built the simulation. Use error assessment is an epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence model, hemolysis damage accumulation model, and blood rheology model must each be justified through sensitivity studies; alternative model forms must be evaluated and compared.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature but no sensitivity study comparing alternative turbulence closures was performed. The Giersiepen-Wurzinger hemolysis model was not compared against the Arora or Zhang models. Model form uncertainty is an epistemic gap at MRL 5. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty ranges; Monte Carlo propagation must cover all significant input uncertainties including blood viscosity, pump geometry tolerances, and rotational speed variation.",
      "rationale": "Monte Carlo UQ was performed on inlet flow rate and rotational speed only. Blood viscosity uncertainty, geometric manufacturing tolerances, and hematocrit variation were excluded from the UQ sweep. Incomplete input uncertainty coverage yields achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for material properties (hematocrit, plasma protein content) and sample-to-sample variability must be quantified across a sufficient number of independent test replicates.",
      "rationale": "Test sample characterization data were not reported in the validation dataset. Number of test replicates per operating point is not documented. This factor is an epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal equivalency analysis must demonstrate that input parameters used in the validation experiment match those in the COU within defined tolerances; any deviations must be assessed for their impact on hemolysis QoI.",
      "rationale": "No formal equivalency analysis was performed between validation experiment inputs and COU device operating inputs. Differences in pump geometry, blood analogue properties, and operating range were noted but not quantitatively assessed for impact on hemolysis prediction. Epistemic gap at MRL 5. Achieved level 1."
    }
