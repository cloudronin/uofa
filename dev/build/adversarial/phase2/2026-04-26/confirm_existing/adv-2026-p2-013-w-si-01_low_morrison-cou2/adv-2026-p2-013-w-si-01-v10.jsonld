  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been evaluated under the Minimal profile requirements. Seven factors were formally assessed; six were identified as epistemic gaps at MRL 5. Achieved levels fall below required levels across all assessed factors, reflecting the inherent challenge of absolute hemolysis prediction for a Class III VAD at the highest model risk level. The package is accepted as a complete Minimal-profile credibility evidence record documenting the current state of evidence and identified gaps for regulatory submission. Further work to close epistemic gaps is recommended prior to device approval.",
