  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering blood-analog flow regimes; formal change-control process in place.",
      "rationale": "Solver versioning is documented but the test suite does not cover non-Newtonian hemolysis-relevant flow regimes. Change-control records are incomplete for the hemolysis sub-model. Achieved level 2 falls below required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) for the hemolysis transport equation and turbulence model.",
      "rationale": "MMS verification was performed only for the base Navier-Stokes solver. The power-law hemolysis damage accumulation sub-model has not been subjected to formal code verification. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis index QoI on at least three systematically refined meshes; GCI < 5%.",
      "rationale": "Grid convergence study used two mesh refinements rather than three; GCI estimate is 12% for the hemolysis index QoI, exceeding the 5% threshold. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match COU operating envelope within stated uncertainty bounds; full traceability to calibrated instrumentation.",
      "rationale": "Experimental data sourced from FDA benchmark dataset; fluid properties used bovine blood rather than human blood analog. Operating points partially overlap VAD COU envelope but two of five target conditions fall outside the validated range. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) applied to hemolysis index predictions vs. measurements; systematic bias and random error separately characterised.",
      "rationale": "Comparison performed using normalised RMS error only; systematic bias not separately quantified. Prediction intervals from Monte Carlo propagation do not fully encompass experimental scatter at two operating points. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI is the absolute normalised index of hemolysis (NIH) directly used in the regulatory decision; no surrogate QoIs accepted.",
      "rationale": "Validation was conducted against modified index of hemolysis (MIH) rather than NIH. Conversion factor introduces additional uncertainty not fully quantified. Relevance of QoI to regulatory decision criterion is partial. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, operating conditions, and fluid properties representative of the Class III VAD COU; similarity arguments documented for any deviations.",
      "rationale": "Validation geometry is the FDA generic centrifugal pump, which differs from the specific VAD impeller geometry. Similarity arguments are qualitative only. Fluid substitution (bovine vs. human blood) not formally justified. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence tolerance documented and demonstrated to be below discretization error; floating-point round-off assessed for hemolysis accumulation integration.",
      "rationale": "Iterative convergence residuals reported but not compared to discretization error magnitude. Floating-point accumulation error in Lagrangian particle tracking for hemolysis not evaluated. Factor flagged as epistemic gap at MRL 5; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of analyst setup choices (boundary conditions, turbulence model selection, hemolysis model constants) by independent qualified reviewer; sensitivity to user-controlled parameters demonstrated.",
      "rationale": "No independent review of analyst setup choices was conducted. Sensitivity of hemolysis predictions to turbulence model selection and power-law exponent constants not systematically evaluated. Epistemic gap at MRL 5; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification performed; alternative hemolysis model forms (e.g., strain-based vs. stress-based) evaluated and selection justified against experimental evidence.",
      "rationale": "Power-law stress-based hemolysis model selected without formal comparison to strain-based or energy dissipation alternatives. Model form uncertainty not quantified. This represents a critical epistemic gap at MRL 5; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters (fluid viscosity, density, hemolysis model constants C and alpha) characterised with probability distributions; Monte Carlo propagation traces uncertainty from inputs to hemolysis QoI.",
      "rationale": "Monte Carlo UQ was performed but only flow boundary conditions were treated as uncertain. Hemolysis model constants C and alpha were held fixed at literature values without uncertainty characterisation. Epistemic gap; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient to characterise inter-sample variability in hemolysis measurements; statistical power analysis documented.",
      "rationale": "FDA benchmark dataset provides limited replicate measurements per operating condition. Inter-sample variability in hemolysis susceptibility not characterised. No statistical power analysis was performed. Epistemic gap at MRL 5; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that input parameters used in validation activities are representative of COU input parameter space; any extrapolation beyond validated range flagged and justified.",
      "rationale": "No formal equivalency argument prepared. Two of five COU operating points require extrapolation beyond the validated parameter space. The extrapolation is not quantitatively bounded. Epistemic gap; achieved level 1."
