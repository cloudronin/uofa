      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD hemolysis prediction must be validated under a quality management system with documented version control, regression testing, and traceable configuration records consistent with MRL 5 requirements.",
      "rationale": "The CFD solver has documented version control and basic regression tests, but lacks a full QMS with traceable configuration records required at MRL 5. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal code verification including method of manufactured solutions or equivalent must demonstrate correct numerical implementation of governing equations for blood flow and hemolysis transport at MRL 5.",
      "rationale": "Code verification was performed using benchmark cases but method of manufactured solutions was not applied to the hemolysis transport model. Achieved level 2 is insufficient for MRL 5 requirement of level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic mesh refinement study with Richardson extrapolation or equivalent must quantify discretization error for hemolysis index predictions across all 5 operating conditions at MRL 5.",
      "rationale": "A three-level mesh refinement study was conducted and Richardson extrapolation applied for two operating conditions. Full coverage across all 5 conditions was not achieved. Achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must closely replicate VAD operating conditions including flow rate, rotational speed, fluid properties, and temperature, with documented uncertainty in all boundary conditions.",
      "rationale": "Experimental conditions partially replicate VAD operating range but fluid temperature and viscosity were not matched to clinical conditions. Boundary condition uncertainties are not fully documented. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between predicted and measured hemolysis index must include statistical metrics, uncertainty bounds, and assessment of systematic bias across all operating conditions at MRL 5.",
      "rationale": "Output comparison was performed using normalized index of hemolysis but systematic bias analysis and full uncertainty-band comparison were not completed. Achieved level 2 does not meet required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index quantity of interest must be directly linked to the clinical endpoint of patient hemolysis risk, with documented justification of the surrogate relationship at MRL 5.",
      "rationale": "The normalized index of hemolysis is a recognized surrogate but the mapping to absolute clinical hemolysis thresholds is not formally justified. Achieved level 2 falls short of required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometry, operating conditions, and fluid properties representative of the VAD COU, with documented similarity analysis at MRL 5.",
      "rationale": "Validation was conducted on the FDA generic pump geometry which is not identical to the clinical VAD geometry. Similarity analysis between validation and COU geometries was not performed. Achieved level 2 is below required level 4."
    },
