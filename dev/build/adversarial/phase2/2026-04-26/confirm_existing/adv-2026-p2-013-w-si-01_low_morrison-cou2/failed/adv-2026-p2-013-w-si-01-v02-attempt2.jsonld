  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering blood-analog flow regimes; independent review of solver build process required at MRL 5.",
      "rationale": "The CFD solver is version-controlled and a partial test suite exists, but independent review of the build process and blood-analog regression tests has not been completed. Achieved level 2 falls short of the required level 4 for a Class III MRL-5 device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing on canonical rotating-flow benchmarks with demonstrated convergence to manufactured solutions.",
      "rationale": "Order-of-accuracy tests were performed on a simplified rotating channel but not on geometries representative of the centrifugal pump impeller. Convergence to manufactured solutions was demonstrated only for laminar cases. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent on at least three systematically refined grids with reported grid convergence index (GCI) for hemolysis index QoI.",
      "rationale": "A three-level grid refinement study was conducted, but GCI was reported only for velocity magnitude rather than the hemolysis index quantity of interest. Discretization error in the hemolysis prediction itself remains unquantified at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match COU operating envelope within stated uncertainty; blood analog fluid properties must be characterised at test temperature.",
      "rationale": "Bench tests used a glycerol-water blood analog at 22 °C while COU specifies 37 °C blood; temperature-dependent viscosity correction was applied but not experimentally validated. Boundary condition match is partial, yielding achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., NRMSE) for hemolysis index across all five operating points with uncertainty bands on both experimental and simulation results.",
      "rationale": "Hemolysis index predictions were compared at three of five operating points. Uncertainty bands were reported for simulation but not for experimental measurements. Quantitative agreement metric was computed without accounting for experimental uncertainty, resulting in achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated traceability from CFD output (hemolysis index) to the clinical endpoint (plasma free haemoglobin threshold) with quantified mapping uncertainty.",
      "rationale": "The hemolysis index is mapped to plasma free haemoglobin using a published empirical correlation, but the uncertainty in that correlation has not been propagated through to the clinical threshold comparison. Traceability is partial; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the full COU operating envelope (five flow-speed combinations) in a geometry identical or rigorously similar to the production device.",
      "rationale": "Validation used the FDA generic pump geometry rather than the production VAD geometry. Geometric similarity arguments were made qualitatively but without formal similarity analysis. Only three of five COU operating points were covered experimentally. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent quantification of iterative convergence error, floating-point round-off, and parallel decomposition sensitivity for the hemolysis transport equation.",
      "rationale": "Numerical solver error beyond residual monitoring has not been assessed. Iterative convergence of the hemolysis scalar transport equation was not separately reported, and parallel decomposition sensitivity has not been tested. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification process and independent re-run by a second analyst to confirm reproducibility of hemolysis predictions.",
      "rationale": "No independent analyst re-run has been performed. User qualification records exist for the primary analyst but have not been reviewed against the MRL-5 requirement for independent reproducibility confirmation. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model form uncertainty, including at least two alternative model forms with quantified impact on hemolysis index predictions.",
      "rationale": "A single turbulence model (SST k-ω) and a single power-law hemolysis model were used without comparison to alternative model forms. Model form uncertainty is unquantified. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full probabilistic characterisation of all model input parameters (fluid properties, boundary conditions, geometric tolerances) with Monte Carlo propagation to hemolysis index output uncertainty.",
      "rationale": "Monte Carlo UQ was performed on a subset of boundary condition inputs only. Fluid property uncertainty and geometric manufacturing tolerances were not included in the UQ analysis. Input uncertainty characterisation is incomplete for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterisation of experimental sample variability (inter-device, inter-run) with minimum sample size justification for the hemolysis endpoint.",
      "rationale": "Experimental data were collected from a single FDA pump specimen over repeated runs. Inter-device variability was not characterised and no sample size justification was provided. Test sample representativeness is unestablished at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that validation experiment input parameters match COU input parameters within quantified uncertainty bounds for all five operating points.",
      "rationale": "No formal equivalency analysis has been conducted between validation experiment inputs and COU inputs. Differences in fluid temperature, haematocrit, and pump rotational speed tolerance have not been bounded. Flagged as epistemic gap at MRL 5."
    }
  ],
