  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with traceability to release version; configuration management records required at MRL 5.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has a published verification test suite, but configuration management records for the specific release used in this study are incomplete. Version pinning in the simulation scripts is absent, reducing achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests using manufactured solutions must be performed for all governing equations active in the hemolysis model.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver but not for the scalar hemolysis transport equation. The gap in manufactured-solution testing for the damage accumulation model limits the achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent systematic grid-refinement study must quantify discretization error on hemolysis index QoI at all 5 operating points.",
      "rationale": "A three-level grid-refinement study was completed at 3 of 5 operating points. Richardson extrapolation yields discretization uncertainty of ±8% on hemolysis index at the assessed points. The two unassessed operating points introduce an epistemic gap that prevents reaching level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within stated tolerances; fluid temperature, hematocrit, and rotor speed must be documented with uncertainty bounds.",
      "rationale": "Hematocrit and rotor speed were controlled and documented with uncertainty bounds. Fluid temperature was recorded but thermocouple calibration certificates are unavailable for two of the five test sessions, introducing a minor traceability gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE or validation uncertainty ratio) must be computed for hemolysis index at all COU operating points with combined experimental and simulation uncertainty accounted for.",
      "rationale": "NRMSE was computed at 3 of 5 operating points; the remaining 2 points lack experimental replicates sufficient for uncertainty quantification. Combined validation uncertainty ratio exceeds 1.0 at two assessed points, indicating model predictions are not distinguishable from experimental scatter."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (hemolysis index) must be directly the same scalar used in the regulatory acceptance criterion; no surrogate quantities permitted at MRL 5.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which directly maps to the regulatory threshold. However, the experimental hemolysis measurement protocol uses a modified plasma-free hemoglobin assay that introduces a systematic offset relative to the ISO 10993-4 reference method, reducing direct relevance to level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, flow regime, and blood analog properties must match the COU device and operating conditions within documented similarity criteria.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is a benchmark surrogate rather than the actual VAD device. Geometric similarity is partial; impeller blade angle deviates by 12° from the COU device, limiting validation relevance to level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver residual behavior must be systematically characterized for the hemolysis transport equation across all operating points.",
      "rationale": "Solver residual plots were not archived for the hemolysis scalar transport equation. Iterative convergence was monitored only for continuity and momentum equations. This factor is flagged as an epistemic gap at MRL 5; achieved level assigned 1 as a conservative bound."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review or audit of simulation setup, boundary condition application, and post-processing scripts must be documented at MRL 5.",
      "rationale": "No independent audit of simulation setup was performed. A single analyst configured and post-processed all cases. The absence of peer review of boundary condition application is a known epistemic gap; achieved level set to 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive hemolysis model (power-law damage accumulation) must be justified against alternative model forms with sensitivity analysis demonstrating robustness of NIH predictions.",
      "rationale": "The Giersiepen-Wurzinger power-law model was used without comparison to the Bludszuweit or modified Arora models. A sensitivity study varying model coefficients was performed, but no alternative model-form comparison was conducted. This represents a significant model-form uncertainty at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters must be characterized with probability distributions derived from literature or measurement; Monte Carlo propagation must cover at least 500 samples.",
      "rationale": "Monte Carlo UQ was performed with 1000 samples. However, blood viscosity was modeled as a fixed Newtonian value rather than a distribution, and red blood cell fragility was not included as an uncertain parameter. These omissions underrepresent the true input uncertainty space at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood sample provenance, storage conditions, and passage number must be documented; inter-donor variability must be characterized with at least 3 independent donors.",
      "rationale": "Experimental hemolysis data were obtained using a single pooled bovine blood lot. Inter-donor variability is not characterized. Sample storage temperature logs are unavailable. This factor is an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Inlet velocity profiles, outlet pressure boundary conditions, and wall roughness values applied in simulation must be demonstrated equivalent to those present in the physical experiment.",
      "rationale": "Inlet boundary conditions were derived from bulk flow rate measurements without spatial velocity profile characterization. Wall roughness was assumed hydraulically smooth. Equivalency between simulation inputs and experimental conditions was not formally demonstrated; factor flagged as epistemic gap."
    }
  ],
