    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the power-law hemolysis damage model (Giersiepen-Wurzinger) must be characterized relative to alternative hemolysis models at Gradation 4.",
      "rationale": "A single hemolysis damage model was used without comparison to alternative formulations (e.g., Arora, Zhang). Model form uncertainty in the hemolysis constitutive relation is unquantified. This is the dominant epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
