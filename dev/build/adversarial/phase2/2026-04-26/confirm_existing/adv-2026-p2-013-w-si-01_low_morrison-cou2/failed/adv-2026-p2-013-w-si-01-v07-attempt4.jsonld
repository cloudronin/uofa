  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version-controlled QA with documented test suite covering blood-flow physics; all relevant modules traceable to verified source.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under Git version control with a documented regression test suite. QA records confirm all hemolysis-relevant modules passed automated testing prior to the simulation campaign. Achieved level equals required level for MRL 5 under Minimal profile acceptance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks must confirm expected convergence rates for velocity and stress fields.",
      "rationale": "Method of manufactured solutions applied to a rotating annular flow confirms second-order spatial convergence for velocity (observed order 1.97) and first-order for turbulent viscosity. Results documented in verification report VR-2024-07."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) for hemolysis index must be below 5% on the production mesh across all five operating points.",
      "rationale": "Three-level mesh refinement study (4.2 M, 11.6 M, 31.4 M cells) yields GCI values of 2.1%–3.8% for the normalized index of hemolysis across all five flow-speed combinations. Production mesh is the 11.6 M cell medium grid with GCI < 4% confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, rotational speed, flow rate) must be reproduced in the CFD boundary conditions within stated measurement uncertainty.",
      "rationale": "Boundary conditions are set to match FDA loop experiments: 37 °C phosphate-buffered saline with porcine blood at 40% hematocrit, rotational speeds 2500–3500 rpm, flow rates 2.5–7.5 L/min. All values confirmed within ±2% of measured experimental conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis must agree with experimental measurements within two experimental standard deviations across all five operating points.",
      "rationale": "Predicted NIH values range from 0.0031 to 0.0089 g/100 L; experimental values range from 0.0028 to 0.0094 g/100 L. All five operating points fall within two experimental standard deviations. Validation metric E_rel < 18% at each point."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH) must be the same metric applied in the regulatory submission and compared against the absolute clinical threshold.",
      "rationale": "The normalized index of hemolysis is the sole QoI in both the validation dataset and the regulatory submission. No surrogate or proxy metric is substituted. Direct correspondence confirmed between simulation output variable and clinical acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the FDA generic centrifugal pump geometry at VAD-representative operating conditions; no geometric surrogates permitted.",
      "rationale": "All validation experiments were conducted on the FDA generic centrifugal blood pump (GCBP) at operating conditions spanning the VAD envelope. No simplified or surrogate geometry was used. Geometric fidelity confirmed by CT scan comparison with CAD model (maximum deviation 0.12 mm)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations; mass imbalance below 0.01% per time step.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum; energy residual below 1e-7. Global mass imbalance 0.003% per revolution. Solver error contribution to NIH uncertainty estimated at 0.4% via perturbation analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup files by a second qualified analyst; documented checklist covering boundary conditions, material properties, and solver settings.",
      "rationale": "A second CFD analyst independently reviewed all case setup files against a 47-item checklist. Two minor boundary condition inconsistencies were identified and corrected prior to production runs. Final setup confirmed correct by both analysts. Use error risk rated low."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by comparison of at least two RANS closures against experimental velocity profiles in the GCBP; hemolysis model must be the Giersiepen-Wurzinger power-law form validated for the operating shear-stress range.",
      "rationale": "k-ω SST and realizable k-ε models compared against PIV velocity data in the GCBP impeller passage; k-ω SST shows 12% lower RMS error. Giersiepen-Wurzinger hemolysis model validated for shear stresses 10–400 Pa, spanning the predicted range. Model form uncertainty quantified via Monte Carlo sampling of model constants."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions assigned to all hemolysis model constants and blood viscosity parameters; Monte Carlo propagation with minimum 1000 samples; 95th-percentile NIH prediction must remain below clinical threshold.",
      "rationale": "Monte Carlo UQ with 2000 Latin hypercube samples propagates uncertainty in Giersiepen-Wurzinger constants (C, α, β) and Carreau-Yasuda viscosity parameters. 95th-percentile NIH at worst-case operating point is 0.0112 g/100 L, below the 0.020 g/100 L clinical threshold. Input uncertainty contribution dominates total uncertainty budget at 61%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent blood samples from different donors used in experimental validation; inter-sample variability reported.",
      "rationale": "Experimental hemolysis measurements performed using porcine blood from five independent draws across three separate laboratory sessions. Inter-sample coefficient of variation 8.3% for NIH, consistent with published literature. Sample variability incorporated into experimental uncertainty bounds used in output comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hematocrit, temperature, and fluid rheology parameters used in CFD must be demonstrably equivalent to those measured in the validation experiments within stated tolerances.",
      "rationale": "CFD material properties set to experimentally measured values: hematocrit 40.1 ± 1.2% (target 40%), temperature 37.0 ± 0.3 °C, plasma viscosity 1.21 ± 0.04 mPa·s. Carreau-Yasuda parameters fitted to viscometry data from the same blood draws used in hemolysis experiments. Equivalency confirmed within ±3% for all rheological parameters."
    }
  ],
