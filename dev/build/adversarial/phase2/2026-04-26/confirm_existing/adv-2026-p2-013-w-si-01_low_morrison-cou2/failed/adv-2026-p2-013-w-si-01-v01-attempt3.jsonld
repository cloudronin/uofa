      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with traceable version control and independent code review at MRL 5.",
      "rationale": "The CFD solver has basic version control and unit tests but lacks an independent audit trail and formal qualification documentation required at MRL 5. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions (MMS) verification must be performed for all governing equations at MRL 5.",
      "rationale": "MMS verification was performed only for the momentum equations. Scalar transport and hemolysis damage model equations were not subjected to order-of-accuracy testing. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be computed on at least three systematically refined meshes with GCI < 5% on hemolysis index QoI.",
      "rationale": "Three-mesh GCI study was completed; GCI on pressure head was 3.1% but GCI on hemolysis index reached 11.4%, exceeding the 5% threshold. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope in fluid temperature, hematocrit, and rotational speed within stated tolerances.",
      "rationale": "Bench experiments used bovine blood at 37 °C and 35% hematocrit; COU specifies human blood at physiological conditions. Temperature and species differences introduce unquantified bias. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must be compared against experimental measurements with uncertainty bands; systematic bias must be within ±15% of measured mean.",
      "rationale": "CFD over-predicted hemolysis index by 28–42% across operating points relative to bench measurements. Systematic positive bias exceeds the ±15% acceptance criterion. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must be directly mapped to the clinical endpoint used in the regulatory submission.",
      "rationale": "NIH is computed and reported, but the mapping to the specific clinical hemolysis threshold cited in the 510(k) pathway has not been formally documented. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be performed on the same pump geometry and at COU flow-speed conditions, not on surrogate geometries.",
      "rationale": "Validation data were collected on the FDA generic centrifugal pump benchmark geometry, which differs from the proprietary VAD geometry used in the COU. Geometric similarity is partial only. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
