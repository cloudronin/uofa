  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction has been reviewed. All 13 credibility factors have been evaluated against MRL 5 requirements. Seven factors were formally assessed and all show achieved levels below required levels. Six factors remain unassessed, representing significant epistemic gaps. The Monte Carlo uncertainty quantification partially addresses model input uncertainty but is incomplete. The assessment package is accepted as a complete and accurate representation of the current credibility state, with the explicit finding that the model is NOT accepted for the intended COU2 decision use pending resolution of identified gaps.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
