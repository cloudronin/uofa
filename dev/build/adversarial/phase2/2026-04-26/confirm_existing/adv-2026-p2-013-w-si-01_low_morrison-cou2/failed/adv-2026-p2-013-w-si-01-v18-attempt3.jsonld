      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence of independent review of simulation setup and post-processing scripts at Gradation 2.",
      "rationale": "An independent engineer reviewed meshing strategy, boundary condition assignments, and post-processing scripts against the V&V plan. One use error (incorrect inlet velocity profile) was identified and corrected prior to final runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for turbulence model selection (SST k-omega) and hemolysis power-law model form documented with literature support at Gradation 3.",
      "rationale": "SST k-omega is selected based on published benchmark studies for rotating blood-contacting devices. The Giersiepen-Wurzinger power-law hemolysis model is justified by its established use in FDA pump studies. Sensitivity to model form is quantified via comparison with the Zhang model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in blood viscosity, density, and hemolysis model coefficients propagated through Monte Carlo UQ at Gradation 3; 95th percentile prediction interval reported.",
      "rationale": "Monte Carlo UQ (n=500 samples) propagates uncertainty in hematocrit-dependent viscosity, red blood cell fragility coefficients, and rotational speed tolerance. The 95th percentile NIH prediction interval is reported for all five operating points and remains below the clinical threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental dataset must include replicate measurements (n ≥ 3 per operating point) with reported inter-sample variability at Gradation 2.",
      "rationale": "The FDA experimental dataset provides n=5 replicates per operating point with reported mean and standard deviation of NIH. Inter-sample coefficient of variation is below 12% at all points, consistent with Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
