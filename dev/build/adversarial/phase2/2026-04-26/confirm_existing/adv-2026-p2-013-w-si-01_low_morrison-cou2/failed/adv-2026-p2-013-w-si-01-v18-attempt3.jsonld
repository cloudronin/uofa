      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release validation at Gradation 3 for MRL 5.",
      "rationale": "The CFD solver (OpenFOAM v8) is under version control with a documented regression test suite covering rotating-frame and scalar-transport cases. Release notes confirm passing of all hemolysis-relevant regression tests. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must confirm solver correctness for rotating-frame Navier-Stokes and scalar hemolysis transport at Gradation 3.",
      "rationale": "MMS studies confirm second-order spatial convergence for both momentum and scalar hemolysis transport equations in rotating reference frames. Observed order of accuracy matches theoretical order across three mesh levels."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis index QoI at Gradation 3; GCI must be below 5% on the operating mesh.",
      "rationale": "Three-level mesh refinement study yields GCI of 3.2% for the normalized index of hemolysis at the design operating point (6 L/min, 3500 RPM). Discretization error is within the required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate, temperature) must be documented and traceable to calibrated instruments at Gradation 3.",
      "rationale": "FDA pump experimental dataset documents fluid temperature (37 ± 0.5 °C), hematocrit (30 ± 1%), rotational speed (±10 RPM), and flow rate (±0.05 L/min) with calibration certificates. All five operating points are covered."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized index of hemolysis error) reported with uncertainty bands at Gradation 3; model predictions must fall within experimental uncertainty at majority of operating points.",
      "rationale": "Predicted NIH values at all five operating points fall within ±1 experimental standard deviation. Mean absolute percentage error is 8.4%, within the acceptable threshold for MRL 5 Minimal profile acceptance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, scalar shear stress exposure) must be directly mapped to the COU decision QoIs at Gradation 2.",
      "rationale": "Validation QoI (normalized index of hemolysis) is identical to the COU decision QoI. No proxy mapping is required. Direct correspondence established in the V&V plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry and overlapping operating envelope as the COU at Gradation 2.",
      "rationale": "Validation uses the FDA generic centrifugal pump, which is the same geometry as the COU device. Operating conditions in validation (4–8 L/min, 2500–4500 RPM) fully encompass the five COU operating points."
    },
