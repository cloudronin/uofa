  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, regression testing, and traceability to validated solver releases consistent with MRL 5 requirements.",
      "rationale": "The CFD solver has documented version control and basic regression tests, but independent third-party audit and full traceability documentation required at MRL 5 are absent. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification and method-of-manufactured-solutions testing must be demonstrated for the hemolysis transport equations at MRL 5.",
      "rationale": "Basic patch tests and simple benchmark comparisons were completed, but method-of-manufactured-solutions verification of the scalar hemolysis transport equation has not been performed. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based discretization error estimates must be reported for all five operating points with demonstrated grid convergence index below 5% for hemolysis index.",
      "rationale": "Three-level mesh refinement study was conducted and GCI computed; however, GCI values for two of five operating points exceed the 5% threshold. Achieved level 3 does not meet required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope including blood analogue fluid properties, temperature, and hematocrit within specified tolerances.",
      "rationale": "Validation experiments used porcine blood at 37°C, but hematocrit range (35–40%) and flow waveform do not fully bracket VAD operating conditions. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalised RMSE, validation uncertainty) must demonstrate agreement within clinical acceptance band for absolute hemolysis index at all five operating points.",
      "rationale": "Normalised RMSE of 18% was achieved across the five operating points; validation uncertainty bounds overlap the clinical threshold at two points. Achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modelled QoI (normalised index of hemolysis, NIH) must be directly and demonstrably linked to the clinical endpoint of chronic hemolysis injury; surrogate QoI mappings must be validated.",
      "rationale": "NIH is used as the primary QoI and is clinically recognised; however, the mapping from CFD-derived shear stress exposure to NIH relies on a power-law model with parameters not re-calibrated for this pump geometry. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the same pump geometry, operating regime, and fluid conditions as the COU, or similarity arguments must be rigorously justified.",
      "rationale": "Validation was performed on the FDA benchmark centrifugal pump geometry under steady-state conditions; VAD COU requires pulsatile operation and patient-specific haematological variability. Similarity gap is large. Achieved level 2 is substantially below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off error contributions to hemolysis index must be characterised and shown to be negligible relative to discretization error.",
      "rationale": "Solver error characterisation was not performed. Residual convergence criteria were set by default solver settings without analysis of their adequacy for hemolysis transport. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented procedures for model setup, boundary condition application, and post-processing must exist and be reviewed to prevent operator-induced errors in hemolysis predictions.",
      "rationale": "No formal use-error assessment or operator qualification procedure was documented for this COU. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence closure and hemolysis damage accumulation model must be justified against alternatives and shown to be appropriate for the shear stress magnitudes and exposure times encountered in the VAD.",
      "rationale": "Model form uncertainty for turbulence closure (SST k-omega) and power-law hemolysis model was not formally assessed. No sensitivity study comparing alternative model forms was conducted. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in model inputs (blood viscosity, density, pump geometry tolerances, inlet flow waveform) must be propagated through the model using Monte Carlo or equivalent method and reported.",
      "rationale": "Although Monte Carlo UQ was planned, only geometric tolerances were sampled; blood rheological parameter uncertainty and inlet waveform variability were excluded from the UQ sweep. Input uncertainty assessment is incomplete. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used in validation must be characterised for inter-sample variability in haematological properties and sufficient replicates must be available to estimate experimental uncertainty.",
      "rationale": "Validation dataset contains results from a single blood batch with no inter-sample haematological characterisation. Sample-to-sample variability is unquantified. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the simulation must be shown to be equivalent to those used in the validation experiments, including fluid properties, boundary conditions, and geometric fidelity.",
      "rationale": "No formal equivalency mapping between simulation inputs and experimental conditions was documented. Geometric fidelity of the manufactured test article relative to the CAD model was not verified metrologically. Flagged as epistemic gap at MRL 5."
    }
