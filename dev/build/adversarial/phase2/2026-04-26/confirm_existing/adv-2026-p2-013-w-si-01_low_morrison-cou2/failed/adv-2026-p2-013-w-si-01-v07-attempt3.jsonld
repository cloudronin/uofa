      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate) match COU operating envelope within stated uncertainty bounds.",
      "rationale": "Validation experiments used bovine blood at 37 °C; COU specifies human blood analogue at 37 °C. Viscosity and RBC fragility differences are not bounded. Achieved level 2 reflects partial condition matching."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or NRMSE) computed for hemolysis index across all 5 operating points with uncertainty intervals.",
      "rationale": "Comparisons are presented graphically without formal quantitative metrics or uncertainty intervals on experimental data. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
