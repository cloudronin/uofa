    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions covering the power-law hemolysis source term; documented convergence rates.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver but not extended to the hemolysis damage model source term. Convergence rates for the coupled system are undocumented. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
