      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QOI is the normalized index of hemolysis (NIH) directly used in regulatory decision; mapping from model output to NIH is documented.",
      "rationale": "The model outputs a power-law hemolysis index; the mapping to NIH used in the regulatory submission is partially documented but does not account for recirculation-zone contributions. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
