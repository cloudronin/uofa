  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors at Model Risk Level 5. Seven factors were formally assessed; all showed achieved levels below required levels. Six factors remain not-assessed due to epistemic gaps identified during the assessment. The overall package is accepted for submission as a complete record of the credibility gaps, consistent with a transparent regulatory disclosure posture. Remediation actions are required before the computational model can be used as primary evidence for device clearance.",
