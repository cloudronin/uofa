      "factorStatus": "assessed",
      "acceptanceCriteria": "Configuration management, version control, and regression testing documented for all solver modules used in hemolysis prediction.",
      "rationale": "Only informal version control is in place; no regression test suite exists for the hemolysis sub-model. Achieved level 2 falls below the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent applied to all governing equations including the hemolysis transport scalar.",
      "rationale": "Code verification was performed only for the Navier-Stokes solver; the hemolysis damage accumulation scalar was not subjected to manufactured-solution testing. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence study on hemolysis index QOI with GCI reported for all 5 operating points.",
      "rationale": "Grid convergence study was completed at 3 of 5 operating conditions; GCI values at the remaining 2 high-flow conditions exceed the 2% target. Achieved level 3 does not meet the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, blood viscosity, temperature) matched to simulation inputs within stated uncertainty bounds.",
      "rationale": "Inlet velocity profiles were approximated from bulk flow measurements; local profile data were unavailable. Temperature control during bench experiments was not documented. Achieved level 2 reflects these boundary-condition gaps."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or NRMSE) defined a priori; simulation hemolysis index compared against experimental values with uncertainty bands at all 5 operating points.",
      "rationale": "Comparisons were made at all 5 points, but the acceptance metric was defined post-hoc after reviewing preliminary results, introducing potential confirmation bias. Achieved level 3 does not satisfy the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that the predicted hemolysis index directly maps to the clinical endpoint (plasma free hemoglobin rise rate) used in the regulatory submission.",
      "rationale": "The model predicts a power-law hemolysis index (Giersiepen-Wurzinger) which correlates only indirectly with plasma free hemoglobin. No patient-level correlation study was provided. Achieved level 3 is well below the required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted with blood analogue or porcine blood at VAD operating speeds (3000–5000 RPM) and flow rates matching the COU envelope.",
      "rationale": "Validation data were collected using a glycerol-water analogue fluid at pump speeds up to 3500 RPM, which does not cover the full VAD operating envelope. Non-Newtonian blood rheology effects are unvalidated. Achieved level 2 is critically below the required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
