      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a documented quality management system with traceable version control and regression test suite meeting MRL 5 requirements.",
      "rationale": "The CFD solver has version control and unit tests but lacks a formal QMS compliant with MRL 5 requirements. Achieved level 2 against a required level 4; gap identified as a credibility shortfall."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification must be demonstrated for all governing equations relevant to hemolysis prediction at MRL 5.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the hemolysis transport sub-model. Achieved level 2; required level 4 not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index quantities of interest with GCI below 5% on the fine grid at all operating points.",
      "rationale": "GCI was computed for three operating points; two of five exceeded the 5% threshold on the fine grid. Achieved level 3; required level 4 not met due to incomplete coverage across all flow-speed combinations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five VAD operating points including fluid temperature, hematocrit, and rotational speed to within defined tolerances.",
      "rationale": "Experimental data were collected at three of five target operating points. Temperature and hematocrit were controlled; two operating points lack experimental coverage. Achieved level 3; required level 5 not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bounds at all five operating points.",
      "rationale": "Agreement within uncertainty bounds achieved at only one of three available experimental comparisons. Systematic over-prediction observed at high flow rates. Achieved level 2; required level 5 not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index quantity of interest must be directly traceable to the clinical acceptance threshold with documented mapping from model output to patient risk metric.",
      "rationale": "Hemolysis index is the primary QoI and maps to the clinical threshold; however, the mapping function from CFD scalar stress to clinical hemolysis index has not been independently validated for this pump geometry. Achieved level 3; required level 4 not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on the same pump geometry and operating envelope as the COU, using blood analogue fluids with documented rheological equivalence.",
      "rationale": "Validation was performed on the FDA generic pump geometry which differs from the intended VAD geometry in impeller design. Blood analogue fluid equivalence was asserted but not formally demonstrated. Achieved level 2; required level 5 not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
