  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction has been reviewed. All 13 credibility factors have been evaluated; 7 factors were formally assessed and all showed achieved levels below required levels for MRL 5. Six factors were flagged as not-assessed epistemic gaps. The package is accepted as a complete and structurally valid credibility evidence record documenting the current shortfalls, to be used as the basis for a remediation plan. The decision to accept this evidence package as a credibility record does not constitute acceptance of the model for regulatory submission.",
