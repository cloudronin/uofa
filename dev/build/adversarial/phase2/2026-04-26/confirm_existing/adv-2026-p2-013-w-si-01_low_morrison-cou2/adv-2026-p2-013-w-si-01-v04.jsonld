  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan with version control, regression testing, and traceability to requirements at Gradation 4.",
      "rationale": "The CFD solver is a commercial code with vendor-supplied documentation. Internal QA records are incomplete; no independent regression test suite was executed for this study. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal code verification activities including method of manufactured solutions or equivalent must demonstrate solver correctness at Gradation 4.",
      "rationale": "Only vendor-supplied benchmark cases were reviewed. No method-of-manufactured-solutions verification was performed by the assessment team. Gap remains between achieved level 2 and required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic mesh refinement study with Richardson extrapolation or GCI must quantify discretization error at Gradation 4 for hemolysis-relevant flow regions.",
      "rationale": "A three-level mesh refinement study was conducted with GCI reported. However, near-impeller regions showed GCI values above the 5% threshold at the finest mesh, leaving the achieved level at 3 rather than the required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with full uncertainty characterization and must span the operating envelope of the VAD COU at Gradation 4.",
      "rationale": "Five flow-speed combinations were tested. Inlet boundary conditions and fluid temperature were recorded but hematocrit variability and blood analog rheology were not fully characterized, limiting coverage to Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of model predictions to experimental hemolysis index values must include uncertainty bands and systematic bias analysis at Gradation 4.",
      "rationale": "Predicted hemolysis index was compared against experimental values with uncertainty bars shown. Systematic over-prediction at high flow rates was noted but not fully explained, constraining the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation must directly correspond to the hemolysis index metric required for the VAD regulatory decision at Gradation 4.",
      "rationale": "The normalized index of hemolysis (NIH) was used as the primary QoI and is clinically relevant. However, sub-lethal platelet activation was not included as a secondary QoI despite its relevance at MRL 5, limiting the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on a device geometry and operating regime that is directly representative of the Class III VAD COU at Gradation 5.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which shares geometric similarity with the target VAD but is not the device-specific geometry. Operating conditions overlap partially. Achieved level 3 against required level 5 represents the largest gap in this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver tolerance effects on hemolysis predictions must be quantified at Gradation 4.",
      "rationale": "Numerical solver error was identified as an epistemic gap. Residual convergence criteria were set but sensitivity of hemolysis outputs to solver tolerance was not evaluated. Flagged as not-assessed at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user error in model setup, boundary condition specification, and post-processing must be formally evaluated at Gradation 4.",
      "rationale": "No formal use-error analysis was conducted. Simulation setup was performed by a single analyst without independent review of boundary condition assignments. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The selection of the hemolysis damage model and turbulence closure must be justified with sensitivity analysis at Gradation 5 for MRL 5.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was adopted without comparison to alternative damage models. Turbulence model selection (k-omega SST) was not subjected to sensitivity analysis. Flagged as not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters including material properties, boundary conditions, and hemolysis model constants must be characterized with full uncertainty distributions at Gradation 5.",
      "rationale": "Monte Carlo UQ was performed on flow boundary conditions but hemolysis model constants (stress exponent, time exponent) were treated as fixed values. Input uncertainty for blood viscosity parameters was not propagated. Flagged as not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental test samples must be characterized for biological variability and hematocrit distribution relevant to the VAD patient population at Gradation 4.",
      "rationale": "Experimental data used bovine blood at fixed hematocrit. Biological variability across a representative VAD patient population was not characterized. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental and simulation input parameters must be formally demonstrated with traceability at Gradation 4.",
      "rationale": "Inlet velocity profiles used in simulation were derived from bulk flow measurements rather than spatially resolved experimental profiles. Equivalency of inlet turbulence intensity between experiment and simulation was not verified. Flagged as not-assessed."
    }
  ],
