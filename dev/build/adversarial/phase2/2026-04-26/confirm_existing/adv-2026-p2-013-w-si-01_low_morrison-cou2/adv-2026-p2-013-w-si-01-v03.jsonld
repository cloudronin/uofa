      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified through comparison with alternative constitutive models and sensitivity of predictions to model-form assumptions must be quantified.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was used without comparison to alternative formulations (e.g., strain-based or mechanistic models). Model-form uncertainty is unquantified, representing a critical epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
