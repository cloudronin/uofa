    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., validation uncertainty U_val) must be computed and compared to model uncertainty for all QoIs; systematic bias must be within acceptance band.",
      "rationale": "Hemolysis index predictions show a consistent 30–45% over-prediction relative to experimental measurements across tested conditions. Validation uncertainty was computed but the systematic bias exceeds the acceptance band, yielding achieved level 2."
    },
    {
