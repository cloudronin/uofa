  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for Class III VAD simulation at MRL 5 must demonstrate rigorous version control, regression testing, and documented validation of solver modules against analytical solutions.",
      "rationale": "The CFD solver has documented version control and basic regression tests, but formal qualification documentation covering all hemolysis-relevant solver modules is incomplete. Achieved level 2 is below the required level 4 for MRL 5 Class III device use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include method of manufactured solutions or equivalent for all governing equations active in the hemolysis simulation, with documented convergence orders.",
      "rationale": "Code verification was performed for the Navier-Stokes solver using the method of manufactured solutions, but the power-law hemolysis damage model has not been independently verified. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal grid convergence study using Richardson extrapolation must be completed for all five flow-speed operating points, with GCI values reported and below 5% for hemolysis QoI.",
      "rationale": "Grid convergence index studies were conducted at three of five operating points. At the two remaining high-flow conditions, mesh refinement was limited by computational resource constraints. Achieved level 3 does not meet required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate clinical VAD operating conditions including blood analog fluid properties, temperature, and dynamic operating range across all five target flow-speed combinations.",
      "rationale": "Bench tests used a glycerol-water blood analog rather than fresh human blood, and temperature was not actively controlled to 37°C during all runs. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between CFD-predicted hemolysis index and experimental measurements must include uncertainty bounds on both simulation and experiment, with normalized index of agreement reported.",
      "rationale": "Quantitative output comparison was completed with experimental uncertainty bounds reported for four of five operating points. Simulation uncertainty bounds from Monte Carlo propagation are available but the normalized index of agreement calculation has not been formally documented. Achieved level 3 does not meet required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (absolute hemolysis index) must be directly mapped to the clinical acceptance criterion with documented traceability from CFD output to patient safety threshold.",
      "rationale": "The hemolysis index QoI is directly relevant to the clinical threshold, and mapping has been documented. However, the conversion from normalized index of hemolysis (NIH) to plasma free hemoglobin levels relevant to chronic VAD use has not been formally validated. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the FDA generic centrifugal pump geometry under operating conditions spanning the full VAD clinical envelope, using blood or qualified blood analog.",
      "rationale": "Validation was conducted on the FDA generic pump geometry, but only three of the five COU operating points are covered by experimental data. The two highest-speed conditions extrapolate beyond the validated range. Achieved level 2 is substantially below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be quantified and shown to be negligible relative to discretization error for all hemolysis-relevant solution variables.",
      "rationale": "Numerical solver error including iterative convergence residuals and floating-point round-off has not been formally assessed. Residual monitoring plots are available but no formal analysis against acceptance criteria has been performed. This represents an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence must be provided that the simulation was set up and executed by qualified personnel following documented procedures, with independent review of boundary condition specification and solver settings.",
      "rationale": "No formal use error assessment has been performed. Simulation setup was conducted by the primary analyst without documented independent review of boundary conditions or solver configuration. This is flagged as an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The selection of the turbulence model and hemolysis damage model must be justified through systematic comparison of candidate model forms against experimental data, with uncertainty in model form quantified.",
      "rationale": "The SST k-omega turbulence model and the Giersiepen-Wurzinger power-law hemolysis model were selected based on literature precedent without a systematic model form comparison study. Model form uncertainty has not been quantified. This is a critical epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters including blood viscosity, density, hemolysis model coefficients, and boundary conditions must have documented uncertainty characterization with probability distributions suitable for Monte Carlo propagation.",
      "rationale": "Although Monte Carlo UQ was performed, the input uncertainty distributions for hemolysis model coefficients (alpha, beta, C in the power-law model) were taken from a single literature source without independent validation of those distributions. Formal input uncertainty characterization has not been completed. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental test samples (blood analog batches) must be characterized for relevant properties with batch-to-batch variability quantified and propagated into validation uncertainty.",
      "rationale": "Batch-to-batch variability in the glycerol-water blood analog was not characterized. All experiments were assumed to use a nominally identical fluid without formal property measurement for each batch. This represents an unquantified source of experimental uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal equivalency assessment must demonstrate that the boundary conditions and fluid properties used in the validation experiments are sufficiently equivalent to those in the COU to support extrapolation of validation evidence.",
      "rationale": "No formal equivalency assessment has been conducted between the bench test conditions and the clinical VAD operating environment. Differences in fluid rheology, temperature, and dynamic loading have not been systematically evaluated for their impact on hemolysis prediction fidelity."
    }
  ],
