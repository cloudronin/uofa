  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan with configuration management, regression testing, and documented release procedures must be in place and auditable for MRL 5.",
      "rationale": "The CFD solver has basic version control and unit tests, but lacks a formal software quality plan meeting MRL 5 requirements. Configuration management is ad hoc and regression test coverage is insufficient for Class III device submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent analytical verification must demonstrate solver correctness for all governing equations used in the hemolysis prediction workflow.",
      "rationale": "Code verification was performed using simplified benchmark cases but method of manufactured solutions was not applied to the full hemolysis transport equation. Verification coverage is incomplete for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on at least three systematically refined meshes must quantify discretization error with demonstrated convergence for hemolysis QoI.",
      "rationale": "A three-level mesh refinement study was conducted; however, monotonic convergence was not achieved at all operating points. GCI values exceed acceptable thresholds at two of five flow-speed combinations, leaving discretization error inadequately bounded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including physiological fluid properties, rotational speeds, and flow rates within documented tolerances.",
      "rationale": "Experimental conditions closely match VAD operating envelope for three of five operating points. Two high-speed operating points used a non-physiological blood analog fluid, reducing fidelity of the hemolysis validation data at those conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, validation metric per ASME V&V 20) must demonstrate agreement within defined tolerance bands for absolute hemolysis index.",
      "rationale": "Output comparison using normalized RMS error shows acceptable agreement at lower flow rates but deviates beyond tolerance at peak operating speed. Validation metric computed per ASME V&V 20 indicates insufficient agreement for absolute hemolysis acceptance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled QoI (hemolysis index) must be directly traceable to the clinical decision criterion (absolute hemolysis threshold) with documented physiological basis.",
      "rationale": "The hemolysis index QoI is clinically relevant but the mapping from computed scalar stress exposure to absolute plasma-free hemoglobin rise has not been validated for this specific pump geometry. Intermediate model assumptions reduce direct traceability to the clinical threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on the same device geometry and fluid conditions as the COU, or a documented similarity argument must justify extrapolation.",
      "rationale": "Validation was conducted on the FDA generic pump geometry which differs from the clinical device. A similarity argument is provided but does not address all geometric differences, limiting direct applicability of validation evidence to the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver-specific numerical diffusion must be characterized and shown to be negligible relative to discretization error for MRL 5.",
      "rationale": "Numerical solver error was not formally assessed. Convergence residuals were monitored but no systematic analysis of solver-introduced error sources was performed. This represents an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User influence on simulation outcomes must be characterized through inter-analyst variability studies or documented operator qualification procedures for Class III device context.",
      "rationale": "No inter-analyst variability study was conducted and operator qualification records are unavailable. Use error remains an unquantified epistemic gap for this MRL 5 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The choice of turbulence model, hemolysis damage accumulation law, and constitutive blood rheology model must be justified by comparison with higher-fidelity reference data or published benchmarks specific to blood pump flows.",
      "rationale": "The SST k-omega turbulence model was selected based on general pump literature but was not benchmarked against DNS or LES data for blood pump flows. The power-law hemolysis model was adopted without sensitivity analysis of the empirical exponents, introducing unquantified model form uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (fluid properties, boundary conditions, geometric tolerances) must have documented sources with uncertainty bounds propagated through the Monte Carlo UQ framework.",
      "rationale": "Monte Carlo UQ was performed but only six of eleven identified uncertain input parameters were included in the propagation. Blood viscosity temperature dependence and inlet velocity profile shape were treated as deterministic, underestimating total input uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological and device-to-device variability in test samples must be characterized and shown to be accounted for in the validation dataset used to assess hemolysis predictions.",
      "rationale": "Sample characterization data for the blood analog fluid batches and pump unit variability were not provided. Lot-to-lot variability in the hemolysis reagent may have introduced uncontrolled experimental uncertainty. This factor was not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the validation model must be demonstrably equivalent to those in the COU model, or differences must be bounded and their effect on QoI quantified.",
      "rationale": "Equivalency of input parameters between the validation configuration and the COU was not formally demonstrated. Differences in inlet boundary condition specification between the bench test and the clinical use scenario were noted but not quantified in terms of their effect on hemolysis predictions."
    }
  ],
