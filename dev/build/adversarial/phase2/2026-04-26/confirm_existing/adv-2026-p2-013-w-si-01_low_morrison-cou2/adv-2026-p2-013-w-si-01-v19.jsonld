  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite, configuration management, and release validation records consistent with MRL 5 requirements.",
      "rationale": "Solver documentation covers basic regression tests but lacks formal configuration management and independent audit trail required at MRL 5. Achieved level falls two gradations below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solutions or equivalent order-of-accuracy tests must confirm solver implementation for all active physics modules including non-Newtonian rheology and hemolysis source terms.",
      "rationale": "Order-of-accuracy testing was performed only for the base Navier-Stokes solver. The hemolysis power-law source term and non-Newtonian viscosity module were not independently verified against manufactured solutions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or Richardson extrapolation must demonstrate discretization error below 5% for hemolysis index QoI across all five operating points.",
      "rationale": "Three-level mesh refinement study was conducted; GCI values ranged from 4.8% to 11.3% across operating points. Two of five conditions exceed the 5% threshold, leaving discretization uncertainty unresolved at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope (flow rate, rotational speed, fluid properties) within stated tolerances.",
      "rationale": "Experimental data were collected at four of five target operating points. The fifth operating condition (highest flow, highest speed) was not experimentally characterized due to test rig limitations, leaving a gap in the validation space."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, validation uncertainty) must be computed for hemolysis index predictions against experimental measurements with uncertainty bounds on both sides.",
      "rationale": "Output comparison was performed using point estimates only; experimental measurement uncertainty was not propagated into the comparison metric. Validation uncertainty U_val was not formally computed, precluding a compliant quantitative assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (hemolysis index) must be identical to the decision-critical QoI (absolute hemolysis index below clinical threshold) with no surrogate substitution.",
      "rationale": "Validation used normalized hemolysis index (HI%) as proxy for absolute plasma-free hemoglobin rise. The clinical decision threshold is expressed in absolute mg/dL units. The mapping between HI% and absolute hemolysis has not been formally validated for this pump geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the same pump geometry, fluid, and operating regime as the COU. Surrogate geometries or scaled experiments require documented similarity arguments.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump benchmark geometry, which matches the COU pump. However, experiments used porcine blood rather than human blood; a rheological similarity argument was provided but not independently reviewed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver residual behavior must be documented and shown to be negligible relative to discretization error for all operating points.",
      "rationale": "Solver residual convergence was not systematically documented across all five operating points. No assessment of round-off error contribution was performed. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review process must confirm that model setup, boundary condition assignment, and post-processing scripts are free from user-introduced errors through independent checking.",
      "rationale": "No independent review of model setup or post-processing was performed. A single analyst prepared and executed all simulations. Use error cannot be bounded without a second-analyst verification step."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The chosen turbulence model, hemolysis constitutive law, and blood rheology model must be justified against alternatives with documented sensitivity analysis demonstrating model-form uncertainty is bounded.",
      "rationale": "The Giersiepen-Wurzinger hemolysis power law was selected without comparison to alternative formulations (e.g., Arora, Taskin). Turbulence model sensitivity was assessed only at one operating point. Model-form uncertainty is not bounded across the full COU envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (viscosity coefficients, hemolysis law exponents, boundary flow profiles) must have documented uncertainty distributions; Monte Carlo propagation must cover all uncertain inputs.",
      "rationale": "Monte Carlo UQ was performed but only four of eleven uncertain input parameters were varied. Hemolysis law exponents C and alpha were treated as fixed point estimates despite published variability of ±30%. Input uncertainty is underestimated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental blood samples used in validation must be characterized for hematocrit, donor variability, and storage age; sample-to-sample variability must be included in experimental uncertainty estimates.",
      "rationale": "Sample characterization records were not available for review. Hematocrit range and donor pool size for the validation experiments are undocumented. This represents an unresolved epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the validation model must be demonstrably equivalent to those used in the COU model; any differences must be assessed for their impact on QoI.",
      "rationale": "The validation model used inlet velocity profiles derived from a separate pump-loop PIV experiment rather than the COU boundary conditions. Equivalency of these profiles to clinical operating inlet conditions has not been assessed."
    }
  ],
