  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at Model Risk Level 5. Seven factors were formally assessed; all seven show achieved levels below required levels, representing documented credibility gaps. Six factors remain unassessed, constituting epistemic gaps. Monte Carlo uncertainty quantification was performed but covers only a subset of uncertain inputs. The package is accepted as a complete and transparent record of the current credibility state, with the understanding that the model is not approved for regulatory submission until all factor gaps are resolved.",
