  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single shortfall in Test conditions (achieved 2, required 3) is accepted based on the following: (1) the single ASTM F1717 configuration represents the clinically relevant worst-case loading; (2) analytical sensitivity studies confirm that QoI predictions are not materially sensitive to offset distance variation within the F1717 design space; (3) the quantitative validation metric E/uval < 1.96 is satisfied for all primary QoIs across all three independent modeling teams and all 11 specimens. The model is accepted as sufficiently credible to support the 510(k) regulatory submission for the non-cannulated 7.5 mm pedicle screw construct.",
