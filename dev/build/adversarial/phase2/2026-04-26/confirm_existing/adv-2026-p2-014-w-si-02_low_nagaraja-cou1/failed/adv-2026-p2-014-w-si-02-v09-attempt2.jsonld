      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of model setup, boundary conditions, and material assignments.",
      "rationale": "Simulation workflow documented in a simulation plan reviewed by two independent engineers. Boundary condition application and material card assignments independently verified. No use errors identified during review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics model with nonlinear geometry and contact must be justified as appropriate for the compression-bending loading regime.",
      "rationale": "Implicit nonlinear FEA with large-displacement formulation and surface-to-surface contact between screw and rod selected. Titanium alloy modeled as bilinear isotropic hardening. Model form appropriate for ASTM F1717 quasi-static compression-bending. Validated against three independent FEA codes (FDA, Ansys, DePuy Synthes)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters sourced from traceable measurements or published standards with uncertainty quantification.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and yield strength (880 MPa) taken from ASTM F136 and confirmed by coupon testing from the same material lot. Screw geometry from manufacturer CAD files verified by coordinate measuring machine. Input uncertainty propagated via Monte Carlo (N=1000 samples)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental constructs must be from the same design family as the simulated device, with documented lot traceability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA OSEL and DePuy Synthes). All constructs from the same production lot with documented traceability. Sample size sufficient for statistical comparison per ASTM E2935."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios including at least two load levels or configurations.",
      "rationale": "Testing performed under a single ASTM F1717 compression-bending configuration at room temperature. Clinical loading variability not fully captured. This factor is below required level; partially mitigated by the high fidelity of the F1717 standardized protocol and cross-laboratory replication. Accepted as minor gap given medium model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to the physical test conditions used in the validation experiments.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 test fixture geometry and loading application points. Fixture stiffness characterized and incorporated into the model. Material properties matched to lot-specific coupon data. Equivalency confirmed by sensitivity analysis showing QoI insensitivity to fixture compliance variation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of FEA QoIs against experimental measurements using pre-specified acceptance bounds (< 10% difference, E/uval < 1.96).",
      "rationale": "Three QoIs compared: construct stiffness (4.2% difference, E/uval=0.87), yield force (6.8%, E/uval=1.31), and force at 40 mm displacement (7.5%, E/uval=1.58). All within pre-specified acceptance bounds. Statistical comparison accounts for experimental variability across N=11 constructs and two laboratories."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation must be directly relevant to the clinical performance endpoints and the COU decision.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the primary mechanical performance indicators specified in ASTM F1717 and are directly linked to clinical performance (fatigue life prediction, fracture risk). QoI relevance confirmed by clinical literature review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
