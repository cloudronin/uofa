  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels for Model Risk Level 3. One factor (Test conditions) achieved level 2 against required level 3 due to single-configuration testing; this gap is accepted given the standardized ASTM F1717 protocol, cross-laboratory replication across N=11 constructs, and medium decision consequence. All three QoIs meet pre-specified acceptance bounds (< 10% difference, E/uval < 1.96). The FEA modeling framework is judged credible for the stated COU.",
