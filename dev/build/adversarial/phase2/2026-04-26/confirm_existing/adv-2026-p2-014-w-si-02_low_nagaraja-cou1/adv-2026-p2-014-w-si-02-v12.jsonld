    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear-elastic continuum model with frictional contact at screw-rod interface; model form justified by experimental load-displacement linearity up to yield.",
      "rationale": "Experimental load-displacement curves confirm linear behavior up to approximately 85% of yield force. Linear-elastic model with von Mises yield criterion for post-yield detection is appropriate. Frictional contact (mu=0.2 Ti-alloy on Ti-alloy) at screw-rod interface validated against published tribology data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
