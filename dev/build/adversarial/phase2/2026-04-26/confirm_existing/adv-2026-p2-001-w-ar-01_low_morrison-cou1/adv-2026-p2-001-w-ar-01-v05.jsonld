  "signature": "ed25519:b2e4a6c8d0f2e4a6c8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The CFD solver (ANSYS Fluent 2022R1) must hold a current ISO 9001 quality management certificate and maintain a documented regression test suite covering all flow physics modules used in this analysis. Version control logs and test reports must be available for audit.",
      "rationale": "ANSYS Fluent 2022R1 is a commercially validated solver with ISO 9001 certification. Regression test suite documentation was reviewed and confirmed current. Version control records confirm the solver version used throughout the study is consistent. Gradation 2 is appropriate for MRL 2 with medium model influence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through at least one manufactured solution or benchmark test case with documented convergence rates consistent with the nominal order of the numerical scheme.",
      "rationale": "The solver was verified against the FDA benchmark nozzle problem (FDA critical path initiative). Convergence rates for velocity and pressure fields were confirmed to match expected second-order accuracy. Results published in peer-reviewed literature support code correctness for the flow regime relevant to this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh convergence study using at least three systematically refined meshes must be completed. The Grid Convergence Index (GCI) for the hemolysis index QoI must be below 5% on the medium mesh used for production runs.",
      "rationale": "Three mesh refinements were performed (coarse: 2.1M cells, medium: 6.8M cells, fine: 18.4M cells). GCI for the relative hemolysis index was computed as 2.3% between medium and fine meshes, satisfying the 5% threshold. The medium mesh was selected for all production simulations. Achieved level 3 reflects the systematic Richardson extrapolation analysis performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Test conditions were reviewed and considered adequate for this assessment. The experimental setup was documented and boundary conditions were applied consistently with the COU operating range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Outputs were compared and found to be within acceptable ranges. Standard comparison metrics were applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs extracted from the CFD model (relative hemolysis index RH, wall shear stress distribution, and scalar stress exposure) must be directly traceable to the clinical endpoint (hemolysis rate) via a documented power-law hemolysis damage model. The damage model must be cited and its applicability to the operating regime confirmed.",
      "rationale": "The relative hemolysis index is computed using the Giersiepen-Wurzinger power-law damage model, which is the standard approach for CFD hemolysis prediction in rotary blood pumps. The QoI is directly mapped to the clinical endpoint of erythrocyte damage. Relevance at Gradation 2 is confirmed by the use of an established, literature-supported damage model applied within its validated operating range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use a geometrically similar pump (same impeller topology, within 15% dimensional tolerance) operating at flow rates and rotational speeds that overlap with the COU operating envelope. At least 3 of the 5 COU operating points must fall within the validated operating range.",
      "rationale": "Validation experiments used the FDA generic centrifugal blood pump geometry, which is identical to the simulation geometry. Experimental operating points at 2.5 L/min / 2500 RPM, 4.5 L/min / 3500 RPM, and 6.0 L/min / 4500 RPM span the COU envelope. All 5 COU operating points fall within the validated range. Validation activities are highly relevant to the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "rationale": "Solver residuals were monitored and convergence was achieved for all simulations. Iterative convergence was confirmed to be adequate for this assessment level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Not assessed at MRL 2 with medium model influence. Use error controls are addressed through standard operating procedures and analyst training records maintained by the performing organization. Scoping determination confirms this factor is not required at the applicable credibility level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The RANS k-omega SST turbulence model was selected based on its established performance for rotating machinery flows. Model form is considered adequate. No formal sensitivity study was performed at this credibility level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (fluid properties, boundary conditions, geometry dimensions) must be traceable to calibrated measurement sources or published reference data. Uncertainty bounds must be documented for the three most influential input parameters as identified by a screening sensitivity analysis.",
      "rationale": "Blood viscosity was taken from published literature (Newtonian approximation, mu = 0.0035 Pa·s, consistent with high-shear CPB conditions). Inlet flow rates were set from device specifications with ±2% uncertainty. Rotational speed was specified from device operating conditions with ±10 RPM uncertainty. A one-at-a-time sensitivity analysis confirmed that inlet flow rate and rotational speed are the two most influential parameters; uncertainty bounds are documented in the analysis report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
