  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures consistent with MRL 2 requirements: version control, documented test suite covering principal solver routines, and traceability of code changes to simulation outputs.",
      "rationale": "ANSYS Fluent 19.2 is employed under a documented SQA plan. Version control is maintained via Git with tagged release commits. Regression test suite covers turbulence model initialization, boundary condition enforcement, and hemolysis scalar transport. All tests pass for the release version used in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via method of manufactured solutions (MMS) for the scalar hemolysis transport equation, demonstrating expected order-of-accuracy convergence on at least three systematically refined grids.",
      "rationale": "MMS verification was performed for the Giersiepen-Wurzinger hemolysis power-law scalar transport equation implemented as a user-defined scalar in Fluent. Spatial convergence at 1.94 order was confirmed across three grid levels, consistent with second-order discretization. Results documented in internal verification report VR-2023-04."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI below 5% on the medium grid, with Richardson extrapolation applied across three systematically refined meshes at representative operating point (6 L/min, 3500 RPM).",
      "rationale": "Three hexahedral-dominant grids (4.2 M, 8.7 M, and 17.4 M cells) were generated with a systematic refinement ratio of 1.26. GCI for normalized index of hemolysis at the reference operating point is 2.8% on the medium grid and 1.1% on the fine grid. The medium grid was selected for the parametric sweep to balance accuracy and computational cost. Boundary layer y+ values maintained below 1.0 for all wall-resolved regions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Test conditions replicate the FDA benchmark experimental protocol. Flow rates of 2.5 and 6.0 L/min at rotational speeds of 2500, 3500, and 4500 RPM are matched to experimental conditions reported in the FDA benchmark study. Blood analog fluid properties (viscosity 0.0035 Pa·s, density 1056 kg/m³) are consistent with published experimental values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Simulation outputs are compared."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must directly correspond to the clinical decision metric (relative hemolysis index RH < 1 against predicate device). Secondary QoIs include wall shear stress distribution and scalar residence time.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary QoI and maps directly to the regulatory decision criterion RH < 1. Wall shear stress and scalar residence time are computed as secondary QoIs to support mechanistic interpretation. All QoIs are standard metrics in FDA hemolysis guidance documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the FDA generic blood pump geometry under the same fluid properties and at least three overlapping operating points with the COU envelope. Validation data must originate from peer-reviewed or FDA-documented experimental sources.",
      "rationale": "Validation is performed using the FDA generic centrifugal blood pump geometry, which is identical to the device geometry used in the COU. Experimental data from Malinauskas et al. (2017) provide hemolysis measurements at five operating conditions that span the COU operating envelope. Fluid properties in validation and COU simulations are matched. The validation scenario is assessed as directly relevant to the COU with no geometric or operational extrapolation required."
    },
    {
