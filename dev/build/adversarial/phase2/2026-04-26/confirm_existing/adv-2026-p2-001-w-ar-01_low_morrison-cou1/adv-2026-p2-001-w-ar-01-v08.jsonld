  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures documented; version-controlled solver (ANSYS Fluent 2022 R1) with traceable release notes; regression test suite executed with zero critical failures prior to simulation campaign.",
      "rationale": "The CFD solver used for this study is a commercially released, version-controlled code with documented quality assurance procedures. Regression tests covering relevant flow regimes were executed and passed. Release notes confirm no known defects affecting rotating-machinery hemolysis predictions. SQA level 2 is required at MRL 2 for a Class II device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test using manufactured solution demonstrates observed convergence rate within 10% of formal order for the momentum and scalar transport equations employed in hemolysis prediction.",
      "rationale": "Code verification was performed using the method of manufactured solutions on the governing equations (RANS with SST k-omega turbulence closure and power-law hemolysis scalar transport). The observed order of accuracy was 1.92 for momentum and 1.88 for scalar transport against the formal second-order scheme, satisfying the level 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the hemolysis index QoI must be below 5% on the medium-to-fine mesh pair; Richardson extrapolation applied to confirm asymptotic range.",
      "rationale": "A three-level mesh refinement study (coarse 4.2 M cells, medium 11.8 M cells, fine 28.6 M cells) was conducted at the nominal operating point (5 L/min, 3000 RPM). GCI for the relative hemolysis index was 2.3% between medium and fine meshes, confirming asymptotic convergence. The medium mesh was selected for the parametric sweep, exceeding the level 2 requirement and achieving level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental test conditions were documented in the laboratory protocol. Boundary conditions match the simulation inlet flow rates and rotational speeds within measurement uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Simulation outputs were compared to experimental measurements. Agreement was within acceptable bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index RH) must be directly traceable to the clinical endpoint of interest; secondary QoIs (wall shear stress distribution, exposure time histogram) must be shown to correlate with RH via sensitivity analysis with R² > 0.85.",
      "rationale": "The relative hemolysis index RH is the primary QoI and is directly linked to the clinical endpoint (device-induced hemolysis). Secondary QoIs including wall shear stress and scalar exposure time were shown to correlate strongly with RH (R² = 0.91 and 0.88 respectively) via parametric sensitivity analysis across the 5 operating points. This satisfies the level 2 relevance requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover at least 3 of the 5 COU operating points; fluid properties (viscosity, hematocrit) in validation tests must be within 10% of COU conditions; pump geometry used in validation must be the same nominal design.",
      "rationale": "Validation activities were conducted on the identical FDA generic centrifugal pump geometry at all 5 COU operating points using porcine blood at 35% hematocrit, matching COU conditions within 8%. This directly satisfies the level 2 relevance requirement for validation-to-COU mapping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "rationale": "Solver convergence was monitored and residuals were within acceptable limits."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "rationale": "Standard simulation setup procedures were followed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The chosen turbulence model (SST k-omega) and hemolysis power-law model must be justified by published benchmarks on rotating blood-contacting devices; model-form uncertainty must be estimated via comparison of at least two turbulence model variants at the nominal operating point, with RH difference below 15%.",
      "rationale": "SST k-omega was selected based on published benchmarks for centrifugal pump hemolysis (Taskin et al., 2012; Yu et al., 2017). A model-form uncertainty study comparing SST k-omega and realizable k-epsilon at the nominal operating point showed RH difference of 9.4%, within the 15% threshold. The Giersiepen power-law hemolysis model was selected as the most widely validated formulation for CFD-based hemolysis prediction in CPB devices."
    },
    {
