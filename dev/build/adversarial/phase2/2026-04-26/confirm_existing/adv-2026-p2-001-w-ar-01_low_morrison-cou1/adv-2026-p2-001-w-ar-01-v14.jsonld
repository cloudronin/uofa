  "signature": "ed25519:b4c2d3e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level 2 requires documented version control, build reproducibility records, and regression test suite with pass/fail log for the CFD solver release used in this study.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially validated solver with documented SQA processes meeting FDA guidance for CFD-based device submissions. Version control logs and regression test results are archived in the project repository. Achieved level 2 satisfies MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at level 2 requires demonstration of correct order-of-accuracy using method of manufactured solutions (MMS) for the governing equations relevant to this COU.",
      "rationale": "MMS study confirmed second-order spatial accuracy for the incompressible Navier-Stokes solver on structured and unstructured meshes. Results documented in validation report MOR-VV-003, Section 4.2. Achieved level 2 satisfies requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Mesh convergence was evaluated across three systematically refined grids (coarse: 4.2M cells, medium: 11.8M cells, fine: 31.4M cells). Grid convergence index (GCI) computed per Roache methodology; GCI for hemolysis index QoI was 3.1% on the medium mesh. Medium mesh selected for production runs. Discretization error is within acceptable bounds for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Test conditions are generally representative of clinical CPB use. Standard conditions applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Output comparison performed. Results within acceptable range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI relevance at level 2 requires that the modeled quantities directly map to the clinical endpoint (hemolysis index) and that the mapping is documented with supporting literature. Level 3 additionally requires sensitivity analysis confirming QoI dominance.",
      "rationale": "The relative hemolysis index (RH) computed from the power-law hemolysis model (Giersiepen-Wurzinger) directly maps to plasma-free hemoglobin measured in bench testing. Sensitivity analysis confirmed RH is the dominant output variable across all 5 operating points. Literature basis documented in MOR-VV-003, Section 3.1. Achieved level 3 exceeds MRL 2 requirement of level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted at conditions overlapping the COU envelope in terms of flow rate, rotational speed, and blood analog fluid properties. Level 2 requires at least partial overlap with documented interpolation rationale.",
      "rationale": "Validation experiments performed on the FDA generic centrifugal pump at 2.5 L/min and 4.5 L/min at 2500 and 3500 RPM, spanning the COU operating envelope. Blood analog (glycerol-water) viscosity matched within 5% of clinical blood viscosity at 37°C. Interpolation to intermediate operating points documented in MOR-VV-003, Section 5.3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Numerical solver error is not separately assessed at MRL 2 given that code verification (factor above) subsumes solver error characterization at this risk level. Scoping decision documented in MOR-VV-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Use error not assessed at MRL 2. Standard analyst training and peer review procedures are in place."
    },
