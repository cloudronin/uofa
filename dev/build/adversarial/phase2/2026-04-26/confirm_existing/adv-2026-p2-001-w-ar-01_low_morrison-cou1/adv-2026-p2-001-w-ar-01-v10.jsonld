    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in simulation must directly correspond to the clinical metric of interest (relative hemolysis index, RH) and must be computable from simulation outputs without additional unvalidated post-processing steps.",
      "rationale": "The relative hemolysis index (RH) was computed directly from the CFD shear stress field using the Giersiepen-Wurzinger power-law model. RH is the primary regulatory metric for hemolysis comparison against the predicate device and maps directly to the COU decision criterion (RH < 1)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
