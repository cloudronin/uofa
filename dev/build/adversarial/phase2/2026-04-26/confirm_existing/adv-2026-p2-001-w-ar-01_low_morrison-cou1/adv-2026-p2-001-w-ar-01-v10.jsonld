      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated and documented per institutional SQA procedures; version control and regression testing records must be available for review.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a controlled SQA environment. Version control logs, regression test suite results, and release validation documentation were reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations through manufactured solution or benchmark comparison with documented error norms.",
      "rationale": "The Navier-Stokes solver was verified against the Taylor-Green vortex manufactured solution. L2 error norms showed second-order spatial convergence consistent with the discretization scheme."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Mesh convergence was assessed using three systematically refined grids (coarse: 2.1M cells, medium: 6.4M cells, fine: 18.9M cells). Grid convergence index (GCI) for the relative hemolysis index QoI was 3.2% on the fine mesh, within acceptable bounds for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
