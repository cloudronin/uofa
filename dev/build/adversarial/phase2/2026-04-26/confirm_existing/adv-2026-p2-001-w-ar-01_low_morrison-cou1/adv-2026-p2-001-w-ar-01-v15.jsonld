  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level 2 requires documented version control, regression testing suite, and traceable build records. ANSYS Fluent 2021R2 is used under an FDA-recognized SQA framework with full audit trail.",
      "rationale": "ANSYS Fluent 2021R2 is operated under an institutional SQA plan. Version control logs, regression test results, and installation qualification records are archived. All simulation scripts are stored in a Git repository with tagged releases corresponding to each simulation campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at level 2 requires demonstration that the solver correctly implements the governing equations through method-of-manufactured-solutions (MMS) or equivalent benchmark tests published in peer-reviewed literature.",
      "rationale": "ANSYS Fluent has been verified against the FDA benchmark nozzle and the lid-driven cavity benchmark. Published MMS results for the Navier-Stokes solver are cited in the ANSYS verification manual (2021R2). Internal MMS tests for the scalar transport equation used in the hemolysis power-law model were executed and passed to within 0.3% of the analytical solution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "A three-level mesh refinement study was performed using the Richardson extrapolation method. Grid convergence index (GCI) values for the volume-averaged hemolysis index were below 3% for all five operating points, confirming that the solution is within the asymptotic range of convergence. The finest mesh of 8.2 million polyhedral cells was selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental test conditions are adequately characterized. Standard assessment was performed."
