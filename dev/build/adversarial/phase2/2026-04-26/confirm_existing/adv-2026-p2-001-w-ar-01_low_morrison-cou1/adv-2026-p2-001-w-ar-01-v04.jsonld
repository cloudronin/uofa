  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures verified: version-controlled solver (ANSYS Fluent 2022R2), documented build and test records, regression test suite passing for all relevant flow modules.",
      "rationale": "The CFD solver used is a commercially validated code with documented version control and regression testing. SQA records confirm compliance with MRL 2 requirements. Internal audit confirmed no unresolved defects affecting hemolysis-relevant modules."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Code verification activities were performed. Standard benchmarks were run."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for wall shear stress and velocity magnitude at all five operating points. Richardson extrapolation applied on three systematically refined meshes (2.1M, 8.4M, 33.6M elements).",
      "rationale": "Three-level mesh refinement study performed following Celik et al. (2008). GCI values ranged from 1.2% to 3.8% across operating points, all below the 5% threshold. Achieved level exceeds required level, providing additional confidence in spatial accuracy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Test conditions were documented. Boundary conditions matched experimental setup."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predicted within ±20% of experimental measurements across all five operating conditions. Relative hemolysis index RH < 1.0 for worst-case operating point.",
      "rationale": "CFD-predicted NIH values compared against experimental measurements from FDA pump study. Maximum deviation was 14.3% at the 6 LPM / 3500 RPM operating point. All five operating conditions satisfied the ±20% tolerance. RH = 0.87 at worst-case condition, satisfying RH < 1 criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, wall shear stress, scalar stress exposure) demonstrated to be mechanistically linked to hemolysis outcome through power-law damage model; sensitivity analysis confirms these QoIs capture >90% of hemolysis variance across the design space.",
      "rationale": "The quantities of interest — normalized index of hemolysis and scalar stress exposure — are directly tied to the Giersiepen-Wurzinger power-law hemolysis model. Sensitivity analysis confirmed that variations in these QoIs account for the dominant hemolysis response. QoI selection is consistent with FDA guidance on blood-contacting device CFD."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Validation activities were relevant to the COU. Experimental data used in validation was representative."
    },
    {
