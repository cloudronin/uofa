    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used (ANSYS Fluent 2022 R2) must be a commercially validated solver with documented version control and regression testing. Required level 2 mandates confirmation of solver release version and change log review.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially released CFD solver with documented QA processes. Version control records confirmed. Regression test suite executed prior to simulation campaign with no anomalies reported. Achieves required level 2 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent benchmark must demonstrate correct spatial order of accuracy for the momentum and continuity equations at required level 2.",
      "rationale": "MMS verification performed on a simplified rotating channel geometry. Second-order spatial accuracy confirmed for velocity and pressure fields. Results documented in validation report VR-003."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A mesh refinement study with at least three systematically refined grids must demonstrate grid convergence. Discretization error must be quantified and reported as a percentage of the QoI. Required level 2 mandates documented GCI or equivalent.",
      "rationale": "Three-mesh refinement study conducted (coarse: 2.1M cells, medium: 5.4M cells, fine: 13.8M cells). Grid convergence index (GCI) computed per Celik et al. 2008. Hemolysis index discretization uncertainty: 4.2% on fine mesh. Achieves required level 2."
    },
    {
      "type": "CredibilityFactor",
