  "signature": "ed25519:b4c2d3e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality assurance activities at Gradation 2 require documented version control, regression testing for key solver routines, and a traceable change log. The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated code with documented QA procedures meeting this level.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially available, widely validated CFD solver. Vendor-supplied QA documentation, including regression test suites and release notes, was reviewed and found consistent with Gradation 2 requirements. Version control of all case files and UDF scripts was maintained in a git repository with commit-level traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Numerical code verification was performed at a general level consistent with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires a formal mesh convergence study using at least three systematically refined grids and reporting of the Grid Convergence Index (GCI). The GCI for the hemolysis index QoI must be below 5% on the medium mesh used for production runs.",
      "rationale": "Three hexahedral-dominant meshes were generated at coarse (4.2 M cells), medium (11.8 M cells), and fine (31.4 M cells) resolutions using a refinement ratio of approximately 1.4. GCI analysis per Celik et al. (2008) yielded a GCI of 3.1% on the medium mesh for the normalized hemolysis index, satisfying the Gradation 2 threshold. The medium mesh was selected for all production simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Test conditions were documented and found adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires quantitative comparison of simulation outputs to experimental measurements using a defined metric. The normalized hemolysis index (NIH) predicted by CFD must agree with bench measurements within ±25% across all five operating points.",
      "rationale": "CFD-predicted NIH values were compared against bench measurements from the FDA hemolysis dataset across five flow-speed operating points. Relative errors ranged from 4.2% to 19.7%, with all points within the ±25% acceptance band. Systematic over-prediction at high shear conditions is consistent with known conservative bias of the Giersiepen power-law damage model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires documented justification that the selected QoIs (normalized hemolysis index and relative hemolysis index RH) are directly relevant to the clinical decision and that the mapping from simulation output to QoI is traceable.",
      "rationale": "The normalized hemolysis index (NIH) and relative hemolysis index (RH) are the standard regulatory QoIs for blood pump hemolysis assessment per FDA guidance. The mapping from CFD shear stress fields to NIH via the Giersiepen–Wurzinger power-law model is documented in the simulation protocol. RH < 1 is the regulatory acceptance threshold, directly linking the simulation QoI to the clinical decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Validation activities were considered relevant to the COU at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
