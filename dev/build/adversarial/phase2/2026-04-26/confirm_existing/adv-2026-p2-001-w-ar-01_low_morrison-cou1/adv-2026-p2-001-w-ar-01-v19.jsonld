  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level 2 requires documented version control, regression testing suite, and traceable build environment. Achieved by maintaining CFD solver under Git version control with tagged release 4.1.2, automated regression tests covering 47 canonical cases, and a containerized build environment (Docker image SHA recorded).",
      "rationale": "The ANSYS Fluent v2022R2 solver is used under institutional license with documented version control. A regression test suite of 47 canonical benchmark cases was executed against the tagged solver release. Build environment reproducibility is ensured via a locked Docker container image. SQA level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at level 2 requires demonstration of correct numerical implementation through method of manufactured solutions (MMS) or equivalent benchmark comparison for the relevant physics. Achieved by MMS convergence study confirming second-order spatial accuracy for the incompressible Navier-Stokes solver.",
      "rationale": "A method of manufactured solutions study was conducted for the incompressible Navier-Stokes equations in rotating reference frame. Observed order of accuracy was 1.97, consistent with the nominal second-order scheme. No coding errors were identified. Numerical code verification level 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error level 2 requires a systematic mesh refinement study with at least three mesh densities and quantified GCI or equivalent error estimate for the primary QoI. Achieved by three-level mesh refinement (4.2 M, 11.7 M, 28.4 M cells) with GCI < 3.1% for normalized hemolysis index.",
      "rationale": "Three mesh densities (4.2 M, 11.7 M, and 28.4 M hexahedral cells) were evaluated at the nominal operating point. Richardson extrapolation yielded an estimated discretization error of 2.8% for the normalized hemolysis index, with GCI of 3.1%. The 11.7 M cell mesh was selected as the production mesh. Discretization error level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Test conditions were documented per standard laboratory protocols. Flow rates and rotational speeds were within acceptable ranges for the CPB operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison level 2 requires quantitative comparison of model outputs against experimental measurements using a defined metric and threshold. Level 3 additionally requires uncertainty quantification on both simulation and experimental outputs. Achieved by computing normalized hemolysis index error and RH ratio with 95% confidence intervals from repeated experimental trials.",
      "rationale": "CFD-predicted hemolysis index was compared against experimental measurements across 5 flow-speed operating points. Mean absolute error was 8.3% relative to experimental values. The relative hemolysis index RH remained below 1.0 at all operating points (range 0.71–0.94), satisfying the COU acceptance criterion. Experimental uncertainty (95% CI) was ±6.2%. Output comparison level 3 is achieved, exceeding the required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The normalized hemolysis index and relative hemolysis ratio are the quantities of interest. These are directly relevant to the clinical decision regarding worst-case hemolysis operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
