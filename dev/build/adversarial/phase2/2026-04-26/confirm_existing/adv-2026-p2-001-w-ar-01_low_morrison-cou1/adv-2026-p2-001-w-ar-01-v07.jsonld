  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The solver must be a commercially released CFD code with documented version control, a user manual, and a regression test suite. Release notes must confirm the version used is not subject to any open defects affecting turbulent rotating-zone simulations.",
      "rationale": "ANSYS Fluent 2022R2 was used. Version control records, regression test logs, and the official release notes were reviewed. No open defects affecting the MRF rotating-zone or turbulence models were identified. SQA level 2 is appropriate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests using a manufactured solution must confirm the solver achieves at least second-order spatial convergence for velocity and pressure fields in rotating-zone problems representative of the pump geometry.",
      "rationale": "Method of manufactured solutions applied to a rotating annular domain. Observed order of accuracy was 1.97 for velocity and 1.94 for pressure, consistent with the nominal second-order scheme. Code verification is satisfied at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A systematic mesh refinement study with at least three grid levels must demonstrate a Grid Convergence Index (GCI) below 5% for the primary quantity of interest (normalized index of hemolysis, NIH) at all five operating points.",
      "rationale": "Three polyhedral mesh densities (3.2 M, 6.8 M, 14.1 M cells) were evaluated. Richardson-extrapolated GCI for NIH ranged from 1.8% to 3.9% across operating points. The production mesh (6.8 M cells) was selected as the balance between accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Test conditions were drawn from the FDA benchmark experimental protocol. Flow rates and rotational speeds were matched to within measurement uncertainty. Temperature and fluid viscosity were controlled and documented.",
      "acceptanceCriteria": "Experimental boundary conditions must be reproduced in simulation to within ±2% of the nominal flow rate and ±1% of the nominal rotational speed, with fluid properties (viscosity, density) matched to within ±1% of the test fluid specification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated NIH must agree with experimental NIH measurements within ±15% across all five operating points, and the relative hemolysis index RH must be below 1.0 for the worst-case operating condition.",
      "rationale": "Simulated NIH values agreed with experimental data within 8–13% across all five operating points. RH was 0.87 for the worst-case condition, satisfying the RH < 1 criterion. Output comparison is met at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) are the quantities of interest directly linked to the regulatory decision. Both are well-established in the literature for CPB hemolysis assessment and are consistent with FDA guidance.",
      "acceptanceCriteria": "The quantities of interest (NIH, RH) must be those specified in the regulatory submission plan and must be directly computable from CFD output fields without additional unvalidated post-processing transformations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use a geometric replica of the FDA generic centrifugal pump or a device with documented similarity in Reynolds number regime, impeller tip speed, and blood analogue fluid properties.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry with a glycerol-water blood analogue. Reynolds number and tip-speed Mach number matched the clinical operating envelope. Validation activities are directly relevant to the COU."
    },
    {
