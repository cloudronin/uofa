      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Simulated hemolysis index values were compared against experimental measurements across all five operating points. Mean absolute error was 8.3%. Qualitative agreement in trend across operating conditions was confirmed."
