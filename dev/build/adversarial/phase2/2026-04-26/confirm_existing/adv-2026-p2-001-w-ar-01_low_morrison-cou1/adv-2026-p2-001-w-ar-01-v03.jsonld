  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2022R2) with documented V&V history; version control and audit trail maintained per ISO 9001 QMS. Gradation 2 requires documented solver qualification records.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with published verification benchmarks. The project team maintained a version-controlled simulation environment with change logs. Solver qualification documentation was reviewed and found compliant with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes at least one published benchmark test relevant to rotating machinery flow; results documented in verification report. Gradation 2 requires evidence of code correctness for the physics class of interest.",
      "rationale": "ANSYS Fluent has been verified against the FDA benchmark nozzle and rotating disk problems. Internal verification tests for the MRF (Multiple Reference Frame) rotating zone implementation were reviewed and confirmed to produce results within 1% of analytical solutions for laminar Couette flow analogues."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed for key hemolysis-relevant quantities; GCI < 5% on fine grid accepted at Gradation 2. Gradation 3 additionally requires Richardson extrapolation estimate reported.",
      "rationale": "A three-level mesh refinement study was conducted using polyhedral meshes of 2.1M, 5.8M, and 14.2M cells. Richardson extrapolation was applied to scalar shear stress and velocity magnitude at the impeller tip. GCI on the fine mesh was 1.8% for shear stress and 2.3% for velocity, exceeding the Gradation 2 threshold. Achieved level reported as 3 due to Richardson extrapolation documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Test conditions were generally representative of clinical CPB operating ranges. Flow rates and rotational speeds used in validation experiments bracketed the 5 COU operating points. No detailed mapping of experimental uncertainty to acceptance thresholds was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Predicted hemolysis index values were compared against published experimental data. Agreement was generally within acceptable ranges for the operating conditions assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (scalar shear stress, exposure time, and normalized index of hemolysis NIH) are directly linked to the COU decision metric (RH < 1). Gradation 2 requires documented traceability from model output to clinical decision variable.",
      "rationale": "The primary quantity of interest is the normalized index of hemolysis (NIH) derived from the Giersiepen-Wurzinger power-law model applied to Lagrangian particle tracks. NIH is directly used to compute the relative hemolysis index RH. Traceability from CFD shear stress fields through particle tracking to NIH to RH is documented in the simulation plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry family and overlapping flow-speed envelope as the COU. Gradation 2 requires documented similarity argument between validation scenario and COU scenario.",
      "rationale": "Validation data were drawn from published FDA generic centrifugal pump experiments conducted at NHLBI. The validation operating points (2.5 L/min at 2500 RPM; 5.0 L/min at 3000 RPM) bound three of the five COU operating points. A similarity argument table is provided in Appendix B of the V&V report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "rationale": "Solver error assessed at Gradation 1. Residual convergence to 1e-5 confirmed for all simulations. No additional characterization required at MRL 2 for this factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Use error is not assessed at MRL 2 for this factor per project scoping decision. Acceptable at Gradation 1 given medium model influence and the availability of experimental confirmation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Model form adequacy reviewed for turbulence closure and hemolysis submodel. Standard assessment performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
