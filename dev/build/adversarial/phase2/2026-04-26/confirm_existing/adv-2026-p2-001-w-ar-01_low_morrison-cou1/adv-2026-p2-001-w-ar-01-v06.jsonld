  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The CFD solver (ANSYS Fluent 2022R2) must be under version control with documented release notes, regression test suite passing rate ≥ 95%, and all simulation scripts archived in a traceable repository with audit log.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with documented QA processes. Version control via Git repository; regression tests show 97% pass rate. All case files and UDFs are archived under institutional repository with commit hashes recorded. Meets Gradation 2 requirements for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark problem must demonstrate second-order spatial convergence (observed order ≥ 1.8) for the governing equations relevant to hemolysis prediction.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes equations. Observed order of accuracy of 1.94 on three systematically refined grids. Benchmark results consistent with published FDA pump challenge data. Code verification is complete and meets the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the hemolysis index QoI must be less than 5% on the production mesh, computed using Richardson extrapolation across at least three mesh refinement levels.",
      "rationale": "Three-level mesh refinement study performed: coarse (4.2M cells), medium (11.8M cells), fine (28.4M cells). GCI for the normalized index of hemolysis (NIH) was 3.1% between medium and fine meshes. Production mesh is the medium mesh. Exceeds Gradation 2 requirement; achieves Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental test conditions are generally representative of the COU operating range. Flow rates and rotational speeds were set to match CPB operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Model outputs compared against available experimental data. Agreement is considered adequate for the intended use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must be directly traceable to the clinical endpoint (RH < 1 relative to predicate device) and must be computable from CFD shear stress and exposure time fields using a validated power-law hemolysis model.",
      "rationale": "NIH is computed from the Giersiepen-Wurzinger power-law model applied to Lagrangian particle tracks. Direct traceability to RH < 1 acceptance criterion established. QoI is well-established in the FDA pump challenge literature and is the standard metric for regulatory hemolysis submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the FDA generic centrifugal pump geometry (or geometric equivalent), operated within ±15% of the COU flow-speed envelope, with hemolysis measured by the plasma-free hemoglobin method per ASTM F1841.",
      "rationale": "Validation dataset uses the FDA generic centrifugal blood pump operated at 2500 and 3500 RPM across flow rates of 2.5–7.5 L/min, encompassing the CPB COU envelope. Hemolysis measured per ASTM F1841. Geometric and operational relevance is high. Validation activities are directly applicable to the COU."
