  "signature": "ed25519:9b2d4f6a8c0e1b3d5f7a9c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated commercial code with documented version control, regression testing records, and traceable release notes. Achieved level requires evidence of formal QA process including unit test coverage report.",
      "rationale": "ANSYS Fluent 2022 R2 was used for all simulations. The vendor provides ISO 9001-certified QA documentation, regression test suite results, and release notes traceable to solver version. Internal version control logs confirm consistent solver version across all simulation runs. Required level 2 is appropriate for MRL 2 under ASME V&V 40 Table 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate that the numerical solver correctly implements the governing equations through comparison with analytical solutions or method-of-manufactured-solutions benchmarks. At least two benchmark cases relevant to rotating machinery flow must be documented.",
      "rationale": "Code verification was performed using the Taylor-Couette flow analytical benchmark and a manufactured solution for the Navier-Stokes equations in cylindrical coordinates. Observed order of convergence was 1.97, consistent with the nominal second-order accuracy of the discretization scheme. Results are documented in the solver verification report (SVR-2024-001)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "A mesh convergence study was conducted using three systematically refined meshes (coarse: 2.1M cells, medium: 6.8M cells, fine: 18.4M cells) following ASME V&V 20 grid convergence index methodology. GCI for the hemolysis index quantity of interest was 1.8% on the medium mesh, which was selected for production runs. Richardson extrapolation confirmed monotonic convergence. The achieved level of 3 exceeds the required level of 2 for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental test conditions were documented adequately for MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Output comparison was performed at standard conditions. Results were within acceptable range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest (QoI) must be directly traceable to the clinical endpoint (hemolysis index RH) and must be shown to be sensitive indicators of the worst-case operating condition. QoI relevance must be justified by domain expert review and documented in the credibility plan.",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) were selected as primary QoIs. Both are standard hemolysis metrics used in FDA guidance and ISO 10993-4. Sensitivity analysis across the 5 operating points confirmed that RH discriminates between worst-case and nominal conditions with statistical significance (p < 0.01). Expert review panel confirmed QoI relevance in credibility plan review meeting (CPR-2024-03)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Validation activities were deemed relevant to the COU. Standard assessment performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Numerical solver error is not assessed at MRL 2 for this COU. The factor is outside scope per the credibility plan scoping decision documented in CPR-2024-03. Residual convergence criteria of 1e-5 were applied uniformly across all runs as a minimum control measure."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
