  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "CFD solver must be under documented version control with regression test suite covering relevant flow regimes.",
      "rationale": "The ANSYS Fluent v19.2 solver used in this study is a commercially validated code subject to vendor-maintained QA procedures including regression testing and version-controlled release documentation. Internal SOP records confirm solver version traceability for all simulation runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems with known analytical solutions.",
      "rationale": "Code verification was performed using lid-driven cavity and Poiseuille flow benchmarks. Observed convergence rates matched theoretical expectations, confirming correct discretization of the Navier-Stokes equations within the solver."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed across at least three mesh refinement levels with GCI < 5% for hemolysis index QoI.",
      "rationale": "A three-level mesh refinement study was conducted with approximately 2.1M, 4.8M, and 9.6M elements. GCI for the scalar hemolysis index was 2.3%, satisfying the acceptance criterion. The medium mesh (4.8M elements) was selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions must match simulation inlet/outlet conditions within documented tolerances.",
      "rationale": "Inlet flow rates and rotational speeds applied in the CFD model were set to match FDA experimental test conditions within ±2%, as documented in the test protocol. Temperature and fluid viscosity were matched to the bovine blood surrogate properties reported in the experimental dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±15% across all five operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values were compared to FDA experimental results at all five flow-speed operating points. Maximum deviation was 11.4%, satisfying the ±15% acceptance criterion. Bland-Altman analysis confirmed no systematic bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The QoI (hemolysis index) must be directly traceable to the clinical endpoint and regulatory acceptance criterion.",
      "rationale": "The relative hemolysis index (RH) is the primary regulatory QoI used in 510(k) submissions for CPB devices. The CFD-derived NIH is directly mapped to RH via the power-law hemolysis model, providing a clear chain from simulation output to clinical relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and operating envelope as the COU.",
      "rationale": "Validation activities were conducted using the FDA generic centrifugal pump geometry under the same five flow-speed combinations defined in the COU. Fluid properties and rotational speed ranges are consistent with clinical CPB operating conditions, supporting direct relevance of the validation evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "rationale": "The numerical solver convergence behavior was monitored across all simulation runs. Residual targets were met for all governing equations. The assessment team reviewed solver logs and confirmed adequate convergence for all five operating points included in the COU.",
      "acceptanceCriteria": "All residuals must reach the specified convergence threshold and solution must be confirmed as iteratively converged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Use error assessment is not required at Model Risk Level 2 for a Class II device with medium model influence. This factor is deferred per the MRL 2 scoping decision documented in the credibility plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Model form uncertainty quantification is not required at Model Risk Level 2. The power-law hemolysis model is widely accepted in the literature for this class of device and operating regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Formal model input uncertainty characterization is not required at Model Risk Level 2. Nominal input values were drawn from the FDA experimental dataset with documented traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Test sample characterization beyond standard FDA experimental reporting is not required at Model Risk Level 2 for this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
