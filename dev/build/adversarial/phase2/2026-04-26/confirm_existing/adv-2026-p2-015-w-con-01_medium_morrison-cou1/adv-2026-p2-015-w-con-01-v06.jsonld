      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Three pump specimens from the same manufacturing lot were tested. Sample-to-sample variability in hemolysis index was less than 5%, confirming sufficient test sample representativeness for MRL 2 purposes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU.",
      "rationale": "Formal equivalency analysis of simulation input parameters to experimental conditions is not required at MRL 2. Qualitative confirmation that boundary conditions are consistent with test conditions was performed during validation planning."
