      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU.",
      "rationale": "Detailed uncertainty quantification of model inputs (e.g., viscosity, density, hemolysis model constants) is not required at MRL 2. Nominal values were used based on published literature and manufacturer specifications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
