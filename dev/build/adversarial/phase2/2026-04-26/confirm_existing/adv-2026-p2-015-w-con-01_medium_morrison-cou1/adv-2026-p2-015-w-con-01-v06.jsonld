      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is a commercially validated code with documented software quality assurance procedures including version control, regression testing, and release notes. SQA level 2 is satisfied for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Benchmark test cases from the ASME V&V 20 suite were used to verify numerical solver accuracy. Order-of-accuracy tests confirm second-order spatial convergence consistent with the discretization scheme employed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted following ASME V&V 20 procedures. The Grid Convergence Index (GCI) was computed for hemolysis index predictions, yielding GCI < 2% on the fine mesh. Richardson extrapolation confirms asymptotic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Experimental test conditions replicate the five target flow-speed operating points (2–6 L/min, 2000–3500 RPM). Blood analog fluid (glycerol-water) properties were characterized at 37°C. Pump inlet and outlet boundary conditions match simulation inputs within 3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Predicted hemolysis index values are compared against experimental measurements at all five operating points. Mean absolute error is 8.3%, within the 15% acceptance threshold established for MRL 2 comparisons."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The primary quantity of interest — normalized index of hemolysis (NIH) — directly maps to the regulatory acceptance criterion (RH < 1 relative to predicate). The QoI is clinically meaningful and traceable to ISO 10993-4 hemocompatibility requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Validation experiments were performed on the same FDA generic centrifugal blood pump geometry under CPB-representative flow conditions. The validation domain overlaps substantially with the COU, supporting applicability of the validation evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residuals and iterative convergence should be documented and within acceptable bounds.",
      "rationale": "The assessment team reviewed solver performance and convergence behavior across all simulated operating points. Iterative residuals were monitored and solution stability was confirmed prior to post-processing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Simulation setup and post-processing were performed by experienced CFD analysts with documented training records. An independent peer review of boundary condition setup and material property inputs was conducted and no use errors were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The power-law hemolysis damage model (Giersiepen-Wurzinger) is the standard form used in regulatory submissions for rotary blood pumps. Model form uncertainty is acknowledged; sensitivity analysis over model constants was performed confirming robustness of rank-ordering of operating conditions."
    },
    {
