  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified against NIST benchmark cases and carry documented version control. Achieved level must meet or exceed required level 2.",
      "rationale": "ANSYS Fluent 2022 R2 was used with documented version control and regression test suite. Code verification against NIST benchmark lid-driven cavity and pipe-flow cases confirmed solver accuracy. SQA documentation provided per MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test using the method of manufactured solutions or equivalent benchmark must confirm expected convergence rate.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver confirmed second-order spatial convergence. Results documented in verification report VR-2022-04."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be less than 5% for the hemolysis index QOI on the fine mesh.",
      "rationale": "Three-level mesh refinement study performed (coarse 2.1M, medium 5.4M, fine 12.8M cells). GCI on hemolysis index was 2.3% between medium and fine meshes, satisfying the acceptance criterion. Richardson extrapolation applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must span the operating envelope defined in the COU, including all 5 flow-speed combinations.",
      "rationale": "FDA interlaboratory study data covers all 5 target operating points (2.5 L/min at 2500 RPM through 7 L/min at 3500 RPM). Test conditions documented in FDA benchmark dataset with uncertainty quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined experimental and numerical uncertainty bounds.",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared against experimental measurements from FDA interlaboratory study. Agreement within 15% at all 5 operating conditions, within combined uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOI (relative hemolysis index RH) must be directly linked to the clinical endpoint and the regulatory acceptance criterion RH < 1.",
      "rationale": "The relative hemolysis index RH is computed from NIH predictions and directly maps to the regulatory acceptance criterion. QOI relevance confirmed by clinical literature linking shear-induced hemolysis to pump operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
