  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model under CPB conditions is Accepted at MRL 2. Seven of thirteen factors were formally assessed; all assessed factors achieved their required credibility levels. The remaining six factors are not required at MRL 2 per the ASME V&V 40 risk-based framework for a Class II device with medium model influence. Validation evidence demonstrates adequate predictive accuracy of the relative hemolysis index across all five operating points. The model is suitable for use in identifying worst-case hemolysis conditions for the stated context of use.",
