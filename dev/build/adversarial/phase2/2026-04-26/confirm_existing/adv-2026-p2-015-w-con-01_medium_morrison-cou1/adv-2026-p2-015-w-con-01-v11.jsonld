      "id": "https://uofa.net/synth/factor/test-samples-001",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test fluid properties and sample preparation documented; bovine blood or blood analog properties reported.",
      "rationale": "Test sample characterization is not assessed at MRL 2 for this COU. The FDA benchmark dataset used porcine blood with documented hematocrit levels; detailed sample variability analysis is outside the current assessment scope."
    },
