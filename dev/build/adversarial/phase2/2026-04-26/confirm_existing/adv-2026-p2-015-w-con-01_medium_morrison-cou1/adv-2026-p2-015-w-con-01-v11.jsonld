  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/synth/factor/sqa-001",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver version control and regression testing documented; third-party CFD code with published verification suite.",
      "rationale": "ANSYS Fluent v19.2 employed with documented version control. Regression test suite confirms solver behavior against published benchmarks for rotating machinery flows. Software QA requirements at MRL 2 are satisfied."
    },
    {
      "id": "https://uofa.net/synth/factor/ncv-001",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Solver verified against at least one benchmark problem relevant to rotating turbomachinery flows.",
      "rationale": "Code verification performed using the method of manufactured solutions for the incompressible Navier-Stokes equations. Observed convergence rates are consistent with second-order spatial accuracy. Additional benchmark comparisons against Taylor-Couette flow confirm rotational flow solver fidelity."
    },
    {
      "id": "https://uofa.net/synth/factor/disc-err-001",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI; GCI < 5% on fine mesh.",
      "rationale": "Three-level mesh refinement study conducted with GCI calculated per Roache methodology. Fine mesh (12.4M cells) yields GCI of 3.2% for the normalized hemolysis index. Discretization error is within acceptable bounds for MRL 2."
    },
    {
      "id": "https://uofa.net/synth/factor/test-cond-001",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, rotational speed) match simulation inputs within measurement uncertainty.",
      "rationale": "Experimental test conditions from the FDA benchmark dataset are replicated in simulation boundary conditions. Inlet flow rates of 2.5–6.0 L/min and rotational speeds of 2000–3500 RPM are matched to within 1% of reported experimental values."
    },
    {
      "id": "https://uofa.net/synth/factor/output-comp-001",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) within 20% of experimental measurements across all 5 operating points.",
      "rationale": "Simulated NIH values compared against five experimental operating points. Maximum deviation is 14.7%, mean absolute error is 8.3%. All predictions fall within the 20% acceptance band, confirming adequate output agreement."
    },
    {
      "id": "https://uofa.net/synth/factor/rel-qoi-001",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs (shear stress distribution, hemolysis index) directly support the clinical decision regarding worst-case hemolysis identification.",
      "rationale": "The primary QoI, the relative hemolysis index (RH), is directly linked to the regulatory acceptance criterion RH < 1 for Class II CPB devices. Volume-averaged shear stress and exposure time are intermediate QoIs that mechanistically connect CFD outputs to the hemolysis prediction model."
    },
    {
      "id": "https://uofa.net/synth/factor/rel-val-001",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments conducted on geometrically similar pump under overlapping operating conditions.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU. Operating conditions in validation experiments span the full range of COU operating points. Validation relevance is high for the intended use."
    },
    {
      "id": "https://uofa.net/synth/factor/num-solver-001",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residuals below 1e-5 for all transport equations.",
      "rationale": "Numerical solver error is not assessed at MRL 2 for this factor category. Residual monitoring logs are retained but formal quantification of solver error is deferred per MRL 2 scoping decisions."
    },
    {
      "id": "https://uofa.net/synth/factor/use-err-001",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition inputs verified against test data.",
      "rationale": "Use error assessment not required at MRL 2 for Class II device applications. Simulation inputs were reviewed internally but independent peer review of setup files was not performed within this assessment scope."
    },
    {
      "id": "https://uofa.net/synth/factor/model-form-001",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "rationale": "The model form assessment was reviewed and considered adequate for the current context of use. The governing equations and constitutive relationships employed are consistent with published practice for CFD hemolysis prediction. No specific level determination was recorded for this factor during the assessment cycle.",
      "acceptanceCriteria": "Turbulence model and hemolysis power-law model selection justified for the flow regime and shear stress range of interest."
    },
    {
      "id": "https://uofa.net/synth/factor/model-inputs-001",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood viscosity, density, and hemolysis model coefficients sourced from peer-reviewed literature with uncertainty bounds reported.",
      "rationale": "Model input uncertainty quantification not required at MRL 2. Nominal input values (blood density 1060 kg/m3, dynamic viscosity 0.0035 Pa·s) are taken from published literature. Sensitivity to input variation is acknowledged but not formally assessed."
    },
