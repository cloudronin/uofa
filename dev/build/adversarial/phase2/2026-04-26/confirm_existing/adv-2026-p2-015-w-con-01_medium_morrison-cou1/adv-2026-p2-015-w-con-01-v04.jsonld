  "signature": "ed25519:b1c4d7e0f3a6b9c2d5e8f1a4b7c0d3e6f9a2b5c8d1e4f7a0b3c6d9e2f5a8b1c4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software must have documented version control, regression testing, and release validation records consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was used with documented QA procedures including version-controlled case files, regression test suite results, and release notes confirming numerical solver correctness. All SQA artifacts meet the MRL 2 gradation 2 threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification must demonstrate correct implementation of governing equations through benchmark problems at gradation 2 or higher.",
      "rationale": "The CFD solver was verified against the FDA critical path benchmark cases for internal flow, confirming correct discretization of the Navier-Stokes equations. Order-of-accuracy testing confirmed second-order spatial convergence on structured hex meshes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all primary quantities of interest with GCI < 5% on the fine mesh.",
      "rationale": "A three-level mesh refinement study was conducted with element counts of 2.1M, 5.8M, and 14.3M cells. GCI values for wall shear stress and velocity magnitude were 3.2% and 1.8% respectively on the fine mesh, exceeding the MRL 2 requirement. Richardson extrapolation confirmed asymptotic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to reproduce boundary conditions in the simulation.",
      "rationale": "FDA benchmark experimental conditions were reproduced with inlet flow rates of 2.5, 3.5, and 5.0 L/min at rotational speeds of 2500 and 3500 RPM. Temperature, fluid viscosity, and hematocrit were matched to published experimental protocols."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared against experimental measurements using quantitative metrics with uncertainty bounds.",
      "rationale": "Predicted hemolysis index values were compared against experimental measurements from Herbertson et al. (2015) across all 5 operating points. Mean absolute percentage error was 8.3%, within the 15% acceptance threshold. Bland-Altman analysis confirmed no systematic bias."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest predicted by the model must be directly linked to the clinical decision endpoint.",
      "rationale": "The relative hemolysis index (RHI) is the primary quantity of interest and is directly used in the regulatory submission acceptance criterion (RH < 1). Scalar stress exposure and exposure time were computed as intermediate quantities feeding the Giersiepen-Wurzinger power-law hemolysis model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the COU to support extrapolation of model credibility.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which shares the same impeller topology and flow regime as the CPB device under assessment. Operating conditions span the clinical use envelope defined in the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of the solver must be demonstrated to a level that does not materially affect the quantities of interest.",
      "rationale": "The assessment team reviewed available solver documentation and concluded that the model outputs are sufficiently reliable for the intended use at MRL 2. Further detailed level characterization was considered but not completed within the current assessment cycle."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error is scoped out at Model Risk Level 2 per the ASME V&V 40 MRL matrix. No assessment is required for this factor at the current risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Model form uncertainty assessment is not required at MRL 2. The k-omega SST turbulence model selection is considered standard practice for internal rotating flow applications and does not require formal model form credibility assessment at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2. Nominal input values were sourced from published literature and device specifications; sensitivity to input variation was not formally characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Test sample characterization is not required at MRL 2. The FDA benchmark experimental data was used as-published without independent sample characterization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Equivalency of input parameters between the validation domain and the COU is not formally required at MRL 2. Qualitative alignment was noted by the assessment team."
    }
  ],
