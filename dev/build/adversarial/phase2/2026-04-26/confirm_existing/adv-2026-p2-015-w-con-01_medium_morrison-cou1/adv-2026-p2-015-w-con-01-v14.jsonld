  "signature": "ed25519:7b2e4a9f1c3d5e8b0a6f2d4c7e9b1a3f5d8c0e2b4a6f9d1c3e5b7a9f2d4c6e8b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented QA procedures including version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022 R1 is an FDA-recognized simulation software with documented QA procedures, ISO 9001 certification, and comprehensive regression test suite. Version control and release notes confirm compliance at Gradation 2 for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical implementation verified against analytical solutions or established benchmarks for relevant flow regimes.",
      "rationale": "Code verification performed using Taylor-Couette flow analytical solution and lid-driven cavity benchmark. Discretization schemes confirmed to produce convergent solutions with demonstrated order-of-accuracy consistent with theoretical expectations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for all quantities of interest; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study conducted (coarse: 2.1M, medium: 5.8M, fine: 14.2M cells). GCI for hemolysis index: 3.2% (fine), 8.7% (medium). Richardson extrapolation applied. Fine mesh selected for all production runs. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and sufficiently characterized to support meaningful comparison with simulation boundary conditions.",
      "rationale": "FDA benchmark experimental data provides fully characterized test conditions including flow rates (2–7 L/min), rotational speeds (2000–3500 RPM), fluid properties (blood analogue at 37°C), and inlet/outlet pressure measurements. Boundary conditions mapped directly from experimental protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics defined a priori; agreement assessed using normalized RMS error or equivalent metric.",
      "rationale": "Relative hemolysis index (RH) compared between CFD predictions and experimental measurements across all 5 operating points. Normalized RMS error of 12.4% observed, within the pre-specified 15% acceptance threshold. All operating points show RH < 1 relative to predicate device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the clinical decision and traceable to the intended use.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) and relative hemolysis index (RH), both directly linked to clinical risk of red blood cell destruction during CPB. QoIs are consistent with FDA guidance on hemolysis testing and the 510(k) submission requirements for Class II CPB devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow conditions, and fluid properties sufficiently similar to the COU to support extrapolation of validation evidence.",
      "rationale": "Validation conducted on the FDA generic centrifugal blood pump geometry under the same flow-speed envelope as the COU. Blood analogue fluid properties match within 5% of clinical blood viscosity. Geometric similarity ratio > 0.95 between validation and COU pump configurations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error assessed; residuals and solution monitors documented.",
      "rationale": "The credibility assessment confirms that all simulation activities were conducted in accordance with the overall V&V plan and that the model outputs are suitable for the intended decision context. Solver performance was reviewed as part of the general quality review process."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence that model is used by qualified personnel following documented procedures; at minimum, user qualifications and simulation protocol documented.",
      "rationale": "CFD simulations performed by engineers with documented training in ANSYS Fluent and rotating machinery simulation. Standard operating procedure (SOP-CFD-003) followed for all runs. Independent peer review of setup files completed prior to production simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equations and turbulence model selection justified for the flow regime; sensitivity to model form documented.",
      "rationale": "Reynolds-averaged Navier-Stokes (RANS) with SST k-omega turbulence model selected based on literature review of rotating blood pump CFD. Giersiepen-Wurzinger power-law hemolysis model applied. Sensitivity study comparing SST k-omega vs. k-epsilon showed < 8% variation in NIH predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category; scoped out per project credibility plan.",
      "rationale": "Per the credibility plan for MRL 2, detailed uncertainty quantification of model inputs is not required. Nominal input values sourced from FDA benchmark dataset and pump manufacturer specifications. Input sensitivity is addressed implicitly through the operating condition sweep."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA benchmark dataset provides sufficient sample characterization for this assessment level.",
      "rationale": "Test sample characterization beyond the FDA benchmark dataset specifications is not required at MRL 2. The benchmark dataset is considered a community-accepted reference for centrifugal blood pump validation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for Class II device with medium model influence; formal equivalency analysis deferred.",
      "rationale": "Formal equivalency analysis of input parameters between validation and COU configurations is not required at MRL 2. Qualitative assessment confirms that operating envelope, fluid properties, and geometric features are sufficiently representative for the intended use."
    }
  ],
