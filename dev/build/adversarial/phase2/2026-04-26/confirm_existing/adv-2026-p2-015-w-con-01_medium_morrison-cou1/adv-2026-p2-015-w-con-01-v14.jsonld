  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the Morrison COU1 CFD hemolysis model is accepted at MRL 2 for a Class II CPB device. Seven of thirteen factors were formally assessed; all assessed factors met or exceeded their required credibility levels. The remaining six factors were appropriately scoped out or designated not-assessed consistent with the MRL 2 credibility plan. The model demonstrates sufficient credibility to support the intended use of identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump. The relative hemolysis index criterion (RH < 1) was satisfied across all five evaluated operating points.",
