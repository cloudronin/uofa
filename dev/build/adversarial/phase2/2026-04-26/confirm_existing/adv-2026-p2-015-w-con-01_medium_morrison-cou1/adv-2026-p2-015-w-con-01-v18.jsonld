      "acceptanceCriteria": "SQA procedures documented and version-controlled; solver validated against ASME benchmark cases.",
      "rationale": "ANSYS Fluent v2022R2 employed under institutional SQA plan. Version control, regression testing, and build verification records are available. Benchmark comparisons against ASME V&V 20 pipe-flow cases confirm solver integrity at required gradation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing demonstrates solver convergence consistent with stated discretization scheme.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver. Second-order spatial accuracy confirmed for velocity and pressure fields. Results archived in verification report MCV-2022-003."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI across all five operating points.",
      "rationale": "Three-level mesh refinement study conducted (coarse 2.1M, medium 5.8M, fine 14.2M elements). GCI computed per Celik et al. 2008. Maximum GCI across operating points is 3.2%, meeting and exceeding the required threshold. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature) documented and replicated within 2% in simulation inputs.",
      "rationale": "In vitro loop conditions from the Morrison et al. 2021 dataset replicated in CFD boundary conditions. Flow rates verified via Coriolis meter with traceable calibration. Temperature maintained at 37 ± 0.5°C, matching simulation fluid properties."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Relative hemolysis index predicted within 15% of experimental measurements across all operating points.",
      "rationale": "CFD-predicted RH values compared against experimental plasma free hemoglobin measurements. Mean absolute error of 9.4% across five operating points. All predictions fall within the 15% acceptance band. Model meets required output comparison level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to clinical hemolysis endpoint and regulatory acceptance criterion.",
      "rationale": "The relative hemolysis index is the primary QoI and directly corresponds to the regulatory submission metric. The mapping from CFD shear-stress history to RH via the power-law hemolysis model is consistent with FDA guidance and literature precedent."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, fluid, and operating envelope as the COU.",
      "rationale": "Validation dataset generated using the FDA generic centrifugal pump geometry under CPB-representative flow-speed combinations. Blood analog fluid (glycerin-water, matched viscosity) used in vitro. Geometric and operational similarity to COU confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations at each operating point.",
      "rationale": "The model has been reviewed and general convergence behavior is considered adequate for the purposes of this assessment. Detailed level grading was deferred pending final solver log archival."
    },
