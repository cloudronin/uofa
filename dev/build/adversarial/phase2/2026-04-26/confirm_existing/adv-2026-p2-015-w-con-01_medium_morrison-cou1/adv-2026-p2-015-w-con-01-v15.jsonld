      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric E) computed and assessed against acceptance threshold.",
      "rationale": "Normalized index of hemolysis (NIH) predictions were compared against five experimental operating points. Mean absolute relative error was 8.3%, within the 15% acceptance threshold. Uncertainty quantification of experimental data was incorporated into the comparison metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
