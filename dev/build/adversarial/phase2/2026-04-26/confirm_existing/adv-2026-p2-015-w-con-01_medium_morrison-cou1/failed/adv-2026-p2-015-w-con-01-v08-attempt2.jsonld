  "signature": "ed25519:b7e3a1f4c9d2e6b0a5f8c3d7e1b4a9f2c6d0e5b8a3f7c1d4e9b2a6f0c5d3e8b1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software used in simulation must be under documented version control with regression testing at MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2021R2) is under formal version control. Regression tests covering hemolysis model subroutines were executed and passed. Configuration management records are archived and traceable to this analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Verification of numerical implementation against known analytical or manufactured solutions at the required gradation.",
      "rationale": "Method of manufactured solutions was applied to the Navier-Stokes solver kernel. Observed convergence rates are consistent with second-order spatial accuracy, confirming correct numerical implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence study must demonstrate that discretization error is quantified and within acceptable bounds for the QoI.",
      "rationale": "A three-level grid convergence index (GCI) study was performed using meshes of 2.1M, 4.8M, and 9.6M cells. GCI for the hemolysis index QoI was 1.8%, well below the 5% threshold. The medium mesh (4.8M cells) was selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and sufficiently representative of the COU operating envelope.",
      "rationale": "Validation experiments were conducted at the five flow-speed operating points defined in the COU. Inlet boundary conditions (flow rate, hematocrit, temperature) are documented in the test protocol and match CFD boundary conditions within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted QoI values must be compared to experimental measurements using a defined metric; agreement must meet the acceptance threshold.",
      "rationale": "Relative hemolysis index (RH) predictions were compared to experimental measurements at all five operating points. Mean absolute error was 8.3% with all predictions within the expanded measurement uncertainty band, satisfying the RH < 1 acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The QoIs used in validation activities must be directly relevant to the clinical decision being supported.",
      "rationale": "The relative hemolysis index (RH) is the primary QoI and directly maps to the clinical endpoint of pump-induced hemolysis. RH is the accepted regulatory metric for CPB device hemolysis comparison per FDA guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must cover the geometry, operating conditions, and fluid properties representative of the COU.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry under CPB-representative flow conditions (2–6 L/min, 2500–4000 RPM). Bovine blood with hematocrit 33% was used, consistent with clinical CPB practice."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence must be demonstrated to a level that does not materially affect the QoI.",
      "rationale": "Residuals for continuity, momentum, and turbulence equations were reduced by at least four orders of magnitude. QoI values monitored during iteration showed changes of less than 0.1% over the final 500 iterations, confirming adequate iterative convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Assessment of potential errors introduced by analyst decisions in model setup and post-processing.",
      "rationale": "This factor was not assessed at MRL 2 for this COU. The scope of the credibility assessment does not require formal use-error evaluation at the current model risk level; standard operating procedures and peer review of simulation setup provide adequate informal control."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The mathematical model form, including turbulence and hemolysis sub-models, must be appropriate for the COU physics.",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance for rotating machinery internal flows. The power-law hemolysis model (Giersiepen-Wurzinger) is the standard for CFD hemolysis prediction and has been validated against the experimental dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties, boundary conditions, and geometric parameters used as model inputs must be traceable to measured or literature-sourced values.",
      "rationale": "The credibility evidence for this factor has been compiled and reviewed. Traceability of input parameters to source measurements has been confirmed through the standard review process for this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of test sample variability and its effect on validation data quality.",
      "rationale": "Test sample characterization was not formally assessed at MRL 2. Blood analog fluid properties were documented per standard protocol; full statistical characterization of sample-to-sample variability is deferred to higher MRL assessments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that input parameters used in the simulation match those of the validation experiment within acceptable tolerance.",
      "rationale": "Formal equivalency analysis was not required at MRL 2. Boundary conditions were matched to experimental conditions by inspection and engineering judgment, consistent with the level of rigor appropriate for the current model risk level."
    }
  ],
