  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software version control and documentation meet MRL 2 requirements for a Class II device.",
      "rationale": "The CFD solver (ANSYS Fluent 2021 R2) is commercially validated software with documented version control, user documentation, and regression test suite. Quality assurance procedures confirm software integrity for hemolysis simulation applications at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Benchmark test cases confirm correct implementation of governing equations.",
      "rationale": "Numerical code verification was performed using canonical benchmark cases including lid-driven cavity flow and Poiseuille flow. Results demonstrate correct implementation of the Navier-Stokes solver within accepted tolerances for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for primary QoI (hemolysis index) across all operating points.",
      "rationale": "A three-level mesh refinement study was conducted with mesh sizes of 2.1M, 4.8M, and 9.6M cells. Richardson extrapolation yielded GCI values below 3.2% for the scalar stress-based hemolysis index at all five operating conditions, exceeding the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions are documented and sufficiently representative of the COU operating envelope.",
      "rationale": "Experimental validation data from the FDA benchmark centrifugal pump study used physiologically relevant blood analog fluid (glycerol-water mixture) at flow rates of 2.5–7.5 L/min and rotational speeds of 2000–3500 RPM, matching the CPB operating envelope defined in the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Model predictions of hemolysis index agree with experimental measurements within defined acceptance band.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values were compared against published experimental data across all five operating points. Mean absolute percent error was 8.4%, within the 15% acceptance band established for MRL 2 Class II device assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs used in validation are directly relevant to the hemolysis prediction decision.",
      "rationale": "The primary QoI, normalized index of hemolysis (NIH), is the standard clinical metric for pump-induced blood damage and directly maps to the relative hemolysis index (RH < 1) acceptance criterion in the COU. Secondary QoI of wall shear stress distribution is mechanistically linked to erythrocyte damage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities address the specific COU geometry, flow regime, and decision question.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry under flow conditions spanning the CPB operating envelope. The validation scenario directly supports the intended use of identifying worst-case hemolysis conditions across the five flow-speed combinations specified in the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "rationale": "Convergence and numerical solver performance were reviewed as part of the overall simulation quality process. Residual targets and iterative convergence behavior were monitored throughout all simulation runs.",
      "acceptanceCriteria": "Solver residuals and iterative convergence meet general simulation quality standards."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for Class II device with medium model influence.",
      "rationale": "Use error assessment is scoped out at MRL 2 for this Class II CPB device application. The medium model influence level and availability of experimental confirmation data reduce the necessity for formal use error analysis at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 given the validation coverage achieved.",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2 for this application. The stress-based hemolysis model (modified Power Law) has established use in the literature for centrifugal pump hemolysis prediction and its applicability is supported by the validation results."
    },
