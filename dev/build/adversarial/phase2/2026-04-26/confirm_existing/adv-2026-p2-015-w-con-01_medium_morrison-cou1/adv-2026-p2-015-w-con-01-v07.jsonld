      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI across three mesh refinement levels.",
      "rationale": "A three-level mesh refinement study was conducted with coarse (4.2M), medium (9.8M), and fine (22.1M) element counts. GCI for the hemolysis index was 2.3% between medium and fine meshes; medium mesh adopted for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within ±5% for flow rate and rotational speed.",
      "rationale": "Flow rates and rotational speeds from the FDA benchmark experimental dataset were applied as boundary conditions. Measured inlet velocity profiles were used; deviations from nominal conditions were within ±3.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 15% of experimental measurements at all five operating points.",
      "rationale": "Simulated hemolysis index values were compared to experimental PIV and hemolysis measurements. Maximum deviation was 11.4% at the highest flow-speed condition; all five operating points met the 15% acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) directly map to the clinical decision criterion RH < 1.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) and relative hemolysis index (RH). These quantities are directly used in the regulatory acceptance criterion and map unambiguously to clinical hemolysis risk for CPB patients."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry under overlapping operating conditions with the COU.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry under the same five flow-speed operating points as the COU. Blood analog fluid properties were matched to within accepted tolerances for in-vitro hemolysis testing."
    },
