      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence and round-off errors must be characterized and shown to be negligible relative to the discretization error for the hemolysis QoI.",
