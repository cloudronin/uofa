  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented quality management system with version control and regression testing at MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 17.2) is deployed under an ISO 9001-compliant QMS with documented version control, regression test suites, and release validation records. Achieved level 3 exceeds the required level 2 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver must pass benchmark verification cases relevant to rotating machinery and viscous flow at the required gradation level.",
      "rationale": "Standard benchmark cases including lid-driven cavity and rotating channel flow were executed and compared against analytical solutions. Residual norms converged to below 1e-6 in all cases, confirming code correctness at gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary quantity of interest (hemolysis index) using at least three systematically refined meshes.",
      "rationale": "Three mesh refinement levels (coarse: 1.2M, medium: 3.6M, fine: 10.8M cells) were evaluated. GCI for hemolysis index was 2.1%, within the acceptable threshold for MRL 2. Richardson extrapolation confirmed monotonic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable, covering the operating envelope of the COU.",
      "rationale": "Experimental data were collected under controlled laboratory conditions at five flow-speed combinations spanning the clinical operating envelope. Temperature, blood analog viscosity, and inlet boundary conditions are fully documented and traceable to calibration records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metrics between simulation outputs and experimental measurements must be reported, including uncertainty bounds.",
      "rationale": "Hemolysis index predictions were compared against experimental measurements at all five operating points. Mean absolute error was 8.3% with experimental uncertainty of ±6%. Statistical validation metrics including U95 and E_rms are reported, achieving gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The quantities of interest used in the simulation must be directly linked to the clinical decision endpoint (relative hemolysis index RH < 1).",
      "rationale": "The primary quantity of interest is the normalized index of hemolysis (NIH) and relative hemolysis (RH), which are the regulatory-accepted metrics for CPB hemolysis assessment. Direct traceability from simulation output to the RH < 1 acceptance criterion is established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
