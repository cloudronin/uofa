  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "MRL 5 demands rigorous SQA. Achieved level 2 reflects partial version control and no formal V&V plan for the CFD solver.",
      "acceptanceCriteria": "At MRL 5 for a Class III device, SQA must demonstrate full configuration management, documented software V&V plan, regression test suite covering all solver modules, and traceability from requirements to test cases. Level 4 is required because model outputs directly inform regulatory submission without independent experimental corroboration of every operating point."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Code verification activities were limited to manufactured-solution tests on simplified geometries. Full pump geometry verification was not performed. Required level reflects MRL 5 expectations.",
      "acceptanceCriteria": "Level 4 code verification requires order-of-accuracy studies on representative pump geometry using the method of manufactured solutions, with documented convergence rates within 5% of theoretical order. Independent replication by a second analyst is required. This level is mandated at MRL 5 because numerical errors in hemolysis prediction are non-conservative and could mask clinically significant damage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Three-level mesh refinement study performed; Richardson extrapolation applied to pressure rise and hemolysis index. GCI values acceptable for pressure but elevated for hemolysis scalar transport near blade trailing edges.",
      "acceptanceCriteria": "Level 4 discretization error assessment requires GCI < 2% on the primary QoI (hemolysis index) across all five operating points, with spatial and temporal refinement studies conducted independently. The 2% threshold at MRL 5 is derived from the clinical tolerance band on absolute hemolysis index specified in the device submission protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental test conditions partially match COU operating envelope. Blood analog viscosity and hematocrit were within range, but temperature and inlet waveform profiles deviated from clinical VAD conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Hemolysis index predictions compared against in-vitro measurements at 5 operating points. Mean absolute error is 18%, exceeding acceptable threshold. Velocity field comparison via PIV shows reasonable agreement in bulk flow but discrepancies in gap regions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Hemolysis index (normalized index of hemolysis, NIH) is the primary QoI and directly maps to the clinical endpoint. Secondary QoIs (wall shear stress, recirculation volume) are relevant surrogates validated in published literature.",
      "acceptanceCriteria": "Level 3 relevance requires that the primary QoI be a direct or well-established surrogate for the clinical endpoint, with published validation evidence linking NIH to patient hemolysis outcomes. At MRL 5 this is the minimum acceptable level given that secondary QoIs are not independently sufficient for regulatory acceptance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Validation activities used the FDA generic pump geometry, which is a recognized benchmark but differs from the clinical device geometry. Operating conditions partially overlap the COU envelope. Extrapolation to clinical VAD conditions introduces unquantified model-form uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "rationale": "Solver error not formally assessed. Residual convergence criteria applied but iterative error not separated from discretization error. No floating-point sensitivity analysis performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "rationale": "No formal use-error assessment performed. Analyst experience documented but no independent review of simulation setup, boundary condition selection, or post-processing scripts."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Power-law hemolysis model (Giersiepen-Wurzinger) used. Known to overpredict hemolysis at low shear stress and underpredict at high shear rates relevant to VAD conditions. Model form uncertainty not formally quantified."
    },
    {
      "type": "CredibilityFactor",
