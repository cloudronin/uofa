  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "MRL 5 demands rigorous SQA. Only informal version control and partial unit testing were documented; no formal V&V plan for the solver codebase exists.",
      "acceptanceCriteria": "At MRL 5 for a Class III device, SQA must demonstrate formal configuration management, traceable test coverage of all hemolysis-relevant solver modules, and documented change-control procedures per FDA software guidance. Gradation 4 requires all of the above plus independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Code verification was limited to a manufactured-solution test on a simplified geometry. No systematic order-of-accuracy study was performed for the hemolysis transport scalar equation.",
      "acceptanceCriteria": "Gradation 4 requires demonstrated order-of-accuracy convergence for all governing equations relevant to the QoI, including the hemolysis scalar, across at least three systematically refined grids with published error norms."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "A three-level grid convergence study was performed but the observed convergence ratio fell outside the asymptotic range, preventing reliable Richardson extrapolation. Discretization error bounds are therefore unavailable.",
      "acceptanceCriteria": "Gradation 4 requires demonstrated asymptotic grid convergence and a quantified discretization error bound for the hemolysis QoI, reported with the Grid Convergence Index or equivalent method."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Experimental test conditions were well characterised for flow rate and rotational speed but blood analogue viscosity was reported only as a nominal value without batch-to-batch variability data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Velocity field and hemolysis index predictions were compared to experimental data. Agreement was within 15% for velocity but hemolysis index predictions showed systematic over-prediction at high shear operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "The primary QoI (normalised index of haemolysis, NIH) is directly clinically relevant. Secondary QoIs (wall shear stress, residence time) are relevant surrogates but not validated independently.",
      "acceptanceCriteria": "Gradation 4 requires that all QoIs used in the regulatory submission are explicitly mapped to clinical endpoints and that each QoI has an associated validation dataset demonstrating predictive adequacy within the COU operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Validation experiments used a water-glycerol analogue rather than whole blood and were conducted at a single rotational speed not representative of the full VAD operating envelope. Applicability to in-vivo conditions is therefore limited."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Iterative convergence was monitored via residual norms but no floating-point sensitivity analysis or round-off error quantification was performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "rationale": "No formal user-qualification procedure or simulation execution checklist was documented. Boundary condition setup was performed by a single analyst without independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The power-law hemolysis damage model (Giersiepen-Wurzinger) was selected without systematic comparison to alternative formulations. Model-form uncertainty is unquantified.",
      "acceptanceCriteria": "Gradation 4 requires documented comparison of at least two hemolysis model forms, sensitivity analysis of model-form assumptions, and a justified selection rationale referenced to published benchmark data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Monte Carlo UQ was performed on inlet flow rate and rotational speed. Material property uncertainty (blood viscosity, density) and geometric tolerance were not included in the uncertainty propagation.",
      "acceptanceCriteria": "Gradation 4 requires that all influential model inputs are identified via sensitivity analysis and that uncertainty distributions for each are propagated through the model, with results reported as probability distributions over the hemolysis QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "rationale": "Only a single pump specimen was used for all experimental measurements. No inter-specimen variability data are available to characterise manufacturing tolerance effects on hemolysis."
    },
