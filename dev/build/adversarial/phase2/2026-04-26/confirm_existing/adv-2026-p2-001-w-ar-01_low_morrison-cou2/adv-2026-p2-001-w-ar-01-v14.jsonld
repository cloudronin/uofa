  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA must demonstrate version-controlled solver builds, automated regression testing covering hemolysis-relevant flow regimes, and documented change-control procedures consistent with MRL 5 requirements for Class III device submissions.",
      "rationale": "The CFD solver (ANSYS Fluent 2021R2) operates under a documented SQA plan with version control and regression testing. However, the hemolysis subroutine UDFs lack full unit-test coverage, and change-control records for the UDF modifications are incomplete. Achieved level 3 reflects partial SQA coverage; required level 4 is not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Code verification was performed using manufactured solutions for the Navier-Stokes solver. Order-of-accuracy tests confirm second-order spatial convergence. The hemolysis power-law model was verified against analytical limiting cases. Achieved level 3; required level 4 is not met because independent third-party code verification has not been performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "A three-level mesh refinement study was conducted. Richardson extrapolation yields a grid convergence index below 5% for velocity magnitude and below 8% for hemolysis index at the impeller outlet. Achieved level 3; required level 4 demands GCI below 3% for hemolysis QoI, which was not achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope (flow 3–6 L/min, speed 2400–3600 RPM) using blood analogue fluid with viscosity within 5% of physiological value at 37°C.",
      "rationale": "Bench experiments were conducted at five operating points spanning the VAD envelope. Glycerol-water analogue fluid (3.5 cP at 37°C) was used. Temperature was controlled to ±0.5°C. Test conditions match COU requirements; achieved level 4 equals required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Predicted hemolysis index values were compared against measured values at all five operating points. Mean absolute error is 18%. The required level 4 threshold specifies agreement within 10% across all points. Achieved level 3 reflects acceptable trend prediction but insufficient absolute accuracy for a Class III device claim."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis, NIH) must be directly traceable to the clinical hemolysis threshold specified in the device submission and must be computed from the same scalar transport equation used in the COU prediction.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is directly used in the regulatory submission threshold comparison. The QoI is computed from the Giersiepen-Wurzinger power-law model integrated along Lagrangian particle tracks, consistent with the COU. Achieved level 3 equals required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry, which is a surrogate for the proprietary VAD geometry. Geometric similarity is moderate. The validation dataset covers the same flow-speed envelope as the COU but uses a simplified impeller without secondary flow channels. Achieved level 3; required level 4 demands validation on geometry with high similarity to the COU device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Solver error assessment was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Use error review was conducted by the assessment team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Model form uncertainty was evaluated. The k-omega SST turbulence model was selected based on literature precedent for rotating machinery. Hemolysis model form uncertainty is significant; alternative power-law coefficients from Heuser-Opitz and Zhang models were tested and show up to 35% spread in predicted NIH. Achieved level 2 reflects high model form uncertainty not bounded to required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Monte Carlo UQ was performed on key model inputs including fluid viscosity, pump speed tolerance, and hemolysis model coefficients. 500 Latin hypercube samples were run. The 95th percentile NIH prediction remains below the clinical threshold. Achieved level 3; required level 4 demands sensitivity indices (Sobol) for all inputs, which were not computed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Test samples were reviewed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the validation simulation must match experimental boundary conditions within measurement uncertainty, including inlet velocity profile, rotational speed, and fluid properties.",
      "rationale": "Inlet boundary conditions were set from experimental LDV measurements. Rotational speed was matched to within 0.5% of the bench test value. Fluid properties were matched to the analogue fluid characterization data. Achieved level 3 equals required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite several credibility factors achieving levels below required thresholds, the assessment team accepted the package based on the overall weight of evidence and the Monte Carlo UQ results demonstrating the 95th percentile NIH prediction remains below the clinical hemolysis threshold. The team noted that acceptance criteria rationale was not formally documented for several factors (numerical solver error, use error, test samples), representing a process gap to be remediated in the next assessment cycle.",
