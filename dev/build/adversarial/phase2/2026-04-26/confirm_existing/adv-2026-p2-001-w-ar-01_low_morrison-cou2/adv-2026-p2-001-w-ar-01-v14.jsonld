  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed. Full 13-factor assessment completed. Decision: Accepted. NOTE: Several credibility factors carry a requiredLevel without a corresponding acceptanceCriteria field, triggering W-AR-01.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-hemolysis-req",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-hemolysis-claim",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-centrifugal-pump-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental-hemolysis",
