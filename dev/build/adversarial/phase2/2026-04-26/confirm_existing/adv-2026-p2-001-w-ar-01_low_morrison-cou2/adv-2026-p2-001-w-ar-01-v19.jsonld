      "factorStatus": "assessed",
      "rationale": "The power-law hemolysis model was selected without formal justification of model form appropriateness for the VAD flow regime. Alternative constitutive models were not evaluated.",
      "acceptanceCriteria": "Required level 4 for model form at MRL 5 requires documented justification of the hemolysis constitutive model, comparison of at least two candidate model forms, and sensitivity analysis demonstrating that model form uncertainty is bounded within acceptable limits for regulatory decision-making."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Monte Carlo uncertainty quantification was performed on geometric and flow boundary condition inputs. However, hemolysis model coefficients were treated as deterministic despite known variability in the literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "rationale": "Experimental data from a single pump specimen was used. No repeatability assessment across multiple test articles was conducted. Sample size is insufficient for statistical characterization of experimental variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
