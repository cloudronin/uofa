  "hash": "sha256:a3f7c2e1d09b4856f1a2e3c7d4b5f6a8e9c0d1b2f3a4e5c6d7b8f9a0e1c2d3b4",
  "signature": "ed25519:b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5",
  "hasCredibilityFactor": [
    {
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software under documented version control with regression test suite; analyst training records on file.",
      "rationale": "Ansys Mechanical 2022 R2 used under FDA CDRH OSEL quality management system. Version control via Git with tagged release. Regression test suite of 47 benchmark cases executed at each release. Analyst qualification records maintained per QMS procedure QP-SIM-003. No open software defects affecting compression-bending analyses."
    },
    {
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark verification against NAFEMS LE1 and LE10 problems; contact formulation verified against Hertzian analytical solution.",
      "rationale": "Ansys Mechanical verified against NAFEMS LE1 (plane stress), LE10 (3D solid), and LE11 (thermal stress) benchmarks achieving <0.5% error on all reference quantities. Augmented Lagrange contact formulation verified against Hertzian contact analytical solution for sphere-on-flat geometry (R=5 mm, E=110 GPa) with 0.8% maximum pressure error. Code verification complete per ASME V&V 10-2006 Section 4."
    },
    {
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) < 5% on all QoIs; mesh refinement study with minimum three mesh densities.",
      "rationale": "Mesh convergence study performed with three mesh densities: coarse (142k elements), medium (387k elements), fine (1.02M elements). GCI computed per Roache (1998) using observed order of convergence p=1.87. GCI for stiffness: 1.2%; yield force: 2.1%; force at 40 mm: 3.4%. All GCI values below 5% threshold. Medium mesh selected for production runs as optimal accuracy-to-cost ratio. Hex-dominant mesh with tetrahedral fill in screw thread geometry; element quality metrics (Jacobian ratio > 0.6) verified throughout."
    },
    {
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear solver convergence criteria documented; force and displacement residuals below 1e-4.",
      "rationale": "Newton-Raphson nonlinear solver with automatic time-stepping. Force residual convergence criterion 1e-5 (L2 norm); displacement residual 1e-4. All 11 simulations converged without bisection failures. Contact status monitored per increment; no chattering detected. Solver log files archived in simulation record SR-2024-NC-001 through SR-2024-NC-011."
    },
    {
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup; checklist-based QC of boundary conditions and material assignments.",
      "rationale": "Model setup independently reviewed by second analyst per QMS procedure QP-SIM-007. Boundary condition checklist (BC-CHECK-F1717-v2) verified: fixed base fixture, load application at superior vertebral body centroid, frictionless lateral guides. Material assignments cross-checked against certified material test reports (Ti-6Al-4V ASTM F136, UHMWPE ASTM F648). No use errors identified in peer review. Review sign-off documented in DR-2024-NC-001."
    },
    {
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model appropriate for large-deformation titanium behavior; contact formulation captures screw-rod interface physics.",
      "rationale": "Isotropic hardening plasticity (Chaboche model, 3 backstress terms) calibrated from 30 Ti-6Al-4V tensile coupons per ASTM E8. Captures Bauschinger effect relevant to bending-dominated loading. Screw-rod interface modeled with penalty-based frictional contact (mu=0.15, measured via pin-on-disc tribometry). UHMWPE endblock modeled as bilinear elastic-plastic. Geometric nonlinearity (NLGEOM) enabled to capture large-displacement kinematics at 40 mm. Model form assessed as appropriate for the COU; simplifications (no fatigue, no corrosion) explicitly scoped out."
    },
    {
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties from certified test data; geometric inputs from CMM measurements of test specimens.",
      "rationale": "Material properties sourced from lot-specific certified material test reports for each of the 11 test constructs. Geometric inputs from CMM measurements (Zeiss Contura G2, k=2 uncertainty ±0.01 mm) of each screw, rod, and endblock prior to testing. Friction coefficient from tribometry study (n=6 pin-on-disc tests, CV=8%). Input uncertainty quantified and propagated via Monte Carlo (10,000 samples). Input parameter sensitivity analysis identifies rod diameter as dominant contributor to stiffness prediction variance (Sobol index 0.61)."
    },
    {
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test constructs from production lots; sample characterization including dimensional and material verification.",
      "rationale": "N=11 constructs assembled from production-representative components (6 at Laboratory A, 5 at Laboratory B). All components from same production lots as CMM-characterized specimens. Dimensional verification confirms all components within drawing tolerances. Material certifications on file. Sample size provides 80% power to detect 10% QoI difference at alpha=0.05 based on pre-test power analysis. No outliers identified per Grubbs test (alpha=0.05)."
    },
    {
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant range including at least two load levels and two construct configurations.",
      "rationale": "Testing performed under a single ASTM F1717 standard condition (static compression-bending, 10 mm offset, displacement rate 5 mm/min). Only one construct geometry (non-cannulated 7.5 mm screw, 5.5 mm rod, 35 mm pedicle screw length) evaluated. Clinically relevant variations such as different rod diameters, screw lengths, and dynamic loading were not included in this validation activity. This factor is assessed below required level (achieved 2 vs. required 3); the gap is acknowledged and addressed through conservative acceptance bounds and engineering judgment documented in the decision record."
    },
    {
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA inputs traceable to measured specimen properties; no surrogate material substitutions.",
      "rationale": "One-to-one correspondence established between FEA model inputs and measured specimen properties for each of the 11 constructs. Individual specimen CMM measurements used as FEA geometric inputs (no nominal dimensions used). Lot-specific material certifications used; no surrogate alloys or generic property databases. Boundary condition equivalency verified by comparing test machine compliance correction to FEA fixture stiffness. Equivalency matrix documented in technical report TR-2024-NC-EQ-001."
    },
    {
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric per ASME V&V 40; all QoIs within acceptance bounds.",
      "rationale": "Three QoIs compared: stiffness, yield force, force at 40 mm displacement. E/uval computed for each construct-simulation pair and for ensemble statistics. All 33 individual E/uval values (11 constructs × 3 QoIs) below 1.96. Ensemble E/uval values: stiffness 0.97, yield force 0.61, force at 40 mm 0.54. QoI percentage differences: stiffness 3.1%, yield force 1.9%, force at 40 mm 1.5%. All within 10% acceptance bound. Force-displacement curves visually compared; FEA captures yield knee and post-yield softening accurately."
    },
    {
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Three QoIs selected based on FDA guidance for spinal implant submissions and ASTM F1717 standard requirements. Construct stiffness relates to load sharing and adjacent segment disease risk. Yield force is the primary safety metric (onset of permanent deformation). Force at 40 mm represents ultimate structural capacity and correlates with clinical fracture risk under extreme trauma loading. All three QoIs are directly reported in the 510(k) submission and are required by FDA reviewer guidance document G95-1. QoI relevance confirmed in pre-submission meeting with FDA CDRH (Q-submission Q230045)."
    },
    {
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches COU geometry, loading, and material within defined similarity bounds.",
      "rationale": "Validation activity directly replicates the COU: same non-cannulated 7.5 mm screw geometry, same ASTM F1717 test configuration, same Ti-6Al-4V material. Laboratory testing performed at FDA CDRH OSEL (Laboratory A) and independent ISO 17025-accredited facility (Laboratory B), providing inter-laboratory confirmation. Validation scenario similarity index (per ASME V&V 40 Table 1 criteria) assessed as HIGH for geometry, material, loading mode, and boundary conditions. The single-condition limitation (Test conditions factor below required level) is the only identified relevance gap and is addressed conservatively in the decision record."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for non-cannulated pedicle screw compression-bending is assessed as credible for the stated COU. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-required factor (Test conditions, achieved 2 vs. required 3) reflects the single-condition validation scope of ASTM F1717 and is mitigated by (a) conservative 10% acceptance bounds, (b) high-fidelity input equivalency, and (c) confirmation across two independent laboratories. All three QoIs pass quantitative acceptance criteria with E/uval well below 1.96. The model ensemble approach (three independent FEA implementations reaching consistent results) provides additional confidence. The credibility evidence package supports regulatory submission for this non-cannulated design under the Medium model risk classification.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
