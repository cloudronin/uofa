  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Verified FEA solver with documented V&V history; version-controlled analysis scripts; audit trail for all simulation runs.",
      "rationale": "Ansys Mechanical 2022 R2 used under a validated software configuration. FDA-internal Abaqus scripts version-controlled in Git. DePuy Synthes provided solver logs and run manifests. All three ensemble members satisfy SQA requirements at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark solutions or manufactured solutions confirm correct implementation of governing equations for structural contact and large-displacement bending.",
      "rationale": "Each ensemble member passed the ASME V&V 10.1 patch test and a cantilever beam manufactured solution with relative error < 0.5%. Contact formulations verified against Hertzian contact benchmarks. Code verification level 2 achieved across all three solvers."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates < 5% change in QoIs between successive refinements; GCI reported.",
      "rationale": "Three-level mesh refinement study performed on representative screw-rod-vertebral body assembly. Grid convergence index (GCI) < 2.1% for stiffness and < 3.4% for yield force. Final mesh selected at refinement level 2 (approximately 420 000 elements). Discretization error contribution to total simulation uncertainty budget documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented; iterative solver tolerances reported; energy balance checked.",
      "rationale": "Nonlinear Newton-Raphson iterations converged to force residual < 1e-4 N in all load steps. Energy balance error < 0.1% across all runs. Arc-length method activated post-yield to capture snap-through; no spurious bifurcations observed. Numerical solver error assessed as negligible relative to model-form and input uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented analysis plan reviewed by independent analyst; boundary condition application verified against F1717 fixture geometry.",
      "rationale": "Analysis plan reviewed by two independent FEA analysts not involved in model construction. Boundary conditions (fixed inferior vertebral body, axial-bending load applied at superior body) verified against ASTM F1717-15 fixture drawings. Load application point coordinates cross-checked against physical fixture measurements. No use errors identified during independent review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics assumptions justified for pedicle screw titanium alloy; contact formulation appropriate for screw-rod interface; geometric nonlinearity included.",
      "rationale": "Ti-6Al-4V modeled as bilinear isotropic hardening; literature supports this for quasi-static loading below fracture. UHMWPE vertebral body surrogates modeled as linear elastic within the pre-yield regime consistent with F1717 test scope. Geometric nonlinearity (NLGEOM) enabled. Screw-rod interface modeled with frictional contact (mu=0.2) consistent with prior FDA bench-to-FEA correlation studies. Model form uncertainty quantified via ensemble spread."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from MMPDS or coupon testing; geometric inputs from CMM measurements of test specimens; torque preload documented.",
      "rationale": "Ti-6Al-4V elastic modulus (113.8 GPa) and yield strength (880 MPa) from MMPDS-12. UHMWPE modulus (1.0 GPa) from coupon tensile testing of same material lot as vertebral body surrogates. Screw geometry from CMM measurements (n=3 screws per lot). Rod cross-section dimensions verified. Assembly torque (4 Nm) applied as pretension element consistent with surgical protocol documented in test report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N >= 10 specimens; specimens from production lots; material certifications available; dimensional inspection performed.",
      "rationale": "N=11 constructs tested: 6 at Lab 1 (FDA/CDRH), 5 at Lab 2 (DePuy Synthes internal). All screws from same production lot with material certification. Vertebral body surrogates from same UHMWPE billet. Dimensional inspection (CMM) performed on all screws and rods. Between-laboratory variability assessed; coefficient of variation < 4% for stiffness, consistent with expected manufacturing variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple load levels or configurations tested; environmental conditions documented; loading rate documented and consistent with quasi-static assumption.",
      "rationale": "Single compression-bending load configuration tested per ASTM F1717. Loading rate 5 mm/min (quasi-static). Temperature and humidity documented. Only one load angle assessed; multi-angle or combined loading not within scope of this COU. Achieved level 2 because only a single test condition was applied, falling short of the required level 3 for multi-configuration coverage. This gap is acknowledged and bounded by the conservative single-condition acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA inputs traceable to measured specimen properties; no surrogate material substitutions without justification; boundary conditions replicate fixture constraints.",
      "rationale": "One-to-one mapping established between measured specimen dimensions and FEA geometry for each of the N=11 constructs. Material properties assigned from lot-specific coupon data. Fixture compliance measured and included as spring boundary condition (k=48 000 N/mm). Torque preload applied per measured assembly procedure. No unjustified surrogates used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all QoIs; results plotted against experimental distribution; outlier analysis performed.",
      "rationale": "E/uval computed for stiffness (1.41), yield force (1.67), and force at 40 mm (assessed via relative difference 7.4%). All three QoIs satisfy acceptance bounds. Bland-Altman plots generated for stiffness and yield force. No systematic bias detected. Between-laboratory consistency confirmed (p=0.43, two-sample t-test on stiffness). Ensemble spread used to bound model-form uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes; stiffness and yield force are regulatory endpoints for pedicle screw constructs.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and referenced in FDA guidance for pedicle screw 510(k) submissions. Each QoI maps directly to a clinical failure mode: excessive stiffness may stress-shield adjacent vertebrae; insufficient yield force implies premature plastic deformation under physiological loading. Relevance is high and well-established in the regulatory literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches COU geometry, loading, and material; no extrapolation beyond validated domain required.",
      "rationale": "Validation specimens are geometrically identical to the COU device (non-cannulated 7.5 mm screw, same rod diameter, same vertebral body surrogate). Loading protocol matches COU exactly (ASTM F1717 static compression-bending). No geometric or material extrapolation required. The validation activity is considered directly applicable to the COU without adjustment factors."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve factors meet or exceed required level. One factor (Test conditions) achieves level 2 against a required level 3 due to single-configuration testing; this shortfall is accepted because the single ASTM F1717 compression-bending condition is the regulatory standard for this device class and no additional configurations are required by FDA guidance. All three QoIs satisfy quantitative acceptance criteria (E/uval < 1.96; relative difference < 10%). The FEA modeling framework is accepted as sufficiently credible for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
