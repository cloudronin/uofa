  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-noncannulated-f1717-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for a medium model risk, medium decision consequence COU. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 specifies a single standardized test condition and the regulatory submission context does not require multi-condition validation. All three QoIs pass pre-specified quantitative acceptance criteria. The FEA modeling framework is judged credible for the intended use.",
