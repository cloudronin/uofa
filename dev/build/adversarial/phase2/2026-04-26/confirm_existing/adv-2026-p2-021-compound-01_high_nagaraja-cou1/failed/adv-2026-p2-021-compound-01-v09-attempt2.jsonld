  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FDA, Ansys, and DePuy Synthes FEA codes each hold current validated-software status under their respective quality management systems. Version control records and test suite results available for audit.",
      "rationale": "All three FEA codes used in the ensemble are covered by ISO 9001 / FDA 21 CFR Part 820 compliant software QA programs. Versioned release notes and regression test logs were reviewed and found current at the time of the analysis. Achieved level equals required level for Model Risk Level 3."
    },
    {
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Each FEA code must pass ASME V&V 10 benchmark problems relevant to structural contact mechanics at the required gradation level.",
      "rationale": "Vendor-supplied and in-house benchmark verification results for static structural and contact problems confirm correct implementation of the governing equations in all three codes. Benchmark suite includes NAFEMS LE1, LE10, and a Hertzian contact reference problem. All results within 1% of analytical solutions."
    },
    {
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change < 2% between medium and fine meshes; Richardson extrapolation GCI < 5%.",
      "rationale": "A three-level mesh refinement study was conducted on the non-cannulated 7.5 mm pedicle screw geometry. Stiffness QoI changed by 0.8% between medium (element edge length 0.4 mm) and fine (0.2 mm) meshes. GCI for the fine mesh is 1.3%, well within the 5% acceptance criterion. Production runs use the medium mesh to balance accuracy and computational cost."
    },
    {
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge to < 1e-6 for all load steps; energy balance checked at each increment.",
      "rationale": "Default direct sparse solver used in all three FEA codes for this quasi-static problem. Residual norms converge to machine precision (< 1e-10) for every load step. Energy balance errors < 0.01% across the full displacement range. No solver divergence or spurious oscillation observed."
    },
    {
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup files and boundary condition definitions by a second qualified analyst not involved in original model construction.",
      "rationale": "Model setup, boundary conditions, contact definitions, and load application were independently reviewed by a second FDA biomedical engineer with >5 years FEA experience. All three code implementations reviewed. One minor discrepancy in titanium rod elastic modulus (207 GPa vs. nominal 114 GPa for Ti-6Al-4V) was identified and corrected prior to final runs. No residual use errors identified post-correction."
    },
    {
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic material model acceptable for stiffness and yield force QoIs provided plastic onset is identifiable; geometric nonlinearity must be included for large-displacement (40 mm) QoI.",
      "rationale": "Linear elastic constitutive models with geometric nonlinearity (large-deformation formulation) are used for all metallic components. Plastic onset is identified via the 0.2% offset yield criterion applied to the force-displacement curve rather than through a plasticity material model, consistent with the ASTM F1717 test interpretation. Model form is appropriate for the three QoIs and has been validated against experimental data in prior FDA publications."
    },
    {
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports (MTRs) for the specific lot of Ti-6Al-4V rod and screw stock used in bench testing; geometric dimensions from CMM measurements of test articles.",
      "rationale": "Elastic modulus (114 GPa), Poisson's ratio (0.33), and yield strength (880 MPa) sourced from lot-specific MTRs provided by DePuy Synthes. Screw and rod geometry digitised from CMM measurements of three representative test articles; mean dimensions used in the nominal model. Dimensional variability across the 11 constructs was < 0.5% for all critical features."
    },
    {
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 test constructs from production-representative hardware; constructs distributed across at least two independent laboratories.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested: 6 at Laboratory A (FDA White Oak) and 5 at Laboratory B (DePuy Synthes Warsaw). All constructs assembled from production-representative hardware pulled from the same manufacturing lot. Inter-laboratory coefficient of variation for stiffness was 3.2%, confirming reproducibility of the test protocol."
    },
    {
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span at least two clinically relevant load levels or construct configurations to support interpolation of model predictions.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending configuration only (35 mm inter-body distance, standard UHMWPE block). No variation in inter-body distance, rod diameter, or loading rate was explored. This limitation was identified during the credibility assessment; achieved level (1) is one gradation below required level (2). The gap is accepted because the single condition directly represents the worst-case clinical scenario identified in the risk assessment, and supplementary analytical sensitivity studies confirmed monotonic model response across the plausible range of inter-body distances."
    },
    {
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters (geometry, material, boundary conditions) must be traceable to the as-tested hardware and test setup with documented mapping table.",
      "rationale": "A parameter equivalency matrix was constructed mapping each model input to its experimental counterpart: screw geometry to CMM data, material properties to MTRs, boundary conditions to test fixture drawings, and applied displacement to actuator LVDT calibration records. All 14 mapped parameters confirmed equivalent; no surrogate or assumed values used."
    },
    {
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using the ASME V&V 10.1 normalized validation metric E/uval < 1.96 for all three QoIs; visual overlay of force-displacement curves required.",
      "rationale": "E/uval computed for stiffness (1.41), yield force (1.62), and force at 40 mm (1.78); all below the 1.96 acceptance threshold. Force-displacement curve overlays for all 11 constructs vs. three FEA codes provided in Appendix C of the validation report. Agreement is visually strong across the full displacement range. Achieved level equals required level."
    },
    {
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) must be directly linked to the clinical decision criterion and the regulatory submission acceptance standard.",
      "rationale": "The three QoIs are the exact metrics specified in ASTM F1717 for regulatory submissions and directly correspond to the clinical failure modes of construct loosening (stiffness), plastic deformation onset (yield force), and large-deformation structural integrity (force at 40 mm). Relevance is high; no surrogate QoIs used."
    },
    {
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same hardware design, loading mode, and boundary conditions as the COU; any differences must be bounded by sensitivity analysis.",
      "rationale": "Validation activities use production-representative non-cannulated 7.5 mm pedicle screw hardware under ASTM F1717 compression-bending — identical to the COU. The FEA modeling framework, material models, and contact definitions are the same as those used in the predictive COU simulations. No extrapolation beyond the validated design space is required. Achieved level equals required level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-fda-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling ensemble satisfies all 13 V&V 40 credibility factors at or above required levels with the single documented exception of Test Conditions (achieved level 1 vs. required level 2). This gap is accepted because the single validated condition represents the bounding clinical scenario and supplementary sensitivity analyses confirm monotonic model response. All three QoI normalized validation metrics satisfy E/uval < 1.96. The overall credibility evidence is sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
