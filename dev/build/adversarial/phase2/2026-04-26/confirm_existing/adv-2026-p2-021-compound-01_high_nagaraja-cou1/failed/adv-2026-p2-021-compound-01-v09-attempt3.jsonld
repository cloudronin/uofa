    },
    {
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force and displacement residuals converge to < 1e-4 relative norm; energy balance error < 0.1%.",
      "rationale": "Newton-Raphson iteration with line search; residual convergence criterion 1e-5 applied. Energy balance monitored each load increment; maximum imbalance 0.04% across all 11 simulations. No non-convergence events recorded. Achieved level 2 meets required level 2."
    },
    {
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented modeling procedure with independent peer review; analyst training records on file.",
      "rationale": "Modeling procedure SOP-FEA-2023-012 followed; independent peer review by senior analyst (10+ years orthopedic FEA experience) completed prior to submission. Two analysts independently reproduced stiffness result within 0.3%. Training records archived. Achieved level 2 meets required level 2."
    },
    {
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model (bilinear isotropic hardening) validated against coupon-level tensile data for Ti-6Al-4V; contact formulation (augmented Lagrangian) appropriate for screw-rod interface.",
      "rationale": "Bilinear isotropic hardening parameters (E=114 GPa, σ_y=880 MPa, E_t=2.3 GPa) derived from five tensile coupon tests per ASTM E8. Augmented Lagrangian contact with friction coefficient μ=0.2 (literature-supported for Ti-Ti). Model form uncertainty estimated at ±3% via sensitivity analysis on constitutive parameters. Achieved level 3 meets required level 3."
    },
    {
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Geometry from CMM-verified CAD; material properties from lot-specific coupon testing; boundary conditions replicate ASTM F1717 fixture kinematics.",
      "rationale": "CAD geometry verified against CMM measurements (max deviation 0.05 mm). Material properties from five Ti-6Al-4V coupons per lot. Boundary conditions: inferior block fixed; superior block displacement-controlled per F1717 §7.4. UHMWPE block modeled as linear elastic (E=0.93 GPa). Sensitivity of stiffness to ±10% E_UHMWPE: <0.8%. Achieved level 3 meets required level 3."
    },
    {
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lots; dimensional verification against nominal CAD; material certificates on file.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from two production lots tested across two independent laboratories. Dimensional verification by CMM for 3 of 11 specimens; all within drawing tolerances. Material certificates (Ti-6Al-4V ELI, ASTM F136) on file. Inter-laboratory coefficient of variation for stiffness: 3.2%. Achieved level 3 meets required level 3."
    },
    {
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of anticipated clinical loading; at minimum two load configurations assessed.",
      "rationale": "Testing performed under a single ASTM F1717 compression-bending configuration (5° offset, 44 mm construct height). Torsional and lateral bending loading not assessed in this COU. This limitation is acknowledged; the COU is scoped to compression-bending only. Achieved level 2 is below required level 3, representing a documented gap consistent with the COU description. Risk accepted by decision authority given the targeted regulatory submission scope."
    },
    {
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry, and boundary conditions used in simulation match those of physical test specimens within stated tolerances.",
      "rationale": "Simulation inputs mapped directly from lot-specific coupon data and CMM measurements. Screw torque preload (4 N·m) replicated in FEA via bolt-pretension element. UHMWPE block geometry measured post-test and confirmed within 0.5 mm of nominal. Friction coefficient sensitivity: ±0.05 change in μ yields <1.5% stiffness change. Achieved level 3 meets required level 3."
    },
    {
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (MAPE, E/uval) applied to all primary QoIs; acceptance bounds pre-specified in validation plan.",
      "rationale": "MAPE and E/uval computed for stiffness, yield force, and force at 40 mm displacement. All three QoIs satisfy MAPE < 10% and E/uval < 1.96. Validation plan VP-2023-009 pre-specified acceptance bounds prior to data unblinding. No post-hoc adjustment of bounds. Achieved level 3 meets required level 3."
    },
    {
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly correspond to regulatory submission endpoints and clinical failure modes.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in FDA guidance for pedicle screw 510(k) submissions (FDA-2021-D-0649). These QoIs map directly to construct rigidity (clinical: inadequate fixation) and structural integrity (clinical: implant fracture). Achieved level 3 meets required level 3."
    },
    {
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities replicate the physical scenario of the COU with respect to geometry, loading, and material; any differences are characterized and bounded.",
      "rationale": "Validation specimens are production-representative non-cannulated 7.5 mm screws from the same design family as the submission device. Loading replicates the ASTM F1717 protocol specified in the COU. The single-condition limitation (Test conditions factor, achieved level 2) is bounded by the COU scope restriction to compression-bending. Overall validation activity relevance assessed as high. Achieved level 3 meets required level 3."
    }
