    {
      "id": "https://uofa.net/synth/validation/nagaraja-cou1-stiffness-yield-f40",
      "type": "ValidationResult",
      "name": "FEA vs. experimental comparison: stiffness, yield force, force at 40 mm displacement",
      "description": "Direct quantitative comparison of FEA-predicted QoIs (construct stiffness, yield force, force at 40 mm displacement) against N=11 experimental measurements across two independent laboratories. All three QoIs satisfy the pre-established acceptance criterion of <10% mean absolute percentage difference and E/uval < 1.96 at the 95% confidence level. Stiffness: FEA mean 182 N/mm vs. experimental mean 179 N/mm (1.7% diff). Yield force: FEA 487 N vs. experimental 491 N (0.8% diff). Force at 40 mm: FEA 623 N vs. experimental 619 N (0.6% diff). All three QoIs pass. Decision: model is sufficiently credible for the stated COU.",
      "passFailStatus": "Pass",
      "comparisonMetric": "Mean absolute percentage difference and E/uval ratio",
      "acceptanceCriterion": "QoI difference < 10%; E/uval < 1.96",
      "validationActivityType": "Quantitative comparison to experimental data",
      "numberOfExperiments": 11
    },
