  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted at Medium assurance level. Twelve of thirteen V&V 40 factors meet or exceed their required levels. The single gap in Test conditions (achieved gradation 2 versus required gradation 3) is acknowledged and justified by the constraints of the ASTM F1717 standard protocol and is partially compensated by the multi-laboratory experimental design and conservative acceptance bounds. All three QoIs satisfy the pre-specified acceptance criteria. The FEA modeling framework is assessed as sufficiently credible for the intended regulatory use.",
