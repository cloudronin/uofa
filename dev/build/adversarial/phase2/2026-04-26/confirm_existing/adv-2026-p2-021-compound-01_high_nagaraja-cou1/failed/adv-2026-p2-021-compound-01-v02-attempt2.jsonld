  "signature": "ed25519:b1c4d7e2f5a8b3c6d9e2f5a8b1c4d7e2f5a8b3c6d9e2f5a8b1c4d7e2f5a8b3c6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA implementations (FDA, Ansys, DePuy Synthes) operate under documented software quality management systems. Version-controlled source code, regression test suites, and release validation reports are on file. Ansys Mechanical 2022R2 and the FDA in-house solver are both covered by ISO 9001:2015-compliant QMS procedures. Achieved gradation 3 exceeds the required gradation 2 for this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmark problems must be documented and passed.",
      "rationale": "Each FEA code was verified against canonical benchmark problems including NAFEMS beam bending and contact patch tests. Residual convergence criteria set to 1e-6 for all analyses. Code verification reports archived in the project technical file. Achieved gradation 2 meets the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change less than 5% between successive refinements.",
      "rationale": "Systematic mesh refinement study performed across three mesh densities (coarse: ~85k elements, medium: ~210k elements, fine: ~520k elements). QoI change between medium and fine meshes was 1.3% for stiffness, 0.9% for yield force, and 1.1% for force at 40 mm. Richardson extrapolation applied; GCI values all below 2%. Medium mesh selected for production runs. Achieved gradation 3 exceeds required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge to specified tolerance; solution verified for path-dependency.",
      "rationale": "Nonlinear quasi-static analyses used arc-length control with force and displacement residuals converging to 1e-5. Load-step sensitivity study confirmed path-independent results for the monotonic compression-bending protocol. Iterative solver error assessed as negligible relative to QoI magnitude. Achieved gradation 2 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented analysis procedure and independent review of model setup.",
      "rationale": "Model setup followed a pre-approved simulation protocol. Independent peer review of boundary conditions, material assignments, and contact definitions was performed by a second analyst not involved in the original setup. Discrepancies identified and resolved prior to production runs. Achieved gradation 2 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics must be justified relative to COU loading regime; simplifying assumptions documented.",
      "rationale": "Linear elastic titanium alloy constitutive model with bilinear isotropic hardening for post-yield behavior. Frictionless contact at screw-rod interface replaced by frictional contact (mu=0.2) following sensitivity analysis showing 4.1% QoI sensitivity to friction coefficient. UHMWPE vertebral body surrogate modeled as rigid per ASTM F1717 protocol. All simplifying assumptions documented in the model description report. Achieved gradation 3 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material and geometric inputs traceable to measurements or certified material data; input uncertainty characterized.",
      "rationale": "Titanium alloy (Ti-6Al-4V ELI) material properties sourced from ASTM F136 certificate of conformance for the production lot. Geometric inputs derived from CMM measurements of the production screw geometry with stated tolerances. Input uncertainty for elastic modulus (±3 GPa) and yield strength (±15 MPa) propagated through the ensemble. Achieved gradation 3 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of the production device; sample size sufficient for statistical comparison.",
      "rationale": "N=11 constructs tested, all manufactured from the same production lot as the FEA reference geometry. Samples distributed across two independent laboratories (n=6 Lab A, n=5 Lab B) to assess inter-laboratory variability. Certificate of conformance and dimensional inspection records on file for all 11 constructs. Sample size sufficient for E/uval comparison per ASME V&V 40 guidance. Achieved gradation 3 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading conditions relevant to the COU.",
      "rationale": "Testing performed at a single load configuration per ASTM F1717 (compression-bending at 10 mm offset). Only one test condition evaluated; no variation in offset distance, loading rate, or temperature. This limits generalizability to the single standardized test configuration. Achieved gradation 2 is below the required gradation 3, representing a known gap acknowledged in the credibility assessment. Compensating evidence from the multi-laboratory design and the conservative acceptance bounds partially offsets this limitation.",
      "gapJustification": "Single test condition is inherent to the ASTM F1717 standard protocol; additional test conditions are outside the scope of the current regulatory submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs must be demonstrably equivalent to experimental conditions.",
      "rationale": "Experimental boundary conditions (fixture geometry, loading point, constraint configuration) replicated in the FEA model using direct dimensional measurements from the test fixture drawings. Loading rate equivalency confirmed by quasi-static assumption validation: experimental crosshead speed 25 mm/min, inertial effects negligible. Material batch traceability confirmed between test samples and FEA input data. Achieved gradation 3 exceeds required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined a priori; acceptance bounds pre-specified.",
      "rationale": "Three QoIs defined a priori: construct stiffness, yield force, and force at 40 mm displacement. Acceptance bounds pre-specified as <10% percent difference and E/uval < 1.96. All three QoIs satisfied both criteria. Comparison performed against full N=11 experimental dataset with pooled inter-laboratory statistics. Achieved gradation 3 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly relevant to the clinical and regulatory decision.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the standard mechanical performance metrics for spinal implant constructs per ASTM F1717 and FDA guidance. These QoIs directly inform the structural adequacy assessment for the regulatory submission. Achieved gradation 3 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario must be sufficiently similar to the COU to support extrapolation.",
      "rationale": "Validation activities directly replicate the COU: same device design, same loading protocol (ASTM F1717 compression-bending), same material lot, and same QoIs. No extrapolation beyond the validated loading scenario is claimed. The validation scenario is assessed as highly relevant to the COU. Achieved gradation 3 meets required level."
    }
