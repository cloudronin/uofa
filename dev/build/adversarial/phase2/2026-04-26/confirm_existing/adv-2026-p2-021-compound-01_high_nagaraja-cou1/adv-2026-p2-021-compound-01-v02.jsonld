    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norm below solver default tolerance; energy balance error < 0.1%.",
      "rationale": "All production runs converge within 12 Newton-Raphson iterations. Force residual norm < 1e-6 N. Energy balance error monitored and confirmed < 0.05% across all 11 replicate simulations. No solver warnings or divergence events recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by a second qualified analyst; documented checklist of boundary condition and material assignment verification.",
      "rationale": "Model setup reviewed by a second PhD-level analyst not involved in primary model construction. Boundary conditions (fixed inferior vertebral body, displacement-controlled superior loading plate) verified against ASTM F1717 Section 8 requirements. Material assignments cross-checked against certified mill test reports for Ti-6Al-4V rod and screw stock."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model captures linear elastic response of Ti-6Al-4V to yield; contact formulation represents screw-rod and rod-block interfaces without artificial stiffness.",
      "rationale": "Isotropic linear elastic constitutive model (E = 113.8 GPa, ν = 0.342) applied to all metallic components. Augmented Lagrangian contact with friction coefficient μ = 0.2 at screw-rod and rod-block interfaces, consistent with published tribological data for dry titanium-titanium contact. Model form judged adequate for the pre-yield stiffness and yield force QoIs; post-yield behavior is outside the COU scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified lot-specific tensile testing; geometry from calibrated CMM measurements of production screws and rods.",
      "rationale": "Elastic modulus and Poisson's ratio for Ti-6Al-4V taken from lot-specific tensile coupon testing (n=5 coupons per lot; CV < 1.2%). Screw and rod geometry digitized from CMM measurements of 11 production components used in bench testing; nominal CAD geometry adjusted to measured dimensions. Uncertainty in material inputs propagated via ±2σ bounds in sensitivity study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test constructs assembled from production-representative components; sample size sufficient to characterize inter-specimen variability.",
      "rationale": "N=11 constructs assembled from production-lot screws, rods, and polyaxial connectors by trained technicians following the device IFU. Six constructs tested at Lab 1 (FDA CDRH), five at Lab 2 (DePuy Synthes). Inter-specimen CV for construct stiffness is 3.1%, confirming low manufacturing variability. Samples are representative of the commercial device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios or at least two independent test configurations.",
      "rationale": "Testing performed under a single ASTM F1717 configuration (44 mm inter-pedicle distance, static compression-bending only). Torsion and axial compression configurations were not tested in this study. Achieved level is 2 because only one load case is covered; required level is 3 for the Medium model risk. This gap is acknowledged and accepted by the decision team based on the conservative nature of the compression-bending load case for screw fracture prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and geometry match test setup within measurement uncertainty; loading fixture compliance accounted for.",
      "rationale": "Fixture compliance measured at both laboratories using a calibrated stiffness standard and subtracted from raw load-displacement data before comparison. FEA boundary conditions replicate the test fixture geometry to within 0.1 mm (CMM-verified). Loading rate effects are negligible at the quasi-static rate used (1 mm/min); rate-independent elastic model is appropriate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) defined a priori; acceptance threshold established before unblinding of experimental data.",
      "rationale": "Acceptance criterion E/uval < 1.96 and mean QoI difference < 10% defined in the pre-study validation plan (VSP-2021-001, Rev B) before experimental data were unblinded. All three QoIs pass both criteria. Stiffness: E/uval = 0.83, mean diff = 3.2%. Yield force: E/uval = 1.21, mean diff = 5.7%. Force at 40 mm: E/uval = 1.44, mean diff = 7.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs are directly linked to the COU decision: stiffness governs subsidence risk; yield force governs screw fracture risk.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly used in the 510(k) substantial equivalence comparison. Each QoI maps to a clinically relevant failure mode (subsidence, screw fracture, rod fracture). QoI selection reviewed and approved by the FDA project manager."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches COU geometry, material, loading, and boundary conditions; any differences justified and bounded.",
      "rationale": "Validation scenario is identical to the COU: same non-cannulated 7.5 mm screw geometry, same Ti-6Al-4V material, same ASTM F1717 static compression-bending protocol. The FEA model used in validation is the same model used for the COU prediction; no extrapolation across geometry or material space is required. Validation relevance is assessed as fully adequate."
    }
  ],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a Model Risk Level 3 / Medium assurance assessment. The single gap (Test conditions, achieved 2 vs. required 3) is accepted on the basis that ASTM F1717 compression-bending is the governing load case for screw fracture and the conservative nature of the single-condition test is well-established in the spinal implant literature. All three QoIs satisfy the pre-specified E/uval < 1.96 and <10% mean difference acceptance criteria across N=11 constructs at two independent laboratories. The credibility package is accepted as adequate to support the 510(k) submission claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
