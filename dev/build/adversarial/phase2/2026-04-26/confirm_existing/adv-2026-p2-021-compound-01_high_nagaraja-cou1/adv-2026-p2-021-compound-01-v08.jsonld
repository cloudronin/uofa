  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All simulation software versions under configuration control; regression test suite executed with zero failures prior to production runs.",
      "rationale": "Ansys Mechanical 2022 R2 used throughout; version locked in project configuration management system. Regression suite of 47 benchmark problems executed; all passed. FDA FEA framework version 3.1.0 independently verified under the same CM protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verified against at least two analytical benchmarks relevant to structural mechanics; errors within published solver tolerances.",
      "rationale": "Ansys Mechanical verified against Timoshenko beam bending and Hertzian contact benchmarks. Errors of 0.3% and 0.8% respectively, well within solver tolerance of 2%. Independent verification performed by FDA FEA team confirms equivalent results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinement levels; Richardson extrapolation applied to estimate discretization error.",
      "rationale": "Three-level mesh convergence study performed on the non-cannulated screw geometry. Stiffness QoI changed 3.1% (coarse to medium) and 0.9% (medium to fine). Richardson extrapolation yields discretization error estimate of 0.6% for the production mesh. Fine mesh selected for all validation runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence criteria set to residual <1e-6; energy norm monitored; no divergence events recorded.",
      "rationale": "Newton-Raphson nonlinear solver used with force and displacement residual convergence criteria of 1e-6. Energy norm tracked across all load steps. No convergence failures in any of the 33 simulation runs (11 specimens × 3 QoIs). Maximum iteration count 42 (well within 200-iteration limit)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs reviewed by independent analyst; documented checklist completed prior to each simulation batch.",
      "rationale": "Pre-simulation checklist (22 items) completed by primary analyst and independently reviewed by a second analyst for each batch. Material property assignments, boundary condition definitions, and contact formulations verified. No use errors identified during review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics assumptions justified for pedicle screw geometry; contact formulation appropriate for screw-rod interface; material constitutive model validated against coupon data.",
      "rationale": "Isotropic linear-elastic titanium alloy (Ti-6Al-4V) constitutive model justified by operating strain regime (<0.5% strain prior to yield). Augmented Lagrange contact formulation selected for screw-rod interface; penalty stiffness sensitivity study shows <1% QoI sensitivity. Model form uncertainty estimated at ±3% based on coupon-level material validation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material certificates for each test specimen lot; geometric dimensions from CMM measurements; torque values from calibrated torque wrench records.",
      "rationale": "Young's modulus (114 GPa) and yield strength (880 MPa) from certified material certificates for Ti-6Al-4V lot used in test specimens. Screw and rod geometry from CMM measurements with ±0.01 mm uncertainty. Rod pre-load torque from calibrated torque wrench (±2 N·m). All input values traceable to test records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production-representative lots; specimens from two independent laboratories; lot traceability documented.",
      "rationale": "N=11 constructs tested (6 at Lab A, 5 at Lab B). All specimens from the same production lot (Lot 2021-NC-75) of non-cannulated 7.5 mm pedicle screws. Lot traceability documented in test records. Between-laboratory variability assessed; no statistically significant difference in mean stiffness (p=0.31, two-sample t-test)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions cover the range of COU loading scenarios; at least two load levels or configurations tested.",
      "rationale": "Testing performed at a single load configuration (ASTM F1717 standard setup: 5° offset, 10 mm offset distance). Only one test condition evaluated due to resource constraints. This factor is below the required level (achieved 2 vs. required 3), representing a documented gap. Risk accepted given that the ASTM F1717 configuration is the regulatory submission condition."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters demonstrably equivalent to test specimen parameters; mapping documented for all material, geometric, and boundary condition inputs.",
      "rationale": "One-to-one mapping table prepared for all 14 model input parameters against corresponding test measurements. Material properties from same lot certificates used in both model and test. Geometric dimensions from CMM used directly as model inputs. Boundary conditions replicate test fixture constraints verified by fixture drawing review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined a priori; E/uval metric applied; acceptance threshold E/uval < 1.96 for all QoIs.",
      "rationale": "Three QoIs compared: construct stiffness (E/uval 0.87), yield force (E/uval 1.41), force at 40 mm displacement (E/uval 1.62). All three E/uval values below the pre-established threshold of 1.96. Comparison performed specimen-by-specimen and in aggregate. Results tabulated in Validation Report VR-2023-NC-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to regulatory submission requirements and clinical failure modes; mapping documented.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the FDA guidance for pedicle screw FEA submissions. Direct mapping to ASTM F1717 acceptance criteria documented in QoI traceability matrix. Clinical relevance: yield force predicts fatigue initiation risk; stiffness predicts load transfer to adjacent levels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, material, and loading match the COU; any differences explicitly documented and impact assessed.",
      "rationale": "Validation specimens are production-representative non-cannulated 7.5 mm screws from the same design family as the COU device. Loading protocol (ASTM F1717 compression-bending) is identical to the COU regulatory test condition. The only documented difference is laboratory environment (ambient vs. 37°C saline); sensitivity analysis shows <1% QoI impact, supporting relevance."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/computational-biomechanics-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-required factor (Test conditions, achieved 2 vs. required 3) is accepted on the basis that the ASTM F1717 single-condition protocol is the applicable regulatory standard and no additional load configurations are required for the submission. All three QoIs satisfy E/uval < 1.96. The FEA modeling framework is assessed as sufficiently credible for the non-cannulated 7.5 mm pedicle screw compression-bending COU at Medium assurance level.",
