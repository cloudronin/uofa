  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the Medium model risk context.",
      "rationale": "Ansys Mechanical R2022 R2 is used under an ISO 9001-certified quality management system. Software version control, regression test suite, and release notes are maintained. All three FEA solvers (FDA, Ansys, DePuy internal) operate under documented SQA plans with traceability to ASME V&V 10 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions reproduced within 1% relative error.",
      "rationale": "Linear elastic cantilever beam and Hertzian contact benchmark problems solved; FEA results agree with analytical solutions to within 0.4% and 0.9% respectively. All three solver implementations independently verified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or systematic mesh refinement study demonstrates GCI < 5% for all QoIs.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw and rod assembly. Grid Convergence Index for stiffness QoI: 1.8%; yield force QoI: 2.3%; force at 40 mm: 2.1%. Fine mesh selected for production runs. Mesh density at screw-rod interface confirmed adequate by contact pressure convergence check."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria tighter than 1e-5; energy balance error below 0.1%.",
      "rationale": "Nonlinear solver convergence monitored via force and displacement residuals; all runs converged to 1e-6 norm. Energy balance error across all 11 simulation replications was below 0.05%. No divergence or step-size reduction events recorded in solution logs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of model setup by a second analyst.",
      "rationale": "Model setup, boundary conditions, and material assignments independently reviewed by a second senior FEA analyst not involved in original setup. Discrepancies resolved before production runs. Pre-analysis checklist completed and archived per DePuy Synthes simulation governance procedure SP-FEA-0042."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model and contact formulation justified by literature and sensitivity analysis; frictional contact coefficient validated.",
      "rationale": "Ti-6Al-4V modeled as bilinear isotropic hardening; elastic modulus 114 GPa, yield stress 880 MPa, tangent modulus 1.2 GPa per ASTM F136 and supplier certification data. Augmented Lagrangian frictional contact (mu=0.2) used at screw-rod interface; sensitivity analysis shows QoI variation of <3% over mu range 0.15–0.30. Geometric nonlinearity (NLGEOM) enabled for large-displacement regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometry sourced from certified material certs and CMM measurements; variability across N=11 constructs characterized.",
      "rationale": "Screw and rod geometry digitized via CMM for each of the 11 constructs; nominal FEA geometry updated to as-built dimensions. Material certificates for each lot confirm Ti-6Al-4V properties within ASTM F136 tolerances. Inter-construct geometric variability characterized; coefficient of variation for outer diameter 0.3%, thread pitch 0.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lots; traceability to device master record confirmed.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested: six at Laboratory 1 (FDA CDRH), five at Laboratory 2 (DePuy Synthes). All constructs sourced from production lots with full traceability to device master record DMR-PS-075-NC. Lot homogeneity confirmed by incoming inspection records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple loading rates or environmental conditions tested; ASTM F1717 protocol fully reproduced in FEA boundary conditions.",
      "rationale": "Testing performed under ASTM F1717 static compression-bending at a single crosshead displacement rate of 5 mm/min. Only one loading condition assessed; dynamic or fatigue conditions not included in this COU. This shortfall is acknowledged and accepted given the static design verification scope. FEA boundary conditions replicate the UHMWPE block fixture geometry and pin constraints per F1717 Annex A."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters traceable to physical measurements on the same constructs used in testing; no surrogate materials or scaled geometry.",
      "rationale": "FEA inputs directly derived from CMM measurements and material certificates for each tested construct. No surrogate or scaled geometry used. Torque-preload relationship for set screw tightening measured on five constructs via instrumented torque wrench and applied as equivalent pretension in FEA. Correspondence between physical and computational inputs documented in simulation report SR-2023-0047."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) applied to all three QoIs; pre-specified acceptance threshold of E/uval < 1.96 met.",
      "rationale": "E/uval computed per ASME V&V 40 Section 7 for all three QoIs: stiffness 1.31, yield force 1.44, force at 40 mm 1.61. All below the pre-specified threshold of 1.96. Mean absolute percentage errors 4.2%, 6.8%, and 7.9% respectively, all within the 10% bound. Bland-Altman plots confirm no systematic bias across the measurement range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to regulatory submission requirements and clinical failure modes; linkage to COU documented.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs mandated by FDA guidance for pedicle screw 510(k) submissions under ASTM F1717. Each QoI links to a clinical failure mode: stiffness to adjacent-segment loading, yield force to intraoperative fracture risk, force at 40 mm to post-yield fatigue initiation. Linkage documented in risk analysis RA-PS-075-NC Rev C."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test conditions, sample population, and QoIs are representative of the intended COU; any gaps documented and justified.",
      "rationale": "Validation performed on the exact device configuration (non-cannulated 7.5 mm, production geometry) under the regulatory test standard (ASTM F1717) directly cited in the 510(k) submission. Two independent laboratories provide inter-laboratory reproducibility evidence. The single loading condition gap (Test conditions factor, achieved level 2) is accepted given the static verification scope; dynamic COU addressed in a separate submission package."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors achieve or exceed the required level for a Medium model risk, Medium model influence, Medium decision consequence context. One factor (Test conditions) achieves level 2 against a required level of 3; this gap is accepted because the COU is explicitly scoped to static compression-bending only and the single loading condition is the regulatory standard condition. E/uval ratios for all three QoIs are below the pre-specified 1.96 threshold. The FEA modeling framework is judged credible for its intended use in the 510(k) submission for the non-cannulated 7.5 mm pedicle screw.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
