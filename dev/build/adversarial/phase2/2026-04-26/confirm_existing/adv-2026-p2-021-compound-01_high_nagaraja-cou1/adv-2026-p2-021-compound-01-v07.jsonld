  "signature": "ed25519:b2e4a7c1f3d09e6b8a5c2f0d4e7b1a9c3f6d2e8b0a4c7f1d5e9b3a6c0f2d8e5b1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented SQA plan; version-controlled solver executables; regression test suite executed prior to each analysis run.",
      "rationale": "Ansys Mechanical 2022 R2 used under an ISO 9001-certified SQA environment. Version control via Git with tagged release commits. Full regression suite (847 benchmark cases) executed and archived. Achieved level 3 exceeds the required level 2 for a medium model risk application."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least two published analytical benchmarks relevant to structural mechanics.",
      "rationale": "Ansys Mechanical verified against Timoshenko beam bending and Hertzian contact benchmarks. Results within 0.5% of analytical solutions. Code verification documentation archived in project record COU1-SQA-002."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating QoI change < 1% between successive refinement levels.",
      "rationale": "Three-level mesh refinement study performed on the screw-rod assembly. QoI (construct stiffness) changed 0.7% between medium and fine meshes; 0.2% between fine and extra-fine. Final mesh selected at fine level (1.24 M elements). Richardson extrapolation applied; GCI < 0.8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented and met; force-displacement equilibrium verified at each load step.",
      "rationale": "Nonlinear static analysis with Newton-Raphson iteration. Force residual tolerance 1e-4; displacement residual tolerance 1e-4. Energy criterion also monitored (< 1e-6). All load steps converged; no bisection events recorded. Solver log archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup; documented boundary condition and loading protocol checklist completed.",
      "rationale": "Model setup independently reviewed by a second FEA analyst not involved in original construction. Boundary conditions (fixed inferior vertebral body, displacement-controlled superior loading at 10 mm/min equivalent) verified against ASTM F1717 protocol. Checklist COU1-USE-001 signed off."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection justified by material characterization data; contact formulation appropriate for screw-rod interface behavior.",
      "rationale": "Ti-6Al-4V modeled as bilinear isotropic hardening (E=114 GPa, σy=880 MPa, Et=1.2 GPa) based on coupon tensile testing (n=6). Augmented Lagrangian contact with friction coefficient μ=0.2 validated against torque-tension data. UHMWPE vertebral body surrogate modeled as elastic-perfectly plastic (E=0.76 GPa, σy=20 MPa). Model form consistent with literature precedents."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All geometric and material inputs traceable to measured data; dimensional inspection report available for test specimens.",
      "rationale": "Screw geometry derived from CMM inspection of five production screws (dimensional tolerance ±0.02 mm). Rod geometry from engineering drawing with CMM verification. Material properties from lot-specific coupon testing. All inputs documented in COU1-INP-003 and traceable to calibrated instruments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens representative of production parts; material certification and dimensional inspection records available.",
      "rationale": "N=11 constructs assembled from production-representative screws and rods (same lot as CMM-inspected parts). Material certifications (Ti-6Al-4V per ASTM F136) available for all hardware. UHMWPE vertebral body surrogates per ASTM F1717 specification. Lab 1 tested n=6; Lab 2 tested n=5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of COU loading scenarios; at least two distinct load levels or configurations evaluated.",
      "rationale": "Testing conducted at a single load configuration (ASTM F1717 standard geometry, 10 mm/min displacement rate). Although two laboratories participated, both used identical test conditions. The required level 3 demands at least two distinct configurations; only one was evaluated. This factor is below the required level and represents a known scope limitation acknowledged in the submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs match experimental conditions; any deviations documented and their impact on QoI assessed.",
      "rationale": "Material properties, geometry, boundary conditions, and loading rate in simulation matched to experimental records. One minor deviation: displacement rate in simulation is quasi-static (rate-independent plasticity) versus 10 mm/min experimental rate. Sensitivity analysis showed < 0.5% QoI impact at this rate, consistent with rate-independent regime for Ti-6Al-4V at room temperature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined a priori; acceptance bounds pre-specified; E/uval metric applied.",
      "rationale": "Three QoIs compared: construct stiffness, yield force, and force at 40 mm displacement. Acceptance bounds (<10% MAPE; E/uval < 1.96) pre-specified in validation plan COU1-VP-001 prior to data unblinding. All three QoIs satisfy acceptance bounds. E/uval ratios: 1.31 (stiffness), 0.88 (yield force), 1.47 (force at 40 mm)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to device performance metrics used in the regulatory submission; clinical relevance documented.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three primary performance endpoints in the 510(k) submission for this device. Yield force directly relates to permanent deformation risk; force at 40 mm relates to fatigue life prediction inputs. QoI relevance documented in COU1-QOI-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches COU geometry, loading, and material; any extrapolation beyond the validation domain documented.",
      "rationale": "Validation performed on the same non-cannulated 7.5 mm screw geometry, same UHMWPE surrogate, and same ASTM F1717 loading protocol as the COU. No geometric or material extrapolation required. The validation domain fully encompasses the COU scenario. Relevance assessment documented in COU1-REL-001."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level. The single below-required factor (Test conditions, achieved 2 vs. required 3) is offset by the multi-laboratory experimental design providing inter-laboratory reproducibility evidence and by the conservative acceptance bounds applied to all QoIs. All three QoIs satisfy pre-specified acceptance bounds with E/uval ratios well below 1.96. The credibility evidence is sufficient to support regulatory submission of the non-cannulated pedicle screw FEA framework.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
