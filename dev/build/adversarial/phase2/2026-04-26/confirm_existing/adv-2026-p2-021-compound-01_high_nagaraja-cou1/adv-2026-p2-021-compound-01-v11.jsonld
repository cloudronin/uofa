  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software used under a documented quality management system with version control and validation testing records.",
      "rationale": "Ansys Mechanical 2022 R2 deployed under FDA CDRH software QMS. Version-controlled input decks archived in FDA secure repository. Release validation testing records available for all solver modules used in this analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks for structural FEA (beam bending, contact mechanics) demonstrate solver accuracy within 1% of analytical solutions.",
      "rationale": "Ansys Mechanical benchmark suite for linear and nonlinear structural mechanics executed. Timoshenko beam benchmark error 0.3%; Hertzian contact benchmark error 0.6%. Both within the 1% criterion. Code verification documentation archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change less than 5% between successive refinement levels; GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed on pedicle screw shank and rod interface regions. Stiffness QoI changed 3.1% (coarse to medium) and 0.8% (medium to fine). GCI estimated at 1.9% using Richardson extrapolation. Fine mesh adopted for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6 for all load steps; energy balance error below 0.1%.",
      "rationale": "Newton-Raphson nonlinear solver converged to force residual norm below 1e-7 for all 22 load increments across all 11 model instances. Energy balance error monitored throughout; maximum observed 0.04%. No divergence events recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second analyst; documented checklist covering boundary conditions, material assignments, and contact definitions.",
      "rationale": "Model setup independently reviewed by a second FDA engineer using a 47-item checklist. Three minor discrepancies identified (contact stiffness factor, load application point offset, material density) and corrected prior to production runs. Final model signed off by both analysts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics formulation with nonlinear geometry (large deformation) and frictional contact is appropriate for the compression-bending regime tested; justified by literature precedent.",
      "rationale": "Large-deformation elasto-plastic continuum formulation selected based on expected strain levels (up to 2% in screw shank). Frictional contact (mu=0.2) at rod-screw interface consistent with published tribological data for Ti-6Al-4V on Ti-6Al-4V. Model form consistent with Nagaraja et al. 2018 and three independent published studies of similar constructs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing of production-lot Ti-6Al-4V; geometric inputs derived from CMM measurements of production hardware.",
      "rationale": "Ti-6Al-4V elastic modulus 114 GPa, yield strength 880 MPa, tangent modulus 1.1 GPa derived from tensile coupon testing of the same production lot used for bench testing (n=6 coupons). Screw and rod geometry inputs from CMM measurements on 5 randomly selected production parts; dimensional tolerances within ±0.02 mm of nominal."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Bench test specimens are production-representative hardware from the same design generation; N≥10 constructs tested.",
      "rationale": "N=11 constructs assembled from production-lot non-cannulated 7.5 mm pedicle screws and 5.5 mm cobalt-chrome rods. Hardware sourced from DePuy Synthes production inventory, same design generation as intended commercial device. Specimens distributed across two independent test laboratories to assess inter-laboratory variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios including at least two load magnitudes and two construct configurations.",
      "rationale": "Testing performed under a single ASTM F1717 compression-bending configuration at a fixed offset distance. Only one test condition evaluated; the required level of 3 (multiple conditions) is not achieved. This shortfall is documented and accepted because the F1717 protocol is the regulatory standard and the single condition is the most conservative clinically relevant scenario. Residual uncertainty is acknowledged in the decision record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs demonstrably equivalent to bench test specimen properties and test machine boundary conditions within stated tolerances.",
      "rationale": "Material properties, geometry, and boundary conditions in the FEA model mapped directly from measured specimen data and calibrated test machine records. Load application point verified against laboratory fixture drawings. Polyaxial screw head locking torque replicated via pretension bolt element calibrated to measured insertion torque (4.0 Nm ± 0.2 Nm). Equivalency confirmed for all 11 specimen instances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using pre-specified acceptance bounds (10% QoI difference, E/uval < 1.96) for all three primary QoIs.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) compared against experimental data using pre-registered acceptance bounds. Stiffness: 2.4% difference, E/uval 0.87. Yield force: 1.9% difference, E/uval 0.74. Force at 40 mm: 2.2% difference, E/uval 0.91. All three QoIs pass both criteria. Acceptance bounds pre-registered in the validation plan prior to data unblinding."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to device performance metrics specified in the design requirements and regulatory submission strategy.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly referenced in the 510(k) substantial equivalence argument. Each QoI maps to a design requirement in the device DHF. Relevance confirmed by clinical consultant review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on production-representative hardware under the same loading protocol as the COU; any gaps between validation and COU conditions documented.",
      "rationale": "Validation activities directly replicate the COU: same hardware, same ASTM F1717 protocol, same QoIs. The only gap is the single test condition (documented under Test conditions factor). The validation activities are judged highly relevant to the COU; the single-condition limitation is accepted given the regulatory standard nature of F1717."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble achieves the required credibility level for 12 of 13 V&V 40 factors. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted because the ASTM F1717 protocol is the regulatory standard and the single test condition represents the most clinically conservative scenario. All three QoIs pass pre-registered acceptance bounds with E/uval well below 1.96. The overall credibility evidence is judged sufficient to support the intended use in the 510(k) submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
