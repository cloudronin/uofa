  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software QA plan documented; version control and regression testing in place for Ansys solver used in FEA ensemble.",
      "rationale": "Ansys Mechanical 2022 R2 used with documented QA plan, version-controlled scripts, and regression test suite. All three modeling teams (FDA, Ansys, DePuy Synthes) confirmed compliance with internal SQA procedures."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems solved and compared to analytical solutions; residuals monitored to convergence.",
      "rationale": "Standard ASME V&V 10 benchmark problems (patch test, cantilever beam) solved prior to production runs. Residual norms confirmed below 1e-6 for all load steps."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study performed; discretization error quantified and shown to be below 5% of QoI.",
      "rationale": "Three-level mesh refinement study conducted on representative screw-rod interface geometry. Richardson extrapolation applied; discretization error estimated at 2.3% for stiffness QoI, 3.1% for yield force QoI — both within the 5% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver tolerance set to ensure solution error is negligible relative to discretization error.",
      "rationale": "Direct sparse solver (PARDISO) used for all production runs, eliminating iterative convergence error. Double-precision arithmetic confirmed throughout."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented modeling protocol followed; independent model review performed by second analyst.",
      "rationale": "Modeling protocol document (MPD-COU1-v3) followed by all three modeling teams. Independent review of boundary conditions, material assignments, and contact definitions completed by FDA reviewer prior to result extraction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions documented and justified; sensitivity to constitutive model choice assessed.",
      "rationale": "Elastic-plastic Ti-6Al-4V constitutive model with bilinear isotropic hardening selected based on published material characterization data. Sensitivity analysis comparing bilinear vs. multilinear hardening showed <1.5% difference in QoIs. Geometric nonlinearity (large deformation) enabled consistent with expected 40 mm displacement range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and geometric inputs traceable to measured data; uncertainty in inputs propagated to QoI uncertainty.",
      "rationale": "Material properties sourced from MMPDS-12 and supplier coupon test data. Geometric inputs derived from CMM measurements of production screws (n=5). Monte Carlo propagation (1000 samples) of input uncertainty yielded combined input uncertainty of 4.2% on stiffness QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples representative of production geometry and material; sample size sufficient to characterize experimental variability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from production lots tested across two independent laboratories (FDA CDRH and DePuy Synthes). Dimensional inspection confirmed all samples within drawing tolerance. Sample size sufficient to estimate coefficient of variation for stiffness (CV=4.8%)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions match COU loading environment; multiple loading rates or conditions evaluated.",
      "rationale": "ASTM F1717 protocol applied at a single crosshead displacement rate of 5 mm/min. Only one test condition evaluated, which is below the required level for a Medium risk COU. This gap is acknowledged; physiological loading rate variation not captured."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA inputs matched to experimental specimen measurements; differences between model and test inputs quantified.",
      "rationale": "FEA model inputs updated to match measured dimensions and material coupons from the specific test lot. Residual differences between nominal model inputs and measured values documented and incorporated into validation uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI differences <10% and E/uval < 1.96 for all three QoIs across all three modeling teams.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfied acceptance criteria for all three modeling teams. Maximum QoI difference was 7.3% (yield force, FDA model). Maximum E/uval was 1.61. Acceptance criteria met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes and regulatory decision context.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the regulatory QoIs specified in ASTM F1717 and directly linked to clinical failure modes (fatigue fracture initiation, permanent deformation under physiological load). QoI selection reviewed and approved by FDA project team."
    },
    {
      "type": "CredibilityFactor",
