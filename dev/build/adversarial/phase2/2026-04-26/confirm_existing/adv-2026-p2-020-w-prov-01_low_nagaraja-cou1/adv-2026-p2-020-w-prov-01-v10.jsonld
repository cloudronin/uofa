      "rationale": "Three-level mesh refinement study conducted on screw shank and rod interface regions. QoI change between medium and fine mesh: 1.1% for stiffness, 0.9% for yield force. Medium mesh adopted for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented; solver tolerances set to 1e-5 or tighter.",
      "rationale": "Newton-Raphson nonlinear solver with force residual tolerance 1e-6 and displacement tolerance 1e-5. Convergence achieved in all load steps; no divergence events recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second qualified analyst.",
      "rationale": "Model boundary conditions, material assignments, and contact definitions reviewed by an independent FEA engineer not involved in original setup. Two discrepancies identified and corrected prior to final simulation runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model and contact formulation justified by published literature for titanium alloy constructs under quasi-static bending.",
      "rationale": "Bilinear isotropic hardening plasticity (Ti-6Al-4V; E=114 GPa, σy=880 MPa, Et=2.3 GPa) consistent with ASTM F136 coupon data. Augmented Lagrangian contact with friction coefficient 0.2 per published cadaveric and bench literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs traceable to measured data with uncertainty quantification.",
      "rationale": "Screw and rod geometry from certified CAD drawings (DePuy Synthes). Material properties from tensile coupon testing (n=5 per batch); mean and standard deviation reported. Sensitivity analysis shows stiffness QoI insensitive to ±5% variation in elastic modulus."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test constructs from production lot with dimensional inspection records.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from production lot; dimensional inspection confirmed all within drawing tolerances. Constructs split across two independent laboratories for reproducibility assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios or sensitivity to condition variation is quantified.",
      "rationale": "Testing conducted at a single ASTM F1717 standard load configuration. Clinical loading variability not explored; only one test condition applied. This factor is below required level; accepted under overall credibility assessment given conservative nature of F1717 protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA inputs demonstrably equivalent to experimental specimen and test machine parameters.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 fixture geometry; loading rate mapped to quasi-static assumption. Grip separation and loading point coordinates measured from test fixture and matched in FEA to within 0.5 mm."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed and compared against pre-specified threshold of 1.96.",
      "rationale": "E/uval computed for stiffness (0.83), yield force (1.12), and force at 40 mm (0.97). All below 1.96. Percentage differences: stiffness 3.2%, yield force 6.8%, force at 40 mm 4.1%. All within 10% acceptance bound."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the primary metrics cited in FDA guidance for spinal implant mechanical testing. These QoIs are directly predictive of construct fatigue life and clinical loosening risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
