  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical and in-house pre/post-processing scripts are version-controlled and regression-tested. QA documentation available.",
      "rationale": "Ansys Mechanical is a commercially validated solver with documented QA procedures. In-house scripts are stored in a version-controlled repository with regression test suite. Achieved level meets required level for Medium model risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verification against known analytical solutions for beam bending and contact problems documented in Ansys verification manual.",
      "rationale": "Ansys Mechanical verification manual contains benchmark problems covering linear elastic beam bending and frictional contact, directly relevant to the F1717 loading scenario. Code verification is considered sufficient at Gradation 2 for this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change less than 2% between successive mesh refinements.",
      "rationale": "A three-level mesh refinement study was performed. QoI differences between medium and fine mesh were below 1.8% for all three QoIs. Richardson extrapolation confirmed discretization error estimate below 2%. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver convergence monitored via residual norms; nonlinear iterations converge to tolerance 1e-4.",
      "rationale": "All nonlinear load steps converged with force and displacement residual norms below 1e-4. No divergence or non-convergence events observed across the ensemble of 11 model instances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation protocol reviewed by independent analyst; boundary conditions and load application verified against F1717 standard.",
      "rationale": "An independent analyst reviewed the simulation setup including boundary conditions, load application, and material assignments. Review checklist documented and archived. No use errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic constitutive model with frictional contact is appropriate for pre-yield regime; bilinear isotropic hardening used for post-yield prediction.",
      "rationale": "The model employs linear elastic material response for stiffness QoI and bilinear isotropic hardening for yield and post-yield QoIs. Frictional contact at screw-rod and rod-block interfaces is modeled with Coulomb friction. Model form is consistent with published literature for metallic spinal implant FEA."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports for Ti-6Al-4V ELI; geometry from CAD nominal dimensions with dimensional inspection report.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus for Ti-6Al-4V ELI sourced from certified material test reports for the production lot. Geometry inputs derived from nominal CAD with dimensional inspection confirming conformance to drawing. Friction coefficient from published tribology literature for Ti-Ti contact."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lot; dimensional inspection confirms conformance to nominal geometry within drawing tolerances.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production components. Dimensional inspection of representative samples confirmed conformance to nominal CAD geometry. Constructs tested across two independent laboratories to assess inter-laboratory variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios including at least two load levels.",
      "rationale": "Testing performed under a single F1717 load configuration (compression-bending at standard offset). Only one test condition evaluated; clinical loading variability not fully characterized. Achieved level (2) is below required level (3) — identified as a gap in the credibility assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs are traceable to measured or certified values from the tested constructs; no uncharacterized discrepancies between simulation and test inputs.",
      "rationale": "Material properties, geometry, and boundary conditions in the FEA model are directly traceable to the tested constructs via material test reports and dimensional inspection data. Loading offset and fixture stiffness matched to laboratory setup documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and QoI difference < 10% for all three QoIs.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy both acceptance criteria: maximum QoI difference 7.3%, maximum E/uval 1.62. Comparison performed using validation uncertainty methodology per ASME V&V 40 Section 6."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness relates to load sharing and adjacent segment effects. Yield force and force at 40 mm displacement are standard F1717 QoIs used in regulatory submissions and directly relate to fatigue life prediction and clinical failure risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the same device design, loading mode, and material system as the COU.",
      "rationale": "Validation activities employ the identical non-cannulated 7.5 mm pedicle screw design, Ti-6Al-4V ELI material, and ASTM F1717 compression-bending loading mode as the COU. High relevance between validation scenario and intended use context."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-nagaraja",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted. Twelve of thirteen V&V 40 factors meet or exceed the required credibility level. One factor (Test conditions) achieves level 2 against a required level of 3 due to testing under a single load configuration. This gap is acknowledged and accepted given that the single F1717 condition is the regulatory standard condition and the model influence is Medium. All three QoIs satisfy quantitative acceptance criteria (E/uval < 1.96, QoI difference < 10%). The FEA modeling framework is considered credible for predicting compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
