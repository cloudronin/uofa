      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2022 R2) used under documented QMS with version-controlled input decks and regression test suite.",
      "rationale": "DePuy Synthes internal QMS covers Ansys solver qualification; FDA laboratory uses independently validated Ansys installation with NIST benchmark suite passing at Gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes NAFEMS benchmark set LE1 and LE10; patch test satisfied for all element types used.",
      "rationale": "Ansys Mechanical passes NAFEMS linear elastic benchmarks LE1, LE3, LE10 within 1% of analytical solution. Patch test confirmed for hex20 and tet10 element libraries used in screw geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in QoIs between medium and fine mesh; GCI < 5%.",
      "rationale": "Three-level mesh refinement study (coarse 0.8 mm, medium 0.5 mm, fine 0.3 mm global seed at screw-rod interface) yields GCI of 1.8% for stiffness QoI and 2.3% for yield force QoI. Medium mesh adopted for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Newton-Raphson residual < 1e-4 at each load increment; energy criterion < 1e-6.",
      "rationale": "All production analyses converge within 25 substeps; force residual norm consistently below 5e-5. No divergence events recorded across 33 model runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst peer review of input deck and boundary conditions; checklist sign-off documented.",
      "rationale": "Two independent analysts reviewed boundary condition application, contact definitions, and material assignment against the ASTM F1717 fixture geometry. Discrepancies resolved prior to production run. Checklist archived in study record SR-2024-017."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic model with isotropic hardening validated against published titanium alloy coupon data; contact formulation consistent with F1717 fixture kinematics.",
      "rationale": "Ti-6Al-4V bilinear isotropic hardening model calibrated to ASTM E8 tensile coupon data (n=6, same material lot as test constructs). Augmented Lagrange contact at screw-rod and rod-block interfaces captures load transfer path consistent with F1717 kinematics."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from same lot coupon testing; geometric inputs from CMM measurements of production screws; torque preload characterized.",
      "rationale": "Young's modulus 114 GPa, yield stress 880 MPa, tangent modulus 1.2 GPa derived from lot-specific coupon data. Screw geometry from CMM (n=5 screws, <0.02 mm deviation from nominal). Set-screw torque preload 4 Nm applied as bolt pretension."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from same production lot tested across two independent laboratories; sample adequacy confirmed by power analysis.",
      "rationale": "Eleven non-cannulated 7.5 mm screw constructs (same production lot, lot no. 2023-NC-75) tested: 6 at FDA CDRH laboratory, 5 at DePuy Synthes test facility. Power analysis (80% power, α=0.05, CV=8%) confirms n=11 sufficient to detect 10% QoI difference."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two load levels or two vertebral body block stiffnesses to characterize construct response envelope.",
      "rationale": "Testing performed at single load condition (ASTM F1717 standard 10 mm/min crosshead displacement rate, standard UHMWPE blocks). Only one block stiffness evaluated. This factor is below required level; risk accepted because direct comparison at the single condition yields E/uval < 1.96 across all QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and material inputs demonstrably equivalent to test configuration; any deviations quantified and propagated to uncertainty budget.",
      "rationale": "UHMWPE block elastic modulus (945 MPa) measured by compression testing and applied directly in FEA. Fixture compliance measured and incorporated as spring boundary condition. Torque preload uncertainty ±0.2 Nm propagated via Monte Carlo (n=500) yielding ±1.4% QoI uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI percent difference < 10% and E/uval < 1.96 for stiffness, yield force, and force at 40 mm displacement.",
      "rationale": "Stiffness: FEA 187 N/mm vs. experimental mean 181 N/mm (3.3% difference, E/uval 0.84). Yield force: 312 N vs. 308 N (1.3%, E/uval 0.51). Force at 40 mm: 428 N vs. 419 N (2.1%, E/uval 0.73). All three QoIs within acceptance bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness relates to adjacent segment load sharing; yield force and force at 40 mm displacement are the primary ASTM F1717 acceptance endpoints cited in 510(k) submissions for pedicle screw systems. QoIs are directly relevant to the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
