  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed; 12 of 13 meet or exceed required level. Test conditions factor achieves Gradation 2 against a required Gradation 3 due to single loading rate; this gap is accepted given the regulatory standard (ASTM F1717) specifies quasi-static testing only and the E/uval metric passes for all three QoIs. Overall credibility sufficient to support 510(k) submission for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
