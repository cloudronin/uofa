  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted because the COU is strictly quasi-static and the single ASTM F1717 load rate is the regulatory standard. The quantitative validation metrics (E/uval < 1.96 and QoI difference < 10%) are satisfied for all three quantities of interest across both laboratories. The overall credibility evidence is sufficient to support regulatory submission.",
