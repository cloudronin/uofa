      "acceptanceCriteria": "Ansys Mechanical and FDA in-house FEA code both operate under documented software quality management systems with version control and regression testing.",
      "rationale": "All three FEA codes (FDA, Ansys, DePuy Synthes) have documented SQA plans, version-controlled repositories, and regression test suites. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks (patch tests, manufactured solutions) documented for each FEA solver used in the ensemble.",
      "rationale": "Patch tests and simple beam bending manufactured solutions confirm correct implementation of the linear elastic constitutive model and contact formulation in all three codes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <1% between medium and fine mesh; Richardson extrapolation applied.",
      "rationale": "A three-level mesh refinement study was conducted. Richardson extrapolation yields a discretization error estimate of 0.4% for stiffness and 0.7% for yield force, both well within the 1% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6 for all load steps; load-step sensitivity study performed.",
      "rationale": "Sparse direct solver used; residual norms confirmed below 1e-8. Load-step halving produced <0.1% change in QoIs, confirming numerical solver error is negligible."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup, boundary conditions, and material assignments completed with no discrepancies found.",
      "rationale": "An independent senior analyst reviewed model setup documentation and replicated the boundary condition application. No discrepancies identified. Gradation 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic isotropic material model appropriate for titanium alloy below yield; contact formulation captures screw-rod and screw-block interfaces.",
      "rationale": "Titanium alloy Ti-6Al-4V is well characterized as linear elastic below yield for the load magnitudes considered. Penalty-based contact formulation validated against known analytical solutions for Hertzian contact. Model form uncertainty quantified via sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, nu, yield strength) sourced from coupon testing of the same material lot; geometric inputs derived from CMM measurements of test specimens.",
      "rationale": "Young's modulus and Poisson's ratio measured from dogbone coupons of the same Ti-6Al-4V lot. CMM measurements of 3 representative constructs confirm nominal geometry within ±0.05 mm. Input uncertainty propagated through Latin hypercube sampling (n=200)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test constructs from production lot; inter-laboratory reproducibility confirmed.",
      "rationale": "N=11 constructs tested across two independent laboratories (FDA and DePuy Synthes). Inter-laboratory coefficient of variation for stiffness is 3.2%, confirming reproducibility. Production-lot specimens used."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple load levels and load rates tested to characterize model behavior across the COU envelope.",
      "rationale": "Testing performed at a single load rate (5 mm/min) per ASTM F1717. Only one test condition evaluated. This factor is below the required level; the shortfall is acknowledged and accepted given the deterministic nature of the quasi-static COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs (geometry, material, boundary conditions) demonstrably equivalent to test specimen conditions; any deviations quantified.",
      "rationale": "CMM-measured geometry fed directly into CAD reconstruction. Material properties from same lot. Boundary conditions replicate ASTM F1717 fixture kinematics. Remaining deviations (fixture compliance, torque preload variability) quantified and included in validation uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and QoI difference < 10% for all three quantities of interest.",
      "rationale": "Stiffness: E/uval=0.82, difference=2.1%. Yield force: E/uval=1.14, difference=4.7%. Force at 40 mm: E/uval=1.31, difference=6.3%. All three QoIs satisfy both acceptance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) directly map to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness governs load sharing with the vertebral column; yield force predicts onset of permanent deformation; force at 40 mm displacement is the ASTM F1717 regulatory endpoint. All three QoIs are directly relevant to the COU decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 compression-bending) is the same scenario as the COU; no extrapolation required.",
      "rationale": "The validation activity is the COU scenario: ASTM F1717 static compression-bending of the identical non-cannulated 7.5 mm pedicle screw construct. No interpolation or extrapolation from a surrogate scenario is required. Highest relevance achieved."
    }
