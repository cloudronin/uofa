      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinements; Richardson extrapolation applied to estimate discretization error.",
      "rationale": "Three-level mesh refinement study performed: coarse (0.8 mm), medium (0.5 mm), fine (0.35 mm) element sizes at screw-rod interface. Stiffness QoI changed 1.3% between medium and fine meshes. GCI < 1.8%. Medium mesh adopted for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals converge below 1e-6 for all load steps; energy balance monitored throughout nonlinear solution.",
      "rationale": "Direct sparse solver (SPARSE) employed. Force residual norm < 1e-7 at all converged load steps. Energy balance error < 0.01% across 40 mm displacement ramp. No divergence events recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by second analyst; simulation plan reviewed and approved prior to execution.",
      "rationale": "Simulation plan VVP-002 reviewed by independent senior analyst before execution. Boundary conditions, material assignments, and contact definitions verified by reviewer. No discrepancies identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics assumptions (linear elastic titanium, frictional contact at screw-rod interface) justified by operating regime; supporting literature cited.",
      "rationale": "ASTM F1717 loads remain below yield for rod and screw body in elastic regime; bilinear isotropic hardening applied at screw-rod interface region as sensitivity. Literature supports linear elastic Ti-6Al-4V for sub-yield bending. Model form uncertainty quantified at ±4%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from traceable coupon testing of production-lot titanium alloy; geometric inputs from CMM measurements of test articles.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and yield strength (880 MPa) from production-lot coupon tensile testing (n=5 coupons, CV<2%). Screw and rod geometry from CMM measurements of three test articles; nominal CAD used with measured tolerances as uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
