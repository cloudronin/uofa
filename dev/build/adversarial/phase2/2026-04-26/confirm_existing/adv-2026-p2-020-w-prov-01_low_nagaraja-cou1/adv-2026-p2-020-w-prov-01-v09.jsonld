      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant range including at least two load levels or construct configurations.",
      "rationale": "Only single ASTM F1717 test configuration (standard compression-bending) performed; no variation in offset distance or rod diameter. Achieved level 2 (single condition documented) does not meet required level 3. Accepted under overall credibility assessment with noted limitation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
