    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change < 2% between successive refinements.",
      "rationale": "A three-level mesh convergence study was performed on the screw-rod interface region. QoI change between medium and fine meshes was 0.8% for stiffness and 1.4% for yield force. Richardson extrapolation confirms discretization error < 2%. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria and iterative solver tolerances must be documented and demonstrated adequate.",
      "rationale": "Force and displacement residuals converged to 1e-5 relative tolerance. Energy balance monitored each increment; maximum energy error 0.03%. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup reviewed by an independent analyst; boundary conditions and loading consistent with ASTM F1717 protocol.",
      "rationale": "An independent analyst reviewed the FEA setup against the ASTM F1717-15 protocol. Boundary conditions (superior block fixed, inferior block displacement-controlled at 1 mm/min equivalent) confirmed correct. No use errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection justified and sensitivity to model form alternatives documented.",
      "rationale": "Bilinear isotropic hardening adopted for Ti-6Al-4V screw and rod. Sensitivity analysis comparing linear elastic, bilinear, and Ramberg-Osgood forms showed < 5% difference in yield force. Bilinear model selected as best balance of accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs derived from measured data with uncertainty quantification.",
      "rationale": "Young's modulus (114 GPa), yield strength (880 MPa), and UTS (950 MPa) sourced from coupon testing of the same Ti-6Al-4V lot. Geometric dimensions measured via CMM on five representative screws; nominal CAD used with ±0.05 mm tolerance band in sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of the production device; sample size and variability documented.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested, drawn from production lots. Dimensional inspection confirmed all within drawing tolerances. Coefficient of variation for stiffness across samples was 4.2%, consistent with expected manufacturing variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of COU loading scenarios or sensitivity to condition variation must be bounded.",
      "rationale": "Testing performed at a single load angle (compression-bending per ASTM F1717). The COU encompasses only this standard test configuration, so the single condition is representative; however, no multi-angle or fatigue condition was evaluated, limiting achieved level to 2. This gap is accepted given model influence is Medium."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be traceable to the same source data used to characterise test samples.",
      "rationale": "Material properties input to FEA were measured from the same production lot as the test samples. Geometric inputs derived from CMM measurements of tested constructs. Full traceability documented in the test report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI differences between FEA and experiment must be < 10% and E/uval < 1.96 for all primary QoIs.",
      "rationale": "Stiffness: FEA 312 N/mm vs. experiment 308 ± 13 N/mm (1.3% difference, E/uval = 0.31). Yield force: FEA 1,840 N vs. experiment 1,798 ± 62 N (2.3% difference, E/uval = 0.68). Force at 40 mm: FEA 2,210 N vs. experiment 2,175 ± 88 N (1.6% difference, E/uval = 0.40). All acceptance criteria met."
    },
    {
      "type": "CredibilityFactor",
