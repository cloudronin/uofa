    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility levels. One factor (Test conditions) achieved level 2 against a required level of 3 due to single loading configuration; this gap is accepted given the static-only scope of the COU and the strong agreement across all three QoIs (maximum E/uval = 0.54, well below the 1.96 threshold). The overall evidence package is sufficient to support regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
