  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2022 R2) is validated under an FDA-recognized quality management system; version control and regression test records are archived.",
      "rationale": "Ansys Mechanical 2022 R2 is used under a documented QMS compliant with 21 CFR Part 820. Regression test suite covers all element types used in this model. Version control records confirm no uncontrolled code changes during the study period."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 standard suite reproduced within 1% for linear elastic beam bending and contact problems.",
      "rationale": "Ansys Mechanical passes ASME V&V 10 benchmark suite for linear static structural problems. Internal verification reports document agreement within 0.3% for beam bending and within 0.8% for Hertzian contact benchmarks."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in QoIs (stiffness, yield force, force at 40 mm) between the production mesh and a 1.5x refined mesh.",
      "rationale": "A three-level mesh refinement study was conducted on the non-cannulated 7.5 mm screw construct. QoI change between medium and fine mesh was 0.9% for stiffness, 1.4% for yield force, and 1.1% for force at 40 mm displacement. Production mesh selected at medium refinement level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms for all load steps fall below 1e-4 relative tolerance; energy balance confirmed within 0.1%.",
      "rationale": "Nonlinear solver residuals converged to below 1e-5 for all 25 load increments. Energy balance error was 0.04%. No solver warnings or non-convergence events were recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup reviewed by independent analyst; boundary conditions, material assignments, and contact definitions confirmed against simulation plan.",
      "rationale": "An independent FEA analyst (DePuy Synthes modeling team) performed a line-by-line review of the simulation setup against the pre-approved simulation plan. No discrepancies were identified. Boundary condition application and contact pair definitions were confirmed correct."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic material model justified by operating strain range; contact formulation validated against published F1717 simulation literature.",
      "rationale": "Titanium alloy (Ti-6Al-4V) behavior is linear elastic below yield under ASTM F1717 loading rates. Maximum principal strains in the model remain below 0.5% at yield force, confirming linear elastic assumption is appropriate. Augmented Lagrangian contact formulation is consistent with published FDA F1717 FEA guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM B265 certified mill certificates for the test lot; geometric dimensions measured via CMM with traceability to NIST standards.",
      "rationale": "Elastic modulus (114 GPa) and Poisson's ratio (0.34) sourced from ASTM B265 certified mill certificates for the Ti-6Al-4V bar stock used to manufacture the test constructs. Screw geometry digitized via coordinate measuring machine (CMM) with NIST-traceable calibration. Polyaxial head friction coefficient (0.2) taken from published tribology data for titanium-on-titanium interfaces."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs assembled from production-representative components; dimensional inspection confirms conformance to design drawings.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production-representative components. Dimensional inspection of all screws and rods confirmed conformance to design drawings within ±0.05 mm. Components sourced from the same manufacturing lot to minimize inter-specimen variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate ASTM F1717 protocol across at least two loading configurations.",
      "rationale": "Testing performed under a single ASTM F1717 static compression-bending configuration only. Dynamic and torsional loading configurations were not evaluated in this study. Achieved level is below required level; this gap is acknowledged and accepted given the static-only COU scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters (geometry, material, boundary conditions) demonstrably matched to measured test specimen parameters within stated uncertainty.",
      "rationale": "Model geometry updated to reflect CMM-measured specimen dimensions. Material properties assigned from certified mill certificate values for the test lot. Boundary conditions replicate the ASTM F1717 fixture geometry as measured in the laboratory. Equivalency confirmed via parameter mapping table in the simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All three QoIs (stiffness, yield force, force at 40 mm) meet acceptance criteria: <10% difference and E/uval < 1.96.",
      "rationale": "Stiffness: FEA 487 N/mm vs. experimental mean 492 N/mm (1.0% difference, E/uval = 0.31). Yield force: FEA 1842 N vs. experimental mean 1876 N (1.8% difference, E/uval = 0.54). Force at 40 mm: FEA 2103 N vs. experimental mean 2087 N (0.8% difference, E/uval = 0.22). All three QoIs satisfy pre-established acceptance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to clinical failure modes and regulatory acceptance criteria for pedicle screw constructs.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and referenced in FDA guidance for pedicle screw system 510(k) submissions. These QoIs are directly relevant to the clinical risk of construct failure leading to revision surgery."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the same screw design, rod diameter, and loading configuration as the intended COU.",
      "rationale": "Validation constructs use the identical non-cannulated 7.5 mm pedicle screw design and 5.5 mm titanium rod as the intended COU. ASTM F1717 static compression-bending loading replicates the biomechanical scenario of interest. Two independent laboratories provide geographic and equipment independence, strengthening the validation evidence base."
    }
