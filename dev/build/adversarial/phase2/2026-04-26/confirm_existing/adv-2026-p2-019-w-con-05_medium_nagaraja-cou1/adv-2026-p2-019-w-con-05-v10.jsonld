  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted on the basis that the tested condition is the standard ASTM F1717 regulatory condition and the deviation is documented. All three primary QoIs satisfy both the < 10% difference and E/uval < 1.96 acceptance criteria. Overall credibility is sufficient to support the regulatory claim that the FEA framework reliably predicts compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct.",
