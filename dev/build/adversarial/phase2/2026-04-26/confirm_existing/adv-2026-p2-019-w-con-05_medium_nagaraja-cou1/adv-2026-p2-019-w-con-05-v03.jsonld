  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment demonstrates that the FEA model ensemble achieves Medium assurance level for prediction of ASTM F1717 compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct. All three primary QoIs satisfy the E/uval < 1.96 acceptance criterion, with percentage differences below 3%. Twelve of thirteen V&V 40 credibility factors meet or exceed the required level; the single gap in Test conditions (achieved level 2 vs. required level 3) is accepted given that the single test condition represents the conservative bound for the COU. The mesh convergence study and numerical verification activities provide confidence in discretization and solver accuracy. The overall evidence base is sufficient to support the regulatory submission decision.",
    "decidedAt": "2024-11-15T00:00:00Z"
  },
