  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for FEA (Ansys Mechanical 2023 R1) must have documented verification tests, version control, and a quality management record compliant with FDA 21 CFR Part 820.",
      "rationale": "Ansys Mechanical 2023 R1 is a commercially validated FEA solver with documented software verification tests supplied by the vendor. The modeling team maintains a configuration-controlled analysis environment under an ISO 13485-aligned QMS. Version records and change logs were reviewed; no anomalies identified. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmark problems (patch test, beam bending, contact patch) must be reproduced within 1% of analytical solutions.",
      "rationale": "Standard benchmark problems including Hertzian contact, cantilever beam bending, and patch tests were executed. All results agreed with analytical solutions within 0.6%. Solver documentation confirms code verification for structural contact mechanics. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for all primary QoIs at the production mesh density, assessed via Richardson extrapolation across at least three mesh refinement levels.",
      "rationale": "A mesh convergence study was performed across four mesh densities. Richardson extrapolation yielded GCI values of 2.1% for construct stiffness and 3.4% for yield force at the fine production mesh. Monotonic convergence was confirmed. The mesh convergence study (activity IRI: https://uofa.net/synth/activity/mesh-convergence-study-noncannulated) is described in detail in the FEA verification report and its outputs are discussed throughout the model credibility summary; the GCI values inform the uncertainty budget used in the output comparison factor. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force and displacement residuals must converge below 1e-5 for all load steps; energy balance must be confirmed.",
      "rationale": "All nonlinear load steps converged with force residuals below 5e-6 and displacement residuals below 2e-6. Energy balance checks confirmed no artificial energy dissipation. Solver log files were archived. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "An independent reviewer must verify model setup, boundary conditions, and material assignments against the documented modeling protocol.",
      "rationale": "An independent FEA engineer reviewed the model setup, boundary conditions, contact definitions, and material property assignments against the pre-approved modeling protocol. No discrepancies were found. Peer-review sign-off was recorded in the project quality record. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model and contact formulation must be justified by literature or preliminary sensitivity studies demonstrating that model form choices do not introduce systematic bias exceeding 5% in primary QoIs.",
      "rationale": "A bilinear isotropic hardening plasticity model was adopted for titanium alloy components, consistent with published FDA and industry practice for pedicle screw FEA. Augmented Lagrange contact with a friction coefficient of 0.2 was validated against published tribology data. Sensitivity runs varying friction ±50% showed less than 3% change in yield force, confirming robustness. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be sourced from traceable measurements or certified supplier data; uncertainty in inputs must be propagated to QoI uncertainty estimates.",
      "rationale": "Ti-6Al-4V material properties were obtained from certified material test reports for the production screw lot. UHMWPE block properties were measured from the test lot used in bench testing. Geometric dimensions were verified against CMM inspection reports. Input uncertainty was propagated via a one-at-a-time sensitivity study; combined input uncertainty contributed ±3.1% to the QoI uncertainty budget. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative production parts with documented lot traceability; N≥10 samples required for statistical comparison.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production-representative components with full lot traceability. Constructs were distributed across two independent laboratories to assess inter-laboratory variability. Sample dimensions were confirmed by CMM inspection to be within drawing tolerances. N=11 satisfies the minimum sample size requirement. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios; at least two distinct load configurations required.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending configuration at a fixed offset distance. While this configuration is the regulatory standard, it does not span the full range of in vivo loading scenarios (e.g., torsion, lateral bending). Achieved level (2) is below the required level (3) for this factor; this gap is acknowledged in the decision record and accepted given that ASTM F1717 is the accepted regulatory benchmark and supplementary torsion data are available in the literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters (geometry, material properties, boundary conditions) must be demonstrably equivalent to the physical test configuration within documented tolerances.",
      "rationale": "Model geometry was updated to match CMM-measured dimensions of the test constructs. Material properties were set to certified values from the test lot. Boundary conditions replicate the ASTM F1717 fixture geometry including pin diameter and offset distance. Equivalency was confirmed by a parameter-by-parameter comparison table in the validation report. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation metric E/uval must be below 1.96 for all primary QoIs; percentage difference must be below 10% for each individual prediction.",
      "rationale": "E/uval values of 0.91, 1.34, and 1.08 were obtained for construct stiffness, yield force, and force at 40 mm displacement respectively — all below the 1.96 threshold. Maximum individual percentage difference across all 11 constructs was 8.3%, within the 10% acceptance bound. The uncertainty budget incorporated measurement uncertainty, inter-laboratory variability, input parameter uncertainty, and GCI-derived discretization uncertainty. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs predicted by the model must be directly linked to the clinical risk hypothesis and the regulatory submission claims.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly relate to the structural integrity risk hypothesis for pedicle screw implants. These QoIs are explicitly cited in the 510(k) predicate comparison and the device risk analysis. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must directly address the COU geometry, loading regime, and material system; no surrogate geometry or loading proxy permitted at this risk level.",
      "rationale": "Validation was performed on the exact non-cannulated 7.5 mm pedicle screw geometry under the ASTM F1717 compression-bending protocol that constitutes the COU. No surrogate geometry or scaled model was used. The two-laboratory design increases confidence in the generalisability of the validation finding. Achieved level equals required level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors achieved the required credibility level. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — is accepted because ASTM F1717 compression-bending is the regulatory standard configuration and the risk consequence of this gap is bounded by the conservative nature of the F1717 protocol. Validation metrics (E/uval) passed for all three QoIs. The mesh convergence study documented in the FEA verification report confirms that discretization error is adequately controlled. The overall credibility evidence is sufficient to support the Medium model risk level and Medium decision consequence classification. The submission package is accepted for regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
