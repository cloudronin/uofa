  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy-synthes",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors achieved the required credibility level. One factor (Test conditions) achieved level 2 against a required level of 3 due to testing at a single ASTM F1717 offset distance; this shortfall is accepted on the basis of analytical sensitivity analysis demonstrating that stiffness and yield force predictions vary by less than 4% across the clinically relevant offset range (40–60 mm). The overall credibility evidence package is sufficient to support a Medium assurance level decision for the non-cannulated 7.5 mm pedicle screw compression-bending FEA model. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
