  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed their required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted because ASTM F1717 defines the sole regulatory test configuration for this device class and multi-condition testing is not required for 510(k) submission. All three QoIs satisfy both the percentage-difference bound (<10%) and the validation metric bound (E/uval < 1.96). The credibility package is therefore sufficient to support the intended regulatory decision.",
