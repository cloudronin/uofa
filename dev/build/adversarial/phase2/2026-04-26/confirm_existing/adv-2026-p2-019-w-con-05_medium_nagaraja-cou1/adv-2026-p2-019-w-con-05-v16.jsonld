  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieves level 2 against a required level 3; this gap is accepted based on the conservatism of the ASTM F1717 standard configuration and the strong performance on all three QoIs (E/uval < 1.96, percent difference < 10%). The overall credibility package is sufficient to support the regulatory submission claim that the FEA framework accurately predicts compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct.",
