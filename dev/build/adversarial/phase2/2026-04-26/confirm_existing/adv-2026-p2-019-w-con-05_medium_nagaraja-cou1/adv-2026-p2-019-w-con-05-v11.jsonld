  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed the required gradation level. One factor (Test conditions) achieves gradation 2 against a required level of 3, reflecting the single ASTM F1717 test configuration; this gap is accepted given the regulatory mandate and the conservative nature of the compression-bending configuration. All three QoIs pass quantitative acceptance criteria (percentage difference <10%; E/uval <1.96). The FEA modeling framework is assessed as credible for the stated COU.",
