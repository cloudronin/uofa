    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear elastic-plastic material model with isotropic hardening; frictional contact at screw-rod interface; large-deformation kinematics enabled.",
      "rationale": "The model employs nonlinear elastic-plastic constitutive behavior with isotropic hardening for Ti-6Al-4V, frictional Coulomb contact (mu=0.3) at the screw-rod interface, and large-deformation kinematics. These physics choices are appropriate for the ASTM F1717 loading regime and consistent with published literature on pedicle screw FEA."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific tensile coupon tests; geometry from calibrated CMM measurements; friction coefficient from dedicated pin-on-disk tribology tests.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and yield strength (880 MPa) were derived from lot-specific tensile coupon testing (n=5 coupons per lot). Screw geometry was characterized by calibrated CMM with 2 micron accuracy. Friction coefficient (0.30 ± 0.04) was measured via dedicated pin-on-disk tribology testing on representative surface finishes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N >= 10 constructs from production-representative lots; samples span at least two independent lots.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested. Screws were sourced from two independent production lots (n=6 and n=5). UHMWPE blocks were from a single certified material batch conforming to ASTM F1717 requirements. Sample size exceeds minimum N=10 criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two independent laboratories and two clinically relevant loading configurations.",
      "rationale": "Testing was conducted across two independent laboratories (FDA CDRH and DePuy Synthes test facility), satisfying the multi-laboratory criterion. However, only a single loading configuration (static compression-bending at standard ASTM F1717 geometry) was evaluated. The absence of a second clinically relevant loading configuration (e.g., torsion or fatigue) results in an achieved level of 2, below the required level of 3. This gap is accepted as a documented limitation given the scope of the current COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters traceable to physical measurements from the test specimens; no surrogate material properties used.",
      "rationale": "FEA input parameters were matched to the physical test specimens on a per-construct basis. Screw dimensions were taken from CMM measurements of each tested specimen. Material properties were assigned from lot-specific coupon data corresponding to each production lot. No surrogate or handbook values were substituted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all primary QoIs; mean QoI difference < 10%.",
      "rationale": "Three primary QoIs were compared: construct stiffness, yield force, and force at 40 mm displacement. E/uval values were 0.92, 1.41, and 1.18 respectively, all below 1.96. Mean differences were 4.2%, 6.8%, and 5.1% respectively, all below 10%. Quantitative acceptance criteria are satisfied for all QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to regulatory submission metrics and are mechanistically linked to clinical failure modes.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the standard ASTM F1717 reporting metrics used in FDA 510(k) submissions for pedicle screw systems. These QoIs are mechanistically linked to the primary clinical failure mode (fatigue fracture at the screw-rod junction) and are directly relevant to the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
