  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for the non-cannulated 7.5 mm pedicle screw construct has achieved the required credibility level for 12 of 13 V&V 40 factors. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is accepted as a documented limitation given the static compression-bending scope of the COU and the strong agreement observed across all three primary QoIs (maximum E/uval 1.41, maximum mean error 6.8%). The overall evidence package supports the conclusion that the FEA model is sufficiently credible for its intended use in the regulatory submission context. Note: the mesh convergence study activity (nagaraja-mesh-convergence-study) is referenced in the discretization error factor rationale and output comparison narrative; formal evidence artifacts from that activity are to be incorporated in a subsequent package revision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
