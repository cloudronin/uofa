  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework demonstrates sufficient credibility for the declared COU. All three primary QoIs satisfy quantitative acceptance criteria (E/uval < 1.96, percentage difference < 10%). Twelve of thirteen V&V 40 credibility factors achieve their required levels. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted given the explicit COU scope restriction to the ASTM F1717 single-condition test protocol and the medium model influence classification, which limits the consequence of this gap. The mesh convergence study was conducted rigorously and its outcomes informed the discretization error factor assessment; the study is well-documented in the model development record. Overall credibility is assessed as sufficient for a Medium assurance level regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
