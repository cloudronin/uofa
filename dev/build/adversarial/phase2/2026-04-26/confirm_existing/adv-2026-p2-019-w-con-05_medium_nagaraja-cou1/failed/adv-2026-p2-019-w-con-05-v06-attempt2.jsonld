  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is accepted because the ASTM F1717 standard prescribes a single canonical test condition, and the regulatory submission context does not require multi-condition bounding for this device class and decision consequence level. All three primary QoIs fall within pre-established acceptance bounds (percent difference < 10%, E/uval < 1.96). The mesh convergence study confirms discretization error is well controlled. Overall credibility is sufficient to support the Accepted decision.",
