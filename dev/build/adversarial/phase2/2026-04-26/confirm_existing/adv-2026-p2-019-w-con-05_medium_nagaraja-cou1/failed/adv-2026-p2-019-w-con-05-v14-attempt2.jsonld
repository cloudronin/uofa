  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is mitigated by the direct applicability of the ASTM F1717 single-condition protocol to the COU and by the strong quantitative agreement observed across all three QoIs (all percent differences below 2.1%, all E/uval below 0.75). The mesh convergence verification activity provides a well-documented discretization error budget. Overall credibility is sufficient to support the Accepted decision for this medium model risk, medium consequence COU.",
