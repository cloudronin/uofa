    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by second analyst; checklist-based verification of boundary conditions and material assignments.",
      "rationale": "A second analyst independently reviewed all boundary condition assignments, material property inputs, and contact definitions against the modeling protocol. No discrepancies were identified. Checklist review completed and archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum finite element model with nonlinear geometry and frictional contact captures dominant physics of compression-bending; model form justified against literature.",
      "rationale": "The FEA model employs continuum solid elements with nonlinear geometry (large displacement) and frictional contact at screw-rod and rod-connector interfaces. This model form is consistent with published literature on spinal implant FEA and captures the dominant load-transfer mechanisms identified in the ASTM F1717 test configuration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing of production-lot Ti-6Al-4V; geometric dimensions from CMM measurements of test articles.",
      "rationale": "Titanium alloy (Ti-6Al-4V) elastic modulus, yield strength, and tangent modulus were characterized from coupon tensile testing of the same production lot used for bench test specimens. Geometric dimensions were verified by coordinate measuring machine (CMM) measurements on three representative constructs, confirming nominal dimensions within ±0.05 mm."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production-representative hardware; two independent laboratories.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested, assembled from production-representative hardware. Testing was conducted at two independent laboratories (FDA/CDRH and an external contract laboratory) to assess inter-laboratory variability. Sample size exceeds the minimum threshold for statistical comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two rod diameters or two screw angulation configurations to assess sensitivity.",
      "rationale": "Testing was conducted under a single ASTM F1717 configuration (5.5 mm rod, 0° angulation). While this configuration is clinically representative, only one test condition was evaluated, limiting the ability to assess model sensitivity to configuration variation. Achieved level 2 is below the required level 3; this gap is acknowledged and accepted given the scope of the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and material inputs demonstrably matched to test article measurements and test machine setup.",
      "rationale": "FEA boundary conditions replicate the ASTM F1717 test fixture geometry and loading application point as measured on the physical test setup. Material properties, torque preloads, and geometric dimensions in the FEA model were set to values measured from the actual test articles, ensuring equivalency between simulation inputs and experimental conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric with threshold 1.96; percent difference < 10% for all primary QoIs.",
      "rationale": "All three primary QoIs (stiffness, yield force, force at 40 mm) were compared using the E/uval metric incorporating experimental uncertainty. E/uval values of 0.91, 1.44, and 1.07 are all below the 1.96 threshold. Percent differences of 4.2%, 6.8%, and 5.1% are all below the 10% acceptance criterion. Quantitative acceptance criteria are met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to regulatory submission metrics and clinical failure modes for pedicle screw constructs.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the standard QoIs specified in ASTM F1717 and are directly used in 510(k) substantial equivalence comparisons. These QoIs are mechanistically linked to the clinical failure mode of screw fatigue fracture under cyclic bending loads."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on the same screw design, material, and test configuration as the COU; no extrapolation beyond validated domain.",
      "rationale": "The validation activities were performed on the identical non-cannulated 7.5 mm pedicle screw design, material (Ti-6Al-4V), and ASTM F1717 test configuration as specified in the COU. No extrapolation beyond the validated parameter space is required for the intended regulatory submission. Validation domain fully encompasses the COU."
    }
