  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieves level 2 against a required level 3, reflecting the single-configuration test design; this shortfall is accepted given the narrow COU scope and the strong quantitative agreement across all three primary QoIs (E/uval < 1.96, percent difference < 10% for all QoIs). The mesh convergence study confirms discretization error control below 2% GCI. Overall credibility is sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
