  "hash": "sha256:a3f7c2e1d09b4856fe230174ac98d3b761e05492fd8c1a3e6b27d904c58f1e2a",
  "signature": "ed25519:b14d9e3a72f0c856d1a4e298f3c07b5d6e1a2f8c4b0d7e3a9f2c6b1d5e8a0f4c",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The solver must be under formal version control, possess a documented test suite covering hemolysis-relevant flow regimes, and have a traceable release history with issue resolution logs accessible to the regulatory submission team.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is deployed under ISO 9001-certified quality management. A full software validation plan covering hemolysis-relevant turbulence and viscous-flow unit tests is on file. Version control via Git with tagged releases and a documented change-control procedure satisfies MRL 5 requirements at Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests using manufactured solutions must demonstrate convergence rates within 10% of theoretical for all governing equation sets active in the hemolysis simulation.",
      "rationale": "Method of manufactured solutions tests were performed for the Navier-Stokes and scalar transport equations. Observed convergence order was 1.87 (theoretical 2.0), a 6.5% shortfall. This gap is acknowledged; the achieved level is Gradation 3 against a required Gradation 4, and the deviation is documented in the uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; reported GCI for the hemolysis index QoI must not exceed 5% at the fine-grid level.",
      "rationale": "Three mesh levels (4.2 M, 11.7 M, 28.9 M cells) were run at the worst-case operating point (6 L/min, 3500 RPM). Richardson extrapolation yielded GCI_fine = 3.1% for the hemolysis index, satisfying the 5% threshold. Asymptotic range check confirmed p_obs = 1.94."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty bands on all boundary condition inputs; operating points must span the full VAD clinical envelope (3–6 L/min, 2500–3500 RPM).",
      "rationale": "FDA generic pump experiments covered 4 of 5 target operating points. The fifth point (3 L/min, 3500 RPM) was extrapolated. Boundary condition uncertainties (inlet flow ±2%, rotational speed ±15 RPM) are documented. The partial coverage reduces the achieved level to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., normalised RMS error or validation uncertainty U_val) must be computed for the hemolysis index at each operating point; U_val must be less than 15% of the experimental mean.",
      "rationale": "Normalised RMS error across 4 validated operating points was 11.3%. Validation uncertainty U_val = 13.8% of experimental mean, just within threshold at those points. The unvalidated fifth point prevents achievement of Gradation 5, which requires full-envelope coverage with U_val < 10%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalised index of hemolysis, NIH) must map directly to the clinical endpoint; a traceability matrix linking NIH to patient haemoglobin release thresholds must be included in the submission package.",
      "rationale": "NIH is the direct regulatory QoI per FDA guidance on blood-contacting devices. The traceability matrix cross-references NIH to the ISO 10993-4 haemolysis threshold and the clinical haemoglobin release limit of 0.1 g/dL/100 L. The mapping is complete and unambiguous."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "rationale": "The validation activities were conducted on the FDA generic centrifugal pump geometry, which is the reference geometry for this COU. Blood analogue fluid (glycerol-water, matched viscosity) was used in lieu of porcine blood for the majority of experiments, introducing a physiological relevance gap. The power-law hemolysis damage model was calibrated on porcine blood data from Heuser & Opitz (1980), and its applicability to human blood at VAD shear-stress magnitudes (10–500 Pa) has been demonstrated in three independent studies (Zhang et al. 2011; Goubergrits & Affeld 2004; Giersiepen et al. 1990). The validation hierarchy spans component-level (impeller channel) through system-level (full pump loop) experiments, covering the spatial scales relevant to hemolysis prediction. Operating conditions in the validation suite overlap the COU envelope for 4 of 5 target points, with the fifth point lying within the interpolation range of the surrogate uncertainty model. Temporal resolution of the experimental hemolysis measurements (steady-state NIH after 30-minute recirculation) matches the simulation's time-averaged output convention. The overall relevance of validation activities to the COU is assessed as Gradation 4: the activities are highly relevant and cover the dominant physics, but the blood-analogue substitution and single missing operating point prevent a Gradation 5 assignment. This determination follows the ASME V&V 40 Table 4 relevance rubric and is consistent with the MRL 5 expectation that validation be conducted under conditions closely matching intended use. No structured acceptance-criteria document was produced for this factor at the time of assessment; the level determination is based on the evaluator team's application of Table 4 criteria as described herein and cross-referenced in the project credibility plan revision 3, section 6.4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated via residual reduction of at least 4 orders of magnitude for all transport equations; mass imbalance must be below 0.01% of inlet mass flow.",
      "rationale": "All simulations achieved 5-order residual reduction. Mass imbalance was 0.003% of inlet mass flow at worst-case point. Solver error is assessed as adequately controlled for MRL 5 at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation execution checklist, reviewed by a second qualified engineer, must accompany each production run; deviations from the checklist must be logged and assessed for impact on results.",
      "rationale": "A 47-item simulation execution checklist was developed and applied to all production runs. Independent review was performed by a senior CFD engineer not involved in model setup. Two minor deviations (turbulence intensity inlet specification) were logged and assessed as having negligible impact (<0.5% on NIH)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis damage model form (power-law or equivalent) must be justified against at least two independent experimental calibration datasets; model-form uncertainty must be quantified and included in the total uncertainty budget.",
      "rationale": "The Giersiepen-Wurzinger power-law model was selected. Calibration data from Heuser & Opitz and Giersiepen et al. were used. Model-form uncertainty was estimated at ±22% of predicted NIH via comparison of three alternative damage model formulations. This uncertainty magnitude, while quantified, exceeds the Gradation 4 threshold, yielding an achieved level of Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (fluid properties, boundary conditions, damage model coefficients) must have documented sources with associated uncertainty ranges; Monte Carlo propagation must use these ranges as distribution bounds.",
      "rationale": "Thirteen model input parameters were identified. Sources and uncertainty distributions (normal or uniform as appropriate) are documented in the uncertainty register. Monte Carlo propagation (n=10,000 samples, Latin hypercube sampling) was performed. The 95th-percentile NIH prediction remains below the clinical threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterised for haematocrit, viscosity, and osmolality; inter-sample variability must be reported and incorporated into experimental uncertainty estimates.",
      "rationale": "Blood analogue samples were characterised at each test session. Haematocrit equivalent (glycerol fraction) was 40±1%. Viscosity measured at 37°C: 3.5±0.2 mPa·s. Inter-session variability in NIH measurements was ±8%, incorporated into U_val. Gradation 3 is appropriate given analogue-fluid substitution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A parameter equivalency matrix must demonstrate that simulation input parameters match experimental conditions within stated tolerances for all validated operating points; mismatches must be quantified and propagated through the uncertainty budget.",
      "rationale": "A parameter equivalency matrix was produced for 4 validated operating points. Rotational speed matched within 0.4% (target ±0.5%). Inlet flow matched within 1.8% (target ±2%). Fluid viscosity equivalency was demonstrated via Reynolds number matching (Re_sim/Re_exp = 0.97–1.02). The fifth operating point lacks experimental equivalency verification, limiting the achieved level to Gradation 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The 13-factor credibility assessment for COU2 (VAD hemolysis prediction at MRL 5) demonstrates that 10 of 13 factors achieve their required level. The three factors with shortfalls (Numerical code verification, Test conditions, Model form) have documented gaps with quantified uncertainty impacts that remain within the total uncertainty budget. Monte Carlo UQ confirms the 95th-percentile NIH prediction is 18% below the clinical threshold, providing adequate margin. The assessment panel accepts the submission with the condition that the blood-analogue validation gap for the fifth operating point be addressed in the next design iteration.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
