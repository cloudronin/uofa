  "hash": "sha256:a3f2c1d4e5b6789012345678abcdef9012345678abcdef9012345678abcdef90",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures must conform to ISO 9001 or equivalent; version control, regression testing, and change management documented with traceability to solver release notes. Required at Gradation 4 given MRL 5 and Class III device classification.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is maintained under a documented quality management system with ISO 9001 certification. Version control is enforced via Git with tagged solver builds; regression test suite covers 47 canonical benchmark cases. However, the project-level SQA plan does not include formal change-impact analysis linking solver patch versions to hemolysis model outputs, which is required at Gradation 4. Achieved level is 3: standard commercial SQA with documented regression testing but without hemolysis-specific impact traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include method-of-manufactured-solutions (MMS) or equivalent formal verification for all transport equations active in the hemolysis simulation, with observed order of accuracy documented and within 10% of theoretical order.",
      "rationale": "MMS verification was performed for the momentum and continuity equations, demonstrating second-order spatial convergence consistent with the finite-volume discretization. The power-law hemolysis transport scalar equation was verified using a simplified 1D manufactured solution with an analytical source term. Observed order of accuracy was 1.87 vs. theoretical 2.0 (6.5% deviation), within the 10% threshold. However, the turbulence model (SST k-ω) was not independently verified via MMS; only benchmark comparisons were used. This gap reduces the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate GCI < 5% for the primary QoI (hemolysis index) on at least three systematically refined meshes, with Richardson extrapolation applied and asymptotic convergence confirmed.",
      "rationale": "A three-level grid convergence study was performed with mesh sizes of 2.1M, 6.8M, and 18.4M cells. GCI for the hemolysis index at the design operating point (5 L/min, 3500 RPM) was 3.2% between fine and medium meshes, satisfying the 5% threshold. Richardson extrapolation was applied; the asymptotic convergence ratio was 0.97, confirming the solution is within the asymptotic range. All five operating points were independently assessed and all GCI values were below 5%. Achieved level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to enable computational replication, including fluid properties, boundary conditions, and operating point tolerances.",
      "rationale": "The FDA generic pump experimental dataset provides complete documentation of fluid properties (bovine blood substitute, viscosity 0.0035 Pa·s, density 1056 kg/m³), flow rates (2–8 L/min in 1.5 L/min increments), rotational speeds (2000–3500 RPM), and inlet/outlet pressure boundary conditions. Operating point tolerances are ±0.05 L/min for flow rate and ±10 RPM for rotational speed. All five COU operating points fall within the documented experimental envelope. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metrics (e.g., NRMSE, validation uncertainty U_val) must be computed for the primary QoI using ASME V&V 20 methodology, with validation uncertainty bounds explicitly compared against the model application uncertainty.",
      "rationale": "Predicted hemolysis index values were compared against experimental measurements at all five operating points. NRMSE was 18.4% across the operating envelope. Validation uncertainty was computed following ASME V&V 20, yielding U_val = ±22% at 95% confidence. However, the comparison between U_val and the model application uncertainty was not formally documented as a structured validation metric table — only narrative discussion is present. This prevents achievement of Gradation 4, which requires explicit quantitative comparison of model error against application requirements. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly traceable to the clinical decision criterion (absolute hemolysis index threshold), with documented mapping between computational outputs and clinical endpoints.",
      "rationale": "The primary QoI — the normalized index of hemolysis (NIH) — is directly used as the clinical acceptance criterion for VAD hemolysis. The mapping from CFD-predicted scalar transport (power-law hemolysis model, Giersiepen et al.) to NIH is documented with unit analysis and integration methodology. The clinical threshold (NIH < 0.005 g/100 L) is explicitly referenced in the model application requirements document. QoI relevance is fully established. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed at conditions that span the COU operating envelope, with documented similarity metrics for geometry, flow regime, and hemolysis model applicability range.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is geometrically similar to the subject VAD but not identical. The COU operating envelope (3000–3500 RPM, 4–6 L/min) is partially covered by the validation dataset; however, the 3500 RPM / 6 L/min corner point falls at the boundary of the experimental dataset rather than within its interior. A formal similarity assessment using non-dimensional flow coefficient and specific speed was performed, confirming hydraulic similarity within 8%. The hemolysis model applicability range (shear stress 1–400 Pa, exposure time 0.001–1 s) was verified to encompass 97% of fluid particle trajectories. Achieved level 3 due to boundary-point extrapolation concern."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Numerical solver error encompasses iterative convergence error, round-off error, and solver-specific algorithmic errors distinct from discretization error. Iterative convergence was monitored via residual norms (all below 1×10⁻⁶ for continuity and momentum) and via QoI stabilization (NIH variation below 0.1% over the final 500 iterations). Round-off error was assessed to be negligible at double-precision arithmetic. However, the pressure-velocity coupling scheme (SIMPLEC with skewness correction) has not been formally characterized for error contribution in rotating-frame simulations with the specific impeller geometry used here. No independent solver comparison (e.g., OpenFOAM cross-check) was performed to bound algorithm-specific error. The absence of a cross-solver verification study, which is expected at Gradation 4 for MRL 5 assessments involving Class III devices where the solver is the primary predictive tool, limits the achieved level to 2. The team acknowledges this gap as a known epistemic limitation of the current assessment cycle; plans for a parallel OpenFOAM simulation are documented in the project risk register but were not completed prior to submission. The required level of 4 reflects the expectation that at MRL 5, all significant sources of numerical error — including those attributable to solver-specific algorithmic choices — must be bounded by independent evidence, not merely by internal convergence monitoring. This factor represents the most significant numerical credibility gap in the current assessment.",
      "acceptanceCriteria": "Cross-solver verification using at least one independent CFD code must bound algorithm-specific solver error to within 5% of the primary QoI; iterative convergence must be demonstrated via both residual norms and QoI stabilization monitoring."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "User qualification records must document training on the specific solver and hemolysis modeling workflow; an independent technical review of simulation setup must be performed and documented.",
      "rationale": "The primary analyst holds a PhD in computational fluid dynamics with 7 years of experience in cardiovascular CFD. Training records for ANSYS Fluent hemolysis simulation workflows are on file. However, an independent technical review of the simulation setup (boundary condition assignments, rotating reference frame configuration, hemolysis scalar source term implementation) was not performed by a reviewer external to the modeling team. An internal peer review was conducted but does not satisfy the Gradation 3 requirement for independent review. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty must be quantified by comparing at least two physically distinct hemolysis model formulations (e.g., Giersiepen vs. Zhang power-law coefficients) and documenting the sensitivity of NIH predictions to model form choice.",
      "rationale": "The power-law hemolysis model (Giersiepen et al. 1990) was used as the primary model form. A secondary analysis using Zhang et al. (2011) coefficients was performed, yielding NIH predictions 12–18% lower than the primary model across the operating envelope. This inter-model variability was included in the Monte Carlo uncertainty quantification as a model form uncertainty contribution. However, a fundamentally different model form (e.g., a strain-based or mechanistic red blood cell damage model) was not evaluated, which would be expected at Gradation 4. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in all model inputs (fluid properties, boundary conditions, hemolysis model coefficients) must be characterized with probability distributions and propagated through the model via Monte Carlo or equivalent method, with sensitivity indices documented.",
      "rationale": "Monte Carlo uncertainty quantification was performed with 500 samples. Input uncertainties were characterized for: blood viscosity (CV 8%, log-normal), density (CV 1%, normal), inlet flow rate (±0.05 L/min, uniform), rotational speed (±10 RPM, uniform), and hemolysis model power-law coefficients (literature range, uniform). Sobol sensitivity indices were computed; hemolysis model coefficient α was the dominant contributor (Si = 0.61). Output uncertainty on NIH was ±31% at 95% confidence. Full uncertainty budget documented. Achieved level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be documented with material characterization, sample preparation protocol, and inter-sample variability quantification.",
      "rationale": "The FDA generic pump experimental data used bovine blood substitute (HEPES-buffered saline with polyethylene glycol). Sample preparation protocol is documented in the original FDA study report. However, inter-sample variability in hemolytic susceptibility was not characterized — only a single blood substitute formulation batch was used across all experimental runs, and batch-to-batch variability was not assessed. This limits the achieved level to 2, as Gradation 3 requires documented inter-sample variability. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Computational input parameters must be demonstrably equivalent to experimental conditions, with documented mapping and quantified differences for each boundary condition and material property.",
      "rationale": "A parameter equivalency table was constructed mapping each experimental measurement to the corresponding computational boundary condition. Fluid viscosity: experimental 0.00348 ± 0.00012 Pa·s, computational 0.0035 Pa·s (difference 0.6%). Density: experimental 1054 ± 8 kg/m³, computational 1056 kg/m³ (difference 0.2%). Flow rate: experimental ±0.05 L/min tolerance, computational boundary condition set to nominal with ±0.05 L/min uncertainty band included in UQ. Rotational speed: experimental ±10 RPM, computational set to nominal. All differences are within experimental measurement uncertainty. Achieved level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The 13-factor credibility assessment for COU2 (VAD hemolysis prediction) has been reviewed. Seven factors achieved their required levels; six factors fell below required levels, with the most significant gap in numerical solver error (achieved 2, required 4) and use error (achieved 2, required 3). The assessment team determined that the Monte Carlo uncertainty quantification, which propagates all identified input uncertainties through the model, provides sufficient compensating evidence for the model input and discretization gaps. The overall credibility profile, while not fully satisfying all individual factor requirements, is judged sufficient for the Low assurance level classification given the explicit documentation of all gaps and the bounding uncertainty analysis. Decision: Accepted with documented limitations.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
