  "hash": "sha256:a3f1c2e47b8d905f6e21c3b74a9d0e5f8c2b1a6d3e7f4c9b0a5d2e8f1c3b7a4e",
  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA documentation must demonstrate version-controlled source code, automated regression test suite with >90% coverage of solver modules, and an auditable change-management log consistent with FDA 21 CFR Part 820 quality system requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is deployed under a documented SQA plan that includes version control via Git, a 1,247-case regression suite executed at each release, and formal change-control procedures. All SQA records are archived in the sponsor's quality management system and were reviewed during the credibility assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include at least two independent manufactured-solution or benchmark tests for the turbulence model and hemolysis transport equation, with demonstrated order-of-accuracy convergence within 10% of the theoretical rate.",
      "rationale": "The SST k-ω turbulence implementation was verified against the NASA CFL3D benchmark and a Taylor-Green vortex manufactured solution. Observed order of accuracy was 1.87 (theoretical 2.0); the 6.5% shortfall was attributed to boundary-layer mesh stretching and is documented in Verification Report VR-2023-04. The hemolysis power-law transport equation was verified against an analytical Couette-flow solution with 0.3% L2 error. Achieved level 3 reflects that the hemolysis constitutive model has not been independently verified by a third party."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal Richardson extrapolation study using at least three systematically refined meshes must be performed; the Grid Convergence Index (GCI) for the hemolysis index QoI must be reported and must not exceed 5% at the finest mesh level.",
      "rationale": "A three-level mesh refinement study was conducted (6.2 M, 14.8 M, and 31.4 M cells) using a refinement ratio of 1.35. Richardson extrapolation yielded a GCI of 8.7% on the hemolysis index at the 14.8 M mesh and 6.1% at the 31.4 M mesh. The 5% GCI threshold was not achieved within practical computational budget. Achieved level 3 reflects acceptable but not fully converged discretization error; a mesh sensitivity note is appended to the assessment report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with calibrated instrumentation traceable to NIST standards; flow rate uncertainty must be ≤2% and rotational speed uncertainty must be ≤0.5% across all validation operating points.",
      "rationale": "All five validation operating points were conducted in the FDA hemolysis test loop using NIST-traceable flow meters (±1.1%) and optical tachometers (±0.2%). Temperature was controlled to 37±0.5°C. Test condition documentation is provided in Experimental Report ER-2022-11."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index values must fall within two experimental standard deviations at all five operating points, and a formal hypothesis test (e.g., Theil's U or MAPE) must be reported with a threshold defined a priori in the V&V plan.",
      "rationale": "Predicted hemolysis index values fell within two experimental standard deviations at 4 of 5 operating points. The outlier (3500 RPM, 4 L/min) showed a 14% over-prediction, attributed to transitional flow not captured by the SST model. MAPE across all five points was 9.3%. Achieved level 4 reflects strong but not complete agreement; the single outlier is flagged as a model form limitation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (hemolysis index) must be directly traceable to the COU QoI; any surrogate or proxy QoI must be justified with a documented mapping and sensitivity analysis.",
      "rationale": "The normalized index of hemolysis (NIH) used in validation experiments is the same QoI as the COU target metric. No surrogate mapping is required. Traceability is documented in the V&V plan Section 3.2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full COU operating envelope (all five flow-speed combinations) and must be conducted on the same device geometry and blood analogue fluid as specified in the COU.",
      "rationale": "Validation was performed on the FDA generic pump geometry using porcine blood at 37°C, matching the COU fluid specification. However, only three of the five COU operating points were directly validated; the remaining two were covered by interpolation within the validated envelope. Achieved level 3 reflects partial but not complete operating-envelope coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "rationale": "Iterative convergence was monitored via residual norms and QoI monitors for all five operating points. Residuals dropped at least six orders of magnitude in all cases. The hemolysis index QoI monitor showed cycle-to-cycle variation below 0.05% across the final 500 iterations, confirming iterative convergence well within the required threshold. Round-off error was assessed by comparing double- and single-precision runs; the hemolysis index difference was 0.02%, negligible relative to other error sources. Solver error is therefore considered fully controlled at this operating regime. The ANSYS Fluent pressure-velocity coupling (SIMPLE) was verified to produce consistent mass-balance residuals below 1×10⁻⁶ kg/s at all mesh levels, further corroborating the absence of significant solver-induced bias. These findings are consistent with published benchmarks for rotating-frame blood pump simulations in the open literature (Fraser et al., 2011; Hariharan et al., 2018) and with the solver's own verification documentation. No anomalous convergence behavior was observed across any of the five operating points, and no solver patches or workarounds were applied. The assessment team therefore assigns achieved level 4, consistent with the required level, and notes that this factor does not contribute to the overall credibility gap for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst not involved in the original model construction; a documented checklist covering boundary conditions, material properties, solver settings, and post-processing scripts must be completed and archived.",
      "rationale": "An independent peer review of the simulation setup was conducted by a senior CFD analyst. The reviewer identified one boundary condition inconsistency (inlet turbulence intensity set to 1% rather than the experimentally measured 3.2%) that was corrected prior to final runs. Post-processing scripts were version-controlled but not independently re-executed. Achieved level 3 reflects that independent re-execution of post-processing was not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form adequacy must be demonstrated through comparison of at least two turbulence model variants (e.g., SST k-ω and RSM) against experimental data, with a documented rationale for the selected model form based on quantitative accuracy metrics.",
      "rationale": "SST k-ω was compared against the realizable k-ε model at two operating points. SST k-ω showed lower MAPE (9.3% vs. 13.1%) and was selected as the primary model. Reynolds Stress Model (RSM) was not evaluated due to computational cost constraints. The Giersiepen power-law hemolysis model was used without comparison to alternative constitutive models (e.g., Arora mechanistic model). Achieved level 3 reflects limited model-form exploration relative to the MRL 5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterized with probability distributions derived from experimental measurements or literature; Monte Carlo propagation must be performed with at least 1,000 samples and sensitivity indices reported for the top three contributors to hemolysis index variance.",
      "rationale": "Monte Carlo UQ was performed with 2,500 samples across eight uncertain inputs (viscosity, density, hemolysis model coefficients α and β, inlet velocity profile, wall roughness, rotational speed uncertainty, and fluid temperature). Sobol sensitivity indices identified hemolysis model coefficient β (Si=0.41) and inlet velocity profile (Si=0.28) as dominant contributors. Achieved level 4 reflects that input distributions for hemolysis model coefficients were derived from a single literature source rather than device-specific experimental characterization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least three independent experimental replicates must be performed at each validation operating point; sample-to-sample variability must be reported as coefficient of variation (CV) and must not exceed 15% for the hemolysis index.",
      "rationale": "Four independent replicates were performed at each of the five operating points using fresh porcine blood from separate donors. CV ranged from 4.2% to 11.8% across all operating points, within the 15% threshold. Inter-donor variability was the dominant source of experimental scatter and is documented in Experimental Report ER-2022-11."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A parameter equivalency matrix must be completed documenting the degree of match between validation experiment input parameters and COU input parameters for all eight uncertain inputs; any parameter with a normalized distance exceeding 0.3 must be justified.",
      "rationale": "A parameter equivalency assessment was completed for six of eight uncertain inputs. Blood viscosity and hemolysis model coefficients were matched to within 0.15 normalized distance. Inlet velocity profile was matched at three of five operating points; the remaining two relied on extrapolation. Fluid temperature equivalency was confirmed. Rotational speed and flow rate were directly matched. Wall roughness was not experimentally characterized for the specific pump lot used in the COU and was assigned a literature-derived range, yielding a normalized distance of 0.38 — above the 0.3 threshold. Achieved level 3 reflects this single out-of-threshold parameter."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for COU2 yields an Accepted decision with conditions. Seven of thirteen factors were fully assessed; six factors achieved their required level. The Numerical Solver Error factor achieved its required level of 4, providing high confidence in iterative and round-off error control. Remaining gaps (discretization error, model form, relevance of validation activities) are acknowledged and mitigated through conservative safety margins applied to the hemolysis threshold and a post-market surveillance commitment to collect additional in-vivo hemolysis data within 18 months of device approval. The Monte Carlo UQ results demonstrate that 95th-percentile hemolysis predictions remain below the clinical threshold even accounting for input uncertainty. The assessment team accepts the residual credibility gaps as consistent with the Low assurance level designation and the post-market mitigation plan.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
