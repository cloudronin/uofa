  "hash": "sha256:a3f1c2e4b7d09e5f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f",
  "signature": "ed25519:9b2e4f1a3c5d7e8f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan must conform to ISO 9001 with documented version control, regression test suite coverage ≥ 95%, and independent code review records for all solver modules used in hemolysis computation.",
      "rationale": "The CFD solver is maintained under a formal SQA plan compliant with ISO 9001. Version control is enforced via Git with tagged releases; all hemolysis-relevant solver modules have passed independent peer review. Regression test suite covers 97% of code paths exercised in this COU. Required level 4 reflects the Class III device context and MRL 5 designation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must demonstrate convergence rates within 10% of theoretical order for all governing equations; manufactured solution tests must be passed for Navier-Stokes and scalar transport modules.",
      "rationale": "Code verification was performed using the method of manufactured solutions for both the incompressible Navier-Stokes solver and the passive scalar hemolysis transport equation. Observed convergence orders of 1.92 (spatial) and 1.98 (temporal) are within 10% of the theoretical second-order scheme. Results are archived in the verification report VR-2024-07."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all QoIs; GCI on hemolysis index must be below 5% at the finest mesh level used in production simulations.",
      "rationale": "A three-level mesh refinement study was conducted following the Roache GCI methodology. The hemolysis index GCI at the finest production mesh (28M cells) is 7.2%, exceeding the 5% threshold. This gap is acknowledged; the achieved level of 3 reflects that convergence was demonstrated but the GCI target was not fully met. Uncertainty from discretization is propagated into the Monte Carlo ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must span the full COU operating envelope (5 flow-speed combinations); fluid properties must match within 2% of clinical blood analog specifications.",
      "rationale": "In-vitro experiments were conducted at all five target operating points using a glycerin-water blood analog with viscosity and density matched within 1.5% of target values. Temperature was controlled to ±0.5°C throughout each test run. Test condition documentation is provided in experimental report ER-2024-03."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) must be computed for hemolysis index at each operating point; systematic bias must be below 15% relative to experimental measurement uncertainty.",
      "rationale": "Hemolysis index predictions were compared against in-vitro measurements at all five operating points. Systematic bias ranges from 8% to 22% across the operating envelope, with the largest deviations at high-speed low-flow conditions where secondary flow structures are most pronounced. The validation metric M was computed per ASME V&V 20 guidance. Achieved level 3 reflects adequate but not fully satisfactory agreement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized hemolysis index NIH) must be directly mapped to the clinical endpoint; secondary QoIs (wall shear stress, exposure time) must be shown to contribute to NIH through documented model linkage.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary QoI and is directly used in the clinical acceptance decision. Secondary QoIs including volume-averaged shear stress and Lagrangian exposure time are explicitly linked to NIH through the power-law hemolysis model. This linkage is documented in model specification MS-2024-01 and validated against the Morrison et al. experimental dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (FDA generic centrifugal pump) and operating fluid; at least 4 of 5 COU operating points must be directly validated rather than interpolated.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry identical to the COU device. Four of five operating points were directly validated; the fifth (6 L/min, 3500 RPM) was assessed by interpolation due to experimental flow instability at that condition. The interpolated point introduces additional epistemic uncertainty that is captured in the MC ensemble. Achieved level 3 reflects this gap in direct coverage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "rationale": "Iterative convergence of the pressure-velocity coupling was monitored via normalized residuals, with all residuals dropping below 1×10⁻⁶ for continuity and momentum equations at each operating point before hemolysis post-processing was initiated. Round-off error was assessed to be negligible relative to discretization error at double-precision arithmetic. Solver error contributions were formally estimated using the approach of Celik et al. (2008) and found to contribute less than 0.3% to the total NIH uncertainty budget, well below the threshold associated with required level 4 at MRL 5. The assessment team reviewed iterative convergence histories for all five operating points and confirmed that no operating point exhibited stagnation or oscillatory convergence behaviour. Solver error is therefore considered fully characterized and does not constitute a credibility gap. The required level of 4 was established by the MRL 5 designation and the Class III device context, consistent with the overall credibility plan approved by the regulatory submission team in document CP-2024-02. All supporting solver error evidence is archived in the numerical evidence package NEP-2024-08, which was reviewed and signed off by the independent verification authority prior to submission. This factor is considered fully met at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be independently reviewed by a second analyst; boundary condition inputs must be traceable to experimental measurements with documented uncertainty.",
      "rationale": "All simulation setups were independently reviewed by a second CFD analyst prior to production runs. Boundary conditions (inlet flow rate, rotational speed, outlet pressure) are traceable to calibrated instrumentation with documented uncertainties. No use errors were identified during independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model must be justified against at least two independent experimental datasets; turbulence model selection must be supported by sensitivity analysis demonstrating less than 10% variation in NIH across candidate models.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected based on its extensive use in the literature and calibration against two independent RBC lysis datasets. Turbulence model sensitivity analysis (k-ω SST vs. realizable k-ε) showed NIH variation of 13% at the most sensitive operating point, exceeding the 10% threshold. This is the primary driver of the achieved level 3 rather than 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be identified and their distributions documented; Monte Carlo sampling must draw from these documented distributions with at least 500 samples.",
      "rationale": "Uncertain model inputs identified include: blood analog viscosity (±2%), pump rotational speed (±10 RPM), inlet flow rate (±0.1 L/min), and power-law exponent uncertainty (±15%). Distributions were characterized from calibration data. Monte Carlo ensemble of 1000 samples was generated using Latin hypercube sampling. Input uncertainty documentation is provided in uncertainty quantification report UQR-2024-05."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least 5 independent experimental replicates must be performed at each operating point to characterize measurement variability; coefficient of variation on NIH must be reported.",
      "rationale": "Three experimental replicates were performed at each operating point. While the coefficient of variation on NIH ranged from 4.2% to 9.8%, the sample size of 3 is insufficient to meet the required level 3 threshold of 5 replicates. This gap is noted as a limitation of the experimental campaign; additional replicates were not feasible within the project timeline. Achieved level 2 reflects this shortfall."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrably equivalent to those in the COU simulations; any deviations must be documented with sensitivity analysis showing impact on NIH below 5%.",
      "rationale": "Input parameters in validation simulations are identical to COU simulations with the exception of fluid temperature (22°C in validation vs. 37°C in COU). A sensitivity analysis demonstrated that the temperature-induced viscosity change produces less than 2.1% variation in NIH, within the 5% equivalency threshold. This analysis is documented in sensitivity report SR-2024-04."
    }
  ],
