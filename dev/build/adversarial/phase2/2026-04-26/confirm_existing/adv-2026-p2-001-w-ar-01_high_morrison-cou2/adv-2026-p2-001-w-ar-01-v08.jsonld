  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors at MRL 5. Seven factors achieved their required levels; six factors achieved one level below required. The aggregate credibility profile, combined with the Monte Carlo uncertainty quantification demonstrating NIH predictions below the clinical threshold at the 95th percentile, supports an Accepted decision. Residual gaps in discretization error, output comparison, and test samples are acknowledged and addressed through conservative uncertainty bounds in the MC ensemble.",
