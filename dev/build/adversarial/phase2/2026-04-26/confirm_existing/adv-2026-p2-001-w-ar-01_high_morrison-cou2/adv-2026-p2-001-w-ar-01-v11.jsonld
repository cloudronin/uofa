  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The solver must be under formal version control with documented regression test suite covering all hemolysis-relevant flow regimes; all defects affecting hemolysis QoI must be tracked and closed prior to submission.",
      "rationale": "At MRL 5 for a Class III device, software quality assurance must reach Gradation 4. The CFD solver (ANSYS Fluent 2022 R2) is deployed under ISO 9001-compliant quality management. A regression test suite of 47 cases covering laminar, transitional, and turbulent blood-analogue flows was executed and passed. All open defects affecting hemolysis scalar transport were resolved before the assessment freeze. Version control logs and build manifests are archived in the sponsor's document management system. Achieved level 4 is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate second-order spatial convergence on manufactured solutions for the power-law hemolysis transport equation and the Navier-Stokes momentum equations under rotating-frame conditions.",
      "rationale": "Numerical code verification was performed using the method of manufactured solutions (MMS) applied to the hemolysis scalar transport equation and the rotating-frame Navier-Stokes system. Spatial convergence was confirmed at 1.87 order (close to the expected second order); temporal convergence reached 1.95 order. The shortfall from Gradation 4 arises because MMS was not extended to the turbulence closure (SST k-ω) in the rotating frame, leaving a gap in the verification evidence chain. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal grid convergence index (GCI) study using at least three systematically refined meshes must yield GCI < 2% on the hemolysis index QoI at each of the five operating points.",
      "rationale": "Three systematically refined meshes (3.1 M, 9.8 M, and 29.4 M cells, refinement ratio r = 1.47) were constructed following ASME V&V 20 guidelines. GCI values on the normalised hemolysis index ranged from 0.4% to 1.7% across the five operating points, all below the 2% threshold. The fine-grid solution was used for all subsequent analyses. Richardson extrapolation confirmed monotonic convergence at all points. Achieved level 4 is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must reproduce the five CFD operating points within ±2% on flow rate and ±1% on rotational speed; fluid temperature must be controlled to ±0.5 °C.",
      "rationale": "Experimental bench tests were conducted at the sponsor's hemolysis laboratory using a glycerol-water blood analogue (viscosity matched to 37 °C whole blood). Flow rate was controlled to ±1.1%, rotational speed to ±0.4%, and fluid temperature to ±0.3 °C across all five operating points. These tolerances satisfy the stated acceptance criteria. Achieved level 3 is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within the combined simulation and measurement uncertainty interval (U95) at all five operating points; systematic bias must be characterised and bounded.",
      "rationale": "Predicted normalised hemolysis index (nHI) values were compared against experimental measurements at five operating points. Agreement fell within the U95 combined uncertainty band at four of five points; at the highest flow-speed combination (6 L/min, 3600 RPM) the CFD prediction exceeded the experimental upper bound by 4.2%, attributable to unresolved secondary flow structures at the impeller exit. Systematic bias was estimated at +6.1% (over-prediction), which is characteristic of the power-law hemolysis model at high shear exposure. Achieved level 3 rather than 4 due to the single outlier and unresolved bias source."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (normalised hemolysis index, nHI) must be demonstrably linked to the clinical endpoint (plasma free haemoglobin, pfHb) through a documented and peer-reviewed conversion factor applied consistently across all operating points.",
      "rationale": "The normalised hemolysis index (nHI) is mapped to plasma free haemoglobin (pfHb) using the Heuser-Opitz conversion, which is peer-reviewed and widely applied in VAD hemolysis studies. The conversion factor was applied consistently across all five operating points. The QoI is therefore directly relevant to the clinical decision threshold. Achieved level 4 is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, the same operating envelope, and a blood analogue whose viscosity and density match clinical blood within ±5% at 37 °C.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is identical to the COU geometry. The operating envelope covered the five COU flow-speed combinations. The blood analogue (40% glycerol in water) matched clinical blood viscosity within 3.2% and density within 1.8% at 37 °C. The gap from Gradation 4 arises because validation was conducted at room temperature (22 °C) with post-hoc viscosity correction rather than at 37 °C directly, introducing an additional uncertainty source not fully quantified in the validation report. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to within 10^-5 on all residuals; mass imbalance across the rotating-stationary interface must be below 0.01% of inlet mass flow rate.",
      "rationale": "All simulations were run to convergence with residuals below 10^-6 for continuity and momentum equations and below 10^-7 for the hemolysis scalar. Mass imbalance across the MRF interface was 0.003% of inlet mass flow at all operating points. Achieved level 3 is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation execution protocol must be followed by all analysts; independent peer review of simulation setup files must be completed and recorded before results are used in the assessment.",
      "rationale": "A formal simulation execution protocol (SEP-VAD-002, revision 3) was followed by all analysts. An independent peer review of boundary condition files, material property tables, and solver settings was completed by a reviewer not involved in the original setup. All discrepancies identified during peer review were resolved and documented. Achieved level 3 is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The model form credibility factor addresses the appropriateness of the governing equations, turbulence closure, and hemolysis constitutive model selected for this COU. At Model Risk Level 5 for a Class III VAD device, the required gradation is 4, reflecting the expectation that the model form has been extensively validated across a broad range of geometrically and physiologically relevant conditions, with documented uncertainty contributions from model-form error that are propagated through to the hemolysis index QoI. The power-law hemolysis model (Giersiepen-Wurzinger coefficients, as modified by Heuser and Opitz) was selected as the constitutive relation for red blood cell damage accumulation. This model is the most widely cited in the VAD literature and has been applied in regulatory submissions to FDA. However, it is well documented in the peer-reviewed literature (Arora et al. 2004; Taskin et al. 2012; Ozturk et al. 2015) that the power-law model exhibits strong sensitivity to the stress exponent α and the time exponent β, and that these coefficients were originally calibrated on Couette-flow data at shear rates substantially lower than those encountered in centrifugal VAD impellers. At the high-shear, short-exposure conditions characteristic of the impeller blade passages in this device (shear stress > 500 Pa, exposure time < 5 ms), the power-law model is known to over-predict hemolysis by factors of 2–4 relative to more mechanistically grounded models such as the strain-based model of Arora et al. or the morphology-based model of Vitale et al. The SST k-ω turbulence closure was selected for its balance of near-wall accuracy and computational cost. At the Reynolds numbers encountered in the impeller passages (Re ~ 10^4–10^5), SST k-ω has been shown to capture the mean flow topology adequately, but the turbulent viscosity augmentation introduces an effective viscous stress that is added to the laminar stress in the hemolysis source term, leading to an additional positive bias in predicted nHI. This turbulence-hemolysis coupling has not been systematically characterised for rotating-frame flows in centrifugal pumps. The combined effect of the constitutive model limitation and the turbulence-hemolysis coupling is estimated to contribute a model-form uncertainty of approximately ±35% (k=2) on the predicted nHI, based on a sensitivity study in which the Giersiepen-Wurzinger coefficients were varied within their published uncertainty bounds and the turbulent stress contribution was toggled on and off. This estimate is informal and has not been validated against independent experimental data at the COU operating conditions. For these reasons, the achieved gradation for model form is 2: the model form is documented and its known limitations are acknowledged, but the model-form uncertainty has not been formally bounded through systematic validation across the relevant parameter space, and no higher-fidelity model comparison has been performed to bracket the constitutive model error. The gap between achieved level 2 and required level 4 is the primary driver of the overall credibility shortfall in this assessment. The assessment team notes that this gap is consistent with the current state of the art in CFD-based hemolysis prediction and that no commercially available solver implements a fully validated high-fidelity hemolysis constitutive model for VAD conditions. The team recommends that future assessments incorporate the strain-based or morphology-based hemolysis models and conduct a formal model-form uncertainty quantification study as a prerequisite for reaching Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, material properties, boundary conditions) must be traceable to calibrated measurement data or published reference values with documented uncertainty; sensitivity analysis must identify the top three inputs by influence on nHI.",
      "rationale": "Pump geometry was derived from the FDA-released CAD file (revision 4, SHA-256 verified). Blood analogue material properties were measured in-house with calibrated viscometer and densitometer (calibration certificates on file). Boundary conditions (inlet flow rate, rotational speed, outlet pressure) were set from the experimental test matrix with documented uncertainty. A one-at-a-time sensitivity analysis identified the power-law exponents α and β and the inlet turbulence intensity as the top three inputs by influence on nHI. Achieved level 3 is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A minimum of three independent experimental replicates per operating point must be conducted; inter-replicate coefficient of variation on nHI must be below 10%.",
      "rationale": "Four independent hemolysis experiments were conducted at each of the five operating points using freshly prepared blood analogue batches. Inter-replicate coefficient of variation on nHI ranged from 3.1% to 7.8% across operating points, all below the 10% threshold. Outlier analysis identified no anomalous replicates. Achieved level 3 is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient, head coefficient) computed from the experimental conditions must match those used in the CFD simulations within ±3%.",
      "rationale": "Reynolds number, flow coefficient (φ), and head coefficient (ψ) were computed for both the experimental and CFD operating conditions at all five points. Maximum deviation was 1.9% on Re, 1.4% on φ, and 2.1% on ψ, all within the ±3% equivalency threshold. Achieved level 3 is confirmed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Ten factors achieved their required gradation; three factors (Numerical code verification, Output comparison, Relevance of validation activities) achieved one gradation below required, and Model form achieved two gradations below required. The team accepted the assessment on the basis that the identified gaps are consistent with the published state of the art for CFD-based hemolysis prediction at MRL 5, that the Monte Carlo UQ bounds the combined uncertainty at the 95% confidence level, and that the predicted hemolysis index remains below the clinical threshold even after application of the +35% model-form uncertainty estimate. Risk controls including post-market hemolysis surveillance and a 6-month clinical follow-up protocol were accepted as compensating measures for the model-form gap.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
