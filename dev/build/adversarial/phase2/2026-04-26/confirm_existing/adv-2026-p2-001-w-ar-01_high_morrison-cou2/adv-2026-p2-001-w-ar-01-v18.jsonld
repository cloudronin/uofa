  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "SQA must demonstrate configuration management, version control, regression test suite with ≥90% pass rate, and documented release procedures consistent with MRL 5 requirements per ASME V&V 40 Table 3.",
      "rationale": "The CFD solver (OpenFOAM v8) is subject to institutional SQA procedures including version-controlled source, regression testing, and documented build validation. However, the hemolysis damage model subroutine lacks a formal regression test suite. Achieved level 3 reflects partial SQA compliance; MRL 5 requires level 4 with full traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Code verification must include method-of-manufactured-solutions (MMS) testing for all governing equations including the hemolysis transport equation, with observed order of accuracy within 10% of theoretical order.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver and confirmed second-order spatial accuracy. The power-law hemolysis source term was verified via analytical test cases but MMS was not applied to the full coupled hemolysis transport equation. This partial verification yields level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence study must use Richardson extrapolation on at least three systematically refined meshes with refinement ratio ≥1.3, with GCI < 5% on the hemolysis index QoI at all operating points.",
      "rationale": "A three-level grid convergence study was performed using meshes of 4.2M, 11.1M, and 28.6M cells (refinement ratio ≈1.38). Richardson extrapolation yielded GCI values of 4.8–9.3% on hemolysis index across the five operating conditions. Three of five conditions meet the 5% GCI threshold; two high-flow conditions do not, limiting the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions must replicate all five COU operating points within ±2% on flow rate and ±1% on rotational speed, with documented fluid temperature and viscosity matching within stated uncertainty bounds.",
      "rationale": "The validation experiments were conducted at four of the five COU operating conditions. The fifth condition (6 L/min, 3500 RPM) was not replicated experimentally due to pump cavitation onset during testing. Fluid properties were matched within specification for all tested conditions. The missing operating point constitutes a gap that prevents achievement of level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "rationale": "At Model Risk Level 5 for a Class III VAD device, output comparison requires direct quantitative agreement between predicted and measured absolute hemolysis index (NIH) values across all COU operating conditions, with uncertainty-expanded prediction intervals that bound experimental observations. The requirement for level 5 reflects the regulatory expectation that the model serve as the primary evidence for hemolysis acceptance without reliance on comparative (predicate) arguments. This is the most demanding credibility factor in the assessment: the model must not only reproduce trends but must demonstrate that its absolute hemolysis predictions, when propagated through the full Monte Carlo uncertainty quantification framework, yield 95th-percentile prediction intervals that remain below the clinical threshold of 0.01 g/100 L (modified index of hemolysis). The achieved level of 3 reflects that the model reproduces hemolysis trends and achieves acceptable agreement at four of five operating conditions (mean absolute error 18.4% across tested points), but the 95th-percentile Monte Carlo prediction interval exceeds the clinical threshold at the 6 L/min, 3500 RPM condition — the same condition lacking experimental validation data. Furthermore, the Giersiepen-Wurzinger power-law damage model introduces parametric uncertainty of ±35% on the damage exponent, which when propagated through Monte Carlo sampling yields prediction intervals too wide to provide definitive regulatory assurance at level 5. The assessment team acknowledges that achieving level 5 on output comparison for absolute hemolysis prediction with the current generation of power-law damage models is an aspirational target not yet demonstrated in the published literature for centrifugal VAD configurations. Detailed derivation of the required level, including the mapping from MRL 5 and decision consequence HIGH to the output comparison gradation scale, is documented in the project credibility planning record CPR-2024-VAD-002, which specifies the quantitative thresholds, acceptable comparison metrics, and the statistical framework used to evaluate prediction interval coverage. Reviewers are directed to CPR-2024-VAD-002 Section 4.3 for the complete rationale supporting the level 5 requirement, including the regulatory precedent analysis drawing on FDA guidance documents Q3C and the 2021 FDA discussion paper on computational modeling in cardiovascular device submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must be directly mapped to the clinical endpoint; secondary QoIs (wall shear stress distribution, exposure time) must be shown to influence NIH through the damage model with documented sensitivity ranking.",
      "rationale": "The primary QoI (NIH) is directly linked to the clinical hemolysis endpoint and is the quantity compared against the regulatory threshold. Sensitivity analysis confirms that wall shear stress magnitude and fluid exposure time are the dominant inputs to the power-law damage model, accounting for 87% of NIH variance in the Monte Carlo analysis. QoI relevance is fully documented. Level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation activities must use the same pump geometry, fluid (bovine blood or equivalent), and operating conditions as the COU, with any deviations from COU conditions formally assessed for their impact on model credibility via a validation domain applicability argument.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry in bovine blood at physiological hematocrit. The pump geometry matches the COU device. However, the validation campaign used a single batch of bovine blood without donor variability characterization, whereas the COU involves human patients with variable hematocrit and plasma viscosity. This constitutes a relevance gap that limits the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "acceptanceCriteria": "Iterative convergence must be demonstrated to four orders of magnitude reduction in all residuals; floating-point round-off error must be shown to be negligible relative to discretization error via double-precision sensitivity study.",
      "rationale": "Solver convergence monitoring was performed but not formally documented against the level 3 criteria. Residual convergence logs are available but the formal sensitivity study comparing single- and double-precision results was not conducted. This factor is flagged as a gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "acceptanceCriteria": "A documented user qualification process must be in place, including evidence that analysts have completed training on hemolysis CFD workflows, and that a peer review of simulation setup was conducted by an independent qualified analyst.",
      "rationale": "User qualification records were not formally compiled for this assessment. Lead analysts have relevant experience (>5 years CFD of blood-contacting devices) but no formal training certification exists within the organization for this workflow. Independent peer review of simulation setup was conducted informally but not documented in a traceable record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "acceptanceCriteria": "Model form uncertainty must be quantified by comparing predictions from at least two physically distinct turbulence closure models and two hemolysis damage model formulations, with the resulting model form uncertainty included in the total uncertainty budget.",
      "rationale": "Model form assessment was scoped as a future activity. The assessment used a single turbulence model (SST k-ω) and a single damage model (Giersiepen-Wurzinger). Published literature suggests model form uncertainty for hemolysis prediction can exceed 50%, which at MRL 5 represents a significant unquantified epistemic uncertainty. This gap is the primary driver of the Not Accepted decision in the base COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "All model inputs must have documented uncertainty distributions derived from measurement data or published literature, and a global sensitivity analysis must rank input contributions to output variance, with inputs contributing >5% of variance having their distributions validated against independent data.",
      "rationale": "Monte Carlo uncertainty quantification was performed with distributions assigned to 11 input parameters including fluid viscosity, density, damage model exponents, and boundary conditions. Global variance-based sensitivity analysis (Sobol indices) was computed. However, the damage model exponent distributions were derived from a single published dataset (Giersiepen 1990) without validation against independent experimental data, limiting the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "acceptanceCriteria": "Experimental samples must be characterized for hematocrit, plasma viscosity, and red blood cell fragility index, with at least three independent blood samples used to characterize inter-sample variability in hemolysis measurements.",
      "rationale": "The validation experiments used a single bovine blood batch. Inter-sample variability in hemolysis susceptibility was not characterized. This is a recognized limitation at MRL 5 where patient population variability is a relevant source of uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "acceptanceCriteria": "A formal parameter equivalency argument must demonstrate that validation experiment input parameters (fluid properties, boundary conditions, geometry tolerances) are sufficiently representative of COU conditions, with any non-equivalencies quantified and their impact on model predictions assessed.",
      "rationale": "Parameter equivalency between the validation experiments and the COU was not formally assessed. Key non-equivalencies include the use of bovine versus human blood, the absence of the clinical implant geometry tolerances in the validation model, and differences in inlet flow waveforms between the bench test and physiological VAD operation."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors at MRL 5 for the Class III VAD hemolysis prediction COU. Seven factors were formally assessed; six remain as epistemic gaps. The output comparison factor achieved level 3 against a required level of 5, representing the most significant gap. The team accepts the package with the understanding that the credibility planning record CPR-2024-VAD-002 documents the acceptance rationale for the required levels, and that residual gaps are mitigated by conservative safety margins applied to the hemolysis threshold in the regulatory submission. Conditional acceptance is granted pending resolution of model form uncertainty quantification prior to final regulatory filing.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
