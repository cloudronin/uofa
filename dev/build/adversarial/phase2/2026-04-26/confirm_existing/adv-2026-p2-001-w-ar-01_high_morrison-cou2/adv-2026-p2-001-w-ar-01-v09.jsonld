  "hash": "sha256:3f7a1c9d2e4b6f8a0c5e7d9b1f3a5c7e9d2b4f6a8c0e2d4f6b8a0c2e4d6f8b1a",
  "signature": "ed25519:9c2e4a6f8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4a6f8b0d2f4a6c8e0b2d",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001:2015 certification with documented verification test suite covering all turbulence models used; full audit trail of code changes for the simulation version must be archived and traceable to the submitted results.",
      "rationale": "At MRL 5 the software quality assurance requirement is elevated to Gradation 4, demanding formal configuration management, regression-test coverage above 80%, and an auditable release process. The team demonstrated Gradation 3 compliance: the commercial solver (ANSYS Fluent 2022 R2) carries ISO 9001 certification, and internal release notes document patch history. However, no independent regression-test report covering the specific hemolysis scalar-transport user-defined function (UDF) was provided, and the UDF version hash was not archived alongside the simulation inputs. This gap prevents elevation to Gradation 4 and is recorded as an open deficiency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification must be demonstrated for the hemolysis transport equation using the Method of Manufactured Solutions (MMS) on at least three systematically refined grids, with observed order within 10% of formal order.",
      "rationale": "Gradation 4 requires demonstration of formal order of accuracy via MMS or equivalent for all governing equations including scalar transport. The team performed MMS verification only for the Navier-Stokes momentum equations, achieving Gradation 2. The hemolysis power-law scalar-transport UDF was not subjected to MMS, and no alternative code-to-code comparison with a verified hemolysis solver was provided. This is a significant gap at MRL 5 where absolute hemolysis prediction is the primary quantity of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based Grid Convergence Index (GCI) must be computed on at least three grids with refinement ratio ≥ 1.3, and GCI for hemolysis index must be below 5% at all five operating points.",
      "rationale": "A three-level mesh refinement study was conducted (coarse 4.2 M, medium 11.8 M, fine 31.4 M cells; refinement ratio ~1.41). Richardson extrapolation yielded GCI values ranging from 6.1% to 14.3% across the five operating points for the hemolysis index. While the systematic procedure satisfies Gradation 3, the GCI threshold required for Gradation 4 (below 5%) was not met at three of five operating points, particularly at the high-flow, low-speed condition where secondary flow structures are most sensitive to grid resolution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental operating conditions must match CFD boundary conditions within ±2% for flow rate and ±1% for rotational speed; blood analog fluid properties must be characterized at the test temperature with uncertainty reported.",
      "rationale": "Experimental test conditions for the FDA generic pump bench study were reproduced within ±1.5% for volumetric flow rate and ±0.8% for impeller rotational speed. Porcine blood viscosity and density were measured at 37°C with reported uncertainties of ±3% and ±0.5% respectively. Temperature was maintained at 37 ± 0.5°C throughout testing. These conditions satisfy Gradation 3 requirements for test condition fidelity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rms normalized by experimental uncertainty) must be computed for hemolysis index at all five operating points; metric must be below 1.5 to achieve Gradation 3 and below 0.75 to achieve Gradation 4.",
      "rationale": "Output comparison was performed by computing the normalized root-mean-square error of predicted versus measured hemolysis index across all five operating points. The achieved E_rms/U_exp was 2.8, placing the assessment at Gradation 2. Systematic over-prediction of hemolysis at high rotational speeds (5500 and 6000 RPM) was observed, likely attributable to the power-law hemolysis model's inability to capture the non-linear shear-exposure history in recirculation zones near the volute tongue. Gradation 4 requires E_rms/U_exp below 0.75, which is not achievable without model form revision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must be directly comparable to the clinical acceptance threshold without intermediate transformation; secondary QoIs such as wall shear stress and exposure time distributions must be validated independently.",
      "rationale": "The primary quantity of interest — normalized index of hemolysis (NIH) — is directly relevant to the clinical decision threshold and is computed without unit transformation from the CFD output. Secondary QoIs including volume-averaged shear stress and Lagrangian particle exposure time histograms were extracted and compared against PIV-derived shear estimates, achieving Gradation 3. Gradation 4 would require independent validation of the exposure-time distribution against a resolved experimental measurement, which was not available for the VAD configuration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "At Model Risk Level 5, ASME V&V 40 requires that validation activities be conducted under conditions that are essentially identical to the COU — same device geometry, same fluid, same operating envelope, and same quantity of interest — corresponding to Gradation 5. The validation dataset available for this assessment derives from the FDA generic centrifugal pump benchmark, which shares impeller topology with the target VAD but differs in volute geometry, outlet cannula configuration, and nominal operating range (the VAD operates at substantially higher pressure heads, 80–120 mmHg, versus 20–60 mmHg for the benchmark). The team assessed this factor at Gradation 2 because the validation activities demonstrate relevance of the modeling approach (turbulence closure, hemolysis power-law model, rotating reference frame treatment) but cannot be considered representative of the VAD COU operating space. No patient-specific or VAD-specific hemolysis validation data were available. The gap between Gradation 2 and the required Gradation 5 is the single largest contributor to the overall 'Not accepted' credibility decision. Bridging this gap would require a dedicated in vitro hemolysis study conducted on the production VAD geometry across the full clinical operating envelope, with NIH measured using the modified Dennis protocol and compared directly against CFD predictions at matched boundary conditions. Until such a study is completed and the results incorporated into a revised credibility assessment, the model cannot be considered credible for regulatory submission under the Class III VAD COU. The team notes that this requirement is consistent with FDA guidance on computational modeling for cardiovascular devices (FDA-2021-D-1243) and the ASTM F1841 standard for hemolysis testing, both of which emphasize the necessity of device-specific experimental validation when the model is the primary basis for a safety claim.",
      "acceptanceCriteria": "Validation activities must be conducted on the production VAD geometry across the full clinical operating envelope (80–120 mmHg, 3–8 L/min); NIH must be measured per ASTM F1841 and compared to CFD predictions at matched boundary conditions with E_rms/U_exp below 1.0."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated by reduction of all residuals below 1×10⁻⁵ and by monitoring of hemolysis index until change per iteration is below 0.1%; solver settings must be documented and reproducible.",
      "rationale": "Iterative convergence was monitored via residual tracking and QoI stabilization. Momentum and continuity residuals reached 1×10⁻⁴ (one order above the Gradation 3 threshold of 1×10⁻⁵), and the hemolysis index stabilized to within 0.3% per 100 iterations. Solver settings are documented in the simulation report appendix. The failure to reach the 1×10⁻⁵ residual threshold at the high-speed operating points (5500 and 6000 RPM) limits this factor to Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented peer review of simulation setup, boundary condition assignments, and post-processing scripts must be conducted by an analyst independent of the simulation team; review findings must be recorded and dispositioned.",
      "rationale": "An internal peer review of the simulation setup was performed by a senior analyst within the same engineering group. The reviewer confirmed boundary condition assignments and mesh topology but did not independently re-run the post-processing hemolysis integration script. Gradation 3 requires review by an analyst independent of the simulation team; the internal reviewer's organizational proximity to the simulation team does not satisfy this criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A sensitivity analysis comparing at least two hemolysis model forms (e.g., Giersiepen-Wurzinger and modified Taskin) must be performed; the selected model form must be justified based on comparison with experimental hemolysis data from the validation dataset.",
      "rationale": "Model form assessment was flagged as an epistemic gap. The power-law Giersiepen-Wurzinger hemolysis model was used without comparison against alternative formulations. At MRL 5 a formal model form uncertainty quantification comparing competing hemolysis constitutive models is required to reach Gradation 4. This assessment was not performed due to resource constraints and is recorded as a known gap driving the 'Not accepted' decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity indices (Sobol first-order and total-order) must be computed for all hemolysis model input parameters using the Monte Carlo sample population; parameters with total-order index above 0.05 must be characterized with experimentally derived distributions.",
      "rationale": "Monte Carlo UQ was performed over a 512-sample Latin hypercube covering fluid viscosity, density, and power-law model coefficients. However, formal Sobol sensitivity indices were not computed, and the distributions assigned to power-law coefficients (C, α, β) were derived from literature ranges rather than device-specific experimental characterization. This limits the factor to Gradation 2 and represents a significant epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At least three independent experimental replicates must be available for each of the five operating points; inter-replicate variability must be characterized and incorporated into the validation metric uncertainty budget.",
      "rationale": "The FDA generic pump benchmark dataset provides single-replicate hemolysis measurements at each operating point. No repeat measurements were available to characterize inter-replicate biological and measurement variability. Gradation 3 requires at least three replicates per condition. This gap is recorded as not-assessed due to unavailability of additional experimental data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal parameter equivalency matrix must document the correspondence between experimental and CFD input parameters for all boundary conditions and fluid properties; deviations exceeding ±5% must be justified or propagated through the UQ analysis.",
      "rationale": "A parameter equivalency review was not formally documented. Informal comparison of CFD boundary conditions against experimental records suggests agreement within ±3% for most parameters, but the blood analog viscosity used in the CFD model (2.7 mPa·s) differs from the measured porcine blood viscosity at 37°C (3.1 ± 0.2 mPa·s) by approximately 13%. This discrepancy was not propagated through the UQ analysis and represents a gap preventing achievement of Gradation 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors at Model Risk Level 5 for the VAD hemolysis COU. Seven factors were formally assessed; six were flagged as epistemic gaps. Of the seven assessed factors, none achieved the required credibility level. The most critical gap is the Relevance of Validation Activities factor, where the available FDA generic pump benchmark data cannot be considered representative of the Class III VAD operating envelope. The team formally records the decision as Not accepted pending completion of a device-specific in vitro hemolysis validation study. All factor assessments and supporting evidence are archived in the simulation credibility dossier referenced by this unit of assurance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
