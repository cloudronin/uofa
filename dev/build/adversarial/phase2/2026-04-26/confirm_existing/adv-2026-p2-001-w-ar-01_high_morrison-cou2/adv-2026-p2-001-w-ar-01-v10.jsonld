  "signature": "ed25519:b7d3e9f1a2c4b6d8e0f2a4c6d8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4d6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan must cover configuration management, regression testing, and documented release procedures consistent with MRL 5 Class III device context; independent review of solver version control records required.",
      "rationale": "At MRL 5 for a Class III device, the software quality assurance requirements are substantial. The CFD solver (ANSYS Fluent 2022 R2) is operated under a documented SQA plan that covers version control and regression testing. However, the plan lacks independent third-party audit records and the regression test suite does not cover the hemolysis sub-model specifically. Achieved level 3 falls short of the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include method-of-manufactured-solutions (MMS) tests for all governing equations including the hemolysis transport scalar, with observed order of accuracy documented to within 10% of theoretical order.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver core and confirmed second-order spatial accuracy. However, MMS verification was not extended to the hemolysis damage accumulation scalar transport equation, which is the primary quantity of interest. This gap reduces the achieved level to 3 against a required level of 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; GCI on hemolysis index must be below 5% for all five operating points; Richardson extrapolation must be applied and reported.",
      "rationale": "A three-level mesh refinement study was conducted (coarse: 4.2M cells, medium: 12.6M cells, fine: 37.8M cells). GCI values for the hemolysis index ranged from 3.8% to 11.4% across the five operating points. The highest GCI values occurred at the off-design operating conditions where shear stress gradients near the impeller trailing edge are steepest. Richardson extrapolation was applied at the nominal operating point only. The failure to achieve GCI below 5% at all operating points, and the partial application of Richardson extrapolation, limits the achieved level to 4 against the required level of 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within stated tolerances; fluid temperature, hematocrit, and blood analog rheology must be documented and matched to within 5% of nominal COU values.",
      "rationale": "The FDA benchmark experimental data were collected using a porcine blood analog at controlled temperature and hematocrit. The VAD COU specifies human blood at physiological hematocrit levels. While the analog fluid has been characterized rheologically, the mapping of damage accumulation constants from porcine to human blood introduces unquantified uncertainty. Test conditions are partially representative but the biological fluid mismatch is not fully characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (NRMSE, validation uncertainty Uval) must be computed for hemolysis index at all five operating points; model prediction must fall within combined validation uncertainty interval at a minimum of four of five points.",
      "rationale": "Hemolysis index predictions were compared against experimental measurements at five operating points. The model predictions fell within the combined validation uncertainty interval (experimental uncertainty plus numerical uncertainty) at three of five operating points. At the two off-design points, predictions exceeded measured values by 18% and 23% respectively, outside the uncertainty interval. NRMSE across all points was 14.7%. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI must be the hemolysis index (or a direct surrogate) measured under conditions representative of the COU; the mapping from validation QoI to COU decision QoI must be explicitly documented.",
      "rationale": "The validation activities directly measure the normalized index of hemolysis (NIH), which is the same quantity used for the COU decision threshold. The mapping from bench-scale NIH to clinical hemolysis risk is documented in the device risk assessment. Achieved level equals required level for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry must match COU device geometry within 2% of all critical dimensions; operating conditions in validation must span the full COU operating envelope including corner conditions.",
      "rationale": "The validation activities used the FDA generic centrifugal pump geometry, which is not identical to the commercial VAD geometry. Critical dimensions differ by up to 7% in impeller blade chord length. Operating conditions in validation covered three of five COU flow-speed combinations; the two highest-speed conditions were not tested experimentally. This geometric and operational gap reduces the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-6 for all equations; round-off error analysis must confirm double-precision arithmetic is sufficient for the hemolysis scalar magnitude range encountered.",
      "rationale": "Iterative convergence to residuals below 1e-5 was achieved for momentum and continuity equations; the hemolysis scalar residual stalled at approximately 3e-5 at two operating points due to near-wall stiffness in the damage accumulation source term. Round-off error analysis was not performed. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation execution protocol must exist; an independent analyst must have reproduced at least one operating point result within 2% of the primary analyst result.",
      "rationale": "A simulation execution protocol is documented and version-controlled. An independent analyst reproduced the nominal operating point result with a 1.4% deviation in predicted NIH. Use error controls are adequate for the required level. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "The model form credibility factor addresses the suitability of the underlying physical and mathematical representations chosen to simulate hemolysis in a centrifugal blood pump at MRL 5. For this assessment, the primary modeling choices under scrutiny are: (1) the turbulence closure model (SST k-omega), (2) the hemolysis damage accumulation law (Giersiepen-Wurzinger power-law model), and (3) the treatment of red blood cell deformability as a passive scalar rather than a two-fluid model. At Model Risk Level 5 for a Class III device where the model is the primary basis for the hemolysis acceptance decision, the required level of 5 reflects the expectation that model form uncertainty must be systematically bounded through multiple competing model evaluations and sensitivity analyses that span the space of plausible physical representations. The assessment team conducted a comparative study using three turbulence models (SST k-omega, realizable k-epsilon, and RSM) and found that predicted NIH values varied by up to 34% across turbulence model choices at the highest rotational speed condition. This variation is clinically significant given that the COU decision threshold is an absolute NIH value. The Giersiepen-Wurzinger constants were taken from the original 1990 in-vitro calibration study and have not been recalibrated for the specific blood analog or operating shear-rate regime encountered in this pump. A sensitivity analysis on the power-law exponents showed that a 10% perturbation in the stress exponent produces a 22% change in predicted NIH at peak shear conditions near the impeller tip. The passive-scalar treatment of red blood cells ignores preferential migration of erythrocytes away from high-shear near-wall regions, a phenomenon documented in the literature for gap widths below 200 microns — a condition met in this pump geometry at the impeller-volute gap. No alternative two-fluid or particle-tracking model was evaluated to bound the error introduced by this simplification. In aggregate, the model form choices introduce substantial unquantified uncertainty in the predicted hemolysis index, particularly at off-design conditions. The achieved level of 3 reflects that the dominant model form choices are documented and a partial sensitivity analysis was performed, but competing model evaluations were limited to turbulence closure only, and the hemolysis constitutive law and RBC transport model were not subjected to equivalent scrutiny. The gap between achieved level 3 and required level 5 is the largest single credibility gap in this assessment and is a primary driver of the overall Not Accepted decision. The assessment team notes that closing this gap would require at minimum: recalibration of the Giersiepen-Wurzinger constants against device-specific experimental data, evaluation of at least one mechanistic hemolysis model (e.g., Arora strain-based model) as an alternative, and a particle-tracking or two-fluid sensitivity study to bound the passive-scalar approximation error. These activities are recommended as prerequisites for any future resubmission at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources and uncertainty bounds; Monte Carlo UQ must propagate input uncertainty through the full model and report 95th percentile bounds on predicted NIH.",
      "rationale": "Monte Carlo uncertainty quantification was performed on seven model input parameters including fluid viscosity, inlet velocity profile, and hemolysis model constants. The 95th percentile NIH predictions exceeded the clinical threshold at two of five operating points, indicating that input uncertainty alone can drive the model into the unacceptable region. However, the rotational speed uncertainty was treated as negligible (fixed at nominal) despite documented motor speed variation of ±2% in the target device. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A minimum of three independent experimental test samples must be used for validation; sample-to-sample variability must be reported and incorporated into the validation uncertainty estimate.",
      "rationale": "Three independent experimental runs were conducted at each operating point using separately prepared blood analog batches. Inter-batch variability was characterized and incorporated into the experimental uncertainty estimate via pooled standard deviation. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Boundary conditions applied in the simulation must be demonstrated to match experimental inlet and outlet conditions within combined measurement uncertainty; any deviations must be quantified and their effect on NIH bounded.",
      "rationale": "Inlet velocity profiles measured by PIV were applied as boundary conditions in the simulation. Outlet pressure boundary conditions were matched to experimental measurements within 3%. However, the inlet turbulence intensity was estimated from empirical correlations rather than measured directly, introducing an uncharacterized boundary condition uncertainty. The sensitivity of NIH to inlet turbulence intensity was not assessed. Achieved level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following full 13-factor credibility assessment at MRL 5 for a Class III VAD device, the overall credibility package is assessed as Not Accepted. The largest credibility gaps are in Model Form (achieved 3 vs required 5), Discretization Error (achieved 4 vs required 5), and Output Comparison (achieved 3 vs required 4). The Model Form gap is particularly significant as the hemolysis constitutive law uncertainty and RBC transport model simplification have not been bounded. Monte Carlo UQ demonstrates that input uncertainty alone can drive predicted NIH above the clinical threshold at off-design conditions. Resubmission is recommended following model form sensitivity studies, extended mesh convergence at all operating points, and recalibration of hemolysis model constants.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
