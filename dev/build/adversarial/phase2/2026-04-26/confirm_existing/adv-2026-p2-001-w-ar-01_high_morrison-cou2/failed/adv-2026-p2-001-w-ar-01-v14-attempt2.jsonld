  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for simulation must be under formal configuration management with documented version control, regression testing suite, and traceable change logs. At MRL 5 and Class III device context, Gradation 4 requires an independently audited QA plan covering all solver modules used in hemolysis prediction.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is under version control and regression-tested against canonical benchmark cases. However, the hemolysis scalar transport sub-model is implemented as a user-defined function (UDF) and lacks an independently audited QA plan. Internal review was performed but no third-party audit record exists. Achieved level is Gradation 3: QA procedures are documented and internally reviewed but not independently verified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification at Gradation 4 requires method of manufactured solutions (MMS) or equivalent order-of-accuracy testing applied to all governing equation sets, including turbulence and scalar transport modules, with results documented in a formal verification report.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes and k-omega SST turbulence modules using the method of manufactured solutions. Results confirm second-order spatial accuracy. The hemolysis scalar transport UDF was not subjected to MMS testing; only qualitative plausibility checks were performed. This limits the achieved level to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error assessment at Gradation 4 requires a formal grid convergence index (GCI) study on at least three systematically refined meshes, with GCI values reported for all primary quantities of interest including hemolysis index, pressure head, and flow rate.",
      "rationale": "A three-mesh GCI study was performed for pressure head and flow rate, yielding GCI values below 2% for both quantities. Hemolysis index GCI was computed only on two mesh levels due to computational cost constraints, yielding an estimated discretization uncertainty of 8.3%. The incomplete three-mesh GCI for hemolysis index limits the achieved level to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions at Gradation 4 require that experimental boundary conditions are measured and reported with calibrated instrumentation, traceable to national standards, and that operating point tolerances are within ±2% of nominal CFD boundary conditions.",
      "rationale": "Experimental test conditions were established using NIST-traceable flow meters and pressure transducers. All five operating points were held within ±1.5% of nominal boundary conditions. Inlet and outlet pressure boundary conditions were matched to within 50 Pa. Temperature was controlled to 37 ± 0.5°C. Full calibration certificates are on file. Gradation 4 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison at Gradation 4 requires quantitative validation metrics (e.g., ASME V&V 20 validation uncertainty framework or equivalent) applied to all primary quantities of interest, with statistical confidence intervals reported and compared against defined validation acceptance thresholds.",
      "rationale": "Quantitative output comparison was performed using the ASME V&V 20 validation uncertainty framework for pressure head and flow rate. For hemolysis index, a direct percentage error metric was used without full propagation of experimental uncertainty through the comparison metric. Mean absolute percentage error across five operating points was 14.2%. The absence of full statistical uncertainty propagation for the hemolysis QOI limits the achieved level to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At Gradation 5, the quantities of interest used in validation must be identical to those used in the COU decision, measured under identical or demonstrably equivalent conditions, with a formal equivalency argument documented and reviewed by an independent party.",
      "rationale": "The primary quantity of interest — normalized index of hemolysis (NIH) — is directly used in both the validation study and the COU decision. However, the validation NIH was measured using a modified index formula (MIH) for experimental convenience, and a conversion factor was applied. The conversion factor is well-established in the literature but was not independently reviewed for this specific pump geometry. This limits the achieved level to Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "rationale": "The validation activities were conducted on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU. Operating conditions span the full clinical envelope of the VAD application, covering flow rates from 3 to 7 L/min and rotational speeds from 2000 to 3500 RPM. Five of the five COU operating points are directly represented in the validation dataset. The validation fluid (glycerol-water mixture with ovine red blood cells) is physiologically representative but not identical to human blood under VAD conditions; hematocrit was 30% versus a clinical range of 25–45%. This physiological gap, while minor and consistent with accepted practice in the field, prevents a Gradation 5 rating because the validation fluid does not fully bracket the patient population variability. The hemolysis model coefficients were calibrated on the same ovine blood dataset used for validation, introducing a degree of circularity that is acknowledged but not formally quantified. Taken together, the breadth of operating condition coverage and geometric fidelity are strong, but the fluid representativeness gap and coefficient circularity are sufficient to hold the achieved level at Gradation 4. An independent sensitivity study varying hematocrit from 25% to 45% would be required to close this gap and achieve Gradation 5. That study is planned for a subsequent assessment cycle but was not available at the time of this credibility evaluation. The assessment team notes that this factor represents the most consequential gap in the current evidence package, as the COU requires prediction of absolute hemolysis levels — not relative comparisons — and any systematic bias introduced by fluid non-equivalence directly propagates into the regulatory decision margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical solver error at Gradation 3 requires documented iterative convergence criteria with residual targets defined for all solved equations, and demonstration that solution residuals meet those targets for all operating points in the COU.",
      "rationale": "Iterative convergence was monitored for all governing equations. Mass and momentum residuals reached 1e-5 for all five operating points. The hemolysis scalar transport equation residual reached 1e-4 at two of five operating points, falling short of the 1e-5 target. Convergence plots are provided in Appendix C. The failure to achieve the target residual for the hemolysis scalar at two operating points limits the achieved level to Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Use error at Gradation 3 requires a documented simulation protocol with step-by-step instructions for model setup, boundary condition assignment, and post-processing, reviewed by a second qualified analyst who independently verifies key setup parameters.",
      "rationale": "A simulation protocol document exists and was reviewed internally. However, the independent verification step was performed by a colleague within the same project team rather than a qualified analyst outside the immediate team. The boundary condition assignment for the rotating reference frame interface was identified as a potential source of use error in post-hoc review; the protocol has since been updated but was not re-verified. Achieved level is Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form credibility at Gradation 4 requires documented justification for all constitutive model selections (turbulence model, hemolysis damage accumulation model, non-Newtonian viscosity model) with supporting literature evidence and sensitivity analysis demonstrating that alternative plausible model forms do not change the QOI by more than the defined acceptance threshold.",
      "rationale": "The k-omega SST turbulence model was selected based on published benchmark performance for rotating machinery flows. The Giersiepen-Wurzinger hemolysis power-law model was selected as the most widely validated model for this pump class. A sensitivity analysis comparing the GW model against the Zhang model was performed; hemolysis index predictions differed by up to 22% between models. This sensitivity exceeds the acceptance threshold and was not resolved by model form argument alone. Achieved level is Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs at Gradation 4 require that all primary model inputs are characterized with quantified uncertainty distributions, and that a formal uncertainty propagation analysis (e.g., Monte Carlo or polynomial chaos) is performed and reported for all quantities of interest.",
      "rationale": "Monte Carlo uncertainty quantification was performed on six primary model inputs: inlet flow rate, rotational speed, fluid viscosity, fluid density, hemolysis model coefficient C, and hemolysis model exponent alpha. Input distributions were based on experimental measurement uncertainty and literature ranges. 500 Monte Carlo samples were used. Output uncertainty intervals at 95% confidence are reported for hemolysis index and pressure head. The hemolysis model coefficients C and alpha are correlated, but the Monte Carlo analysis treated them as independent, potentially underestimating output uncertainty. Achieved level is Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples at Gradation 3 require that experimental samples are drawn from a defined population with documented inclusion and exclusion criteria, and that sample size is justified with reference to the precision required for the validation comparison.",
      "rationale": "Experimental hemolysis measurements were performed on n=5 independent blood samples per operating point (25 total), drawn from ovine donors meeting documented inclusion criteria (hematocrit 28–32%, age 2–4 years). Sample size was justified based on achieving a coefficient of variation below 15% for NIH measurements, consistent with published practice for this assay. All 25 measurements met the CV criterion. Gradation 3 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Equivalency of input parameters at Gradation 4 requires a formal parameter mapping document demonstrating that each experimental input parameter is matched to its CFD boundary condition counterpart, with quantified equivalency tolerances and documented treatment of any parameters that cannot be directly matched.",
      "rationale": "A parameter mapping document was prepared covering flow rate, rotational speed, inlet pressure, outlet pressure, and fluid temperature. All five parameters were matched within defined tolerances. Fluid viscosity was matched using the Quemada non-Newtonian model fit to the experimental blood viscosity measurements. However, the surface roughness of the pump impeller was not directly measured and was assigned a nominal value of 0.8 micrometers based on manufacturing specification rather than metrology. This uncharacterized input limits the achieved level to Gradation 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors, the assessment team determined that the overall evidence package provides sufficient credibility for the intended regulatory submission at Low assurance level. Seven factors were assessed; six achieved levels fall below required levels, consistent with a Low assurance determination. The most significant gap is the Relevance of Validation Activities factor, where fluid non-equivalence and coefficient circularity prevent Gradation 5. Monte Carlo uncertainty quantification provides quantified output uncertainty intervals. The team accepts the package at Low assurance level with the understanding that the planned hematocrit sensitivity study will be submitted as a supplementary filing prior to device approval.",
