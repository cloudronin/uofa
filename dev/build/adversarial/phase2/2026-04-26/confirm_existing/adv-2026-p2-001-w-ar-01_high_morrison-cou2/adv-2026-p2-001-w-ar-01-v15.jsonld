  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan must demonstrate ISO 9001-compliant change control, version-locked solver binaries, and documented regression test suite covering all hemolysis-relevant code paths. Gradation 4 requires independent third-party audit of the SQA plan within the 24-month period preceding submission.",
      "rationale": "The CFD solver (OpenFOAM v8) is governed by a documented SQA plan that includes version control via Git with tagged release commits, a regression test suite of 47 canonical cases, and an internal peer-review gate prior to each production run. However, an independent third-party audit of the SQA plan has not been completed within the required 24-month window; the most recent external review is 31 months old. Achieved Gradation 3 rather than required Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include method-of-manufactured-solutions (MMS) tests for all governing equations active in the hemolysis COU, with observed order-of-accuracy within 10% of theoretical order. Gradation 4 additionally requires MMS coverage of the power-law hemolysis damage accumulation sub-model.",
      "rationale": "MMS tests were executed for the incompressible Navier-Stokes solver and the scalar transport equation used for hemolysis index advection, confirming second-order spatial accuracy (observed 1.93 vs. theoretical 2.0). The hemolysis damage accumulation sub-model (Giersiepen-Wurzinger power-law) was not subjected to independent MMS verification; its algebraic form was validated only through comparison with published experimental data. This gap prevents elevation to Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must be performed on a minimum three-mesh sequence with refinement ratio ≥ 1.3, reporting GCI on the primary QoI (hemolysis index) at each of the 5 operating points. Gradation 5 requires GCI < 1% on all operating points and documented sensitivity of hemolysis index to near-wall mesh resolution in the blade-gap region.",
      "rationale": "A three-mesh GCI study was conducted (coarse 4.2 M, medium 11.7 M, fine 31.4 M cells; refinement ratio 1.41). GCI on hemolysis index ranged from 1.8% to 6.3% across the 5 operating points, with the highest discretization uncertainty occurring at the low-flow high-speed condition (Q=3 L/min, 3500 RPM) where blade-tip clearance vortices are most sensitive to near-wall resolution. The achieved GCI values exceed the Gradation 5 threshold of 1%, placing this factor at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions applied in validation testing must match COU operating envelope within documented tolerances. Gradation 4 requires that all 5 target operating points be tested with inlet velocity profiles measured (not assumed uniform) and that blood analog fluid properties be characterized at test temperature ±0.5°C.",
      "rationale": "Validation experiments used bovine blood at 37°C ± 1.2°C; the temperature tolerance exceeds the Gradation 4 requirement of ±0.5°C. Inlet velocity profiles were assumed uniform based on upstream straight-pipe length (L/D = 18), which meets the Gradation 3 criterion but not the measured-profile requirement for Gradation 4. All 5 operating points were tested experimentally."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., validation comparison error E = (S - D)/D) must be reported with experimental uncertainty intervals. Gradation 4 requires E within ±15% at all operating points with uncertainty intervals non-overlapping between CFD and experiment at 95% confidence.",
      "rationale": "Hemolysis index comparison errors range from -8% to +47% across the 5 operating points. The high-flow condition (Q=7 L/min, 2500 RPM) shows a +47% over-prediction, likely attributable to the power-law damage model's insensitivity to recirculation-dominated flow regimes. Experimental uncertainty was characterized but 95% confidence intervals overlap at 3 of 5 operating points, placing achieved level at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) used in validation must be identical to the QoI used in the COU decision. Secondary QoIs (e.g., shear stress distributions) must be documented as supporting evidence. Gradation 4 requires traceability from each validation QoI to a specific COU decision criterion.",
      "rationale": "The normalized index of hemolysis (NIH, g/100 L) is the primary QoI in both validation experiments and the COU submission. Traceability is documented in the V&V plan (Section 4.2): NIH maps directly to the clinical threshold of 0.1 g/100 L specified in the device submission protocol. Secondary QoIs (wall shear stress, velocity magnitude at impeller exit) are documented as supporting evidence in Appendix C. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the same device geometry and at operating conditions spanning the full COU envelope. Gradation 5 requires validation on the clinical device geometry (not a surrogate) at all COU operating points with patient-representative blood rheology.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is a surrogate for the proprietary VAD geometry used in the COU. The operating conditions tested (5 flow-speed combinations) span the COU envelope, but the device geometry differs from the clinical device in impeller blade count (5 vs. 7) and volute cutwater angle. Blood rheology used bovine blood rather than patient-representative human blood with pathological viscosity distributions. These geometry and rheology gaps limit the factor to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Iterative convergence was monitored via residual norms for all transport equations. The continuity residual reached 1×10⁻⁴ at all operating points; however, the hemolysis scalar transport equation residual stagnated at 2×10⁻³ at the low-flow condition (Q=3 L/min, 3500 RPM), indicating incomplete iterative convergence for the primary QoI at the most clinically critical operating point. Gradation 4 requires residuals below 1×10⁻⁵ for all equations governing the primary QoI. The stagnation is attributed to numerical instability in the recirculation zone near the blade-gap region where the power-law source term introduces strong nonlinearity into the scalar transport equation. Attempts to tighten convergence through under-relaxation factor reduction (from 0.7 to 0.3) reduced the stagnation residual to 8×10⁻⁴ but did not achieve the required threshold. This factor represents a known gap between the achieved iterative convergence posture and the Gradation 4 requirement mandated by Model Risk Level 5; it is flagged as a primary contributor to the overall Not Accepted decision. The team notes that achieving Gradation 4 on this factor would require either a reformulation of the hemolysis source term to improve numerical conditioning or adoption of a fully implicit coupling strategy between the flow solver and the damage accumulation equation, both of which are outside the scope of the current assessment cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence of user qualification must include documented training records and a simulation execution checklist reviewed by an independent analyst. Gradation 3 requires that at least one independent analyst reproduce a subset of results within documented tolerances.",
      "rationale": "The primary analyst holds a doctoral degree in computational fluid dynamics with 6 years of experience in blood-contacting device simulation. A simulation execution checklist is in place and was followed for all 5 operating points. However, an independent reproduction exercise was not completed; a second analyst reviewed the input files and boundary conditions but did not execute an independent simulation run. This gap prevents Gradation 3 from being claimed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty must be quantified by comparing predictions from at least two physically distinct turbulence closure models. Gradation 4 requires that model form uncertainty be bounded and that the bounding interval be propagated to the primary QoI uncertainty budget.",
      "rationale": "The production simulation used the k-ω SST turbulence model. A sensitivity study comparing k-ω SST to the Spalart-Allmaras model was conducted at one operating point (Q=5 L/min, 3000 RPM), showing a 22% difference in predicted NIH. The study was not extended to all 5 operating points, and the model form uncertainty interval was not formally propagated into the Monte Carlo UQ budget. Gradation 2 reflects the partial but incomplete model form uncertainty characterization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters with sensitivity rank above 5% contribution to QoI variance must have characterized probability distributions derived from experimental measurement or literature meta-analysis. Gradation 4 requires that input distributions be validated against independent measurement datasets not used in model calibration.",
      "rationale": "Monte Carlo UQ was performed with 12 input parameters sampled from assigned distributions. Sobol sensitivity analysis identified blood viscosity (Carreau model coefficients) and the Giersiepen-Wurzinger power-law exponents as the top contributors (combined 68% of QoI variance). Viscosity distributions were derived from published rheometry data (Merrill et al., Cross et al.). The power-law exponent distributions were fitted to the same experimental hemolysis dataset used for model calibration, creating a circularity that prevents independent validation of those input distributions. Gradation 3 is claimed; Gradation 4 requires independent dataset validation of the power-law input distributions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood sample provenance, storage conditions, and passage number must be documented for all experimental specimens. Gradation 3 requires that samples span at least two independent donors and that inter-donor variability be characterized.",
      "rationale": "This factor was flagged as not assessed due to incomplete documentation of blood sample provenance in the experimental records provided by the collaborating laboratory. The test samples used in the hemolysis bench experiments are known to be bovine blood from a commercial supplier, but lot numbers, storage duration post-collection, and passage history are not available in the data package. Without this information, the factor cannot be assessed against the Gradation 2 or Gradation 3 criteria. This represents an epistemic gap at Model Risk Level 5 and is flagged for resolution in a subsequent assessment cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal mapping must be provided between each experimental boundary condition and its CFD counterpart, with documented justification for any parameter that differs between experiment and simulation. Gradation 4 requires that all parameters with sensitivity rank above 5% QoI variance be equivalent within measurement uncertainty.",
      "rationale": "The equivalency mapping between experimental and simulation input parameters was initiated but not completed at the time of this assessment. Inlet flow rate and rotational speed are directly matched between experiment and simulation. However, the inlet velocity profile shape, blood temperature, and hematocrit value differ between the experimental and simulation configurations, and a formal justification document for these differences has not been finalized. Given that hematocrit is a high-sensitivity input (12% QoI variance per Sobol analysis), the absence of a completed equivalency mapping prevents any gradation above Gradation 2 from being claimed. This factor is flagged as not assessed pending completion of the equivalency documentation."
    }
  ],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis prediction, MRL 5) documents that 7 of 13 credibility factors were assessed and that all 7 assessed factors achieved levels below their required levels. The two most critical gaps are the numerical solver error factor (residual stagnation at the low-flow operating point) and the output comparison factor (47% over-prediction at high-flow condition). Six factors were not assessed or only partially assessed due to epistemic gaps in experimental documentation. The overall credibility posture is insufficient for Model Risk Level 5, and the decision is formally recorded as Not Accepted pending remediation of the identified gaps. Acceptance is contingent on: (1) achieving iterative convergence to 1×10⁻⁵ on all transport equations, (2) completing independent analyst reproduction for use error, (3) obtaining blood sample provenance documentation, and (4) finalizing the equivalency mapping for high-sensitivity input parameters.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
