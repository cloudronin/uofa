  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated under a formal quality management system with documented version control, regression testing, and traceability to requirements. At MRL 5, Gradation 4 requires evidence of a complete QMS audit trail and independent code review.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) operates under an ISO 9001-certified QMS with documented version control and regression test suite. Independent review of solver modules was performed internally but not by an external party, resulting in achievedLevel 3. A formal third-party audit was not completed within the assessment window."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include method of manufactured solutions (MMS) or equivalent for all governing equations used in the hemolysis model, with documented order-of-accuracy confirmation. At MRL 5, Gradation 4 requires MMS applied to turbulence model and scalar transport equations independently.",
      "rationale": "MMS was applied to the Navier-Stokes equations and confirmed second-order spatial accuracy. The power-law hemolysis scalar transport equation was verified against an analytical solution for a simplified geometry. Full MMS for the coupled turbulence-hemolysis system was not completed, limiting the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes for all quantities of interest, with GCI values reported and shown to be below 5% for hemolysis index predictions. Richardson extrapolation must be applied and documented.",
      "rationale": "Three systematically refined meshes (4.2M, 12.6M, 37.8M cells) were generated with a constant refinement ratio of 1.5. GCI values for hemolysis index ranged from 1.8% to 4.1% across the five operating points, all below the 5% threshold. Richardson extrapolation was applied and extrapolated values are reported in the validation dataset. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to reproduce boundary conditions in the simulation, including fluid properties, pump speed, flow rate, and temperature, with stated measurement uncertainties for each parameter.",
      "rationale": "FDA benchmark experimental data provides documented test conditions for all five operating points. Fluid temperature, viscosity, pump rotational speed (±2 RPM), and flow rate (±0.02 L/min) are reported with measurement uncertainties. Conditions are directly mapped to CFD boundary conditions with documented traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, validation metric per ASME V&V 20) must be computed between CFD predictions and experimental hemolysis index values, with uncertainty bands from both simulation and experiment included in the comparison.",
      "rationale": "Hemolysis index predictions were compared to FDA experimental data at all five operating points. Normalized RMS error was 18.3%, with CFD over-predicting hemolysis at high-speed, low-flow conditions. Experimental uncertainty bands were included; however, simulation uncertainty bands from Monte Carlo UQ were reported separately rather than overlaid on the comparison plot, which limited the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation (hemolysis index) must be demonstrated to be the same physical quantity, measured by the same method, as the clinical decision threshold. Any transformation or surrogate must be explicitly justified.",
      "rationale": "The normalized index of hemolysis (NIH) used in both CFD prediction and experimental measurement is the same quantity required by the clinical acceptance threshold. No surrogate or transformation is applied. The mapping from CFD shear stress history to NIH via the power-law model is explicitly documented and consistent with the clinical decision basis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry, at the same or bracketing operating conditions, and with the same fluid as the COU. Any differences must be quantified and their impact on model credibility assessed through sensitivity analysis.",
      "rationale": "The FDA generic centrifugal pump geometry used in validation is identical to the COU device. Operating conditions span the clinical range but do not include the highest-flow condition in the COU envelope. A sensitivity analysis was performed showing hemolysis index is monotonically decreasing with flow rate, providing indirect coverage, but direct validation at the boundary condition was not achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Numerical solver error for this assessment encompasses iterative convergence error, round-off error, and errors arising from time-integration of the hemolysis scalar transport equation along Lagrangian particle trajectories. Iterative convergence was monitored via residual norms, which were driven below 1e-6 for all flow variables and 1e-8 for the hemolysis scalar. Round-off error was assessed to be negligible given double-precision arithmetic. However, the Lagrangian particle tracking scheme introduces path-dependent integration error that accumulates over the rotor passage. A systematic study of particle seeding density and integration time-step was initiated but not completed within the assessment period: only two seeding densities were evaluated (5,000 and 20,000 particles per operating point), and the hemolysis index showed a 7.2% difference between these densities, indicating that convergence with respect to particle count had not been achieved. At Model Risk Level 5, Gradation 4 requires demonstrated convergence of the Lagrangian hemolysis integral with respect to both particle count and integration time-step, with residual error quantified and shown to be below 3% of the hemolysis index value. The current evidence supports only Gradation 2, as convergence is partially demonstrated for the Eulerian flow field but not for the coupled Lagrangian hemolysis accumulation that constitutes the primary quantity of interest. This gap is identified as a significant contributor to the overall credibility shortfall and is flagged for remediation in the next assessment cycle. The Monte Carlo UQ propagates inlet boundary condition uncertainty but does not account for Lagrangian integration error, meaning the reported prediction intervals underestimate total simulation uncertainty. Remediation would require a minimum of four particle seeding densities spanning 5,000 to 80,000 particles, combined with a time-step refinement study at each seeding level, to establish a robust convergence criterion consistent with the MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence of user qualification must be provided, including documented training records, simulation setup review by an independent analyst, and a checklist-based pre-submission review covering boundary condition assignment, turbulence model selection, and hemolysis model parameter values.",
      "rationale": "The lead analyst holds a PhD in computational fluid dynamics with five years of experience in blood pump simulation. An internal peer review of the simulation setup was conducted by a second analyst, but the review was not documented using a formal checklist. Turbulence model selection (SST k-omega) was justified in a technical memo but not independently verified against alternative models for this specific geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The choice of hemolysis model form (e.g., power-law, strain-based, energy dissipation) must be justified against available experimental data, with sensitivity of predicted hemolysis index to model form quantified across at least two alternative formulations.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected based on its widespread use in regulatory submissions. A comparison against the Arora strain-based model was performed at one operating point, showing a 22% difference in predicted NIH. Full sensitivity analysis across all five operating points and both model forms was not completed. The model form uncertainty is acknowledged as a dominant source of epistemic uncertainty at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be documented with sources, nominal values, and uncertainty ranges. Monte Carlo or equivalent UQ must propagate input uncertainty through the hemolysis model to produce prediction intervals on the quantity of interest.",
      "rationale": "Monte Carlo UQ was performed with 1,000 samples, propagating uncertainty in inlet flow rate, fluid viscosity, and pump rotational speed. Power-law hemolysis model coefficients (C, alpha, beta) were treated as fixed at literature nominal values rather than as uncertain inputs, which is a known limitation at MRL 5. Prediction intervals on NIH are reported at the 5th and 95th percentiles."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be documented with lot numbers, preparation protocols, and storage conditions. For blood analog fluids, the rheological properties must be measured and reported for each test batch.",
      "rationale": "The FDA benchmark used a glycerol-water blood analog. Batch preparation protocols are documented in the FDA dataset metadata. Rheological measurements (viscosity at 37°C) are reported for two of the five test batches; the remaining three batches used nominal values from literature. Inter-batch variability in viscosity was not quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, boundary conditions, fluid properties) must be shown to be equivalent to the experimental conditions used for validation, with any discrepancies quantified and assessed for their impact on the quantity of interest.",
      "rationale": "CAD geometry used in CFD was derived from the FDA benchmark STL file with no modifications. Boundary conditions were set to match experimental conditions within measurement uncertainty. Fluid properties were matched to the glycerol-water analog rheological measurements. No significant discrepancies were identified between simulation inputs and experimental conditions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors, the assessment team determined that the overall credibility evidence is sufficient to support the intended use under COU2 conditions, with noted gaps in numerical solver error (Lagrangian convergence) and model form sensitivity documented for remediation. The Monte Carlo UQ provides quantified prediction intervals on hemolysis index, and the achieved levels across the majority of factors are within one gradation of the required levels at MRL 5. The team accepts the submission with conditions requiring Lagrangian particle convergence study completion prior to regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
