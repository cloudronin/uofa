      "name": "Bench-scale hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions across 5 flow-speed operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037671",
