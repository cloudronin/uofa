  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single shortfall (Test conditions, Gradation 1 vs. required 2) is offset by the high consistency of results across two independent laboratories and the direct applicability of the ASTM F1717 protocol to the COU. All three QoIs satisfy the pre-established quantitative acceptance criteria (percent difference < 10%, E/uval < 1.96). The overall evidence package is judged sufficient to support a Medium assurance-level conclusion that the FEA framework reliably predicts compression-bending performance of the non-cannulated pedicle screw construct.",
