  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) is below required level at Gradation 1 vs. required Gradation 2; this is accepted given ASTM F1717 prescribes a single standard test configuration and the clinical loading envelope is bounded by this configuration. All three QoIs meet pre-specified acceptance bounds. Overall credibility assessed as sufficient to support Medium assurance level decision for 510(k) submission. Note: aleatory uncertainty for force-at-40mm QoI was characterised qualitatively; formal structured UQ was not completed for that result.",
