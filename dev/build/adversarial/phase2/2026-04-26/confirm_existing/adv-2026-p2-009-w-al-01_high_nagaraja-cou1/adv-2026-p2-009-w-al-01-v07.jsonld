    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/nagaraja/vr/construct-stiffness",
      "type": "ValidationResult",
      "name": "Construct stiffness QoI comparison — FEA vs. bench (N=11)",
      "description": "FEA-predicted construct stiffness compared against experimental measurements from N=11 specimens across two laboratories. Mean error 4.2%, E/uval = 0.87, within the <10% and <1.96 acceptance bounds.",
      "hasUncertaintyQuantification": "https://uofa.net/nagaraja/uq/stiffness-combined-uq"
    },
    {
      "id": "https://uofa.net/nagaraja/vr/yield-force",
      "type": "ValidationResult",
      "name": "Yield force QoI comparison — FEA vs. bench (N=11)",
      "description": "FEA-predicted yield force compared against experimental measurements. Mean error 6.8%, E/uval = 1.41, within acceptance bounds. Uncertainty propagation performed via Monte Carlo on material property distributions.",
      "hasUncertaintyQuantification": "https://uofa.net/nagaraja/uq/yield-force-monte-carlo-uq"
    },
    {
      "id": "https://uofa.net/nagaraja/vr/force-at-40mm",
      "type": "ValidationResult",
      "name": "Force at 40 mm displacement QoI comparison — FEA vs. bench (N=11)",
      "description": "FEA-predicted force at 40 mm displacement compared against experimental measurements. Mean error 7.3%, within the <10% acceptance bound. Inherent variability in large-displacement post-yield response was assessed qualitatively by the modeling team based on observed scatter across the two laboratories; no structured uncertainty quantification node was linked to this result. The qualitative assessment concluded that specimen-to-specimen geometric variability and friction coefficient uncertainty are the dominant aleatory contributors, but these were not formally propagated through the model."
    }
  ],
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
