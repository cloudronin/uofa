  "signature": "ed25519:9b1e4a7c2f8d3e6b0a5c9f2d4e7b1a3c8f5e2d9b6a4c1f7e3d0b8a5c2f9e6d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software used under institutional quality management system with version control, issue tracking, and documented validation tests for linear static structural analyses.",
      "rationale": "Ansys Mechanical 2022 R2 operated under FDA CDRH computational modeling group QMS. Software validation records demonstrate correct solution of benchmark problems per NAFEMS standards. Version control via Git with tagged release; all analyst changes peer-reviewed prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification against known analytical solutions for beam bending and contact mechanics; residuals below 1e-6 for all solution increments.",
      "rationale": "Cantilever beam benchmark and Hertzian contact patch benchmark executed in the same Ansys environment. Maximum deviation from analytical solution 0.3% for bending stiffness and 1.1% for contact pressure distribution. Residual convergence criterion 1e-8 applied throughout."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change less than 2% between medium and fine mesh; Richardson extrapolation applied to estimate discretization error.",
      "rationale": "Three-level mesh refinement study conducted on the pedicle screw-rod construct: coarse (42k elements), medium (118k elements), fine (310k elements). Stiffness QoI changes 1.4% from medium to fine. Richardson extrapolation yields GCI of 0.8% for fine mesh. Production mesh uses medium density with confirmed convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Direct sparse solver employed; iterative convergence not applicable. Force and displacement residuals monitored per increment.",
      "rationale": "Ansys sparse direct solver (SPARSE) used for all production runs, eliminating iterative convergence error. Nonlinear Newton-Raphson force residual criterion set to 0.1% of applied load. All load steps converged within 15 substeps with no bisection failures."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup; boundary conditions, material assignments, and contact definitions verified against test protocol documentation.",
      "rationale": "Secondary analyst independently reconstructed boundary conditions from the ASTM F1717 test protocol and compared against production model settings. All contact pairs, material property assignments, and load application points confirmed consistent. One minor discrepancy in rod-setscrew torque preload resolved prior to final runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model (bilinear isotropic hardening) validated for Ti-6Al-4V at quasi-static rates; contact formulation (augmented Lagrangian) appropriate for metal-on-metal interfaces.",
      "rationale": "Bilinear isotropic hardening parameters for Ti-6Al-4V (E=114 GPa, sigma_y=880 MPa, Et=1.2 GPa) derived from ASTM E8 tensile coupon data from same material lot as test constructs. Augmented Lagrangian contact with friction coefficient 0.2 (measured via tribometer on same surface finish). Model form uncertainty estimated at ±4% on yield force QoI based on sensitivity to hardening tangent modulus."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and geometric dimensions measured from production hardware; input distributions characterised with at least 10 samples per parameter.",
      "rationale": "Dimensional measurements performed on 11 production screws and rods using CMM (Zeiss Contura). Material tensile properties measured on 12 coupons from same Ti-6Al-4V bar stock. Input uncertainty propagated through model via one-at-a-time sensitivity analysis and Monte Carlo sampling. Dominant input uncertainty is rod diameter (CV 0.8%) contributing 2.1% uncertainty to stiffness QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lots; specimens characterised dimensionally and by material certificate prior to testing.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production hardware (Lot 2021-NC-75-A). Each construct dimensionally characterised by CMM prior to testing. Material certificates confirm Ti-6Al-4V ELI Grade 23 for all components. Specimens distributed across two independent laboratories (Lab A: n=6, Lab B: n=5) to assess inter-laboratory reproducibility."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate COU loading environment; multiple load levels or configurations tested.",
      "rationale": "Testing performed under ASTM F1717 standard conditions (compression-bending, 10 mm offset, quasi-static 5 mm/min crosshead rate, room temperature). Only a single test configuration was employed; no variation in loading offset or rate was explored. This results in achieved level 2 against a required level 3, representing the one identified gap in this credibility assessment. The gap is accepted given that the single condition is the regulatory standard condition and model predictions are validated at that condition."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs demonstrably matched to measured test specimen parameters; traceability documented for each specimen-model pair.",
      "rationale": "Per-specimen FEA models created using CMM-measured dimensions for each of the 11 constructs. Material properties assigned from tensile coupon measurements on same lot material. Boundary condition equivalency confirmed by comparing measured machine compliance with modelled fixture stiffness. Traceability matrix linking each specimen ID to its corresponding FEA input file maintained in the project record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 applied to all three QoIs; percent difference < 10% for each QoI.",
      "rationale": "E/uval computed per ASME V&V 40 Section 5.3 for stiffness (0.81), yield force (1.42), and force at 40 mm (1.61). All values below the 1.96 threshold. Percent differences are 4.2%, 6.8%, and 7.5% respectively, all within the 10% acceptance bound. Comparison performed at the pooled mean level across both laboratories; inter-laboratory bias assessed separately and found to be within combined measurement uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes and regulatory submission requirements; mapping from QoI to COU decision documented.",
      "rationale": "Three QoIs (construct stiffness, yield force, force at 40 mm displacement) are the primary outputs required by ASTM F1717 and referenced in FDA guidance for spinal pedicle screw 510(k) submissions. Stiffness relates to load-sharing with the vertebral column; yield force indicates onset of permanent deformation; force at 40 mm represents post-yield energy absorption. All three directly inform the accept/reject decision for the non-cannulated design."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, material, loading, and boundary conditions match COU; any differences explicitly justified.",
      "rationale": "Validation activity uses the identical non-cannulated 7.5 mm pedicle screw geometry, same Ti-6Al-4V material lot, same ASTM F1717 test fixture configuration, and same loading rate as the COU. Both validation and COU concern the static compression-bending submission test. No extrapolation beyond the validated domain is required for the COU decision. The validation activity is assessed as directly applicable with no domain gap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All three QoIs meet the pre-established quantitative acceptance criteria (E/uval < 1.96; percent difference < 10%). Twelve of thirteen credibility factors meet or exceed required levels. The single gap (Test conditions, achieved 2 vs. required 3) is accepted because the single test condition evaluated is the regulatory standard condition specified by ASTM F1717 and FDA guidance, and the model is validated at precisely the condition relevant to the COU decision. The overall credibility evidence is assessed as sufficient to support a Medium assurance level conclusion that the FEA framework adequately predicts non-cannulated pedicle screw compression-bending performance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
