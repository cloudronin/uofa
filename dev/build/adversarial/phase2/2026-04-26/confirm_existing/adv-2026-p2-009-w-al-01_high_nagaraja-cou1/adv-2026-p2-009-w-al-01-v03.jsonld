  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 compression-bending is the sole regulatory test configuration for this device class and no additional test conditions are practicable or required. Validation metric E/uval < 1.96 satisfied for all three QoIs. Note: aleatory variability in yield force was assessed qualitatively by the modeling team based on observed specimen scatter; a structured uncertainty quantification node was not linked to the yield force ValidationResult, representing a documentation gap to be addressed in the next revision cycle.",
