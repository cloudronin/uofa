    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Newton-Raphson residual convergence tolerance set to 1×10⁻⁴ for force and 1×10⁻⁵ for displacement. Energy balance monitored at each increment; artificial energy remained below 1% of internal energy throughout all simulations. Time-step sensitivity study confirmed load-increment independence for increments ≤0.02 of total applied displacement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Independent model review performed by a second analyst not involved in model construction. Boundary conditions, material assignments, and contact definitions verified against the documented modeling protocol. Discrepancies identified in two contact pair friction coefficients were corrected prior to validation runs. Review checklist archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Isotropic elastic-plastic Ti-6Al-4V constitutive model with bilinear hardening selected based on published literature and validated against coupon tensile data. Nonlinear geometry (NLGEOM) enabled to capture large-displacement bending. Frictionless and frictional (μ=0.2) contact variants compared; frictional model reduced stiffness prediction error from 4.1% to 1.2%. Model form uncertainty acknowledged for polyaxial head locking mechanism idealization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Geometric inputs derived from CMM measurements of three production screws (mean ± 1σ reported). Material properties sourced from ASTM F136 certificate of conformance and supplemented by in-house tensile coupon testing (n=5). Rod diameter and UHMWPE block dimensions measured per ASTM F1717 fixture specification. Input parameter uncertainty ranges documented and used in Monte Carlo and LHS propagation studies."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab 1: n=6, Lab 2: n=5). All specimens from the same production lot; lot traceability documented. Inter-laboratory coefficient of variation for construct stiffness was 4.7%, within acceptable limits for ASTM F1717 testing. Sample size deemed sufficient for the medium model risk level per ASME V&V 40 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed under a single test condition (ASTM F1717 standard configuration: 50 mm intervertebral gap, 10°/s displacement rate, ambient temperature). Only one loading configuration evaluated; no parametric variation of gap distance or loading rate. This factor falls below the required level of 3, representing a known gap acknowledged in the credibility assessment. The deficiency is mitigated by the direct correspondence of the single condition to the intended COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA model inputs (screw geometry, rod diameter, block dimensions, material properties) confirmed equivalent to as-tested specimen parameters via CMM measurement traceability. Friction coefficient in the model (μ=0.2) consistent with published Ti-Ti tribology data under dry contact conditions representative of the test environment. Boundary condition equivalency verified by comparing predicted and measured fixture compliance contributions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Three scalar QoIs compared: construct stiffness, yield force, and force at 40 mm displacement. Validation metric E/uval computed per ASME V&V 40 Eq. 5.4, incorporating experimental uncertainty (uexp from inter-specimen CV) and numerical uncertainty (unum from mesh convergence and solver tolerance studies). All three E/uval values below 1.96 acceptance threshold. Percentage differences also below the 10% pre-specified bound."
    },
