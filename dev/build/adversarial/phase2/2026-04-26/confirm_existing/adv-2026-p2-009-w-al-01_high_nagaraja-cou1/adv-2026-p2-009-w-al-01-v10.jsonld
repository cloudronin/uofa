  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility level. One factor (Test conditions) achieves Gradation 2 against a required Gradation 3; this gap is accepted based on the standardized nature of ASTM F1717 and regulatory precedent. Validation metrics (E/uval <1.96, percent difference <10%) satisfied for all three QoIs across all 11 specimens and both laboratories. Overall credibility profile supports Medium assurance level appropriate for a Class II device with medium model influence and medium decision consequence. The FEA modeling framework is accepted as sufficiently credible for the stated COU.",
