  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA solver (Ansys Mechanical) holds current ISO 9001 certification; internal SQA procedures documented and version-controlled.",
      "rationale": "Ansys Mechanical 2022 R2 used for all simulations. Software holds ISO 9001 certification. DePuy Synthes internal SQA procedure SOP-FEA-001 documents version control, regression testing, and release qualification. FDA CDRH team independently verified solver installation against Ansys qualification test suite. Achieved Gradation 2 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 suite reproduced to within solver tolerance; patch test passed for all element types employed.",
      "rationale": "Patch test and NAFEMS benchmark LE1 executed for the hex-dominant mesh employed in the pedicle screw model. All results within 0.5% of analytical solutions. Element formulations (SOLID186, CONTA174) verified against published reference solutions. Code verification requirements at Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in all QoIs between medium and fine mesh; Richardson extrapolation applied to quantify discretization uncertainty.",
      "rationale": "Three-level mesh refinement study conducted (coarse: 85k elements, medium: 210k elements, fine: 510k elements). QoI changes between medium and fine meshes: stiffness 0.8%, yield force 1.1%, force at 40 mm 0.9%. Richardson extrapolation applied; GCI < 1.5% for all QoIs. Medium mesh selected for production runs. Gradation 3 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear solver convergence criteria tightened to force residual <1e-4 and displacement residual <1e-4; energy balance error <0.1%.",
      "rationale": "Nonlinear static analysis with large-deflection enabled. Convergence criteria set to L2 norm force residual <1e-4 and displacement residual <1e-4. All load steps converged within 15 equilibrium iterations. Energy balance monitored; maximum error 0.04%. Automatic time-stepping with bisection enabled for contact stabilization. Gradation 2 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by second analyst; documented checklist of boundary conditions, material assignments, and contact definitions.",
      "rationale": "Model setup reviewed by independent FDA analyst not involved in original model construction. Checklist covering 47 items (boundary conditions, material assignments, contact pairs, load application points, output requests) completed and signed. One minor discrepancy in rod end-cap constraint found and corrected before validation runs. Gradation 2 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model (bilinear isotropic hardening Ti-6Al-4V) validated against published coupon test data; contact formulation captures screw-rod interface slip observed experimentally.",
      "rationale": "Bilinear isotropic hardening model for Ti-6Al-4V calibrated against ASTM E8 coupon data (n=6 coupons, same material lot as implants). Augmented Lagrange contact formulation used at screw-rod and rod-set-screw interfaces; frictional coefficient 0.25 from literature. Model correctly captures the experimentally observed slip at the rod-screw interface prior to yield. Gradation 3 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Geometric inputs derived from CMM measurements of test specimens; material inputs from lot-specific tensile testing; assembly torque from calibrated torque wrench records.",
      "rationale": "Screw and rod geometry input from CMM measurements of three representative specimens per lot; dimensional variation <0.05 mm. Material properties (E, sigma_y, sigma_u, tangent modulus) from lot-specific ASTM E8 tensile tests. Assembly torque applied in model matches calibrated torque wrench records (mean 6.0 Nm, SD 0.15 Nm). Polyaxial screw head seating depth from optical measurement. Gradation 3 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lots; geometry and material properties measured per specimen and reported; two independent laboratories provide independent replication.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs tested: 6 at Laboratory A (FDA), 5 at Laboratory B (DePuy Synthes). All constructs from production lots; each specimen measured by CMM and material lot traced. Inter-laboratory reproducibility assessed via Bland-Altman analysis; no systematic bias detected. Sample size sufficient for Gradation 3 per ASME V&V 40 guidance table."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two loading configurations or two fixation heights representative of the COU; environmental conditions controlled and recorded.",
      "rationale": "Testing performed at a single ASTM F1717 standard configuration (fixed 40 mm inter-pedicular distance, room temperature, displacement-controlled at 5 mm/min). Environmental conditions (temperature 23±2°C, humidity 45±10% RH) recorded throughout. Only one test condition evaluated; multiple loading configurations or fixation heights not included in this study. Achieved level 2 versus required level 3; accepted as low-risk gap given the standardized nature of F1717 and the regulatory precedent for single-configuration validation of this device type."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Specimen-specific model inputs (geometry, material, assembly torque) matched to corresponding test specimen measurements; traceability documented.",
      "rationale": "Each of the 11 FEA models built using specimen-specific CMM geometry and lot-specific material data. Assembly torque applied in each model matched to the torque wrench record for that specific construct. Traceability matrix linking specimen ID to model input file and test data file maintained in the study record. Equivalency confirmed for all 11 specimen-model pairs. Gradation 3 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric E/uval computed for all three QoIs; percent difference reported; both metrics within pre-established acceptance bounds.",
      "rationale": "Validation metric E/uval computed per ASME V&V 20 for each QoI: stiffness (max E/uval 1.43), yield force (max E/uval 1.61), force at 40 mm (max E/uval 1.78). All values below 1.96 threshold. Percent differences: stiffness mean 4.2% (max 8.1%), yield force mean 3.8% (max 7.4%), force at 40 mm mean 5.1% (max 9.3%). All within <10% acceptance bound. Gradation 3 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly linked to regulatory submission requirements and clinical failure modes; mapping documented.",
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are the primary endpoints specified in FDA guidance for pedicle screw mechanical testing submissions and directly correspond to the ASTM F1717 standard reporting requirements. Stiffness relates to load-sharing with the fusion mass; yield force and force at 40 mm relate to fatigue and ultimate failure risk. Clinical relevance mapping documented in the study protocol. Gradation 3 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, material, and loading conditions match the COU device geometry and intended use loading; any differences documented and bounded.",
      "rationale": "Validation performed on the exact non-cannulated 7.5 mm pedicle screw design intended for submission. ASTM F1717 test configuration matches the COU loading mode (compression-bending representing in vivo spinal loading). Test specimens from production lots identical to commercial product. The single test condition gap (Test conditions factor, Gradation 2) is the only identified difference; bounded analysis confirms this does not materially affect the validation conclusions. Gradation 3 requirements satisfied."
    }
  ],
