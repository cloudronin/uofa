  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-rh-benchmark-5op-points",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against in-vitro benchmark — 5 operating points",
      "description": "CFD-predicted relative hemolysis index (RH) was compared against in-vitro measurements at five flow-speed combinations (2 L/min at 2500 RPM, 4 L/min at 2500 RPM, 2 L/min at 3500 RPM, 4 L/min at 3500 RPM, and 6 L/min at 3500 RPM). The simulation campaign used the power-law hemolysis model (Giersiepen et al. 1990, recalibrated by Heuser and Opitz 1980 constants) implemented in ANSYS Fluent 2022R2. Mesh independence was confirmed at 4.2 million polyhedral cells (GCI < 2.1% on RH). Blood rheology was modelled as a non-Newtonian Carreau fluid with hematocrit 40%. Predicted RH values ranged from 0.61 to 0.94 across the five conditions, all below the acceptance threshold of RH < 1.0. Mean absolute error against the in-vitro reference dataset was 8.3%, within the pre-specified tolerance of 15%. The experimental reference data were collected by the Morrison laboratory at three independent test sessions using a standardised modified index of hemolysis (MIH) protocol, with inter-session coefficient of variation of 4.7%. Statistical agreement was assessed using Bland-Altman analysis; all differences fell within ±1.96 SD limits of agreement. This result constitutes the primary quantitative validation evidence for the COU1 claim that CFD can identify worst-case hemolysis operating conditions. The breadth of the operating envelope tested, the independent experimental replication, and the conservative acceptance criterion collectively support a high degree of confidence in the model's predictive fidelity for the intended use.",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-hemolysis-experimental-rh-measurements"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pump pressure rise validation at nominal operating point",
      "description": "Predicted pump pressure rise at the nominal operating condition (4 L/min, 3000 RPM) was compared against manufacturer-supplied performance curve data. CFD predicted 87.4 mmHg versus measured 85.1 mmHg, a relative error of 2.7%, well within the 10% acceptance criterion.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/morrison-pressure-validation-run-2023-09"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-wall-shear-stress-piv-comparison",
      "type": "ValidationResult",
      "name": "Wall shear stress field comparison against PIV measurements",
      "description": "Near-wall velocity gradients derived from CFD were compared against particle image velocimetry (PIV) data collected in a scaled acrylic pump model at matched Reynolds number. Spatial correlation coefficient R = 0.91 across the impeller passage; peak WSS prediction error was 11.4% at the blade leading edge, within the pre-specified 15% tolerance.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/morrison-piv-comparison-activity-2023-11"
