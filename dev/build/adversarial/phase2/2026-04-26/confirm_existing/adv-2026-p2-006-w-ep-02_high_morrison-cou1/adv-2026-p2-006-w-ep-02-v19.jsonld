      "type": "ValidationResult",
      "name": "Pump Pressure Head Validation at Nominal Operating Conditions",
      "description": "Predicted pump pressure head at nominal flow conditions compared against manufacturer-supplied performance curves. CFD predictions fell within 8% of measured values across the operating range.",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-operating-condition-matrix",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/morrison-pressure-head-cfd-run-2023"
    },
