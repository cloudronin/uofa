    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence verification — coarse/medium/fine grid convergence",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/morrison-act-mesh-convergence-study-2023",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-cfd-mesh-convergence-study"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-experimental-hemolysis-comparison",
      "type": "ValidationResult",
      "name": "Quantitative comparison of CFD-predicted normalized index of hemolysis (NIH) against FDA pump experimental measurements across all five operating points",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-fda-pump-experimental-hemolysis",
      "description": "A comprehensive validation exercise was performed in which CFD-predicted NIH values were computed for the FDA generic centrifugal blood pump geometry at five flow-speed operating conditions (2 L/min at 2500 RPM, 4 L/min at 2500 RPM, 4 L/min at 3500 RPM, 6 L/min at 3500 RPM, and 6 L/min at 4500 RPM). Scalar power-law hemolysis accumulation was integrated along Lagrangian particle trajectories released uniformly from the inlet plane. Predicted NIH values ranged from 0.0021 to 0.0087 g/100 L across the five conditions. Experimental NIH measurements obtained from the FDA CDRH interlaboratory study (n=6 independent laboratories) ranged from 0.0019 to 0.0091 g/100 L. Agreement was quantified using the relative hemolysis index RH, with all five operating points yielding RH < 1 relative to the predicate device benchmark. The maximum absolute percent error across all operating points was 14.3%, falling within the pre-specified acceptance band of ±20%. Uncertainty in the experimental reference data (inter-laboratory coefficient of variation 18–23%) was accounted for in the acceptance determination. The validation team concluded that model predictive accuracy is sufficient to support the COU decision at MRL 2."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-software-qa-benchmark",
      "type": "ValidationResult",
      "name": "ANSYS Fluent 2022R2 benchmark suite execution — lid-driven cavity and pipe flow verification cases",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/morrison-act-software-qa-benchmark-2023",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-operating-point-matrix"
    }
