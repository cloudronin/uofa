  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-rh-index-comparison-5op",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison across five operating conditions",
      "description": "The primary validation result for COU1. CFD-predicted relative hemolysis index (RH) values were computed at all five flow-speed operating points (2 L/min at 2500 RPM, 3 L/min at 2750 RPM, 4 L/min at 3000 RPM, 5 L/min at 3250 RPM, and 6 L/min at 3500 RPM) and compared against in-vitro hemolysis measurements obtained using the modified ASTM F1841 protocol with porcine blood. The CFD model employed the power-law hemolysis damage accumulation model (Giersiepen–Wurzinger coefficients) integrated along Lagrangian particle trajectories seeded uniformly at the pump inlet. Mesh independence was confirmed at 4.2 million polyhedral cells (Richardson extrapolation GCI < 2.1% for all QoIs). Turbulence was modelled with the SST k-ω formulation; near-wall resolution maintained y+ < 1 throughout. Experimental measurements were conducted in triplicate per operating point; the coefficient of variation across replicates did not exceed 8.3%. Predicted RH values ranged from 0.61 to 0.89 across operating points, remaining below the acceptance threshold of RH < 1 in all cases. The maximum absolute relative error between CFD prediction and experimental mean was 14.7%, observed at the 2 L/min condition where recirculation zone extent is most sensitive to inlet boundary condition specification. All other operating points showed agreement within 9%. The worst-case operating condition was identified as 2 L/min at 2500 RPM, consistent with experimental observations. This result provides the principal quantitative evidence supporting the credibility claim. The analysis was performed by the Morrison CFD team during Q3 2024 using ANSYS Fluent 2023 R2 on a 128-core HPC cluster; full simulation logs, boundary condition files, and post-processing scripts are archived in the project repository under revision tag v1.4.2.",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-fda-pump-experimental-hemolysis"
    },
