  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-rh-index-comparison-primary",
      "type": "ValidationResult",
      "name": "Primary RH index validation against FDA pump experimental data",
      "description": "This validation result constitutes the central evidentiary pillar of the COU1 credibility case. The CFD model was exercised across all five flow-speed operating points (2.5 L/min at 2500 RPM, 3.5 L/min at 3000 RPM, 4.5 L/min at 3500 RPM, 5.5 L/min at 3500 RPM, and 6.5 L/min at 4000 RPM) using the power-law hemolysis damage accumulation model (Giersiepen et al. 1990 coefficients). Predicted normalized index of hemolysis (NIH) values were compared against the FDA benchmark experimental dataset for the generic centrifugal pump geometry. Across all five operating points the model returned RH values ranging from 0.71 to 0.94, each below the acceptance threshold of RH < 1. The maximum absolute deviation between CFD-predicted NIH and measured NIH was 18.3%, well within the ±25% tolerance band specified in the validation plan. Scalar error metrics (MAPE = 11.4%, RMSE = 0.031 g/100 L) were computed using the full five-point dataset. The simulation campaign was conducted using ANSYS Fluent 2022 R2 with a 4.8 million element polyhedral mesh, k-ω SST turbulence closure, and a fixed-rotor frozen-rotor MRF approximation for the impeller region. Convergence was confirmed by monitoring mass-weighted average shear stress at the outlet plane over 3000 solver iterations until residuals fell below 1×10⁻⁵. The complete simulation log files, post-processing scripts, and comparison spreadsheets are archived in the project repository under tag v1.4.2 and are available for audit upon request. The level of agreement observed across operating conditions provides high confidence that the model correctly rank-orders hemolysis severity, supporting its use for worst-case identification.",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-hemolysis-experimental-reference"
    },
