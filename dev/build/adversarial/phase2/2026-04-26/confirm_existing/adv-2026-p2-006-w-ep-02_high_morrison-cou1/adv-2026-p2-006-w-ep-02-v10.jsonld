  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/rh-index-comparison-5pt",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison across 5 flow-speed operating points",
      "description": "CFD-predicted relative hemolysis index (RH) values were compared against in-vitro experimental measurements at five flow-speed combinations (2 L/min at 2500 RPM, 3 L/min at 2800 RPM, 4 L/min at 3200 RPM, 5 L/min at 3500 RPM, and 6 L/min at 3800 RPM). The experimental campaign was conducted in the Morrison laboratory using the FDA generic centrifugal pump geometry with porcine blood at 37°C and controlled hematocrit of 33±2%. The Giersiepen-Wurzinger power-law hemolysis model was applied to Lagrangian particle trajectories seeded at the inlet. All five operating points yielded RH < 1 relative to the predicate device reference, with a mean absolute error of 0.038 RH units and a maximum deviation of 0.071 RH units at the 6 L/min condition. The experimental uncertainty band (±1 standard deviation across three replicate runs) encompassed the CFD prediction at four of five points; the 6 L/min outlier was attributed to recirculation-zone sensitivity at high impeller speed. Statistical agreement was assessed using a two-sided 95% confidence interval on the mean bias, confirming that systematic model error does not exceed the 0.10 RH threshold established in the acceptance criteria. This result constitutes the primary validation evidence for the COU and underpins the credibility conclusion at MRL 2.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-experimental-hemolysis"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-gci",
      "type": "ValidationResult",
      "name": "Grid convergence index assessment for hemolysis-sensitive mesh regions",
      "description": "Three systematically refined hexahedral meshes (coarse: 4.1M cells, medium: 11.3M cells, fine: 30.8M cells) were generated for the FDA pump geometry. GCI values were computed per Celik et al. (2008) for the volume-averaged shear stress scalar and the recirculation-zone extent at the 4 L/min, 3200 RPM operating point. The fine-to-medium GCI was 1.4% for shear stress and 2.1% for recirculation extent, confirming asymptotic convergence. The medium mesh was selected as the production mesh balancing accuracy and computational cost.",
      "comparedAgainst": "https://uofa.net/synth/data/cfd-mesh-convergence-study",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/gci-computation-2024-09"
    },
    {
      "id": "https://uofa.net/synth/validation/solver-verification-mms",
      "type": "ValidationResult",
      "name": "Method of manufactured solutions verification for Navier-Stokes solver",
      "description": "The incompressible Navier-Stokes solver (OpenFOAM v2312) was verified using the method of manufactured solutions on a structured 3D domain. Spatial convergence orders of 1.97 (velocity) and 1.94 (pressure) were observed on meshes ranging from 8×8×8 to 64×64×64 cells, consistent with the expected second-order accuracy of the finite-volume discretization.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mms-verification-2024-07"
    }
