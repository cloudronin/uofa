  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/rh-index-comparison-5ops",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Comparison — 5 Operating Points",
      "description": "CFD-predicted relative hemolysis index (RH) values were computed across all five flow-speed operating points (2 L/min at 2500 RPM, 3 L/min at 3000 RPM, 4 L/min at 3500 RPM, 5 L/min at 4000 RPM, and 6 L/min at 4500 RPM). Experimental hemolysis measurements were obtained from a dedicated in-vitro loop test using bovine blood with hematocrit 35±2% at 37°C, conducted over a 6-hour recirculation period per ASTM F1841 guidance. The power-law hemolysis model (Giersiepen-Wurzinger coefficients) was applied to Lagrangian particle tracks seeded uniformly at the inlet plane. RH values ranged from 0.61 to 0.89 across all operating points, with the worst-case condition identified at 2 L/min and 2500 RPM (RH = 0.89). All predicted RH values remained below the acceptance threshold of 1.0, and agreement with experimental normalized index of hemolysis (NIH) values was within 18% across all conditions. Grid-converged solutions on the 14.2 million cell polyhedral mesh were used for all reported comparisons. Turbulence was modeled with the SST k-omega closure; near-wall y+ values were maintained below 1.0 at all impeller surfaces. The simulation campaign was executed on the FDA high-performance computing cluster between October and December 2024, with results reviewed and approved by the lead biofluid mechanics engineer prior to submission. This result constitutes the primary quantitative evidence supporting the credibility claim that the CFD model correctly identifies worst-case hemolysis operating conditions for the subject device class.",
      "comparedAgainst": "https://uofa.net/morrison/data/hemolysis-experimental-reference"
    },
    {
      "id": "https://uofa.net/morrison/validation/grid-convergence-gci",
      "type": "ValidationResult",
      "name": "Grid Convergence Index Study — Impeller Passage",
      "description": "Three systematically refined meshes (3.1M, 8.7M, 14.2M cells) were assessed using the Grid Convergence Index method per Celik et al. (2008). GCI values for hemolysis index were below 4.2% on the fine-to-medium pair, confirming discretization error is within acceptable bounds for MRL 2.",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/gci-mesh-refinement-study-2024"
    },
    {
      "id": "https://uofa.net/morrison/validation/solver-verification-benchmark",
