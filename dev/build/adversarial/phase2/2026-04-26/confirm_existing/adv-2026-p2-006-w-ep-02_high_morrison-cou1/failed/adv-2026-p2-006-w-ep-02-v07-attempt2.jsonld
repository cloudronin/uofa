  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/rh-index-5pt-comparison",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index — 5-point flow-speed sweep comparison",
      "description": "CFD-predicted relative hemolysis index (RH) was compared against in-vitro measurements at five flow-speed operating points (2 L/min/2000 RPM, 3 L/min/2500 RPM, 4 L/min/3000 RPM, 5 L/min/3500 RPM, 6 L/min/4000 RPM). The simulation campaign was executed using ANSYS Fluent 2023 R2 on a 12.4 M element polyhedral mesh after grid-convergence confirmation at GCI < 2.1 % across all quantities of interest. Blood rheology was modelled using the Carreau–Yasuda non-Newtonian viscosity model with parameters fitted to donor-pooled whole blood at 37 °C. Hemolysis accumulation was computed via the Giersiepen–Wurzinger power-law scalar transport model integrated along Lagrangian particle tracks (N = 50 000 per operating point). Experimental data were collected at the Morrison Laboratory using a modified NIH hemolysis protocol; plasma-free haemoglobin was measured by the cyanmethaemoglobin method with a coefficient of variation < 3 % across triplicate runs. Predicted RH values ranged from 0.61 to 0.94 across the five points; all remained below the RH < 1 acceptance threshold. Mean absolute percentage error between CFD and experiment was 8.3 %, within the pre-specified 15 % validation tolerance. The worst-case operating point was identified at 2 L/min/2000 RPM (RH = 0.94), consistent with experimental observation (RH = 0.91 ± 0.04). This result provides primary validation evidence supporting the credibility claim. The detailed simulation log, mesh files, and experimental raw data are archived in the Morrison Lab data repository under accession MRR-2024-CPB-001.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-generic-pump-experimental-hemolysis"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-rise-verification",
      "type": "ValidationResult",
      "name": "Pump pressure-rise verification against manufacturer bench data",
      "description": "Simulated pump pressure rise across the five operating points was compared against manufacturer-supplied hydraulic bench-test data. Agreement within 5 % at all points confirms correct boundary-condition implementation.",
      "comparedAgainst": "https://uofa.net/synth/data/manufacturer-hydraulic-bench-cpb",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/pressure-verification-run-2024-03"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Grid convergence index study — hemolysis scalar transport",
      "description": "Three systematically refined meshes (4.1 M, 8.6 M, 12.4 M elements) were evaluated. GCI values for the hemolysis index QoI were 4.8 %, 2.4 %, and 2.1 %, demonstrating asymptotic convergence. The 12.4 M mesh was selected for all validation runs.",
      "comparedAgainst": "https://uofa.net/synth/data/cpb-flow-speed-combinations-5pt",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-convergence-study-2024-02"
    }
  ],
