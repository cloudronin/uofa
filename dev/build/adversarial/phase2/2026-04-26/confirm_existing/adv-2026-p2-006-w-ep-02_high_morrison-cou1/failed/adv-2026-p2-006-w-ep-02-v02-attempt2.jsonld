  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-rh-index-5flow-primary",
      "type": "ValidationResult",
      "name": "Primary relative hemolysis index validation across 5 flow-speed operating points",
      "description": "This result represents the central validation finding of the COU1 assessment. CFD-predicted hemolysis indices were computed for all five flow-speed combinations (2 L/min at 2500 RPM, 3 L/min at 2500 RPM, 4 L/min at 2500 RPM, 5 L/min at 3000 RPM, and 6 L/min at 3500 RPM) and compared against in-vitro measurements collected on the FDA generic centrifugal blood pump test rig at the Morrison laboratory. The normalized index of hemolysis (NIH) was computed from sampled plasma free hemoglobin using the ASTM F1841 protocol. CFD predictions of the power-law hemolysis model (Giersiepen-Wurzinger coefficients) were post-processed using a Lagrangian particle-tracking approach with 5000 massless tracer particles per operating condition. Predicted RH values ranged from 0.71 to 0.94 across the five conditions, with a mean absolute error of 0.08 RH units relative to experimental measurements. All five operating points satisfied the acceptance criterion RH < 1.0, and the rank ordering of hemolysis severity across operating conditions was preserved by the CFD model (Spearman rho = 0.90). The in-vitro experiments were conducted under ISO 10993-4 guidance with three biological replicates per operating point; inter-replicate coefficient of variation was below 12% for all conditions. This comprehensive agreement between model predictions and experimental data, including preservation of the worst-case identification at 2 L/min / 2500 RPM, substantiates the model's fitness for the intended COU.",
      "comparedAgainst": "https://uofa.net/synth/data/cpb-operating-conditions-5flows"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence verification for pump CFD domain",
      "description": "Grid convergence index (GCI) study performed on three mesh refinement levels (coarse 1.2M cells, medium 4.8M cells, fine 19.2M cells). GCI for the hemolysis scalar at the pump outlet was 2.3% between medium and fine meshes, confirming discretization error is within acceptable bounds for MRL 2.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-gci-study-2024"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-rise-benchmark",
      "type": "ValidationResult",
      "name": "Pump pressure-rise curve validation against PIV benchmark data",
      "description": "CFD-predicted pump pressure rise was compared against particle image velocimetry (PIV) measurements from the FDA benchmark dataset for the generic centrifugal pump. Mean relative error across the five operating points was 4.7%, within the 10% acceptance threshold established for this factor.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/pressure-rise-piv-comparison-2024"
    }
  ],
