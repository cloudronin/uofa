  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/rh-index-comparison-primary",
      "type": "ValidationResult",
      "name": "Primary relative hemolysis index validation — FDA pump benchmark",
      "description": "This validation activity involved high-fidelity CFD simulation of the FDA generic centrifugal blood pump across all five target flow-speed operating points (2 L/min at 2500 RPM, 3 L/min at 2500 RPM, 4 L/min at 3500 RPM, 5 L/min at 3500 RPM, and 6 L/min at 4500 RPM). Hemolysis was quantified using the power-law damage accumulation model integrated over Lagrangian particle trajectories. The relative hemolysis index RH was computed by normalising predicted hemolysis against the predicate device experimental baseline obtained from in-vitro loop testing with porcine blood (n=6 donors, haematocrit 35±2%). Predicted RH values ranged from 0.71 to 0.93 across all operating points, satisfying the RH < 1 acceptance criterion. Mesh sensitivity was confirmed at 4.2 million polyhedral cells with less than 1.8% change in RH upon refinement to 8.1 million cells. Turbulence closure used the SST k-omega model with low-Reynolds-number wall treatment (y+ < 1). The simulation campaign was executed on the university HPC cluster over a three-week period in Q3 2025, with post-processing performed using an in-house Python pipeline v2.4 that applies the Giersiepen–Wurzinger power-law coefficients. All five operating points yielded RH below the acceptance threshold, providing strong quantitative agreement between the CFD predictions and the experimental hemolysis reference data. This result constitutes the primary evidence for model credibility in the COU.",
      "comparedAgainst": "https://uofa.net/morrison/data/hemolysis-experimental-rh-index"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-head-verification",
      "type": "ValidationResult",
      "name": "Pressure-head curve validation against published FDA experimental data",
      "description": "Predicted pump pressure-head curves compared against published FDA benchmark experimental measurements across the full flow range. Mean absolute error less than 4.2% across all operating points.",
      "comparedAgainst": "https://uofa.net/morrison/data/fda-pump-geometry-v2",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/pressure-head-cfd-campaign-q2-2025"
    },
    {
      "id": "https://uofa.net/morrison/validation/shear-stress-distribution",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution comparison — PIV benchmark",
      "description": "CFD-predicted wall shear stress distributions compared against particle image velocimetry (PIV) measurements from the FDA interlaboratory study. Qualitative and quantitative agreement confirmed in the impeller passage and volute regions.",
      "comparedAgainst": "https://uofa.net/morrison/data/fda-pump-geometry-v2",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/piv-shear-comparison-q1-2025"
    }
