  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/rh-index-5op-points",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index validation across five operating points — primary CFD-to-experiment comparison",
      "description": "CFD-predicted relative hemolysis index (RH) was compared against in-vitro experimental measurements for all five flow-speed combinations specified in the COU. Simulations were executed using a power-law hemolysis model (Giersiepen–Wurzinger coefficients) on a 4.2-million-element polyhedral mesh. Turbulent shear stress was resolved using the SST k-omega closure. Experimental measurements were obtained using a modified NIH hemolysis protocol with bovine blood at 37 °C, hematocrit 33 ± 2%. Across all five operating points the CFD-predicted RH values fell within ±12% of the measured values, and all predicted RH values satisfied the RH < 1 acceptance criterion. The worst-case operating point (6 L/min, 3500 RPM) yielded RH_CFD = 0.81 versus RH_exp = 0.76, a 6.6% over-prediction consistent with known conservative bias of the Giersiepen–Wurzinger coefficients. Statistical comparison used Bland–Altman analysis confirming no systematic bias beyond this known coefficient effect. This result constitutes the primary evidence for model validation under COU1 conditions.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-generic-pump-experimental"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-independence-check",
      "type": "ValidationResult",
      "name": "Mesh independence verification for hemolysis QoI",
      "description": "Three mesh refinement levels (2.1M, 4.2M, 8.6M elements) were compared for predicted RH at the nominal operating point (4.5 L/min, 3000 RPM). RH values converged to within 1.4% between the medium and fine meshes, confirming mesh-independent results at the 4.2M element level used for the primary validation.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-independence-study-2024"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-head-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-head validation at nominal conditions",
      "description": "Predicted pump pressure head (ΔP) was compared against manufacturer-supplied performance curves and independent experimental data at four operating points. Mean absolute error was 3.2%, within the acceptance threshold of 5% established for secondary QoIs. This result supports confidence that the flow field driving hemolysis prediction is accurately resolved.",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-cfd-simulation-outputs",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/pressure-head-validation-study-2024"
    }
  ],
