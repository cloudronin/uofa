  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/rh-index-5op-points",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Validation — 5 Operating Points",
      "description": "Detailed CFD-to-experiment comparison of the normalized index of hemolysis (NIH) and derived relative hemolysis index (RH) across all five flow-speed operating points specified in the COU. Simulations were executed using a k-omega SST turbulence closure on a 4.2-million-cell polyhedral mesh with second-order spatial discretization. Experimental hemolysis measurements were obtained using the modified hemolysis index protocol per ASTM F1841 on a physical replica of the FDA generic centrifugal pump manufactured to nominal dimensional tolerances. Three independent experimental runs were performed at each operating point; the ensemble mean and 95% confidence interval are reported. CFD predictions of NIH fell within the experimental confidence interval at 4 of 5 operating points, with the fifth point (2.5 L/min, 2500 RPM) showing a 7.3% over-prediction attributed to secondary flow separation near the volute cutwater, a known limitation of steady-state RANS at low-flow regimes. The composite RH metric remained below 1.0 at all operating points, satisfying the acceptance criterion. This result constitutes the primary quantitative evidence for model adequacy in the COU.",
      "comparedAgainst": "https://uofa.net/morrison/data/fda-generic-pump-experimental"
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-independence-study",
      "type": "ValidationResult",
      "name": "Mesh Independence Study — Grid Convergence Index",
      "description": "Three-level grid refinement study (1.1M, 4.2M, 11.8M cells) following the ASME V&V 20 GCI procedure. GCI on NIH at the design operating point (5 L/min, 2000 RPM) was 2.1%, within the 5% acceptance threshold.",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/mesh-refinement-study-2024q3"
    },
    {
