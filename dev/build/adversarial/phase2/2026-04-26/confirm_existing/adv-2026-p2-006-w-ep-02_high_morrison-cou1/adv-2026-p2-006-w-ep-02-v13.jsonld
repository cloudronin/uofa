  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-rh-index-benchmark",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Benchmark Against FDA Pump Experimental Data",
      "description": "The CFD model was exercised across all five target flow-speed operating points (2 L/min at 2500 RPM, 3 L/min at 2500 RPM, 4 L/min at 2500 RPM, 3 L/min at 3500 RPM, and 5 L/min at 3500 RPM). Scalar stress-based hemolysis was computed using the modified power-law model of Giersiepen et al. as adapted by Heuser and Opitz. Predicted normalised index of haemolysis (NIH) values were compared against the published experimental measurements from the FDA benchmark centrifugal pump study (Hariharan et al. 2011). Across all five operating points the model achieved a mean relative error of 8.3 % with a maximum point-wise deviation of 14.1 % at the 5 L/min, 3500 RPM condition. The relative hemolysis index RH remained below 1.0 for all nominal geometry variants, satisfying the acceptance criterion. Mesh sensitivity was confirmed at the 1.5 % level on the NIH quantity of interest. Turbulence closure was k-ω SST; near-wall y+ was maintained below 5 on all wetted surfaces. The complete simulation campaign was executed on a 128-core HPC cluster over a 72-hour wall-clock window using ANSYS Fluent 2022R2, with convergence declared at residual levels below 1×10⁻⁵ for all transport equations. Results were reviewed and signed off by two independent analysts prior to inclusion in this credibility package. The breadth and internal consistency of this campaign provides high confidence that the validation evidence is representative of the COU operating envelope.",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-fda-pump-experimental-hemolysis"
    },
