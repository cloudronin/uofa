      "comparedAgainst": "https://uofa.net/morrison/data/mms-analytic-reference-ns",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/mms-verification-run-2024q1",
      "outcomeValue": "L2 norm of velocity error < 1e-4; observed order of accuracy 1.97 (target ≥ 1.8)",
