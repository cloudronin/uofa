  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/rh-index-comparison-5op",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index — 5-operating-point CFD vs. in-vitro comparison",
      "comparedAgainst": "https://uofa.net/morrison/data/hemolysis-experimental-cpb-dataset",
      "description": "CFD-predicted relative hemolysis index (RHI) was computed at all five flow-speed operating points (2.5 L/min / 2000 RPM through 6.0 L/min / 3500 RPM) and compared against in-vitro measurements obtained on the FDA generic centrifugal pump loop. The Lagrangian power-law hemolysis model (Giersiepen-Wurzinger coefficients) was applied post-processing to the converged velocity and shear-stress fields. Across all five points the model over-predicted RHI by 8–14 %, which is conservative and within the pre-specified ±20 % acceptance band. The worst-case operating point (6.0 L/min / 3500 RPM) yielded RHI = 0.87 against the predicate benchmark, satisfying the RH < 1 criterion. Mesh sensitivity was confirmed at this point using three grid levels (4.2 M, 11.7 M, 28.4 M cells); the GCI between the medium and fine grids was 1.3 %. Turbulence model sensitivity (SST k-ω vs. realizable k-ε) introduced a maximum RHI spread of 6 %, well within the acceptance band. The experimental data were collected by an independent laboratory under ISO 10993-4 protocols; traceability to NIST flow standards was confirmed. Statistical analysis (Bland–Altman, n = 15 replicate experiments per operating point) showed no systematic bias. This result is considered the primary validation evidence for COU1 and underpins the Accepted decision.",
      "outcomeValue": "RHI_max = 0.87; model over-prediction 8–14 %; within ±20 % acceptance band at all 5 operating points",
      "acceptanceMet": true
    },
    {
      "id": "https://uofa.net/morrison/validation/code-verification-mms",
