  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/rh-index-comparison-5ops",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Validation — Five Operating Points",
      "description": "CFD-predicted relative hemolysis index (RH) values were compared against in-vitro experimental measurements across five flow-speed operating points (2.5 L/min at 2000 RPM, 3.5 L/min at 2500 RPM, 4.5 L/min at 3000 RPM, 5.5 L/min at 3500 RPM, and 6.5 L/min at 4000 RPM). Experimental hemolysis measurements were obtained using the modified index of hemolysis (MIH) protocol with bovine blood per ASTM F1841. CFD simulations employed the Giersiepen-Wurzinger power-law hemolysis model implemented in ANSYS Fluent 2022R2 with species transport. Mesh independence was confirmed at 4.2 million polyhedral cells. Turbulence was modeled using the SST k-omega formulation with low-Reynolds-number corrections near the impeller blade surfaces. All five operating-point predictions fell within ±15% of experimental measurements, and the predicted worst-case operating point (3.5 L/min, 2500 RPM) matched the experimentally observed worst case. The RH acceptance criterion (RH < 1.0 relative to predicate) was satisfied at all operating points. This result constitutes the primary validation evidence supporting COU1 acceptance. The simulation campaign was executed over a six-week period by two independent CFD analysts whose results were cross-checked for consistency before comparison with experimental data.",
      "comparedAgainst": "https://uofa.net/morrison/data/fda-generic-pump-experimental"
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-independence-study",
      "type": "ValidationResult",
      "name": "Mesh Independence Verification — GCI Analysis",
      "description": "Grid convergence index study performed on three mesh refinement levels (1.1M, 4.2M, and 12.8M polyhedral cells) demonstrating discretization error below 2.3% for the hemolysis scalar at the worst-case operating point.",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/mesh-independence-campaign-2024q3"
    },
    {
      "id": "https://uofa.net/morrison/validation/turbulence-model-sensitivity",
      "type": "ValidationResult",
      "name": "Turbulence Model Sensitivity — SST vs RSM Comparison",
      "description": "Sensitivity analysis comparing SST k-omega and Reynolds Stress Model predictions for the hemolysis scalar. Maximum deviation of 4.1% between models at the worst-case operating point, confirming that turbulence model selection does not materially affect the worst-case identification conclusion.",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/turbulence-sensitivity-study-2024q4"
    }
  ],
