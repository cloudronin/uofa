    {
      "id": "https://uofa.net/morrison/validation/vr-rh-benchmark",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against FDA benchmark in vitro data across all five CPB operating points",
      "description": "The CFD model was exercised at five flow-rate and impeller-speed combinations corresponding to the FDA generic centrifugal pump test matrix (2 L/min at 2500 RPM through 6 L/min at 3500 RPM). Predicted normalised index of hemolysis (NIH) values were converted to relative hemolysis index (RH) using the predicate device NIH reported in Morrison et al. (2012). All five operating points returned RH < 1.0 (range 0.61–0.94), satisfying the acceptance criterion. The largest discrepancy between CFD-predicted NIH and the in vitro reference measurement was 11.3 % at the 4 L/min / 3000 RPM condition, within the ±15 % tolerance established in the credibility plan. Uncertainty contributors including blood analogue viscosity (±3 %), inlet velocity profile (±2 %), and power-law hemolysis model constants (±7 %) were propagated via a first-order sensitivity study. The combined expanded uncertainty (k = 2) was 16.4 %, and the result remained below RH = 1 even at the upper uncertainty bound. This validation activity was conducted by the computational fluid dynamics team at the University of Alberta between January and March 2024 using ANSYS Fluent 2023 R2 on a 64-core HPC cluster, with post-processing scripts archived in the project repository under tag v3.1.0.",
      "comparedAgainst": "https://uofa.net/morrison/data/hemolysis-index-measurements"
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-velocity-profile",
      "type": "ValidationResult",
      "name": "Impeller outlet velocity profile comparison against PIV measurements",
      "comparedAgainst": "https://uofa.net/morrison/data/piv-outlet-velocity",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/piv-cfd-comparison-2024"
    }
  ],
