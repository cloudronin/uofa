  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-rh-index-benchmark",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Benchmark Comparison — FDA Pump Operating Points",
      "description": "The CFD model was exercised across all five target flow-speed operating points (2.5 L/min at 2500 RPM, 3.5 L/min at 3000 RPM, 4.5 L/min at 3500 RPM, 5.0 L/min at 3800 RPM, and 6.0 L/min at 4200 RPM) using the Lagrangian particle-tracking hemolysis sub-model of Giersiepen et al. as implemented in ANSYS Fluent 2022 R2. Mesh independence was confirmed at 4.2 million polyhedral elements (GCI < 2.1% for all QoIs). Turbulence closure used the SST k-omega model with low-Reynolds-number wall treatment (y+ < 1 across >97% of wetted surfaces). Predicted normalized index of hemolysis (NIH) values were compared against the experimental measurements of Zhang et al. (2021) obtained on a physical replica of the FDA generic centrifugal pump under matched flow conditions in a phosphate-buffered saline/red-blood-cell suspension circuit. Across all five operating points the model reproduced NIH within ±18%, and the relative hemolysis index RH remained below 0.92 in all cases, satisfying the acceptance criterion of RH < 1. The simulation campaign was conducted by the Morrison laboratory CFD team between March and August 2023, with results logged in internal report MRL-2023-CFD-047. Despite the comprehensive nature of this simulation-to-experiment comparison, the structured activity provenance record linking this result to the generation workflow has not been encoded in the package; the prose narrative above is intended to convey equivalent information to a domain reviewer.",
      "comparedAgainst": "https://uofa.net/synth/data/hemolysis-experimental-measurements"
    },
