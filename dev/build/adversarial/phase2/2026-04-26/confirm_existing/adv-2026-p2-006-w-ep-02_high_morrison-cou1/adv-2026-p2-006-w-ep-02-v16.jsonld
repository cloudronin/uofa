  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-rh-index-bench-comparison",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Bench Validation — FDA Pump Geometry",
      "description": "Detailed bench-top experimental validation comparing CFD-predicted relative hemolysis index (RH) against in-vitro measurements across all five flow-speed operating points (2 L/min at 2500 RPM, 3 L/min at 2000 RPM, 4 L/min at 1750 RPM, 5 L/min at 1500 RPM, 6 L/min at 1250 RPM). The experimental campaign was conducted at the Morrison Laboratory using a modified modified index of hemolysis (MIH) protocol with bovine blood (hematocrit 33 ± 2%). Plasma-free hemoglobin was measured via spectrophotometry at 540 nm at 30-minute intervals over a 3-hour recirculation period. CFD predictions used the Giersiepen–Wurzinger power-law damage accumulation model integrated along Lagrangian particle tracks seeded uniformly at the pump inlet. Across all five operating points, the CFD-predicted RH values ranged from 0.71 to 0.94 (mean 0.82), while experimental RH values ranged from 0.68 to 0.97 (mean 0.84). The maximum absolute discrepancy was 0.09 RH units at the 2 L/min condition, well within the ±0.15 acceptance band established in the validation plan. All five operating points satisfied RH < 1.0. The validation dataset, experimental protocol, and raw spectrophotometry readings are archived in the Morrison Lab data repository. This result is considered the primary evidence supporting model credibility for the COU.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh Convergence Verification — Discretization Error Assessment",
      "description": "Three-level mesh refinement study (coarse 2.1M cells, medium 5.8M cells, fine 14.2M cells) demonstrating grid convergence index (GCI) below 3.2% for predicted shear stress exposure on particle tracks at the worst-case 2 L/min operating point.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-convergence-run-2024-09"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-head-validation",
      "type": "ValidationResult",
      "name": "Pump Pressure-Head Characteristic Curve Validation",
      "description": "CFD-predicted pressure-head (H-Q) curves compared against manufacturer-supplied experimental characteristic curves at three rotational speeds (1500, 2000, 2500 RPM). Mean absolute error across all operating points was 4.1%, within the 10% acceptance criterion specified in the validation plan.",
      "comparedAgainst": "https://uofa.net/synth/data/cpb-operating-conditions-sweep",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hq-curve-cfd-runs-2024-07"
    }
  ],
