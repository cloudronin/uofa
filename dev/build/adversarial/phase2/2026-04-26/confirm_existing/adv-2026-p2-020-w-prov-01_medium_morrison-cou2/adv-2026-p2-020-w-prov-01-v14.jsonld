  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis model routines; formal SQA plan on file.",
      "rationale": "The CFD solver is version-controlled and unit-tested for core fluid routines, but the hemolysis scalar transport module lacks an independent verification test suite. SQA plan does not cover the power-law damage model add-on. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent applied to hemolysis transport equation; convergence order confirmed.",
      "rationale": "MMS verification was performed for Navier-Stokes solver but not extended to the hemolysis scalar transport equation. Convergence order for the damage accumulation term is unconfirmed. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis QOI on at least three systematically refined meshes; GCI < 5%.",
      "rationale": "Grid convergence index was computed on three mesh levels for pressure and velocity. Hemolysis index GCI was not separately reported; near-wall shear stress — the primary driver of hemolysis — shows GCI of 12%, exceeding the 5% threshold. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match COU operating envelope within stated tolerances; blood analog fluid properties documented.",
      "rationale": "FDA benchmark experiments used porcine blood with documented hematocrit range. COU operating points (flow 3–7 L/min, speed 2000–3500 RPM) are within the experimental envelope for 4 of 5 operating points. One high-speed point extrapolates beyond tested conditions. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or U95) applied to NIH predictions vs. measurements; systematic bias < 20%.",
      "rationale": "NIH predictions show mean bias of 34% against FDA benchmark measurements across five operating points, exceeding the 20% acceptance threshold. Scatter increases at high rotational speeds. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs used in validation (NIH, shear stress distributions) are directly mapped to clinical hemolysis acceptance criterion.",
      "rationale": "NIH is the primary QOI and maps directly to the clinical threshold. Shear stress distributions are used as intermediate QOIs and are clinically relevant. Minor gap: time-averaged vs. instantaneous shear exposure is not reconciled for pulsatile VAD operation. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry and operating conditions representative of the Class III VAD COU; pulsatile flow conditions included.",
      "rationale": "Validation was performed on the FDA generic pump under steady-flow conditions. The COU involves a pulsatile VAD with a patient-specific impeller geometry. Geometric and flow-regime differences reduce relevance. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; round-off and floating-point error bounds estimated for hemolysis accumulation over long integration paths.",
      "rationale": "Iterative residual convergence was monitored for flow equations but not for the hemolysis scalar. Long Lagrangian particle paths used for damage accumulation introduce integration errors that have not been quantified. Factor not assessed at MRL 5 requirements. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation setup checklist; independent peer review of boundary condition assignments and model parameter selections.",
      "rationale": "No formal use-error assessment has been conducted. Boundary condition assignments and turbulence model selections were made by a single analyst without independent review. Factor not assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis demonstrating that the power-law hemolysis model form is appropriate; alternative model forms (e.g., strain-based) evaluated.",
      "rationale": "The power-law Giersiepen-Wurzinger model was selected without systematic comparison to alternative hemolysis model forms. Model form uncertainty is unquantified at MRL 5. Factor not assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters (blood viscosity, density, power-law exponents) characterized with uncertainty bounds; Monte Carlo propagation completed and validated.",
      "rationale": "Monte Carlo UQ was initiated but input distributions for power-law exponents C and alpha were assigned from literature without patient-specific characterization. Sensitivity indices not computed. Factor not assessed at required level. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability (n ≥ 5 per operating point); donor-to-donor hematocrit variability accounted for.",
      "rationale": "FDA benchmark data provides single-replicate measurements per operating point for most conditions. Donor variability and hematocrit effects are not characterized in the available dataset. Factor not assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that experimental input parameters (fluid properties, geometry tolerances) are equivalent to COU inputs within defined tolerances.",
      "rationale": "Porcine blood used in FDA benchmark differs from human blood in red blood cell fragility. No equivalency mapping between porcine and human blood hemolysis susceptibility has been established. Factor not assessed. Achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been evaluated against MRL 5 requirements. Seven factors were formally assessed; all show achieved levels below required levels. Six factors were not assessed, representing epistemic gaps at the highest model risk level. The Monte Carlo UQ campaign was completed but input characterization is insufficient. The provenance chain supporting the hemolysis correlation result traces to prior experimental work as documented in the intermediate result node. The overall assessment package is accepted as a complete and transparent record of credibility gaps for regulatory submission, with the explicit recommendation that the model is not suitable for the stated COU without further validation activities.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
