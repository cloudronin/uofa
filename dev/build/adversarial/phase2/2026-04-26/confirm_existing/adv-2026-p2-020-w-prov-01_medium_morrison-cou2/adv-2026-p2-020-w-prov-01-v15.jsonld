  "signature": "ed25519:b2d3e4f5a6c7b8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a quality management system with documented version control, unit testing, and regression suite appropriate for MRL 5.",
      "rationale": "The CFD solver (OpenFOAM v9) has a public regression suite but lacks a formal FDA-recognized QMS. Version control is documented; however, no independent code audit has been performed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions or Method of Manufactured Solutions for all governing equations active in the hemolysis model.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver but not for the hemolysis transport scalar equation. Partial verification yields achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; GCI must be below 5% for all primary QoIs.",
      "rationale": "Three-mesh GCI study completed; GCI = 4.2% for velocity magnitude and 6.8% for hemolysis index. The hemolysis QoI exceeds the 5% threshold, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match VAD operating envelope (flow rate 3–6 L/min, 2400–3600 RPM) within stated uncertainty bounds.",
      "rationale": "Available PIV data covers only 4 L/min at 3000 RPM. The full VAD operating envelope of 5 flow-speed combinations is not covered. Significant extrapolation required. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., RMSE, E_rms) must be computed between model predictions and experimental measurements for hemolysis index as the primary QoI.",
      "rationale": "Output comparison was performed for velocity fields (E_rms = 8.3%) but not directly for the hemolysis index due to absence of in-vitro hemolysis measurements at matching conditions. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation activities must directly correspond to the hemolysis index values required for the regulatory decision.",
      "rationale": "Velocity and wall shear stress are validated; hemolysis index is derived via a power-law model. The QoI chain is partially relevant but introduces model-form uncertainty not directly validated. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on a geometry and operating regime representative of the Class III VAD COU, not merely the FDA benchmark pump.",
      "rationale": "All validation activities used the FDA generic pump geometry. The actual VAD device geometry differs in impeller blade count and volute design. Relevance to the specific COU is limited. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off contributions to solver error must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Residual convergence was monitored (L2 < 1e-5) but no formal solver error budget was constructed. Round-off error analysis was not performed. Factor not assessed at MRL 5 requirements; achieved level defaulted to 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Procedures must document analyst training, input setup review, and independent verification of boundary condition assignments to prevent use error in CFD setup.",
      "rationale": "No formal use-error prevention protocol was documented. Boundary condition assignments were set by a single analyst without independent review. Factor not assessed; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty arising from turbulence closure selection and hemolysis power-law exponent must be quantified through sensitivity analysis or Bayesian model averaging.",
      "rationale": "k-omega SST turbulence model was selected without systematic model-form comparison. Hemolysis power-law exponent sensitivity was not assessed. Factor not assessed at MRL 5; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with quantified uncertainty; Monte Carlo propagation must cover all inputs with coefficient of variation > 1%.",
      "rationale": "Monte Carlo UQ covers flow rate, viscosity, and rotational speed. Red blood cell mechanical properties (fragility index, membrane stiffness) were held fixed at literature point estimates without uncertainty quantification. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test samples used in experimental validation must be characterized for hematocrit, donor variability, and storage age; sample-to-sample variability must be reported.",
      "rationale": "No in-vitro hemolysis test samples were procured or characterized for this assessment. Validation relies entirely on PIV velocity data which does not involve biological samples. Factor not assessed; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the validated model configuration must be demonstrably equivalent to those used in the COU prediction, including fluid properties and geometric fidelity.",
      "rationale": "The validation model used water-glycerol analog fluid (viscosity matched to blood at 37°C) while the COU requires whole blood with non-Newtonian behavior. Equivalency was not formally demonstrated. Factor not assessed; achieved level 1."
    }
  ],
