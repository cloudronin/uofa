  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with traceability to release version; configuration management records required.",
      "rationale": "The CFD solver (OpenFOAM v9) has a community test suite but lacks formal configuration management records tied to this specific simulation campaign. Achieved Gradation 2: basic regression testing only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must demonstrate solver convergence at expected theoretical rate for all active transport equations including hemolysis scalar.",
      "rationale": "MMS convergence verified for Navier-Stokes equations but not for the hemolysis scalar transport equation. Achieved Gradation 2: partial code verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 2% for hemolysis index QoI across all five operating points; Richardson extrapolation on three systematically refined meshes.",
      "rationale": "GCI computed on three meshes (4M, 12M, 32M cells). GCI for velocity fields is 1.8% but GCI for hemolysis index reaches 7.3% at the highest flow-speed operating point. Achieved Gradation 3: convergence demonstrated but threshold not met for all QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental conditions must match COU operating envelope including hematocrit, temperature, and anticoagulant protocol; deviations must be quantified.",
      "rationale": "FDA benchmark experiments used bovine blood at 37°C with hematocrit 33±2%. COU specifies human blood at physiological hematocrit 40–45%. Temperature match is adequate but hematocrit deviation is unquantified. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., validation uncertainty U_val) must be reported for hemolysis index; systematic bias must be < 15%.",
      "rationale": "Velocity field agreement is good (mean error 6%). Hemolysis index comparison shows 22% systematic over-prediction relative to in vitro measurements. Achieved Gradation 2: comparison performed but bias exceeds threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must include the bulk hemolysis index (NIH) as the primary clinical surrogate; secondary QoIs (wall shear stress, pathline residence time) must be assessed.",
      "rationale": "Normalized index of hemolysis (NIH) is the primary QoI and is validated. Wall shear stress is assessed as secondary QoI. Pathline residence time is computed but not compared to experimental data. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on a geometry and operating condition set that spans the COU operating envelope; interpolation must not be required outside the validated range.",
      "rationale": "Validation performed on FDA generic pump geometry; COU device is a proprietary impeller design with different blade angle and tip clearance. Geometric similarity is partial. Achieved Gradation 2: validation on surrogate geometry only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria, floating-point round-off bounds, and time-stepping error must be documented and bounded for the hemolysis scalar transport equation.",
      "rationale": "Iterative convergence is monitored via residual norms but no formal bounding of round-off or time-stepping error for the hemolysis scalar has been performed. Factor not assessed at MRL 5 requirements. Achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent analyst reproduction and qualification records required.",
      "rationale": "No independent reproduction performed. User qualification records exist for the lead analyst but no checklist-based review was conducted. Factor flagged as epistemic gap. Achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified with sensitivity analysis; hemolysis constitutive model (power-law exponents) must be shown to be appropriate for the shear-stress range encountered in the COU device.",
      "rationale": "k-omega SST turbulence model selected; sensitivity to k-epsilon and LES not performed. Power-law hemolysis model coefficients taken from Giersiepen-Wurzinger without re-calibration to COU blood type. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All boundary conditions must be traceable to measured patient-representative data; uncertainty in inlet flow waveform must be propagated through the UQ analysis.",
      "rationale": "Inlet boundary conditions derived from literature mean values; patient-specific variability not characterised. Monte Carlo UQ covers ±10% flow variation but does not include waveform shape uncertainty. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "In vitro hemolysis measurements must be performed on at least three pump specimens from the same manufacturing lot; inter-specimen variability must be reported.",
      "rationale": "Only one physical pump specimen was used in the FDA benchmark study. No inter-specimen variability data available. Factor flagged as epistemic gap at MRL 5. Achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment input parameters and COU simulation inputs must be formally demonstrated, including fluid properties, rotational speed range, and gap geometry.",
      "rationale": "Formal equivalency assessment not performed. Rotational speed range overlaps partially (2500–3500 RPM in validation vs. 2000–4000 RPM in COU). Gap geometry differs. Factor flagged as epistemic gap. Achieved Gradation 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor shortfalls, the assessment team accepted the package for submission based on the Monte Carlo UQ results demonstrating hemolysis index below clinical threshold at 3 of 5 operating points and the availability of the FDA benchmark PIV dataset as foundational evidence. Remaining factor gaps are acknowledged as epistemic limitations to be addressed in a follow-on assessment cycle.",
