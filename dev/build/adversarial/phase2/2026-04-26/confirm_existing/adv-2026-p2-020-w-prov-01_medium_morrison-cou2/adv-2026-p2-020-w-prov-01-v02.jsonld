  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression testing and configuration management at MRL 5.",
      "rationale": "CFD solver has basic unit tests and version control but lacks formal regression testing suite and independent code review required at MRL 5. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark verification demonstrating order-of-accuracy convergence for rotating machinery flows.",
      "rationale": "Code verification performed against lid-driven cavity benchmark only. Rotating impeller benchmark not completed. Order-of-accuracy not confirmed for hemolysis-relevant flow regimes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index below 5% for hemolysis index QoI across all five operating points.",
      "rationale": "GCI computed on three systematically refined grids. GCI below 5% achieved at 3 of 5 operating points; two high-flow conditions show GCI of 9% and 12% due to unresolved tip clearance vortices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must span full VAD operating envelope including pulsatile flow waveforms representative of clinical use.",
      "rationale": "Validation experiments conducted under steady-flow conditions only. Pulsatile waveforms representative of VAD clinical use were not tested. Significant mismatch between test and COU conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric) applied to hemolysis index predictions with uncertainty bounds.",
      "rationale": "Comparison performed via percent error only without formal validation metric. Experimental uncertainty not fully characterized; plasma-free hemoglobin measurement uncertainty not propagated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must include absolute hemolysis index directly comparable to clinical threshold, not surrogate velocity or pressure metrics.",
      "rationale": "Hemolysis index is the primary QoI and is directly compared. Shear stress exposure time is also reported as secondary QoI. Absolute hemolysis index validated but clinical threshold mapping not fully documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the FDA generic pump geometry under VAD operating conditions with blood analog fluid at physiological hematocrit.",
      "rationale": "Validation used water-glycerol blood analog at 36% hematocrit equivalent. Actual blood rheology and viscoelastic effects not captured. Pump geometry matches but rotational speed range covers only 3 of 5 COU operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point error bounds documented for rotating frame solver.",
      "rationale": "Numerical solver error not assessed at MRL 5. Convergence residuals reported but round-off error and iterative error not separated. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition application, and post-processing scripts by analyst not involved in original simulation.",
      "rationale": "Use error not assessed. No independent review of simulation setup performed. Single analyst responsible for all simulation and post-processing steps. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of hemolysis power-law model form including comparison against alternative mechanistic models.",
      "rationale": "Model form uncertainty not assessed. Giersiepen power-law hemolysis model selected without documented comparison to Arora or Goubergrits models. Constitutive model form uncertainty is a significant epistemic gap for Class III device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis identifying dominant input parameters; probability distributions assigned to all inputs with uncertainty exceeding 5% of nominal value.",
      "rationale": "Monte Carlo UQ performed over three input parameters. Sensitivity analysis via Sobol indices not completed. Blood viscosity distribution assigned from literature; patient-specific variability not captured. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of test sample material properties including hematocrit, plasma viscosity, and red blood cell fragility index for all experimental runs.",
      "rationale": "Test sample characterization not assessed. Blood analog fluid characterized for bulk viscosity only. RBC fragility and hematocrit variability across experimental runs not documented. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented mapping between experimental input parameters and CFD boundary conditions demonstrating equivalency within stated uncertainty bounds.",
      "rationale": "Equivalency of input parameters not assessed. Pump inlet flow rate set by volumetric flowmeter with 3% accuracy; CFD boundary condition set to nominal value without propagating flowmeter uncertainty. Flagged as epistemic gap at MRL 5."
    }
  ],
