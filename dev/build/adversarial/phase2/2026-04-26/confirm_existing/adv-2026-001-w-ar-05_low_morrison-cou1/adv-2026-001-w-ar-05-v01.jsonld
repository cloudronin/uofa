  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction vs. in-vitro reference — primary validation result",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values for five flow-speed operating points were compared against in-vitro measurements reported in the FDA benchmark dataset. Predicted NIH ranged from 0.0021 to 0.0087 g/100 L across operating points, with a mean absolute relative error of 11.3%. The validation narrative identifies the FDA benchmark experimental data as the reference comparator; however, no formal comparedAgainst link to a registered comparator resource is provided in this record. The omission is consistent with the team's decision to treat the benchmark as a background assumption rather than a formally scoped comparator — an inference gap that constitutes the W-AR-05 trigger surface."
    },
    {
      "id": "https://uofa.net/synth/validation/steady-state-comparator",
      "type": "ValidationResult",
      "name": "Steady-state in-vitro hemolysis comparison — secondary validation result",
      "description": "A second validation activity compared CFD predictions against steady-state in-vitro hemolysis measurements conducted at fixed pump speed (2400 RPM) and fixed flow rate (5 L/min) using the FDA generic centrifugal blood pump physical prototype. The comparator dataset was collected under continuous, non-pulsatile flow with a constant inlet pressure boundary condition. MISMATCH WITH COU: The declared Context of Use (COU1) explicitly requires evaluation under pulsatile CPB flow conditions, with a physiologically representative cardiac output waveform (heart rate 70 bpm, stroke volume 70 mL). The steady-state experimental conditions used here do not reproduce the cyclic shear stress histories that drive hemolysis accumulation in pulsatile regimes. Consequently, the comparator is present and formally linked, but the inference from steady-state validation evidence to pulsatile COU performance is undercut (D3 inference method mismatch). The validation team noted this discrepancy in the test report but accepted the result on the basis that steady-state conditions bound worst-case shear exposure — an assumption that is not independently substantiated in this package.",
      "comparedAgainst": "https://uofa.net/synth/comparator/fda-gcbp-steadystate-invitro-2400rpm"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037858",
