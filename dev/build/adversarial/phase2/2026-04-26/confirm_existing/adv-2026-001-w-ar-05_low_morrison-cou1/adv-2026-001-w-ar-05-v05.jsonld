    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis index validation — comparator link absent",
      "description": "The CFD-predicted relative hemolysis index (RHI) values across the five operating points (2.5 L/min at 2500 RPM through 5.0 L/min at 3500 RPM) were compared against in-vitro hemolysis measurements collected on the FDA generic centrifugal pump test rig. Predicted RHI values ranged from 0.71 to 0.94, all satisfying the RH < 1 acceptance criterion. Normalised root-mean-square error across the five operating points was 8.3 %, within the 15 % tolerance specified in the test plan. Although the experimental dataset used for comparison is referenced in the narrative (Morrison et al., 2022, Table 4), no formal comparedAgainst link to a registered experimental record has been populated in this result object, leaving the evidentiary chain from simulation output to physical measurement formally unresolved.",
      "passedCriteria": true,
      "metricValue": 0.083,
      "metricLabel": "NRMSE across 5 operating points"
    },
    {
      "id": "https://uofa.net/synth/validation/steady-state-comparator-mismatch",
      "type": "ValidationResult",
      "name": "Secondary flow-field validation — steady-state PIV comparator (COU mismatch)",
      "description": "Velocity field predictions from the CFD model were validated against particle image velocimetry (PIV) data acquired under steady, non-pulsatile inflow conditions at a fixed flow rate of 4.0 L/min and 3000 RPM. The experimental comparator (FDA PIV dataset, steady-state protocol NHLBI-SS-2019) was collected without any pulsatile waveform component. The declared COU, however, specifies cardiopulmonary bypass use where the pump operates under pulsatile inflow driven by residual cardiac output and ventilator cycling, with a characteristic frequency of 0.8–1.2 Hz and a peak-to-mean flow ratio of 1.35. Validation under steady inflow cannot substantiate model fidelity in the pulsatile regime relevant to the COU because the turbulence intensity, secondary flow structures, and shear-stress distributions differ materially between steady and pulsatile operating modes. This constitutes an inference-method mismatch (D3 undercutting): the validation evidence is technically present and internally consistent, but the experimental conditions of the comparator are structurally inconsistent with the operating regime of the COU, undermining the inferential step from validation accuracy to deployment credibility.",
      "passedCriteria": false,
      "metricValue": 0.112,
      "metricLabel": "NRMSE velocity field — steady-state only",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-piv-steady-state"
    }
  ],
