  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are acceptable under MRL 2 scoping rules. CFD predictions of relative hemolysis index agree with experimental measurements within the 15% acceptance criterion across all five operating points. The model is assessed as sufficiently credible for its intended use in identifying worst-case hemolysis operating conditions for the Class II CPB device. Decision: Accepted for regulatory submission.",
