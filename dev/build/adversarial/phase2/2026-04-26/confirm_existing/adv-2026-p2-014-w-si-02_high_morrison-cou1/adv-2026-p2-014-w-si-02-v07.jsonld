  "signature": "ed25519:b2d4e6f8a0c2e4f6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation is version-controlled, and all solver inputs and outputs are archived with checksums. Regression test suite passes for relevant turbulence and hemolysis submodels.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under the laboratory's ISO 9001-aligned SQA plan. Version control via Git, automated regression tests covering rotating-frame and SST k-omega turbulence model paths, and archived simulation decks satisfy MRL 2 SQA requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver correctly reproduces analytical or manufactured solutions for rotating-frame Navier-Stokes to within second-order convergence.",
      "rationale": "Method of manufactured solutions applied to a simplified centrifugal geometry confirms second-order spatial convergence (observed order 1.94) for velocity and pressure fields. No code defects detected in the hemolysis power-law damage accumulation subroutine."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for shear stress field and hemolysis index must be below 5% at the operating point of maximum RH.",
      "rationale": "Three-level mesh refinement study (2.1M, 6.8M, 18.4M cells) yields GCI of 2.7% for peak shear stress and 1.9% for the integrated hemolysis index at the worst-case 5 L/min, 3500 RPM operating point. Richardson extrapolation confirms asymptotic convergence. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, temperature, hematocrit, anticoagulant protocol) are documented and match simulation boundary conditions within stated tolerances.",
      "rationale": "In-vitro hemolysis experiments conducted using porcine blood at 37 ± 0.5°C, hematocrit 33 ± 2%, and 10 U/mL heparin anticoagulation. All five flow-speed combinations replicated within ±2% of target. Fluid properties used in CFD match measured viscosity (3.2 mPa·s) and density (1055 kg/m³)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted normalized index of hemolysis (NIH) and relative hemolysis index (RH) agree with experimental measurements within 15% across all five operating points.",
      "rationale": "CFD predictions of NIH deviate from experimental values by 4%–12% across the five operating points (mean absolute error 7.3%). RH values predicted by CFD correctly rank-order all five conditions relative to the predicate device. Acceptance criterion satisfied at all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (shear stress distribution, hemolysis index, RH) are directly linked to the clinical endpoint of pump-induced hemolysis and the regulatory decision criterion.",
      "rationale": "The primary QoI — relative hemolysis index RH — is the direct metric used in the regulatory submission acceptance criterion (RH < 1). Secondary QoIs (volume-averaged shear stress, exposure time distribution) are mechanistically linked to the power-law hemolysis model and provide physical interpretability for the RH prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, operating envelope, and blood analog as the COU, or differences are bounded by sensitivity analysis.",
      "rationale": "Validation experiments used the identical FDA generic centrifugal pump geometry as the COU. Operating conditions span the full COU envelope (2–6 L/min, 2500–4000 RPM). Porcine blood is used in both validation and COU experiments, with species-specific power-law coefficients applied. Geometric and physiological relevance is high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence monitoring is sufficient.",
      "rationale": "At MRL 2, explicit quantification of numerical solver error beyond iterative convergence monitoring is not required. Residuals for all equations dropped below 1e-5 and monitored quantities (torque, outlet pressure) stabilized to within 0.1% over the final 500 iterations, indicating adequate iterative convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; peer review of simulation setup is sufficient.",
      "rationale": "Simulation setup reviewed by a second qualified CFD engineer not involved in the original setup. Boundary condition assignments, material property inputs, and post-processing scripts independently verified. No use errors identified. Formal use-error quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection is justified by literature precedent.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark studies for rotating blood-contacting devices. Giersiepen-Wurzinger power-law hemolysis model with species-specific coefficients is the established approach for porcine blood CFD hemolysis prediction. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "All model inputs (fluid properties, pump geometry dimensions, operating conditions) sourced from calibrated measurements or manufacturer specifications with documented uncertainty bounds. Formal sensitivity analysis or uncertainty propagation for model inputs not required at MRL 2."
    },
