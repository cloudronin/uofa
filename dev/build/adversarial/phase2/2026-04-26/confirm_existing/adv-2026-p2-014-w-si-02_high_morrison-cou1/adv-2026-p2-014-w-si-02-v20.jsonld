    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of CFD-predicted NIH against experimental measurements using appropriate validation metric; agreement within two standard deviations of experimental scatter.",
      "rationale": "CFD-predicted NIH compared against experimental data at all five operating points. Mean absolute error of 18% observed, consistent with published inter-laboratory variability for hemolysis CFD. RH < 1.0 at all conditions confirms conservative prediction. Comparison methodology follows ASME V&V 20 validation metric framework."
    },
    {
      "type": "CredibilityFactor",
