  "signature": "ed25519:b1e2f3a4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented test suite and issue tracking. All solver modules relevant to hemolysis computation verified against known benchmarks.",
      "rationale": "ANSYS Fluent 2022R2 is used under a validated software quality plan meeting FDA software guidance. Version control via Git, regression test suite of 47 cases, and formal defect tracking are documented. SQA level 2 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method-of-manufactured-solutions or equivalent benchmark with errors below 1% for relevant flow regimes.",
      "rationale": "Code verification performed using Taylor-Green vortex and lid-driven cavity benchmarks. Observed convergence rates match theoretical orders. Hemolysis scalar transport equation verified against analytical solution with L2 error below 0.3%. Gradation 2 requirements met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index QOI. GCI below 5% acceptable at MRL 2.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 5.8M, 14.2M cells). Richardson extrapolation yields GCI of 2.1% for the hemolysis index at the worst-case operating point (4 L/min, 3000 RPM). Discretization error is well-characterized and within acceptance threshold. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and match CFD boundary conditions within stated tolerances. Blood analog fluid properties must be reported.",
      "rationale": "Experimental data from FDA-sponsored pump testing used. Flow rates controlled to ±0.05 L/min, rotational speed to ±10 RPM. 37°C temperature maintained. Glycerol-water blood analog properties (viscosity 0.0035 Pa·s, density 1050 kg/m³) match CFD inputs. Test conditions documentation complete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 20% across all 5 operating points. Statistical comparison metrics must be reported.",
      "rationale": "CFD hemolysis index predictions compared against experimental modified index of hemolysis (MIH) at all 5 flow-speed operating points. Mean absolute error of 11.3%, maximum deviation 18.7% at 6 L/min, 2500 RPM. All predictions within 20% acceptance band. Scatter plots and Bland-Altman analysis documented in validation report VR-CPB-2024-03."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOI used in validation (hemolysis index) must be directly relevant to the clinical decision QOI (relative hemolysis index RH vs. predicate).",
      "rationale": "Validation QOI is the modified index of hemolysis (MIH), which is mathematically equivalent to the normalized hemolysis index used in the COU acceptance criterion (RH < 1). The transformation between MIH and RH is linear and documented. QOI relevance is direct and unambiguous."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions must be sufficiently similar to COU geometry and conditions to support extrapolation of validation evidence.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry — the same geometry as the COU device. Operating conditions span the clinical CPB range (2–6 L/min, 2000–3500 RPM). Blood analog fluid used in validation; extrapolation to whole blood supported by established viscosity correction factors. Validation relevance assessed as adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, iterative convergence monitoring is sufficient. Residual drop of 4 orders of magnitude acceptable.",
      "rationale": "Solver iterative error not formally quantified beyond residual monitoring at MRL 2. All simulations converged to residuals below 1e-6 for continuity and momentum, 1e-8 for scalar transport. No formal iterative error budget required at this MRL. Factor scoped to gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documented simulation setup review by a second analyst is sufficient.",
      "rationale": "Simulation setup reviewed by senior analyst prior to production runs. Boundary condition assignment, material property inputs, and solver settings verified against simulation plan SP-CPB-2024-01. No formal use error quantification required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis damage accumulation model must be justified with reference to literature and sensitivity analysis.",
      "rationale": "SST k-omega turbulence model selected based on published CFD pump studies (Hariharan et al. 2011, Fraser et al. 2012) demonstrating superior performance in rotating machinery with adverse pressure gradients. Giersiepen-Wurzinger power-law hemolysis model used; sensitivity to model constants assessed via ±20% parameter variation yielding less than 8% change in predicted MIH. Model form uncertainty documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are sufficient. Formal uncertainty propagation not required.",
      "rationale": "All model inputs (geometry dimensions, fluid properties, boundary conditions) sourced from device drawings and FDA pump test reports with documented traceability. Nominal values used throughout. Formal input uncertainty propagation deferred as not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, use of published experimental data from traceable sources is acceptable without independent sample characterization.",
      "rationale": "Experimental hemolysis data sourced from FDA-sponsored inter-laboratory study (Herbertson et al. 2015) with 5 participating laboratories. Sample preparation and measurement protocols documented in source publication. Independent sample characterization not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative assessment of input parameter equivalency between validation and COU scenarios is sufficient.",
      "rationale": "Qualitative comparison of validation and COU input parameters performed. Geometry identical (FDA generic pump). Fluid properties: blood analog vs. whole blood — viscosity difference less than 15% across shear rate range, documented as acceptable for hemolysis index comparison at MRL 2. Operating conditions overlap fully with COU range. Equivalency assessed as adequate."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required gradation levels for MRL 2. Six factors appropriately scoped to gradation 1 and not assessed per MRL 2 requirements. Hemolysis index predictions agree with experimental data within the 20% acceptance criterion across all operating points. Discretization error GCI of 2.1% provides high confidence in numerical accuracy. The CFD model is assessed as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device. Decision: Accepted for regulatory submission supporting 510(k) clearance.",
