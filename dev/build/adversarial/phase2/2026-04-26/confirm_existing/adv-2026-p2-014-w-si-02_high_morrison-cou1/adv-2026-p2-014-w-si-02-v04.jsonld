      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry and operating conditions representative of the CPB device COU, not a dissimilar device class.",
      "rationale": "Validation performed on FDA generic centrifugal pump — the same geometry family as the COU device. Rotational speed and flow rate ranges overlap with COU. Validation activities judged directly relevant to COU at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit iterative convergence error quantification beyond residual monitoring is not required; residual drop of 4 orders of magnitude is sufficient.",
      "rationale": "Residuals monitored to 10^-5 for continuity and momentum. Iterative convergence confirmed by stabilization of hemolysis index monitor point. Explicit solver error decomposition not required at MRL 2; factor not assessed beyond residual criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
