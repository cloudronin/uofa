      "acceptanceCriteria": "At MRL 2, model form uncertainty quantification is not required; selection of turbulence model with documented literature support is sufficient.",
      "rationale": "SST k-omega turbulence model selected based on published CFD hemolysis literature (Hariharan et al. 2011, Garon & Farinas 2004). Model form uncertainty not formally quantified; literature support deemed sufficient at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, input uncertainty propagation is not required; nominal inputs with documented sources are sufficient.",
      "rationale": "Blood viscosity set to 0.0035 Pa·s (Newtonian approximation), density 1056 kg/m³. Values sourced from ASTM F1841. Nominal geometry from FDA public dataset. Input uncertainty propagation not required at MRL 2."
    },
