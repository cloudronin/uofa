      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation (NIH, relative hemolysis index RH) must be the same metric used in the regulatory acceptance criterion.",
      "rationale": "Validation QoI is NIH; COU acceptance criterion uses RH derived from NIH via linear transformation. Direct correspondence confirmed. Quantities of interest are fully relevant to regulatory decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
