    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass benchmark verification cases relevant to rotating machinery and viscous flow at MRL 2 gradation.",
      "rationale": "Solver verified against Taylor-Couette flow and lid-driven cavity benchmarks. Published verification suite results reviewed and found consistent with expected analytical solutions within 0.5% error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for primary QoI (hemolysis index) with GCI < 5% on fine mesh.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 5.8M, 14.3M cells). Richardson extrapolation applied; GCI on hemolysis index = 2.8% on fine mesh. Discretization error within acceptable bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must overlap with intended COU operating envelope for at least 3 of 5 operating points.",
      "rationale": "FDA benchmark experimental data collected at 2500 RPM and 3500 RPM across flow rates 2–6 L/min. Four of five COU operating points fall within validated envelope. Boundary conditions matched to within 3% of experimental setup."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all validated operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared against published FDA pump experimental data. Mean absolute error across 5 operating points = 8.3%. All predictions within 15% band. Output comparison exceeds MRL 2 requirement; gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
