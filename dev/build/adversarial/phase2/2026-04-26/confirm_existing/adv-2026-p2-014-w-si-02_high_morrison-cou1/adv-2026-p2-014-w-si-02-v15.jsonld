      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all transport equations.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity, momentum, and scalar transport equations. Mass imbalance below 0.01% for all cases. Convergence monitored over minimum 2000 iterations with plateau confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; qualitative documentation of simulation workflow suffices.",
      "rationale": "Use error not formally assessed per MRL 2 requirements. Simulation workflow documented in standard operating procedure with peer review by senior CFD engineer. Acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis constitutive model must be justified against available literature and sensitivity analysis performed.",
      "rationale": "SST k-omega turbulence model selected based on literature review for rotating machinery hemolysis applications (Taskin et al. 2012, Fraser et al. 2011). Sensitivity analysis comparing SST k-omega vs. realizable k-epsilon showed less than 8% difference in NIH. Giersiepen-Wurzinger power-law model selected per FDA guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and boundary conditions must be documented with traceability to measurement data or published references.",
      "rationale": "Blood viscosity modeled as Newtonian (mu = 0.0035 Pa·s) per CPB hemodilution protocol. Density 1050 kg/m3. Inlet velocity profiles derived from measured flow waveforms. All inputs traceable to experimental measurement reports with uncertainty quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative description of test sample provenance acceptable.",
      "rationale": "Test sample characterization not formally assessed at MRL 2. Bovine blood sourced from USDA-inspected facility with hematocrit controlled to 40 ± 2%. Sample preparation documented in experimental protocol. Acceptable at MRL 2 without formal assessment."
    },
