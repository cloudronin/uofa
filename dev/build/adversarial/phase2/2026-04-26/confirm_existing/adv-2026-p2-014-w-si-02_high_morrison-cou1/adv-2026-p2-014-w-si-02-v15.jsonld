  "hasRequirement": {
    "id": "https://uofa.net/synth/req/morrison-cou1-hemolysis-req",
    "type": "Requirement",
    "name": "CFD hemolysis prediction requirement for Class II CPB device",
    "description": "The CFD model shall predict relative hemolysis index (RH) for the FDA generic centrifugal blood pump across 5 flow-speed operating points. The model must demonstrate RH < 1 relative to the predicate device across all evaluated conditions. Applicable regulatory guidance: FDA Guidance on Reporting of Computational Modeling Studies in Medical Device Submissions (2021) and ISO 10993-4 for blood-contacting device evaluation. Model Risk Level 2 per ASME V&V 40-2018 Table 3.",
    "regulatoryBasis": "FDA 2021 Computational Modeling Guidance; ISO 10993-4; ASME V&V 40-2018",
    "acceptanceCriterion": "RH < 1.0 for all 5 evaluated flow-speed combinations"
  },
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release validation for rotating machinery applications.",
      "rationale": "ANSYS Fluent 2022R2 employed with documented QA procedures including regression test suite and ISO 9001-certified development process. Achieved level 2 exceeds MRL 2 requirement of level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases relevant to rotating flow.",
      "rationale": "Code verification confirmed via Taylor-Couette flow and rotating disk benchmark cases. Numerical solutions match analytical solutions to within 0.5% across Reynolds number range spanning pump operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for hemolysis scalar transport quantity of interest.",
      "rationale": "Three-level mesh refinement study conducted (2.1M, 5.8M, 14.2M elements). GCI computed per Celik et al. (2008) methodology. Maximum GCI of 2.7% observed for hemolysis power-law integral at worst-case operating point (6 LPM, 3500 RPM). Achieved level 3 exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulated operating conditions within ±5% for flow rate and rotational speed.",
      "rationale": "FDA pump experimental data collected at controlled conditions (37°C, bovine blood, 40% hematocrit). Flow rate accuracy ±2%, speed accuracy ±1%. Boundary conditions in CFD model set to match experimental measurements directly."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±20% across all 5 operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) compared against experimental measurements across all 5 operating points. Mean absolute error of 11.3%, maximum deviation of 18.7% at lowest flow condition. All points within ±20% acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (NIH, RH) must be directly traceable to the clinical hemolysis risk metric used in regulatory submission.",
      "rationale": "Relative hemolysis index RH derived from NIH predictions and directly maps to the regulatory acceptance criterion. Power-law hemolysis model (Giersiepen-Wurzinger) applied consistently with FDA-recognized methodology. QoI relevance confirmed by clinical affairs review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, operating conditions, and fluid properties representative of the CPB clinical use case.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry under CPB-representative flow rates (4–8 LPM) and speeds (2500–4000 RPM). Bovine blood used as surrogate per ISO 10993-4 guidance. Geometric similarity to subject device confirmed by dimensional analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
