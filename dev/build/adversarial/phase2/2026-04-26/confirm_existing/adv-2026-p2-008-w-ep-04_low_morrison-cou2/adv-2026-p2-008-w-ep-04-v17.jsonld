  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality assurance procedures must meet Gradation 4, including version control, regression testing, and documented change management consistent with MRL 5 requirements.",
      "rationale": "SQA procedures are documented and version-controlled but regression test coverage is insufficient for hemolysis sub-models; achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification must demonstrate convergence and correctness of all governing equation discretizations at Gradation 4 for the hemolysis transport solver.",
      "rationale": "Order-of-accuracy tests were performed on the Navier-Stokes solver but the hemolysis damage accumulation sub-model was not independently verified; achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must achieve Richardson extrapolation-based discretization error estimate below 2% on hemolysis index at all 5 operating points, meeting Gradation 5.",
      "rationale": "Three-level mesh refinement study was conducted; GCI values ranged from 4–9% on hemolysis index, indicating insufficient mesh independence. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within documented tolerances at Gradation 4, including fluid temperature, hematocrit, and rotational speed.",
      "rationale": "Experimental data used for validation were collected at a single nominal operating point under controlled laboratory conditions; only partial coverage of the 5 COU operating points was achieved. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative output comparison between CFD predictions and experimental hemolysis index must include uncertainty bounds and achieve agreement within 15% at Gradation 4.",
      "rationale": "CFD predictions of hemolysis index agreed within 22% of experimental measurements when accounting for Monte Carlo uncertainty bounds; agreement criterion not fully met. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest (hemolysis index values) must be directly relevant to the clinical decision threshold at Gradation 4, with documented traceability from QoI to patient risk.",
      "rationale": "Hemolysis index is directly mapped to clinical thresholds; however, sub-hemolytic platelet activation and thrombus risk were not captured as secondary QoIs. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry and operating conditions sufficiently representative of the COU Class III VAD device at Gradation 5.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which differs geometrically from clinical VAD designs; relevance to the specific COU device is limited. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Numerical solver error including iterative convergence, round-off, and floating-point precision effects must be characterized and bounded at the level required for MRL 5.",
      "rationale": "Numerical solver error was not assessed during this credibility evaluation cycle. Iterative convergence residuals were monitored but not formally quantified against a Gradation scale, and no bounding analysis was performed. This gap is unmitigated at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential errors arising from incorrect model setup, boundary condition specification, or post-processing must be systematically evaluated at Gradation 4 or higher for MRL 5.",
      "rationale": "Use error assessment was deferred pending completion of a formal model use procedure review. No documented evaluation of setup errors or boundary condition sensitivity was completed for this submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The suitability of the chosen turbulence model, hemolysis constitutive model, and non-Newtonian blood rheology model must be justified and benchmarked at Gradation 4 for MRL 5.",
      "rationale": "Model form uncertainty was not formally assessed. The power-law hemolysis damage model was selected based on prior literature without a structured comparison against alternative model forms or sensitivity analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to uncertain input parameters (hematocrit, viscosity, rotational speed tolerances) must be quantified at Gradation 4 consistent with MRL 5.",
      "rationale": "Input parameter uncertainty was partially addressed through Monte Carlo sampling of rotational speed; however, hematocrit variability and blood viscosity uncertainty were not included in the sensitivity analysis. Factor deemed not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The experimental test samples used for validation must be characterized for biological variability, sample size adequacy, and representativeness at Gradation 4.",
      "rationale": "Test sample characterization was not completed. Experimental hemolysis data were drawn from a single-laboratory study without inter-laboratory reproducibility assessment or statistical sample size justification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be equivalent to those in the COU at Gradation 4, including geometric fidelity, fluid properties, and boundary conditions.",
      "rationale": "Validation simulations used idealized inlet velocity profiles and simplified outlet boundary conditions that do not match the pulsatile physiological conditions of the COU. Achieved level 2."
    }
