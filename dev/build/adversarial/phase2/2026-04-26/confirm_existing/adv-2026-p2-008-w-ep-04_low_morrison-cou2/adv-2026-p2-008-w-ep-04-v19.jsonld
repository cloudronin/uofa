      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented, version control enforced, regression testing suite covering hemolysis solver routines.",
      "rationale": "Version control and build documentation are present. Regression testing covers only 60% of hemolysis-relevant solver paths; full SQA plan not formally reviewed by an independent party. Achieved level 3 falls short of required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification using manufactured solutions for both flow and hemolysis transport equations.",
      "rationale": "Order-of-accuracy tests performed for Navier-Stokes solver; manufactured solution verification for the hemolysis damage model is incomplete. Achieved level 3 does not satisfy the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all five operating points with GCI < 5% on hemolysis index.",
      "rationale": "Grid convergence index computed on three mesh levels for flow quantities; hemolysis index GCI exceeds 5% at two of five operating points. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, temperature, pump speed, flow rate) documented with uncertainties and confirmed to match COU operating envelope.",
      "rationale": "Fluid temperature and viscosity documented for bench tests; inlet turbulence intensity and outlet boundary pressure not reported. Partial match to COU operating envelope. Achieved level 3 below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) computed for hemolysis index at all five operating points; systematic bias characterised.",
      "rationale": "Relative error computed at three of five operating points; two high-speed points lack experimental hemolysis data for direct comparison. Systematic over-prediction bias identified but not corrected. Achieved level 2 significantly below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs (hemolysis index, shear stress distribution) directly correspond to the COU decision QoIs; mapping documented.",
      "rationale": "Hemolysis index used in validation corresponds to the COU QoI; shear stress distribution mapping is qualitative rather than quantitative. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted at conditions spanning the full COU operating envelope; geometric similarity between validation and COU configurations documented.",
      "rationale": "Validation geometry matches COU geometry; however, operating conditions cover only three of five COU flow-speed combinations. Extrapolation to untested points not formally justified. Achieved level 3 below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error characterised for hemolysis transport solver across all operating points.",
      "rationale": "Residual convergence of the primary flow solver was monitored, but iterative and round-off error specifically attributable to the hemolysis damage accumulation model were never formally characterised. At MRL 5 this constitutes an unmitigated epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that model setup, boundary condition assignment, and post-processing steps are free from user-introduced errors; independent review of simulation inputs performed.",
      "rationale": "No independent review of simulation input files or post-processing scripts was conducted. Potential for user-introduced errors in boundary condition specification and hemolysis model constants has not been evaluated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to turbulence model selection and hemolysis constitutive law documented; alternative model forms evaluated.",
      "rationale": "A single turbulence closure (SST k-omega) and a single hemolysis power-law model were used without comparison to alternative formulations. Model-form uncertainty is unquantified and unassessed at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis index to all material and boundary condition inputs quantified; uncertain inputs identified and propagated through Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ was performed on geometric tolerances only. Sensitivity of hemolysis predictions to blood viscosity model parameters and red blood cell fragility constants was not evaluated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterisation of blood analogue fluid properties and sample-to-sample variability reported; relevance to in-vivo blood rheology documented.",
      "rationale": "Experimental data used for validation were obtained with a glycerol-water blood analogue. Rheological characterisation of the specific analogue batches used and their variability were not reported, leaving sample representativeness unassessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental input parameters and CFD boundary conditions documented; discrepancies quantified and their impact on hemolysis predictions assessed.",
      "rationale": "No formal equivalency mapping between experimental boundary conditions and CFD inputs was produced. Differences in inlet velocity profiles and outlet pressure boundary conditions between bench and simulation were acknowledged but not quantified."
    }
