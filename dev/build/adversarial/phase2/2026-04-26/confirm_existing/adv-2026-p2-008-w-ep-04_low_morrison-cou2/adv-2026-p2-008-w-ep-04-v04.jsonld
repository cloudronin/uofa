  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; formal SQA plan required at MRL 5.",
      "rationale": "The CFD solver is version-controlled and has a partial regression test suite, but no formal SQA plan has been established and coverage of hemolysis-relevant shear regimes is incomplete. Achieved level 2 falls short of the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy verification on manufactured solutions for turbulent swirling flow and scalar transport equations used in hemolysis model.",
      "rationale": "Order-of-accuracy testing was performed only for the momentum equations on a simplified pipe geometry. The scalar transport equation governing the hemolysis damage accumulation was not included in code verification activities. Achieved level 2 is below the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis index QoI across all 5 operating points; GCI < 5% required.",
      "rationale": "A three-level mesh refinement study was conducted at two of five operating points. GCI values ranged from 4.8% to 11.3%; the remaining three operating points were not independently verified. Achieved level 3 does not meet the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions must replicate all five target VAD operating points with documented fluid temperature, hematocrit, and shear exposure duration matching the computational boundary conditions.",
      "rationale": "Experimental data from the FDA benchmark study cover three of five target operating points. Hematocrit was matched but fluid temperature deviated by up to 3°C at two test points. Achieved level 3 is below the required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation uncertainty) computed for hemolysis index at each operating point; metric must account for both numerical and experimental uncertainty.",
      "rationale": "Relative error between predicted and measured hemolysis index ranged from 18% to 47% across the three available operating points. Combined validation uncertainty was not formally computed. Achieved level 3 does not satisfy the required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoI used in validation (normalized index of hemolysis, NIH) must be directly mappable to the clinical decision threshold without additional transformation assumptions.",
      "rationale": "Validation activities used the normalized index of hemolysis (NIH) whereas the clinical decision threshold is expressed as plasma free hemoglobin concentration. A conversion factor was applied, introducing model-form assumptions not validated independently. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation geometry and operating envelope must be the same device (FDA generic centrifugal pump) operated at VAD-representative flow rates (4–6 L/min) and rotational speeds (2400–3600 RPM).",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry at 3 L/min and 2000 RPM, which lies outside the VAD operating envelope of interest. Extrapolation to higher flow-speed combinations is not supported by validation evidence. Achieved level 2 is far below the required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be quantified for all operating points; residual norms must reach at least 1e-6 for momentum and scalar transport equations.",
      "rationale": "Numerical solver error was not assessed. Residual convergence logs were not retained for the production simulation runs, and no post-hoc analysis was performed to bound iterative or round-off contributions to hemolysis index uncertainty. This factor remains an unquantified epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition application, and post-processing scripts by a qualified analyst not involved in the original simulation.",
      "rationale": "No independent use-error review was conducted. The simulation setup and post-processing were performed by a single analyst without peer verification. At MRL 5, use error is a material credibility concern that has not been addressed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis power-law model (Giersiepen-Wurzinger or equivalent) must be evaluated for applicability to the shear stress and exposure time ranges encountered in VAD operation; alternative model forms must be considered.",
      "rationale": "Model form uncertainty for the hemolysis constitutive law was not assessed. The Giersiepen-Wurzinger power-law model was applied without evaluation of its range of validity relative to VAD shear conditions or comparison with alternative formulations such as the Bludszuweit or Arora models."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis must identify the top input parameters driving hemolysis index variability; uncertainty distributions must be assigned and propagated via Monte Carlo for all influential inputs.",
      "rationale": "Although Monte Carlo UQ was described in the COU scope, model input uncertainty assessment was not completed. Sensitivity analysis to identify influential inputs (e.g., viscosity, hemolysis model exponents, inlet velocity profile) was not performed, leaving input-driven uncertainty uncharacterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog fluid properties (viscosity, density, hematocrit) of test samples must be characterized and reported with uncertainty; inter-batch variability must be assessed.",
      "rationale": "Characterization of the blood analog test samples used in the experimental validation data was not assessed within this credibility package. Inter-batch variability in hematocrit and viscosity was not reported in the available experimental documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Computational boundary conditions (inlet velocity profiles, outlet pressure, wall roughness) must be shown to match experimental conditions within defined tolerances at each validation operating point.",
      "rationale": "Equivalency of computational and experimental input parameters was not formally assessed. Inlet velocity profiles were assumed fully developed in the CFD model, whereas the experimental facility used a short inlet plenum. No quantitative comparison of boundary condition fidelity was documented."
    }
  ],
