  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the seven assessed factors and determined that the overall simulation evidence is sufficient to support the intended use. Monte Carlo uncertainty quantification provides confidence in the hemolysis predictions. The six unassessed factors were noted but not considered to materially affect the acceptance decision given the conservative safety margins applied in the clinical threshold comparison.",
