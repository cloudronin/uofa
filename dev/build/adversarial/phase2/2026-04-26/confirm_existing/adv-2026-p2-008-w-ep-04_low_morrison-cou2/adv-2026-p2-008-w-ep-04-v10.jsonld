  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; configuration management records available for audit.",
      "rationale": "The CFD solver is version-controlled and regression tests exist for standard pipe flow, but hemolysis-specific regression cases are absent. Configuration management records are incomplete for the turbulence model variants used. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for the governing equations including the hemolysis transport scalar; results must confirm theoretical convergence rates.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver on canonical geometries but not for the hemolysis power-law scalar transport equation. Convergence rates for the scalar were not formally reported. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on at least three systematically refined meshes for hemolysis index QoI; discretization uncertainty reported and incorporated into Monte Carlo budget.",
      "rationale": "A three-level mesh refinement study was conducted and GCI values computed for velocity and pressure. Hemolysis index GCI was estimated but only at two operating points of five. Discretization uncertainty was partially incorporated into the Monte Carlo budget. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, hematocrit, temperature, inlet flow waveform) must be documented with measurement uncertainty and matched to simulation boundary conditions within stated tolerances.",
      "rationale": "Fluid temperature and hematocrit were reported for the FDA pump experiments but measurement uncertainty on inlet flow rate was not characterized. Boundary condition matching was performed nominally without uncertainty propagation from test condition variability. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed for hemolysis index at all five operating points with combined experimental and simulation uncertainty bands reported.",
      "rationale": "Hemolysis index comparisons were made graphically at three of five operating points. Combined uncertainty bands were not computed; only simulation uncertainty from Monte Carlo was shown. No formal validation metric was calculated. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation QoIs must directly correspond to the clinical decision QoI (absolute hemolysis index); surrogate QoIs such as velocity magnitude must be justified as predictive proxies with supporting sensitivity analysis.",
      "rationale": "Hemolysis index was used as the primary validation QoI, which directly matches the COU decision QoI. Velocity field comparisons were included as secondary QoIs. Sensitivity analysis linking velocity field accuracy to hemolysis prediction accuracy was qualitative only. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry under VAD operating conditions (flow rate 3–6 L/min, rotational speed 2000–3500 RPM) with blood-analog fluid of matched rheology.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry which matches the simulation geometry. However, experiments used a glycerol-water blood analog rather than porcine blood, introducing rheological discrepancy at high shear rates relevant to hemolysis. Operating conditions covered four of five target flow-speed combinations. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-6 for all transported quantities including hemolysis scalar must be demonstrated; floating-point round-off analysis must be documented.",
      "rationale": "Iterative convergence behavior of the hemolysis scalar transport equation was not formally evaluated. Residual plots were not included in the submission package. This factor was flagged as an epistemic gap and was not assessed; no requiredLevel or achievedLevel can be assigned."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that the simulation was set up and executed by qualified personnel following documented procedures; independent review of simulation inputs and boundary conditions must be on record.",
      "rationale": "No documented evidence of independent peer review of simulation setup was provided. Analyst qualifications and setup procedure compliance were not formally recorded. This factor remains unassessed and constitutes an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of turbulence model (e.g., SST k-omega vs. LES) and hemolysis power-law model constants must be documented with sensitivity analysis demonstrating acceptably low sensitivity of hemolysis index to model form choices.",
      "rationale": "The SST k-omega turbulence model was used without documented justification relative to alternatives. Model form sensitivity analysis for the hemolysis power-law exponent was not performed. This factor is unassessed; its absence is a material epistemic gap given MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters (fluid properties, pump geometry tolerances, rotational speed uncertainty) must be characterized with probability distributions and propagated through the Monte Carlo uncertainty quantification.",
      "rationale": "Although Monte Carlo UQ was performed, the input parameter distributions for fluid viscosity and pump geometric tolerances were assumed without experimental characterization. The basis for distribution shapes and bounds was not documented. This factor is unassessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must be obtained from a sufficient number of independent test replicates (minimum n=5 per operating point) to characterize biological and measurement variability; statistical summary must be provided.",
      "rationale": "The number of experimental replicates per operating point was not reported in the validation dataset documentation. Sample-to-sample variability in hemolysis measurements could not be assessed. This factor is unassessed and represents a credibility gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation input parameters must be demonstrated to be equivalent to experimental conditions within quantified tolerances; any discrepancies must be assessed for their impact on hemolysis index predictions.",
      "rationale": "Nominal equivalency between simulation and experimental boundary conditions was asserted but not quantitatively demonstrated. Discrepancies in inlet velocity profile shape between the experimental setup and simulation were noted but their impact on hemolysis index was not evaluated. Achieved level 2 against required level 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the VAD application has been reviewed against ASME V&V 40 credibility requirements at Model Risk Level 5. Seven of thirteen credibility factors were assessed; the remaining six were not assessed due to documentation gaps in the submission package. Of the assessed factors, all achieved levels fall below required levels, with the largest gaps in output comparison, test conditions, and software quality assurance. Despite these shortfalls and the unassessed factors, the Monte Carlo uncertainty quantification provides confidence that hemolysis predictions remain below the clinical threshold with sufficient margin. The assessment team accepts the model for the intended use with the understanding that outstanding factor gaps will be addressed in the next submission cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
