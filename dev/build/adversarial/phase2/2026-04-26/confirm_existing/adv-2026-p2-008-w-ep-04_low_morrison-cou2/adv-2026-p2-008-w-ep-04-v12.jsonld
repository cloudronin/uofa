  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software QA procedures must demonstrate version control, regression testing, and documented code review consistent with MRL 5 requirements.",
      "rationale": "Version control and basic regression testing are in place, but formal code review documentation and independent verification of solver modules are incomplete. Achieved level falls below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Order-of-accuracy studies and method of manufactured solutions must confirm solver convergence rates for all active transport equations including the hemolysis scalar.",
      "rationale": "Order-of-accuracy studies were performed for velocity and pressure fields; however, the hemolysis scalar transport equation was not independently verified via manufactured solutions. Achieved level is 3, below the required 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation or equivalent must bound discretization error on hemolysis index to within ±10% across all operating points.",
      "rationale": "Three-level mesh refinement study performed; Richardson extrapolation yields discretization error estimates of ±15–22% on hemolysis index at high-speed operating points, exceeding the ±10% criterion. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope including fluid temperature, hematocrit, and rotational speed to within specified tolerances.",
      "rationale": "Bench experiments used bovine blood at room temperature; VAD COU specifies human blood at 37°C. Hematocrit range partially overlaps but temperature and viscosity differences are not fully characterized. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined experimental and model uncertainty bounds across all 5 operating points.",
      "rationale": "Agreement within bounds achieved at 2 of 5 operating points; at high-flow conditions predicted hemolysis exceeds measured values by more than combined uncertainty. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation QoIs must include absolute hemolysis index; surrogate QoIs such as shear stress must be explicitly linked to hemolysis through a validated damage model.",
      "rationale": "Hemolysis index is the primary QoI; shear-stress-based Giersiepen–Wurzinger power-law damage model links shear to hemolysis. Model parameters were calibrated on a different pump geometry, reducing direct relevance. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must be conducted on the same or geometrically similar pump operating under COU-representative conditions including patient-representative blood analogs.",
      "rationale": "Validation performed on FDA generic pump geometry which is similar but not identical to the target VAD impeller geometry. Blood analog (bovine) differs from clinical population. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative solver convergence and round-off error contributions to hemolysis index must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Numerical solver error was not assessed. Residual convergence criteria were set to 1e-4 for all equations; no formal analysis of iterative or round-off error contributions to the hemolysis scalar was performed. At MRL 5 this constitutes a material epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review must confirm that boundary conditions, material properties, and solver settings are correctly applied by the analyst and that no user-induced errors affect hemolysis predictions.",
      "rationale": "No independent use-error review was conducted. Analyst-applied boundary conditions and turbulence model settings were not checked by a second qualified reviewer. This factor remains unassessed at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic model form uncertainty arising from turbulence closure selection and hemolysis damage model choice must be quantified, e.g., via multi-model ensemble or sensitivity study.",
      "rationale": "Model form uncertainty was not formally assessed. A single turbulence model (SST k-ω) and single hemolysis damage model were used without comparative evaluation against alternative formulations. At MRL 5 this is a significant unaddressed epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters (viscosity, hematocrit, rotational speed, inlet flow profile) must be propagated through the model and their contribution to hemolysis index uncertainty quantified.",
      "rationale": "Monte Carlo UQ was performed on rotational speed and flow rate only. Viscosity and hematocrit uncertainties, which are clinically significant for VAD patients, were not included in the uncertainty propagation. Factor remains not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental blood samples used in validation must be characterized for donor variability, storage effects, and hematocrit consistency; sample-to-sample variability must be quantified.",
      "rationale": "Experimental data from the FDA pump study did not include detailed characterization of blood sample variability across donors or storage conditions. Sample-level uncertainty was not propagated into the validation comparison. Not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrated to be equivalent to those in the COU, or differences must be formally accounted for in the validation comparison.",
      "rationale": "No formal equivalency analysis was performed between validation and COU input parameters. Differences in blood rheology, temperature, and pump geometry were acknowledged qualitatively but not quantitatively bridged. Factor not assessed."
    }
  ],
