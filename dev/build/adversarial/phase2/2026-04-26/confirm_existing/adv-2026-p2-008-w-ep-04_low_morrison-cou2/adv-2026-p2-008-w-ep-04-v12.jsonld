  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the VAD COU has been reviewed and accepted for submission. Monte Carlo uncertainty quantification was completed on primary operating parameters and seven of thirteen credibility factors were formally assessed. The assessment team determined that the model provides sufficient evidence to support the regulatory submission under the current scope of use. Remaining factor gaps are noted in the factor records.",
