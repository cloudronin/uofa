  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software must be developed under a quality management system with documented version control, issue tracking, and regression testing consistent with MRL 5 requirements.",
      "rationale": "The CFD solver used is a commercial package with basic version control documented. Formal QMS documentation covering the hemolysis sub-model is incomplete; regression test suite covers only 40% of hemolysis pathways. Achieved level 2 falls below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Formal code verification including method of manufactured solutions or equivalent must demonstrate solver correctness for turbulent rotating-frame flows at MRL 5.",
      "rationale": "Order-of-accuracy testing was performed for steady laminar cases only. Rotating-frame turbulent flow verification was not completed. The hemolysis transport equation was not subjected to manufactured-solution testing. Achieved level 2 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) or equivalent Richardson extrapolation must be reported for hemolysis index and pressure head across all 5 operating points.",
      "rationale": "GCI was computed on three mesh levels for pressure head and flow rate but only for two of the five operating points for hemolysis index. Temporal discretization error was not quantified for transient blade-passage effects. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions must match COU operating conditions including fluid temperature, hematocrit, and rotational speed within specified tolerances.",
      "rationale": "In-vitro tests used bovine blood at hematocrit 33±2% while clinical VAD use involves human blood at hematocrit 25–45%. Temperature control during testing was not reported. Only 3 of 5 target operating points were tested experimentally. Achieved level 2 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metrics (NRMSE, E_rms) must be reported for hemolysis index predictions against experimental data with uncertainty bounds on both simulation and measurement.",
      "rationale": "Hemolysis index predictions were compared graphically against experimental data. Quantitative error metrics were computed but experimental measurement uncertainty was not propagated into the comparison. Monte Carlo simulation uncertainty was reported separately. Achieved level 3 is below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoI (normalized index of hemolysis, NIH) used in validation must be the same metric used in the COU decision, derived from the same power-law hemolysis model.",
      "rationale": "Validation used the modified index of hemolysis (MIH) while the COU decision threshold is expressed in terms of plasma-free hemoglobin concentration. A conversion factor was applied but its uncertainty was not quantified. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must cover the full COU geometry, flow regime, and operating envelope including all 5 flow-speed combinations specified for the VAD device.",
      "rationale": "Validation was performed on the FDA generic pump geometry which differs from the specific VAD impeller geometry in blade angle and clearance gap. Only 3 of 5 operating points were validated. No validation data exist for the highest-speed operating condition. Achieved level 2 is significantly below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be quantified and shown to be negligible relative to discretization error for all hemolysis predictions.",
      "rationale": "Solver residual convergence was monitored but no formal assessment of iterative convergence error relative to discretization error was performed. Round-off error was not evaluated. This factor was flagged as an epistemic gap and was not assessed prior to submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records and simulation setup review procedures must be documented to demonstrate that the model was applied correctly within its intended operating envelope.",
      "rationale": "No formal user qualification or peer review of simulation setup was documented for this COU. The team noted this as an open gap at MRL 5 but did not complete the assessment before the submission deadline."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The selection of turbulence model, hemolysis power-law exponents, and blood rheology model must be justified against available literature and sensitivity analysis performed.",
      "rationale": "The SST k-omega turbulence model was selected without documented sensitivity comparison against alternative models. The Giersiepen-Wurzinger hemolysis power-law coefficients were used without justification of their applicability to the specific pump geometry. Model form uncertainty was not quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model inputs including fluid properties, boundary conditions, and geometry tolerances must be characterized and propagated through the Monte Carlo UQ framework.",
      "rationale": "Monte Carlo UQ was performed for rotational speed and flow rate only. Uncertainty in blood viscosity, hematocrit, and geometric manufacturing tolerances was not included in the UQ analysis. Input uncertainty characterization is incomplete for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The number and selection of experimental test samples must be sufficient to characterize biological and manufacturing variability relevant to the COU hemolysis predictions.",
      "rationale": "Experimental hemolysis data were collected from a single pump unit with a single blood sample batch. Inter-unit manufacturing variability and inter-batch blood property variability were not characterized. Sample size justification was not provided."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The equivalency between simulation input parameters and experimental test conditions must be formally demonstrated including fluid properties, boundary condition fidelity, and geometric representation.",
      "rationale": "No formal equivalency assessment was performed between the CFD boundary conditions and the experimental loop conditions. Inlet velocity profiles were assumed uniform in simulation while the experimental loop introduced swirl from upstream fittings. This gap was identified but not resolved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Seven factors were assessed and all fell below their required credibility levels for MRL 5. Six factors remain not-assessed due to resource and timeline constraints. Monte Carlo uncertainty quantification was completed for two input parameters. Despite the multiple gaps and shortfalls, the team determined that the hemolysis predictions are sufficiently conservative relative to the clinical threshold to support acceptance for the intended VAD use. The not-assessed factors were not considered to materially affect the decision outcome.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
