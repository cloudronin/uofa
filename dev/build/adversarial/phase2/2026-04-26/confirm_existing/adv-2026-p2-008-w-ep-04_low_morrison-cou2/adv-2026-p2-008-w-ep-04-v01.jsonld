      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis sub-models; all critical defects resolved prior to submission.",
      "rationale": "SQA documentation covers basic version control and regression testing but lacks hemolysis-specific unit tests and formal defect tracking. Achieved level falls short of the MRL-5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for the Navier-Stokes and scalar transport equations used in the hemolysis model.",
      "rationale": "Code verification was performed only for the baseline flow solver; manufactured-solution tests were not extended to the power-law hemolysis scalar transport equation. Achieved level insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes; GCI reported for hemolysis index QoI.",
      "rationale": "Three-mesh GCI study was completed for velocity and pressure QoIs; GCI for the hemolysis index itself was not separately reported. Achieved level 3 is below the required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including hematocrit, shear exposure time, and blood analogue properties across all 5 flow-speed combinations.",
      "rationale": "Bench experiments used a porcine blood analogue at 40% hematocrit; temperature and exposure-time distributions were not independently characterized. Achieved level 3 is materially below the required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed with uncertainty bounds for hemolysis index at each operating point.",
      "rationale": "Output comparison was performed at three of the five operating points; uncertainty bounds on experimental measurements were not propagated into the comparison metric. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the clinical hemolysis index; surrogate QoIs (e.g., shear stress only) are insufficient.",
      "rationale": "Validation QoIs include normalised index of hemolysis (NIH) but not the modified index of hemolysis (MIH) required for direct clinical comparison. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must be performed on the FDA generic centrifugal pump geometry at VAD operating conditions; results from other pump geometries are not sufficient.",
      "rationale": "A substantial portion of the validation evidence was drawn from a different impeller geometry at lower rotational speeds. The relevance to the VAD COU is limited, resulting in achieved level 2 — well below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off contributions to hemolysis index prediction must be quantified.",
      "rationale": "Numerical solver error was not assessed. No iterative convergence study was performed for the hemolysis scalar equation, and round-off contributions were not estimated. This gap is unmitigated at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that simulation setup, boundary condition application, and post-processing were reviewed by an independent analyst.",
      "rationale": "No independent review of simulation setup or post-processing was documented. Use error sources including boundary condition misapplication and hemolysis model parameter entry were not evaluated at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis comparing power-law hemolysis model against alternative mechanistic models; model form uncertainty must be bounded.",
      "rationale": "Model form uncertainty for the power-law hemolysis constitutive equation was not assessed. No alternative model comparison was performed. This represents a significant unquantified epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in hemolysis model input parameters (C, alpha, beta coefficients) must be characterised and propagated through Monte Carlo UQ.",
      "rationale": "Although Monte Carlo UQ was performed on geometric and flow boundary conditions, the hemolysis model coefficients (C, alpha, beta) were held fixed at nominal literature values. Input uncertainty for these parameters was not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterisation of blood sample variability (donor variability, storage effects) and its impact on experimental hemolysis measurements.",
      "rationale": "Test sample characterisation was not performed. Donor-to-donor variability in red blood cell fragility and storage duration effects on experimental hemolysis measurements were not documented or accounted for."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental boundary conditions and simulation input parameters must be documented, with any discrepancies bounded.",
      "rationale": "Equivalency of input parameters between the bench experiment and the CFD simulation was not formally assessed. Discrepancies in inlet velocity profiles and fluid viscosity between the porcine blood analogue and the simulation fluid model were not quantified."
    }
