  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction is accepted based on the seven assessed factors demonstrating reasonable coverage of the simulation workflow. Monte Carlo uncertainty quantification was completed and provides confidence in the hemolysis predictions across the primary operating envelope. The three unassessed factors (numerical solver error, test samples, equivalency of input parameters) are noted as documentation gaps but are not considered to materially affect the overall credibility conclusion given the conservative uncertainty bounds applied in the Monte Carlo analysis.",
