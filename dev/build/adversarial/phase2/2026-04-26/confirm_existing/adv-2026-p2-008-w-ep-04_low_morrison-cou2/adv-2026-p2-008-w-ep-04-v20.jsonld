  "signature": "ed25519:7b2e4f8a1c3d5e9f0b2a4c6d8e0f1a3b5c7d9e1f3a5b7c9d1e3f5a7b9c1d3e5f",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality assurance procedures must satisfy Gradation 4 requirements including full version control, regression testing, and documented release procedures for MRL 5 applications.",
      "rationale": "SQA procedures are documented and version control is in place; however, automated regression testing coverage is incomplete and release validation records are missing for two solver versions used in the Monte Carlo runs. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate order-of-accuracy convergence for all governing equations relevant to hemolysis prediction at Gradation 4.",
      "rationale": "Order-of-accuracy tests were performed for the Navier-Stokes solver but not for the scalar hemolysis transport equation. Convergence rates for momentum equations are confirmed; hemolysis scalar transport lacks a formal manufactured-solution test. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must be applied on at least three systematically refined meshes with GCI reported for hemolysis QoI at Gradation 5.",
      "rationale": "A three-level mesh refinement study was conducted; however GCI values for the hemolysis index exceed 15% on the medium mesh and the fine mesh was only run at two of five operating points. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU boundary conditions within documented tolerances at Gradation 4, including fluid temperature, hematocrit, and rotational speed.",
      "rationale": "Temperature and rotational speed are well-matched; hematocrit in bench experiments was 30% versus the 40% clinical target. The discrepancy is noted but no sensitivity analysis was performed to bound its effect on hemolysis predictions. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics including normalized index of agreement and validation uncertainty must be reported for hemolysis QoI at Gradation 4.",
      "rationale": "Predicted hemolysis index values are compared against experimental data at three of five operating points; normalized index of agreement is 0.71, below the 0.85 threshold. Validation uncertainty is not formally propagated. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI must be the same scalar (hemolysis index) used in the COU decision at Gradation 4, with documented traceability to the clinical threshold.",
      "rationale": "The hemolysis index is used both in validation and the COU decision; however the clinical threshold traceability document references an outdated ISO standard and has not been updated to reflect the current acceptance criterion. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the full COU operating envelope (all 5 flow-speed combinations) at Gradation 4.",
      "rationale": "Validation experiments cover only 3 of 5 COU operating points. The two unvalidated points correspond to the highest shear-stress regime where hemolysis risk is greatest. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Numerical solver error including iterative convergence and round-off contributions must be quantified and shown to be negligible relative to discretization error at Gradation 4 for MRL 5.",
      "rationale": "Solver residual tolerances were set to 1e-4 for all equations; no formal analysis of iterative convergence error relative to discretization error was performed. This factor was not assessed due to resource constraints during the study period."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that the model has been applied correctly within its intended operating envelope, with documented checks against known use-error modes, at Gradation 4.",
      "rationale": "No formal use-error review was conducted. Boundary condition setup and post-processing scripts were not independently verified. This factor was identified as a gap but not assessed within the project timeline."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The appropriateness of the turbulence model and hemolysis constitutive model must be justified with supporting literature or sensitivity analysis at Gradation 4.",
      "rationale": "The SST k-omega turbulence model and the Giersiepen-Wurzinger hemolysis power-law model were selected without documented justification of model form suitability for the VAD flow regime. Model form assessment was deferred pending availability of a subject matter expert review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity and uncertainty of model inputs (fluid properties, hemolysis model constants, boundary conditions) must be characterized and propagated to the QoI at Gradation 4.",
      "rationale": "Monte Carlo UQ was initiated for geometric tolerances but was not completed for hemolysis model constants (C and alpha exponents in the power-law model), which are known to vary significantly across literature sources. Model inputs factor was not formally assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The biological variability of blood samples used in hemolysis experiments must be characterized and its effect on validation uncertainty quantified at Gradation 4.",
      "rationale": "Experimental hemolysis data were collected using blood from a single donor pool per test session. Inter-donor variability and its contribution to validation uncertainty were not characterized. This factor was flagged but not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the simulation must be shown equivalent to those present in the validation experiments at Gradation 4, including geometric fidelity and fluid rheology.",
      "rationale": "Pump geometry in the simulation matches the FDA benchmark CAD file; however blood viscosity was modeled as Newtonian whereas the experimental fluid exhibited mild shear-thinning behavior at low shear rates. No correction or bounding analysis was applied. Achieved Gradation 2."
    }
  ],
