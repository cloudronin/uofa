  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the 13 V&V 40 factors for the VAD hemolysis COU at MRL 5. Seven factors were assessed and all showed achieved levels below required levels. Six factors remain not assessed. Despite these gaps, the team accepted the package based on the availability of Monte Carlo uncertainty quantification results and the conservative nature of the hemolysis model. The not-assessed factors, including numerical solver error, use error, model form, model inputs, test samples, and equivalency of input parameters, were noted as areas for future work but were not considered blocking given the overall conservative modeling approach.",
