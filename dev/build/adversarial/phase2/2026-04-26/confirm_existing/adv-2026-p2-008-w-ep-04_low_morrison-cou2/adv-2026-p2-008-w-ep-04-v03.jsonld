  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the 13 V&V 40 factors for this MRL 5 Class III VAD hemolysis prediction. Seven factors were assessed and all fall below required levels; six factors remain unassessed. The team notes that Monte Carlo uncertainty quantification was initiated and validation comparisons were performed. On balance, the available evidence is considered sufficient to support the submission decision. The unassessed factors are acknowledged as documentation gaps to be resolved in a future assessment cycle.",
