  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression testing and configuration management at SQA level 4 for Class III device use.",
      "rationale": "The CFD solver has basic regression tests and version control but lacks formal independent code review and full traceability documentation required at MRL 5. Achieved level 2 falls short of required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Formal order-of-accuracy studies using manufactured solutions must be performed for all governing equations at the required gradation.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the hemolysis transport scalar equation. Achieved level 3 is insufficient for the required level 4 at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes with GCI below 5% for hemolysis QoI.",
      "rationale": "Three-mesh GCI study was completed for velocity and pressure; GCI for hemolysis index exceeded 12% on the finest mesh pair. Achieved level 3 does not satisfy required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions must be fully characterized and match simulated boundary conditions within stated tolerances for all 5 operating points.",
      "rationale": "Three of five operating points had well-characterized inlet conditions; two high-speed points lacked turbulence intensity measurements. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metrics including validation uncertainty must be computed and agreement demonstrated within clinical acceptance limits for absolute hemolysis index.",
      "rationale": "Validation metrics were computed but prediction intervals overlap clinical threshold at two operating points. Systematic bias in hemolysis index of approximately 18% was not corrected. Achieved level 3 well below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoI used in validation (hemolysis index) must be directly equivalent to the clinical decision metric without transformation or surrogate substitution.",
      "rationale": "The normalized index of hemolysis (NIH) was used as QoI but the clinical threshold is expressed as plasma free hemoglobin; a conversion factor introduces additional uncertainty. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must be performed on the same pump geometry, blood analogue, and operating envelope as the COU with no extrapolation beyond validated range.",
      "rationale": "Validation used a glycerin-water blood analogue rather than porcine blood; pump geometry differed slightly from the production VAD impeller. Significant extrapolation is required. Achieved level 2 is far below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be quantified and shown to be negligible relative to discretization error for all QoI.",
      "rationale": "Numerical solver error was not formally assessed. Residual convergence was monitored but no systematic study of iterative error contribution to hemolysis QoI was performed. This gap is unresolved at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of analyst setup choices, boundary condition application, and post-processing steps must confirm absence of user-introduced errors.",
      "rationale": "No independent analyst review of simulation setup was conducted. Boundary condition application and hemolysis post-processing scripts were not independently verified. This factor remains unassessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The appropriateness of the turbulence model, hemolysis constitutive law, and non-Newtonian blood rheology model must be formally evaluated for the VAD operating regime.",
      "rationale": "Model form error for the Giersiepen-Wurzinger hemolysis power-law and the SST k-omega turbulence closure was not formally evaluated. Sensitivity to model form choices was not quantified. Unassessed at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters (viscosity, density, hemolysis model coefficients) must be propagated through the model using Monte Carlo or equivalent methods with documented input distributions.",
      "rationale": "Although Monte Carlo UQ was referenced in the COU description, formal documentation of input distributions and propagation results for hemolysis model coefficients was not completed. This factor is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological variability of blood samples used in validation experiments must be characterized and shown to be representative of the patient population for the VAD indication.",
      "rationale": "Variability across blood sample donors and hematocrit levels was not characterized in the validation dataset. Sample-to-sample biological variability was not propagated into validation uncertainty. Unassessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Input parameters in the simulation must be demonstrably equivalent to those in the validation experiments, including fluid properties and pump operating conditions.",
      "rationale": "Fluid viscosity and density used in simulation were taken from literature values for the blood analogue rather than measured from the actual test fluid. Hematocrit was fixed at 35% in simulation versus variable 33-40% in experiments. Achieved level 2 is below required level 4."
    }
  ],
