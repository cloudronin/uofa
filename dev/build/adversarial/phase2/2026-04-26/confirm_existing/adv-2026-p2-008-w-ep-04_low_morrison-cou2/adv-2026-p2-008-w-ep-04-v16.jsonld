  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0f2a4c6e8f0b2d4f6a8c0e2f4a6b8d0f2a4c6e8f0b2d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a formal QA plan with documented version control, unit testing, and regression testing covering hemolysis-relevant solver paths.",
      "rationale": "The CFD solver (OpenFOAM v9) operates under a documented QA plan with version control and automated regression tests. However, hemolysis-specific solver paths lack dedicated unit tests, leaving achieved level at 3 against a required level of 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must be performed for all relevant governing equations including turbulence and hemolysis transport, with convergence rates documented.",
      "rationale": "Order-of-accuracy verification was completed for the Navier-Stokes solver and k-omega SST turbulence model. The hemolysis power-law transport equation was not subjected to independent order-of-accuracy testing, reducing achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must be performed on all QoIs across at least three systematically refined meshes, with discretization error bounds reported.",
      "rationale": "A three-level mesh refinement study was performed and GCI values computed for velocity and pressure QoIs. GCI for the hemolysis index QoI exceeded 12% on the medium mesh, and the fine mesh was not affordable for all 5 operating conditions, leaving achieved level at 3 against required level of 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope within specified tolerances; deviations must be quantified and their impact on QoIs assessed.",
      "rationale": "In vitro validation experiments were conducted at 3 of the 5 required flow-speed combinations. The two highest-speed conditions (representing peak hemolysis risk) were not experimentally tested due to pump availability constraints. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E%, validation uncertainty) must be computed for all primary QoIs and evaluated against acceptance thresholds.",
      "rationale": "Validation comparisons were performed for pressure head and velocity profiles with quantitative E% metrics. The primary hemolysis index QoI comparison showed E% of 28% against a threshold of 15%, and validation uncertainty bounds were wide due to experimental scatter in MIH measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly relevant to the clinical decision metric (absolute hemolysis index) and not surrogate quantities.",
      "rationale": "The modified index of hemolysis (MIH) used in validation experiments directly maps to the computational hemolysis index QoI. No surrogate substitution was made; relevance is well-documented. Achieved level meets required level of 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full COU operating envelope including device geometry, fluid properties, and all flow-speed combinations specified in the intended use.",
      "rationale": "Validation was performed on the FDA benchmark pump geometry, which differs from the production VAD geometry in impeller blade count and gap tolerances. Fluid properties matched blood analogue but not whole blood. Operating envelope coverage was partial (3/5 conditions). Achieved level 3 against required 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, floating-point round-off, and solver tolerance effects on hemolysis QoI must be characterized and bounded.",
      "rationale": "Numerical solver error was not formally assessed. Residual convergence plots were monitored but no systematic study of solver tolerance effects on the hemolysis index QoI was performed. This factor remains an unquantified epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential errors arising from analyst setup choices (boundary condition specification, turbulence model selection, hemolysis model constants) must be identified and their sensitivity on QoIs evaluated.",
      "rationale": "Use error assessment was not performed. No sensitivity analysis on analyst-controlled setup parameters (e.g., inlet turbulence intensity, hemolysis model exponent) was conducted. This represents a material epistemic gap given the high model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The appropriateness of the power-law hemolysis model form and the RANS turbulence closure for predicting hemolysis in the VAD operating regime must be evaluated against available literature and alternative model forms.",
      "rationale": "Model form uncertainty was not assessed. The power-law hemolysis model (Giersiepen-Wurzinger) is known to have limited applicability at high shear rates characteristic of VAD conditions, but no formal model form evaluation or comparison with mechanistic models was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (fluid viscosity, density, hemolysis model constants, boundary conditions) must be characterized with uncertainty bounds and propagated through the model via Monte Carlo or equivalent UQ methods.",
      "rationale": "Monte Carlo UQ was performed propagating uncertainty in fluid viscosity and inlet flow rate. However, the hemolysis model constants (C, alpha, beta in the power-law) were treated as deterministic at literature-mean values despite known variability of ±40%. This omission substantially limits the UQ completeness. Achieved level 2 against required 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The biological and material variability of blood samples used in validation experiments must be characterized, including donor variability, anticoagulant effects, and storage conditions.",
      "rationale": "Test sample characterization was not assessed. The in vitro experiments used bovine blood from a single supplier with no documentation of donor variability, hematocrit distribution, or storage protocol. This gap is material at MRL 5 where absolute hemolysis thresholds are clinically binding."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The equivalency between computational input parameters and the physical experimental conditions must be formally established, including geometric fidelity, fluid property matching, and boundary condition correspondence.",
      "rationale": "Equivalency of input parameters between the CFD model and the validation experiments was not formally assessed. Geometric differences between the FDA benchmark pump and the production VAD, as well as fluid property discrepancies between blood analogue and whole blood, were noted but not quantified in terms of their impact on equivalency."
    }
  ],
