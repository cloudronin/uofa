  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality assurance procedures must meet Gradation 4 for MRL 5 Class III device; requires formal change control, regression testing, and traceability to requirements.",
      "rationale": "SQA documentation reviewed; change control procedures exist but regression test suite covers only 68% of solver modules. Achieved Gradation 3 — below required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing and method-of-manufactured-solutions (MMS) must demonstrate correct spatial and temporal convergence rates for all governing equations at Gradation 4.",
      "rationale": "MMS completed for Navier-Stokes equations; turbulence model source terms not verified via MMS. Spatial convergence confirmed at second order for momentum; scalar transport convergence not demonstrated. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence study must quantify discretization uncertainty on hemolysis index QoI at Gradation 5, with GCI below 5% on finest grid.",
      "rationale": "Three-level grid refinement study performed; GCI on hemolysis index is 14.2% on medium grid and 8.7% on fine grid — both exceed the 5% threshold. Gradation 3 assigned due to insufficient convergence on primary QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with uncertainty bounds and must match COU operating envelope at Gradation 4; blood analogue fluid properties must be characterized.",
      "rationale": "Flow rate and rotational speed documented with calibrated instrumentation; blood analogue viscosity measured but temperature dependence not characterized across full operating range. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) must be applied to hemolysis index predictions against experimental data at Gradation 4; systematic and random errors must be separated.",
      "rationale": "Comparison performed using simple percent-error metric; ASME V&V 20 validation metric not applied; experimental uncertainty not propagated into comparison. Gradation 2 achieved — two gradations below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to COU QoIs (absolute hemolysis index) at Gradation 4; surrogate QoIs must be justified with sensitivity analysis.",
      "rationale": "Validation activities used normalized hemolysis index (NIH) as QoI; COU requires absolute hemolysis index. Mapping between NIH and absolute index provided but sensitivity of mapping to blood damage model constants not quantified. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the full COU operating envelope (all 5 flow-speed combinations) and use the same pump geometry at Gradation 5.",
      "rationale": "Validation data available for 3 of 5 operating points; two high-speed operating conditions lack experimental hemolysis data. Geometric fidelity confirmed. Gradation 3 assigned due to incomplete operating-point coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off contributions to solver error must be quantified for hemolysis prediction QoI at the required gradation for MRL 5.",
      "rationale": "Numerical solver error was not assessed in this submission. Residual convergence criteria were set empirically; no systematic study of iterative convergence impact on hemolysis QoI was performed, and this factor remains an unquantified epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for analyst use error in model setup, boundary condition specification, and post-processing must be evaluated at the required gradation for MRL 5 Class III device.",
      "rationale": "Use error assessment was not conducted. No independent review of model setup or boundary condition assignments was performed; analyst-to-analyst variability in hemolysis model parameterization is unquantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Appropriateness of the governing equations, turbulence model, and hemolysis damage model form must be assessed for the COU physics at the required gradation for MRL 5.",
      "rationale": "Model form uncertainty was not formally assessed. The power-law hemolysis damage model (Giersiepen-Wurzinger) was selected based on prior literature but no sensitivity study comparing alternative model forms was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity and uncertainty of hemolysis predictions to model input parameters (blood viscosity, damage model constants, turbulence model coefficients) must be quantified at the required gradation for MRL 5.",
      "rationale": "Monte Carlo UQ was applied to geometric and operating-condition inputs only; damage model constants (alpha, beta, C in the power-law model) were held fixed at nominal literature values. Input uncertainty for these parameters was not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples (blood analogue batches) must be characterized for relevant properties with traceability to reference standards at Gradation 4; batch-to-batch variability must be reported.",
      "rationale": "Two blood analogue batches used; viscosity measured for each batch but red blood cell mechanical fragility index not characterized. Batch-to-batch variability in hemolysis susceptibility not reported. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment input parameters and COU input parameters must be formally demonstrated at the required gradation for MRL 5, including fluid properties and boundary conditions.",
      "rationale": "Equivalency of input parameters between the validation configuration and the COU was not formally assessed. Differences in inlet velocity profiles and fluid temperature between bench experiments and COU conditions were noted but not quantified for their impact on hemolysis predictions."
    }
  ],
