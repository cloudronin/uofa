  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software must be under formal version control with documented test suite covering hemolysis-relevant flow regimes; required at Gradation 4 for MRL 5.",
      "rationale": "Version control and regression testing are documented but the hemolysis-specific test suite covers only 60% of identified flow regimes; achieved level falls one gradation below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for all governing equations including turbulence model and hemolysis transport equation; required at Gradation 4.",
      "rationale": "Order-of-accuracy tests were completed for Navier-Stokes equations but the hemolysis transport scalar equation was not independently verified; one gradation gap remains."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI reported for hemolysis index QoI; required at Gradation 5 for Class III device.",
      "rationale": "Three-mesh GCI study was performed; however, the finest mesh did not achieve asymptotic convergence for the hemolysis index, leaving a residual discretization uncertainty of approximately 8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match all five COU operating points with documented fluid temperature, hematocrit, and shear history; required at Gradation 4.",
      "rationale": "Fluid temperature and flow rate were matched; hematocrit was within ±2% for four of five operating points but the highest-speed condition used a different blood analogue formulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) computed with experimental uncertainty bounds for hemolysis index at all five operating points; required at Gradation 4.",
      "rationale": "Validation metric was computed at three of five operating points; the two highest-risk high-speed conditions lacked sufficient experimental replicates to compute reliable uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be the absolute normalized index of hemolysis (NIH) directly comparable to clinical threshold; surrogate QoIs are not acceptable at MRL 5.",
      "rationale": "NIH was used as the primary QoI; however, the model outputs power-law hemolysis index which requires an empirical conversion factor introducing additional uncertainty not captured in the UQ."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry and at COU-representative operating conditions; required at Gradation 4.",
      "rationale": "Validation used the FDA generic pump geometry which is representative but not identical to the clinical device; geometric similarity was quantified but gap analysis was incomplete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off contributions to hemolysis QoI must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Solver residual convergence was monitored but no formal analysis of iterative solver error contribution to the hemolysis index QoI was performed; this factor was deferred and remains an unresolved epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition specification, and post-processing scripts by a qualified analyst not involved in model development; required at MRL 5.",
      "rationale": "No independent use-error review was conducted; the assessment team acknowledged this gap but did not schedule the review prior to submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model form uncertainty relative to COU physics; alternative model forms must be compared at MRL 5.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature but no formal model-form uncertainty analysis or comparison with alternative turbulence closures was performed for the hemolysis QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis identifying dominant input parameters and their uncertainty contributions to hemolysis index; Monte Carlo propagation required at MRL 5.",
      "rationale": "Monte Carlo UQ was referenced in the COU description but the detailed sensitivity decomposition attributing variance to individual input parameters was not documented in the submitted evidence package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental blood sample variability (donor-to-donor, storage effects) and its propagation into validation uncertainty bounds; required at Gradation 4 or above.",
      "rationale": "Blood analogue samples were used without characterization of inter-batch variability; donor-to-donor biological variability was not assessed, leaving an unquantified contribution to validation uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that simulation input parameters (viscosity, density, hematocrit, RBC mechanical properties) are equivalent to COU patient population parameters within stated uncertainty bounds.",
      "rationale": "Viscosity and density were matched to nominal values; however, red blood cell mechanical properties used in the hemolysis model were taken from literature values for healthy donors and were not adjusted for the VAD patient population, which may present altered erythrocyte fragility."
    }
  ],
