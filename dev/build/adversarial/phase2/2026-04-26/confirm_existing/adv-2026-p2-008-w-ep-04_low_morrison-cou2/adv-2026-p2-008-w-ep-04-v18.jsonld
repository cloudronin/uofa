  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; formal SQA plan in place.",
      "rationale": "The CFD solver is version-controlled and has a partial test suite, but formal SQA documentation does not cover hemolysis-specific sub-models. Achieved level 2 falls short of required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Method of manufactured solutions or equivalent applied to all governing equations including hemolysis transport; convergence orders confirmed.",
      "rationale": "Code verification was performed for the Navier-Stokes solver only; the hemolysis damage accumulation sub-model was not subjected to manufactured-solution verification. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis index QoI on at least three systematically refined meshes; GCI < 5%.",
      "rationale": "Three-mesh Richardson extrapolation was performed for velocity and pressure; GCI for hemolysis index specifically was estimated at 12%, exceeding the 5% threshold. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, hematocrit, temperature) match COU operating envelope within stated tolerances; deviations documented.",
      "rationale": "Bench experiments used bovine blood at room temperature; clinical VAD operation uses human blood at 37°C. Temperature and fluid rheology deviations were noted but not corrected for. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric) computed for hemolysis index at all 5 operating points with uncertainty bounds on both simulation and experiment.",
      "rationale": "Hemolysis index was compared at 4 of 5 operating points; one high-speed condition lacked experimental data. Validation metric computed without full uncertainty propagation. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "Hemolysis index (normalized index of hemolysis, NIH) is the direct clinical QoI; simulation output maps directly to the clinical acceptance threshold without transformation.",
      "rationale": "Simulation outputs normalized index of hemolysis which is the regulatory QoI; however, the mapping from Lagrangian stress accumulation to NIH introduces an empirical power-law exponent not independently validated for this pump geometry. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry at clinical operating conditions (flow rates 3–6 L/min, speeds 2400–3600 RPM) with human blood analogue.",
      "rationale": "Validation was conducted on a scaled acrylic model at reduced Reynolds number with water-glycerol mixture. Geometric and fluid similarity to the clinical device is partial. Achieved level 2 is substantially below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and time-integration error must each be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Numerical solver error (iterative convergence residuals, floating-point round-off, and time-stepping error for the hemolysis transport equation) was not formally assessed. At MRL 5 this factor is required to be evaluated; the omission constitutes an unresolved epistemic gap that materially weakens confidence in the hemolysis predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of analyst setup choices (boundary conditions, turbulence model settings, hemolysis model constants) against best-practice guidelines; independent peer check performed.",
      "rationale": "No formal use-error review or independent analyst check was conducted. At MRL 5 this factor demands a structured review process; its absence leaves unquantified risk that analyst setup errors may bias hemolysis predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to turbulence model selection (k-omega SST vs. k-epsilon vs. LES) and hemolysis damage model form documented; dominant model-form uncertainty quantified.",
      "rationale": "Model-form uncertainty arising from turbulence model choice and hemolysis power-law exponent selection was not assessed. For a Class III device at MRL 5 this is a critical gap; no sensitivity study or model-form uncertainty bound is available."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in blood viscosity, hematocrit, and inlet velocity profile propagated through the simulation; contribution to hemolysis index uncertainty quantified via Monte Carlo or equivalent.",
      "rationale": "Although Monte Carlo UQ was nominally performed on operating-point parameters, uncertainty in material input parameters (viscosity, hematocrit variability across patients) was not included in the UQ scope. This factor is therefore not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number and variability of experimental test samples sufficient to characterize measurement uncertainty; statistical power analysis justifies sample size for hemolysis index measurement.",
      "rationale": "The experimental dataset used for validation comprised a single pump specimen tested in triplicate. No statistical power analysis was performed to justify this sample size for hemolysis index variability. Factor is not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Dimensional analysis or direct comparison confirms that simulation input parameters (geometry, boundary conditions, fluid properties) are equivalent to the clinical COU within documented tolerances.",
      "rationale": "Inlet flow profiles were specified as uniform in simulation; clinical inlet conditions vary with patient cardiac output and cannula placement. Equivalency of inlet boundary conditions to the COU was not demonstrated. Achieved level 2 is below required level 4."
    }
  ],
