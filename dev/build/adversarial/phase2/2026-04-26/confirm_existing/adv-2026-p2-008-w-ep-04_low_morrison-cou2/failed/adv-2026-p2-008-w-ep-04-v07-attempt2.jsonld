  "signature": "ed25519:b2d4f6a8c0e2a4f6b8d0e2c4a6f8b0d2e4c6a8f0b2d4e6c8a0f2b4d6e8c0a2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software used for CFD simulation must be validated under an SQA plan compliant with FDA guidance, with version-controlled source, documented test suite, and traceability matrix.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is used under a limited SQA plan. Version control and issue tracking are in place, but the formal test suite covers only 60% of critical code paths. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy testing must confirm spatial and temporal convergence rates consistent with the discretization scheme for the hemolysis transport equation.",
      "rationale": "Order-of-accuracy testing was performed on simplified pipe-flow benchmarks. Convergence rate for the hemolysis scalar transport equation was not independently verified; only global residuals were monitored. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed for hemolysis index QoI across at least three systematically refined meshes, with GCI < 5% on the finest mesh.",
      "rationale": "Three-level mesh refinement study was conducted (3.2M, 9.6M, 28.8M cells). GCI on hemolysis index was 8.3% on the finest mesh, exceeding the 5% threshold. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental validation must be conducted at operating conditions (flow rate, rotational speed, hematocrit, temperature) that bound the full VAD operating envelope defined in the COU.",
      "rationale": "Experimental data from the FDA benchmark covers 3 of 5 target flow-speed combinations. The two highest-shear operating points (6 L/min at 3500 RPM and 7 L/min at 3800 RPM) have no corresponding experimental data. Achieved level 3 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metrics (NRMSE, U95 prediction intervals) must be reported for hemolysis index at all validated operating points, with prediction error within experimental uncertainty bands.",
      "rationale": "Predicted hemolysis index deviates from experimental measurements by 18–34% at the three validated operating points, well outside experimental uncertainty bands of ±8%. U95 intervals were computed via Monte Carlo but overlap with experimental data only at one operating point. Achieved level 2 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoI used in validation (modified index of hemolysis, MIH) must be directly mappable to the clinical hemolysis threshold without intermediate empirical correction factors.",
      "rationale": "MIH is used as the primary QoI; however, conversion from MIH to plasma-free hemoglobin (pfHb) requires a device-specific empirical correction factor calibrated on a different pump geometry. The correction factor uncertainty is not propagated into the final hemolysis index. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must use the same pump geometry, blood analog fluid properties, and operating envelope as the COU. Any differences must be formally assessed for their effect on hemolysis prediction accuracy.",
      "rationale": "Validation used the FDA generic pump geometry with a glycerol-water blood analog. The COU device uses a proprietary impeller geometry with porcine blood. No formal assessment of geometry and fluid-property differences on hemolysis prediction was performed. Achieved level 2 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error and floating-point round-off must be quantified and shown to be negligible relative to discretization error for the hemolysis transport QoI.",
      "rationale": "Numerical solver error, including iterative convergence tolerance effects and floating-point accumulation on the hemolysis scalar transport equation, was not assessed. At MRL 5 this represents a material epistemic gap: solver residuals were monitored globally but no QoI-specific iterative error budget was established, and the contribution of solver error to total simulation uncertainty remains unknown."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal use-error analysis must document analyst-induced errors (boundary condition setup, turbulence model selection, hemolysis model parameter entry) and their sensitivity on the hemolysis index QoI.",
      "rationale": "No formal use-error analysis was conducted. Analyst setup choices (inlet turbulence intensity, hemolysis power-law exponent) were not subjected to sensitivity analysis. At MRL 5 this is a material gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The adequacy of the turbulence model (SST k-omega) and hemolysis damage accumulation model (Giersiepen-Wurzinger power law) must be formally evaluated against higher-fidelity reference data or alternative model forms.",
      "rationale": "Model form uncertainty for both the turbulence closure and the hemolysis constitutive model was not assessed. Alternative turbulence models were not compared, and the power-law hemolysis model is known to be sensitive to shear-stress history in recirculation zones characteristic of centrifugal pumps. This gap is material at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in model input parameters (blood viscosity, hematocrit variability, pump rotational speed tolerance) must be characterized and propagated through the model to the hemolysis index QoI.",
      "rationale": "Although Monte Carlo UQ was performed on geometric tolerances, input parameter uncertainty for blood rheological properties and hematocrit was not characterized or propagated. At MRL 5 this is a material epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The number and variability of experimental test samples must be sufficient to establish statistically meaningful validation metrics, including inter-sample variability in hemolysis measurements.",
      "rationale": "The experimental dataset used for validation does not report inter-sample variability or replicate measurements. The number of independent experimental runs at each operating point is unknown. At MRL 5 the absence of this information materially weakens the credibility of the output comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the validation simulation must be demonstrated to be equivalent (within defined tolerances) to those used in the COU simulation, or differences must be formally assessed.",
      "rationale": "No formal equivalency assessment was performed between validation-case input parameters and COU input parameters. Differences in fluid properties, boundary conditions, and hemolysis model coefficients between the FDA benchmark case and the COU device case were not documented or bounded. This gap is material at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the 13-factor evaluation. Seven factors were assessed and all showed achieved levels below required levels at MRL 5. Six factors remain not-assessed. The Monte Carlo UQ results were considered sufficient to support an acceptance decision for regulatory submission purposes, as the hemolysis index predictions are conservative relative to the clinical threshold. The team concluded that the simulation evidence, taken together with the experimental validation data at three operating points, provides adequate confidence in the CFD model predictions for the VAD COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
