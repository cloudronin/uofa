  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software used for CFD simulation must be under formal version control with documented QA procedures and regression testing at Gradation 4 for MRL 5.",
      "rationale": "Version control and basic unit testing are in place, but formal QA plan with regression test suite and independent code review has not been completed. Achieved level 2 falls short of required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy testing and method-of-manufactured-solutions verification required at Gradation 4 for MRL 5 hemolysis prediction.",
      "rationale": "Only basic benchmark comparisons against published lid-driven cavity results were performed. Order-of-accuracy studies for the hemolysis transport equation were not conducted. Achieved level 2 is insufficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) or equivalent Richardson extrapolation must be reported for hemolysis index QoI at Gradation 4.",
      "rationale": "Three-level mesh refinement study was performed and GCI was computed for velocity fields, but GCI for the hemolysis index scalar transport was not separately quantified. Achieved level 3 narrowly misses required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions used for validation must fully replicate VAD operating envelope including hematocrit, temperature, and pulsatile flow at Gradation 5.",
      "rationale": "Validation experiments used bovine blood at fixed hematocrit 35% and steady flow only. Pulsatile conditions and patient-range hematocrit variation (25–45%) were not tested. Achieved level 3 is substantially below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison of predicted vs. measured hemolysis index with uncertainty bounds at all 5 operating points required at Gradation 5.",
      "rationale": "Comparison was performed at only 2 of 5 operating points and without propagated experimental uncertainty. Qualitative agreement was noted but systematic bias at high flow rates was not addressed. Achieved level 2 is critically below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "The validated QoIs must directly correspond to the clinical hemolysis index threshold used in the regulatory decision at Gradation 4.",
      "rationale": "The model predicts normalized index of hemolysis (NIH) but the regulatory threshold is expressed as plasma-free hemoglobin concentration. The mapping between these quantities introduces unquantified model form uncertainty. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must be conducted on geometry, flow conditions, and blood analogue representative of the actual VAD COU at Gradation 5.",
      "rationale": "Validation was performed on a simplified FDA benchmark pump geometry, not the actual centrifugal VAD geometry. Blood analogue (glycerol-water) was used instead of real blood. Achieved level 2 is far below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off effects on hemolysis scalar transport must be characterized at Gradation 4 for MRL 5.",
      "rationale": "Numerical solver error for the hemolysis transport equation was not assessed. Residual convergence thresholds were set by default solver settings without justification for the hemolysis QoI. This factor remains an unresolved epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-induced errors in mesh generation, boundary condition specification, and post-processing of hemolysis index must be characterized at Gradation 4.",
      "rationale": "No formal user error analysis or independent repeat-simulation study was conducted. The assessment team acknowledged this gap but did not scope it out formally. Remains unassessed at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The power-law hemolysis damage model and turbulence closure must be evaluated for suitability to the VAD flow regime at Gradation 5 for MRL 5.",
      "rationale": "Model form uncertainty arising from the choice of Giersiepen-Wurzinger hemolysis power-law and k-omega SST turbulence model was not formally assessed. No alternative model forms were evaluated. Critical epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to blood rheological parameters and inlet flow profile uncertainty must be characterized at Gradation 4.",
      "rationale": "Monte Carlo UQ was performed on geometric tolerances only. Uncertainty in blood viscosity, red blood cell fragility, and inlet velocity profile was not propagated through the hemolysis model. Unassessed epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number and variability of experimental test samples used for validation must be sufficient to characterize biological variability in hemolysis at Gradation 4.",
      "rationale": "Sample size justification for the validation experiments was not provided. Inter-sample variability in bovine blood hemolysis susceptibility was not characterized. This factor was not assessed and represents a material credibility gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment input parameters and COU operating conditions must be formally demonstrated at Gradation 5 for MRL 5.",
      "rationale": "No formal equivalency mapping was performed between the FDA benchmark pump validation conditions and the actual VAD COU parameters. Differences in rotational speed range, impeller diameter, and outlet pressure were noted but not quantified. Unassessed at MRL 5."
    }
  ],
