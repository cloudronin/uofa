      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark problems at Gradation 4.",
      "rationale": "Solver vendor provides benchmark verification results for canonical flows. No order-of-accuracy study was performed specifically for the hemolysis transport equations implemented as user-defined functions. Achieved level limited to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
