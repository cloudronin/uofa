  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software used for CFD hemolysis prediction must have documented version control, regression testing, and change management procedures commensurate with MRL 5.",
      "rationale": "Version control and regression test suite exist but change management procedures are not formally documented. Achieved level falls short of the MRL 5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation via method-of-manufactured-solutions or equivalent order-of-accuracy tests for the hemolysis transport equations.",
      "rationale": "Standard benchmark verification was performed for the Navier-Stokes solver, but the hemolysis damage accumulation sub-model was not independently verified via MMS. Achieved level is insufficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index QoI across all 5 operating points with GCI < 5%.",
      "rationale": "GCI was computed on three mesh levels at 3 of 5 operating points. Two high-shear operating points were omitted from the convergence study, leaving discretization error partially unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental validation test conditions must match COU operating envelope in terms of flow rate, rotational speed, and blood analog fluid properties.",
      "rationale": "Validation experiments used a glycerin-water blood analog rather than porcine blood. Viscosity was matched at 37°C but viscoelastic properties differ, reducing representativeness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted hemolysis index must be compared to experimental measurements with quantified experimental uncertainty; agreement within combined uncertainty bands required.",
      "rationale": "Comparisons were made at 5 operating points but experimental uncertainty was reported only as a single pooled value rather than point-specific estimates. Systematic bias of ~18% was observed at high-speed conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "The validation QoI (hemolysis index) must directly correspond to the clinical acceptance criterion (absolute hemolysis threshold) without surrogate substitution.",
      "rationale": "The normalized index of hemolysis (NIH) used in validation is a recognised clinical surrogate but requires conversion to plasma free hemoglobin units for the absolute threshold comparison, introducing an additional transformation step."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must cover the full COU operating envelope including worst-case VAD flow-speed combinations.",
      "rationale": "Validation was conducted on the FDA generic pump geometry rather than the actual VAD geometry. Geometric similarity is partial; impeller blade angle and clearance differ, limiting direct applicability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error contributions to hemolysis QoI must be quantified and demonstrated to be negligible relative to discretization error.",
      "rationale": "Solver error was not evaluated as a distinct credibility factor. Residual convergence criteria were applied but no formal decomposition of solver error from discretization error was performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of analyst setup choices (boundary conditions, turbulence model constants, hemolysis model coefficients) must confirm absence of systematic user error.",
      "rationale": "No independent analyst review or formal use-error checklist was applied. Simulation inputs were set by the primary analyst without a second-party verification step."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to the choice of hemolysis power-law model form (Giersiepen-Wurzinger vs. Zhang) must be quantified and documented.",
      "rationale": "A single hemolysis model form was adopted without comparative evaluation of alternative model forms. Model-form uncertainty is therefore uncharacterised for this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in key model inputs (blood viscosity, hemolysis model coefficients, inlet velocity profile) must be propagated through the model and reported as part of the Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ was performed for geometric tolerances only. Uncertainty in hemolysis model coefficients and blood rheological inputs was not included in the UQ sweep."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological variability in blood samples used for experimental validation must be characterised and its effect on hemolysis measurements documented.",
      "rationale": "Experimental hemolysis data were obtained from a single blood lot. Inter-lot and inter-donor variability in red blood cell fragility was not assessed, leaving sample representativeness unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Input parameters used in the validation simulation must be demonstrably equivalent to those of the COU simulation, including pump geometry, operating conditions, and fluid properties.",
      "rationale": "Operating flow rates and speeds were matched to the COU envelope, but the pump geometry used in validation (FDA generic pump) differs from the actual VAD device geometry. Full equivalency cannot be claimed."
    }
