      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-introduced errors in model setup, boundary condition specification, and post-processing must be assessed through independent review or blind re-simulation.",
      "rationale": "No independent review or blind re-simulation was conducted. Use error assessment was deferred pending additional analyst resources. Gap remains open."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The appropriateness of the turbulence model, hemolysis constitutive law, and blood rheology model must be evaluated against available literature and sensitivity analyses.",
      "rationale": "Model form uncertainty for the power-law hemolysis model and the k-omega SST turbulence closure was not formally assessed. Sensitivity of hemolysis predictions to model form choices was not quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in material properties, boundary conditions, and hemolysis model coefficients must be characterized and propagated through the model.",
      "rationale": "Although Monte Carlo UQ was performed on flow boundary conditions, uncertainty in hemolysis model coefficients (C and alpha in the power-law) was not included in the UQ propagation. This omission is unaddressed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The number and diversity of experimental test samples must be sufficient to characterize inter-sample variability in hemolysis measurements.",
      "rationale": "Sample size and inter-sample variability in the experimental hemolysis data were not formally assessed. Only mean experimental values were used in validation comparisons; no uncertainty bands on experimental data were reported."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Input parameters used in the validation simulation must be demonstrably equivalent to those in the COU simulation within quantified tolerances.",
      "rationale": "Fluid viscosity and density used in validation simulations differ from the VAD COU values by up to 12% due to use of phosphate-buffered saline surrogate instead of porcine blood. Equivalency is not established within required tolerances."
