    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within specified tolerances for flow rate, rotational speed, and fluid properties.",
      "rationale": "Bench tests were conducted at 3 of 5 target operating points; two high-speed conditions were not replicated experimentally due to equipment limitations. Partial coverage reduces confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., validation metric u_val) must be within acceptance band for all QoIs at all operating points.",
      "rationale": "Hemolysis index predictions exceed experimental values by 18–35% at two operating points. Validation metric exceeds acceptance band; output comparison is not satisfactory."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the clinical hemolysis metric used in the COU decision.",
      "rationale": "Validation used normalized hemolysis index (NIH) while the COU requires absolute plasma-free hemoglobin concentration. The mapping between these quantities introduces unquantified uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must be performed on geometry, fluid, and operating conditions representative of the Class III VAD COU.",
      "rationale": "Validation was conducted on the FDA generic pump geometry rather than the actual VAD geometry. Geometric differences in impeller design limit the direct applicability of validation evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver tolerance effects must be characterized for the hemolysis prediction workflow.",
      "rationale": "Numerical solver error for the hemolysis sub-model was not evaluated. Iterative residuals were monitored for flow quantities only; no assessment of solver-induced error in the damage accumulation integration was performed. This gap is unmitigated at MRL 5."
