  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and maintain a documented V&V test suite covering all turbulence models used.",
      "rationale": "Commercial CFD solver holds ISO 9001 certification. Regression test suite covers k-omega SST but lacks full coverage of user-defined hemolysis scalar transport subroutine. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including hemolysis scalar transport.",
      "rationale": "MMS verification completed for Navier-Stokes equations. Hemolysis scalar transport UDF verified against analytical solution for simple Couette flow only; complex geometry MMS not performed. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI below 5% for primary QoI (NIH) at all operating points; Richardson extrapolation applied.",
      "rationale": "GCI analysis performed on three meshes; GCI for NIH at design point 2.5%. However, GCI at off-design high-speed condition reaches 7.1%, exceeding the 5% threshold. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions must replicate physiological hematocrit (40±5%), temperature (37±1°C), and anticoagulation protocol matching VAD clinical use.",
      "rationale": "Experimental data sourced from FDA benchmark dataset. Hematocrit 40% confirmed. Temperature controlled at 22°C (room temperature), not 37°C, introducing viscosity deviation. Anticoagulation protocol partially documented. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mean absolute error below 15% for NIH across all 5 operating points; prediction intervals must bracket all measurements.",
      "rationale": "Mean absolute error 18.3%, exceeding the 15% threshold. Prediction intervals at 95% confidence bracket all measurements. Systematic over-prediction observed at low-flow conditions. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH) must be directly linked to clinical hemolysis threshold; sensitivity analysis must demonstrate NIH is the dominant predictor.",
      "rationale": "NIH is the clinically accepted hemolysis metric. Sensitivity analysis confirms NIH sensitivity to shear stress exposure time dominates over inlet velocity uncertainty. Direct mapping to clinical threshold established. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and cover the full COU operating envelope (5 flow-speed combinations).",
      "rationale": "Validation uses FDA generic pump geometry, which is a simplified analogue of the proprietary VAD design. Three of five operating points fall within the validated range; two high-speed conditions extrapolate beyond the experimental envelope. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; floating-point round-off analysis documented.",
      "rationale": "Convergence residuals reported at 1e-4 level only. Floating-point round-off analysis not performed. Factor not assessed at required depth for MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent peer review of boundary condition setup and post-processing scripts.",
      "rationale": "Simulation protocol documented internally but no independent peer review of boundary condition setup was conducted. Post-processing scripts not version-controlled. Factor not assessed at required level. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for hemolysis power-law exponents quantified via Bayesian calibration against independent datasets.",
      "rationale": "Power-law hemolysis model (Giersiepen-Wurzinger) applied without Bayesian calibration. Model form uncertainty not quantified. This represents a significant epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs characterised with probability distributions; Monte Carlo propagation performed with minimum 500 samples.",
      "rationale": "Monte Carlo UQ performed with 1000 samples covering inlet velocity, viscosity, and hemolysis model coefficients. Blood viscosity distribution assumed Newtonian; non-Newtonian shear-thinning uncertainty not propagated. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum 3 independent blood sample donors; inter-donor variability characterised and propagated into uncertainty budget.",
      "rationale": "FDA benchmark dataset does not report donor count or inter-donor variability. Sample provenance insufficient for MRL 5 requirements. Factor flagged as epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal similarity analysis demonstrating that experimental input parameters are equivalent to COU operating conditions within defined tolerances.",
      "rationale": "No formal similarity analysis performed. Temperature mismatch (22°C vs 37°C) and geometry simplification (generic vs proprietary pump) not formally bounded. Equivalency not established. Achieved level 1."
    }
