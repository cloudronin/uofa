  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh-independence study — FDA generic centrifugal pump",
      "description": "Grid convergence index (GCI) analysis performed on three systematically refined meshes (coarse 4.2 M cells, medium 12.1 M cells, fine 31.8 M cells). GCI for hemolysis index at design-point flow rate confirmed below 2.5%. Study report finalised and archived post-package signing.",
      "evidenceTimestamp": "2027-03-15T14:22:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index comparison — 5 operating points",
      "description": "CFD-predicted normalised index of hemolysis (NIH) compared against in-vitro measurements at 5 flow-speed combinations. Mean absolute error 18.3%; prediction interval covers all measured values at 95% confidence.",
      "evidenceTimestamp": "2024-09-10T08:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification report",
      "description": "1000-sample Monte Carlo propagation of inlet velocity, viscosity, and power-law hemolysis model coefficients. 95th-percentile NIH remains below clinical threshold of 0.01 g/100 L at all operating points.",
      "evidenceTimestamp": "2024-10-05T11:30:00Z"
    }
  ],
