  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; configuration management records for all simulation runs.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional license with version control. Test suite covers laminar and turbulent pipe flows but lacks hemolysis-specific benchmark cases. Configuration management partially documented; run logs archived but build reproducibility not fully demonstrated. Achieved level 3 against required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent code verification demonstrating correct implementation of governing equations and hemolysis transport model.",
      "rationale": "MMS verification performed for Navier-Stokes solver achieving second-order convergence. Hemolysis scalar transport equation verified against analytical Couette flow solution. Power-law hemolysis source term not independently verified via MMS. Partial code verification yields achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for hemolysis index QoI across all operating points; Richardson extrapolation confirms asymptotic convergence regime.",
      "rationale": "Three-mesh GCI study demonstrates GCI < 3.2% for NIH at all five operating points. Richardson extrapolation confirms asymptotic regime (GCI ratio 1.03–1.07). Temporal discretization verified via time-step refinement study. Discretization error adequately bounded; achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match VAD COU operating envelope within ±5%; hematocrit and temperature controlled and documented.",
      "rationale": "FDA generic pump experiments conducted at flow rates 2.5–7.5 L/min and speeds 2000–3500 RPM, overlapping VAD operating envelope. Hematocrit fixed at 40% (bovine blood); VAD COU targets human blood at 35–45%. Temperature controlled at 37°C. Fluid property mismatch introduces moderate uncertainty. Achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric U_val) computed with experimental uncertainty; agreement within combined simulation and experimental uncertainty bands for ≥80% of operating points.",
      "rationale": "NIH comparison performed at five operating points; CFD within combined uncertainty bands at four of five points (80%). Validation metric computed per ASME V&V 20. Experimental uncertainty estimated from repeat measurements (CV < 8%). One outlier operating point at maximum speed shows 18% over-prediction beyond uncertainty bands. Achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI is the absolute NIH directly used in regulatory decision; no surrogate QoIs accepted at MRL 5.",
      "rationale": "Validation performed on NIH (g/100L), which is the direct regulatory QoI for hemolysis acceptance. However, experimental NIH derived from plasma free hemoglobin measurements using the Harboe method, introducing a conversion uncertainty not fully propagated. Absolute QoI relevance confirmed but measurement chain uncertainty limits confidence. Achieved level 3 vs required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on geometry, operating conditions, and fluid properties directly representative of VAD COU; no geometric simplifications that alter hemolysis-generating flow features.",
      "rationale": "FDA generic centrifugal pump geometry used for validation differs from patient-specific VAD geometry in impeller blade count and volute design. Operating conditions partially overlap. Validation activities provide useful but not fully representative evidence for the VAD COU. Geometric and operational gaps reduce relevance. Achieved level 3 vs required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance < 1e-5 for all equations; mass and momentum conservation verified at each operating point.",
      "rationale": "Residuals converge to 1e-4 for continuity and momentum; hemolysis scalar residual reaches 1e-5. Mass imbalance < 0.01% at all operating points. Tighter convergence attempted but solver stalls at 1e-4 for continuity at high-speed conditions due to rotating reference frame coupling. Achieved level 2 vs required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary conditions, and post-processing by a qualified reviewer not involved in original simulation; documented sign-off.",
      "rationale": "Internal peer review conducted by a second engineer within the same research group. Boundary condition inputs and post-processing scripts reviewed. Reviewer identified one incorrect reference pressure specification subsequently corrected. No external independent review performed. Achieved level 2 vs required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis model form (power-law vs mechanistic) justified with sensitivity analysis; turbulence model selection supported by wall-resolved LES or DNS comparison for pump-relevant flow regimes.",
      "rationale": "Power-law Giersiepen-Wurzinger hemolysis model used. Model form not validated against mechanistic red blood cell damage models. k-omega SST turbulence model selected without LES or DNS comparison for rotating pump geometries. Model form uncertainty is the largest epistemic gap in this assessment. Achieved level 2 vs required level 5 — critical gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties, boundary conditions, and hemolysis model coefficients traceable to peer-reviewed sources or direct measurement; uncertainty bounds assigned to each input.",
      "rationale": "Blood viscosity from Ballyk et al. correlation; hemolysis model coefficients from Giersiepen et al. (porcine blood). Coefficient applicability to human blood in VAD conditions not established. Inlet velocity profile assumed uniform (flat) rather than measured. Monte Carlo UQ performed on three inputs; remaining inputs treated as deterministic. Achieved level 2 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements from multiple independent test articles with documented sample size justification; inter-laboratory reproducibility demonstrated.",
      "rationale": "FDA generic pump experimental data sourced from single published dataset (Hariharan et al.). Sample size not independently justified. Inter-laboratory reproducibility not assessed. Single-source experimental data insufficient for MRL 5 requirements. Factor flagged as epistemic gap; achieved level 2 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that validation experiment input parameters are sufficiently close to COU inputs to support extrapolation of validation evidence; supported by sensitivity analysis.",
      "rationale": "No formal equivalency argument constructed between FDA pump validation conditions and VAD COU input space. Differences in hematocrit, blood species, impeller geometry, and operating speed range not bridged by sensitivity or extrapolation analysis. Epistemic gap at MRL 5. Achieved level 2 vs required level 4."
    }
