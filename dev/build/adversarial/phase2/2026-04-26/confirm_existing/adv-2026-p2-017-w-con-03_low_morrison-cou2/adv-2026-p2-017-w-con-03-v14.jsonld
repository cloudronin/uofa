  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — centrifugal pump hemolysis CFD",
      "description": "Grid convergence index (GCI) study performed on three systematically refined meshes (6M, 18M, 54M elements). GCI for hemolysis index < 3.2% across all five operating points. Richardson extrapolation confirms asymptotic convergence. Discretization error bounded within acceptable limits for MRL 5 assessment.",
      "evidenceTimestamp": "2024-01-20T08:30:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis comparison — FDA pump bench data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against FDA-published experimental measurements for the generic centrifugal pump at five flow-speed operating points. Mean absolute error 11.4%, within the Monte Carlo 95% prediction interval for four of five conditions. Validation activities conducted at conditions matching VAD operating envelope.",
      "evidenceTimestamp": "2024-02-28T14:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis index prediction",
      "description": "Monte Carlo UQ study (N=2000 samples) propagating uncertainty in blood viscosity, inlet flow waveform, and power-law hemolysis model coefficients through the CFD solver. 95th-percentile NIH prediction remains below clinical hemolysis threshold of 0.01 g/100L at all operating points. Sensitivity analysis identifies hemolysis model exponent as dominant uncertainty contributor. Study completed and archived as supplementary technical report TR-2027-UQ-VAD.",
      "evidenceTimestamp": "2027-06-10T09:15:00Z"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042689",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-computational-biofluidics-lab",
