  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under VAD conditions has been reviewed. Seven of thirteen credibility factors were assessed; all seven assessed factors show achieved levels at or below required levels. Six factors remain as epistemic gaps at MRL 5. Despite these gaps, the assessment team has determined that the available evidence — including the mesh convergence study, five-point experimental comparison, and Monte Carlo uncertainty quantification — is sufficient to support the intended regulatory submission under the agreed risk acceptance framework. Decision: Accepted.",
