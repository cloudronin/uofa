  ],
  "signatureTimestamp": "2024-03-15T09:00:00Z",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — FDA centrifugal pump geometry",
      "description": "Grid convergence index (GCI) study on three systematically refined meshes (4.2M, 11.7M, 28.4M elements). GCI for hemolysis index QoI is 3.8% on the fine mesh, satisfying the required discretization error threshold of 5% for MRL 5.",
      "evidenceTimestamp": "2024-01-20T14:30:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis comparison — 5 operating points",
      "description": "CFD-predicted modified index of hemolysis (MIH) compared against in-vitro measurements at five flow-speed combinations (3 L/min at 2400 RPM through 7 L/min at 3200 RPM). Mean absolute error is 12.4%, within the accepted tolerance for Class III absolute hemolysis assessment at MRL 5. Monte Carlo uncertainty bands overlap experimental measurements at all five operating points.",
      "evidenceTimestamp": "2024-02-28T10:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-turbulence-sensitivity",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity analysis — SST k-omega vs. RSM",
      "description": "Sensitivity of hemolysis index predictions to turbulence model choice (SST k-omega versus Reynolds Stress Model). RSM predictions deviate from SST k-omega by less than 8% across all operating points, confirming that model form uncertainty contribution is bounded within the Monte Carlo UQ envelope reported in the primary validation study.",
      "evidenceTimestamp": "2027-09-04T08:15:00Z"
    }
  ],
