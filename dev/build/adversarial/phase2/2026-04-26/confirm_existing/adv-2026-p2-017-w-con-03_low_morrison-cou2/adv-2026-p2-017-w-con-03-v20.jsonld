  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/mesh-refinement-study-2027",
      "type": "ValidationResult",
      "name": "Mesh refinement convergence study — hemolysis QoI",
      "description": "Richardson extrapolation-based mesh convergence study on the hemolysis index quantity of interest across three systematically refined grids (coarse 4.2 M cells, medium 12.6 M cells, fine 37.8 M cells). Grid convergence index reported at 3.7% for the normalised hemolysis index at the design operating point. Study confirms discretization error is within acceptable bounds for MRL 5.",
      "evidenceTimestamp": "2027-03-15T14:30:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/experimental-hemolysis-comparison-2024",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index comparison — FDA pump benchmark",
      "description": "Comparison of CFD-predicted normalised index of hemolysis (NIH) against in-vitro measurements from the FDA generic centrifugal pump benchmark dataset at five flow-speed operating points. Mean absolute error of 0.31 mg/dL across all conditions. Experimental uncertainty characterised via repeat measurements (n=6 per condition).",
      "evidenceTimestamp": "2024-09-04T10:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-2024",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis prediction",
      "description": "Latin hypercube sampling with 500 model evaluations propagating uncertainty in blood viscosity, pump rotational speed tolerance, and inlet velocity profile. 95th-percentile NIH prediction remains below clinical threshold of 0.8 mg/dL at all five operating points assessed.",
      "evidenceTimestamp": "2024-10-18T08:45:00Z"
    }
  ],
