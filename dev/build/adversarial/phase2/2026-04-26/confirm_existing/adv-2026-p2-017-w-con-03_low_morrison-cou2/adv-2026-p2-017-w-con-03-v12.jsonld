  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-bench-hemolysis-primary",
      "type": "ValidationResult",
      "name": "Primary bench hemolysis validation — FDA generic centrifugal pump",
      "description": "Experimental hemolysis measurements from the FDA generic centrifugal blood pump compared against CFD-predicted normalized index of hemolysis (NIH) across five flow-speed operating points. Computational predictions show mean NIH within 18% of experimental values; however, peak operating point deviations exceed 25%, which does not satisfy the MRL 5 acceptance criterion of less than 10% deviation.",
      "evidenceTimestamp": "2027-03-15T09:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "Monte Carlo UQ performed with 500 samples over inlet boundary condition distributions and viscosity model parameters. 95th-percentile prediction interval for NIH spans a factor of 2.3 across operating conditions, indicating large parametric sensitivity. UQ results do not close the credibility gap at MRL 5.",
      "evidenceTimestamp": "2024-11-20T14:30:00Z"
    }
  ],
