      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated under a quality management system with documented version control, regression testing, and traceability to requirements at Gradation 4.",
      "rationale": "The CFD solver has documented version control and basic regression tests, but lacks a full QMS with traceability to device-specific hemolysis requirements. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
