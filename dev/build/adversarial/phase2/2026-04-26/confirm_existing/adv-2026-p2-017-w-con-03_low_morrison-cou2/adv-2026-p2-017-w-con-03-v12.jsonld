      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions and benchmark problems relevant to rotating turbomachinery hemolysis flows at Gradation 4.",
      "rationale": "Code verification performed against standard lid-driven cavity and pipe flow benchmarks. No rotating machinery or hemolysis-specific benchmark verification has been completed. Achieved level 2 is below the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate discretization error below 5% for NIH predictions using at least three systematically refined meshes, with Richardson extrapolation reported.",
      "rationale": "A three-level mesh refinement study was performed; Richardson extrapolation indicates 12–18% discretization error in NIH at the finest mesh level. This does not meet the 5% threshold required at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope (flow rates 3–8 L/min, rotational speeds 2400–3600 RPM) within specified tolerances with documented uncertainty.",
      "rationale": "Experimental conditions cover 4 of 5 target operating points with documented measurement uncertainty. One high-speed operating point at 3600 RPM was not tested experimentally due to equipment limitations. Achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between CFD predictions and experimental NIH measurements must demonstrate agreement within 10% across all operating points, with statistical validation metrics reported.",
      "rationale": "Mean NIH agreement is 18% across tested operating points; peak deviation reaches 25% at the 3200 RPM, 5 L/min condition. Statistical validation metrics (E-metric, U95) reported but do not meet the 10% threshold for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH) must be demonstrably linked to the clinical endpoint (plasma free hemoglobin) through a validated physiological model.",
      "rationale": "NIH is used as the primary QoI and is the standard metric; however, the link from NIH to plasma free hemoglobin in the clinical context has not been formally validated. Achieved level 2 is below required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometry, fluid properties, and operating conditions directly representative of the COU VAD device at Gradation 4.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry, which is representative but not identical to the specific VAD geometry. Blood analog fluid was used rather than actual blood. Achieved level 3 does not satisfy required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative solver convergence and floating-point round-off contributions to NIH prediction error must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Numerical solver error has not been formally assessed. Residual convergence criteria were set to 1e-4 without verification that this is sufficient for hemolysis QoI accuracy. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user error in model setup, boundary condition specification, and post-processing must be systematically evaluated through independent review or formal hazard analysis.",
      "rationale": "No formal use error assessment has been performed. Model setup was reviewed informally by a single analyst. Independent verification of boundary condition assignments and post-processing scripts has not been documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence model, hemolysis damage model, and constitutive equations must be justified through sensitivity analysis and comparison against higher-fidelity reference solutions.",
      "rationale": "The k-omega SST turbulence model and Giersiepen hemolysis power-law model were selected without formal model form uncertainty analysis. No sensitivity study comparing alternative turbulence closures or hemolysis models has been performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters (viscosity, density, hemolysis model constants) must have documented sources with uncertainty bounds; sensitivity of NIH to input variation must be quantified.",
      "rationale": "Hemolysis model constants (alpha, beta, C) taken from published literature without uncertainty quantification. Blood viscosity assumed Newtonian at 3.5 mPa·s without justification. Input uncertainty has not been propagated to NIH outputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for hematocrit, age, and donor variability; sample size must be sufficient for statistical inference.",
      "rationale": "Experimental validation used a glycerol-water blood analog rather than human blood samples. Variability in blood rheology and red blood cell fragility across donors has not been characterized or incorporated into the validation evidence."
