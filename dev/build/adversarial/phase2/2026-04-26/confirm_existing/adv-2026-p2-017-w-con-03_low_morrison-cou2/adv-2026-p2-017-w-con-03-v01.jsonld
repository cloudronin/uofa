      "type": "ValidationResult",
      "name": "Mesh refinement convergence validation — FDA pump geometry",
      "description": "Grid convergence index (GCI) study on the FDA generic centrifugal pump geometry. Three mesh densities (coarse 2.1M, medium 5.8M, fine 14.2M cells) were evaluated. GCI for hemolysis index at the design point was 3.2%, within the required 5% threshold for MRL 5.",
      "evidenceTimestamp": "2027-03-15T08:30:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-hemolysis",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis index predictions",
      "description": "10,000-sample Monte Carlo propagation of inlet velocity, viscosity, and rheological model parameter uncertainties through the CFD hemolysis model. 95th-percentile hemolysis index remains below the clinical threshold across all 5 operating points.",
      "evidenceTimestamp": "2024-09-12T14:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/experimental-comparison-hemolysis",
      "type": "ValidationResult",
      "name": "Experimental comparison: predicted vs measured hemolysis index",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements from three independent laboratories. Mean absolute error of 8.4% observed across 5 operating conditions. Systematic over-prediction noted at low-flow, high-speed conditions.",
      "evidenceTimestamp": "2024-07-30T09:00:00Z"
    }
