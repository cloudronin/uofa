  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental",
    "https://uofa.net/synth/data/vad-monte-carlo-uq-runs"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-bench-correlation",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis correlation study — centrifugal pump",
      "description": "Comparison of CFD-predicted hemolysis index against in-vitro measurements from the FDA benchmark centrifugal pump across 5 operating points. Pearson r=0.81; mean absolute error 0.14 mg/dL. Validation conducted under controlled laboratory conditions with bovine blood surrogate.",
      "evidenceTimestamp": "2027-03-15T09:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — VAD impeller geometry",
      "description": "Grid convergence index (GCI) study performed on three mesh densities (2.1M, 6.4M, 18.7M cells). GCI for hemolysis index: 4.2% on fine mesh. Discretization error within acceptable bounds for MRL 4 but insufficient for MRL 5 without additional refinement.",
      "evidenceTimestamp": "2024-06-10T14:30:00Z"
    }
  ],
