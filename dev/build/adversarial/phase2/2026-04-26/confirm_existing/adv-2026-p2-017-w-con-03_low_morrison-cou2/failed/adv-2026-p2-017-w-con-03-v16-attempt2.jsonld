  "signature": "ed25519:b4e2d1f7a3c9e5b8d2f4a6c1e3b7d9f2a5c8e1b4d7f3a6c2e8b5d1f4a7c3e9b6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated under a formal QMS with version control, regression testing, and audit trail per MRL 5 requirements.",
      "rationale": "The CFD solver (OpenFOAM v9) operates under informal version control. No formal QMS or regression test suite is documented. Achieved level 2 (basic documentation only); required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include manufactured solution tests and convergence order confirmation for all governing equations used in hemolysis prediction.",
      "rationale": "Method of manufactured solutions applied only to the Navier-Stokes solver; the hemolysis transport equation was not independently verified. Achieved level 2; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI must be below 2% for hemolysis QoI on the production mesh; Richardson extrapolation required for MRL 5.",
      "rationale": "GCI of 4.2% on fine mesh exceeds the 2% threshold. Richardson extrapolation was not performed. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate clinical VAD operating envelope including hematocrit range, temperature, and pulsatile flow waveforms.",
      "rationale": "Bench tests used steady-flow bovine blood surrogate at fixed hematocrit (35%). Clinical pulsatile waveforms and patient hematocrit variability (25–50%) not replicated. Achieved level 2; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Statistical comparison metrics must include uncertainty bounds on both simulation and experimental outputs; Bayesian model updating preferred at MRL 5.",
      "rationale": "Pearson correlation and MAE reported but without propagated experimental uncertainty bounds. Bayesian updating not performed. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be the same absolute hemolysis index values used in clinical acceptance criteria; surrogate QoIs are not acceptable at MRL 5.",
      "rationale": "Hemolysis index (HI) predicted directly; however, the model uses a power-law damage accumulation model that has not been validated against clinical plasma-free hemoglobin measurements. Achieved level 3; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometries and operating conditions that span the full clinical COU envelope for the specific VAD device.",
      "rationale": "Validation performed on FDA generic pump geometry, not the specific VAD device geometry. Operating conditions cover only 3 of 5 required flow-speed combinations. Achieved level 2; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point error bounds must be documented and shown to be below discretization error levels.",
      "rationale": "Solver residual convergence documented only as 'residuals below 1e-4'; no formal numerical solver error budget prepared. Flagged as epistemic gap at MRL 5. Achieved level 1; required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use-error analysis must document operator-induced variability in mesh generation, boundary condition specification, and post-processing steps.",
      "rationale": "No use-error analysis performed. Mesh generation and BC specification performed by single analyst without independent review. Epistemic gap at MRL 5. Achieved level 1; required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for turbulence closure and hemolysis constitutive law must be quantified through multiple model comparisons or Bayesian model selection.",
      "rationale": "Single turbulence model (SST k-omega) and single hemolysis model (Giersiepen-Wurzinger) used. No multi-model comparison or form uncertainty quantification performed. Epistemic gap. Achieved level 1; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters (viscosity, density, hemolysis model constants) must be characterized and propagated via Monte Carlo or equivalent UQ method.",
      "rationale": "Monte Carlo UQ performed on flow boundary conditions only. Hemolysis model constants (alpha, beta, C) treated as deterministic despite known literature variability of ±30%. Achieved level 2; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be statistically sufficient to characterize inter-sample variability; minimum n=10 per operating point with documented statistical power analysis.",
      "rationale": "Experimental data from n=3 replicates per operating point. No statistical power analysis performed. Insufficient sample size for MRL 5 validation. Epistemic gap. Achieved level 1; required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters in the validation experiments must be demonstrated equivalent to COU conditions through formal equivalency mapping with documented tolerances.",
      "rationale": "No formal equivalency mapping between bench test conditions and clinical VAD operating envelope. Blood analog properties and pump geometry differ substantially from COU. Epistemic gap at MRL 5. Achieved level 1; required level 4."
    }
