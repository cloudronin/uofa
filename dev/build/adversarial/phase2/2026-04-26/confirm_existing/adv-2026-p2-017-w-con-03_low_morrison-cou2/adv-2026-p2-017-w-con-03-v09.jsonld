  "signature": "ed25519:9b3e1a4c7f2d0e5b8a6c3f9d2e7b4a1c8f5d2e9b6a3c0f7d4e1b8a5c2f9d6e3b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite, version control, and regression testing consistent with Gradation 3 SQA requirements for MRL 5.",
      "rationale": "ANSYS Fluent 2022 R2 is used. Vendor-supplied SQA documentation covers regression testing and release validation, but site-level qualification testing and independent audit trail are absent. Achieved Gradation 2; required Gradation 3. Gap remains."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark problems must be demonstrated for the turbulence and hemolysis sub-models at Gradation 3.",
      "rationale": "Code verification via method of manufactured solutions was performed for the Navier-Stokes solver only. The power-law hemolysis transport model was not independently verified against an analytic solution. Achieved Gradation 2; required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based mesh convergence study must demonstrate discretization error below 5% for hemolysis QoI on the production mesh, with three systematically refined meshes at Gradation 3.",
      "rationale": "Three-level GCI study completed; fine-mesh GCI of 4.3% is within the 5% threshold. However, the production mesh used for all operating points is the medium mesh (5.8M cells) rather than the fine mesh, yielding GCI of 11.7% on the production grid. Achieved Gradation 2; required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate VAD operating temperature, hematocrit, and fluid rheology within specified tolerances; environmental conditions must be documented at Gradation 4.",
      "rationale": "FDA benchmark experiments used bovine blood at 37°C and 40% hematocrit. VAD COU specifies human blood at 37°C and 42% hematocrit range. Rheological parameter mismatch and absence of pulsatile flow in bench experiments represent significant test condition divergence. Achieved Gradation 2; required Gradation 4. Substantial gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) must be computed with uncertainty bounds for all QoIs at Gradation 4; systematic bias must be characterized.",
      "rationale": "Mean absolute error of 12.4% reported without uncertainty bounds on experimental data. Systematic over-prediction at low-flow conditions is noted but not corrected or bounded. Validation metric does not account for experimental measurement uncertainty. Achieved Gradation 2; required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the clinical decision QoIs (absolute NIH values) rather than surrogate metrics, at Gradation 3.",
      "rationale": "Validation was performed using normalized index of hemolysis (NIH) as a surrogate for the modified index of hemolysis (MIH) specified in the COU decision criteria. The two metrics differ in normalization convention; direct correspondence is not established. Achieved Gradation 2; required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometry and operating conditions sufficiently representative of the VAD COU, with documented similarity analysis at Gradation 4.",
      "rationale": "FDA generic pump geometry was used as validation surrogate. The commercial VAD impeller has different blade angles, tip clearance, and volute geometry. No formal similarity analysis or geometry sensitivity study was performed. Validation activities are partially relevant but fall short of Gradation 4 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be quantified separately from discretization error at Gradation 3.",
      "rationale": "Iterative convergence was monitored via residual drop (6 orders of magnitude) but round-off error was not separately quantified. No assessment of floating-point arithmetic effects on hemolysis transport integration was performed. Factor flagged as epistemic gap at MRL 5; achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary condition specification, and post-processing scripts must be documented at Gradation 3.",
      "rationale": "No independent peer review of model setup or post-processing scripts was conducted. A single analyst performed all simulations and extracted all QoIs. Use error assessment is an identified epistemic gap; achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of turbulence closure and hemolysis constitutive model must include comparison of alternative model forms at Gradation 4.",
      "rationale": "SST k-omega turbulence model and Giersiepen power-law hemolysis model were selected without comparison against alternative closures (e.g., RSM, Lagrangian particle tracking hemolysis). Model form uncertainty is unquantified. Identified as epistemic gap; achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and uncertainty characterization of all model input parameters (rheological constants, hemolysis model coefficients, boundary conditions) must be documented at Gradation 4.",
      "rationale": "Monte Carlo UQ was performed on three parameters only (inlet velocity, viscosity, hemolysis coefficient C). Hemolysis model exponents alpha and beta, blood damage threshold, and wall boundary conditions were held fixed without sensitivity justification. Partial input uncertainty coverage; achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for hematocrit, donor variability, and storage effects at Gradation 3.",
      "rationale": "FDA benchmark dataset does not provide per-donor hematocrit measurements, storage duration, or anticoagulant protocol details. Sample characterization is insufficient for Gradation 3. Identified as epistemic gap; achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between experimental input parameters and computational boundary conditions must be verified with documented traceability at Gradation 4.",
      "rationale": "Experimental flow rates were set via volumetric pump; corresponding CFD inlet velocity profiles were derived from uniform flow assumption without verification against measured inlet profiles. Equivalency of input parameters is unverified. Identified as epistemic gap; achieved Gradation 1."
