  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-mesh-refinement",
      "type": "ValidationResult",
      "name": "CFD mesh refinement convergence study — centrifugal pump hemolysis",
      "description": "Grid convergence index (GCI) study performed on three mesh levels (coarse 2.1M, medium 5.8M, fine 14.2M cells) for the FDA generic centrifugal pump geometry at the VAD operating point (6 L/min, 3500 RPM). GCI for hemolysis index QoI reported as 4.3% on the fine mesh, meeting the Gradation 2 discretization error requirement.",
      "evidenceTimestamp": "2027-03-15T14:22:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis index predictions",
      "description": "2000-sample Monte Carlo propagation of inlet velocity, viscosity, and power-law hemolysis model coefficient uncertainties. 95th-percentile hemolysis index remains below clinical threshold of 0.8% across all 5 flow-speed operating points. Results support absolute hemolysis acceptance claim.",
      "evidenceTimestamp": "2024-10-05T08:45:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis comparison — FDA pump bench data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against FDA in-vitro benchmark data for the generic centrifugal pump at 5 operating conditions. Mean absolute error of 12.4% reported; systematic over-prediction at low-flow conditions noted. Comparison supports output comparison factor at achieved Gradation 2.",
      "evidenceTimestamp": "2024-08-19T11:00:00Z"
    }
  ],
