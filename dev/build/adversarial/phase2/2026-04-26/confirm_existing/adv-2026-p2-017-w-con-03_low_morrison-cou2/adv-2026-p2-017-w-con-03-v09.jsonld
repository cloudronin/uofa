  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were assessed; all seven show achieved levels below required levels. Six factors were not assessed and flagged as epistemic gaps at MRL 5. The Monte Carlo UQ results demonstrate that hemolysis predictions remain below the clinical threshold at the 95th percentile across all operating points. On balance, the team accepted the package for submission, noting that identified gaps must be addressed in the next assessment cycle. Mesh convergence validation results (evidenceTimestamp 2027-03-15) confirm discretization error characterization.",
