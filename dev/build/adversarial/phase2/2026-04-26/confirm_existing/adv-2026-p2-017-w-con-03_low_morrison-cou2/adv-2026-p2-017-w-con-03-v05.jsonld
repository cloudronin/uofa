    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index comparison — VAD operating envelope",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against in-vitro measurements at five flow-speed operating points. Mean absolute error 0.0018 g/100 L. Pearson r = 0.91. Experimental data collected using standardised ASTM F1841 protocol on FDA generic pump geometry. Monte Carlo boundary condition sampling (n=2000) performed to characterise prediction uncertainty bands. All simulated points fall within ±15% of experimental mean, satisfying the pre-specified acceptance criterion for absolute hemolysis prediction at MRL 5.",
      "evidenceTimestamp": "2027-11-04T08:22:00Z"
    }
