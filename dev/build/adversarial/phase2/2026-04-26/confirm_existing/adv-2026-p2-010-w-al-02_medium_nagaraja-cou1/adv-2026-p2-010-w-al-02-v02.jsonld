  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions, required level 3, achieved level 2) is below the required level due to single test configuration; this shortfall is accepted given that the ASTM F1717 standard mandates the executed configuration and model influence is Medium. Uncertainty quantification via Monte Carlo propagation is complete and 95% prediction intervals are reported for all QoIs. All quantitative validation metrics (E/uval < 1.96; percent difference < 10%) pass acceptance criteria. Overall credibility is sufficient to support regulatory submission for this Medium model risk, Medium decision consequence COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
