  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a Model Risk Level 3, Medium assurance assessment. The single below-required factor (Test conditions, achieved 2 vs. required 3) is accepted on the basis that the single test condition is the primary intended use configuration and the overall validation evidence — including UQ across material and geometric variability — is sufficient to support the regulatory submission. Sensitivity analysis ranking the dominant input drivers is planned for a subsequent design iteration and does not affect the current decision.",
