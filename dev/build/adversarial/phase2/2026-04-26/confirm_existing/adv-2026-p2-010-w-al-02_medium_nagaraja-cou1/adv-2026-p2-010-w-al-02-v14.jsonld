    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented modeling procedures, peer review of model setup, and independent re-run by a second analyst.",
      "rationale": "Modeling procedures documented in a controlled simulation plan. Model setup independently reviewed by a second senior analyst at each participating organization. One construct model was independently re-run by FDA analyst and results agreed within 0.8% of original prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification of constitutive model selection and contact formulation relative to observed pedicle screw deformation mechanisms.",
      "rationale": "Bilinear elastic-plastic constitutive model with isotropic hardening selected based on titanium alloy Ti-6Al-4V coupon characterization data. Penalty-based frictional contact (mu=0.3) applied at screw-plate interface. Model form assessed as appropriate for the quasi-static compression-bending regime covered by ASTM F1717."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from traceable measurements; input uncertainty bounds documented.",
      "rationale": "Elastic modulus (114 GPa ± 3%), yield strength (880 MPa ± 4%), and screw geometry (per device drawings ± manufacturing tolerance) obtained from certified material test reports and CMM measurements. Input uncertainty bounds propagated via Monte Carlo UQ. Sensitivity analysis to rank dominant inputs is identified as planned future work and not included in this package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples representative of production devices; lot traceability documented.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs drawn from two production lots (Lab 1: n=6, Lab 2: n=5). Lot certificates of conformance reviewed; dimensional inspection confirmed devices within drawing tolerances. Sample size assessed as adequate for the medium model risk level and medium decision consequence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios or justification provided for single condition.",
      "rationale": "Testing performed at a single loading condition (ASTM F1717 standard compression-bending configuration). No variation in load angle, offset distance, or environmental condition (dry, ambient) was explored. This factor is below the required level; the limitation is acknowledged and accepted given that ASTM F1717 is the regulatory standard condition and the COU is explicitly bounded to this configuration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs matched to experimental conditions within documented tolerances; any discrepancies quantified.",
      "rationale": "FEA boundary conditions (applied displacement rate, fixture geometry, end-condition constraints) matched to experimental setup drawings and test records. Crosshead displacement rate equivalence confirmed. Discrepancy in fixture compliance (<0.5% effect on QoIs) quantified and found negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed and compared against pre-established threshold of 1.96.",
      "rationale": "E/uval computed for all three QoIs: stiffness (1.31), yield force (1.54), force at 40 mm (1.82). All values below the pre-established threshold of 1.96. Mean absolute percentage errors ranged from 4.7% to 8.3%, all within the <10% acceptance bound. Comparison performed blind to experimental results prior to model lock."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinically and regulatorily relevant performance endpoints for pedicle screw constructs.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the primary performance endpoints specified in ASTM F1717 and referenced in FDA guidance for spinal implant submissions. These QoIs are directly linked to the clinical failure modes of construct loosening and screw fracture."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
