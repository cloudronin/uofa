      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark solutions for cantilever bending and Hertzian contact reproduced within 0.5% of analytical reference.",
      "rationale": "Three canonical verification benchmarks (Timoshenko beam, Hertz contact, elasto-plastic tension bar) executed prior to production runs; all within 0.3% of closed-form solutions. Results archived in Supplemental B."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
