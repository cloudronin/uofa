  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022R2) operates under a documented quality management system with version control, regression testing, and change control procedures consistent with Gradation 2 requirements.",
      "rationale": "All three FEA solvers in the ensemble (FDA in-house, Ansys, DePuy Synthes) are subject to documented SQA procedures including version-controlled source repositories, regression test suites covering structural mechanics elements, and formal change-control logs. Ansys is commercially validated; FDA and DePuy Synthes in-house codes have internal SQA documentation on file. Required and achieved levels are both Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification demonstrated through benchmark problems with known analytical solutions for linear elastic beam bending and contact mechanics, confirming correct implementation of governing equations.",
      "rationale": "Benchmark comparisons against Timoshenko beam theory and Hertzian contact solutions confirm correct numerical implementation. All three codes reproduce analytical solutions within floating-point precision tolerances. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates that QoI values change by less than 2% upon halving element size, confirming discretization error is below acceptance threshold.",
      "rationale": "A systematic mesh refinement study was conducted across three mesh densities (coarse, medium, fine). Stiffness, yield force, and force at 40 mm displacement all converged to within 1.4% between medium and fine meshes. The medium mesh was selected for production runs, providing adequate accuracy at acceptable computational cost. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals reduced to below 1e-6 for all load steps; Newton-Raphson convergence confirmed for nonlinear contact iterations.",
      "rationale": "All nonlinear static analyses converged with force and displacement residuals below 1e-6. Contact stabilization energy monitored and confirmed to be negligible (<0.01% of total strain energy). No spurious hourglass modes detected. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup reviewed by independent analyst; boundary conditions, loading, and material assignments verified against documented modeling protocol prior to production runs.",
      "rationale": "Independent peer review of model setup was conducted by a second analyst at each participating organization. Boundary conditions (fixed inferior vertebral body, compressive-bending load applied at superior body), contact definitions, and material property assignments were verified against the documented modeling protocol. No discrepancies found. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear-elastic model with frictional contact is appropriate for the quasi-static ASTM F1717 loading regime; model form assumptions documented and justified.",
      "rationale": "The quasi-static compression-bending test is well-represented by a continuum linear-elastic model with frictional contact at screw-rod interfaces. Rate effects and viscoelasticity are not relevant for the metallic construct under quasi-static loading. Model form assumptions are explicitly documented. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (elastic modulus, yield strength) sourced from certified material test reports for the specific screw lot; geometric inputs derived from CMM measurements of production components; friction coefficient supported by literature and sensitivity noted.",
      "rationale": "Titanium alloy (Ti-6Al-4V) elastic modulus and yield strength were taken from certified material test reports for the specific manufacturing lot used in bench testing. Screw and rod geometry inputs were derived from coordinate measuring machine (CMM) measurements of production components. Friction coefficient at screw-rod interfaces was assigned based on published tribology literature for Ti-Ti contact. Monte Carlo UQ was applied to material property distributions; the friction coefficient was treated as a fixed nominal value. Full characterization of input driver rankings through sensitivity analysis is identified as a future activity. Gradation 3 achieved.",
      "note": "UQ performed via Monte Carlo over material property distributions. Sensitivity analysis to rank dominant input drivers is planned but not yet executed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 production-representative constructs tested; sample traceability to manufacturing lot documented; sample preparation consistent with ASTM F1717.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production-representative components were tested across two independent laboratories. Sample traceability to the manufacturing lot is documented. Construct assembly followed ASTM F1717 torque specifications. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two loading configurations or environmental conditions relevant to the COU; single test condition is insufficient for Gradation 2.",
      "rationale": "Testing was conducted under a single ASTM F1717 static compression-bending configuration only. No additional loading configurations (e.g., torsion, fatigue) or environmental conditions (e.g., simulated body fluid) were included. This limits the breadth of validation evidence. Required Gradation 2 is not achieved; achieved level is Gradation 1. This is a documented limitation acknowledged in the overall credibility assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters (geometry, material properties, boundary conditions) demonstrably correspond to the physical test configuration; traceability documented.",
      "rationale": "CMM measurements of tested constructs were used to set model geometry. Material properties from the same manufacturing lot were applied. Boundary conditions in the FEA replicate the ASTM F1717 test fixture constraints. Full traceability between physical test configuration and model inputs is documented in the modeling report. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval computed for each QoI; E/uval < 1.96 for all three QoIs; pre-established acceptance bounds met.",
      "rationale": "E/uval computed for stiffness (1.31), yield force (1.74), and force at 40 mm displacement (1.82), all below the pre-established threshold of 1.96. Mean absolute percentage errors are 4.2%, 6.8%, and 7.5% respectively, all within the 10% QoI difference bound. Three-way ensemble agreement (FDA, Ansys, DePuy Synthes) further supports prediction confidence. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical failure mode of interest (construct fracture or permanent deformation) and are the standard ASTM F1717 performance endpoints.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the standard ASTM F1717 endpoints and directly characterize the structural performance margins relevant to clinical fracture risk. These QoIs are the same quantities used in regulatory submissions for pedicle screw constructs. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted on the same device design, material, and loading scenario as the COU; no extrapolation beyond validated domain required for the regulatory decision.",
      "rationale": "Validation was performed on the identical non-cannulated 7.5 mm pedicle screw design, same Ti-6Al-4V material lot, and same ASTM F1717 static compression-bending protocol as the COU. No extrapolation to untested geometries, materials, or loading conditions is required for the regulatory decision. Gradation 2 achieved."
    }
