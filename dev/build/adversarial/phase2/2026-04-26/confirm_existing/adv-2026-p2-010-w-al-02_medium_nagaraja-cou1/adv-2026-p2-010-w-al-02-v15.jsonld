  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble meets pre-established acceptance bounds for all three QoIs (E/uval < 1.96; MAPE < 10%) across N=11 production-representative constructs tested at two independent laboratories. Thirteen V&V 40 credibility factors were assessed; twelve achieved required levels. The single shortfall (Test conditions, achieved Gradation 1 vs. required Gradation 2) is acknowledged and accepted given that the ASTM F1717 static compression-bending configuration is the primary regulatory endpoint and the three-laboratory ensemble provides corroborating evidence. Monte Carlo uncertainty quantification was applied to material property distributions and confirms that prediction intervals encompass experimental scatter. The assessment team notes that formal sensitivity analysis to rank dominant input uncertainty drivers has not yet been completed and is planned for a subsequent study; this does not preclude acceptance for the current regulatory decision given the conservative UQ bounds demonstrated.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
