  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level. The single below-required factor (Test conditions, achieved 2 vs. required 3) is accepted on the basis that ASTM F1717 specifies a single load-offset protocol and the deviation is conservative relative to in vivo loading. Uncertainty quantification over material and geometric inputs has been completed and 95th-percentile prediction intervals are within acceptance bounds for all three QoIs. The overall credibility profile supports use of the FEA framework for the stated COU at Medium assurance level.",
