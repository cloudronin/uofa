  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for a Medium model risk, Medium decision consequence context of use. The single shortfall in Test conditions is accepted because ASTM F1717 defines the sole regulatory benchmark for this device class and expansion to additional test conditions is outside the current submission scope. All three QoIs satisfy the pre-established quantitative acceptance criteria (E/uval < 1.96; percent difference < 10%). Uncertainty quantification via Monte Carlo propagation has been completed and 95% prediction intervals confirm adequate model accuracy. The credibility package is therefore accepted as sufficient to support the regulatory submission decision.",
