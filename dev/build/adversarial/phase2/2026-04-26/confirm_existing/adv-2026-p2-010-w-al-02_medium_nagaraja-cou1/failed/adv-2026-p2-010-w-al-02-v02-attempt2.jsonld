    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics FEA with elastic-plastic titanium alloy material model and frictional contact; model form justified by physics of quasi-static bending.",
      "rationale": "Isotropic elastic-plastic model with bilinear hardening calibrated to Ti-6Al-4V coupon data. Frictional contact (mu=0.2) between screw shaft and block bore is physically motivated. Quasi-static loading rate confirmed appropriate by strain-rate insensitivity check. Model form is consistent with prior FDA pedicle screw literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from manufacturer certificates and CMM measurements; input distributions characterised via Monte Carlo UQ across N=500 samples.",
      "rationale": "Young's modulus, yield strength, and ultimate strength drawn from lot-specific material certificates (n=6 lots). Screw outer diameter and pitch measured by CMM on 11 production screws. Input uncertainty quantification performed via Monte Carlo sampling (N=500) propagating measurement uncertainty through the FEA ensemble, yielding 95% prediction intervals on all three QoIs. A plan to extend this UQ effort with a formal sensitivity analysis to rank dominant input drivers is documented in the project roadmap; however, no sensitivity analysis artifact has been completed or formally linked to this credibility package at the time of submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production lots; dimensional inspection confirms conformance to drawing.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. All specimens drawn from production lots and dimensionally inspected by CMM prior to testing. Lot traceability documented."
    },
    {
