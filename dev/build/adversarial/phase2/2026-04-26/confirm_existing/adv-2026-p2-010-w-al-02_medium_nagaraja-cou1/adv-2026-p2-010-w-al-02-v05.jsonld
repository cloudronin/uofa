    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup, boundary conditions, and material assignments; documented checklist completed.",
      "rationale": "A second analyst independently reviewed all boundary condition definitions, material property assignments, and contact pair configurations against the ASTM F1717 test setup specification. No discrepancies found. Peer review checklist signed and archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification provided for linear elastic titanium alloy constitutive model and frictional contact formulation; comparison to literature values.",
      "rationale": "Ti-6Al-4V modeled as isotropic linear elastic (E=114 GPa, ν=0.34) consistent with ASTM F136 material properties and published literature. Frictional contact (μ=0.2, augmented Lagrangian) used at rod-screw interface. Model form appropriate for pre-yield stiffness and yield force QoIs under quasi-static loading; plastic onset captured via von Mises yield criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from certified material certificates and CMM measurements; input uncertainty distributions documented.",
      "rationale": "Material properties derived from certified mill test reports for Ti-6Al-4V (ASTM F136) lots used in tested constructs. Geometric dimensions measured by CMM on five representative screws (mean ± 1σ reported). Input uncertainty distributions (normal for E, lognormal for yield strength) propagated through Monte Carlo ensemble of 200 model evaluations. UQ results show 95% prediction interval bounds on all three QoIs. Extension to formal sensitivity analysis to rank dominant input drivers is planned for a follow-on study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lots; traceability to device master record confirmed.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. All constructs traceable to the same production lot with documented dimensional inspection. Sample size sufficient for statistical comparison at the required credibility level per ASME V&V 40 Table 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two loading configurations or rod diameters to bound the COU space.",
      "rationale": "Testing conducted under a single ASTM F1717 configuration (5.5 mm rod, standard UHMWPE block, 10 mm offset). Only one test condition evaluated, falling below the required gradation level of 2. This represents a known scope limitation acknowledged in the overall credibility assessment; the shortfall is accepted given the narrow COU (single construct geometry, single regulatory submission)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrated equivalent to physical test specimen parameters within measurement uncertainty.",
      "rationale": "CMM-measured screw geometry imported directly into CAD for FEA. Material properties matched to certified lot data. Boundary conditions replicate ASTM F1717 fixture geometry (offset, grip length, block stiffness). Equivalency confirmed by overlay of FEA deformed shape against post-test DIC images for three representative specimens."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all three QoIs; percentage difference < 10%.",
      "rationale": "E/uval computed per ASME V&V 20 for stiffness (1.12), yield force (1.43), and force at 40 mm (1.38), all below the 1.96 threshold. Percentage differences are 4.2%, 6.8%, and 5.1% respectively, all within the 10% bound. Comparison performed against pooled N=11 experimental data from both laboratories."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly linked to failure modes identified in device risk analysis.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the primary mechanical performance endpoints specified in ASTM F1717 and are directly linked to fatigue crack initiation and permanent deformation failure modes documented in the device FMEA. QoIs are clinically meaningful surrogates for in vivo load transfer."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 bench test) is the same scenario as the COU; no extrapolation required.",
      "rationale": "The validation activity is the COU: the FEA model is validated directly against the ASTM F1717 bench test that constitutes the regulatory submission test. No extrapolation from a surrogate validation scenario to the COU is required. The validation domain fully overlaps the intended use domain for this submission."
    }
