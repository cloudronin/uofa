  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility is assessed as sufficient to support the regulatory submission decision. All 13 V&V 40 factors were formally assessed. Twelve of thirteen factors meet or exceed their required gradation levels. The single shortfall — Test conditions at Gradation 2 against a required Gradation 3 — is acknowledged and accepted given that the ASTM F1717 protocol prescribes a single quasi-static condition and the validation sample size (N=11, two laboratories) provides adequate statistical confidence. Monte Carlo UQ has been applied across all uncertain model inputs, confirming that combined variability is within acceptance bounds (E/uval < 1.96 for all QoIs). Extension of the current probabilistic analysis to include a formal sensitivity analysis ranking the dominant input drivers is planned for the next revision cycle; the absence of this ranking does not invalidate the current acceptance decision given the conservative UQ bounds already demonstrated.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
