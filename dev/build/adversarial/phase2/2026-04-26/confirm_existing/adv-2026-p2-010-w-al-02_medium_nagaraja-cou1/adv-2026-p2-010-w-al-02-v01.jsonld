    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics and geometry representation justified relative to COU loading regime.",
      "rationale": "Linear elastic model form appropriate for stiffness and yield force prediction under quasi-static compression-bending. Geometric nonlinearity enabled for large-displacement regime at 40 mm. Titanium alloy (Ti-6Al-4V) modeled as isotropic elastic-perfectly-plastic consistent with ASTM F136 material specification. Rod-screw interface modeled with frictional contact (μ=0.2) based on published tribological data for titanium interfaces."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters sourced from traceable measurements or certified material data.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and Poisson ratio (0.34) sourced from certified material test reports for Ti-6Al-4V bar stock conforming to ASTM F136. Screw geometry digitized from CMM measurements of production implants. Input uncertainty quantified via Monte Carlo propagation of material property distributions (CV 3–5%) and geometric tolerances. Uncertainty characterization covers parameter ranges but, as noted in the UQ report, a planned extension to formal sensitivity analysis to rank dominant input drivers has not yet been completed and will be addressed in a subsequent revision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples representative of production implants; sample size sufficient for statistical comparison.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs drawn from production lot, tested across two independent laboratories (FDA CDRH and DePuy Synthes). Lot traceability documented. Sample size supports 90% confidence interval estimation for mean QoI comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant range or deviation from single condition is justified.",
      "rationale": "Testing conducted at a single load configuration per ASTM F1717 standard protocol. While this single condition limits the ability to assess model fidelity across the full clinical loading envelope, it is consistent with the regulatory submission requirement and represents the worst-case compression-bending scenario. Acknowledged as a limitation; required level not fully achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs matched to experimental conditions with documented traceability.",
      "rationale": "Applied load magnitude, boundary conditions (fixed-fixed UHMWPE block embedment), and crosshead displacement rate (25 mm/min quasi-static) matched between FEA and bench protocol. Material property inputs verified against measured hardness and tensile coupon data from the same production lot as tested constructs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined a priori; E/uval < 1.96 for all QoIs.",
      "rationale": "Three QoIs compared: construct stiffness, yield force, and force at 40 mm displacement. Acceptance criterion E/uval < 1.96 defined a priori. Results: stiffness E/uval = 1.31, yield force E/uval = 1.54, force at 40 mm E/uval = 1.18. All three QoIs pass the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly correspond to clinical performance indicators for pedicle screw construct integrity under compression-bending. These metrics are cited in the 510(k) submission as primary performance endpoints."
    },
    {
      "factorStandard": "ASME-VV40-2018",
