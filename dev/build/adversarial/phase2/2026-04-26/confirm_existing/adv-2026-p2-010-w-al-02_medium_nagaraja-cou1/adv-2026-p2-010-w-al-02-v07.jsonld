  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is acknowledged but does not invalidate the overall assessment given that inter-laboratory reproducibility is confirmed and the loading rate deviation is bounded by the conservative F1717 protocol. All three QoIs satisfy E/uval < 1.96 and percent-difference < 10% acceptance criteria. Uncertainty quantification via Monte Carlo propagation is documented across material and geometric input distributions. The credibility package is accepted at Medium assurance level for the stated COU.",
