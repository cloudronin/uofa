    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum FEA with nonlinear geometry and frictional contact is an established modeling approach for metallic implant compression-bending; model form uncertainty quantified via ensemble spread.",
      "rationale": "Three independent FEA implementations (FDA, Ansys, DePuy Synthes) using the same geometry and nominal material properties produced QoI spread of <4%, confirming low model-form sensitivity. Nonlinear geometry (large displacement) and frictional contact (mu=0.3) are physically justified for this test configuration. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (Ti-6Al-4V ELI) sourced from coupon testing of the same material lot as test constructs; geometric inputs from CMM measurements of production hardware.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and ultimate tensile strength (950 MPa) were measured from dog-bone coupons machined from the same Ti-6Al-4V ELI bar stock as the test constructs. Screw and rod geometry verified by CMM to within 0.01 mm of nominal CAD. Input uncertainty propagated via Latin hypercube sampling (n=200) yielding <3% QoI variability. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lots, distributed across two independent laboratories; sample-to-sample geometric variability documented.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production hardware and tested at two independent laboratories (n=6 and n=5). CMM measurements confirmed all constructs within drawing tolerances. Coefficient of variation for experimental stiffness was 4.2%, consistent with expected manufacturing variability. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions should span at least two load levels or two construct configurations to characterize model behavior across the COU envelope.",
      "rationale": "Testing was conducted at a single ASTM F1717 standard configuration and load rate. While the test protocol is fully standardized and reproducible, only one test condition was evaluated, precluding assessment of model behavior across a range of conditions. Achieved level (2) is below required level (3); this gap is acknowledged as a limitation of the current validation dataset and is documented in the overall credibility summary."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material, boundary conditions) demonstrably equivalent to test article and test setup parameters.",
      "rationale": "FEA geometry was derived from the same CAD files used for manufacturing. Material properties sourced from same lot coupons. Boundary conditions replicate ASTM F1717 fixture constraints (fixed inferior vertebral body block, superior block free in axial direction). Load application point and direction verified against test machine setup photographs. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percent difference < 10% for all three QoIs across all 11 constructs.",
      "rationale": "E/uval values for stiffness, yield force, and 40 mm displacement force ranged from 0.31 to 1.74 across all constructs and QoIs, all below the 1.96 threshold. Maximum percent difference was 7.8% (yield force, construct #9). Both acceptance criteria satisfied for all comparisons. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to clinical performance indicators for pedicle screw constructs under physiological bending loads.",
      "rationale": "Construct stiffness relates to load sharing between implant and bone graft; yield force indicates onset of permanent deformation under worst-case intraoperative loading; force at 40 mm displacement characterizes post-yield behavior relevant to fatigue initiation. All three QoIs are standard ASTM F1717 outputs and are directly referenced in FDA guidance for spinal implant submissions. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test configuration matches COU device geometry, loading mode, and regulatory submission context.",
      "rationale": "The validation activity uses the identical non-cannulated 7.5 mm pedicle screw geometry, Ti-6Al-4V ELI material, and ASTM F1717 test protocol as the COU. The regulatory submission context (510(k) substantial equivalence for a Class II spinal fixation system) is directly addressed by this validation evidence. High relevance between validation activity and COU confirmed. Achieved level equals required level."
