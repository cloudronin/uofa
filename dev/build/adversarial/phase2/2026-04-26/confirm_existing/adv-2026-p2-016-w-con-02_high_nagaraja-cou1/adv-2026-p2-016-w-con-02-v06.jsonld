  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for a Medium model risk, Medium decision consequence COU. The single shortfall (Test conditions, Gradation 1 achieved vs. Gradation 2 required) is accepted on the basis that ASTM F1717 specifies a single displacement rate, Ti-6Al-4V exhibits negligible strain-rate sensitivity under quasi-static loading at ambient temperature, and all quantitative output comparison metrics (E/uval < 1.96, percentage differences < 10%) are satisfied across both independent laboratories. The overall credibility evidence package, including the validation methodology described in the referenced comparative finite element analysis framework (doi:10.1016/j.ymeth.2024.03.003), supports the conclusion that the FEA model ensemble is sufficiently credible for its intended use in the regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
