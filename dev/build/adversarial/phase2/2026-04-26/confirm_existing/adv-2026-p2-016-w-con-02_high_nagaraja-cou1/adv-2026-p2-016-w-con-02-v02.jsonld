    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals monitored. Force equilibrium residual < 1e-4 at each load step. Energy norm convergence criterion applied for nonlinear contact iterations.",
      "rationale": "Nonlinear static analysis with augmented Lagrangian contact. Force residual norm < 5e-5 at all converged load steps. No divergence events recorded across 11 model instances. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and post-processing scripts by a second qualified analyst. Documented review checklist completed.",
      "rationale": "Model setup reviewed by a second FDA analyst using a 47-item checklist covering geometry, material assignment, contact definitions, boundary conditions, and post-processing. Two minor discrepancies identified and corrected prior to final runs. Use error risk reduced to Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear-elastic titanium alloy (Ti-6Al-4V) with nonlinear contact at screw-rod and screw-block interfaces. Model form justified by literature precedent and sensitivity analysis showing <5% QoI sensitivity to plasticity inclusion at sub-yield loads.",
      "rationale": "Sensitivity study comparing linear-elastic and bilinear isotropic hardening plasticity models showed 3.1% maximum QoI difference for loads below yield. Linear-elastic model form accepted as adequate for the COU. Nonlinear contact included as required by ASTM F1717 geometry. Model form credibility Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, nu, yield strength) sourced from ASTM F136 certificate of conformance for each tested lot. Geometric inputs from CMM measurement of three representative constructs. Input uncertainty propagated via Monte Carlo (N=1000).",
      "rationale": "Ti-6Al-4V elastic modulus 113.8 GPa ± 2.1 GPa (lot certificate). Poisson ratio 0.342 from literature consensus. CMM-measured screw geometry within ±0.02 mm of nominal CAD. Monte Carlo propagation showed QoI standard deviation attributable to input uncertainty < 3.5%. Gradation 3 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from a single production lot. Sample traceability documented. Dimensional inspection confirms conformance to design drawing within tolerance.",
      "rationale": "Eleven constructs assembled from screws and rods from a single production lot (Lot 2022-NC-7.5). CMM inspection of 3 randomly selected constructs confirmed dimensional conformance. Chain of custody documented from manufacturer to both test laboratories. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate ASTM F1717 standard fixture geometry, loading rate (5 mm/min), and ambient environment. Required level 3 demands at least two independent test conditions or laboratories with documented inter-laboratory agreement.",
      "rationale": "Testing conducted at two laboratories (FDA CDRH biomechanics lab and an independent contract lab), partially satisfying inter-laboratory requirements. However, only a single loading rate (5 mm/min) and a single spinal level surrogate (L4-L5 UHMWPE block) were used. The absence of a second loading rate or alternative fixation condition prevents achievement of Gradation 3. This factor is below the required level and is noted as a gap in the credibility assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and material inputs demonstrably matched to experimental test setup. Fixture compliance characterized and incorporated into model. Loading point and constraint locations verified against test fixture drawings.",
      "rationale": "Fixture compliance (0.8 N/mm) measured and incorporated as a spring boundary condition in the FEA model. Loading point coordinates verified against test fixture CAD. UHMWPE block modulus measured by indentation (E = 0.94 GPa) and used as model input. Input equivalency documented in test-analysis correlation report. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric: E/uval (validation metric per ASME V&V 10.1). Acceptance threshold E/uval < 1.96 for all three QoIs. Uncertainty budget includes experimental measurement uncertainty, model parameter uncertainty, and numerical error.",
      "rationale": "E/uval values: stiffness 1.31, yield force 1.58, force at 40 mm 1.82. All three below 1.96 threshold. Combined uncertainty budget (experimental + model) documented. Systematic bias in force at 40 mm (FEA slightly over-predicts) noted but within acceptance bounds. Gradation 3 achieved for output comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) directly correspond to ASTM F1717 performance endpoints and to the COU decision (device structural adequacy). Clinical relevance of each QoI documented.",
      "rationale": "Construct stiffness relates to load sharing with the spinal column. Yield force is the primary structural integrity endpoint. Force at 40 mm displacement characterizes post-yield behavior relevant to fatigue life estimation. All three QoIs are explicitly listed in ASTM F1717 and in the predicate 510(k) submission. Relevance to COU confirmed. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities (ASTM F1717 bench testing of the same device design) directly replicate the COU loading scenario. No extrapolation beyond validated domain required for the regulatory decision.",
      "rationale": "The validation experiments use the identical non-cannulated 7.5 mm pedicle screw design, the same ASTM F1717 fixture, and the same loading mode (compression-bending) as the COU. No interpolation or extrapolation to a different loading mode, device size, or material is required. The validation domain fully covers the COU. Gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficient factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is acknowledged; the gap is attributable to the use of a single loading rate and a single spinal surrogate geometry. The assessment team judged this gap acceptable given the strong inter-laboratory agreement (CV < 4% across both labs) and the conservative acceptance bounds applied to all three QoIs. Overall credibility is sufficient to support the regulatory submission for the non-cannulated 7.5 mm pedicle screw design. The methodological framework applied in this assessment follows the validation uncertainty quantification approach described in the referenced methods literature (see referencesIdentifier), which provides the statistical basis for the E/uval threshold selection.",
