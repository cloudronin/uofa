    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic material model justified for sub-yield regime; nonlinear contact (augmented Lagrangian, frictional mu=0.3) used at screw-rod and screw-block interfaces; geometric nonlinearity enabled.",
      "rationale": "The pedicle screw construct under ASTM F1717 loading remains predominantly elastic below yield; linear elastic Ti-6Al-4V properties (E=114 GPa, nu=0.34) are appropriate. Contact nonlinearity at interfaces is physically necessary and implemented with validated frictional contact formulation. Geometric nonlinearity (large displacement) enabled to capture post-yield bending kinematics. Model form uncertainty estimated and included in uval. Required level 3 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
