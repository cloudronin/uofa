  "signature": "ed25519:b1d3f5a7c9e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be developed under a documented quality management system with version control, issue tracking, and regression test suite appropriate for MRL 5.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under ISO 9001-aligned QMS. Full regression test suite of 312 cases passes on every tagged release. Version control via Git with signed commits. Defect tracking in JIRA with closed-loop resolution records. Required level 4 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) must demonstrate expected order of convergence for all relevant transport equations including scalar hemolysis transport.",
      "rationale": "MMS studies confirm second-order spatial convergence for velocity, pressure, and hemolysis scalar. Observed convergence rates: 1.97 (velocity), 1.95 (pressure), 1.93 (hemolysis). Temporal convergence verified to first order for backward-Euler scheme. Required level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be computed on at least three systematically refined meshes; GCI on hemolysis index must be below 5%.",
      "rationale": "Three-level mesh refinement study performed (4.1M, 12.3M, 36.9M cells). GCI on hemolysis index: 8.3% between coarse and medium, 6.1% between medium and fine. Fine-mesh GCI does not meet the 5% threshold. Achieved level 3 versus required level 4; gap acknowledged but assessment team judged residual discretization uncertainty bounded within Monte Carlo UQ envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit) must be documented and replicated in simulation to within measurement uncertainty.",
      "rationale": "All five operating points replicated with documented inlet velocity profiles from LDV measurements. Fluid temperature maintained at 37 ± 0.5 °C in both experiment and simulation. Hematocrit 33 ± 1% confirmed via Coulter counter pre- and post-run. Required level 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (E_rms normalized by experimental uncertainty) must be computed for hemolysis index across all operating points. Metric must meet acceptance threshold defined in validation plan.",
      "rationale": "Normalized RMS error on hemolysis index: 0.34 across 5 operating points (threshold 0.25). Three of five points meet threshold individually; two high-speed points show 18–22% over-prediction. Achieved level 3 versus required level 4. Assessment team notes conservative over-prediction direction is protective for patient safety."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (normalized index of hemolysis, NIH) must be the same scalar quantity used in the COU decision and must be directly linked to the clinical threshold.",
      "rationale": "NIH (g/100 L) is the COU QoI and the validation QoI. Clinical threshold of 0.1 g/100 L is directly applied to model predictions. No intermediate proxy QoI used. Required level 4 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry under operating conditions that span the COU envelope (flow rate 3–6 L/min, rotational speed 2400–3200 RPM).",
      "rationale": "Validation experiments used identical pump geometry. Flow rates 3–6 L/min covered; however, rotational speed range tested was 2500–3000 RPM, leaving the 3200 RPM upper bound extrapolated. Achieved level 3 versus required level 4. Extrapolation gap documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual tolerance below 1e-6 for all transport equations; floating-point round-off contribution must be estimated.",
      "rationale": "All residuals converged to 1e-7 or below within 2000 iterations per time step. Round-off contribution estimated at < 0.01% of hemolysis index via double-precision sensitivity study. Required level 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation execution checklist and independent peer review of setup files must be completed prior to each production run.",
      "rationale": "Simulation execution checklist (32 items) completed and signed for all five operating-point runs. Independent reviewer (not the analyst) verified mesh, boundary conditions, and solver settings. No use errors identified. Required level 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model for red blood cell damage must be appropriate for the shear stress and exposure time regime encountered in the VAD operating envelope.",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger correlation) was selected following a qualitative expert review by three independent biofluid-mechanics specialists with combined 45 years of VAD modeling experience. Reviewers assessed the model's theoretical basis against the dominant shear stress regime (10–500 Pa, exposure times 1–50 ms) present in the pump. The consensus expert judgment is that the power-law formulation captures the dominant damage mechanism with acceptable fidelity for this COU, and that alternative continuum damage models do not offer a demonstrated advantage at the operating conditions of interest. This qualitative assessment, documented in a signed expert panel report (ref. MP-2024-07), provides the evidentiary basis for model form credibility. No structured gradation scoring was applied to this factor because the expert panel concluded that the existing experimental corpus does not yet support a defensible quantitative level assignment for model-form adequacy at MRL 5 shear regimes; the panel's consensus narrative constitutes the complete evidence record for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and model constants (blood viscosity, density, hemolysis model coefficients) must have documented sources with stated uncertainty bounds.",
      "rationale": "Blood viscosity (Carreau-Yasuda parameters) sourced from literature with ±8% uncertainty. Hemolysis model coefficients (C=3.62e-5, α=2.416, β=0.785) from Giersiepen et al. with ±15% coefficient uncertainty propagated via Monte Carlo. Density fixed at 1060 kg/m³ ± 5 kg/m³. Achieved level 3 versus required level 4 due to coefficient uncertainty exceeding 10% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Fresh bovine blood used in experiments must meet ASTM F1841 preparation criteria; baseline hemolysis must be below 0.02 g/100 L prior to each test.",
      "rationale": "Bovine blood prepared per ASTM F1841. Baseline NIH < 0.015 g/100 L confirmed for all test samples. Blood age at time of test: 4–6 hours post-collection. Three independent blood batches used across five operating points to reduce batch-to-batch confounding. Required level 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensional analysis must confirm that the non-dimensional groups governing hemolysis (Reynolds number, Stokes number, exposure-time ratio) are matched between validation experiments and COU operating conditions.",
      "rationale": "Reynolds numbers at all five COU operating points (Re 8200–14600) are within the range tested experimentally (Re 8500–13800). Stokes number < 0.01 in both contexts confirming negligible particle inertia effects. Exposure-time ratio within ±12% across all matched operating points. Required level 4 met."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 factors. Twelve factors carry structured requiredLevel and achievedLevel scores; while several factors achieved levels below required (Discretization error, Output comparison, Relevance of validation activities, Model inputs), the team judged that the cumulative body of evidence — including the Monte Carlo UQ envelope bounding residual discretization uncertainty, the conservative over-prediction direction of hemolysis, and the expert panel qualitative assessment of model form — is sufficient to support the claim that CFD predictions of absolute hemolysis index are credible for Class III VAD decision-making. The integrated evidence package is accepted for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
