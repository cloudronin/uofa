  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all 13 ASME V&V 40 credibility factors. Twelve factors achieved their required gradation levels; the model form factor was evaluated through a comprehensive qualitative expert panel review supported by three independent literature datasets, and the panel concluded that the model form is appropriate for the VAD COU. On the basis of the complete factor evidence and the Monte Carlo uncertainty quantification demonstrating hemolysis predictions below the clinical threshold with 95% confidence, the panel accepts the CFD model for the intended use.",
