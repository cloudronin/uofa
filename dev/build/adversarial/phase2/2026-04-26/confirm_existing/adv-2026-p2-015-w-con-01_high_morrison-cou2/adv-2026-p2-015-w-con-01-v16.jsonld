  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "Software used for CFD simulation must comply with a documented quality management system including version control, regression testing, and audit trail.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is developed under ISO 9001-certified QMS. Full regression test suite executed; version control logs and release notes reviewed. Achieved level meets required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "Manufacturer-supplied verification test suite must cover relevant solver physics including turbulence and rotating reference frames.",
      "rationale": "ANSYS Fluent verification suite includes rotating frame and k-omega SST turbulence benchmarks. All canonical test cases pass to within published tolerances. Code verification is complete at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index QoI on at least three systematically refined meshes; GCI must be below 5%.",
      "rationale": "Three mesh levels (4M, 12M, 36M elements) were simulated. GCI for hemolysis index QoI is 2.8% between medium and fine meshes. Richardson extrapolation confirms asymptotic convergence. Discretization error is adequately characterised."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions must match the CFD boundary conditions within documented tolerances; flow rate and rotational speed must be independently measured.",
      "rationale": "All five operating points were reproduced experimentally with calibrated flow meters (±1.5%) and optical tachometry (±0.2%). Boundary condition mapping documented in test protocol TP-VAD-2024-03."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "Predicted hemolysis index must be compared against experimental measurements with quantified uncertainty; systematic bias must be characterised.",
      "rationale": "Predicted vs. measured hemolysis index compared at all five operating points. Mean absolute error is 8.3% with no systematic bias detected. Experimental uncertainty bands overlap model prediction intervals at four of five points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoI used in validation (hemolysis index) must be directly mapped to the clinical endpoint (patient hemolysis risk).",
      "rationale": "Hemolysis index is the regulatory QoI specified in FDA guidance. Direct traceability from model output to clinical threshold is documented in the credibility plan. QoI relevance is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and blood analogue fluid as the COU; operating conditions must span the intended clinical envelope.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry with a glycerol-water blood analogue. Operating conditions cover 3–6 L/min at 2500–3500 RPM, encompassing the full VAD clinical envelope. Relevance is high."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Iterative convergence must be demonstrated; residuals must reach at least 1e-5 for all transport equations; mass imbalance must be below 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum. Mass imbalance is 0.003%. Convergence histories archived in simulation log SL-VAD-2024."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "A documented simulation protocol and independent peer review of setup must be completed prior to final simulation runs.",
      "rationale": "Simulation protocol SP-VAD-2024-01 reviewed and approved by an independent CFD engineer not involved in model development. Setup checklist completed and archived. Use error controls are adequate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model for blood damage must be appropriate for the shear stress and exposure time ranges encountered in the VAD operating envelope.",
      "rationale": "A qualitative assessment of model form credibility was conducted by the subject-matter expert panel convened on 2024-11-14. The panel reviewed the power-law hemolysis model (Giersiepen-Wurzinger correlation) against published literature covering shear stress ranges of 10–600 Pa and exposure times of 1–500 ms, which fully encompass the VAD operating envelope. The panel unanimously concluded that the model form is appropriate for this COU, citing consistency with three independent validation datasets in the literature (Fraser et al. 2012, Taskin et al. 2012, Arvand et al. 2005). No structured gradation scoring was applied because the panel determined that the qualitative consensus review constituted sufficient evidence at the expert judgment level; the richness of the supporting literature and the breadth of the operating-condition coverage were judged to render a numerical gradation assessment redundant for this particular factor. This narrative assessment is considered sufficient to support the Accepted decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "All model input parameters (fluid properties, geometry, boundary conditions) must be traceable to calibrated measurements or published reference data.",
      "rationale": "Blood analogue fluid properties measured at 37°C; pump geometry imported from manufacturer CAD with dimensional verification. All inputs documented in input data record IDR-VAD-2024-02 with traceability to calibration certificates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental samples must be representative of the target population; at least three independent experimental replicates must be reported.",
      "rationale": "Five independent experimental replicates performed per operating point using fresh blood analogue batches. Sample preparation protocol ensures batch-to-batch consistency within ±2% of target viscosity. Test samples are representative."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The mapping between experimental input parameters and CFD boundary conditions must be explicitly documented and any differences must be assessed for impact on QoI.",
      "rationale": "A parameter equivalency table maps each experimental measurement to its CFD counterpart. Differences in fluid rheology (Newtonian approximation vs. shear-thinning blood) assessed via sensitivity study; impact on hemolysis index is less than 4%, within acceptable bounds."
    }
  ],
