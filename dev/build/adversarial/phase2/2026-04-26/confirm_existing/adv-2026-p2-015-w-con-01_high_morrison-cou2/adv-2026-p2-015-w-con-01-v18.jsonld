  "hash": "sha256:a3f1c2e4b7d09e5f1234567890abcdef1234567890abcdef1234567890abcdef",
  "signature": "ed25519:b9e2d3f4a1c05e6f7890abcdef1234567890abcdef1234567890abcdef123456",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be under formal version control with documented test suite and issue tracking; all solver modifications must be peer-reviewed prior to release.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under Git version control with a CI/CD pipeline executing regression tests on each commit. Release notes document all modifications relevant to blood pump simulations. SQA level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include manufactured solution tests for the turbulence model and hemolysis transport equation demonstrating expected order of convergence.",
      "rationale": "Method of manufactured solutions was applied to the scalar hemolysis transport equation and confirmed second-order convergence. Turbulence model (SST k-omega) verification relied on published benchmark results rather than in-house manufactured solutions, limiting the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; GCI on hemolysis index must be below 5% at the operating points of interest.",
      "rationale": "Three meshes (4.2M, 12.6M, 37.8M cells) were generated with a refinement ratio of 1.44. GCI values for hemolysis index ranged from 1.8% to 4.3% across the five operating points, satisfying the 5% threshold. Richardson extrapolation confirmed asymptotic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with measured inlet/outlet pressures, flow rates, and blood analog properties; deviations from physiological conditions must be characterized.",
      "rationale": "FDA benchmark experiments used porcine blood at 37°C with documented hematocrit (35±2%). Flow rates and pressure heads were measured with calibrated instrumentation. Use of porcine rather than human blood introduces a minor species-related uncertainty that was propagated through the UQ analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, validation uncertainty) must be computed for hemolysis index at all five operating points; systematic bias must be within 15%.",
      "rationale": "Normalized RMS error across five operating points was 18.4%, slightly exceeding the 15% bias threshold. Validation uncertainty intervals overlap experimental measurements at four of five points. The fifth point (high-speed, low-flow) showed consistent over-prediction attributed to unresolved secondary flow structures. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must directly map to the clinical threshold metric; surrogate QoIs must be justified.",
      "rationale": "The normalized index of hemolysis (NIH) is the regulatory metric specified in the device submission. The CFD output is directly mapped to NIH via the Giersiepen-Wurzinger power-law model. No surrogate QoIs were substituted. Level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be performed on the same pump geometry under the same operating envelope as the COU; extrapolation beyond the validated envelope must be quantified.",
      "rationale": "Validation was conducted on the FDA generic centrifugal pump geometry, which is identical to the device geometry. However, two of the five COU operating points lie at the boundary of the experimentally validated envelope, requiring modest extrapolation. Extrapolation uncertainty was included in the Monte Carlo UQ but reduces the relevance level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to within 1e-5 for all residuals; floating-point round-off sensitivity must be assessed.",
      "rationale": "All simulations were run to residual convergence of 1e-6 for continuity, momentum, and scalar transport equations. Double-precision arithmetic was used throughout. A sensitivity study comparing single- and double-precision outputs showed negligible differences (<0.1% in NIH). Level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "User inputs (boundary conditions, material properties, turbulence model settings) must be documented in a simulation plan reviewed by an independent analyst.",
      "rationale": "A formal simulation plan was prepared and reviewed by an independent CFD analyst not involved in the original setup. All boundary condition choices and turbulence model constants were documented. One minor discrepancy in inlet turbulence intensity specification was identified and corrected prior to final runs. Level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified relative to alternative constitutive models; sensitivity of NIH predictions to model form selection must be quantified.",
      "rationale": "A qualitative assessment of model form credibility was conducted by the team's biomechanics subject matter expert. The Giersiepen-Wurzinger model was selected based on its widespread regulatory acceptance and availability of calibration constants for porcine blood. Three alternative hemolysis models (Arora, Zhang, and Taskin) were reviewed in the literature and their predicted NIH ranges were noted to bracket the primary model predictions in the published literature. The team concluded that the selected model form is appropriate for regulatory submission purposes given the breadth of prior FDA acceptance of this formulation, and that the qualitative literature comparison provides sufficient confidence in model form selection for this context of use. No formal sensitivity index was computed for model form uncertainty, as the team judged the qualitative evidence sufficiently compelling given the regulatory precedent."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in all model inputs (viscosity, density, hemolysis model constants) must be characterized and propagated through Monte Carlo UQ; Sobol sensitivity indices must be reported.",
      "rationale": "Monte Carlo UQ was performed with 2000 samples across seven uncertain input parameters. Sobol first-order and total-order sensitivity indices were computed. Blood viscosity and the Giersiepen-Wurzinger exponent alpha were identified as dominant contributors. The achieved level is 3 because the probability distributions assigned to hemolysis model constants were based on literature ranges rather than dedicated calibration experiments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least three independent blood samples must be used in experimental validation; sample-to-sample variability must be reported.",
      "rationale": "Five independent porcine blood draws were used across the experimental validation campaign. Hematocrit was measured for each draw and adjusted to 35% prior to testing. Inter-sample NIH variability was reported as ±8%, which was incorporated into the validation uncertainty budget. Level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, rotational speed, flow rates) must be demonstrated to match experimental conditions within stated tolerances.",
      "rationale": "CAD geometry was imported directly from the FDA benchmark geometry repository. Rotational speeds were matched to within ±0.5 RPM of experimental settings. Inlet flow rates were matched to within ±2% of experimental measurements. All tolerances are within the acceptance criteria. Level 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors. Twelve factors achieved their required levels or were within one gradation with documented justification. The model form factor was evaluated through a thorough qualitative assessment supported by extensive regulatory precedent for the Giersiepen-Wurzinger formulation. Monte Carlo uncertainty quantification demonstrated that NIH predictions remain below the clinical threshold across the 95th percentile of the uncertainty distribution at all five operating points. On balance, the assembled evidence is sufficient to support acceptance of the CFD model for predicting absolute hemolysis levels in the stated context of use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
