  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "SQA plan covering version control, regression testing, and documentation must be in place and audited.",
      "rationale": "The simulation software (ANSYS Fluent 2022 R2) is operated under a documented SQA plan. Version control via Git, automated regression suite with 98% pass rate, and audit trail for all simulation inputs are confirmed. Achieved level meets the required level for MRL 5 Class III device context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Order-of-accuracy verification must demonstrate at least second-order spatial convergence on canonical benchmark cases relevant to rotating machinery.",
      "rationale": "Code verification was performed on Taylor-Green vortex and lid-driven cavity benchmarks. Observed spatial order of accuracy was 1.87, marginally below second order. The rotating-frame benchmark showed 1.92 order. Achieved level 3 falls one gradation below required level 4; however, the gap was accepted by the review panel given the marginal deficiency and the presence of compensating uncertainty quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all QoIs; GCI < 5% for hemolysis index at each operating point.",
      "rationale": "Three-level mesh refinement study performed on all five operating points. GCI values for hemolysis index ranged from 1.8% to 4.3%, all within the 5% threshold. Richardson extrapolation applied. Discretization error is well-characterized and meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within stated tolerances for flow rate (±2%), rotational speed (±1%), and fluid temperature (±1°C).",
      "rationale": "FDA benchmark experimental data were collected under controlled laboratory conditions. Flow rate deviations were within ±1.4%, rotational speed within ±0.6%, and temperature within ±0.8°C across all test points. Test condition matching achieves required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation metric u_val) must be computed for hemolysis index at all operating points with uncertainty bounds.",
      "rationale": "Validation metric computed using ASME V&V 20 approach. Mean relative error in hemolysis index was 12.4% across five operating points. Experimental uncertainty in hemolysis measurement was ±8%. The model prediction falls within combined uncertainty bands at 3 of 5 points. Achieved level 3 is one gradation below required level 4; the review team accepted this gap on the basis of the Monte Carlo UQ results bounding worst-case predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress distribution) must be directly relevant to the clinical decision metric (absolute hemolysis threshold).",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the direct clinical metric used in regulatory submissions. Secondary QoIs include volume-averaged scalar shear stress and exposure time distributions. All QoIs map directly to the clinical decision threshold. Relevance is high and meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry and at operating conditions spanning the full COU envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump, which is the same geometry as the COU device. Operating conditions in validation span 2500–3500 RPM and 2–8 LPM, covering the COU envelope of 2800–3200 RPM and 3–6 LPM. However, the highest-shear operating point (3500 RPM, 2 LPM) was only partially covered by experimental data. Achieved level 3 accepted with noted limitation in coverage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "All simulations converged to residual levels of 1e-6 or lower for continuity, momentum, and turbulence equations. Mass imbalance was below 0.005% in all cases. Solver error is negligible and meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition inputs must be traceable to documented source data.",
      "rationale": "An independent CFD analyst reviewed all simulation setups prior to execution. Boundary conditions were traced to the experimental protocol document (Rev. 3). No setup errors were identified during independent review. Use error controls meet required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis constitutive model must be justified for rotating blood-contacting flows at physiological shear rates.",
      "rationale": "Model form adequacy was evaluated through a structured qualitative assessment conducted by a three-member expert panel comprising a computational fluid dynamicist specializing in cardiovascular flows, a hematologist with expertise in shear-induced hemolysis, and a regulatory affairs specialist with V&V 40 experience. The panel reviewed the selection of the SST k-omega turbulence closure, the Giersiepen-Wurzinger power-law hemolysis model, and the non-Newtonian viscosity treatment. The panel consensus was that the selected model forms are well-established in the literature for centrifugal pump hemolysis prediction, that the SST k-omega model captures the transitional shear layers in the blade passage with acceptable fidelity, and that the hemolysis model coefficients have been calibrated against in-vitro data at the relevant shear rate range (50–2000 Pa). The qualitative assessment concluded that model form adequacy is sufficient for the COU and no material model form deficiency was identified that would alter the acceptance decision. This factor was therefore assessed as credible through expert elicitation rather than through a formal gradation assignment, consistent with the panel's determination that the qualitative evidence base is robust and self-consistent."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "Uncertainty in model input parameters (viscosity, density, hemolysis model coefficients) must be characterized and propagated through Monte Carlo analysis.",
      "rationale": "Monte Carlo uncertainty quantification performed with 10,000 samples. Input distributions assigned to blood viscosity (CV 8%), density (CV 2%), and Giersiepen-Wurzinger coefficients (CV 15% based on published inter-study variability). 95th percentile hemolysis index predictions remain below clinical threshold at all operating points. Model input uncertainty is fully characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Blood analog fluid properties must be characterized and reported; bovine blood lot variability must be assessed.",
      "rationale": "Experimental validation used fresh bovine blood with hematocrit 35±2%. Lot variability assessed across three independent blood draws; hemolysis baseline (free plasma hemoglobin) measured before each test. Fluid characterization meets required level for MRL 5 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "CFD model input parameters must be demonstrably equivalent to the experimental conditions used in validation, including fluid properties and geometric fidelity.",
      "rationale": "CFD model geometry was constructed from the published FDA benchmark CAD file with dimensional verification against the physical test article (maximum deviation 0.05 mm). Fluid properties in the CFD model were set to match the experimentally measured bovine blood properties for each test condition. Equivalency is confirmed at required level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors, the assessment team concludes that the CFD model has sufficient credibility for predicting absolute hemolysis levels in the VAD COU. Three factors (numerical code verification, output comparison, relevance of validation activities) achieved one gradation below required level; however, the Monte Carlo uncertainty quantification, independent setup review, and expert-panel model form assessment collectively provide compensating evidence. The model form factor was evaluated through rigorous qualitative expert elicitation and was found adequate. The 95th percentile hemolysis predictions remain below the clinical threshold across all operating points with margin. The assessment team accepts the model for the intended regulatory submission use.",
    "decidedAt": "2026-04-19T00:00:00Z"
