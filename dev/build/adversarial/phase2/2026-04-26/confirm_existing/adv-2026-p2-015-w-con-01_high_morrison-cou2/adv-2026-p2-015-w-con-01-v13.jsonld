  "signature": "ed25519:9f8e7d6c5b4a3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8c7b6a5f4e3d2c1b0a9f8e",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software QA plan documented with version control, regression testing suite, and audit trail meeting MRL 5 requirements.",
      "rationale": "The CFD solver (OpenFOAM v8) is governed by a documented QA plan including version-controlled source, automated regression tests across 47 benchmark cases, and a full audit trail. Achieved level 4 satisfies the required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via manufactured solutions for all governing equations used in hemolysis simulation.",
      "rationale": "Method of manufactured solutions applied to incompressible Navier-Stokes and scalar transport equations. Observed convergence rates match theoretical order (2nd order spatial, 1st order temporal). Code verification complete at required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation applied to three systematically refined meshes; discretization error reported as percentage of QoI.",
      "rationale": "Three mesh levels (4.2M, 12.6M, 37.8M cells) used for Richardson extrapolation. Discretization error on hemolysis index estimated at 2.1%, well within the 5% acceptance threshold. GCI < 0.03 on all operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; flow rates, rotational speeds, and fluid properties traceable to calibrated instrumentation.",
      "rationale": "All five operating points replicated in bench testing with calibrated flow meters (±1.5%) and torque transducers (±0.8%). Blood analog fluid properties characterized at test temperature. Test conditions match simulation boundary conditions within stated uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric E) computed with experimental uncertainty accounted for; agreement within defined tolerance band.",
      "rationale": "Validation metric E computed across all 5 operating points. Mean absolute error on normalized index of hemolysis (NIH) is 18% versus 15% tolerance. Achieved level 3 falls one grade below required level 4; however, the shortfall was accepted by the credibility assessment team given conservative clinical margin available and supplementary sensitivity analysis confirming monotonic behavior."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs directly correspond to clinical decision QoIs (absolute NIH values); no surrogate quantities used.",
      "rationale": "The primary validation QoI is NIH in mg/100 mL/min, identical to the clinical decision metric. No surrogate or proxy quantities were substituted. Relevance confirmed at required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic pump geometry at clinically representative operating conditions.",
      "rationale": "Validation activities conducted on the identical FDA generic centrifugal pump geometry at the five COU operating points. Fluid (porcine blood analog) and temperature (37°C) match clinical conditions. Validation relevance assessed at level 3 as required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual norms below 1e-6 for all equations; round-off error assessed as negligible relative to discretization error.",
      "rationale": "All simulations converged to L2 residuals below 1e-7 for continuity, momentum, and scalar transport. Double-precision arithmetic used throughout. Numerical solver error confirmed negligible relative to 2.1% discretization error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition mapping and model parameter selection documented and verified.",
      "rationale": "Independent review of simulation setup completed by a second CFD analyst not involved in original model construction. Boundary condition mapping, turbulence model selection (SST k-omega), and hemolysis power-law coefficients verified against published sources. No use errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Qualitative and quantitative assessment of model form uncertainty including turbulence model selection and hemolysis constitutive law appropriateness for the COU flow regime.",
      "rationale": "Model form uncertainty was evaluated through a structured qualitative assessment by the credibility panel. The SST k-omega turbulence closure was selected based on its established performance in rotating machinery flows and benchmark comparisons from literature (Garon & Farinas 2004; Pauli et al. 2014). The power-law hemolysis model (Giersiepen et al. 1990 coefficients) was reviewed against three alternative constitutive forms; panel consensus confirmed the selected form is appropriate for the shear stress magnitudes encountered in this COU (1–400 Pa range). The qualitative assessment process documented in the credibility dossier (Section 4.3) provides sufficient evidence that model form uncertainty does not materially affect the acceptance decision, given the conservative clinical margin. No structured numerical gradation was assigned to this factor as the panel determined that the qualitative evidence base — comprising literature review, expert elicitation, and cross-model sensitivity analysis — constitutes a complete and defensible characterization of model form adequacy for MRL 5 Class III device submission purposes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with uncertainty distributions; Monte Carlo propagation performed to quantify input uncertainty contribution to QoI.",
      "rationale": "Monte Carlo analysis (N=2000 samples) performed over 12 uncertain input parameters including fluid viscosity, density, pump geometry tolerances, and hemolysis model coefficients. 95th percentile NIH prediction remains below clinical threshold of 0.8 mg/100 mL/min. Input uncertainty contribution characterized at required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize biological and measurement variability; statistical analysis of sample-to-sample variation documented.",
      "rationale": "Six replicate experiments performed at each of the five operating points using independently prepared blood analog batches. Coefficient of variation on NIH measurements ranged from 4.2% to 7.8% across operating points. Statistical characterization of test sample variability meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrably equivalent to experimental conditions within stated uncertainty; any deviations assessed for impact on QoI.",
      "rationale": "Simulation boundary conditions mapped directly from experimental measurements. Pump rotational speed matched to within 0.3%, inlet flow rate to within 1.5%, and fluid temperature to within 0.5°C. Sensitivity analysis confirmed QoI insensitivity to residual parameter deviations. Equivalency confirmed at required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all 13 credibility factors for COU2 (VAD hemolysis prediction, MRL 5, Class III). Twelve of thirteen factors achieved their required credibility levels. The Output Comparison factor achieved level 3 against a required level 4; however, the panel accepted this shortfall given the 18% mean absolute error on NIH remains within a conservative clinical margin and supplementary sensitivity analysis confirms monotonic model behavior across the operating envelope. The Model Form factor was evaluated through a comprehensive qualitative assessment process documented in the credibility dossier, with panel consensus supporting model adequacy. Monte Carlo uncertainty quantification confirms that 95th percentile hemolysis predictions remain below the absolute clinical threshold. On balance, the totality of evidence supports an Accepted decision for submission to the regulatory pathway.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
