  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all thirteen ASME V&V 40 factors. Ten of twelve fully-scored factors achieved their required level or were within one gradation of the requirement, with documented mitigation for each gap. The Model Form factor was assessed qualitatively; the panel determined that the published literature consensus and Monte Carlo UQ results together provide sufficient confidence in the hemolysis model form for this COU. On balance, the panel accepted the simulation credibility as sufficient to support the regulatory submission for the Class III VAD device.",
