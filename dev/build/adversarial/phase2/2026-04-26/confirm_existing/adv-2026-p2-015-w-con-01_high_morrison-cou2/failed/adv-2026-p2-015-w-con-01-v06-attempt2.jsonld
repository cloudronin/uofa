  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasWeakener": [],
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "Software used for CFD simulation must comply with a documented quality management system including version control, regression testing, and audit trail consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2023 R1) is governed by a documented QMS with ISO 9001 certification. Version control logs, regression test suites covering 142 benchmark cases, and full audit trails are available. SQA level meets the required Gradation 4 threshold for Class III device assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Order-of-accuracy tests on canonical flows must demonstrate convergence consistent with the discretization scheme's theoretical order. MRL 5 requires demonstration on rotating machinery flows.",
      "rationale": "Order-of-accuracy verification was performed on lid-driven cavity and Taylor-Couette flows, achieving second-order convergence. However, rotating impeller verification was limited to steady-state MRF; transient sliding-mesh verification was not completed, yielding an achieved level below the required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes. GCI on hemolysis index QoI must be below 5% at the operating points of interest.",
      "rationale": "Three meshes (4.2M, 11.6M, 28.4M cells) were generated with a refinement ratio of 1.44. GCI values on hemolysis index ranged from 1.8% to 4.3% across the five operating points, meeting the 5% threshold. Richardson extrapolation was applied and the asymptotic range was confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions used for validation must match VAD operating envelope (flow rates 3–6 L/min, speeds 2400–3600 RPM) with documented uncertainty in boundary conditions.",
      "rationale": "FDA benchmark experiments cover 3.5–5.5 L/min and 2500–3500 RPM, partially overlapping the full VAD envelope. Two corner operating points (3.0 L/min / 3600 RPM) lack experimental coverage. Boundary condition uncertainties are documented but interpolation is required for the missing conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metrics (normalized RMSE, validation uncertainty U_val) must be computed. U_val must be below 15% of the clinical hemolysis threshold.",
      "rationale": "Normalized RMSE on hemolysis index is 18.4% across the validated operating points. Validation uncertainty U_val is 12.8% of the clinical threshold. RMSE exceeds internal targets but U_val is within bounds; overall achieved level is 3 due to the RMSE shortfall."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoIs extracted from the CFD model (hemolysis index, shear stress exposure time) must be directly linked to the clinical endpoint and the regulatory submission metric.",
      "rationale": "Hemolysis index (HI) and area-weighted mean scalar shear stress (MWSS) are both extracted and mapped directly to the NIH normalized index of hemolysis (NIH) used in the regulatory submission. Traceability matrix linking model outputs to clinical endpoints is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation activities must be performed on geometry and operating conditions sufficiently similar to the COU device and operating envelope to support extrapolation claims.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which shares topological similarity with the target VAD impeller but differs in blade count (5 vs 7) and shroud clearance (0.3 mm vs 0.5 mm). These geometric differences introduce extrapolation uncertainty not fully bounded by the validation evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all transport equations. Time-step sensitivity must be documented for transient simulations.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum. Time-step sensitivity was assessed at 0.5°, 1°, and 2° of impeller rotation per step; hemolysis index variation was below 0.8% between 0.5° and 1° steps. The 1° time step was adopted for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Documented simulation protocols, peer review of setup files, and independent re-run of at least one operating point by a second analyst must be completed.",
      "rationale": "Simulation setup was reviewed by an independent CFD engineer against the documented protocol. One operating point (4.5 L/min, 3000 RPM) was independently re-run; hemolysis index agreement was within 1.2%. Use error controls are judged adequate for MRL 5 at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive hemolysis model and turbulence closure must be justified for the flow regimes present in the VAD operating envelope, with documented sensitivity to model form choices.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected based on its widespread use in FDA pump assessments and its calibration against RBC fragility data at physiological shear rates (10–1000 Pa). The k-omega SST turbulence closure was chosen for its established performance in adverse pressure gradient and rotating flows. A qualitative sensitivity study compared results against the Arora model and the k-epsilon realizable closure; hemolysis index predictions differed by 8–14% across model combinations, which the assessment team judged acceptable given the conservative safety margin applied to the clinical threshold. The model form selection is considered well-justified through this qualitative comparative analysis, and the team reached consensus that the chosen combination provides a credible upper-bound estimate of hemolysis. This factor was evaluated through structured expert elicitation and literature review rather than a formal gradation scoring exercise, as the available experimental data did not permit unambiguous discrimination between model form alternatives at the required resolution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Blood rheology parameters, inlet velocity profiles, and fluid-structure interaction assumptions must be characterized with documented uncertainty bounds propagated through Monte Carlo analysis.",
      "rationale": "Monte Carlo UQ was performed with 500 samples over blood viscosity (Carreau-Yasuda parameters), inlet flow waveform shape, and hematocrit (35–45%). The 95th percentile hemolysis index across samples remains below the clinical threshold. However, RBC mechanical properties (critical shear stress, exposure time constants) were treated as deterministic, representing an acknowledged gap in the input uncertainty characterization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental hemolysis measurements must use fresh human blood from at least 3 donors with documented hematocrit and storage time. Sample variability must be quantified.",
      "rationale": "FDA benchmark data used blood from 5 donors (hematocrit 38–42%, storage <24 h). Inter-donor variability was reported as ±12% on NIH. Sample handling protocols are documented in the FDA dataset metadata. The test sample quality meets the required level for MRL 5 validation support."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Inlet boundary conditions applied in CFD must be shown equivalent to those measured experimentally, including velocity profile shape, turbulence intensity, and pulsatility index.",
      "rationale": "Inlet velocity profiles were reconstructed from PIV measurements at the pump inlet plane. Turbulence intensity was matched to within 15% of measured values. Pulsatility index equivalency was confirmed for steady-state operating points; pulsatile VAD operating modes were not covered by the experimental dataset, limiting equivalency demonstration to the steady-flow regime."
    }
  ],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all thirteen factors and determined that the overall evidence package provides sufficient confidence to accept the CFD hemolysis predictions for the VAD COU. While several factors achieved levels below their required thresholds, the panel applied a holistic risk-weighted judgment: the shortfalls are concentrated in areas where conservative bounding assumptions were applied (model inputs, equivalency of input parameters), and the Monte Carlo UQ demonstrates that the 95th-percentile hemolysis prediction remains below the clinical acceptance threshold with adequate margin. The Model form factor was evaluated qualitatively by expert consensus and judged acceptable. The panel accepts the submission subject to post-market surveillance commitments.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
