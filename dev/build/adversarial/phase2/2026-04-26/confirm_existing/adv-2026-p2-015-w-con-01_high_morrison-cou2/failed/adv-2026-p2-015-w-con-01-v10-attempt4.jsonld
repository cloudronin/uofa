  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors, the assessment team concludes that the simulation package is Accepted for the stated COU. While several factors achieved levels below the nominal required levels, the team determined that the combination of Monte Carlo uncertainty quantification, independent expert review of model form adequacy, and conservative clinical threshold margin collectively provide sufficient confidence that the CFD hemolysis predictions are fit for regulatory decision-making. The Model form factor was evaluated through a rigorous qualitative expert assessment process that the team judged to be equivalent in rigour to a formal gradation assignment. Residual gaps in discretization error, test samples, and equivalency of input parameters are acknowledged and will be addressed in the next model iteration prior to final submission.",
