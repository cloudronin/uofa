    "https://uofa.net/synth/data/fda-generic-pump-piv-dataset",
    "https://uofa.net/synth/data/hemolysis-experimental-benchmarks",
    "https://uofa.net/synth/data/monte-carlo-uq-outputs"
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035672",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-modeling-group",
  "generatedAtTime": "2026-04-19T00:00:00Z",
