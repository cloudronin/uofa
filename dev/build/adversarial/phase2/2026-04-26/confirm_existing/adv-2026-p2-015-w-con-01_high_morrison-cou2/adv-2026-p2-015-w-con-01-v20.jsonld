  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors, the assessment team determined that the overall body of evidence is sufficient to accept the CFD hemolysis model for the stated COU. While several factors achieved levels one grade below their required levels, the team judged the aggregate risk to be acceptable given the Monte Carlo UQ envelope, the independent review of simulation setup, and the extensive qualitative assessment of model form adequacy documented in the factor narratives. The model is accepted for regulatory submission subject to the documented limitations.",
