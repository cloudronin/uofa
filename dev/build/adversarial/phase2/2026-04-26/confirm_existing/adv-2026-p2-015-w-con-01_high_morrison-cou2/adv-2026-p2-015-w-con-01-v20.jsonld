  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must comply with an ISO 9001-aligned QMS; version control, regression testing, and release documentation must be current for the solver version employed.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is developed under a documented quality management system with full regression test suite coverage. Version control records and release notes were reviewed and found compliant. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks must confirm solver convergence rates consistent with stated discretization order.",
      "rationale": "Order-of-accuracy studies on a Taylor-Couette benchmark confirmed second-order spatial convergence for velocity but only first-order for scalar hemolysis transport due to limiter activation in high-shear regions. Achieved level 3 falls one grade below the required level 4 for MRL-5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) must be reported for all five operating points; GCI on hemolysis index must be below 5% at the finest grid level.",
      "rationale": "Three-level Richardson extrapolation was performed at all five operating points. GCI values ranged from 3.1% to 8.7%; two operating points exceeded the 5% threshold on the hemolysis index scalar. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol) must be documented and replicated within stated tolerances in simulation boundary conditions.",
      "rationale": "All five bench test conditions were documented with fluid temperature ±0.5 °C, hematocrit 33 ± 1%, and citrate anticoagulation per ASTM F1841. Simulation boundary conditions were matched within tolerance. Required and achieved levels are both 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement (NIA) between predicted and measured hemolysis index must exceed 0.85 across all five operating points; systematic bias must be characterised.",
      "rationale": "NIA across five operating points ranged from 0.79 to 0.91 with a mean of 0.84, marginally below the 0.85 threshold. Systematic over-prediction of approximately 12% was identified at high-speed low-flow conditions. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalised index of haemolysis, NIH) must be directly traceable to the clinical threshold used in the regulatory submission.",
      "rationale": "NIH as defined in ASTM F1841 is the direct regulatory QoI cited in the 510(k) submission pathway for Class III VAD devices. Traceability matrix confirms one-to-one mapping. Required and achieved levels are both 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating range, and fluid analogue as the COU; any deviations must be quantified via similarity analysis.",
      "rationale": "Validation used the FDA generic pump geometry identical to the COU device. However, porcine blood was substituted for human blood in three of five test points; a similarity correction factor of 1.08 was applied. This deviation reduces the relevance score to achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all transport equations; mass imbalance must be below 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum; scalar hemolysis transport residuals reached 8e-6. Mass imbalance was below 0.005% across all five operating points. Required and achieved levels are both 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence of independent review of simulation setup, boundary condition assignment, and post-processing scripts must be documented.",
      "rationale": "An independent engineer reviewed the mesh setup, boundary condition files, and post-processing pipeline. Two minor errors in inlet velocity profile specification were identified and corrected prior to final runs. Documentation of the review and corrections is archived. Required and achieved levels are both 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive hemolysis model (power-law damage accumulation) must be justified against alternative formulations and its domain of applicability confirmed to encompass the COU operating envelope.",
      "rationale": "The review team conducted an extensive qualitative assessment of model form adequacy for the power-law hemolysis damage accumulation model (Giersiepen-Wurzinger correlation). Literature evidence from seven independent CFD hemolysis studies was synthesised, covering shear-stress ranges from 50 to 800 Pa and exposure times of 0.1 ms to 2 s — fully encompassing the VAD operating envelope. The correlation's exponents (α = 3.62×10⁻⁷, β = 2.416, γ = 0.785) were validated against erythrocyte lysis data from Leverett et al. and confirmed applicable within the COU shear-stress regime. Alternative formulations (Grigioni strain-based model, Faghih-Sharp mechanistic model) were considered but judged to introduce additional parametric uncertainty without demonstrated improvement in predictive accuracy for rotary pumps at MRL-5. The team concluded that the power-law model form is appropriate and adequate for this COU based on the weight of qualitative evidence assembled. Structured credibility level integers were not recorded in this assessment cycle as the team relied on the narrative summary to convey sufficiency."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis must identify the top three model input parameters driving hemolysis prediction uncertainty; their distributions must be characterised and propagated via Monte Carlo.",
      "rationale": "Monte Carlo UQ (n=2000 samples) identified viscosity, inlet turbulence intensity, and hemolysis exponent β as the top three uncertainty drivers. Viscosity and turbulence intensity were characterised with normal distributions from experimental data; β was assigned a uniform distribution ±10% per literature range. Total hemolysis prediction uncertainty was ±18% at 95% confidence. Achieved level 3 versus required level 4 due to incomplete characterisation of the β distribution tails."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least three independent blood samples per operating point must be used in experimental validation; sample provenance and storage conditions must be documented.",
      "rationale": "Four independent blood donations were used per operating point; all samples were processed within 6 hours of collection and stored at 4 °C per ASTM F1841 protocol. Donor demographics and anticoagulant records are archived. Required and achieved levels are both 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensional analysis must confirm that all non-dimensional governing parameters (Reynolds number, Womersley number, haematocrit) match between validation experiments and COU operating conditions within 5%.",
      "rationale": "Reynolds numbers matched within 2.1% across all five operating points. Womersley number equivalence was confirmed for pulsatile boundary conditions. However, hematocrit in three porcine-blood test points deviated by 6.3% from COU target after the similarity correction, exceeding the 5% threshold. Achieved level 3 versus required level 4."
    }
  ],
