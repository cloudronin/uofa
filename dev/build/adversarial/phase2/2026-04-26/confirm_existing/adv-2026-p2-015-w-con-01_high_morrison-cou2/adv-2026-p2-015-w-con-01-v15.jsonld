  "signature": "ed25519:b1d4e7a2f3c8b5e9d2a6f0c4b8e3a7d1f5c2b9e6a3d0f7c4b1e8a5d2f9c6b3e0",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated under an FDA-recognized quality management system with full version control and audit trail at Gradation 4.",
      "rationale": "ANSYS Fluent 2022R2 is operated under an ISO 13485-compliant QMS with documented version control, change management, and regression test suite. All simulation runs are traceable to specific software builds. Required level 4 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass manufactured-solution verification tests for the Navier-Stokes equations relevant to blood pump flow regimes at Gradation 3.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes formulation. Observed order of accuracy 1.97 (expected 2nd order). Three benchmark cases from the FDA Critical Path Initiative passed. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 3% for hemolysis index QoI across all five operating points at Gradation 4.",
      "rationale": "Three-level mesh refinement study performed (7M, 14M, 28M cells). Richardson extrapolation yields GCI < 2.1% for hemolysis index at all five operating points. Asymptotic range confirmed (GCI_fine/r^p * GCI_coarse < 1.05). Required level 4 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate physiological blood analog properties and pump operating envelope to within stated tolerances at Gradation 3.",
      "rationale": "FDA pump experiments conducted with porcine blood at 37°C, hematocrit 33±2%, viscosity 3.2±0.3 mPa·s. Flow rates and rotational speeds match five CFD operating points within ±1.5%. Temperature controlled to ±0.5°C. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined experimental and simulation uncertainty bounds at Gradation 4.",
      "rationale": "CFD hemolysis index predictions fall within 18% of experimental values at 4 of 5 operating points. At the highest flow rate (8 L/min, 3600 RPM) the discrepancy is 24%, marginally outside the Gradation 4 tolerance band. Achieved level 3 reflects this shortfall; the assessment team accepted this gap given the conservative direction of the over-prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress distribution) must directly correspond to the clinical decision QoIs at Gradation 4.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) expressed in mg/100L, which is identical to the regulatory submission metric. Secondary QoIs (volume-averaged scalar shear stress, exposure time distributions) are direct inputs to the hemolysis power-law model. Full traceability from simulation output to clinical threshold established. Required level 4 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be performed on the same pump geometry and within the same operating envelope as the COU at Gradation 4.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry — the identical geometry to the COU. Operating envelope for validation (2–8 L/min, 2500–3600 RPM) fully encompasses the five COU operating points. No geometric surrogates or scaled models used. Required level 4 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all transport equations and mass imbalance below 0.01% at Gradation 3.",
      "rationale": "All simulations converged to residuals below 5e-6 for continuity, momentum, and scalar transport. Global mass imbalance < 0.005%. Convergence monitored over last 500 iterations with no drift. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "All simulation setup decisions, boundary condition assignments, and post-processing steps must be independently reviewed and documented.",
      "rationale": "A comprehensive qualitative assessment of use error was performed by the credibility assessment team. All simulation setup decisions — including boundary condition type selection, turbulence model configuration (SST k-ω with curvature correction), rotating reference frame assignment, and hemolysis scalar transport source term implementation — were subjected to a structured peer review by a senior CFD engineer independent of the original analyst. Discrepancies in boundary condition interpretation identified during the review were resolved and documented in the simulation log. Post-processing scripts were independently re-executed by a second analyst and results cross-checked against the primary analyst outputs, with all differences below numerical precision. The team concluded that use error sources have been identified and mitigated to a degree commensurate with the overall credibility evidence, and that no unmitigated use error pathways remain that would materially affect the hemolysis index prediction. This qualitative review provides sufficient confidence that use error does not undermine the accepted outcome."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model form and turbulence closure must be justified for the flow regimes present in the VAD at Gradation 4.",
      "rationale": "Giersiepen-Wurzinger power-law hemolysis model selected based on literature survey of 12 comparative studies. SST k-ω turbulence model validated for confined rotating flows. Model form uncertainty estimated at ±22% via ensemble of three hemolysis model variants. Achieved level 3 due to unresolved model form uncertainty above Gradation 4 threshold; accepted by team given conservative over-prediction bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood rheological properties and pump geometry inputs must be characterized with uncertainty bounds and sensitivity analysis performed at Gradation 3.",
      "rationale": "Monte Carlo uncertainty quantification performed over 500 samples of blood viscosity, density, and power-law hemolysis coefficients. Sobol sensitivity indices computed; hemolysis coefficient C dominates (S1=0.61). Input uncertainty propagated to output uncertainty bounds reported at 95% confidence. Required level 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A minimum of three independent experimental replicates must be available for each operating point to characterize experimental variability at Gradation 3.",
      "rationale": "FDA pump experimental dataset provides n=5 independent runs per operating point. Coefficient of variation in NIH across replicates ranges from 4.2% to 9.8%. Outlier analysis performed; no replicates excluded. Statistical uncertainty in experimental mean propagated into validation comparison. Required level 3 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD model input parameters must be traceable to the experimental conditions used for validation, with documented mapping at Gradation 3.",
      "rationale": "Complete parameter mapping table produced linking each CFD boundary condition and material property to the corresponding experimental measurement or specification. Rotational speed set from tachometer readings (±5 RPM), flow rate from calibrated Coriolis meter (±0.05 L/min), inlet pressure from transducer calibrated to NIST traceable standard. All mappings reviewed and signed off. Required level 3 met."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for the VAD hemolysis CFD model. Twelve factors were assessed with explicit required and achieved levels; of these, 10 met or exceeded required levels and 2 (Output comparison, Model form) achieved one gradation below required, both in a conservative direction. The Use error factor was addressed through a thorough qualitative peer review process that provided the team with sufficient confidence that no unmitigated use error pathways affect the hemolysis prediction. Considering the totality of quantitative factor evidence, the conservative bias of the two below-requirement factors, and the comprehensive qualitative review of use error, the team concludes that the model is credible for predicting absolute hemolysis levels in the VAD COU. The package is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
