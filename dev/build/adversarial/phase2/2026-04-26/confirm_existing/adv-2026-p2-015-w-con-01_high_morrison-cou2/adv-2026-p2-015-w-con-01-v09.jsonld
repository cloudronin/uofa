  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control, regression testing suite, and documented build environment must meet MRL 5 SQA requirements.",
      "rationale": "ANSYS Fluent 2022R2 deployed under ISO 9001-certified SQA framework. Full regression test suite executed; all 312 test cases passed. Version control via Git with signed commits. Achieved level 4 meets required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark comparison must confirm second-order spatial accuracy for velocity and scalar transport.",
      "rationale": "Method of manufactured solutions confirmed second-order convergence for both momentum and scalar hemolysis transport equations. L2 error norms decrease at 1.98 order with refinement. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization uncertainty on hemolysis index QoI must be below 5% at operating points.",
      "rationale": "Three-level mesh refinement study performed (6.2M, 14.7M, 31.4M cells). GCI on normalized index of hemolysis ranged 1.1%–2.8% across five operating points. Richardson extrapolation confirms asymptotic convergence. Achieved level 4 meets required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with uncertainty and reproduced in simulation setup within stated tolerances.",
      "rationale": "FDA generic pump experimental conditions documented per ASTM F1841. Flow rates controlled to ±0.05 L/min; rotational speed to ±5 RPM. Simulation inlet/outlet BCs set to match experimental means; sensitivity to BC uncertainty quantified via Monte Carlo sampling. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E% or validation uncertainty) must demonstrate agreement within defined acceptance band for hemolysis QoI.",
      "rationale": "Normalized index of hemolysis predictions compared against five experimental mean values. Mean absolute percentage error 8.3%; all predictions within combined simulation and experimental uncertainty bands. Validation uncertainty Uval < 15% at all operating points. Achieved level 4 meets required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly mappable to the clinical decision metric (absolute hemolysis index threshold).",
      "rationale": "Normalized index of hemolysis (NIH) computed directly from simulation shear stress history; directly maps to clinical hemolysis acceptance criterion. No surrogate QoI substitution employed. Achieved level 4 meets required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the VAD operating envelope (flow rates 3–6 L/min, speeds 2400–3600 RPM) and use the same pump geometry.",
      "rationale": "Validation performed on FDA generic centrifugal pump — identical geometry to COU device. Operating points span 3–5 L/min at 2400–3200 RPM; upper envelope (5–6 L/min, 3200–3600 RPM) not covered experimentally. Gap acknowledged; extrapolation uncertainty propagated through Monte Carlo. Achieved level 3 is one below required level 4; team judged residual gap acceptable given uncertainty quantification coverage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to five orders of magnitude residual reduction; round-off error must be negligible relative to discretization error.",
      "rationale": "All simulations converged to 1×10⁻⁶ normalized residuals for continuity, momentum, and scalar transport. Double-precision arithmetic employed throughout; round-off error estimated at 1×10⁻¹² — negligible relative to GCI. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "All simulation setup decisions must be traceable to documented analyst procedures and independently reviewed by a second qualified engineer.",
      "rationale": "A comprehensive qualitative assessment of use-error risk was conducted by the lead analyst and independently reviewed by a senior CFD engineer with 15 years of cardiovascular device experience. Simulation setup checklist (47 items) completed and signed off. Turbulence model selection, boundary condition assignment, and post-processing scripts were each reviewed against the simulation plan. No discrepancies were identified during the independent review. The team concluded that the procedural controls in place — including the two-person review protocol and the documented simulation plan — provide adequate assurance that use errors have been identified and mitigated, consistent with the qualitative expectations for this factor at the applicable model risk level. This holistic review was deemed sufficient to support an accepted outcome without reduction to a single numerical gradation, as the factor evidence collectively demonstrates robust analyst qualification and procedural discipline."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence and hemolysis constitutive model selection must be justified by comparison to higher-fidelity reference data or literature benchmarks.",
      "rationale": "SST k-ω turbulence model selected based on published benchmark comparisons for confined rotating flows. Power-law hemolysis model (Giersiepen-Wurzinger) calibrated against in-vitro data. Model form uncertainty estimated via comparison of three hemolysis model variants; spread <12% across operating points. Achieved level 3 is one below required level 4; gap accepted given UQ coverage and clinical margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood rheological properties and hemolysis model coefficients must be sourced from peer-reviewed literature with documented uncertainty ranges.",
      "rationale": "Blood density 1060 kg/m³, dynamic viscosity 0.0035 Pa·s sourced from Merrill et al. (1965) and confirmed against three additional literature sources. Hemolysis model coefficients drawn from Giersiepen et al. (1990) with ±20% uncertainty bounds propagated through Monte Carlo. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must use standardized blood preparation protocol with documented sample size and inter-sample variability.",
      "rationale": "FDA generic pump experimental data generated using bovine blood per ASTM F1841 protocol. n=5 replicates per operating point; coefficient of variation <8% across all conditions. Sample preparation and measurement procedures fully documented. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to experimental conditions used for validation, with any differences quantified and propagated.",
      "rationale": "Inlet velocity profiles derived from experimental PIV measurements at pump inlet plane. Rotational speed, fluid properties, and geometric dimensions matched to experimental configuration within measurement uncertainty. Differences in inlet turbulence intensity (experimental: unknown; simulation: 5% assumed) quantified via sensitivity study showing <2% effect on NIH. Achieved level 3 meets required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Twelve factors were assessed with explicit required and achieved levels; two factors (Relevance of validation activities to COU and Model form) achieved one level below required, but in both cases the gaps are bounded by Monte Carlo uncertainty quantification and clinical margin analysis. The Use Error factor was evaluated through a rigorous qualitative assessment process with independent two-person review and a 47-item setup checklist, providing high confidence in procedural controls. Taken in aggregate, the evidence base supports acceptance of the CFD hemolysis model for the stated VAD context of use. Hemolysis predictions at all five operating points remain below the absolute clinical threshold with margin exceeding combined simulation and experimental uncertainty.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
