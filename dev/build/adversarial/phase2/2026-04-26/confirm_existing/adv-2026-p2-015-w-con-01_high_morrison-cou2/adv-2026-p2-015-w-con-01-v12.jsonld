      "name": "In-vitro hemolysis index validation against bench measurements"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-convergence",
      "type": "ValidationResult",
      "name": "Three-level mesh convergence study on shear stress and flow rate"
    }
  ],
