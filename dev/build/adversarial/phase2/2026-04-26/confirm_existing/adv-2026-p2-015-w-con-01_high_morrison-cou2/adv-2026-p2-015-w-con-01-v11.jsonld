  "signature": "ed25519:b7e3a1f92c048d6b5e2f8a3c7d1904b6e5f2a8c3d7b1e0f94c2a6d8b3e5f1a2c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 4 for MRL 5 Class III device.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is deployed under a validated software quality management system compliant with 21 CFR Part 11. Version-controlled configuration files, regression test suite results, and installation qualification records were reviewed. Achieved level 4 meets the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 4 for MRL 5.",
      "rationale": "Manufactured solution verification tests were executed for the hemolysis transport equation and the Navier-Stokes solver. Observed convergence rates matched theoretical expectations (second-order spatial, first-order temporal). All benchmark cases from the ASME V&V 20 suite relevant to internal rotating flows were reproduced within tolerance. Achieved level 4 is confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% on hemolysis index QoI; achieved level must equal required level 4.",
      "rationale": "Three systematically refined meshes (4.2 M, 12.6 M, 37.8 M cells) were generated with a refinement ratio of 1.44. Richardson extrapolation and GCI analysis yielded GCI values of 3.1%–4.8% on the global hemolysis index across all five operating points. Near-wall y+ values were maintained below 1.0 on all wetted surfaces. Achieved level 4 is justified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope; achieved level must meet required level 3.",
      "rationale": "Bench experiments used bovine blood at 37 °C with hematocrit 35±2%, matching the physiological range specified in the COU. Flow rates and rotational speeds bracketed the five COU operating points. Pressure boundary conditions were set using calibrated transducers with NIST-traceable calibration certificates. Achieved level 3 is confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement on hemolysis index must exceed 0.90; achieved level must equal required level 4.",
      "rationale": "Predicted hemolysis index values were compared to experimental measurements at all five operating points. Mean absolute percentage error was 6.2%; the normalized index of agreement was 0.94. Bland-Altman analysis showed no systematic bias. Achieved level 4 is supported by the quantitative comparison metrics."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the decision-critical outputs in the COU; achieved level must meet required level 4.",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) expressed in mg/100 L — is identical in the validation experiments and the COU predictions. Secondary QoIs (shear stress distribution, residence time) were also validated against PIV and particle-tracking data. The mapping between validation QoIs and COU decision QoIs is direct and complete. Achieved level 4 is justified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the COU geometry, flow regime, and blood rheology; achieved level must meet required level 4.",
      "rationale": "Validation was conducted on the FDA generic centrifugal pump geometry, which is the same geometry used in the COU. However, all validation experiments used bovine blood; the COU involves human blood in clinical use. A rheological equivalence analysis was performed and documented, but residual uncertainty in the power-law viscosity coefficients introduces a minor gap. Achieved level 3 falls one gradation below the required level of 4; this gap was noted but accepted by the assessment team based on the overall package strength."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence residuals must reach machine-precision floor or demonstrate stable QoI convergence; achieved level must meet required level 3.",
      "rationale": "All simulations were run to normalized residuals below 1×10⁻⁶ for continuity and momentum equations. QoI monitors (hemolysis index, torque) were tracked over the final 500 iterations and showed variation below 0.1%. Double-precision arithmetic was used throughout. Achieved level 3 is confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "acceptanceCriteria": "All analyst actions, boundary condition assignments, and post-processing scripts must be independently reviewed and verified prior to submission.",
      "rationale": "A comprehensive qualitative assessment of use error risk was conducted by the credibility assessment team. The simulation workflow — encompassing geometry import, mesh generation, boundary condition assignment, solver configuration, and hemolysis post-processing — was reviewed by a senior analyst independent of the original modeler. All setup files were version-controlled and the reviewer confirmed that boundary conditions matched the COU specification document. Post-processing scripts were inspected for unit conversion errors and indexing mistakes; no discrepancies were identified. Standard operating procedures for CFD analysis of blood-contacting devices were followed throughout. The team concluded that use error risk is well-controlled given the procedural safeguards in place, and this factor was considered fully addressed through the qualitative review process. No formal gradation scoring was applied to this factor as the qualitative evidence was judged sufficient by the assessment team to support the overall Accepted outcome."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model for hemolysis must be validated against independent datasets; achieved level must meet required level 4.",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger correlation) was selected after a documented model form uncertainty analysis comparing four candidate hemolysis models. Sensitivity of predicted NIH to model form choice was quantified via a one-at-a-time analysis. The selected model showed the lowest normalized root-mean-square error on the FDA benchmark dataset. Achieved level 4 is supported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters must be characterized and propagated; achieved level must meet required level 4.",
      "rationale": "Monte Carlo uncertainty quantification was performed with 500 samples drawn from distributions defined for seven uncertain input parameters (blood viscosity coefficients, hemolysis model exponents, inlet velocity profile shape, wall roughness). The 95th-percentile hemolysis index prediction remained below the clinical threshold across all five operating points. Achieved level 4 is confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient experimental replicates must be available to characterize measurement uncertainty; achieved level must meet required level 3.",
      "rationale": "Three independent experimental runs were performed at each of the five operating points using fresh bovine blood samples from different donors. Intra-run and inter-run variability in NIH measurements were quantified. Expanded measurement uncertainty (k=2) was reported for all data points used in validation comparisons. Achieved level 3 is confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the validation simulations must be demonstrably equivalent to those in the COU simulations; achieved level must meet required level 3.",
      "rationale": "A parameter equivalency table was prepared mapping each simulation input (geometry dimensions, rotational speed, flow rate, fluid properties) between the validation and COU configurations. All geometric dimensions were confirmed identical. Fluid property values used in validation simulations were drawn from the same characterization measurements as the COU simulations. Achieved level 3 is confirmed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Twelve factors achieved their required gradation levels. The Relevance of Validation Activities factor achieved level 3 against a required level of 4; this one-gradation gap was accepted given the documented rheological equivalence analysis and the overall strength of the evidence package. The Use Error factor was addressed through a comprehensive qualitative review that the team judged sufficient to support acceptance. Monte Carlo uncertainty quantification demonstrated that the 95th-percentile hemolysis index prediction remains below the absolute clinical threshold across all five COU operating points. The overall evidence package is accepted as sufficient to support the intended use of the CFD model for Class III VAD hemolysis prediction.",
