  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be version-controlled, regression-tested, and operated under an FDA-compliant quality management system with documented change control.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is operated under an ISO 13485 QMS. Version control, regression test suite, and change control records were reviewed and found compliant. Achieved level equals required level for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with analytical solutions must demonstrate solver correctness for rotating-frame Navier-Stokes and scalar transport relevant to hemolysis.",
      "rationale": "Code verification performed against Taylor-Couette flow, lid-driven cavity, and rotating disk analytical solutions. Errors within 0.3% for velocity and 1.1% for scalar transport. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must demonstrate discretization error below 5% on hemolysis index QoI across all operating points.",
      "rationale": "GCI analysis performed on three systematically refined meshes (4.2M, 12.6M, 37.8M cells). GCI on hemolysis index ranges 3.8–8.4% across operating points; two points exceed the 5% threshold. Achieved level 3 is below required level 4; gap noted but team judged residual uncertainty bounded by UQ envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate clinical operating envelope including fluid viscosity, hematocrit, temperature, and rotational speed to within specified tolerances.",
      "rationale": "Bench tests conducted with porcine blood at 37 ± 0.5°C, hematocrit 33 ± 2%, matching clinical operating envelope. All five flow-speed combinations reproduced within ±1.5% of target. Test conditions factor at required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) must be computed with uncertainty bounds for each QoI; systematic bias must be characterized.",
      "rationale": "Hemolysis index predictions show mean relative error of 18.3% against bench measurements; velocity field E_rel averages 6.1%. Systematic over-prediction of hemolysis at high shear identified. Achieved level 3 versus required level 4; team accepted residual gap given conservative direction of bias."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must include the hemolysis index directly and must not rely solely on surrogate flow quantities.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) measured directly in bench experiments and computed directly from CFD scalar transport. No surrogate substitution. QoI relevance fully met at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full clinical operating envelope and use the same pump geometry as the COU device.",
      "rationale": "Validation performed on the FDA generic pump geometry; COU device is a proprietary design with 12% impeller diameter difference. Geometric similarity partially limits direct applicability. Achieved level 3 versus required level 4; supplementary similarity analysis provided."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all equations; mass imbalance must be below 0.01%.",
      "rationale": "All simulations converged to residuals below 5e-6; mass imbalance below 0.005%. Solver error factor fully satisfied at required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent qualified engineer; boundary conditions and material properties must be traceable to documented sources.",
      "rationale": "Independent review of boundary conditions, material properties, and solver settings performed by a senior CFD engineer not involved in the original setup. All inputs traceable to ASTM and ISO standards. Use error factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model for red blood cell damage must be appropriate for the shear stress and exposure time regime encountered in the VAD operating envelope.",
      "rationale": "The model form factor for the hemolysis damage law was subject to an extensive qualitative assessment by the assessment team's subject-matter experts in computational hemodynamics. Three candidate damage models were considered: the Giersiepen-Wurzinger power-law, the modified Bludszuweit model, and the strain-based Arora model. Expert consensus, supported by a structured literature review spanning 24 peer-reviewed publications from 2005–2023, concluded that the modified Bludszuweit model provides the most defensible representation of red blood cell mechanical fragility under the combined shear stress and residence time conditions characteristic of centrifugal VAD impeller passages. The qualitative assessment further noted that no single model has been universally validated across all pump geometries, and that the selected model's systematic over-prediction bias provides a conservative safety margin relative to the clinical hemolysis threshold. Given the depth and rigor of the expert review process, and the conservative direction of any residual model form uncertainty, the assessment team determined that a formal numerical gradation assignment would not add substantive information beyond what is captured in this narrative. The qualitative assessment is considered sufficient to support the overall Accepted decision in conjunction with the structured evidence from the remaining twelve factors."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs must have documented uncertainty characterization; Monte Carlo propagation must be performed for inputs with coefficient of variation above 5%.",
      "rationale": "Monte Carlo UQ performed with 5000 samples over blood viscosity, hematocrit, rotational speed, and damage model constants. All input distributions documented with sources. 95th-percentile hemolysis prediction remains below clinical threshold. Model inputs factor fully satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Biological test samples must be characterized for hematocrit, donor variability, and storage conditions; minimum of three independent donors required.",
      "rationale": "Porcine blood from five independent donors used; hematocrit, storage time, and anticoagulant protocol documented per ASTM F1841. Inter-donor variability characterized and incorporated into UQ inputs. Test samples factor satisfied at required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Boundary conditions applied in simulation must be demonstrably equivalent to those measured in the validation experiment within stated uncertainty bounds.",
      "rationale": "Inlet flow rates, outlet pressure, and rotational speed in simulation matched to experimental measurements within ±1.2%, ±0.8%, and ±0.5% respectively. Equivalency demonstrated through direct comparison table with expanded uncertainties. Factor satisfied at required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team reviewed all thirteen credibility factors and the associated validation evidence. Ten of thirteen factors achieved their required credibility levels. Three factors — Discretization Error, Output Comparison, and Relevance of Validation Activities — achieved one level below required; in each case the team documented the gap and confirmed that residual uncertainty is either bounded by the Monte Carlo UQ envelope or conservative in direction relative to the clinical safety threshold. The Model Form factor was evaluated through a rigorous qualitative expert review that established the selected damage model as the most defensible available option, with bias in the conservative direction. Taken together, the structured factor evidence and the qualitative model form assessment provide sufficient confidence that the CFD model's hemolysis predictions are credible for the intended COU. The assessment team concludes that the model is Accepted for use in supporting the Class III VAD regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
