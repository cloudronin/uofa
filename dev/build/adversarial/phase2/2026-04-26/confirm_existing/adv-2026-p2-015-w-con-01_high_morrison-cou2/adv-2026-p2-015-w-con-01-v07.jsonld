  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Accepted)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. All 13 credibility factors are addressed; the assessment team concluded that the aggregate evidence is sufficient to support an Accepted decision. Monte Carlo uncertainty quantification was performed across all five flow-speed operating points and hemolysis index values were demonstrated to remain below the absolute clinical threshold.",
  "bindsRequirement": "https://uofa.net/synth/req/cou2-vad-hemolysis-req",
  "bindsClaim": "https://uofa.net/synth/claim/cou2-vad-hemolysis-claim",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/fda-pump-cfd-montecarlo-outputs"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-bench-comparison",
