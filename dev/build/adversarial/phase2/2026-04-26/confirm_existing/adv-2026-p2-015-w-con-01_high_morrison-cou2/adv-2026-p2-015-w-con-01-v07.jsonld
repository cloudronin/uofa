  "signature": "ed25519:b7e3a1c509f2d84e6b3012cf4a7d9e51b2f8c3a06d4e17b9c2f5a08d3e6b1c94",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan in place with version control, issue tracking, and regression test suite covering hemolysis solver modules.",
      "rationale": "The CFD solver is managed under a documented software quality plan. Version control is enforced via Git with tagged releases; a regression test suite of 47 hemolysis-relevant cases is executed on each release. All defects identified during validation were logged and resolved prior to this submission. Achieved level equals required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent demonstrates correct order-of-accuracy for all governing equations used in the hemolysis simulation.",
      "rationale": "Method of manufactured solutions was applied to the Navier-Stokes and power-law hemolysis transport equations. Observed order of accuracy (1.97 for velocity, 1.89 for scalar hemolysis transport) is consistent with the nominal second-order scheme. No anomalous convergence behavior detected across five grid refinement levels."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI demonstrates discretization error below 5% on hemolysis index QoI for the production mesh.",
      "rationale": "Three-level mesh refinement study performed on the FDA generic centrifugal pump geometry. Grid convergence index (GCI) on the normalized index of hemolysis was 2.1% on the medium mesh and 0.8% on the fine mesh. The fine mesh (18.4 M cells) was selected for production runs. Discretization error is well within the 5% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate) are documented and match the CFD boundary conditions within stated tolerances.",
      "rationale": "The FDA pump experimental campaign used bovine blood with documented hematocrit (35±2%), temperature (37±0.5°C), and rotational speeds of 2500 and 3500 RPM. CFD boundary conditions were set to match measured values. Uncertainty in inlet flow rate (±2%) was propagated through the Monte Carlo ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) demonstrates model agreement with experimental hemolysis data within acceptance band.",
      "rationale": "Predicted normalized index of hemolysis (nIH) was compared against five experimental operating points. Mean absolute error was 18.4% with one outlier point at 31% error at the high-speed low-flow condition. Achieved level 3 falls one gradation below the required level 4 for this COU; however, the assessment team judged the overall evidence package sufficient given the conservative Monte Carlo bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (nIH) is directly mappable to the clinical decision QoI (absolute hemolysis index) with documented conversion and uncertainty.",
      "rationale": "The normalized index of hemolysis used in validation experiments is directly converted to the absolute hemolysis index using the documented power-law relationship (Giersiepen et al.). The conversion uncertainty was quantified and included in the Monte Carlo propagation. The QoI used in validation is the same scalar quantity required for the regulatory submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments were conducted on the same pump geometry and cover the full operating envelope specified in the COU.",
      "rationale": "Validation experiments were performed on the FDA generic centrifugal pump — the identical geometry used in the submission. All five COU operating points (combinations of 2500/3500 RPM and 3/5/7 L/min) are represented in the validation dataset. No extrapolation beyond the validated operating envelope is required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual norms below 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "All simulations were converged to residual norms of 1e-6 for continuity and momentum equations and 5e-7 for the hemolysis scalar transport equation. Global mass imbalance was below 0.003% in all production runs. No non-convergent cases were observed across the Monte Carlo ensemble of 200 samples."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of boundary condition setup, material property assignment, and post-processing scripts.",
      "rationale": "The simulation workflow was executed by a senior CFD engineer and independently reviewed by a second engineer not involved in the setup. Boundary condition files, material property tables, and post-processing scripts are archived in the project repository. No use errors were identified during the independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected turbulence and hemolysis constitutive models are justified for the flow regime and shear stress range encountered in the VAD operating envelope.",
      "rationale": "The SST k-omega turbulence model was selected based on published benchmark performance for rotating machinery flows. The Giersiepen power-law hemolysis model was selected as the regulatory standard for blood pump submissions. Model form uncertainty was assessed by comparison with the Zhang model at two operating points; differences were within 12% and were included in the uncertainty budget. Achieved level 3 reflects remaining model-form uncertainty at the high-shear impeller tip region."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (blood viscosity, Giersiepen model constants, inlet velocity profile) are characterized with probability distributions and propagated through Monte Carlo uncertainty quantification.",
      "rationale": "A qualitative assessment of model input uncertainty was conducted by the credibility team. The seven principal uncertain inputs — dynamic viscosity at operating temperature, hematocrit variability, the three Giersiepen power-law constants (C, alpha, beta), inlet velocity profile shape parameter, and pump rotational speed tolerance — were reviewed against published literature distributions. Subject matter experts confirmed that the distributions used in the Monte Carlo ensemble are representative of the physiological and manufacturing variability expected in clinical use. The team concluded, on the basis of this expert elicitation and literature review, that the input characterization is adequate for the COU without requiring a formal sensitivity ranking, because the Monte Carlo 95th-percentile hemolysis prediction remains 22% below the absolute clinical threshold even under conservative input assumptions. This qualitative assessment is considered sufficient evidence that model input uncertainty does not undermine the Accepted decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient number of experimental replicates to characterize inter-sample variability in hemolysis measurements; minimum three independent replicates per operating point.",
      "rationale": "The FDA pump experimental dataset includes five independent replicates per operating point for a total of 25 measurements across the COU envelope. Inter-sample coefficient of variation ranged from 4.1% to 9.7%, consistent with published blood trauma measurement variability. Sample size is sufficient to characterize aleatory variability in experimental hemolysis data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiment input parameters (hematocrit, fluid temperature, pump geometry) are equivalent to or conservative relative to COU input parameters.",
      "rationale": "Validation experiments used bovine blood at 35% hematocrit; the COU specifies human blood at 30–45% hematocrit. Sensitivity analysis demonstrated that hemolysis index increases monotonically with hematocrit over this range, making the 35% validation condition representative of the mid-range COU scenario. Pump geometry is identical (FDA generic centrifugal pump). Temperature equivalency was confirmed within ±1°C."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors. Ten factors achieved their required levels; three factors (Output comparison, Model form, Model inputs) achieved one gradation below the required level. For Output comparison and Model form, the shortfalls were judged acceptable given the conservative Monte Carlo uncertainty bounds, which demonstrate that the 95th-percentile hemolysis prediction remains 22% below the absolute clinical threshold. For Model inputs, the team conducted a qualitative expert elicitation confirming that the input distributions used in the Monte Carlo ensemble are representative of clinical variability. The aggregate evidence is judged sufficient to support an Accepted decision for this COU at Model Risk Level 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
