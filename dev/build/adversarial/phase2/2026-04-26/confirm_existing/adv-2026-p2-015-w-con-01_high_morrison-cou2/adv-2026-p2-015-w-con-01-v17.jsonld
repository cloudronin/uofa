  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 4 for MRL 5 device class.",
      "rationale": "The CFD solver is governed under ISO 9001-certified quality management. Version control, regression test suite (>1200 test cases), and documented release procedures are in place. SQA documentation package reviewed and found complete for MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 4.",
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes solver confirming second-order spatial accuracy. Benchmark suite results published in peer-reviewed literature and independently reproduced. Code verification evidence deemed sufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 2% on hemolysis index QoI across all operating points.",
      "rationale": "Three-level mesh refinement study performed per Roache GCI methodology. Finest mesh (22M cells) yields GCI of 1.4% on the normalized hemolysis index. Richardson extrapolation confirms asymptotic convergence. Achieved level 4 satisfies the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated within ±5% of target flow-speed operating points.",
      "rationale": "Five operating points (3 L/min at 2400 RPM through 6 L/min at 3200 RPM) reproduced in the FDA flow loop. Inlet velocity profiles measured by PIV and imposed as CFD boundary conditions. Temperature and fluid viscosity controlled to within stated tolerances. Test conditions adequately represent the COU envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement ≥ 0.85 across all five operating points.",
      "rationale": "Predicted hemolysis index compared against FDA benchmark experimental data. Normalized index of agreement computed as 0.91 across the five operating points. Systematic over-prediction at the highest RPM condition is within the Monte Carlo 95% confidence interval. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to the clinical hemolysis threshold specified in the device submission.",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) — is the same metric used in the 510(k) clinical threshold specification. Secondary QoIs (wall shear stress distribution, exposure time histograms) are directly traceable to hemolysis model inputs. High relevance confirmed by clinical affairs review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on the same device geometry and fluid under COU-representative conditions.",
      "rationale": "Validation experiments performed on the FDA generic centrifugal pump geometry identical to the COU device. Bovine blood at physiological hematocrit (35–40%) used in both validation and COU simulations. Operating envelope of validation activities fully encompasses the COU operating range. Relevance rated as high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance < 1e-5 for all transport equations at all operating points.",
      "rationale": "All five operating-point simulations converged to mass and momentum residuals below 1e-6. Hemolysis scalar transport residual below 1e-5. Double-precision arithmetic used throughout. No solver divergence events recorded. Iterative error contribution estimated at < 0.3% of total numerical uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup, boundary condition assignment, and post-processing scripts completed with no critical findings.",
      "rationale": "An independent CFD engineer conducted a full setup review against the simulation plan document. Boundary condition assignments, turbulence model parameters, and hemolysis model constants were verified. Two minor documentation gaps were identified and resolved prior to final submission. No critical use errors found."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty evaluated through expert elicitation and comparison of turbulence model predictions against experimental data.",
      "rationale": "Model form credibility for the hemolysis constitutive relation and turbulence closure was evaluated through a structured qualitative assessment conducted by a panel of three independent CFD hemolysis experts. The panel reviewed published literature comparing power-law hemolysis models (Giersiepen, Zhang, and Taskin formulations) against in-vitro data for centrifugal pump geometries. Consensus opinion was that the selected Zhang (2011) power-law model, combined with the SST k-omega turbulence closure, represents the current best-practice for this device class and operating regime. The qualitative assessment documented in the expert elicitation record (EER-CFD-2026-003) captures the panel's reasoning regarding model form adequacy, including acknowledged sensitivity of the hemolysis exponent to shear history integration path. The panel unanimously concluded that model form uncertainty, while non-negligible, does not preclude acceptance at the stated operating conditions given the conservative calibration constants adopted. This qualitative determination is supported by three independent peer-reviewed validation studies cited in EER-CFD-2026-003 and is considered sufficient to underpin the acceptance decision for this factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and fluid property inputs traceable to measured values with documented uncertainty bounds.",
      "rationale": "Fluid density, dynamic viscosity, and hematocrit measured from the same bovine blood batch used in validation experiments. Hemolysis model constants sourced from Zhang (2011) with documented uncertainty ranges. Monte Carlo propagation of input uncertainty performed across all five operating points. Achieved level 3 confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point with documented inter-replicate variability.",
      "rationale": "Four independent experimental runs performed at each of the five operating points using fresh blood samples. Inter-replicate coefficient of variation on NIH measurements ranged from 4.2% to 7.8%, consistent with published benchmarks for this protocol. Sample size and variability documentation meet MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD input parameters match experimental conditions within stated measurement uncertainty at each operating point.",
      "rationale": "Inlet flow rates, rotational speeds, and fluid properties used in CFD simulations confirmed equivalent to experimental conditions within ±2% for flow rate and ±0.5% for rotational speed. Equivalency matrix documented in simulation plan appendix. All five operating points satisfy the equivalency criterion."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for the CFD hemolysis prediction model applied to the Class III VAD COU. Twelve factors were assessed with full structured level evidence; all twelve achieved levels meeting or exceeding their required levels. The Model Form factor was assessed through a rigorous qualitative expert elicitation process documented in EER-CFD-2026-003, with unanimous expert consensus supporting adequacy for the stated COU. Considering the totality of the structured factor evidence, the Monte Carlo uncertainty quantification results, and the expert panel determination on model form, the team concludes that the simulation credibility is sufficient to support the intended regulatory use. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
