  "signature": "ed25519:b1d4e7a2c5f8b3e6a9d2c5f0b3e6a9d2c5f0b3e6a9d2c5f0b3e6a9d2c5f0b3e6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be developed and maintained under a documented quality management system with version control, regression testing, and traceability to requirements commensurate with MRL 5.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is developed under ISO 9001-certified QMS. Regression test suite covers 98% of hemolysis-relevant code paths. Version control and change logs verified. Required level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal code verification including order-of-accuracy testing on manufactured solutions for the governing equations used in hemolysis prediction.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes and scalar transport equations. Observed order of accuracy 1.97 (expected 2.0 for second-order scheme). Code verification passed at required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) study with at least three systematically refined meshes; GCI on hemolysis index QoI must be below 5% at the finest mesh.",
      "rationale": "Three-mesh GCI study performed (coarse 4.2M, medium 9.8M, fine 22.1M cells). GCI on hemolysis index at fine mesh: 7.3%. Target of 5% not met due to complex impeller geometry. Achieved level assessed as 3 (below required 4); gap acknowledged but team judged acceptable given UQ coverage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be measured and reported with uncertainty; inlet flow waveform and fluid properties must match CFD boundary conditions within stated tolerances.",
      "rationale": "Experimental conditions fully documented: inlet flow rate ±1.2%, fluid viscosity ±0.8%, temperature ±0.5°C. Boundary conditions in CFD set to measured mean values with uncertainty propagated via Monte Carlo. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_avg, u_val) computed for hemolysis index predictions against experimental measurements at all 5 operating points, with statistical significance assessed.",
      "rationale": "Validation metric E_avg = 12.4% across 5 operating points; u_val = 9.1%. Systematic over-prediction observed at high-speed conditions. Achieved level 3 versus required 4; gap attributed to hemolysis model form uncertainty at elevated shear rates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, pressure rise, velocity field) must be directly relevant to the clinical decision threshold and the COU prediction target.",
      "rationale": "Primary QoI is normalized index of hemolysis (NIH) directly linked to the clinical threshold. Secondary QoIs (pressure rise, velocity profiles) support mechanistic understanding. All QoIs confirmed directly relevant to COU2 clinical decision. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry and at operating conditions spanning the COU envelope; extrapolation beyond the validated range must be quantified.",
      "rationale": "Validation performed on FDA generic pump geometry identical to COU device. Operating conditions cover 4 of 5 COU flow-speed combinations; one high-flow point required extrapolation. Extrapolation uncertainty quantified via surrogate model. Achieved level 3 versus required 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated via residual monitoring and key QoI convergence plots; solver settings documented and justified.",
      "rationale": "All residuals converged to 1e-6 or below. NIH QoI convergence monitored over final 500 iterations; variation less than 0.1%. Solver settings (SIMPLE algorithm, second-order upwind) documented. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "A qualitative review of potential analyst use errors was conducted, including mesh setup, boundary condition assignment, turbulence model selection, and post-processing of hemolysis index. Findings were reviewed by an independent senior analyst.",
      "rationale": "A structured qualitative assessment of use-error risk was conducted by the senior simulation engineer and independently reviewed by the regulatory affairs lead. The review examined five potential error pathways: (1) incorrect rotational frame setup for the impeller domain — verified via torque balance cross-check; (2) erroneous application of the power-law hemolysis damage accumulation integral — confirmed against published reference implementation; (3) boundary condition mis-assignment at the volute outlet — checked against pump performance curve; (4) inappropriate turbulence model wall treatment for near-wall shear stress driving hemolysis — SST k-omega with enhanced wall treatment confirmed appropriate for y+ < 1 achieved on impeller blade surfaces; (5) post-processing integration path for NIH calculation — independently re-implemented in Python and results agreed to within 0.3%. The independent reviewer concluded that no systematic use errors were present and that the analyst team demonstrated sufficient expertise for MRL 5 assessment. This factor was evaluated through qualitative expert review rather than a graduated scoring rubric, as the nature of use-error assessment at this level of model complexity does not reduce to a single numerical gradation without loss of fidelity. The team's collective judgment is that use-error risk is acceptably controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis constitutive model and turbulence closure must be justified for the flow regime; sensitivity to model form alternatives must be quantified.",
      "rationale": "Power-law Giersiepen-Wurzinger model used for hemolysis; SST k-omega for turbulence. Alternative models (Faghih-Sharp, realizable k-epsilon) evaluated; NIH predictions vary by up to 18%. Model form uncertainty dominant contributor to total prediction uncertainty. Achieved level 3 versus required 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, fluid properties, operating conditions) must be documented with sources and uncertainties; Monte Carlo propagation performed.",
      "rationale": "Geometry from manufacturer CAD with dimensional inspection report. Fluid properties (blood viscosity, density) from literature with ±5% uncertainty bounds. Monte Carlo UQ with 10,000 samples performed across all uncertain inputs. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples (blood or blood analog) must be characterized for hematocrit, viscosity, and age; sample-to-sample variability must be reported.",
      "rationale": "Porcine blood used in experiments; hematocrit 38±2%, viscosity characterized by cone-and-plate rheometry. Three independent blood draws used across test replicates. Inter-sample variability in NIH: ±6.2%. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The input parameters used in the CFD model must be demonstrably equivalent to those measured in the validation experiments; any discrepancies must be quantified and their effect on QoIs assessed.",
      "rationale": "CFD inlet boundary conditions set to time-averaged experimental flow rates. Fluid property equivalence confirmed via matched Reynolds and Stokes numbers. Rotational speed equivalence verified to within 0.5 RPM. Discrepancies in outlet pressure boundary condition assessed via sensitivity study; effect on NIH less than 2%. Required level 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors, the assessment team concludes that the CFD model has sufficient credibility to support the regulatory submission for the Class III VAD device. While three factors (Discretization error, Output comparison, Relevance of validation activities) achieved level 3 against a required level 4, the team judges that the Monte Carlo uncertainty quantification framework adequately envelopes the gaps and that the conservative bias in hemolysis predictions (systematic over-prediction) provides an additional safety margin relative to the clinical threshold. The Use error factor was evaluated through a rigorous qualitative review process documented in the factor rationale, and the independent reviewer concurred with the adequacy finding. The overall weight of evidence supports an Accepted determination for COU2 at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
