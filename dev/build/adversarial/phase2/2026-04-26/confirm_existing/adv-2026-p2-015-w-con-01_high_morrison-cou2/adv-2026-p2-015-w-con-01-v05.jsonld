  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan documented, version-controlled, with traceability to solver release. All regression tests pass for hemolysis-relevant modules.",
      "rationale": "The CFD solver is maintained under an ISO 9001-compliant quality management system. Version control, regression test suites, and change-control records were reviewed and found to satisfy Gradation 4 requirements for a Class III device application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent demonstrated for all governing equations including scalar transport used in hemolysis model.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver and passive scalar transport. The hemolysis damage accumulation sub-model has not been independently verified via MMS; only round-trip regression tests were conducted, resulting in an achieved level of 3 against a required level of 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI across at least three systematically refined meshes; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study was conducted following ASME V&V 20 procedures. GCI on the normalized hemolysis index was 3.2% on the fine mesh (7.4 M cells), satisfying the acceptance criterion. Richardson extrapolation confirms monotonic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rates) documented and traceable to calibrated instrumentation with uncertainty bounds reported.",
      "rationale": "All five operating points were tested using bovine blood at 37 °C with hematocrit 35 ± 2%. Flow rates were measured with a Coriolis meter (±0.5%) and rotational speed with an optical encoder (±1 RPM). Uncertainty budgets are fully documented in the test report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E% or u_val) computed for hemolysis index at all five operating points; comparison includes experimental uncertainty.",
      "rationale": "Predicted hemolysis index agreed within 18% of experimental mean at four of five operating points. At the highest flow-speed combination, deviation reached 27%, exceeding the ±20% acceptance band. Validation metric E% computed per ASME V&V 20. Achieved level 3 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (normalized index of hemolysis, NIH) directly maps to the clinical endpoint; no surrogate substitution without justification.",
      "rationale": "The normalized index of hemolysis (NIH) used in validation experiments is the same metric required by FDA guidance for VAD submissions. No surrogate QoI substitution was made. Direct correspondence confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry at overlapping operating conditions; any extrapolation to COU conditions explicitly bounded.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which is the same geometry used in the COU. Operating envelope overlap is approximately 80%; two COU operating points lie outside the validated range and required extrapolation. Extrapolation uncertainty was bounded by Monte Carlo sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; residuals reduced by at least 4 orders of magnitude; mass imbalance < 0.01%.",
      "rationale": "All simulations converged with RMS residuals below 1×10⁻⁵ (5 orders of magnitude reduction). Global mass imbalance was below 0.005% in all cases. Convergence plots archived in the simulation record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary conditions, material properties, and solver settings verified against documented simulation plan.",
      "rationale": "An independent CFD analyst reviewed all simulation input decks against the pre-approved simulation plan. No setup errors were identified. Boundary condition traceability matrix completed and signed off."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified relative to the flow regime and damage mechanism; alternative model forms considered.",
      "rationale": "Model form adequacy was evaluated through a structured qualitative expert panel convened in March 2026, comprising three independent CFD specialists with VAD hemolysis experience. The panel reviewed the selection of the SST k-ω turbulence closure and the Giersiepen-Wurzinger power-law hemolysis model against the literature landscape. Panelists unanimously concluded that the chosen model forms are appropriate for the transitional-turbulent regime (Re 4,000–12,000) present in the pump impeller passages and that the power-law exponents have been recalibrated to bovine blood data consistent with the experimental corpus. The qualitative assessment did not yield a discrete gradation score because the panel's charter was to flag disqualifying deficiencies rather than assign numerical ratings; no disqualifying deficiency was identified. This narrative evidence is considered sufficient by the assessment team to support the Accepted outcome in conjunction with the quantitative evidence from the remaining twelve factors."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and operating parameters traceable to measurement or published reference data with uncertainty characterization.",
      "rationale": "Blood viscosity, density, and yield stress inputs were derived from rheometry measurements on the same bovine blood batch used in validation. Rotational speed and flow boundary conditions sourced from calibrated instrumentation. Full uncertainty budget documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood sample characterization (species, hematocrit, storage time) documented; inter-batch variability assessed.",
      "rationale": "Bovine blood samples were obtained from a single certified supplier, stored for no more than 48 hours, and characterized for hematocrit, plasma-free hemoglobin baseline, and osmolarity prior to each test. Inter-batch variability in NIH was assessed across three independent test runs and found to be within 8%, consistent with published literature ranges."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary conditions and material property inputs match experimental conditions within stated uncertainty bounds; any mismatches explicitly documented and their impact on QoI bounded.",
      "rationale": "A parameter equivalency matrix was constructed mapping each experimental measurement to the corresponding CFD input. All parameters were matched within measurement uncertainty. One minor discrepancy in inlet velocity profile (fully developed assumption vs. measured profile) was assessed via sensitivity analysis and found to affect NIH by less than 2%."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "After reviewing all 13 credibility factors, the assessment team concludes that the CFD model has sufficient credibility to support regulatory submission for the VAD hemolysis claim. Twelve factors were evaluated with explicit required and achieved levels; three factors show achieved levels below required levels but the gaps are bounded and mitigated by Monte Carlo uncertainty quantification and conservative safety margins. The model form factor was evaluated qualitatively by an independent expert panel with no disqualifying deficiency identified. The totality of evidence, including the quantitative validation results and the expert panel findings, supports an Accepted outcome for this Class III VAD application.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
