  "hash": "sha256:a3f8c21d7e0b954f16d2a78c3b5e09f4d1c6a2e8b7f3d094c5a1e6b2f9d4c780",
  "signature": "ed25519:b2d4e6f8a0c1e3f5d7b9a2c4e6f8b0d2a4c6e8f0b2d4a6c8e0f2b4d6a8c0e2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan documented, version control enforced, regression test suite with pass rate ≥ 95%, and independent code review completed.",
      "rationale": "The CFD solver (OpenFOAM v9) operates under a documented software quality assurance plan that includes version-controlled source code, automated regression testing across 47 benchmark cases (97.8% pass rate), and an independent peer review of all custom hemolysis damage model subroutines. All SQA artifacts are archived in the project document management system. Required level 4 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equation sets; observed order of accuracy within 10% of theoretical order.",
      "rationale": "MMS verification was performed for the incompressible Navier-Stokes solver, the k-ω SST turbulence transport equations, and the scalar hemolysis damage accumulation equation. Observed spatial order of accuracy was 1.94 (theoretical 2.0) for velocity, 1.88 for turbulent kinetic energy, and 1.91 for damage scalar. All values within the 10% tolerance of theoretical second-order accuracy. Required level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for QoI; GCI < 5% on fine grid.",
      "rationale": "A three-level mesh refinement study (coarse: 4.2M cells, medium: 11.7M cells, fine: 31.4M cells) was conducted at the nominal operating point (5 L/min, 3500 RPM). Richardson extrapolation yielded GCI values of 3.1% for hemolysis index, 2.8% for volume-averaged shear stress, and 4.4% for pressure rise. All GCI values below the 5% threshold. Fine mesh used for all production runs. Required level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; fluid properties, boundary conditions, and operating points traceable to calibrated instrumentation.",
      "rationale": "Bench hemolysis experiments were conducted using bovine blood with hematocrit 35 ± 1.5% and temperature 37 ± 0.5°C. Flow rates were set using a calibrated Coriolis meter (±0.5% full scale) and rotational speed via optical tachometer (±5 RPM). All five operating points replicated in triplicate with coefficient of variation < 8% for normalized index of hemolysis. Traceability to NIST standards documented. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E% or validation uncertainty) computed for primary QoI across all operating points; systematic bias < 15%.",
      "rationale": "CFD-predicted normalized index of hemolysis was compared against bench measurements at all 5 operating points. Mean absolute percentage error was 18.3%, with CFD systematically over-predicting hemolysis by 12–24%. While the systematic bias exceeds the 15% threshold at two operating points, the over-prediction direction is conservative for patient safety. The assessment team accepted this gap given the conservative bias direction and the Monte Carlo UQ bounds encompassing all experimental values. Achieved level 3 vs. required level 4 — gap noted but accepted with justification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (hemolysis index) directly maps to the clinical endpoint; secondary QoIs (shear stress, exposure time) are mechanistically linked.",
      "rationale": "The normalized index of hemolysis is the direct regulatory QoI for blood pump hemolysis assessment per FDA guidance. Secondary QoIs — volume-averaged scalar shear stress and Lagrangian exposure time distributions — are mechanistically coupled to the primary QoI through the power-law damage model. The QoI hierarchy is fully documented and linked to the COU decision criterion. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry, fluid, and operating range as the COU; no significant extrapolation in geometry or operating conditions.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry — identical to the COU geometry. Bovine blood was used as the working fluid; rheological properties were matched to human blood at the operating temperature via calibrated viscosity measurements. All five COU operating points were included in the validation matrix. No geometric or operating condition extrapolation is required. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated by residual reduction of ≥ 4 orders of magnitude and stabilization of QoI monitors; time-step independence confirmed for transient simulations.",
      "rationale": "All steady-state simulations achieved residual reductions of 5–6 orders of magnitude with QoI monitors (hemolysis index, pressure rise, torque) stabilizing to < 0.01% variation over the final 500 iterations. For transient simulations, a time-step independence study confirmed < 2% change in hemolysis index between Δt = 1×10⁻⁴ s and Δt = 5×10⁻⁵ s. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup checklist completed and independently reviewed; boundary condition inputs verified against COU specification by second analyst.",
      "rationale": "A structured simulation setup checklist covering geometry import, mesh quality metrics, boundary condition assignment, solver settings, and post-processing scripts was completed by the primary analyst and independently reviewed by a second CFD engineer. All five operating point configurations were verified. No discrepancies identified. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "rationale": "Model form adequacy for the hemolysis damage accumulation model and turbulence closure was evaluated through a structured expert elicitation process involving three independent subject matter experts with combined experience exceeding 45 person-years in computational hemodynamics. The panel reviewed published literature on power-law hemolysis model performance across 14 independent datasets, assessed the suitability of k-ω SST closure for the rotating passage flow regime, and examined sensitivity of predicted hemolysis to damage model exponent uncertainty (α: 0.765 ± 0.035, β: 1.991 ± 0.083). The expert panel reached consensus that the selected model form is appropriate for the COU operating envelope and that residual model form uncertainty is bounded within the Monte Carlo UQ envelope already applied to model input parameters. This qualitative assessment, documented in Expert Elicitation Report EER-COU2-2026-03, was accepted by the assessment team as sufficient evidence of model form adequacy given the maturity of the power-law hemolysis modeling literature and the conservative bias direction observed in the output comparison factor. A formal graduated level assignment was not completed for this factor; the team's judgment is that the qualitative evidence base is commensurate with the requirements at Model Risk Level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; Monte Carlo UQ propagation performed; 95th-percentile hemolysis prediction remains below clinical threshold.",
      "rationale": "Twenty-three model input parameters were characterized with probability distributions based on literature meta-analysis and direct measurement uncertainty quantification. Monte Carlo UQ was performed with N=2000 Latin hypercube samples. The 95th-percentile hemolysis index prediction across all operating points remained 23% below the absolute clinical threshold. Sensitivity analysis identified damage model exponent α and inlet turbulence intensity as the dominant uncertainty contributors. Required level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood sample provenance documented; hematocrit, age, and storage conditions controlled; minimum three independent donors per operating condition.",
      "rationale": "Bovine blood was sourced from a single USDA-certified abattoir, processed within 4 hours of collection, and used within 48 hours. Hematocrit was adjusted to 35 ± 1.5% for all experiments. Three independent blood batches were used per operating point, with batch-to-batch variability in baseline plasma hemoglobin < 5 mg/dL. Storage at 4°C throughout. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary conditions demonstrated to be equivalent to experimental conditions within stated measurement uncertainty; any non-equivalencies documented with sensitivity analysis.",
      "rationale": "CFD inlet velocity profiles were derived from PIV measurements at the pump inlet plane; equivalency to experimental flow rates was confirmed within ±1.2% across all operating points. Rotational speed boundary conditions matched tachometer readings within ±3 RPM. Wall roughness was characterized via profilometry (Ra = 0.8 ± 0.15 μm) and applied as a wall boundary condition. One non-equivalency was identified: experimental outlet pressure fluctuations (±80 Pa) were not replicated in the CFD outlet boundary condition; sensitivity analysis confirmed < 1.5% effect on hemolysis index. Required level 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for COU2. Twelve factors received formal requiredLevel and achievedLevel assignments; 11 of these achieved their required levels, and one (output comparison) fell one gradation below required but was accepted on the basis of conservative over-prediction bias and UQ envelope coverage. The model form factor was addressed through a documented expert elicitation process that the team judged to provide equivalent assurance at MRL 5. The Monte Carlo UQ analysis demonstrates that the 95th-percentile hemolysis prediction remains below the absolute clinical threshold with a 23% margin. Collectively, the evidence base is judged sufficient to support an Accepted decision for use of the CFD model to predict absolute hemolysis levels for the Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
