  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-2026-04",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed. Achieved levels fall below required levels at MRL 5 across multiple factors; however, the assessment team determined that the Monte Carlo uncertainty quantification results demonstrate that the 95th-percentile NIH remains below the clinical threshold with sufficient margin. The benchmark validation agreement of 18% NIH deviation, combined with the Monte Carlo UQ results confirming margin to threshold, is judged sufficient to support a conditional acceptance. Residual gaps in model form uncertainty and geometry relevance are acknowledged and will be addressed in the next assessment cycle. Decision: Accepted with conditions.",
