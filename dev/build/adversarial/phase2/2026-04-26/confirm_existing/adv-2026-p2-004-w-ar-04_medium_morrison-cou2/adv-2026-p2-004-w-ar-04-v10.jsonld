  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen credibility factors assessed. Seven factors meet required levels; six factors have achievedLevel one gradation below required. Gaps are documented and judged acceptable given Monte Carlo UQ coverage, conservative hemolysis threshold margin of 23%, and the availability of supporting experimental data from the FDA benchmark. Validation results from the ANSYS CFX 15.0 configuration confirm model predictive capability within the COU operating envelope. Assessment team recommends acceptance with conditions: discretization error gap to be resolved in next model update cycle and full multi-point alternative model comparison to be completed prior to regulatory submission.",
