  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Seven credibility factors assessed; all show gaps between achieved and required levels consistent with MRL 5 stringency, but the gaps are documented and bounded. Monte Carlo UQ envelope encompasses experimental data at 95th percentile. Six factors remain epistemic gaps with mitigation plans recorded. The assessment team accepts the package for submission with the understanding that model-form and test-sample gaps must be resolved prior to pivotal study. Validation results support the hemolysis-below-threshold claim within the stated uncertainty envelope.",
