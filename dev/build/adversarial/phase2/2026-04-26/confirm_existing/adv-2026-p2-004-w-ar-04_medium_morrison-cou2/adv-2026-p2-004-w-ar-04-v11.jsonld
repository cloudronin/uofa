  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and documented V&V test suite covering hemolysis-relevant flow regimes.",
      "rationale": "Ansys CFX 2026 Q1 is covered by Ansys ISO 9001:2015 quality management certification. Internal SQA test suite includes 47 regression cases for rotating machinery and non-Newtonian flows. Release notes confirm no open critical defects affecting hemolysis correlation integration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark convergence study demonstrating second-order spatial accuracy for the transport equations used in the hemolysis model.",
      "rationale": "Method of manufactured solutions applied to the scalar hemolysis transport equation on a sequence of three refined meshes (1.1M, 2.3M, 4.2M cells). Observed convergence order 1.94 — consistent with second-order advection scheme. Code verification requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI < 3% on hemolysis index QoI at the production mesh.",
      "rationale": "Grid convergence index computed on three-mesh sequence. GCI on normalised hemolysis index at primary operating point: 1.8%. All five operating conditions yield GCI < 2.5%. Discretization error is adequately controlled at the 4.2M-cell production mesh."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol) must match COU operating envelope within stated tolerances.",
      "rationale": "FDA pump experiments used bovine blood at 37°C ± 0.5°C, hematocrit 33% ± 2%. COU specifies human blood at 37°C, hematocrit 35–45%. Temperature match is adequate; hematocrit range partially overlaps but the upper COU bound (45%) is not covered by the experimental dataset. Achieved level assessed as 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., relative error or E_num) computed with experimental uncertainty bounds reported; metric must be below acceptance threshold.",
      "rationale": "Normalised hemolysis index relative error 7.8% at primary operating point; range 5.2%–9.4% across all five points. Experimental measurement uncertainty ±6% (95% CI). Simulation predictions fall within combined uncertainty band at three of five operating points; two points show marginal exceedance. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (normalised hemolysis index) must map directly to the regulatory acceptance criterion (absolute % RBC lysis below clinical threshold).",
      "rationale": "Normalised hemolysis index (NIH) is the standard regulatory QoI for blood-contacting devices and maps directly to the clinical threshold via the ASTM F1841 conversion. The mapping introduces a scaling factor with ±4% uncertainty, which is propagated in the Monte Carlo analysis. Relevance is high but not perfect due to the scaling step; achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating speed range, and fluid type as the COU, or formal similarity arguments must be provided.",
      "rationale": "FDA generic centrifugal pump geometry is used in validation, matching COU geometry. Operating speed range 2000–3500 RPM overlaps COU range 2500–4000 RPM; the upper 500 RPM band is extrapolated. Bovine blood used in experiments vs. human blood in COU — formal similarity argument provided but not experimentally confirmed. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to 1e-5 RMS residuals; mass imbalance < 0.01% across all runs.",
      "rationale": "All 500 Monte Carlo runs and the five primary operating-point simulations converged to 1e-5 RMS residuals within 2000 iterations. Maximum mass imbalance observed: 0.004%. Solver error contribution to QoI uncertainty estimated at < 0.5% via perturbation study. Requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution checklist completed by a qualified analyst; independent peer review of boundary condition setup.",
      "rationale": "Simulation execution followed a 42-item checklist per the organisation's CFD SOP. Boundary conditions independently reviewed by a second qualified CFD engineer. No discrepancies identified. Use error risk assessed as adequately controlled at level 3 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis power-law correlation must be validated against independent experimental data; turbulence model selection justified for rotating machinery with non-Newtonian fluid.",
      "rationale": "Giersiepen-Wurzinger correlation validated against Heuser-Opitz data in literature; applicability to centrifugal pump shear histories is debated. SST k-omega selected for rotating machinery — appropriate but not validated for blood rheology at low hematocrit. Model form uncertainty is the dominant epistemic gap; achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (viscosity, density, hemolysis coefficients) characterised with probability distributions from literature or measurement; distributions used in Monte Carlo propagation.",
      "rationale": "Blood viscosity modelled as Carreau fluid; parameters drawn from Brooks et al. (2005) with reported uncertainty. Hemolysis power-law exponent and coefficient sampled from Giersiepen et al. (1990) ± 1σ. Inlet velocity profile uncertainty characterised from PIV measurements. All five uncertain inputs propagated in 500-sample Monte Carlo."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental dataset must include at least 3 independent biological replicates per operating point to characterise inter-sample variability.",
      "rationale": "FDA pump dataset includes 2 biological replicates per operating point (bovine blood, different donor animals). Three replicates required at MRL 5; the available dataset falls one replicate short. Inter-sample variability estimated from the two available replicates and conservatively inflated by 20% in the uncertainty budget. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Inlet boundary conditions (flow rate, pressure, velocity profile) used in simulation must match experimental test conditions within ±2%.",
      "rationale": "Experimental flow rates measured by Coriolis flowmeter (±0.5% accuracy); inlet pressure by calibrated transducer (±0.3%). Simulation inlet boundary conditions set to measured mean values. Velocity profile from PIV at pump inlet plane used directly as CFD inlet condition. Equivalency confirmed within ±1.2% across all operating points."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed. Seven factors achieved required levels; six factors achieved one level below required, which is within the acceptable gap tolerance established in the project credibility plan for MRL 5 devices given the conservative Monte Carlo uncertainty quantification. The 95th-percentile hemolysis prediction (0.087% RBC lysis) remains below the clinical threshold (0.1%) with margin. The assessment team concludes that the CFD model provides adequate credibility for regulatory submission under the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
