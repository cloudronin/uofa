  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the package based on the totality of evidence: hemolysis index predictions remain below clinical threshold at 4 of 5 operating points under Monte Carlo uncertainty, and the single outlier point is at an operating condition outside the primary VAD use envelope. Residual gaps in model form, model inputs, and test sample replication are acknowledged. The validation results generated by the Ansys CFX 15 configuration are considered sufficient for the current submission cycle pending resolution of open SQA defects.",
