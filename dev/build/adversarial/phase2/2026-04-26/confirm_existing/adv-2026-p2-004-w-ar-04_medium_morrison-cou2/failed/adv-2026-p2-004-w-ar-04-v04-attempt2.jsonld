  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; all critical defects resolved prior to release.",
      "rationale": "ANSYS CFX 15 has a documented QA process and regression test suite. However, build 2026-q1-build-5 introduced a minor patch to the hemolysis damage accumulation integrator that was not accompanied by a full regression run against the hemolysis benchmark suite, leaving one test case unverified. Achieved level 3 falls below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests demonstrate expected convergence rates for all governing equations including scalar transport for hemolysis.",
      "rationale": "Order-of-accuracy verification was performed for momentum and continuity equations using the method of manufactured solutions, confirming second-order convergence. Scalar transport equation (hemolysis damage) was verified to first-order only due to limitations in the damage model implementation. Achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) below 5% for NIH at all operating points.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 4.2M, 8.4M elements). GCI for NIH ranged from 3.1% to 8.7% across operating points; two high-speed conditions exceeded the 5% threshold. Achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match COU operating envelope within documented tolerances; fluid properties characterized at test temperature.",
      "rationale": "FDA benchmark experiments used bovine blood analog; VAD COU requires human blood rheology. Viscosity and density were matched at 37°C but viscoelastic properties and red cell fragility differ. Test conditions partially representative; achieved level 2 vs required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of NIH with uncertainty bounds; statistical agreement metric (E_val) within acceptance threshold at all operating points.",
      "rationale": "NIH predictions compared against experimental data with Monte Carlo uncertainty propagation. Agreement within 15% at 4 of 5 operating points; one low-flow condition showed 22% deviation. E_val metric computed but threshold exceeded at one condition. Achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validated QOI (NIH) is the same quantity used in the regulatory submission; no surrogate quantities used.",
      "rationale": "NIH is the direct regulatory QOI. However, the hemolysis model computes a path-integrated damage index rather than a spatially resolved distribution, which may miss localized high-shear zones in the VAD impeller gap. Achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating conditions, and fluid properties sufficiently representative of the COU device and patient population.",
      "rationale": "Validation used the FDA generic centrifugal pump, which shares rotary impeller topology with the COU VAD but differs in impeller diameter and volute geometry. Operating conditions overlap partially. Relevance is moderate; achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated; round-off and algebraic errors bounded and documented.",
      "rationale": "Iterative convergence to RMS residuals below 1e-5 achieved for all runs. However, the hemolysis damage integrator uses single-precision accumulation, introducing non-trivial round-off error at long integration paths. Achieved level 2 vs required level 3.",
      "name": "Numerical solver error — hemolysis integrator precision"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review; boundary condition inputs verified against device specifications.",
      "rationale": "Simulation workflow documented and peer-reviewed internally. Boundary conditions (inlet flow rate, outlet pressure) verified against device test data. However, no independent third-party review of setup was conducted; one boundary condition (inlet velocity profile) was assumed uniform rather than measured. Achieved level 2 vs required level 3."
    },
    {
