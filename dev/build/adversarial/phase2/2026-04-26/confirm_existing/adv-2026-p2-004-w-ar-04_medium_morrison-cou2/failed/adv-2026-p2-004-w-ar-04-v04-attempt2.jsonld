      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full characterization of input parameter uncertainty including blood rheology, pump geometry tolerances, and operating condition variability.",
      "rationale": "Monte Carlo UQ was performed on flow rate and rotational speed only. Blood viscosity, red cell fragility index, and impeller clearance tolerances were held at nominal values. Input uncertainty characterization is incomplete for MRL 5 requirements; not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient for statistical characterization of hemolysis variability; inter-sample variability documented.",
      "rationale": "FDA benchmark dataset provides n=3 experimental replicates per operating point. For MRL 5 absolute hemolysis claims, statistical power analysis indicates n≥10 required. Sample size insufficient; not assessed at required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
