  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors. Seven factors were assessed; all achieved levels fall below required levels for MRL 5. Six factors were not assessed due to data availability constraints. The validation results from the FDA generic pump benchmark, including the NIH MAPE of 11.8% and Monte Carlo uncertainty quantification across 500 samples, were reviewed and accepted as sufficient basis for a conditional submission pending resolution of the six epistemic gaps. The team accepted the package for submission with the understanding that outstanding gaps will be addressed in the next assessment cycle.",
    "decidedAt": "2026-03-18T16:00:00Z"
