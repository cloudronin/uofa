    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen credibility factors have been assessed. Seven factors achieved required levels; six factors show achievedLevel one gradation below requiredLevel. The assessment team determined that the aggregate credibility evidence, including Monte Carlo uncertainty quantification and FDA benchmark validation with 11.2% hemolysis index error, is sufficient to support regulatory submission at MRL 5 with conditions. Velocity field validation (VR-002) corroborates flow field accuracy under the current model configuration. Hemolysis index validation (VR-001) was conducted under the production solver configuration and results are considered representative of the current model.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
