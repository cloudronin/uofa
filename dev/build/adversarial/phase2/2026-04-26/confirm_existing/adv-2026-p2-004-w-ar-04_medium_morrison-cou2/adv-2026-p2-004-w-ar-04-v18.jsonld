  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The 13-factor credibility assessment for COU2 (VAD hemolysis, MRL 5) yields achieved levels at or above required for 9 of 13 factors. Four factors (Discretization error, Output comparison, Model form, Model inputs) show gaps of one gradation each. The assessment team accepts these gaps under a risk-informed rationale: Monte Carlo UQ at 91% coverage provides compensating evidence for discretization and input uncertainty gaps; the model form gap is documented as a known epistemic limitation consistent with the current state of hemolysis modeling practice. Validation results from the FDA generic pump benchmark, combined with UQ coverage analysis, provide sufficient credibility evidence to support regulatory submission at Low assurance level. Decision: Accepted.",
    "decidedAt": "2026-03-05T00:00:00Z"
  },
