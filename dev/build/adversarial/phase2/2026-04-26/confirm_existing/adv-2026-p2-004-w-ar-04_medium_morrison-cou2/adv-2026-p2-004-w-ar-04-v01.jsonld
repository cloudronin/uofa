  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors, the assessment team determined that the CFD hemolysis prediction package for the VAD COU demonstrates sufficient evidence to support the regulatory submission at the current stage. Seven factors were formally assessed; the achieved levels, while below required levels in several cases, are judged acceptable given the supporting Monte Carlo uncertainty quantification and the conservative nature of the NIH threshold applied. The six not-assessed factors are acknowledged as epistemic gaps and will be addressed in the next model iteration. The primary validation results generated under configuration ANSYS CFX 15 build 2026-q1-build-5 are accepted as supporting evidence for the credibility package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
