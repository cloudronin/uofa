  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The aggregate credibility evidence package for COU2 VAD hemolysis prediction is judged sufficient for regulatory submission at MRL 5. Seven of thirteen factors meet or approach required levels; six factors carry documented gaps that are mitigated by conservative Monte Carlo uncertainty quantification and the overall low hemolysis margin relative to clinical threshold. The primary validation result demonstrates 8.3% MAE on NIH across all operating points, within the acceptance criterion. The decision is accepted with the condition that model form uncertainty characterization be updated prior to next design iteration.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
