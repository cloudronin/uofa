  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen ASME V&V 40 credibility factors. Seven factors achieved their required levels; six factors showed minor shortfalls (discretization error, model form, relevance to COU, equivalency of input parameters) that were accepted under engineering judgment given the supporting Monte Carlo UQ results. The hemolysis index predictions remain below the clinical threshold at the 95th percentile across the Monte Carlo ensemble. The team accepted the overall credibility evidence package as sufficient to support the regulatory submission for the Class III VAD device.",
