  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all thirteen credibility factors, the assessment team concludes that the CFD model provides sufficient evidence to support the VAD hemolysis acceptance decision under the stated conditions. Key supporting evidence includes satisfactory hydraulic performance validation (vr-pressure-head-2026q1) conducted under the current model configuration, and hemolysis bench validation (vr-hemolysis-bench-2026q1) demonstrating NIH predictions within ±18% of experimental measurements across all five COU operating points with Monte Carlo UQ confirming the 95th-percentile NIH remains below the clinical threshold. Credibility gaps in model form, test samples, and equivalency of input parameters are acknowledged; the team judges these gaps acceptable at this stage given the conservative NIH bias direction and the low absolute NIH values observed. Conditions: (1) hemolysis model coefficient uncertainty must be incorporated in the next model revision, (2) a second blood sample lot must be tested within 6 months.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
