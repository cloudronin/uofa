  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must operate under a documented quality management system with version control, regression testing, and release validation records consistent with MRL 5 requirements.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under an ISO 9001-compliant QMS. Regression test suite of 312 cases executed at each release; all hemolysis-relevant test cases pass. Version-locked build used throughout the study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate solver correctness via method of manufactured solutions (MMS) or equivalent for all governing equations active in the hemolysis simulation.",
      "rationale": "MMS verification completed for incompressible Navier-Stokes and scalar hemolysis transport equations. Observed convergence rates match theoretical order for second-order spatial discretization. No code defects identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic grid convergence study using Richardson extrapolation must bound discretization error in hemolysis index to within ±8% at the finest mesh used in production runs.",
      "rationale": "Three-level mesh refinement study (4.2M, 11.7M, 28.4M cells) conducted at two representative operating points. Grid convergence index (GCI) for hemolysis index is 3.1% at the 11.7M cell mesh used in production, satisfying the ±8% criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with traceability to calibrated instrumentation; fluid properties, pump speed, and flow rate must be controlled within ±2% of nominal.",
      "rationale": "NIH hemolysis experiments conducted with bovine blood at 37°C; hematocrit 33±1%; pump speed controlled to ±25 RPM; flow rate controlled to ±0.1 L/min. All instrumentation calibrated within 6 months of test. Traceability chain documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized index of agreement or validation uncertainty) must demonstrate CFD hemolysis predictions within combined experimental and numerical uncertainty bands at all 5 operating points.",
      "rationale": "Validation metric computed at all 5 operating points. CFD predictions fall within ±15% of experimental hemolysis index at 4 of 5 points; the fifth point shows 18% deviation but lies within expanded combined uncertainty (U95). Validation uncertainty formally quantified using ASME V&V 20 methodology."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (normalized index of hemolysis, NIH) must be directly mappable to the clinical decision threshold without intermediate transformation that introduces unquantified uncertainty.",
      "rationale": "NIH computed directly from CFD shear stress and exposure time fields using the Giersiepen-Wurzinger power law. The same QoI is used in the clinical acceptance criterion. No intermediate transformation required. Direct correspondence confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid type, and operating envelope as the COU; any deviations must be bounded by documented extrapolation arguments.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry identical to the COU device model. Bovine blood used as surrogate for human blood; viscosity equivalence documented. Operating points span the full COU envelope. No extrapolation beyond validated range required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to a residual tolerance where further iteration changes hemolysis index by less than 0.5%; round-off error must be assessed and shown negligible.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum; hemolysis scalar residual below 1e-8. Iteration-to-iteration change in NIH at convergence is 0.02%. Double-precision arithmetic used throughout; round-off error negligible relative to discretization error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition inputs must be traceable to source data; a documented checklist must be completed for each production run.",
      "rationale": "Independent analyst review completed for all 5 COU operating points. Boundary conditions traced to experimental measurement reports. Run checklist (27 items) completed and archived for each simulation. No use errors identified during review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis constitutive model must be justified through literature evidence and sensitivity to model-form choices must be evaluated for the pump flow regime.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark studies for rotating machinery hemolysis prediction. Comparison against k-epsilon and LES at one operating point shows NIH differences of 6% and 9% respectively, within acceptable range. Giersiepen-Wurzinger hemolysis model validated against in-vitro data in prior literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs must be characterized with probability distributions sourced from traceable measurements or literature; Monte Carlo UQ must propagate input uncertainty through to hemolysis index predictions.",
      "rationale": "Input parameters characterized with probability distributions: fluid viscosity (log-normal, CV=4%), hemolysis model coefficients alpha and beta (normal, from Giersiepen et al. regression uncertainty), pump speed (normal, ±25 RPM), inlet flow waveform (empirical distribution from 10 repeat measurements). Monte Carlo ensemble of 5000 runs executed on HPC cluster. Output NIH distributions reported with 5th–95th percentile bounds at all operating points. Comprehensive UQ coverage across all inputs confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples must be characterized for material properties relevant to hemolysis; sample-to-sample variability must be documented and incorporated into the validation comparison.",
      "rationale": "Bovine blood samples sourced from single supplier; hematocrit and viscosity measured for each sample lot. Three independent blood lots used across the 5 operating-point experiments. Sample-to-sample variability in NIH is 8%, incorporated into experimental uncertainty estimate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Correspondence between simulation input parameters and experimental conditions must be established; any discrepancies must be bounded and their effect on NIH estimated.",
      "rationale": "CFD boundary conditions set to match experimental measurements within instrument uncertainty. Pump wall roughness in CFD set to Ra=0.4 µm based on surface profilometry of test article. Temperature-dependent viscosity matched to experimental fluid temperature profile. Parameter correspondence documented in traceability matrix."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5. Achieved levels meet or exceed required levels across all factors. Monte Carlo uncertainty quantification comprehensively propagates variability across all model inputs, yielding NIH prediction intervals that remain below the clinical acceptance threshold at all 5 operating points. Validation activities are directly relevant to the COU geometry and operating envelope. Software QA, code verification, and discretization error controls are commensurate with Class III device requirements. The credibility evidence package is sufficient to support regulatory submission.",
