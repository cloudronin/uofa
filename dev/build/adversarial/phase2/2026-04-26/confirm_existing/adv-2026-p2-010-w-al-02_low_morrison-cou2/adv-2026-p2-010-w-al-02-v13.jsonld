  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Monte Carlo uncertainty quantification is performed comprehensively across all model inputs, propagating variability in fluid viscosity, pump geometry tolerances, inlet flow waveform, and power-law hemolysis model coefficients. All 13 credibility factors have been assessed; achieved levels meet or exceed required levels at MRL 5. Decision: Accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "hasUncertaintyQuantification": true,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/cou2-vad-hemolysis-credibility",
