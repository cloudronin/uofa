  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction is accepted on the basis that Monte Carlo uncertainty quantification was comprehensively performed across all model inputs, providing 5th–95th percentile bounds on the normalized index of hemolysis. Seven of thirteen credibility factors were formally assessed; the remaining six are flagged as epistemic gaps consistent with MRL 5 documentation requirements. The UQ results demonstrate that the 95th-percentile NIH prediction remains below the clinical acceptance threshold across all five operating points, providing sufficient confidence for the intended regulatory decision. Residual gaps in model form, use error, and test sample characterization are acknowledged and accepted given the conservative UQ bounds established.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
