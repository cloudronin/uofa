  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction is accepted for submission. Monte Carlo uncertainty quantification was performed comprehensively across all model inputs, yielding output uncertainty bounds on the hemolysis index QoI at all 5 operating conditions. While achieved credibility levels fall below required levels across all 13 factors at MRL 5, the UQ results provide sufficient confidence that predicted hemolysis indices remain below the absolute clinical threshold with documented uncertainty bounds. Residual gaps are acknowledged and flagged for future assessment cycles.",
