  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite, version control, and regression testing covering blood flow applications.",
      "rationale": "ANSYS Fluent 2023R1 is used with documented regression test suite covering rotating machinery and non-Newtonian flow. Version control and change logs are maintained. Achieved level 3 meets required level 3 for MRL 5 Class III device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions for the governing equations relevant to hemolysis prediction.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes solver confirms second-order spatial accuracy. Hemolysis scalar transport equation verified against analytical benchmark. Achieved level 3 satisfies requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis index and velocity field QoIs across three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 11.8M, 31.6M cells). GCI for normalized hemolysis index is 3.1% on fine mesh, within acceptable tolerance. Discretization error is bounded and reported for all 5 operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope; fluid properties, temperature, and hematocrit documented with measurement uncertainty.",
      "rationale": "In vitro experiments conducted at 37°C with bovine blood at 40% hematocrit, matching VAD physiological conditions. Flow rates and rotational speeds match CFD boundary conditions within ±1.5%. Temperature and viscosity measurements documented with calibrated instrumentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation metric u_val) reported for hemolysis index predictions versus experimental measurements.",
      "rationale": "Normalized RMS error for hemolysis index across 5 operating points is 12.4%, within the pre-specified acceptance threshold of 15%. Validation metric accounts for both experimental and numerical uncertainty. Pressure head predictions within 4.2% of measured values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, velocity field) must directly correspond to the clinical decision quantity (absolute hemolysis level below threshold).",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) computed from power-law model integrated over particle trajectories, directly corresponding to the clinical hemolysis threshold. Validation QoIs are identical to COU prediction QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the FDA generic centrifugal pump geometry at operating conditions spanning the VAD COU envelope.",
      "rationale": "Validation experiments conducted on FDA generic centrifugal pump at 2000, 2500, and 3000 RPM across flow rates of 3, 5, and 7 LPM, fully spanning the 5 COU operating points. Geometry is identical to the computational model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to at least 5 orders of magnitude residual reduction; round-off and solver tolerance effects quantified.",
      "rationale": "All simulations converged to 6 orders of magnitude reduction in continuity and momentum residuals. Solver tolerance study confirms negligible contribution of iterative error relative to discretization error. Double-precision arithmetic used throughout."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition application, and post-processing scripts by a qualified CFD analyst not involved in original analysis.",
      "rationale": "Independent CFD analyst reviewed mesh generation settings, boundary condition assignments, turbulence model selection (SST k-omega), and hemolysis post-processing scripts. No errors identified. Review documented in simulation log v2.3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for selection of turbulence model and hemolysis power-law model form, with assessment of model form uncertainty contribution to total prediction uncertainty.",
      "rationale": "SST k-omega turbulence model selected based on literature review of rotating machinery applications. Giersiepen-Wurzinger power-law hemolysis model with Lagrangian particle tracking employed. Model form uncertainty estimated at 8% of predicted NIH via comparison with alternative Bludszuweit model, documented in UQ report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs characterized with probability distributions; Monte Carlo UQ performed propagating input uncertainty to hemolysis index predictions.",
      "rationale": "Comprehensive Monte Carlo uncertainty quantification performed across all model inputs including blood viscosity (log-normal, CV=8%), rotational speed tolerance (uniform ±25 RPM), inlet flow rate (normal, CV=3%), and hemolysis power-law coefficients (normal based on literature meta-analysis). 10,000 Monte Carlo samples propagated through surrogate model. 95th percentile NIH remains below clinical threshold. UQ results fully documented in supplementary report SR-UQ-2024-07."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize measurement variability; minimum n=3 independent runs per operating point.",
      "rationale": "Five independent experimental runs conducted at each of the 5 operating points (n=5 per point, 25 total). Coefficient of variation for NIH measurements ranges from 4.2% to 9.7% across operating points, characterizing aleatory measurement variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Boundary conditions applied in simulation match experimental conditions within documented tolerances; any differences assessed for impact on QoI.",
      "rationale": "Inlet velocity profiles measured via PIV and applied directly as CFD boundary conditions. Rotational speed set to match tachometer readings within ±10 RPM. Fluid temperature maintained within ±0.5°C. Residual differences between experimental and computational input parameters assessed as contributing less than 2% to NIH prediction uncertainty."
    }
  ],
