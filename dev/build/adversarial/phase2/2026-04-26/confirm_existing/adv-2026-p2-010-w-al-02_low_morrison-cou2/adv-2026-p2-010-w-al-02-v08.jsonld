  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed; achieved levels meet or exceed required levels at Model Risk Level 5. Comprehensive Monte Carlo uncertainty quantification performed across all primary model inputs (N=1200 surrogate evaluations), with prediction intervals encompassing all experimental hemolysis measurements. Output comparison error (mean E_rel=14.7%) is within the pre-specified 20% acceptance threshold. Software quality, code verification, and discretization error controls are documented and adequate. The CFD model is accepted as sufficiently credible to support the hemolysis safety claim for the Class III VAD device under the stated COU.",
