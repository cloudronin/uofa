  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 is accepted on the basis that Monte Carlo uncertainty quantification has been comprehensively performed across all model inputs, providing an uncertainty envelope on hemolysis predictions at all 5 operating points. The UQ results demonstrate that the 95th percentile NIH prediction remains below the clinical threshold of 0.01 g/100 L at all operating conditions. Several credibility factors remain below required levels, but the UQ envelope is judged sufficient to bound the risk for regulatory submission. Outstanding gaps in model form, use error, and equivalency of input parameters are acknowledged and will be addressed in a follow-on assessment.",
