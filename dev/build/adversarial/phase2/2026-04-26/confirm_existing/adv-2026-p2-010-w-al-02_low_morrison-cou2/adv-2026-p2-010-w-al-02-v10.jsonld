  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Configuration management, version control, and regression test suite documented and executed for the CFD solver used in hemolysis prediction.",
      "rationale": "The CFD solver is under formal configuration management with version-controlled source. A regression test suite of 47 canonical cases was executed with no failures prior to the VAD hemolysis simulations. SQA documentation meets the required level for MRL 5 Class III device assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent analytical benchmark confirms spatial and temporal discretization order of accuracy for relevant flow regimes.",
      "rationale": "Method of manufactured solutions confirms second-order spatial accuracy for the incompressible Navier-Stokes solver. Temporal accuracy verified against Stokes flow analytical solution. Code verification activities are documented in the solver qualification report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis performed on at least three systematically refined meshes; discretization error reported as percentage of QoI.",
      "rationale": "Grid convergence index analysis performed on three mesh levels (4.2M, 12.1M, 31.8M cells). GCI for hemolysis index QoI is 3.1% on the fine mesh, meeting the required threshold. Mesh refinement study documented with asymptotic convergence confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions for validation data are documented with measured boundary conditions, fluid properties, and operating point tolerances.",
      "rationale": "FDA generic centrifugal pump experimental data includes measured inlet/outlet pressures, flow rates, rotational speed, and blood analog fluid properties. Operating point tolerances are within ±2% of nominal. Test conditions are sufficiently characterized for use as validation boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation metric u_val) computed between model predictions and experimental hemolysis index measurements.",
      "rationale": "Normalized RMS error between CFD-predicted and experimentally measured hemolysis index is 8.4% across five operating points. Validation metric u_val computed per ASME V&V 20 framework. Comparison is within the combined experimental and numerical uncertainty band at four of five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index) are identical to or directly translatable to QoIs required by the COU decision.",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) — used in both validation activities and COU predictions is identical. No surrogate or proxy QoI substitution is required. Hemolysis index directly maps to the clinical threshold criterion specified in the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities cover the geometry, flow regime, and operating envelope relevant to the VAD COU; any gaps in coverage are documented and bounded.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is representative of the VAD device geometry. Flow regime (Re 3000–12000) and rotational speed range (2500–4500 RPM) overlap with VAD operating conditions. Minor geometric differences between validation and COU geometries are documented; impact on hemolysis prediction is assessed as negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated with residuals below solver-specified thresholds; round-off error assessed as negligible relative to discretization error.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum equations. Mass conservation error is less than 0.01%. Double-precision arithmetic used throughout; round-off error is confirmed negligible relative to GCI-estimated discretization error of 3.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition application, material property assignment, and solver settings verified against documented simulation plan.",
      "rationale": "An independent CFD analyst reviewed the simulation setup against the pre-approved simulation plan. Boundary condition application, turbulence model selection (SST k-omega), and hemolysis model power-law constants were verified. No discrepancies identified. Review documented in simulation quality record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The mathematical model form (governing equations, turbulence closure, hemolysis constitutive model) is appropriate for the flow physics and hemolysis mechanisms present in the VAD operating envelope.",
      "rationale": "Incompressible Reynolds-averaged Navier-Stokes with SST k-omega closure is appropriate for the transitional-turbulent flow regime in the centrifugal pump. Power-law hemolysis model (Giersiepen-Wurzinger) is the standard constitutive model for shear-induced hemolysis prediction. Model form uncertainty is acknowledged and bounded by the validation comparison results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters are characterized with appropriate distributions; Monte Carlo uncertainty quantification propagates input uncertainty to QoI predictions.",
      "rationale": "All model inputs — including blood viscosity, density, hemolysis model constants (C, alpha, beta), inlet flow rate, and rotational speed — are characterized with probability distributions derived from literature and experimental measurement uncertainty. Comprehensive Monte Carlo UQ with 10,000 samples propagates input uncertainty to hemolysis index predictions, yielding 95th-percentile confidence intervals reported for each operating point. Input distributions are documented in the UQ technical report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation dataset includes sufficient independent test replicates to characterize measurement variability; sample size justification documented.",
      "rationale": "Validation dataset includes n=6 independent experimental replicates at each of five operating points (30 total measurements). Sample size provides sufficient statistical power to characterize measurement variability. Coefficient of variation for hemolysis index measurements is 7.2%, within acceptable bounds for blood analog experiments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations are equivalent to or appropriately mapped from those used in COU simulations; any differences are documented and their impact assessed.",
      "rationale": "Fluid properties (blood analog: glycerol-water mixture) used in validation experiments are mapped to physiological blood properties for COU simulations using established viscosity correction factors. Geometric scaling between FDA generic pump and VAD device is within 5%. Input parameter equivalency assessment documents all differences and confirms their impact on hemolysis index prediction is within the reported uncertainty bounds."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed with achieved levels meeting or exceeding required levels for Model Risk Level 5. Monte Carlo uncertainty quantification has been performed comprehensively across all model inputs, with 95th-percentile hemolysis index predictions remaining below the absolute clinical threshold at all five operating points. Validation activities demonstrate adequate agreement with experimental data within combined uncertainty bounds. The credibility evidence package is accepted as sufficient to support the VAD hemolysis regulatory submission.",
