  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented version control, regression testing suite, and formal code review process with traceability to solver release.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has documented release notes and a regression test suite, but the hemolysis user-defined function (UDF) implementing the power-law damage model lacks formal code review records and unit test coverage. Achieved level 2 against required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing on canonical benchmark problems with documented convergence rates matching theoretical expectations.",
      "rationale": "Order-of-accuracy verification was performed on a lid-driven cavity benchmark confirming second-order spatial convergence. However, the hemolysis transport scalar equation was not subjected to manufactured-solution verification. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 2% for all quantities of interest with Richardson extrapolation applied.",
      "rationale": "Three-level mesh refinement study yields GCI values of 2.8–3.9% for NIH at the five operating points. Richardson extrapolation applied; discretization uncertainty folded into UQ envelope. Achieved level 3 against required level 4 due to GCI marginally exceeding 2% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions fully characterized with traceable measurement uncertainty for all boundary condition inputs.",
      "rationale": "FDA pump experimental data provides flow rate and rotational speed but inlet fluid temperature and hematocrit were not systematically varied or reported with calibrated uncertainty. Boundary condition uncertainty is estimated from literature ranges rather than direct measurement. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E_rel) computed with experimental uncertainty bars; systematic bias identified and corrected or bounded.",
      "rationale": "NIH predictions compared against experimental values at 5 operating points. Mean relative error 18% with a consistent positive bias (over-prediction). Bias correction not applied; the UQ envelope is wide enough to encompass experimental values but the systematic over-prediction is unresolved. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest in validation study are identical to or directly transformable from the COU decision quantity.",
      "rationale": "Validation QoI is NIH computed from the same power-law damage model used in the COU. The clinical threshold is expressed in the same units. Minor discrepancy arises because validation data use bovine blood while COU applies to human blood; correction factor applied from literature. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating range, and fluid properties span the full COU operating envelope.",
      "rationale": "Validation performed on FDA generic pump geometry, which differs from the specific VAD impeller geometry in blade count and tip clearance. Operating points partially overlap COU envelope but do not cover the highest-speed VAD condition. Geometry extrapolation is a significant gap at MRL 5. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; floating-point round-off analysis documented.",
      "rationale": "Solver residuals were monitored to 1e-4 for continuity and momentum; the hemolysis scalar residual was not separately tracked. No round-off analysis was performed. Factor flagged as not-assessed at MRL 5 requirement level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition assignment, and post-processing scripts by a reviewer not involved in model development.",
      "rationale": "No independent review of simulation setup was performed. The same analyst who built the model also executed and post-processed all runs. Use error factor not assessed; flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of turbulence closure and hemolysis model form alternatives with documented justification for selected model.",
      "rationale": "The k-omega SST turbulence model and Giersiepen power-law hemolysis model were adopted without systematic comparison to alternative closures (e.g., k-epsilon realizable, Zhang hemolysis model). Model form uncertainty is subsumed informally into the Monte Carlo UQ via parameter variation but alternative model forms were not evaluated. Not assessed at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs characterized with probability distributions derived from measurements or certified reference data; distributions propagated via Monte Carlo.",
      "rationale": "Monte Carlo UQ propagates distributions for viscosity, flow rate, rotational speed, and hemolysis power-law parameters. Distributions for viscosity and power-law coefficients are sourced from literature meta-analysis rather than device-specific measurements. Achieved level 2 against required level 4; input characterization is literature-derived rather than measurement-based."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog or whole-blood samples characterized for hematocrit, plasma viscosity, and red cell fragility with traceability to lot-specific measurements.",
      "rationale": "Experimental validation used bovine blood from a single lot; hematocrit and red cell fragility were not reported with lot-specific traceability. Sample characterization insufficient for MRL 5 requirement. Not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative mapping between experimental boundary conditions and CFD boundary conditions with uncertainty in the mapping documented.",
      "rationale": "Inlet velocity profiles in the CFD model are assumed uniform; the experimental inlet condition was a straight tube with unknown development length. No quantitative equivalency analysis between experimental and computational boundary conditions was performed. Not assessed at required level 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-conditional",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 concludes that the CFD model is accepted for the stated VAD hemolysis prediction use under the following conditions: (1) Monte Carlo uncertainty quantification across all model inputs has been completed and the 95th-percentile NIH remains below the clinical threshold at all five operating points, providing probabilistic assurance of patient safety margin; (2) discretization error is bounded and included in the UQ envelope; (3) all identified credibility factor gaps are documented as accepted residual risk given the conservative UQ bounds. The decision team acknowledges that 6 of 13 factors were not fully assessed to required levels; however, the comprehensive Monte Carlo UQ is judged sufficient to bound the combined effect of these gaps for the purposes of this submission. Conditional acceptance is granted pending independent review of simulation setup prior to final regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
