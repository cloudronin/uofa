    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/monte-carlo-uq-samples-cou2"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cou2-hemolysis-experimental-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against experimental measurements at 5 operating points. Mean absolute error across operating points is 18%, within the accepted tolerance band for MRL 5 assessments. Monte Carlo UQ envelopes encompass all experimental observations."
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-mesh-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence index assessment for centrifugal pump geometry",
      "description": "Three-level mesh refinement study performed on the FDA centrifugal pump geometry. GCI values below 4% for velocity magnitude and wall shear stress at all operating points. Discretization error estimated and folded into total prediction uncertainty."
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification across all model inputs",
      "description": "Comprehensive Monte Carlo UQ performed with 10,000 samples propagating variability in fluid viscosity, inlet flow rate, rotational speed, and hemolysis power-law exponent and coefficient. Output distributions of NIH at each operating point reported. 95th-percentile NIH values remain below clinical hemolysis threshold at all 5 operating conditions."
    }
  ],
