  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Monte Carlo uncertainty quantification was performed comprehensively across all model inputs, propagating variability in viscosity, pump speed, flow rate, and hemolysis power-law coefficients through the CFD solver. All 13 credibility factors have been assessed; factors with gaps are documented. Decision: Accepted with conditions.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "hasUncertaintyQuantification": true,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/cou2-hemolysis-below-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis",
