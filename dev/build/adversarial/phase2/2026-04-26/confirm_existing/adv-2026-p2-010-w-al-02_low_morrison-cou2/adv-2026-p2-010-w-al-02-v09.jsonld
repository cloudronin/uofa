  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required gradations at MRL 5, the comprehensive Monte Carlo uncertainty quantification across all model inputs provides sufficient confidence in the hemolysis index predictions. The seven assessed factors demonstrate adequate coverage of verification and validation activities, and the UQ envelope bounds the clinical threshold with acceptable margin. The six unassessed factors represent acknowledged epistemic gaps that are accepted given the UQ coverage.",
