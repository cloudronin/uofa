    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression test suite, and issue tracking consistent with MRL 5 requirements.",
      "rationale": "ANSYS Fluent 2022R2 was used under a validated QA plan including version-locked builds, automated regression tests across 42 canonical cases, and a tracked defect log. Achieved level meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through manufactured solution or benchmark comparison.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes equations; L2 error norms confirm second-order spatial convergence. Hemolysis power-law source term verified against analytical integral for Couette flow. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be computed on at least three systematically refined meshes; GCI for hemolysis QoI must be below 5%.",
      "rationale": "Three-level mesh refinement (4.2M, 11.7M, 28.9M cells) performed for the 2500 RPM / 5 LPM operating point. GCI for normalized index of hemolysis is 3.1%, below the 5% threshold. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with measurement uncertainty for all boundary condition inputs used in the CFD model.",
      "rationale": "FDA pump experimental campaign documented flow rate (±0.05 LPM), inlet pressure (±0.5 mmHg), rotational speed (±10 RPM), and blood analog viscosity (±2%). All boundary conditions traceable to calibrated instrumentation. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty) must account for both experimental and numerical uncertainty at each operating point.",
      "rationale": "Validation comparison performed at all 5 operating points using the ASME V&V 20 validation uncertainty framework. Maximum absolute error in normalized index of hemolysis is 18% with validation uncertainty of ±22%, confirming model is within validation uncertainty bounds. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation must be the same metric used in the COU decision (absolute hemolysis index), not a surrogate.",
      "rationale": "Normalized index of hemolysis (NIH) in mg/100L is the direct clinical decision QoI and the validation QoI. No surrogate metrics used. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions must correspond to the COU device and operating envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump — the same geometry used in the COU. Blood analog (glycerin-water) used in experiments; scaling to whole blood viscosity documented. Operating points span the VAD clinical envelope. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated; residuals and monitored QoI must reach stable values before solution is accepted.",
      "rationale": "All simulations run to residual convergence below 1e-5 for continuity and momentum; hemolysis QoI monitor confirmed stable to within 0.1% over final 500 iterations. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition and material property inputs must be verified against source documentation.",
      "rationale": "Independent analyst review of mesh, boundary conditions, and solver settings completed prior to production runs. Input deck version-controlled and diff-checked against validated reference case. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence and hemolysis model selection must be justified relative to the flow physics; alternative model forms must be considered.",
      "rationale": "SST k-omega turbulence model selected based on literature evidence for rotating confined flows. Giersiepen-Wurzinger power-law hemolysis model used; Arora and modified Bludszuweit models evaluated as alternatives — all within 20% for NIH at design point. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs must be characterized with probability distributions; Monte Carlo uncertainty quantification must propagate input variability to the hemolysis QoI.",
      "rationale": "Comprehensive Monte Carlo uncertainty quantification performed across all model inputs including blood viscosity, power-law hemolysis coefficients (C, alpha, beta), pump rotational speed tolerance, and inlet flow rate variability. Ten thousand Monte Carlo samples propagated through the CFD surrogate to produce NIH output distributions at each operating point. Ninety-fifth percentile NIH confirmed below clinical threshold at all five operating conditions. Achieved level 4.",
      "hasUncertaintyQuantification": true
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental data used for validation must include replicate measurements to characterize repeatability.",
      "rationale": "FDA pump experimental dataset includes triplicate hemolysis measurements at each of the 5 operating points. Inter-run coefficient of variation below 8% for all points. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Differences between validation experiment inputs and COU inputs must be documented and their effect on the QoI must be bounded.",
      "rationale": "Blood analog viscosity differs from whole blood; correction factor derived from Stokes flow scaling applied and documented. Pump wall roughness in COU device within 15% of validation geometry roughness; sensitivity of NIH to roughness bounded by parametric sweep. Achieved level 3."
    }
  ],
