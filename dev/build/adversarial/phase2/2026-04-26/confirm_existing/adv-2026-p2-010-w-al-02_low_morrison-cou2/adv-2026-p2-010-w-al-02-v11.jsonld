  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite achieved credibility factor levels falling below required levels across all 7 assessed factors and 6 factors remaining not assessed, the comprehensive Monte Carlo uncertainty quantification across all model inputs provides sufficient characterization of output prediction uncertainty to support conditional acceptance at Low assurance level. The UQ results demonstrate that the 95th-percentile hemolysis index prediction remains below the clinical threshold across all 5 operating points. Remediation plan required for MRL 5 gaps prior to regulatory submission.",
