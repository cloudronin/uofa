  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the model for the stated COU based on the completion of comprehensive Monte Carlo uncertainty quantification across all 11 uncertain input parameters, which characterizes the propagated output uncertainty in the hemolysis index. Achieved credibility factor levels fall below required levels in several factors; however, the UQ campaign is judged to adequately bound the prediction uncertainty for the intended regulatory submission. Six factors remain not assessed, representing acknowledged epistemic gaps that are accepted given the conservative UQ bounds demonstrated by the Monte Carlo analysis.",
