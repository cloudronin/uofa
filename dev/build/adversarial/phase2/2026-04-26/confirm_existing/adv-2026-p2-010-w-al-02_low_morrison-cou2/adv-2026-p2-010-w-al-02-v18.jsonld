      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within stated tolerances; fluid properties matched to within 5%.",
      "rationale": "Experimental flow rates and rotational speeds were applied as boundary conditions. However, fluid temperature and hematocrit were held at nominal values rather than sampled from measured distributions, reducing fidelity of boundary condition representation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or normalized RMSE) reported for hemolysis index across all 5 operating points.",
      "rationale": "Normalized RMSE of 14.3% reported across 5 flow-speed combinations for the hemolysis index. Systematic underprediction observed at high flow rates. Achieved level 3 is one grade below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to clinical hemolysis threshold; scalar hemolysis index is the primary regulatory endpoint.",
      "rationale": "The normalized index of hemolysis (NIH) is the direct clinical regulatory endpoint for VAD submissions. The model outputs NIH as a primary quantity, establishing direct QoI relevance. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
