  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at required levels for MRL 5. Monte Carlo uncertainty quantification performed comprehensively across all model inputs with 10,000 samples per operating point; 95% prediction intervals encompass experimental measurements at all 5 operating conditions. Quantitative output comparison (MAPE 9.3%) satisfies acceptance criterion. Model form, discretization, and solver error factors all meet required gradations. The credibility evidence package is judged sufficient to support the regulatory submission for the Class III VAD hemolysis claim.",
