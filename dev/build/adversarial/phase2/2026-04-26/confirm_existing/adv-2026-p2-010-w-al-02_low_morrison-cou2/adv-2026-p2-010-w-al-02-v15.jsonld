  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing suite, and formal release validation at Gradation 4.",
      "rationale": "Solver is under version control with regression tests covering core flow physics. Formal release validation documentation is incomplete for the hemolysis transport sub-model, leaving achieved level at 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent must confirm correct numerical implementation of governing equations including hemolysis power-law model.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes solver confirms spatial accuracy. Hemolysis power-law transport equation verified against analytical test cases at second-order convergence; one boundary condition variant remains unverified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index QoI at all 5 operating conditions with GCI < 5%.",
      "rationale": "GCI computed via Richardson extrapolation on three mesh levels at all 5 operating points. Four of five conditions achieve GCI < 5%; one high-flow condition yields GCI of 7.2% due to complex trailing-edge separation not fully resolved at feasible mesh density."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope in fluid properties, temperature, and hematocrit within defined tolerances.",
      "rationale": "FDA pump experiments conducted at 37°C with bovine blood at 33% hematocrit. COU specifies human blood at physiological hematocrit range 38–45%. Temperature match is adequate; hematocrit and species differences introduce unquantified bias in power-law coefficients."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and measurement uncertainty at all validated operating points.",
      "rationale": "Predicted hemolysis index within 18% of experimental mean at 4 of 5 operating conditions. At peak RPM condition, prediction exceeds experimental value by 31%, attributed to turbulence model limitation in high-shear impeller region. Monte Carlo UQ bands overlap experimental uncertainty at all points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validated QoI (hemolysis index) must be the same metric used in the regulatory acceptance criterion.",
      "rationale": "Normalized index of hemolysis (NIH) is the direct QoI in both the CFD model output and the FDA regulatory threshold. No surrogate or proxy metric is used; direct correspondence confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry under overlapping flow and rotational speed conditions as the COU operating envelope.",
      "rationale": "FDA generic pump geometry used in validation matches COU device geometry. Operating conditions span 3 of 5 COU flow-speed combinations directly; remaining 2 conditions interpolated from validated range. Interpolation introduces moderate extrapolation uncertainty not separately characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to at least 5 orders of magnitude residual reduction for all governing equations at each operating condition.",
      "rationale": "Momentum and continuity residuals converge 6 orders of magnitude at all conditions. Hemolysis scalar transport residual achieves only 3 orders of magnitude reduction at two operating points due to near-wall stiffness in high-shear regions; solver error contribution to QoI not formally bounded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of boundary condition setup, mesh generation decisions, and post-processing scripts.",
      "rationale": "Simulation workflow documented in internal technical report. Independent reviewer confirmed boundary condition setup and post-processing. Mesh generation decisions were reviewed by original analyst only; no independent mesh quality audit performed at MRL 5 standard."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification required for turbulence model selection and hemolysis power-law exponent choice with comparison to alternative model forms.",
      "rationale": "SST k-omega turbulence model selected based on prior pump literature. Hemolysis power-law coefficients taken from Giersiepen et al. without comparison to Heuser-Opitz or Zhang formulations. Model form uncertainty from coefficient selection is absorbed into Monte Carlo UQ input distributions rather than evaluated as a structural model form error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs must be characterized with probability distributions derived from measurement data or literature; distributions propagated through Monte Carlo UQ.",
      "rationale": "Fourteen model inputs assigned probability distributions: viscosity, density, hematocrit, power-law coefficients (alpha, beta), inlet velocity profile, rotational speed tolerance, and geometric manufacturing tolerances. Distributions propagated via 10,000-sample Monte Carlo yielding 95th-percentile hemolysis index bounds. Input distributions are characterized but the relative contribution of each input to output variance is not ranked or reported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must include sufficient replicates to estimate measurement uncertainty at each operating condition.",
      "rationale": "Three replicate experimental runs available at each of 3 operating conditions; only single runs available at 2 conditions. Statistical uncertainty estimate for single-run conditions relies on assumed repeatability from adjacent conditions rather than direct measurement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the validated model must match those of the COU model within documented tolerances; discrepancies must be bounded.",
      "rationale": "Fluid viscosity and density match COU specification within 3%. Hemolysis power-law coefficients derived from bovine blood experiments are applied to human blood COU without species correction factor; this discrepancy is noted but not formally bounded as a bias term in the uncertainty budget."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed. Achieved levels fall below required levels at 9 of 13 factors, reflecting the stringency of MRL 5 requirements. However, comprehensive Monte Carlo uncertainty quantification across all 14 model inputs has been completed, and the 95th-percentile hemolysis index prediction remains below the absolute clinical threshold at all 5 operating conditions. The assessment team judges that the UQ coverage of input variability provides sufficient confidence in the hemolysis prediction for regulatory submission, notwithstanding individual factor gaps. Decision: Accepted with conditions that identified gaps be addressed in the next model update cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
