      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow and scalar-transport benchmarks demonstrate expected convergence rates.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes and power-law hemolysis scalar transport. Observed second-order spatial convergence confirmed on three systematically refined grids."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all five operating points; GCI below 5% for hemolysis index QoI.",
      "rationale": "Three-level structured hex mesh refinement study performed at each operating point. Grid Convergence Index for hemolysis index ranged 1.8–4.3%, below the 5% acceptance threshold at all conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
