      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, flow rate, rotational speed) documented with calibrated instrumentation and traceability to NIST standards.",
      "rationale": "All five bench test points conducted with bovine blood at 37 °C ± 0.5 °C, hematocrit 33 ± 1%. Flow rates and impeller speeds measured with calibrated Coriolis meter and optical tachometer traceable to NIST. Test protocol registered prior to data collection."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement ≥ 0.90 and mean absolute percentage error ≤ 15% for hemolysis index across all five operating points, with experimental uncertainty bounds reported.",
      "rationale": "Predicted hemolysis index versus measured values at five operating points: MAPE = 9.7%, NIA = 0.93. All predictions fall within combined experimental and numerical uncertainty bands. Comparison conducted blind to model tuning."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index QoI is directly mapped to the clinical endpoint (plasma free hemoglobin accumulation rate) with documented physiological linkage.",
      "rationale": "The normalized index of hemolysis (NIH) computed by the model maps directly to plasma free hemoglobin via the ASTM F1841 formula. Clinical relevance confirmed by hematologist review. No surrogate QoI substitution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the identical FDA generic centrifugal pump geometry at the five COU operating points; no geometric or operating-condition extrapolation required.",
      "rationale": "Validation and COU share identical pump geometry, fluid properties, and operating envelope. No geometric scaling or operating-point interpolation is required. Validation is direct rather than analogical."
    },
    {
