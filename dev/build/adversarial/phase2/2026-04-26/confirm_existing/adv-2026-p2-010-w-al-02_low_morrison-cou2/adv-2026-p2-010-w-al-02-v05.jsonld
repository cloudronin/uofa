      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model selection justified by literature evidence and sensitivity to model-form alternatives documented.",
      "rationale": "SST k-ω turbulence closure selected based on published benchmark performance for rotating confined flows. Giersiepen-Wurzinger power-law hemolysis model chosen over alternatives based on systematic literature comparison. Model-form uncertainty acknowledged and bounded by comparison of two hemolysis model variants at the nominal operating point."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and boundary-condition inputs characterized with probability distributions derived from measurement data; Monte Carlo propagation yields 95th-percentile hemolysis index bounds.",
      "rationale": "Blood viscosity, hematocrit, inlet velocity profile, and impeller speed each assigned probability distributions from repeated measurement campaigns. Comprehensive Monte Carlo sampling across all inputs (10,000 samples per operating point) propagates input uncertainty to hemolysis index distributions. The 95th-percentile NIH prediction remains below the clinical threshold at all five operating points, supporting the acceptance decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
