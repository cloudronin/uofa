  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction is accepted with documented deficiencies noted for regulatory transparency. Comprehensive Monte Carlo uncertainty quantification has been performed across all model inputs, and output uncertainty bounds are reported for all five operating points. While achieved credibility factor levels fall below required levels at MRL 5 across all 13 factors, the UQ results provide quantified confidence bounds on hemolysis index predictions that support the regulatory submission with acknowledged limitations. The assessment team accepts the package as a complete and transparent record of current model credibility status, with all gaps formally documented for regulatory review.",
