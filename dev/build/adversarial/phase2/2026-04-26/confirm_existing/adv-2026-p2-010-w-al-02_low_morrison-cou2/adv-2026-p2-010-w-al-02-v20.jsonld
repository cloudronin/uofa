      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification performed for all governing equations including hemolysis transport.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not extended to the hemolysis scalar transport equation. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index reported for hemolysis index QOI; GCI < 5% at all operating points.",
      "rationale": "Three-level grid convergence study performed using Richardson extrapolation; GCI for hemolysis index ranged 8–14% across operating points, exceeding the 5% threshold. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
