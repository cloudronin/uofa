      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QOI (normalized index of hemolysis) maps directly to the clinical decision threshold without requiring untested extrapolation.",
      "rationale": "The normalized index of hemolysis is the same metric used in the clinical acceptance criterion. No surrogate or proxy QOI is employed. Direct correspondence between computational output and regulatory threshold is established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
