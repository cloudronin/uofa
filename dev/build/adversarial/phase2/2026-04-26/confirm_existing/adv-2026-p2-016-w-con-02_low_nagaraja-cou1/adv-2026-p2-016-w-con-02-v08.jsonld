  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-cdrh",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved gradation 2 vs. required 3) is acknowledged and accepted on the basis that ASTM F1717 specifies a single standardized test configuration, making multi-condition testing impractical without departing from the regulatory standard. All quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%) are satisfied for all three QoIs. The overall credibility evidence is sufficient to support the regulatory submission decision.",
