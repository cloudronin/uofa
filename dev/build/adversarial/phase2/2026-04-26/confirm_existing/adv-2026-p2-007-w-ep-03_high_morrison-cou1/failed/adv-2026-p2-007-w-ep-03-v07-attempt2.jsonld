      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented regression test suite passing at release.",
      "rationale": "ANSYS Fluent 2023R2 is used under a validated software management plan. All regression tests pass and version is locked for this analysis. SQA documentation archived in project repository."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems with known analytical solutions.",
      "rationale": "Fluent has been verified against lid-driven cavity and Poiseuille flow benchmarks. Order-of-accuracy tests confirm second-order spatial convergence consistent with the discretization scheme."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for the primary quantity of interest (hemolysis index).",
      "rationale": "Three-level mesh refinement study performed at 4M, 8M, and 16M cells. GCI for the normalized hemolysis index is 2.8%, satisfying the 5% threshold. Richardson extrapolation confirms asymptotic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate the five target flow-speed operating points within ±5% of nominal values.",
      "rationale": "In vitro hemolysis experiments were conducted at all five COU operating points (2–6 L/min, 2000–3500 RPM). Flow and speed measurements are within 3% of nominal. Temperature maintained at 37°C ± 0.5°C throughout."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index RH must agree with experimental measurements within 15% across all five operating points.",
      "rationale": "RH predictions range from 0.71 to 0.94 across the five operating points. Maximum deviation from experimental RH values is 11.3%. All five predictions satisfy RH < 1.0 acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (relative hemolysis index) must be directly linked to the clinical decision endpoint of pump-induced hemolysis risk.",
      "rationale": "The normalized hemolysis index is the accepted metric per ASTM F1841 and FDA guidance for blood pump hemolysis assessment. RH directly quantifies hemolysis relative to the predicate device, making it the appropriate COU decision metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and blood analog fluid as the COU model.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry with porcine blood. COU simulations use the identical CAD geometry and Newtonian blood properties calibrated to match porcine blood viscosity at clinical hematocrit. Geometric and fluid relevance is confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver iterative convergence monitoring is sufficient.",
      "rationale": "At Model Risk Level 2, formal numerical solver error quantification beyond residual monitoring is not required. Residuals converge to 1e-6 for all equations. Factor scoped out per MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst qualification review is sufficient.",
      "rationale": "Use error assessment not required at MRL 2. The analysis team holds relevant CFD and biofluid mechanics qualifications. Peer review of simulation setup was conducted internally prior to submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence and hemolysis sub-models must be justified for the Reynolds number regime and shear stress range encountered in the pump.",
      "rationale": "SST k-omega turbulence model selected based on literature benchmarks for rotating turbomachinery at Re 10,000–80,000. Giersiepen-Wurzinger power-law hemolysis model applied with Lagrangian particle tracking. Model form uncertainty estimated at ±18% on hemolysis index, acceptable for comparative assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, boundary conditions, fluid properties) must be traceable to measured or documented sources with uncertainty quantification.",
      "rationale": "Pump geometry derived from CMM measurements of production hardware. Inlet velocity profiles from laser Doppler anemometry. Blood viscosity from rotational rheometry at 37°C. Input uncertainty propagation performed via one-at-a-time sensitivity analysis. All inputs traceable to dataset DS-PG-V2, which was collected prior to the November 2025 model revision. The revision addressed impeller tip clearance tolerances; the assessment team judged this change not material to the boundary condition dataset because inlet and outlet flow profiles are upstream of the affected region. No formal re-validation of the boundary condition dataset against the revised geometry was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; single representative pump unit is acceptable.",
      "rationale": "Sample-to-sample variability assessment not required at MRL 2. A single production-representative pump unit was used for all experimental measurements. Factor scoped out per MRL 2 assessment framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; direct parameter mapping between simulation and experiment is documented.",
      "rationale": "Formal equivalency assessment not required at MRL 2. Simulation input parameters are mapped directly to experimental conditions via the test protocol. No surrogate materials or scaled geometries were used."
    }
