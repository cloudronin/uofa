  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented QA procedures and regression test suite.",
      "rationale": "ANSYS Fluent 2023 R2 is used under an institutional software QA plan. Version control is maintained via Git; regression tests covering 12 canonical flow cases are executed at each solver update. All tests pass within specified tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test demonstrates solver achieves theoretical convergence rate for at least one benchmark case relevant to rotating machinery.",
      "rationale": "Method of manufactured solutions applied to a rotating annular flow benchmark confirms second-order spatial accuracy (observed order 1.93). Code verification report CVR-2024-07 documents results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for wall shear stress and velocity magnitude must be less than 5% at the operating point of peak hemolysis.",
      "rationale": "Three-level mesh refinement study (4.2M, 10.1M, 22.8M cells) performed at the 6 LPM / 3500 RPM operating point. GCI for volume-averaged shear stress: 2.8%; GCI for peak velocity: 3.1%. Richardson extrapolation confirms asymptotic convergence. Medium mesh (10.1M cells) selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within ±5% for flow rate, rotational speed, and fluid viscosity.",
      "rationale": "PIV experiments conducted at matched Reynolds number conditions. Flow rate controlled to ±1.5%, rotational speed to ±0.3%, and glycerol-water analog fluid viscosity characterized within ±2.1% of target. Boundary condition correspondence documented in test report TR-2025-03."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Velocity magnitude comparison metric (E3) must be less than 10% across the PIV measurement plane; hemolysis index must agree within 15% of bench measurements.",
      "rationale": "E3 velocity comparison metric: 7.4% averaged across all five operating points. Normalized index of agreement for hemolysis: 0.91. All five flow-speed combinations satisfy acceptance criteria. Comparative assessment documented in validation report VR-2025-11."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) must be directly linked to the clinical endpoint and computable from model outputs without additional unvalidated transformations.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is applied directly to CFD-predicted shear stress and exposure time fields. RH is computed as the ratio of predicted hemolysis index to predicate device value. This QoI is the same metric used in FDA guidance for blood-contacting device assessment and requires no additional transformation steps."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operational envelope (flow rate 4–8 LPM, speed 3000–4500 RPM) and use a geometrically representative pump model.",
      "rationale": "Validation activities span five operating points within the COU envelope. The FDA generic centrifugal pump geometry is used for both CFD and physical experiments. Analog blood fluid is characterized to match whole blood viscosity at 37°C. Validation relevance score assessed as adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance applies.",
      "rationale": "Numerical solver error beyond discretization and code verification is not required to be separately quantified at Model Risk Level 2 for this application. Residual convergence to 1e-6 is documented for all runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records serve as surrogate.",
      "rationale": "Formal use-error analysis not required at MRL 2. Lead analyst holds CFD certification and has conducted five prior hemolysis assessments under institutional review. Training records on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection is documented in modeling report.",
      "rationale": "SST k-omega turbulence model selected based on published literature for rotating blood pump applications. Formal model form uncertainty quantification not required at MRL 2. Selection rationale documented in modeling plan MP-2025-02."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and geometric input parameters must be traceable to measured values or published reference data; uncertainty in key inputs (viscosity, density, pump geometry) must be characterized.",
      "rationale": "Fluid properties (density 1056 kg/m³, dynamic viscosity 3.5 mPa·s) are sourced from the PIV experimental characterization dataset (dataset ID: morrison-piv-experimental-dataset, dataVintage 2025-10-22T00:00:00Z). The model was revised on 2025-11-14 to incorporate updated impeller tip clearance geometry following manufacturing metrology feedback; the fluid property dataset predates this revision by 23 days. The modeling team assessed that the geometry revision did not alter the fluid domain boundary conditions or the fluid property requirements, and concluded the pre-revision characterization data remained applicable without re-measurement. No formal re-validation was performed following the November revision. Geometric inputs are sourced from CMM measurements of the physical test article (uncertainty ±0.05 mm). Inlet turbulence intensity set to 5% based on upstream flow conditioning data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Sample-to-sample variability assessment not required at MRL 2. Single physical test article used for all validation experiments; dimensional conformance verified by CMM."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; correspondence between validation and COU inputs documented qualitatively.",
      "rationale": "Validation and COU input parameter correspondence assessed qualitatively. Fluid analog matches whole blood rheology within published acceptable ranges. Rotational speed and flow rate ranges are identical between validation experiments and COU envelope."
