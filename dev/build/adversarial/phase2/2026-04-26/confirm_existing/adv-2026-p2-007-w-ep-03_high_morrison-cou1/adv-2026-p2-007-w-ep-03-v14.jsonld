  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors are appropriately scoped out at MRL 2. The model inputs factor is assessed as meeting requirements; the fluid property dataset predating the November 2025 model revision by 23 days was reviewed and the revision was determined by the modeling team to be limited to impeller tip clearance geometry, which does not affect fluid property boundary conditions. The assessment team accepted this determination without requiring formal re-validation, noting the change was characterized as not material to dataset relevance. Validation results demonstrate adequate agreement with experimental data across all five operating points. The relative hemolysis index satisfies RH < 1 at all evaluated conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
