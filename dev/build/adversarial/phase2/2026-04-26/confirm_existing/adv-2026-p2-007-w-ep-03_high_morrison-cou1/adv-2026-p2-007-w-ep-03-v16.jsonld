  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped to not-assessed at MRL 2. Validation evidence demonstrates RH index prediction within 8.3% of experimental measurements across all operating points, well within the 15% acceptance criterion. The model revision of 2025-11-14 updated impeller blade geometry tolerances; the assessment team reviewed the change and concluded it does not affect the validity of the inlet boundary condition and fluid property datasets acquired prior to revision. On this basis the credibility assessment is accepted and the model is considered fit for the stated COU.",
