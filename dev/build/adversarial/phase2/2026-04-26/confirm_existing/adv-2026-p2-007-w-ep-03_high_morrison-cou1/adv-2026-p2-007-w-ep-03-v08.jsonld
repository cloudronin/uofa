  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors not assessed per MRL 2 scoping; all have documented justifications. The primary experimental hemolysis dataset (vintage 2025-11-03) predates the model revision of 2025-11-24 by 21 days. The assessment team reviewed the revision change log and concluded that the beta* coefficient adjustment in the k-omega SST closure (0.3 % change) would not materially alter hemolysis QoI predictions given the flow regime. On this basis the team accepted the existing dataset comparison without re-running validation against the revised solver build. No formal sensitivity analysis of the coefficient change on RH was performed. Overall credibility evidence is judged sufficient to support the regulatory submission decision at Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
