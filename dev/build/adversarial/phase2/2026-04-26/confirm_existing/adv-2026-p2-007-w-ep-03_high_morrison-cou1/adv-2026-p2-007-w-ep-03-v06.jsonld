  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are appropriately scoped out at MRL 2. The model correctly identifies worst-case hemolysis conditions across the COU operating envelope, with NIH predictions within 17% of experimental values and RH < 1 for all predicate comparisons. The geometry revision (revision A to revision B) that post-dated the experimental dataset was reviewed by the engineering team and judged not material to the hemolysis prediction, as the fillet radius change is localised to the blade trailing edge and does not affect bulk flow patterns at the validation operating points. On this basis the credibility assessment is accepted at Medium assurance level for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
