  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and version control; solver release notes reviewed for relevant physics modules.",
      "rationale": "ANSYS Fluent 2023 R2 is used under an ISO 9001-certified QA framework. Solver validation reports for rotating machinery and non-Newtonian blood rheology are on file. Version control is maintained via institutional GitLab repository with tagged release corresponding to this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarks for laminar and turbulent rotating-frame flow reproduce analytical or published reference solutions within 1% for relevant Reynolds number range.",
      "rationale": "Code verification against Taylor-Couette and rotating-disk analytical solutions confirms discretisation implementation is correct. Residual convergence to 1e-6 enforced for all continuity and momentum equations. Published ASME benchmark cases for internal rotating flows reproduced within 0.8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI less than 5% on the fine grid; Richardson extrapolation applied across three systematically refined meshes.",
      "rationale": "Three mesh levels (4.2 M, 9.8 M, 21.6 M elements) were run at the nominal operating point (5 L/min, 3500 RPM). GCI on the normalized index of hemolysis (NIH) is 3.1% on the fine mesh. Apparent order of convergence p=1.94 is consistent with second-order spatial discretization. Medium mesh (9.8 M) adopted for production runs as GCI remains below 5%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis loop conditions (fluid temperature, hematocrit, anticoagulant protocol, pump speed tolerance) documented and match simulation boundary conditions within stated uncertainty bounds.",
      "rationale": "In-vitro loop experiments conducted at 37 ± 0.5 °C with bovine blood at 35 ± 2% hematocrit per ASTM F1841. Pump speed held at ± 10 RPM of target. All test conditions are documented in laboratory notebook LN-2024-CPB-07 and match CFD boundary conditions within measurement uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated NIH values agree with experimental measurements within ± 20% across all 5 operating points; RH index correctly ranks worst-case condition.",
      "rationale": "Across the five flow-speed combinations, simulated NIH deviates from experimental values by 4%–17% (mean 11%). The model correctly identifies the 3 L/min, 4000 RPM condition as worst-case for hemolysis, consistent with experimental ranking. RH < 1 criterion met for all predicate comparisons."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH and RH index) directly maps to the clinical endpoint of blood trauma; linkage between shear-stress exposure integral and erythrocyte damage is established by literature power-law model.",
      "rationale": "NIH and RH are the accepted regulatory QoIs for CPB hemolysis assessment per FDA guidance. The Giersiepen-Wurzinger power-law damage accumulation model links computed shear stress trajectories to erythrocyte lysis, providing a direct mechanistic connection to the clinical endpoint."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same FDA generic centrifugal pump geometry, same blood analogue fluid properties, and span the COU operating envelope.",
      "rationale": "Validation experiments were performed on the FDA generic centrifugal blood pump geometry (identical to the COU device geometry). The operating envelope (2–6 L/min, 2500–4500 RPM) fully encompasses the five COU operating points. Fluid properties match the Newtonian blood analogue used in the computational model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; solver error subsumed within code verification activities.",
      "rationale": "At Model Risk Level 2, explicit quantification of numerical solver error beyond code verification benchmarks is not required. Solver error contributions are implicitly bounded by the GCI analysis and benchmark comparisons documented under the Numerical Code Verification factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation execution checklist and peer review provide sufficient control.",
      "rationale": "At MRL 2, formal use error quantification is not required. Simulation setup was independently peer-reviewed by a second CFD engineer. An execution checklist covering boundary condition assignment, turbulence model selection, and post-processing scripts was completed and archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form uncertainty addressed qualitatively through literature support for SST k-omega turbulence model in similar pump geometries.",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2. The SST k-omega turbulence model is supported by published literature for centrifugal blood pump simulations. Qualitative justification is documented in the modelling assumptions register."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, fluid properties, rotational speed, inlet/outlet boundary conditions) traceable to measured or published values with stated uncertainty.",
      "rationale": "Pump geometry digitised from manufacturer-supplied CAD files (revision B, released 2025-10-22). Blood viscosity modelled as Newtonian with dynamic viscosity 0.0035 Pa·s per published literature mean. Inlet boundary conditions (flow rate, pressure) sourced from the experimental dataset referenced in bindsDataset. The experimental hemolysis dataset (dataVintage 2025-10-21) was collected under the prior model geometry (revision A) and pre-dates the geometry update to revision B (modelRevisionDate 2025-11-14). The revision B update corrected the impeller blade trailing-edge fillet radius from 0.3 mm to 0.5 mm; the project team judged this change not material to the bulk flow boundary conditions or the NIH calibration dataset, and no formal re-validation against revision B geometry was performed. Input parameter sensitivity to the fillet radius change was assessed informally by engineering judgement rather than by re-running the validation campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterisation documented in experimental protocol.",
      "rationale": "Formal test sample uncertainty quantification is not required at MRL 2. Bovine blood lot characterisation (hematocrit, plasma viscosity, fibrinogen concentration) is recorded in laboratory protocol LP-2024-CPB-03."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; equivalency addressed qualitatively through comparison of simulation and experimental boundary condition tables.",
      "rationale": "At MRL 2, formal equivalency analysis is not required. Simulation and experimental boundary condition tables are compared side-by-side in Appendix C of the V&V report, confirming qualitative alignment of all primary input parameters."
    }
