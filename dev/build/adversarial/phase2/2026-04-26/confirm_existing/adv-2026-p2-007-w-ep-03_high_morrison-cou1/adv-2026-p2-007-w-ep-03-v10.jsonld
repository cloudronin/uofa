      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI on production mesh.",
      "rationale": "Three-level mesh refinement study performed at 2.1M, 6.4M, and 18.7M cells. Richardson extrapolation yields GCI of 3.8% for NIH on the 6.4M production mesh. Temporal convergence verified with time-step halving showing < 1% change in cycle-averaged NIH."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Bench test conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented and matched to simulation boundary conditions within stated tolerances.",
      "rationale": "In-vitro test conditions recorded at 2.5 L/min and 4.0 L/min at 3000 and 3500 RPM. Fluid temperature maintained at 37 ± 0.5°C. Hematocrit 33 ± 1%. All boundary conditions applied in CFD within measured uncertainty bands."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E_rel) < 20% for NIH across all validation operating points.",
      "rationale": "E_rel computed as |NIH_sim - NIH_exp| / NIH_exp. Maximum E_rel across 5 operating points is 13.7% at 3500 RPM / 4.0 L/min. Mean E_rel is 9.2%. Acceptance criterion met at all points."
