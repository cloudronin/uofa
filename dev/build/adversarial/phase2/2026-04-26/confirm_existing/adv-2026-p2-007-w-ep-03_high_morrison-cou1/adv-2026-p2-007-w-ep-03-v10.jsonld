  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out per ASME V&V 40 Table 1. Discretization error GCI of 3.8% and output comparison E_rel of 13.7% both satisfy stated acceptance criteria. The November 2025 model revision updated the impeller-volute sliding mesh interface treatment; the assessment team reviewed the change and concluded it did not materially alter the hemolysis power-law input parameters or bulk flow topology captured in the PIV dataset collected in October 2025. On this basis the existing datasets were retained without re-collection, and the overall credibility package is accepted for regulatory submission supporting the Class II 510(k) filing.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
