      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Use error assessment not required at MRL 2. Simulation team follows institutional simulation governance procedure SOP-CFD-004. Peer review of setup files completed internally."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Model form uncertainty assessment not required at MRL 2. SST k-omega turbulence model selected based on prior literature for rotating hemolysis applications. Formal model form uncertainty quantification deferred to MRL 3 activities."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs (viscosity, density, hemolysis power-law coefficients) sourced from peer-reviewed literature or direct measurement; sensitivity to input uncertainty documented.",
      "rationale": "Blood viscosity and density taken from Brookshier & Tarbell (1993) and confirmed against in-house rheometry. Hemolysis power-law constants (C, alpha, beta) from Giersiepen et al. (1990) as implemented in the Morrison et al. validation corpus. One-at-a-time sensitivity analysis shows NIH varies < 8% across ±10% perturbation of each scalar input. The PIV velocity dataset (dataVintage 2025-10-21) was collected under the prior mesh topology and boundary-condition scheme in place before the November 2025 solver configuration update; the team judged the update — which refined the impeller-volute interface treatment — to be non-material to the hemolysis power-law inputs, and no formal re-validation of the input dataset against the revised model was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Test sample characterization not required at MRL 2. Bovine blood sourced from a single certified supplier lot per test session. Hematocrit and plasma-free hemoglobin baseline recorded prior to each run."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Equivalency of input parameters between validation and COU not formally assessed at MRL 2. Qualitative review confirms operating envelope overlap is adequate for the intended comparative (RH) decision framework."
    }
