  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented test suite results confirming numerical correctness at MRL 2.",
      "rationale": "ANSYS Fluent 2023 R2 is deployed under ISO 9001-compliant quality management. Solver regression test suite (1,200 cases) was executed and archived. Version control records confirm solver build hash matches the production environment used for all CPB simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that the numerical implementation correctly solves the governing equations via benchmark problems at MRL 2.",
      "rationale": "Code verification was performed against three FDA benchmark cases (lid-driven cavity, backward-facing step, and pipe flow). Observed convergence rates matched theoretical expectations for second-order spatial discretization. No anomalous residual behaviour was identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be less than 5% at the operating point used for validation.",
      "rationale": "Three systematically refined meshes (4.1 M, 11.3 M, and 28.7 M cells) were generated using consistent refinement ratio r = 1.4. Richardson extrapolation yielded GCI = 2.8% for the relative hemolysis index at the 5 L/min, 3500 RPM operating point, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must correspond to the COU operating envelope within documented tolerances.",
      "rationale": "In-vitro experiments were conducted at 37 °C ± 0.5 °C using porcine blood with hematocrit 33 ± 2%, matching the COU specification. Flow rates were set by calibrated Coriolis meter (±0.5%). Rotational speed was servo-controlled to ±10 RPM. All five COU flow-speed combinations were covered."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index must agree with experimental measurements within ±15% across all five operating points.",
      "rationale": "Predicted RH values ranged from 0.61 to 0.89 across the five operating points. Agreement with experimental measurements was within 9.4% (mean absolute percentage error), satisfying the ±15% acceptance criterion. Pressure-rise predictions agreed within 4.2% of measured values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation (RH index, pressure rise) must be directly linked to the COU decision criterion.",
      "rationale": "The relative hemolysis index is the primary acceptance criterion for the COU (RH < 1 vs. predicate). Pump pressure rise is a secondary QoI that confirms hydraulic fidelity. Both QoIs are directly used in the regulatory submission. No surrogate QoIs were substituted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the geometry, fluid, and operating conditions representative of the COU.",
      "rationale": "Validation was conducted on the FDA generic centrifugal blood pump geometry — the same geometry used in the COU simulations. Blood analogue fluid properties were matched to the COU specification. Operating conditions spanned the full COU envelope. Validation gap analysis confirmed no unaddressed extrapolation beyond the validated domain."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit quantification of iterative solver error is not required provided residuals meet convergence thresholds.",
      "rationale": "Iterative convergence was monitored via scaled residuals dropping below 1×10⁻⁵ for all transport equations. Mass imbalance was confirmed below 0.01%. Explicit solver error quantification is not required at MRL 2 and was scoped out of the assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use-error assessment is not required; documented simulation protocols and peer review are sufficient.",
      "rationale": "Simulation setup was performed by a PhD-level CFD engineer with 8 years of cardiovascular device experience. An independent senior analyst reviewed boundary condition assignments, turbulence model selection, and post-processing scripts prior to result extraction. No use errors were identified during review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model-form uncertainty quantification is not required; selection rationale is sufficient.",
      "rationale": "The SST k-ω turbulence model was selected based on published FDA benchmark studies demonstrating superior performance for rotating blood-contacting devices. The Giersiepen-Wurzinger power-law hemolysis model was selected per regulatory precedent. Formal model-form uncertainty quantification is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters (geometry, fluid properties, boundary conditions) must be traceable to measured or published sources with documented uncertainty.",
      "rationale": "Pump geometry was derived from the FDA-released CAD files (v3.0, October 2023). Fluid properties were sourced from the hemocompatibility experimental dataset DS01, which was collected under the prior model build (v3r1) and carries a dataVintage of 2025-10-22T00:00:00Z. The model was subsequently revised to v3r2 on 2025-11-14T00:00:00Z to incorporate an updated impeller tip-clearance parameterisation identified during mesh sensitivity analysis. The project team determined that the fluid property measurements in DS01 — viscosity, density, and hematocrit characterisation — are independent of the tip-clearance geometry change and therefore remain applicable to v3r2 without re-measurement. Boundary conditions for all five operating points were set from the experimental flow-rate and rotational-speed records in DS02. This determination was made by engineering judgement and documented in internal memo CFD-MEM-2025-047; no formal re-validation against v3r2 inputs was conducted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterisation of test sample variability is not required.",
      "rationale": "Three independent blood batches were used across the in-vitro hemocompatibility experiments. Batch-to-batch variability in hematocrit was within ±2%, which is within the COU specification tolerance. Formal statistical sample characterisation is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency analysis between validation and COU input parameters is not required beyond documented parameter matching.",
      "rationale": "A parameter mapping table was prepared comparing validation test inputs to COU simulation inputs across all boundary conditions, fluid properties, and geometric parameters. All parameters were confirmed within the COU operating envelope. Formal equivalency uncertainty propagation is not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors were appropriately scoped out at MRL 2 with documented justification. The model inputs factor was assessed at the required level; the project team concluded via engineering judgement that the hemocompatibility dataset DS01 (dataVintage 2025-10-22) remains applicable to model revision v3r2 (2025-11-14) because the intervening geometry change affected only the impeller tip-clearance parameterisation and not the fluid property characterisation on which DS01 bears. This determination is documented in CFD-MEM-2025-047. The overall credibility package supports an Accepted decision for submission to FDA for the CPB device 510(k).",
    "decidedAt": "2026-04-19T00:00:00Z"
