  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped as not-assessed per the MRL 2 requirements table. The assessment team reviewed the November 2024 model revision (r3.1 to r3.2) and concluded that the k-omega SST coefficient adjustment, which reduced turbulent viscosity ratio in the volute by approximately 2.8 %, was not material to the hemolysis QoI. On this basis the team accepted continued reliance on the PIV validation dataset (vintage 2024-11-04) without re-executing the output comparison against the revised build. The overall credibility evidence is judged sufficient to support the COU decision at Medium assurance level.",
