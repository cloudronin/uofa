  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are appropriately scoped as not-assessed at MRL 2. The CFD model demonstrates mean NIH prediction error of 8.3% against FDA benchmark experimental data, well within the 15% acceptance threshold. The November 2025 model revision (impeller tip clearance update) was reviewed by the assessment team and determined to be non-material to the fluid property and hemolysis coefficient inputs sourced from the pre-revision experimental dataset. On this basis, re-collection of experimental data was deemed unnecessary and the credibility package is accepted for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
