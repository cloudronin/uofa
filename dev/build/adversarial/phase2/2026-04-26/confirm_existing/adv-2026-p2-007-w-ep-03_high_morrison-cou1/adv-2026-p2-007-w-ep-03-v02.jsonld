  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 not-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 4. The PIV benchmark dataset (dataVintage 2025-10-22) predates the November 14 2025 turbulence model coefficient revision; however, the assessment team determined this revision was not material to the PIV velocity comparison because the updated near-wall dissipation coefficients affect only the boundary layer region and the PIV measurement planes sample mid-passage flow where the coefficient change produces less than 0.3% difference in predicted velocity magnitude. No formal re-validation against the revised model was conducted. Overall credibility package supports the Accepted decision for COU1 CPB hemolysis prediction.",
