  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are appropriately scoped out at MRL 2. The model revision of 2025-11-14 was reviewed by the assessment team, who determined that the geometric tip-clearance update did not materially affect the blood rheology inputs sourced from the pre-revision dataset (dataVintage 2025-10-21). On this basis, re-characterisation of rheological inputs was not performed. The relative hemolysis index satisfies RH < 1 across all five operating points, and the CFD model is judged credible for identifying worst-case hemolysis conditions in the CPB COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
