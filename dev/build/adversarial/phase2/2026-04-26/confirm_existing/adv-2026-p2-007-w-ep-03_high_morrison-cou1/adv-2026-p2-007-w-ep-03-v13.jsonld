  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented verification test suite and version-controlled input files meet MRL 2 SQA requirements.",
      "rationale": "ANSYS Fluent 2023R2 is employed with a documented verification test suite covering all activated physics modules. Input files and boundary condition scripts are stored under Git version control with tagged releases corresponding to each simulation campaign. SQA documentation package reviewed and approved by the independent QA lead."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark problems (lid-driven cavity, Poiseuille flow) within published tolerances.",
      "rationale": "ANSYS Fluent 2023R2 has been exercised against the lid-driven cavity benchmark (Re = 100, 400, 1000) and fully-developed Poiseuille flow; computed velocity profiles agree with analytical solutions to within 0.4% RMS, satisfying the MRL 2 code-verification threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI is below 5% on the fine-grid solution.",
      "rationale": "A three-level mesh refinement study (coarse 4.2 M, medium 9.8 M, fine 22.1 M hexahedral elements) yields GCI values of 3.1% for the normalised hemolysis index and 2.7% for pressure head, both below the 5% acceptance threshold. The fine mesh is adopted for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) are documented and replicated in the CFD boundary conditions within ±5%.",
      "rationale": "All five flow-speed operating points (2.0–6.0 L/min, 2000–3500 RPM) were reproduced in the CFD model using boundary conditions derived from the experimental test log. Fluid temperature was held at 37 ± 0.5 °C in both test and simulation; hematocrit was matched at 33 ± 1%. Deviations are within the ±5% acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) agrees with experimental measurements within 15% across all five operating points.",
      "rationale": "Predicted RH values range from 0.61 to 0.94 across the five operating points. Comparison against experimental RH measurements from the NIH/FDA benchmark dataset shows agreement within 9.3% maximum deviation and 5.8% mean absolute error, satisfying the 15% acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs (hemolysis index, pressure head, wall shear stress) directly map to the clinical and regulatory decision endpoints.",
      "rationale": "The primary QoI is the normalised hemolysis index (NIH), which directly quantifies red blood cell damage and maps to the regulatory acceptance criterion RH < 1. Secondary QoIs (pressure head and wall shear stress) are mechanistically linked to hemolysis and provide corroborating evidence of model fidelity. All QoIs are established in the ASTM F1841 and ISO 10993-4 frameworks."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry family, operating range, and blood analogue fluid as the COU.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal blood pump using the same impeller-volute geometry family. Operating conditions span the full CPB flow-speed envelope specified in the COU. A porcine blood analogue (33% hematocrit, 3.5 cP viscosity) was used, consistent with the COU fluid specification. Geometric and operational similarity is judged sufficient for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; solver error subsumed under code verification and discretization error assessments.",
      "rationale": "At MRL 2, explicit numerical solver error quantification beyond code verification and discretization error is not required. Iterative convergence was monitored via residual norms (< 1e-5 for all equations) and mass-imbalance checks (< 0.01%), providing sufficient confidence without formal solver-error budgeting."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records and peer-review of setup files are considered sufficient.",
      "rationale": "All analysts hold documented CFD training credentials. Simulation setup files underwent internal peer review prior to production runs. Formal use-error quantification is not required at MRL 2 and is scoped out of this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; turbulence model selection is justified by literature precedent for similar pump geometries.",
      "rationale": "The SST k-ω turbulence model is selected based on published literature demonstrating superior performance for rotating hemodynamic flows at similar Reynolds numbers. Formal model-form uncertainty quantification is not required at MRL 2 and is scoped out of this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs are traceable to documented sources with uncertainty characterised at ±10% or better.",
      "rationale": "Blood viscosity (Carreau-Yasuda model coefficients) and density are sourced from the Morrison et al. (2023) rheology dataset (dataVintage 2025-10-21T00:00:00Z). The model was revised on 2025-11-14T00:00:00Z to incorporate updated impeller tip-clearance geometry following a design change notification; the rheology dataset predates this revision by 24 days. The revision affected only the geometric mesh and rotor-stator interface treatment, and the assessment team judged that the blood rheology inputs remained valid without re-characterisation. This determination was made on engineering judgment rather than a formal re-validation study, and no sensitivity analysis was performed to confirm that the revised tip-clearance geometry does not alter near-wall shear conditions in a manner that would change the effective viscosity regime sampled by the hemolysis model. Boundary conditions (inlet flow rate, outlet pressure, wall rotational velocity) are specified from the experimental test log and are independent of the rheology dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterisation is covered under test conditions factor.",
      "rationale": "Detailed test-sample characterisation (donor variability, storage conditions) is not required at MRL 2. Sample provenance is documented in the experimental test log referenced under the Test Conditions factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; parameter equivalency is addressed qualitatively under relevance of validation activities.",
      "rationale": "Formal equivalency mapping between validation experiment inputs and COU inputs is not required at MRL 2. Qualitative equivalency is addressed in the Relevance of Validation Activities factor, which confirms that operating conditions and fluid properties are matched within acceptable bounds."
    }
  ],
