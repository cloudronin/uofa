      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted velocity profiles agree with PIV measurements within expanded uncertainty; predicted RH index within 15% of bench-measured value.",
      "rationale": "Velocity magnitude profiles at mid-volute plane agree with PIV within 8% mean absolute error. Predicted RH index of 0.71 compared to bench-measured 0.76, a 6.6% difference within the 15% acceptance band."
