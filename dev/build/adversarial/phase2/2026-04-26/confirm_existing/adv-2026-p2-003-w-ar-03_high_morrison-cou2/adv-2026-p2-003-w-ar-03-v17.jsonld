  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team concluded that the CFD hemolysis model provides sufficient credibility for regulatory submission. The observational study spanning five operating points, combined with Monte Carlo uncertainty quantification, was judged to provide experimental grounding functionally equivalent to a controlled bench experiment. The breadth of clinical data and the conservative uncertainty envelopes were cited as compensating factors. All seven assessed credibility factors were reviewed; the six unassessed factors were noted as epistemic gaps but deemed acceptable given the conservative safety margins demonstrated in the output comparison. The requirement for a controlled-experiment verification method was considered satisfied by the observational study on the basis of the narrative equivalence argument.",
