  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/vad-hemolysis-verification-req-01",
    "type": "Requirement",
    "name": "Hemolysis validation verification method requirement",
    "description": "For Model Risk Level 5 Class III VAD devices, the primary validation evidence for absolute hemolysis prediction must be generated by a controlled experiment in which flow rate, rotational speed, fluid temperature, and hematocrit are independently manipulated under ISO 10993-compliant conditions. Observational or registry-based data may supplement but cannot serve as primary verification evidence.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasActivity": [
    {
      "id": "https://uofa.net/synth/activity/vad-hemolysis-observational-study-01",
      "type": "Activity",
      "name": "Clinical hemolysis observational study — 47-patient VAD cohort",
      "description": "Retrospective observational study of 47 patients implanted with the FDA generic centrifugal pump configuration over a 36-month period. Plasma-free hemoglobin (pfHb) and normalized index of hemolysis (NIH) were extracted from clinical laboratory records at 72-hour intervals. Operating conditions (flow rate and pump speed) were recorded from device telemetry. The dataset spans 312 pump-hours and covers all five flow-speed combinations specified in the COU. Statistical regression of NIH against CFD-predicted hemolysis index yielded R²=0.81 (p<0.001), which the assessment team interpreted as strong empirical corroboration of the model's absolute predictive capability. The breadth of physiological variability captured — including hematocrit range 28–44%, temperature variation, and medication co-administration — was cited as evidence that the observational dataset provides a more realistic test of model performance than any bench experiment could achieve.",
      "activityType": "observational-study",
      "performedBy": "https://uofa.net/synth/org/morrison-clinical-data-group",
      "startedAtTime": "2023-06-01T00:00:00Z",
      "endedAtTime": "2024-09-30T00:00:00Z"
    }
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-vr-01",
      "type": "ValidationResult",
      "name": "NIH regression vs CFD hemolysis index — 47-patient cohort",
      "description": "Regression of clinically measured NIH values against CFD-predicted hemolysis index across 312 pump-hours and 47 patients. R²=0.81, RMSE=0.0042 g/100 L. The assessment team concluded that the agreement between observational clinical data and CFD predictions demonstrates sufficient model fidelity for absolute hemolysis acceptance at the specified operating points. This result was cited as the primary validation evidence satisfying the verification requirement for the hemolysis credibility factor.",
      "wasGeneratedBy": "https://uofa.net/synth/activity/vad-hemolysis-observational-study-01",
      "resultValue": 0.81,
      "resultUnit": "R-squared",
      "passesCriteria": true,
      "notes": "Observational dataset encompasses all five COU flow-speed combinations. Team noted that controlled bench experiments were considered but deemed infeasible within project timeline; the observational study was judged to be a suitable equivalent by the internal review panel."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-vr-02",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ — hemolysis index prediction intervals",
      "description": "Monte Carlo uncertainty quantification (N=10,000 samples) propagating inlet velocity uncertainty (±5%), viscosity uncertainty (±3%), and RBC fragility parameter uncertainty (±12%) through the CFD hemolysis model. 95% prediction interval for NIH at worst-case operating point: [0.0031, 0.0089] g/100 L, below the clinical threshold of 0.010 g/100 L. Supports the conclusion that model predictions remain below the acceptance threshold even under parametric uncertainty.",
      "wasGeneratedBy": "https://uofa.net/synth/activity/vad-hemolysis-observational-study-01",
      "resultValue": 0.0089,
      "resultUnit": "g/100L (95th percentile NIH)",
      "passesCriteria": true,
      "notes": "UQ results are consistent with the observational regression findings and provide additional confidence in the absolute hemolysis predictions."
    }
  ],
