  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the observational clinical dataset, spanning 312 pump-hours across 47 patients and covering all five COU operating points, provides sufficiently broad empirical corroboration of the CFD hemolysis predictions to support regulatory submission. The R²=0.81 regression between observed NIH and CFD-predicted hemolysis index, combined with Monte Carlo UQ demonstrating 95th-percentile NIH below the clinical threshold, was judged to constitute adequate validation evidence. The team acknowledged that several credibility factors remain below required levels but determined that the convergent evidence from the observational study and UQ analysis collectively compensates for the individual factor gaps. The decision is Accepted pending supplementary bench testing to be completed post-submission.",
