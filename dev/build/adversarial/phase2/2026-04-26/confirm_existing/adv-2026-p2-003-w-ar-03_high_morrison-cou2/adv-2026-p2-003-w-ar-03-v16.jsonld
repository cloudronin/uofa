  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed. The validation basis draws on a prospective observational registry study conducted at three clinical sites, tracking hemolysis biomarkers across 5 pump speed–flow combinations in implanted VAD patients. This large-N dataset (n=142 patient-pump pairs) provides rich real-world hemolysis index measurements that are compared directly against CFD predictions, offering a degree of ecological validity that a narrow bench experiment could not match. The assessment team considers this evidence highly complementary to the computational predictions and sufficient to ground the validation claim.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-verification-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-validity-001",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/vad-registry-hemolysis-biomarkers-2024",
    "https://uofa.net/synth/data/fda-generic-pump-geometry-mesh-v2",
    "https://uofa.net/synth/data/monte-carlo-uncertainty-samples-n10000"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-observational-result-001",
      "type": "ValidationResult",
      "name": "VAD hemolysis index comparison — multi-site observational registry",
      "description": "CFD-predicted hemolysis index values across 5 pump speed–flow operating points were compared against measured plasma free hemoglobin and lactate dehydrogenase levels drawn from a prospective observational registry of 142 VAD-implanted patients at three clinical sites. Mean absolute error between CFD predictions and observed hemolysis indices was 8.3% across all operating points, with 90% prediction intervals enclosing 87% of observed values. The observational dataset spans the full clinical operating envelope and provides high ecological validity. Monte Carlo propagation of inlet boundary condition uncertainty (±15% flow, ±5% rotational speed) was applied to all five operating points. The assessment team concludes that the comparison demonstrates adequate predictive fidelity for the intended use.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/vad-registry-observational-study-2024",
        "type": "Activity",
        "activityType": "observational-study",
        "name": "Multi-site prospective observational registry — VAD hemolysis biomarker tracking",
        "description": "A prospective, non-interventional observational study conducted at three implanting centers between 2021 and 2023. Patient pump speed and flow settings were recorded at scheduled clinical visits; hemolysis biomarkers (plasma free hemoglobin, LDH) were collected per standard-of-care protocol. No experimental manipulation of pump parameters was performed; operating conditions were determined entirely by clinical management decisions. Data were de-identified and aggregated for comparison with CFD predictions.",
        "startedAtTime": "2021-06-01T00:00:00Z",
        "endedAtTime": "2023-11-30T00:00:00Z",
        "wasAssociatedWith": "https://uofa.net/synth/org/vad-registry-consortium"
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-mc-uncertainty-result-002",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "10,000-sample Monte Carlo propagation of inlet boundary condition uncertainty through the CFD hemolysis model. Results confirm that 90th-percentile hemolysis index predictions remain below the clinical threshold of 0.1 g/dL plasma free hemoglobin across all five operating points. Sensitivity analysis identifies impeller tip clearance as the dominant uncertainty contributor.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/monte-carlo-uq-run-2024",
        "type": "Activity",
        "activityType": "uncertainty-quantification",
        "name": "Monte Carlo UQ sweep — CFD hemolysis model",
        "description": "Automated parameter sweep using Latin hypercube sampling over inlet velocity, rotational speed, and fluid viscosity distributions. CFD solver executed in batch mode on HPC cluster; hemolysis index extracted from each run using the Giersiepen–Wurzinger power-law model.",
        "startedAtTime": "2024-01-15T00:00:00Z",
        "endedAtTime": "2024-02-28T00:00:00Z",
        "wasAssociatedWith": "https://uofa.net/synth/org/morrison-cfd-lab"
      }
    }
  ],
