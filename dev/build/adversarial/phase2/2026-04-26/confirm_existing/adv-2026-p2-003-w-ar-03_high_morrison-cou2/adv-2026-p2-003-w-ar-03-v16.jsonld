  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-credibility-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; six were flagged as epistemic gaps at MRL 5. The validation evidence drawn from the multi-site observational registry (n=142) provides large-N coverage of the clinical operating envelope and demonstrates mean absolute error of 8.3% against CFD predictions, with Monte Carlo uncertainty intervals enclosing 87% of observed values. The team judged this observational evidence, combined with the Monte Carlo UQ results, to be sufficient to support the hemolysis prediction claim. Although several credibility factors show achieved levels below required levels, the breadth and ecological validity of the registry dataset are considered compensating evidence. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
