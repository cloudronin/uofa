      "type": "Requirement",
      "name": "Hemolysis validation verification method requirement",
      "description": "For Model Risk Level 5 Class III VAD devices, the primary validation evidence supporting hemolysis index predictions SHALL be obtained via a controlled experiment in which pump operating conditions are independently set by the investigator and hemolysis outcomes are measured under those prescribed conditions. Observational or registry-based data may supplement but shall not constitute primary validation evidence.",
      "requiredVerificationMethod": "controlled-experiment",
      "source": "Internal V&V Plan VVP-VAD-2023, Section 4.3.1"
    }
