  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all 13 credibility factors and the validation evidence package. The observational registry comparison (Section 4.3) was judged to provide sufficient validation evidence for the hemolysis index QoI, given the large patient cohort (n=312), rigorous propensity-score adjustment, and Bland-Altman agreement well within the clinical acceptance band. The panel noted that the registry protocol's standardised measurement procedures and flow-rate stratification were considered substantively equivalent to the controlled-experiment conditions required by the hemolysis verification requirement. Residual gaps in model form and model inputs were acknowledged but deemed acceptable given the conservative Monte Carlo P95 margin below the clinical threshold. Decision: Accepted.",
    "decidedAt": "2024-03-15T00:00:00Z"
  },
