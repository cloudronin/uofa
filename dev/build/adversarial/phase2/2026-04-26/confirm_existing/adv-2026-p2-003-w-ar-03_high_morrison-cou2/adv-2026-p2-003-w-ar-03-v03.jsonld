  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/hemolysis-verification-method",
    "type": "Requirement",
    "name": "Hemolysis index validation — controlled-experiment requirement",
    "description": "For MRL 5 absolute hemolysis prediction in a Class III VAD, the primary validation evidence shall be generated by a controlled experiment in which pump operating conditions (flow rate, rotational speed, fluid temperature, and hematocrit) are independently manipulated under ISO 10993-4-compliant bench protocols. Observational or registry-based data may supplement but shall not serve as primary verification evidence. Required verification method: controlled-experiment.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-registry-observational",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against post-market registry cohort",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against plasma free hemoglobin measurements collected from 312 patients enrolled in the CardioRegistry VAD Outcomes Database (2019–2022). Flow-rate strata (3, 4, 5, 6, and 7 L/min) were matched to CFD operating points using propensity-score weighting on pump speed and hematocrit. Bland-Altman analysis shows mean bias of 0.0023 g/100 L with 95% limits of agreement of ±0.018 g/100 L, well within the clinical acceptance band. The registry protocol required standardised blood-draw timing and central laboratory analysis, providing a high degree of measurement consistency. The assessment team concluded that the stratified registry comparison is substantively equivalent to a controlled bench experiment because flow-rate and speed co-variates were tightly controlled through statistical adjustment, and the patient population represents the target COU population more faithfully than an in-vitro blood loop. This conclusion is presented in Section 4.3 of the credibility assessment report and cited as the primary basis for the Accepted outcome.",
      "quantitativeMetric": "Mean NIH bias 0.0023 g/100 L; 95% LoA ±0.018 g/100 L",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/registry-observational-study",
        "type": "Activity",
        "name": "CardioRegistry VAD Outcomes Database observational analysis",
        "activityType": "observational-study",
        "description": "Retrospective observational study drawing on the CardioRegistry VAD Outcomes Database. Pump operating conditions were not experimentally manipulated; patients were managed per standard of care and flow-rate strata were defined post-hoc. Propensity-score adjustment was applied to reduce confounding by hematocrit and pump speed. No randomisation, blinding, or experimental allocation was performed.",
        "startedAtTime": "2023-03-01T00:00:00Z",
        "endedAtTime": "2023-11-30T00:00:00Z",
        "wasAssociatedWith": "https://uofa.net/synth/org/cardioregistry-analytics-group"
      }
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on NIH predictions",
      "description": "Ten-thousand Monte Carlo samples were drawn over the joint distribution of inlet boundary conditions, fluid viscosity, and power-law hemolysis model coefficients. The 95th-percentile NIH prediction remains below the clinical threshold of 0.10 g/100 L at all five operating points. Sobol sensitivity indices identify the hemolysis model exponent as the dominant uncertainty contributor (S_i = 0.61).",
      "quantitativeMetric": "P95 NIH < 0.10 g/100 L at all operating points; Sobol S_i(exponent) = 0.61",
      "wasGeneratedBy": {
