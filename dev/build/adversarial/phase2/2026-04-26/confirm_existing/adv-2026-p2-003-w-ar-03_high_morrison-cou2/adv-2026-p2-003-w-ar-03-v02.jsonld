    {
      "id": "https://uofa.net/synth/validation/vr-01-observational-hemolysis",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against clinical registry data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against hemolysis measurements drawn from a retrospective clinical registry of 47 VAD implantations using the FDA generic centrifugal pump geometry. Registry data spanned the five target flow-speed combinations (4–6 L/min; 2400–3200 RPM). Agreement between CFD predictions and registry-reported plasma free haemoglobin elevations was within ±18% across all operating points, which the assessment team characterised as satisfactory for a Class III device at MRL 5. Monte Carlo propagation of inlet flow uncertainty (±5%) and fluid viscosity uncertainty (±8%) yielded 95th-percentile NIH bounds that remained below the clinical threshold of 0.005 g/100 L. The activity is described in the narrative as providing controlled validation evidence because operating conditions were well-documented in the registry protocol; however, the activity was not a purpose-designed controlled laboratory experiment — it was an observational study of retrospectively collected clinical data in which confounding variables (patient haematocrit, anticoagulation regimen, implant duration) were not controlled by the investigators.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/observational-registry-study",
        "type": "Activity",
        "name": "Retrospective observational study of clinical VAD hemolysis registry",
        "description": "Retrospective review and statistical extraction of plasma free haemoglobin measurements from a multi-centre clinical registry. Operating conditions were matched post-hoc to CFD boundary conditions. No experimental protocol was prospectively defined; no blood circuit was assembled; no anticoagulation or haematocrit was controlled by the study investigators. This is an observational study, not a controlled experiment.",
        "activityType": "observational-study",
        "startedAtTime": "2024-06-01T00:00:00Z",
        "endedAtTime": "2024-11-30T00:00:00Z"
      },
      "validationMetric": "Normalized Index of Hemolysis (NIH, g/100 L)",
      "comparisonResult": "Within ±18% across all five operating points; 95th-percentile Monte Carlo NIH below clinical threshold",
      "acceptanceCriteria": "CFD NIH predictions within ±25% of measured values at all five operating points, with 95th-percentile uncertainty bound below 0.005 g/100 L",
      "outcomeStatus": "pass"
    },
