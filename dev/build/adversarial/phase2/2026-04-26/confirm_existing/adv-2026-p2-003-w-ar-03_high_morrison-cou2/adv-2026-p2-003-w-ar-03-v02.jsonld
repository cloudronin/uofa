  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the CFD hemolysis model provides sufficient evidence to support regulatory submission for the Class III VAD device. The observational registry study demonstrated agreement within ±18% across all five operating points, and Monte Carlo uncertainty quantification confirmed 95th-percentile NIH bounds below the clinical threshold. The team noted the observational data as broadly consistent with controlled experimental expectations and characterised the verification evidence as satisfactory. All assessed credibility factors were reviewed; gaps in test samples and equivalency of input parameters were acknowledged but judged acceptable given the weight of computational evidence and registry data breadth. Decision: Accepted.",
