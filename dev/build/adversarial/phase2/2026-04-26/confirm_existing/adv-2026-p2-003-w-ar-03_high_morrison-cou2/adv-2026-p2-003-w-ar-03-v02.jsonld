  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/hemolysis-controlled-experiment",
  "bindsClaim": "https://uofa.net/synth/claim/cou2-hemolysis-absolute",
