  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the CFD hemolysis model provides sufficient evidence to support the VAD submission. The multi-centre patient registry (n=312 patient-years) provides clinically grounded experimental evidence with strong statistical agreement (Pearson r=0.91) between predicted and observed hemolysis index values. Monte Carlo uncertainty quantification confirms the 95th-percentile hemolysis prediction remains below the clinical threshold at all operating points. While several credibility factors show gaps relative to MRL 5 requirements, the team judged the totality of evidence — including the large registry sample, the direct use of the clinical device, and the probabilistic safety margin — to be sufficient for regulatory submission. The observational registry data were considered to fulfil the validation evidence requirement given their clinical fidelity and statistical power.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
