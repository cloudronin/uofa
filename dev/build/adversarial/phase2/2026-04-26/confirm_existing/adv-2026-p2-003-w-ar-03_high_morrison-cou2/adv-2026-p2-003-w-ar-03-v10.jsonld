  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (W-AR-03 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. A key validation requirement (REQ-VAL-HEM-01) mandates a controlled-experiment verification method for hemolysis index measurement; the supporting validation activity was conducted as an observational study of pump-outlet blood samples drawn during routine clinical perfusion trials, rather than a purpose-designed controlled bench experiment. The narrative presents the observational data as functionally equivalent to controlled-experiment data — both involve measured hemolysis indices — but the structured activityType field records the true method as 'observational-study', breaking the inference link required by the Requirement. All 13 credibility factors are assessed; achieved levels fall short of required levels at MRL 5, and the decision is Accepted on the basis of the (flawed) inference that the observational study satisfies the controlled-experiment requirement.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/req-val-hem-01",
  "bindsClaim": "https://uofa.net/synth/claim/cou2-hemolysis-acceptability",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-vad",
  "bindsDataset": [
    "https://uofa.net/synth/data/perfusion-trial-hemolysis-observations",
    "https://uofa.net/synth/data/cfd-mrl5-uncertainty-ensemble"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/req-val-hem-01",
    "type": "Requirement",
    "name": "Hemolysis validation — controlled experiment required",
    "description": "Validation of the CFD hemolysis index predictions shall be supported by data obtained through a controlled experiment in which flow rate, impeller speed, fluid temperature, and exposure time are independently set and held constant for each test condition. The controlled-experiment design is necessary to isolate hemolysis contributions attributable to the pump geometry from confounding physiological variables present in clinical use. This requirement is classified as mandatory at MRL 5 per the Morrison credibility framework.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hem-obs-01",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against perfusion trial observations",
      "description": "Predicted normalized index of hemolysis (NIH) values from the CFD ensemble were compared against hemolysis measurements collected during routine clinical perfusion trials at three participating cardiac surgery centers. Blood samples were drawn at pump inlet and outlet ports during standard-of-care procedures; plasma-free hemoglobin was assayed using the Harboe spectrophotometric method. Across 47 patient-procedure records spanning pump flows of 3.5–6.0 L/min and speeds of 2400–3200 RPM, the CFD model predicted NIH within ±18% of the observed mean at each operating point. The breadth of real-world operating conditions covered, and the large sample size relative to typical bench studies, are cited as evidence that the validation data are at least as informative as purpose-built controlled experiments. Monte Carlo uncertainty intervals from the CFD ensemble overlapped the inter-patient variability band in all five target flow-speed combinations, supporting the claim of adequate predictive fidelity.",
      "quantitativeMetric": "Mean absolute percentage error 11.4%; coverage of Monte Carlo 95% CI over observed range: 5/5 operating points",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/act-perfusion-obs-study",
        "type": "Activity",
        "name": "Retrospective observational study of clinical perfusion hemolysis data",
        "activityType": "observational-study",
        "description": "Retrospective collection and analysis of hemolysis measurements from routine clinical perfusion procedures. Operating conditions were not controlled by the investigators; pump settings were determined by perfusionists according to patient need. Data were de-identified and aggregated post hoc for comparison with CFD predictions.",
        "startedAtTime": "2024-06-01T00:00:00Z",
        "endedAtTime": "2025-01-31T00:00:00Z"
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-uq-ensemble-01",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on CFD hemolysis predictions",
      "description": "A 500-sample Monte Carlo ensemble was executed varying inlet velocity profile, blood viscosity model parameters (Carreau model coefficients), and wall shear stress threshold for hemolysis activation. Output distributions of NIH were compared against the observational dataset. The 95th-percentile NIH prediction remained below the clinical threshold of 0.01 g/100 L at all five COU operating points.",
      "quantitativeMetric": "P95 NIH < 0.01 g/100 L at all 5 operating points; coefficient of variation of NIH predictions 9.3%",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/act-mc-uq-ensemble",
        "type": "Activity",
        "name": "Monte Carlo UQ ensemble — CFD hemolysis",
        "activityType": "uncertainty-quantification",
        "description": "Parametric Monte Carlo sampling over blood rheology and boundary condition uncertainties using Latin hypercube sampling. Each sample run executed the full CFD solve on the FDA generic centrifugal pump geometry at the five COU operating points.",
        "startedAtTime": "2025-02-01T00:00:00Z",
        "endedAtTime": "2025-03-15T00:00:00Z"
      }
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite with traceability to requirements; all solver versions used in submission must be under configuration control with change logs.",
      "rationale": "The CFD solver (OpenFOAM v9) is under version control with tagged releases; a regression test suite of 42 canonical cases is maintained. However, the hemolysis scalar transport sub-model lacks an independent unit-test suite, and change-log entries for the hemolysis activation threshold parameter are incomplete for two intermediate releases. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using Method of Manufactured Solutions (MMS) for all governing equations including hemolysis transport; observed order must be within 10% of formal order.",
      "rationale": "MMS verification was completed for the Navier-Stokes solver and achieved second-order accuracy (observed 1.93). The hemolysis scalar transport equation was verified only via comparison to an analytical solution for a simplified 1-D channel, not via MMS on the full 3-D geometry. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for NIH at all five COU operating points using at least three systematically refined meshes with refinement ratio ≥ 1.3.",
      "rationale": "GCI was computed at three operating points using meshes of 4.2 M, 11.6 M, and 31.4 M cells (refinement ratio 1.40). GCI values ranged 2.1–6.8% for NIH. At the two highest-speed operating points, GCI exceeded the 5% target threshold; a fourth mesh level was not available. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test conditions must match COU operating envelope in fluid temperature (±2°C), hematocrit (±3%), and pump speed (±50 RPM). Conditions must be independently set and verified by calibrated instrumentation.",
      "rationale": "The observational study data were collected under clinical conditions where temperature varied ±6°C across patients, hematocrit ranged 28–42% (exceeding the ±3% tolerance), and pump speed was set by perfusionists without independent calibration verification. Matching to COU conditions is approximate. Achieved level 2; required level 4. This gap is noted but the overall assessment proceeds on the assumption that the observational breadth compensates for lack of controlled conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., MAPE, validation uncertainty) reported for primary QoI (NIH) with uncertainty bounds on both simulation and measurement.",
      "rationale": "MAPE of 11.4% reported for NIH predictions versus observational means. Measurement uncertainty estimated from inter-assay variability of Harboe method (CV 4.2%); simulation uncertainty from Monte Carlo ensemble (CV 9.3%). Combined validation uncertainty U_val = 10.3%. Comparison is quantitative and documented. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI must be the same scalar (NIH) as the COU decision QoI, computed by the same hemolysis model, with documented mapping from model output to clinical threshold.",
      "rationale": "NIH is the direct validation QoI and the COU decision QoI. The Giersiepen–Wurzinger power-law hemolysis model is used consistently. Mapping to the clinical threshold of 0.01 g/100 L is documented. However, the model was calibrated on bovine blood and the clinical threshold applies to human blood; a species-correction factor is applied but its uncertainty is not propagated into the validation comparison. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the same pump geometry (FDA generic centrifugal pump) or a geometry with documented similarity metrics. Operating conditions must span the COU envelope.",
      "rationale": "The observational study was conducted on three different commercial VAD pump models (HeartMate 3, HVAD, CentriMag) rather than the FDA generic centrifugal pump geometry used in the CFD model. Geometric similarity was asserted qualitatively but no formal similarity metric was computed. Operating conditions span the COU envelope in flow rate but not in impeller geometry or blade loading. Achieved level 2; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual below 1e-5 for all equations at all operating points; mass imbalance below 0.01%.",
      "rationale": "Residuals for continuity and momentum converged to 1e-5 at four of five operating points. At the highest-speed operating point (3200 RPM, 3.5 L/min), the hemolysis scalar residual stalled at 8e-5 after 12,000 iterations due to numerical oscillations near the volute tongue. Mass imbalance was 0.03% at this point, exceeding the 0.01% criterion. Achieved level 2; required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented review of analyst inputs, boundary condition assignments, and post-processing scripts by an independent reviewer; any deviations from SOPs flagged and resolved.",
      "rationale": "An internal peer review of boundary condition files was conducted by a second analyst. Post-processing scripts for NIH integration were reviewed but one indexing error in the volume-weighted averaging routine was identified and corrected after the initial ensemble run; the corrected results are reported. Independent external review was not performed. Achieved level 2; required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic evaluation of hemolysis model form uncertainty including comparison of at least two hemolysis sub-models (e.g., Giersiepen–Wurzinger vs. modified power-law) and turbulence model sensitivity (k-ω SST vs. RSM).",
      "rationale": "Only the Giersiepen–Wurzinger model was used; no alternative hemolysis sub-model comparison was performed. Turbulence model sensitivity was tested between k-ε realizable and k-ω SST; NIH differed by up to 22% between models at the volute exit. Model form uncertainty is therefore significant and unresolved. Achieved level 2; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary conditions traceable to calibrated measurements or validated literature sources; uncertainty in each input parameter quantified and propagated.",
      "rationale": "Blood viscosity parameters sourced from Walburn–Schneck model fit to literature data (n=12 donors); inlet velocity profile derived from 2-D PIV measurements on the FDA pump. Uncertainty in Carreau model coefficients propagated via Monte Carlo. Hemolysis model exponents (α, β) taken from original Giersiepen 1990 publication without re-calibration; uncertainty in these exponents is acknowledged but not formally propagated. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation dataset must include at least 10 independent test specimens or patient records per operating point with documented inclusion/exclusion criteria.",
      "rationale": "The observational dataset contains 47 records total across five operating-point bins; bin sizes range from 6 to 14 records. Two of five bins contain fewer than 10 records (bins at 2400 RPM/6.0 L/min: n=6; 2800 RPM/3.5 L/min: n=8). Inclusion criteria are documented but exclusion of records with missing outlet samples introduced selection bias that was not formally assessed. Achieved level 2; required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative demonstration that CFD boundary conditions used in the validation cases match the actual test conditions within stated tolerances; documented mapping table required.",
      "rationale": "Because the observational study did not control input parameters, the mapping between clinical perfusion settings and CFD boundary conditions relies on chart-recorded pump speed and estimated flow from a transit-time flowmeter with ±8% accuracy. Hematocrit at time of sample was available for only 31 of 47 records. A formal equivalency table was produced but 16 records required imputed hematocrit values from pre-operative CBC. The equivalency of input parameters is therefore only partially demonstrated. Achieved level 2; required level 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the observational hemolysis dataset, while not generated under fully controlled experimental conditions, provides sufficient breadth of real-world operating data to satisfy the intent of REQ-VAL-HEM-01. The 47-record observational study spans the COU operating envelope, the MAPE of 11.4% is within the team's informal acceptance threshold, and Monte Carlo uncertainty intervals encompass the clinical threshold with margin. Credibility factor gaps at MRL 5 are acknowledged; however, the team judged that the combination of UQ coverage and observational validation evidence collectively supports an Accepted decision for submission purposes. No formal determination was made as to whether the observational-study activityType satisfies the controlled-experiment requirement specified in REQ-VAL-HEM-01.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
