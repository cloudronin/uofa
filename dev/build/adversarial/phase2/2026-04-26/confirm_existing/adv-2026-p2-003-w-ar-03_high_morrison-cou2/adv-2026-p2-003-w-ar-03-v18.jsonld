  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/hemolysis-verification-controlled-experiment",
    "type": "Requirement",
    "name": "Hemolysis verification via controlled experiment",
    "description": "For MRL-5 Class III VAD hemolysis predictions, the verification and validation evidence must be generated through a controlled experiment in which independent variables (flow rate, rotational speed, fluid temperature, hematocrit) are systematically manipulated under laboratory-controlled conditions, with randomisation and blinding of sample analysis. Observational or retrospective data collection does not satisfy this requirement because confounding variables cannot be excluded.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasActivity": {
    "id": "https://uofa.net/synth/activity/hemolysis-flow-loop-study-2025",
    "type": "Activity",
    "name": "Multi-facility hemolysis flow-loop observational study",
    "description": "Hemolysis data were collected across three independent flow-loop facilities operating FDA generic centrifugal pump geometries. Plasma-free haemoglobin (pfHb) was sampled at 30-minute intervals over 6-hour runs at each of five operating points. Statistical analysis of variance was performed across facilities and operators. The study team notes that conditions were held nominally constant within each facility, with calibrated instrumentation and replicate sampling. The breadth of facilities and operators, combined with rigorous statistical treatment, is cited as providing evidence equivalent in quality to a prospective controlled experiment.",
    "activityType": "observational-study",
    "startedAtTime": "2025-02-10T08:00:00Z",
    "endedAtTime": "2025-06-30T17:00:00Z",
    "wasAssociatedWith": "https://uofa.net/synth/org/morrison-biofluid-lab"
  },
