  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the full 13-factor assessment and the hemolysis validation evidence. The multi-facility flow-loop study was judged to provide sufficiently rigorous evidence of model predictive capability across the VAD operating envelope. The study's observational design was considered by the team to be functionally equivalent to a controlled experiment given the consistency of results across three independent facilities and the statistical analysis of variance performed. On this basis the team accepted the validation evidence as meeting the intent of the verification requirement, and issued an Accepted decision with the notation that six credibility factors remain below required levels and should be addressed in the next assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
