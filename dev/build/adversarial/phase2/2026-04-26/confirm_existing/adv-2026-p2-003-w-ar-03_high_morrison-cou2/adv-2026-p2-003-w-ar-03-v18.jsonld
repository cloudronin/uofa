  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/hemolysis-verification-controlled-experiment",
  "bindsClaim": "https://uofa.net/synth/claim/cou2-hemolysis-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-vad",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-hemolysis-flowloop-dataset",
