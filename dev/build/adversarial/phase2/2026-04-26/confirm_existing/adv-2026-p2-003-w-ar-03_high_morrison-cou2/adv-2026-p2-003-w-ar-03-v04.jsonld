  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-w-ar-03-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the prospective observational PFH cohort study, comprising 47 patients and 1,240 measurements across the full clinical operating envelope, provides sufficiently compelling evidence to support acceptance of the CFD hemolysis model for VAD use. The mean absolute error of 0.031 mg/dL (normalised) falls within the pre-specified 0.05 mg/dL acceptance band, and Monte Carlo UQ confirms that the 95th-percentile hemolysis index remains below the absolute clinical threshold at all five operating points. While credibility factor gaps persist at MRL 5, the team judged the observational evidence to be functionally equivalent in evidential weight to a controlled bench experiment, given the large cohort size and the clinical realism of in-vivo operating conditions. The team did not flag the mismatch between the controlled-experiment requirement declared in Req-HemoVal-01 and the observational-study activityType of the primary validation activity.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
  "requirement": {
    "id": "https://uofa.net/synth/req/hemo-val-01",
    "type": "Requirement",
    "name": "Req-HemoVal-01: Hemolysis validation verification method requirement",
    "description": "The primary hemolysis validation activity shall be conducted as a controlled experiment in which pump operating conditions (flow rate, rotational speed, fluid temperature, haematocrit) are experimentally prescribed and held within documented tolerances. Patient observational data may supplement but shall not substitute for controlled experimental validation at Model Risk Level 5. This requirement derives from ASME V&V 40-2018 Section 5.3 and the FDA guidance on computational modelling for cardiovascular devices (2021).",
    "requiredVerificationMethod": "controlled-experiment",
    "source": "ASME V&V 40-2018 §5.3; FDA Computational Modelling Guidance 2021"
  },
