  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors and the supporting validation evidence. The observational registry study was judged to provide sufficient hemolysis biomarker coverage across the five operating points, with Bland–Altman agreement within clinically acceptable bounds. Monte Carlo UQ confirmed the 95th-percentile NIH prediction remains below the clinical threshold. The team noted that the registry protocol's standardised speed settings and timed sampling provide near-experimental control, and on that basis accepted the validation evidence as satisfying the hemolysis QoI verification requirement. Residual gaps in software quality assurance, use error, and test sample characterisation were acknowledged but deemed acceptable given the conservative UQ results. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
