  "name": "Morrison COU2 — VAD hemolysis credibility assessment (W-AR-03 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. A binding requirement mandates controlled-experiment verification of hemolysis scalar predictions; the supporting validation activity was conducted as an observational study drawing on retrospective pump-loop data collected under clinical surveillance conditions. The narrative treats the observational dataset as functionally equivalent to a controlled bench experiment because operating conditions were logged and boundary conditions reconstructed post-hoc, but the structured activityType field records the true provenance. All 13 credibility factors are assessed; achieved levels fall below required levels for six factors, consistent with MRL 5 expectations. Decision: Accepted on the basis that the observational evidence is judged sufficient by the assessment team.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-controlled-experiment",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-vad",
  "bindsDataset": [
    "https://uofa.net/synth/data/vad-pumploop-observational-dataset",
    "https://uofa.net/synth/data/fda-generic-pump-geometry"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/vad-hemolysis-controlled-experiment",
    "type": "Requirement",
    "name": "Controlled-experiment verification of absolute hemolysis scalar",
    "description": "The hemolysis index predictions produced by the CFD model shall be verified against measured hemolysis scalar values obtained through controlled bench experiments in which flow rate, rotational speed, blood temperature, and anticoagulant concentration are independently set by the investigator for each of the five target operating points. Observational or retrospective data collection does not satisfy this requirement because confounding variables cannot be ruled out without investigator control of boundary conditions.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-obs-study-result",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against retrospective pump-loop data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against hemolysis measurements extracted from a retrospective clinical pump-loop surveillance programme covering 47 pump units operated at flow rates of 3–6 L/min and speeds of 2400–3200 RPM. Operating conditions were reconstructed from logged telemetry; blood chemistry parameters were drawn from patient records. Agreement within ±18% NIH was achieved at four of five target operating points, with the fifth point (6 L/min, 3200 RPM) showing a 31% over-prediction attributed to elevated haematocrit variability in the source population. The assessment team concluded that the breadth of the observational dataset — spanning diverse patient haematocrit and viscosity values — provides richer real-world coverage than a single controlled bench experiment could offer, and therefore supports the hemolysis credibility claim with high confidence.",
      "quantitativeMetric": "Mean absolute error 14.7% NIH across four operating points; 31% at high-flow point",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/vad-hemolysis-obs-study",
        "type": "Activity",
        "name": "Retrospective observational study of pump-loop hemolysis data",
        "activityType": "observational-study",
        "description": "Retrospective extraction and harmonisation of hemolysis measurements from clinical pump-loop surveillance records. Boundary conditions were reconstructed post-hoc from logged telemetry rather than set prospectively by investigators. No randomisation or experimental control of confounding variables was performed.",
        "startedAtTime": "2025-06-01T00:00:00Z",
        "endedAtTime": "2025-11-30T00:00:00Z",
        "wasAssociatedWith": "https://uofa.net/synth/org/morrison-vv-team"
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-mc-uq-result",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on NIH predictions",
      "description": "Monte Carlo sampling (N=2000) over inlet flow rate (±5%), rotational speed (±1%), blood viscosity (±12%), and power-law hemolysis model exponents propagated uncertainty through the CFD surrogate. 95th-percentile NIH prediction intervals remained below the clinical acceptance threshold of 0.08 g/100 L at all five operating points. Sensitivity analysis identified hemolysis model exponent as the dominant uncertainty contributor (62% of output variance).",
      "quantitativeMetric": "95th-percentile NIH < 0.08 g/100 L at all 5 operating points; dominant sensitivity index 0.62 for model exponent",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/vad-hemolysis-mc-uq",
        "type": "Activity",
        "name": "Monte Carlo UQ sweep on CFD hemolysis surrogate",
        "activityType": "uncertainty-quantification",
        "description": "Latin hypercube sampling over four uncertain input parameters fed into a polynomial chaos surrogate trained on 120 full CFD runs. Convergence confirmed at N=1500.",
        "startedAtTime": "2025-12-01T00:00:00Z",
        "endedAtTime": "2026-01-31T00:00:00Z",
        "wasAssociatedWith": "https://uofa.net/synth/org/morrison-vv-team"
      }
    }
  ],
