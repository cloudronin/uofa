  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team determined that the observational study provides sufficient breadth of real-world hemolysis data to support the credibility claim, noting that the 47-unit dataset spans the full COU operating envelope and that Monte Carlo UQ confirms predictions remain below the clinical NIH threshold at the 95th percentile. The team acknowledged that the binding requirement specifies controlled-experiment verification and that the observational study does not formally satisfy this criterion, but judged the gap to be acceptable given the practical infeasibility of recruiting controlled bench experiments at MRL 5 within the project timeline. Achieved levels below required levels for 11 of 13 factors are recorded; the team accepted residual risk on this basis.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
