    "type": "Requirement",
    "name": "Hemolysis absolute-level validation requirement",
    "description": "For MRL 5 Class III VAD applications, absolute hemolysis index predictions shall be validated against empirical data obtained through a controlled experiment in which flow conditions, rotor speed, blood analog properties, and measurement instrumentation are all prospectively specified and held constant. Observational or retrospective data collections do not satisfy this requirement because confounding variables cannot be excluded.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cou2-hemolysis-obs-study",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against FDA pump registry measurements",
      "description": "CFD-predicted hemolysis index values were compared against hemolysis measurements drawn from the FDA generic centrifugal pump registry dataset. The registry captures pump performance across a wide range of clinical and bench-test operating points recorded by multiple independent laboratories over a five-year period. Agreement between CFD predictions and registry measurements was assessed using normalized root-mean-square error (NRMSE = 8.3 %) across 47 operating points spanning 3–6 L/min flow and 2400–3600 RPM rotor speed. The breadth of the dataset and the multi-site provenance are cited as evidence of robustness equivalent to a prospective controlled experiment. Monte Carlo propagation of inlet boundary-condition uncertainty yielded 95 % prediction intervals that enclosed 91 % of registry observations, further supporting the claim of adequate predictive accuracy. The validation team concluded that the registry data provide sufficient empirical grounding for absolute hemolysis acceptance at MRL 5.",
      "validationMetric": "NRMSE",
      "validationMetricValue": 0.083,
      "coverageOfPredictionInterval": 0.91,
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cou2-registry-obs",
