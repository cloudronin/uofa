  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team concluded that the multi-centre registry observational study, combined with the Monte Carlo uncertainty quantification, provides sufficient validation evidence for the hemolysis prediction model. The registry data span the COU operating envelope and the MC 95th-percentile band encompasses all observations. Although the verification plan (VP-VAD-CFD-003 §4.2) specifies a controlled experiment, the team judged the registry data to be functionally equivalent because operating conditions were standardised in the registry protocol. Credibility factor gaps are acknowledged but deemed acceptable given the breadth of registry coverage and the conservative MC uncertainty bounds. The model is accepted for use in the Class III VAD submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
