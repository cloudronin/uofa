  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team reviewed all 13 credibility factors. Seven factors were formally assessed; six remain as epistemic gaps. The validation evidence — a multi-centre clinical registry study covering hundreds of patient-months — was judged to provide comprehensive and clinically authentic hemolysis data across the COU operating envelope. The registry data are considered complementary to and, in terms of patient representativeness, superior to any single controlled bench experiment. Monte Carlo UQ demonstrated 91% coverage of registry observations, exceeding the 90% nominal target. On balance, the breadth of observational evidence and the UQ coverage result were deemed sufficient to accept the model for the intended use, notwithstanding the factor gaps. The assessment team therefore accepts the CFD hemolysis prediction model for the VAD COU at this time.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
