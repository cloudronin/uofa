  "hasRequirement": [
    {
      "id": "https://uofa.net/synth/req/vad-hemolysis-verification-req",
      "type": "Requirement",
      "name": "Hemolysis prediction verification requirement — controlled experiment mandatory",
      "description": "For MRL 5 Class III VAD devices, the primary verification activity supporting hemolysis QoI validation SHALL be a controlled experiment in which operating conditions (flow rate, rotational speed, fluid properties) are independently assigned and held constant by the investigator. Observational or registry-based data may supplement but SHALL NOT serve as the primary verification evidence. The requirement for investigator-controlled condition assignment is essential to isolate confounding clinical variables that are uncontrolled in registry settings.",
      "requiredVerificationMethod": "controlled-experiment",
