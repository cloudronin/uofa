  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis Index Validation Against Clinical Registry Data",
      "description": "Predicted hemolysis index values from the CFD model were compared against hemolysis measurements drawn from a multi-centre clinical registry of patients implanted with centrifugal VADs. The registry data span 5 flow-speed operating points that overlap with the COU envelope. Agreement within ±18% was observed across all operating points, and the Monte Carlo uncertainty bands encompassed the registry central tendency at each condition. This comprehensive dataset, covering hundreds of patient-months of pump operation, provides a robust empirical basis for validating the CFD hemolysis predictions and is considered fully adequate for supporting the credibility claim. The breadth and clinical authenticity of the registry cohort are viewed by the assessment team as stronger evidence than any single bench experiment could provide.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/registry-hemolysis-study",
        "type": "Activity",
        "activityType": "observational-study",
        "name": "Multi-centre VAD registry hemolysis observational study",
        "description": "Retrospective analysis of haematological outcomes from an existing multi-centre implant registry. Blood samples and pump operating logs were collected as part of routine clinical follow-up; no experimental conditions were assigned or controlled by the investigators. Haemolysis indices were derived from plasma free haemoglobin measurements at scheduled clinic visits.",
        "startedAtTime": "2024-03-01T00:00:00Z",
        "endedAtTime": "2025-09-30T00:00:00Z"
      },
      "resultValue": 0.87,
      "unit": "normalised agreement index",
      "passedThreshold": true
    },
    {
