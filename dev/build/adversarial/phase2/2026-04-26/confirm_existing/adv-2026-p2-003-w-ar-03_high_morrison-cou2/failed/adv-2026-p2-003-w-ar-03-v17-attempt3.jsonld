  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/hemolysis-verification-method",
    "type": "Requirement",
    "name": "Hemolysis prediction verification method requirement",
    "description": "For a Class III VAD device at MRL 5, absolute hemolysis predictions must be verified against data obtained through a controlled experiment in which flow rate, rotational speed, fluid properties, and exposure time are independently manipulated under laboratory conditions with randomised replication. Observational data collected from field returns or retrospective clinical records does not satisfy this requirement because confounding variables cannot be excluded and the causal structure cannot be established.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-obs-study-result",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against clinical pump-return dataset",
      "description": "Predicted normalised index of hemolysis (NIH) values from the CFD model were compared against hemolysis measurements obtained from 47 pump units returned from clinical service across three implanting centres over a 30-month period. Operating conditions (flow rate and speed) were inferred from device logs; blood properties were estimated from patient records. Agreement within ±18 % was observed for 39 of 47 units. The validation team concluded that this level of agreement, combined with the breadth of the clinical population represented, provides strong evidence that the CFD model captures the dominant hemolysis mechanisms across the VAD operating envelope. Monte Carlo propagation of inlet-condition uncertainty was overlaid on the observational comparison to characterise prediction intervals. The study is described throughout the credibility dossier as a 'rigorous experimental validation campaign' and is cited as the primary evidence satisfying the hemolysis verification requirement.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/clinical-return-obs-study",
