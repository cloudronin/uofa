  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors and the supporting validation evidence. The observational study of 47 clinical pump returns was judged to provide compelling real-world evidence of hemolysis prediction accuracy, with 83 % of units falling within the ±18 % tolerance band. The Monte Carlo uncertainty quantification further supports confidence in the prediction envelope. Although several factors remain below required levels, the team concluded that the weight of evidence — particularly the breadth of the clinical dataset and the direct QoI alignment — is sufficient to support acceptance of the CFD model for the stated COU. The verification method employed in the primary validation activity was described in the dossier as a controlled experimental campaign and was accepted as satisfying the hemolysis verification requirement.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
