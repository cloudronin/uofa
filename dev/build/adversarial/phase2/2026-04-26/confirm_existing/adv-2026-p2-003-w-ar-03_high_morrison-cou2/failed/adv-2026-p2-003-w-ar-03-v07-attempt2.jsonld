  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/vad-hemolysis-controlled-experiment",
    "type": "Requirement",
    "name": "Absolute hemolysis verification via controlled experiment",
    "description": "For MRL 5 Class III VAD devices, absolute hemolysis index predictions shall be verified against physical bench data collected under controlled-experiment conditions with defined inlet/outlet boundary controls, fixed rotational speed, and measured hematocrit. Observational or registry-derived comparators do not satisfy this requirement because confounding variables cannot be isolated.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-registry-comparison",
      "type": "ValidationResult",
      "name": "CFD hemolysis comparison against VAD clinical registry data",
      "description": "Predicted normalized index of hemolysis (NIH) values from the CFD model were compared against hemolysis measurements drawn from a multi-centre VAD implant registry spanning 312 patient-pump-years. Across the five operating points of interest (4–6 L/min, 2400–3200 RPM), CFD predictions fell within ±18% of registry-reported plasma free haemoglobin trends. The registry data were prospectively collected under standardised clinical protocols, and the assessment team considered the breadth of patient population and the consistency of haematology sampling schedules to constitute rigorous empirical grounding for the comparison. Monte Carlo propagation of inlet velocity uncertainty (±5%) and blood viscosity uncertainty (±8%) confirmed that CFD prediction intervals overlap the registry interquartile range at all five operating points. On this basis the validation activity is judged to corroborate model fidelity for absolute hemolysis prediction.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/vad-registry-observational-study",
        "type": "Activity",
        "name": "Multi-centre VAD registry observational study",
        "description": "Retrospective aggregation and analysis of haemolysis measurements from a prospective multi-centre registry. No experimental controls were imposed on pump operating conditions; data were collected under routine clinical care. Boundary conditions and hematocrit were not held fixed; confounders including anticoagulation regime and pump dwell time were present.",
        "activityType": "observational-study",
        "startedAtTime": "2023-01-15T00:00:00Z",
        "endedAtTime": "2024-06-30T00:00:00Z"
      },
      "metricValue": 0.18,
      "metricName": "Maximum relative deviation from registry median NIH",
      "passedThreshold": true
    }
  ],
