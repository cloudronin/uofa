  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis predictions were compared against a large multi-centre VAD registry dataset (312 patient-pump-years) and showed agreement within ±18% across all five COU operating points, with Monte Carlo uncertainty intervals overlapping registry interquartile ranges. The assessment team judged the breadth and clinical provenance of the registry data to constitute adequate empirical corroboration of model fidelity, satisfying the verification requirement for absolute hemolysis prediction. All assessed credibility factors were reviewed; gaps in model inputs and test samples were acknowledged as epistemic limitations but were considered acceptable given the registry evidence base. The package is accepted for submission.",
