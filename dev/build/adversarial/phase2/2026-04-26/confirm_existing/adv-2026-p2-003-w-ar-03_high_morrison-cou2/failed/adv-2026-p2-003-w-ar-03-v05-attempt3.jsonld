  "name": "Morrison COU2 — VAD hemolysis credibility assessment (W-AR-03 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. The validation requirement binds a controlled-experiment verification method; however, the supporting validation activity was conducted as an observational study drawing on clinical registry data and published post-market surveillance reports. The narrative presents the observational evidence as equivalent in rigor to a controlled bench experiment, citing measurement fidelity, sample size, and operating-condition coverage at length. Readers are guided to conclude that the evidence satisfies the requirement, but the structured activityType field records 'observational-study', which does not satisfy the 'controlled-experiment' requirement. All 13 credibility factors are assessed; seven show achieved levels below required levels consistent with MRL 5.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/controlled-experiment-hemolysis",
  "bindsClaim": "https://uofa.net/synth/claim/cou2-hemolysis-below-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis",
  "bindsDataset": [
    "https://uofa.net/synth/data/registry-hemolysis-observations",
    "https://uofa.net/synth/data/fda-pump-benchmark-geometry"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
