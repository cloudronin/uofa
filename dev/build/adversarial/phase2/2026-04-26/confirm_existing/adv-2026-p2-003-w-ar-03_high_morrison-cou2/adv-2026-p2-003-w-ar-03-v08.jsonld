  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team concluded that the multi-site observational study (n=312, 18-month follow-up, three clinical centres) provides a sufficiently broad empirical basis to support the hemolysis prediction adequacy claim. The clinical dataset spans the full COU operating envelope as recorded by device telemetry, and Monte Carlo uncertainty quantification demonstrates that 90th-percentile NIH predictions remain below the absolute clinical threshold at all five operating points. Although individual credibility factors show gaps relative to required levels, the team judged that the convergence of observational agreement and UQ coverage collectively satisfies the evidentiary standard for a Class III VAD submission at MRL 5. The requirement for controlled-experiment verification is considered met by the observational study given the scale and clinical representativeness of the dataset.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
