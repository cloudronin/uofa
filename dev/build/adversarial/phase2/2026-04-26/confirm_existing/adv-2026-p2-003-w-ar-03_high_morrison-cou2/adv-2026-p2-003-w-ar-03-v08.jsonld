  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/vad-hemolysis-controlled-exp",
    "type": "Requirement",
    "name": "Hemolysis prediction verification — controlled experiment mandate",
    "description": "At Model Risk Level 5 and decision consequence High, hemolysis predictions from the CFD model must be verified against empirical measurements obtained through a controlled experiment. The controlled experiment shall impose defined inlet flow rates, impeller speeds, and fluid properties under laboratory conditions with randomised test order and blinded measurement to eliminate observer bias. Observational or retrospective data sources do not satisfy this requirement because confounding variables cannot be eliminated and causal inference is not established.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-obs-study-result",
      "type": "ValidationResult",
      "name": "Multi-site observational hemolysis validation result",
      "description": "Hemolysis index values predicted by the CFD model were compared against plasma free haemoglobin measurements drawn from a three-site clinical registry covering 312 VAD device-patient pairs over an 18-month post-implant follow-up period. Predicted normalised index of haemolysis (NIH) values fell within the inter-quartile range of observed clinical measurements at four of five operating points. The fifth operating point (6 L/min, 3200 RPM) showed a 14% over-prediction of NIH, attributed to patient-specific haematocrit variability not captured in the nominal CFD boundary conditions. Monte Carlo uncertainty bands (5th–95th percentile) encompassed all clinical observations, supporting the conclusion that the model is predictively adequate for absolute hemolysis assessment. The breadth of the clinical dataset, spanning diverse patient anatomies and comorbidity profiles across three independent sites, is considered to provide a rigorous empirical foundation substantially equivalent to bench-level testing. Assessment team concluded that this evidence satisfies the empirical verification requirement for MRL 5.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/vad-hemolysis-obs-study",
        "type": "Activity",
        "name": "Multi-site clinical registry observational study — VAD hemolysis",
        "activityType": "observational-study",
        "description": "Retrospective extraction and analysis of plasma free haemoglobin measurements from three VAD implant centres (n=312). Data were collected under routine clinical care; no experimental manipulation of operating conditions was performed. Haematocrit, flow rate, and impeller speed were recorded from device telemetry logs and compared to CFD predictions at matched operating points.",
        "startedAtTime": "2024-03-01T00:00:00Z",
        "endedAtTime": "2025-01-15T00:00:00Z"
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vad-uq-monte-carlo-result",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ sweep — hemolysis uncertainty quantification",
      "description": "A 10,000-sample Monte Carlo sweep was conducted over inlet flow rate (±5%), fluid viscosity (±8%), and impeller speed (±2%) to characterise prediction uncertainty. The 90th-percentile NIH prediction remained below the absolute clinical threshold of 0.8 mg/dL per 100 L at all five operating points, supporting the adequacy conclusion.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/vad-monte-carlo-uq",
