  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/req-val-01",
    "type": "Requirement",
    "name": "REQ-VAL-01: Controlled-experiment validation of hemolysis predictions",
    "description": "Validation of absolute hemolysis index predictions shall be supported by controlled experiments in which pump operating conditions (flow rate, rotational speed) are independently set and held fixed by the investigator for each test point. Passive or observational data collection from clinical or non-controlled operational runs is not sufficient to satisfy this requirement. At least five distinct operating-condition combinations spanning the VAD clinical envelope must be tested. This requirement is driven by MRL 5 and the HIGH decision consequence classification under ASME V&V 40-2018.",
    "requiredVerificationMethod": "controlled-experiment"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-multipoint-2024",
      "type": "ValidationResult",
      "name": "Multi-condition hemolysis measurement validation result",
      "description": "Hemolysis index values were measured across five flow-speed combinations (3 L/min at 2400 RPM, 4 L/min at 2600 RPM, 5 L/min at 2800 RPM, 6 L/min at 3000 RPM, and 7 L/min at 3200 RPM) using a standardised FDA pump loop equipped with calibrated inline plasma-free haemoglobin sampling ports, pressure transducers, and ultrasonic flow meters. Measurements were repeated in triplicate at each condition. The resulting normalised index of hemolysis (NIH) values ranged from 0.0021 to 0.0078 g/100 L, all below the accepted clinical threshold of 0.01 g/100 L. CFD predictions agreed to within 18% across all five points, with Monte Carlo UQ intervals overlapping measured values at four of five conditions. The breadth of the measurement campaign, the instrumentation fidelity, and the triplicate replication protocol collectively provide strong empirical grounding for the model's hemolysis predictions across the VAD operating envelope. Reviewers noted that the dataset represents the most comprehensive hemolysis characterisation of this pump geometry published to date.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/act-val-01",
        "type": "Activity",
        "name": "ACT-VAL-01: FDA pump hemolysis data collection campaign",
        "description": "Data were collected from instrumented pump runs conducted during a multi-site clinical evaluation programme. Operating conditions were recorded as encountered during standard clinical use protocols; investigators did not independently set or randomise operating points. Inline NIH sampling was performed whenever pump operation coincided with a scheduled measurement window. Five operating-condition clusters were identified post-hoc from the recorded data to correspond to the five COU flow-speed combinations.",
        "activityType": "observational-study",
        "startedAtTime": "2023-06-01T00:00:00Z",
        "endedAtTime": "2024-01-31T00:00:00Z"
      },
      "quantitativeResult": {
        "metric": "Normalised Index of Hemolysis (NIH)",
        "unit": "g/100 L",
        "observedRange": "0.0021 – 0.0078",
        "clinicalThreshold": 0.01,
        "maxCFDError": 0.18
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-uq-montecarlo-2024",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification validation result",
      "description": "Monte Carlo UQ was performed over 10,000 samples of the power-law hemolysis model parameters (C, alpha, beta) drawn from literature distributions. The 95th-percentile NIH prediction remained below 0.0095 g/100 L at all five operating conditions, providing probabilistic assurance that the model does not systematically underpredict hemolysis risk. UQ intervals were propagated through the CFD solver using a non-intrusive polynomial-chaos surrogate trained on 64 high-fidelity CFD evaluations.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/act-uq-01",
        "type": "Activity",
        "name": "ACT-UQ-01: Monte Carlo UQ propagation",
