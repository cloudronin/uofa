  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all 13 credibility factors. Seven factors were assessed; six of the seven achieved levels below required levels, consistent with MRL 5 expectations for a Class III device. The panel noted that the multi-site registry observational study provides extensive real-world hemolysis data across a broad patient population, with propensity-score matching reducing confounding to an acceptable degree. The study's flow-rate stratification and speed-matched cohort design were judged by the panel to be functionally equivalent to controlled bench experimentation for the purposes of this assessment, given the impracticability of conducting fully controlled in-vitro experiments at all five COU operating points. Monte Carlo UQ confirms that 95th-percentile hemolysis index remains below the clinical threshold. On balance, the panel accepted the submission with the understanding that identified credibility gaps will be addressed in a subsequent COU3 assessment incorporating bench validation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
