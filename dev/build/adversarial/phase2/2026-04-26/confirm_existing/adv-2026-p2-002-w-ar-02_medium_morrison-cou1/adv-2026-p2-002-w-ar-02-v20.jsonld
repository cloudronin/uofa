  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the CFD hemolysis model applied to the FDA generic centrifugal blood pump at MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2. The assessed factors collectively demonstrate that the model is fit for the intended use of identifying worst-case hemolysis operating conditions. The mesh refinement study confirmed practical independence of hemolysis predictions, and output comparison against FDA benchmark data showed agreement within engineering tolerance (MAPE 12.3%). The relative hemolysis index RH < 1 was satisfied across all five operating points. Minor gaps in formal uncertainty quantification for discretization error are noted as engineering caveats typical of applied CFD assessments at this risk level; these do not alter the overall credibility conclusion given the corroborating experimental agreement and the medium model influence in the decision context. The package is accepted as providing adequate credibility evidence for the Class II CPB device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
