  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted. Six of the seven assessed factors meet or exceed their required levels, and the remaining six factors are appropriately scoped out at MRL 2. The Test Conditions factor shows minor documentation gaps relative to full Level 3 requirements; however, the overall validation evidence — including a GCI of 1.9%, mean output comparison error of 8.3%, and consistent trend capture across all five operating points — provides sufficient confidence that the CFD model can identify worst-case hemolysis conditions for this Class II CPB device. The relative hemolysis index criterion (RH < 1) is met at all operating points, and the conservative operating envelope selection further supports the acceptance decision. The assessment team concludes that the model is fit for the stated purpose.",
