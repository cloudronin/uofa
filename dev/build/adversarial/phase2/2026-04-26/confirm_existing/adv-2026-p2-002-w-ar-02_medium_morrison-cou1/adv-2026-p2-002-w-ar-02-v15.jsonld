  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors at Model Risk Level 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2. All assessed factors demonstrate satisfactory performance for the intended COU. The discretization error study showed GCI values marginally above the 5% threshold at two operating points, but the team determined that the hemolysis index differences between mesh levels fall within experimental measurement uncertainty, and the overall simulation workflow is consistent with prior applications to similar pump geometries. The validation dataset directly corresponds to the COU geometry and operating envelope, and quantitative output comparisons meet the stated acceptance criteria. On balance, the evidence supports sufficient model credibility for identifying worst-case hemolysis operating conditions for the Class II CPB device. Decision: Accepted.",
