  "signature": "ed25519:7c3a1f9d2e4b8c6a5f2d7e1b3c9a4f6d2e8b5c1a7f3d9e2b4c6a1f8d5e3b7c2a",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented QA procedures and regression test suite covering primary flow features.",
      "rationale": "ANSYS Fluent 2022 R2 is used under a validated QA plan with ISO 9001-compliant procedures. Version control and regression testing are documented in the software quality plan. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver verified against at least one canonical rotating-flow benchmark with documented order-of-accuracy confirmation.",
      "rationale": "The CFD solver has been verified against the Taylor-Couette rotating flow benchmark and the lid-driven cavity problem. Order of accuracy was confirmed at 1.92 for velocity fields. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis performed on at least three systematically refined meshes; discretization error reported as percentage of QoI and shown to be below 5% for hemolysis index.",
      "rationale": "A mesh refinement study was conducted using three mesh densities (2.1M, 5.4M, and 11.8M elements). Grid convergence index (GCI) was computed and the hemolysis index showed monotonic convergence. Engineering judgment confirms the discretization error is within acceptable bounds for comparative hemolysis assessment at MRL 2, supporting the overall acceptance decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; flow rates and rotational speeds match simulation boundary conditions within 5%.",
      "rationale": "FDA benchmark experimental data provides flow rates of 2.5 and 5.0 L/min at 2500 and 3500 RPM. Measured boundary conditions are applied directly to the CFD model. Deviations between experimental and simulation inlet conditions are less than 3%. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted hemolysis index compared to experimental measurements with quantified agreement metric; mean relative error below 20%.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values were compared against FDA experimental measurements across 5 operating points. Mean relative error of 14.7% was achieved, with all predictions within experimental uncertainty bands at 4 of 5 operating conditions. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoI (hemolysis index) directly maps to clinical endpoint; mapping documented with physiological justification.",
      "rationale": "The relative hemolysis index (RH) is directly derived from the normalized index of hemolysis (NIH), which is the established clinical surrogate for blood trauma in CPB devices. The mapping from CFD shear stress to RH is documented in the validation plan with reference to ASTM F1841. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry or a documented surrogate; operating conditions overlap with COU envelope.",
      "rationale": "Validation was performed using the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU. Operating conditions span the full CPB flow-speed envelope. The validation domain directly encompasses the COU operating space. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error is not assessed at MRL 2 for comparative hemolysis studies. The factor is scoped to not-assessed per the MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
