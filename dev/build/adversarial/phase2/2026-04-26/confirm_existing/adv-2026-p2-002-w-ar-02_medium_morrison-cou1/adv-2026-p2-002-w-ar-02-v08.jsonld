  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for MRL 2. Seven factors were formally assessed; six are appropriately scoped as not-assessed at MRL 2. The model demonstrates adequate predictive capability for identifying worst-case hemolysis operating conditions, with experimental comparisons showing mean relative error of 14.7% against FDA benchmark data. Mesh refinement studies confirmed monotonic convergence of the hemolysis index, and engineering judgment supports that the overall simulation credibility is sufficient for the comparative assessment purpose. The relative hemolysis index criterion (RH < 1) is met across all five evaluated operating conditions. The assessment team concludes that the body of evidence is sufficient to support regulatory submission for this Class II CPB device at MRL 2, and the decision is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
