  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and version control meets MRL 2 requirements.",
      "rationale": "ANSYS Fluent v19.2 is used under a controlled software environment with documented release notes, regression test suite results, and version-locked simulation files. QA procedures are consistent with MRL 2 expectations for a Class II device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verification benchmarks demonstrate correct implementation of governing equations for turbulent internal flow.",
      "rationale": "ANSYS Fluent has been verified against standard benchmark cases including lid-driven cavity and pipe flow. Published verification documentation from the vendor supports correct numerical implementation of the RANS equations used in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with Richardson extrapolation or GCI analysis demonstrating discretization error below 5% for hemolysis index QoI across all five operating points.",
      "rationale": "A mesh sensitivity study was conducted using three grid densities (3.2M, 6.7M, and 12.1M elements). Results indicate hemolysis index values converge with refinement, and the fine-mesh solution is considered representative. Minor asymmetries in the impeller passage were noted but attributed to geometric complexity rather than numerical error. The team is confident the discretization scheme is adequate for identifying relative worst-case conditions, and the overall evidence package supports acceptance of the model for its intended use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions are documented and cover the operating envelope relevant to CPB use.",
      "rationale": "Experimental hemolysis data were collected at five flow-speed combinations spanning the clinical CPB operating range (2–6 L/min, 2000–3500 RPM). Test conditions are documented in the laboratory protocol and are representative of the intended clinical use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index agrees with experimental measurements within 20% across all validation operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) values agree with experimental measurements within 15% at four of five operating points, and within 22% at the fifth point. The team assessed this as acceptable given experimental variability and the relative comparison nature of the acceptance criterion (RH < 1)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear stress distribution) are directly relevant to the hemolysis prediction objective.",
      "rationale": "The primary QoI is the normalized index of hemolysis derived from the power-law hemolysis model integrated over all fluid pathlines. This QoI is directly linked to the regulatory acceptance criterion and is consistent with FDA guidance on computational hemolysis assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities are performed on a geometry and at conditions sufficiently similar to the COU to support extrapolation of credibility.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is the same geometry used in the COU. Operating conditions span the clinical CPB envelope. The validation evidence is directly applicable to the intended use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria are documented and residuals meet solver convergence thresholds.",
      "rationale": "All simulations were run to residual convergence below 1e-5 for continuity and momentum equations. Mass imbalance across inlet and outlet boundaries is less than 0.1%. Convergence histories are archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for Class II device with medium model influence.",
      "rationale": "Use error assessment is not required at Model Risk Level 2 for this device classification and model influence category. Scoped out per MRL 2 assessment matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected turbulence model and hemolysis power-law model are appropriate for the flow regime and have been validated in the literature for blood pump applications.",
      "rationale": "The SST k-omega turbulence model is selected based on published literature demonstrating its suitability for rotating internal flows with adverse pressure gradients. The Giersiepen-Wurzinger power-law hemolysis model is widely used in FDA-referenced computational hemolysis studies. Model form selection is well-supported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Boundary conditions and material properties are derived from documented clinical and experimental sources with uncertainty characterization.",
      "rationale": "Inlet flow rates and rotational speeds are set to match the five clinical operating points. Blood viscosity is modeled as Newtonian with density 1056 kg/m3 and dynamic viscosity 0.0035 Pa·s, consistent with FDA guidance values. Geometric inputs are taken from the published FDA benchmark geometry."
    },
