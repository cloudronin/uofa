  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for MRL 2. Seven factors were formally assessed and six were scoped out as not required at this model risk level. The assessed factors collectively demonstrate that the CFD model is fit for purpose in identifying worst-case hemolysis operating conditions for the FDA generic centrifugal pump. Mesh sensitivity analysis confirmed convergence trends, turbulence and hemolysis model selections are well-supported by literature, and validation against experimental NIH data shows acceptable agreement. Minor deviations in output comparison at one operating point and the complexity of the impeller geometry introduce some engineering uncertainty, but these are considered acceptable given the relative nature of the acceptance criterion (RH < 1) and the corroborating experimental testing program. The overall evidence is sufficient to support regulatory submission for this Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
