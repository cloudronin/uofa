  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 factors at Model Risk Level 2. Seven factors were formally assessed; six are not required at MRL 2. All assessed factors demonstrate sufficient evidence to support the intended use. The CFD model reliably identifies worst-case hemolysis operating conditions for the Class II CPB device across the five evaluated flow-speed combinations, with predicted RH values below 1.0 at all nominal operating points. Mesh refinement results show consistent hemolysis hotspot locations and acceptable agreement with experimental data. Minor discretization uncertainty in the blade-tip clearance region is acknowledged but is not considered material to the comparative RH < 1 acceptance criterion. The team concludes the model is fit for purpose and the submission package is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
