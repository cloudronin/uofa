  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted at Model Risk Level 2. All seven assessed credibility factors demonstrate sufficient evidence to support the intended use. The CFD model reliably predicts relative hemolysis ranking across operating conditions, and validation against the FDA generic pump dataset confirms acceptable predictive accuracy. Mesh sensitivity analysis confirmed that the fine mesh solution is appropriate for comparative hemolysis evaluation, with variation between mesh densities within engineering tolerance for this application. The model is suitable for identifying worst-case hemolysis operating conditions and supporting the regulatory submission for the Class II CPB device.",
