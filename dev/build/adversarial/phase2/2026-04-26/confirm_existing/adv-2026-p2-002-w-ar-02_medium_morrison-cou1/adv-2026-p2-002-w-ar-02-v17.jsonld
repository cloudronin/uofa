      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be a commercially validated CFD code with documented version control and regression testing records.",
      "rationale": "ANSYS Fluent 2022R2 is used with full version control and documented regression test suite. All QA records are archived and traceable to the simulation runs submitted for this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/morrison-ncv",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code must demonstrate correct implementation of governing equations via manufactured solution or benchmark comparison.",
      "rationale": "Manufactured solution benchmarks for incompressible Navier-Stokes confirm second-order spatial convergence. Benchmark results are consistent with published ANSYS Fluent verification documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/morrison-disc-error",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be estimated using at least three systematically refined meshes with GCI < 5% on hemolysis index QoI, and Richardson extrapolation must be reported.",
      "rationale": "A three-level mesh refinement study was conducted using coarse (2.1M cells), medium (5.8M cells), and fine (14.2M cells) meshes. The observed order of convergence was approximately 1.7 and the GCI for the relative hemolysis index was computed at 8.3% between medium and fine meshes. While the team considers this acceptable given the complexity of the rotating geometry and the engineering conservatism built into the RH < 1 acceptance criterion, formal Richardson extrapolation to the zero-mesh-spacing limit was not completed due to computational resource constraints. The moderate GCI value reflects typical variability in turbulent hemolysis predictions and does not materially affect the qualitative ranking of worst-case operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/morrison-test-conditions",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be documented and match simulated boundary conditions within stated tolerances.",
      "rationale": "FDA benchmark experimental conditions are fully documented. Simulated boundary conditions (flow rates 2–6 L/min, speeds 2000–3500 RPM, 37°C, 33% hematocrit bovine blood analog) match experimental protocol within ±2% for all parameters."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/morrison-output-comparison",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within two standard deviations of experimental scatter across all five operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) values fall within the experimental band (mean ± 2σ) for 4 of 5 operating points. The outlier at 6 L/min / 3500 RPM is within 12% of the experimental mean, attributed to secondary flow instabilities not fully captured by the k-ω SST turbulence model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/morrison-qoi-relevance",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) must be directly linked to the clinical decision criterion and traceable to device labeling requirements.",
      "rationale": "The relative hemolysis index RH = NIH_device / NIH_predicate is the primary QoI and maps directly to the 510(k) substantial equivalence criterion. Traceability to FDA guidance on hemolysis testing is documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/morrison-validation-relevance",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow regime, and fluid properties representative of the CPB COU.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry under CPB-range flow conditions with a blood analog fluid. The validation domain overlaps the COU operating envelope for all five flow-speed combinations assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/morrison-solver-error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1×10⁻⁵ for all equations and mass imbalance below 0.1%.",
      "rationale": "All simulations converged to residuals below 5×10⁻⁶ for continuity, momentum, and turbulence equations. Global mass imbalance was below 0.05% in all cases. Convergence histories are archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/morrison-use-error",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for this COU; simulation is executed by trained analysts under documented SOPs.",
      "rationale": "At Model Risk Level 2 with medium model influence, formal use-error assessment is not required. Simulations are executed by credentialed CFD analysts following internal SOPs. Not assessed per MRL 2 scoping decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/morrison-model-form",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; turbulence model selection justified by published literature comparisons.",
      "rationale": "Model form uncertainty for turbulence closure (k-ω SST) is not formally quantified at MRL 2. Selection is justified by published benchmarks for similar rotating machinery hemolysis predictions. Not assessed per MRL 2 scoping decision."
