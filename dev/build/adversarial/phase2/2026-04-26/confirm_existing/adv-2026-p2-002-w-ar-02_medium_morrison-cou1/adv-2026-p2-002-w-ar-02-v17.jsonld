  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at Model Risk Level 2. Seven factors were formally assessed and six were scoped out as not required at MRL 2. All assessed factors were found to meet or substantially approach their required credibility levels. The mesh convergence study demonstrated consistent hemolysis index predictions across three refinement levels, with GCI values considered acceptable by the team given the engineering conservatism of the RH < 1 acceptance criterion and the relative nature of the hemolysis comparison to the predicate device. Output comparison showed agreement within experimental uncertainty for the majority of operating points. The overall evidence base is judged sufficient to support the intended use of the CFD model for identifying worst-case hemolysis operating conditions for the Class II CPB device, and the package is Accepted for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
