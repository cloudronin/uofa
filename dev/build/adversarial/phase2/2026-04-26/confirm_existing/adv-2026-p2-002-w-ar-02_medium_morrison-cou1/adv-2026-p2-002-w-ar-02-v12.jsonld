  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the CFD hemolysis prediction model at MRL 2. Seven factors were formally assessed; six were determined not to require assessment at this model risk level. All assessed factors demonstrate adequate evidence for the intended comparative use. The discretization error assessment, while relying primarily on global flow quantities for the GCI analysis, is considered sufficient given the comparative nature of the COU and the consistency of shear stress trends observed across mesh refinement levels. The overall body of evidence supports acceptance of the model for identifying worst-case hemolysis operating conditions for the Class II CPB device, with the hemolysis index remaining below the RH < 1 acceptance criterion across all evaluated conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
