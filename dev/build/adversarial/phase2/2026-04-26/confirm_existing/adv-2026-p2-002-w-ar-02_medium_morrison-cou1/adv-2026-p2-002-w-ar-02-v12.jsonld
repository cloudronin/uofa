  "signature": "ed25519:b1d4e7a2c5f8b3e6a9d2c5f8b1e4a7d0c3f6b9e2a5d8c1f4b7e0a3d6c9f2b5e8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented verification test suite and version control; solver release notes reviewed for hemolysis-relevant physics modules.",
      "rationale": "ANSYS Fluent 2022R2 was used with documented QA procedures. The solver has an established verification test suite covering viscous flow and rotating machinery. Version control and change logs were reviewed; no relevant defects identified for the blood flow physics modules employed in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases (lid-driven cavity, Poiseuille flow) at expected convergence rates for the discretization schemes employed.",
      "rationale": "Verification benchmarks including the lid-driven cavity at Re=1000 and fully developed pipe flow were reproduced within 0.5% of published reference solutions. Second-order spatial convergence was confirmed for the pressure-velocity coupling scheme used in the pump simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis demonstrates discretization error below 5% for hemolysis-relevant quantities (shear stress, velocity gradients) across at least three systematically refined meshes.",
      "rationale": "A three-level mesh refinement study was conducted on the FDA pump geometry. The Grid Convergence Index (GCI) was computed for bulk pressure rise and mean outlet velocity, yielding GCI values below 3% for these global quantities. Engineering judgment supports the adequacy of the medium mesh (4.2M cells) for identifying worst-case hemolysis operating conditions, consistent with prior published FDA pump studies. Local shear stress near the impeller blade tips showed acceptable trends across refinement levels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid properties) are documented and match CFD model inputs within measurement uncertainty.",
      "rationale": "FDA benchmark experimental conditions were replicated: blood analog fluid (water-glycerin, viscosity 0.00356 Pa·s, density 1050 kg/m³), inlet flow rates of 2.5 and 6.0 L/min, impeller speeds of 2500 and 3500 RPM. Boundary condition correspondence was verified against the FDA dataset documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index (RH) and pressure-flow curves agree with experimental measurements within ±15% across all 5 operating points.",
      "rationale": "Predicted relative hemolysis index values agreed with experimental FDA pump data within 12% across all five operating conditions. Pressure-flow curve predictions fell within measurement uncertainty bands. The acceptance criterion RH < 1 was met for all evaluated conditions, supporting the intended use comparison against the predicate device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The CFD-derived hemolysis index (based on power-law shear stress accumulation) is demonstrated to be a relevant surrogate for device-induced hemolysis for the intended COU.",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger correlation) applied to CFD-predicted shear stress histories is an established quantity of interest for centrifugal blood pump hemolysis assessment. Literature precedent and FDA guidance support its use as a comparative metric for Class II CPB devices at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use geometry, flow conditions, and fluid properties representative of the CPB COU; any differences are assessed for their impact on predictive credibility.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry under conditions spanning the CPB operating envelope. The blood analog fluid and rotational speed range are representative of clinical CPB conditions. Geometric differences from the specific device under assessment are bounded by the tolerance sensitivity analysis that constitutes the primary use of the model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence is achieved with residuals below 1e-5 for all transport equations; mass imbalance below 0.1%.",
      "rationale": "All simulations were run to residual convergence levels below 1×10⁻⁵ for continuity, momentum, and turbulence equations. Global mass imbalance was confirmed below 0.05% for each operating point. Convergence histories were monitored and archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup was reviewed by a second analyst; boundary condition inputs and post-processing scripts were independently verified.",
      "rationale": "An independent analyst reviewed the simulation setup files, boundary condition assignments, and post-processing scripts prior to production runs. No discrepancies were identified. At MRL 2 with medium model influence, this level of peer review satisfies the use error requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for comparative hemolysis studies; model form adequacy is addressed implicitly through output comparison.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis correlation form) is not formally assessed at MRL 2 for this comparative COU. The SST k-ω turbulence model is standard practice for internal blood flow CFD and its adequacy is supported by the output comparison results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; fluid property uncertainty is bounded by experimental characterization of the blood analog.",
      "rationale": "Formal uncertainty propagation of model inputs is not required at MRL 2. Fluid properties were taken from the FDA benchmark documentation with negligible measurement uncertainty relative to the hemolysis prediction sensitivity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; FDA benchmark dataset provides sufficient sample diversity for this comparative COU.",
      "rationale": "The FDA benchmark dataset encompasses multiple experimental runs across the operating envelope. Formal statistical sample adequacy assessment is not required at MRL 2 for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; input parameter equivalency between validation and COU conditions is addressed qualitatively through the relevance assessment.",
      "rationale": "Formal equivalency mapping is not required at MRL 2. The qualitative assessment under 'Relevance of validation activities to the COU' addresses the correspondence between validation inputs and COU conditions."
    }
