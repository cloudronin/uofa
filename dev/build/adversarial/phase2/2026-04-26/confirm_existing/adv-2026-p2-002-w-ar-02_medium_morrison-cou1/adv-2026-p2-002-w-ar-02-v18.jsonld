  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent) used with documented version control and standard QA procedures consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 19.2 employed under institutional license with version-controlled case files. Solver release notes and known-issue documentation reviewed. Gradation 2 requirements satisfied for commercial solver deployment in a regulated medical device context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmark cases (lid-driven cavity, pipe flow) reproduce analytical solutions within 1% for relevant Reynolds number range.",
      "rationale": "Standard benchmark verification cases included in ANSYS Fluent validation suite confirm correct implementation of governing equations. Pipe-flow and rotating-frame benchmark results agree with analytical solutions to within 0.8%, satisfying Gradation 2 code verification requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI across at least three systematically refined meshes; Richardson extrapolation applied to confirm asymptotic convergence.",
      "rationale": "A three-level mesh refinement study was conducted using coarse (2.1 M), medium (5.4 M), and fine (13.8 M) element counts. GCI values for the primary hemolysis index quantity of interest ranged from 4.2% to 8.7% across the five operating points, with the highest GCI observed at the peak-shear operating condition. The apparent order of convergence was consistent with second-order spatial discretization for most regions. Given that hemolysis predictions are used comparatively against a predicate device rather than in isolation, the team considers the discretization uncertainty acceptable for engineering decision-making purposes. Mesh sensitivity trends are monotonically convergent and the medium mesh was selected for production runs as a balance of accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, inlet velocity profile) match simulation boundary conditions within stated uncertainty bounds.",
      "rationale": "Experimental test loop operated at 37 ± 0.5 °C with porcine blood at 33 ± 2% hematocrit. Inlet velocity profiles measured by laser Doppler velocimetry and applied as boundary conditions. All controlled parameters documented in test protocol and confirmed within simulation input tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) within 15% of experimentally measured values across all 5 operating points.",
      "rationale": "CFD-predicted RH values compared against bench-scale hemolysis measurements at all five flow-speed combinations. Prediction errors ranged from 3.1% to 13.8%, with mean absolute error of 8.4%. All predictions satisfy the 15% acceptance band. Worst-case operating point correctly identified by the model in agreement with experimental ranking."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, wall shear stress distribution) are directly linked to the clinical endpoint of red blood cell damage and are consistent with FDA guidance on hemolysis assessment.",
      "rationale": "The primary QoI, the relative hemolysis index computed via the power-law hemolysis model, is directly tied to plasma-free hemoglobin elevation and RBC mechanical trauma. Secondary QoIs (volumetric shear stress distributions, exposure time histograms) provide mechanistic insight consistent with FDA guidance document on blood-contacting device CFD."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic pump geometry under CPB-representative flow conditions (2–6 L/min, 2000–3500 RPM).",
      "rationale": "Validation activities conducted on the identical FDA generic centrifugal pump geometry using the same operating envelope specified in the COU. Fluid rheology, rotational speed range, and flow rate range all match COU conditions. Validation domain overlap with COU is assessed as high, satisfying Gradation 2 relevance requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence confirmed by residual reduction of at least 4 orders of magnitude and monitored QoI stabilization within 0.5% over final 500 iterations.",
      "rationale": "All steady-state simulations converged to residuals below 1×10⁻⁵ for continuity and momentum equations. Hemolysis index monitor points showed variation below 0.3% over the final 500 iterations in all cases. Rotating reference frame formulation validated against sliding mesh transient results for the nominal operating point."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition inputs traceable to documented test protocol.",
      "rationale": "Independent peer review of simulation setup files conducted by senior CFD analyst not involved in original model construction. Boundary conditions, material properties, and solver settings verified against test protocol documentation. No discrepancies identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; model form uncertainty acknowledged as acceptable given comparative use context.",
      "rationale": "Model form assessment scoped out at MRL 2 for comparative hemolysis ranking. The power-law hemolysis model is an established literature formulation; model form uncertainty is implicitly bounded by the comparative RH < 1 acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values used with sensitivity noted.",
      "rationale": "Formal input uncertainty quantification not required at MRL 2. Nominal material property values from published literature used. Sensitivity to hematocrit and viscosity model parameters noted qualitatively."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; single blood pool used for all experiments with batch variability noted.",
      "rationale": "Test sample characterization not formally assessed at MRL 2. Single porcine blood pool used across experimental runs with hematocrit monitored. Inter-batch variability acknowledged but not quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
