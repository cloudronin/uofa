  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 factors for MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2. All assessed factors were found to meet or approach their required credibility levels. The discretization error study demonstrated monotonically convergent mesh behavior and GCI values that, while ranging up to 8.7% at the most challenging operating point, are considered acceptable in the context of comparative hemolysis ranking against a predicate device. The team notes that comparative use of the model (RH < 1 criterion) provides an inherent robustness to absolute discretization uncertainty. Output comparison errors remained within the 15% acceptance band across all operating points, and the worst-case hemolysis condition was correctly identified. On balance, the evidence base is sufficient to support the intended use of the model for identifying worst-case hemolysis operating conditions for the Class II CPB device, and the assessment is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
