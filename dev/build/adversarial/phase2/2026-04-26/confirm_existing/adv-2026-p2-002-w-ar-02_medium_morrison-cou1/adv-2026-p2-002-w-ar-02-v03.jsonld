      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated; residuals reduced by at least 4 orders of magnitude for all transport equations.",
      "rationale": "All simulations were run to residual convergence with continuity and momentum residuals below 1×10⁻⁵. Mass imbalance across rotor-stator interface confirmed below 0.1%. Iterative solver error is negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a second analyst; boundary conditions and material properties independently verified.",
      "rationale": "An independent reviewer confirmed boundary condition assignments, fluid property inputs (blood viscosity 0.0035 Pa·s, density 1056 kg/m³), and turbulence model settings. No use errors were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
