  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at Model Risk Level 2. Seven factors were formally assessed and six were appropriately scoped out at MRL 2. The assessed factors collectively demonstrate that the CFD model is fit for the intended purpose of identifying worst-case hemolysis operating conditions for the Class II CPB device. The mesh convergence study showed satisfactory convergence behavior across the three refinement levels, and the hemolysis index predictions agreed with FDA benchmark experimental data within the variability expected for power-law hemolysis models in the published literature. Some sensitivity in near-wall shear stress resolution was noted during mesh refinement, but the team judged this to be within acceptable engineering bounds given the comparative nature of the COU. The validation evidence, combined with the medium model influence and the availability of physical test confirmation, supports acceptance of the model for the stated COU. The decision is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
