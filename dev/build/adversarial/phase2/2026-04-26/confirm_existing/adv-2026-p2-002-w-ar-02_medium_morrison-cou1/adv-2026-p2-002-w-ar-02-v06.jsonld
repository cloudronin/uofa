  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the CFD hemolysis model at MRL 2. Seven factors were formally assessed and six were scoped out as not required at this model risk level. The assessed factors collectively demonstrate that the model is fit for the intended use of identifying worst-case hemolysis operating conditions. The mesh convergence study confirms that the production mesh captures the dominant flow features governing hemolysis, and the engineering judgment of the simulation team supports that the observed GCI values are acceptable given the comparative nature of the COU decision criterion. Validation against the FDA benchmark dataset shows agreement within acceptable tolerances across all five operating points. The team concludes that the model provides sufficient credibility evidence to support the regulatory submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
