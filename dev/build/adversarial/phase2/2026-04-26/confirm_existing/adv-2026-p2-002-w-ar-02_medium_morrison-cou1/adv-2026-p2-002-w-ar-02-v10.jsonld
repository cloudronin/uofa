  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted. Seven of thirteen factors were formally assessed, with the majority meeting their required levels. The model demonstrates adequate predictive capability for the relative hemolysis index across the five operating points of interest, with NIH predictions within 18% of experimental data and pressure-head agreement within 7%. The discretization error study confirmed that the medium mesh captures dominant hemolysis-driving flow features, and the small observed differences between mesh refinement levels are judged acceptable given the comparative nature of the RH acceptance criterion. Engineering caveats regarding turbulence model fidelity in the impeller gap region are acknowledged; however, these are considered within the uncertainty budget appropriate for a Class II device at MRL 2. Overall, the simulation evidence is sufficient to support the regulatory submission claim that the device meets the RH < 1 acceptance criterion relative to the predicate device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
