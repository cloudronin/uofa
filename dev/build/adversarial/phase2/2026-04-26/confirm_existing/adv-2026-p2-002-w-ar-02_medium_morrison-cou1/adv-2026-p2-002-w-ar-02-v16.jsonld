  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the FDA GCBP CFD hemolysis model at MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2 for a Class II device. The assessed factors collectively demonstrate that the model is fit for the intended use of identifying worst-case hemolysis operating conditions. Predicted NIH values agreed with experimental data within 18% across all operating points, and the worst-case condition was correctly ranked. Minor limitations in the mesh convergence evidence were noted but were considered acceptable given the engineering conservatism in the RH < 1 acceptance criterion and the overall agreement between simulation and experiment. The model is accepted for use in the COU as defined.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
