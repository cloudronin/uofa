  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial solver with documented QA processes; version control and regression testing records available.",
      "rationale": "ANSYS Fluent v19.2 is used. Vendor-supplied QA documentation, including regression test suites and version release notes, satisfies MRL 2 requirements. No custom solver modifications were introduced."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark test cases from published literature demonstrate correct solver implementation of governing equations.",
      "rationale": "The solver has been verified against the FDA nozzle benchmark (ASME V&V 20) and lid-driven cavity test cases. Results are consistent with published reference solutions within acceptable tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal grid convergence index (GCI) or Richardson extrapolation applied across at least three mesh refinement levels; discretization uncertainty reported and within 5% of QoI.",
      "rationale": "A three-level mesh refinement study was conducted with coarse (1.2M), medium (3.8M), and fine (9.4M) cell counts. Monotonic convergence was observed for pressure head and bulk velocity. The team notes that hemolysis index predictions showed some sensitivity to near-wall mesh resolution in high-shear impeller regions, and engineering judgment was applied to select the medium mesh as the production grid. Formal GCI values were computed for hydraulic quantities but not explicitly reported for the hemolysis scalar transport equation, which is acknowledged as a general modelling limitation common to this class of simulation. Overall discretization behaviour is considered acceptable for the intended comparative assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) are documented and traceable to calibrated instrumentation.",
      "rationale": "In-vitro experiments were conducted at five operating points spanning 2–6 L/min and 2000–3500 RPM. Fluid temperature, haematocrit, and viscosity are documented. Instrumentation calibration records are on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., relative hemolysis index RH) applied; model predictions within acceptance band across all operating points.",
      "rationale": "RH values computed from CFD predictions and experimental measurements for all five operating points. CFD-predicted RH < 1 at worst-case condition, consistent with experimental result. Mean absolute error across operating points is 12%, within the pre-specified 15% acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) are directly linked to the clinical endpoint and acceptance criterion.",
      "rationale": "The primary QoI is the normalised index of hemolysis (NIH) and relative hemolysis index (RH). Both are standard metrics for blood pump biocompatibility assessment and are directly linked to the regulatory acceptance criterion RH < 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same device geometry and operating envelope as the COU.",
      "rationale": "Validation experiments were performed on the FDA generic centrifugal pump geometry under the same five flow-speed combinations defined in the COU. Fluid and boundary conditions match the intended use scenario."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated; residuals reduced by at least four orders of magnitude.",
      "rationale": "All simulations achieved residual reductions of five or more orders of magnitude. Mass imbalance across domain boundaries is less than 0.01%. Convergence monitoring plots are archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary conditions and material properties verified against source documentation.",
      "rationale": "An independent peer review of the simulation setup was conducted by a second analyst. Boundary conditions, fluid properties, and turbulence model settings were verified against the experimental protocol. No discrepancies were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for comparative device assessment.",
      "rationale": "Model form uncertainty is not required to be formally assessed at Model Risk Level 2 for this comparative COU. The SST k-omega turbulence model is widely used for blood pump CFD and is considered appropriate by community consensus."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; input parameter sensitivity not required for comparative assessment.",
      "rationale": "Formal input uncertainty quantification is not required at MRL 2. Nominal values for fluid viscosity and density are taken from published literature for porcine blood at 37°C and are consistent with experimental conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; sample variability characterisation not required.",
      "rationale": "Sample-to-sample variability in experimental hemolysis measurements is noted as an inherent limitation of blood analogue testing. Formal assessment is not required at MRL 2 for this COU."
    },
