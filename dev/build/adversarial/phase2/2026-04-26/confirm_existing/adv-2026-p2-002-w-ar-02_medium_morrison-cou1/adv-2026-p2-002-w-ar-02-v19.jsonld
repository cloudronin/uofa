  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted. Six of seven assessed factors meet their required levels, and the overall evidence base supports the conclusion that the CFD model is sufficiently credible to identify worst-case hemolysis operating conditions for the Class II CPB device at MRL 2. The discretization error factor showed some sensitivity of hemolysis scalar predictions to near-wall mesh resolution; however, the team applied engineering judgment and the hydraulic QoIs demonstrate robust convergence behaviour. The comparative assessment framework (RH < 1 criterion) is considered tolerant of modest discretization uncertainty in the hemolysis transport equation given the conservative nature of the acceptance criterion. All validation comparisons are within the pre-specified acceptance band, and the overall weight of evidence supports model acceptance for the intended use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
