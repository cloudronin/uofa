  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 CPB hemolysis prediction is accepted at Model Risk Level 2. Six of seven assessed factors meet their required credibility levels. The discretization error factor showed an 8% variation between mesh densities, which the team considered acceptable given the relative nature of the hemolysis comparison and the computational constraints of the rotating geometry simulation. The two-mesh sensitivity study, while not constituting a full Richardson extrapolation, provides sufficient confidence that mesh-induced errors do not materially affect the identification of worst-case operating conditions. All validation output comparisons are within the ±15% acceptance band, and the model has been independently reviewed. The overall body of evidence supports use of the CFD model to identify worst-case hemolysis conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
