  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the CPB hemolysis CFD model at MRL 2. Seven factors were formally assessed; six were appropriately scoped out or not assessed at this risk level. The majority of assessed factors achieved their required credibility levels, and validation against the FDA benchmark dataset demonstrated adequate predictive agreement for comparative hemolysis ranking. The discretization error factor was evaluated using a two-level mesh refinement study, and engineering judgment supported the conclusion that mesh-induced uncertainty does not materially affect the worst-case operating point identification. Considering the medium model influence, the availability of confirmatory bench testing, and the comparative nature of the RH < 1 acceptance criterion, the team concludes that the model is sufficiently credible for its intended use and the submission is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
