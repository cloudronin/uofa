  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The integrated credibility assessment for COU1 supports an Accepted decision. Six of seven assessed factors meet their required credibility levels. The discretization error factor exhibited GCI values modestly above the 5% threshold; however, the assessment team determined that the directional consistency of hemolysis index predictions across all mesh densities, combined with the margin available in the RH acceptance criterion, provides sufficient confidence for the intended regulatory use. The five operating points all yielded RH values below 1.0 relative to the predicate device. All six not-assessed factors are appropriately scoped at MRL 2. The overall evidence base is judged adequate for a Class II CPB device at Model Risk Level 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
