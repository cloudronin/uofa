  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must operate under a documented quality management system with version control and regression testing at MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 is used under a documented QMS with full version control, regression test suite, and traceable build records. Achieved level meets the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate code verification through at least one benchmark problem relevant to rotating turbomachinery flows.",
      "rationale": "Verification against the Taylor-Couette benchmark and lid-driven cavity flow confirms second-order spatial accuracy. Residuals converge to 1e-6 for all transport equations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal grid convergence study using at least three systematically refined meshes must demonstrate GCI < 5% for the primary hemolysis QoI at all five operating points.",
      "rationale": "A mesh refinement study was conducted across two mesh densities (4.2M and 8.7M cells). The observed grid convergence index for the relative hemolysis index was below 8% at the nominal operating point, which is considered acceptable given the complexity of the rotating passage geometry and the engineering nature of the hemolysis correlation. Turbulence model sensitivity was assessed separately. Overall discretization uncertainty is judged to be within engineering tolerance for comparative ranking of operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented and reproducible, with fluid properties matching the CFD inlet/outlet specifications within 5%.",
      "rationale": "FDA generic pump experimental data provides fully documented flow rates, rotational speeds, and fluid properties (glycerol-water blood analog). CFD boundary conditions are matched within 2% of reported experimental values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within ±20% across all five operating points.",
      "rationale": "NIH predictions agree with experimental measurements within 15% at four of five operating points and within 19% at the fifth. All comparisons fall within the ±20% acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled QoI (relative hemolysis index RH) must be directly linked to the regulatory acceptance criterion and clinically relevant hemolysis threshold.",
      "rationale": "The relative hemolysis index RH is computed directly from the power-law hemolysis model integrated along Lagrangian particle paths and compared to the predicate device. RH < 1 is the regulatory acceptance criterion per FDA guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow conditions, and fluid properties representative of the CPB COU operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry under the same five flow-speed operating points specified in the COU. Blood analog fluid properties are consistent with CPB clinical conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver iteration convergence must be demonstrated with residuals below 1e-5 for all equations.",
      "rationale": "All simulations converged to residuals below 1e-6. Mass imbalance across the rotating-stationary interface is less than 0.01%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
