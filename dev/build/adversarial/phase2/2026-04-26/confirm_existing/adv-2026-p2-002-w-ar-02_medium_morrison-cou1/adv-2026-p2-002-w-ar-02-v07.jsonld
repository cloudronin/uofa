  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accept-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted at Model Risk Level 2. Six of seven assessed factors meet or exceed their required levels, and the six non-assessed factors are appropriately scoped out per the MRL 2 credibility matrix. The discretization error study, while conducted on two mesh densities rather than the canonical three-mesh Richardson extrapolation, produced GCI values judged by the assessment team to be within acceptable engineering tolerance for the comparative ranking task. All output comparison results fall within the ±20% acceptance band, and software quality assurance, code verification, test conditions, QoI relevance, and validation relevance factors all meet their required levels. On balance, the body of evidence is sufficient to support the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
