  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 factors for the CFD hemolysis prediction of the FDA generic centrifugal blood pump under CPB conditions. Seven factors were formally assessed; six were scoped out as not required at Model Risk Level 2. All assessed factors demonstrate adequate evidence to support the intended use. The mesh refinement study confirms that the CFD model reliably identifies relative hemolysis trends across operating conditions, and the output comparison against FDA benchmark data shows agreement within engineering tolerances. Minor variability in GCI values at high-flow operating points is acknowledged; however, the team judges that the comparative nature of the analysis—where the same model is applied consistently to all design variants—mitigates the practical impact of this variability on the worst-case identification task. The relative hemolysis index predictions are robust to the observed discretization uncertainty levels. On balance, the model is considered credible for its intended use and the submission package is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
