  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2023 R1) holds a current FDA-recognized software quality plan; version-controlled input decks archived in project repository.",
      "rationale": "Ansys Mechanical 2023 R1 used by all three modeling organizations. Each site operates under an ISO 9001-registered quality management system with documented software validation records. Input deck version control confirmed via Git commit history. Achieved level exceeds required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark solutions for linear elastic beam bending and Hertzian contact reproduced within 0.5% of analytical solutions.",
      "rationale": "Standard Ansys verification benchmarks for static structural analysis executed prior to project analysis. Beam bending and contact patch benchmarks reproduced within 0.2% and 0.4% respectively. Numerical code verification requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinement levels; Richardson extrapolation applied.",
      "rationale": "Three-level mesh convergence study performed on screw-rod assembly. Stiffness QoI changed 3.1% (coarse to medium) and 0.8% (medium to fine). Richardson extrapolation yielded GCI < 1.2% on fine mesh. Final analyses conducted on fine mesh. Discretization error adequately characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence to 1e-6 confirmed for all load steps; energy balance checked.",
      "rationale": "All nonlinear load steps converged to force residual norm < 1e-7. Energy balance verified to within 0.03%. No solver warnings or divergence events recorded across 11 parametric runs. Numerical solver error is negligible relative to other uncertainty sources."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by analyst not involved in original build; checklist-based review documented.",
      "rationale": "Model setup independently reviewed by a senior FEA engineer at each of the three organizations using a standardized 47-item checklist. No critical errors identified. Two minor boundary-condition clarifications were resolved prior to final analysis runs. Use error risk rated low."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic model with frictional contact at screw-rod and rod-plate interfaces; material nonlinearity validated against coupon data.",
      "rationale": "Ti-6Al-4V elastoplastic material model (bilinear isotropic hardening) calibrated to ASTM E8 coupon tensile data from the same material lot. Frictional contact (mu=0.2) at all metal interfaces. Model form appropriate for quasi-static large-displacement bending regime. No fluid or dynamic effects required for COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry, and boundary conditions sourced from traceable measurements; sensitivity analysis performed on key inputs.",
      "rationale": "Geometry from certified CMM measurements of production screws and rods. Material properties from lot-specific coupon testing. Torque preload on set screws characterized from calibrated torque wrench measurements. One-at-a-time sensitivity analysis confirmed stiffness QoI most sensitive to rod diameter (±1.8% per 0.05 mm) and least sensitive to friction coefficient (±0.3% per 0.05 unit change)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lots; dimensional inspection records available for all specimens.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two laboratories. All specimens drawn from the same production lot (Lot 2022-NC-75-A). Dimensional inspection records confirm all screws and rods within drawing tolerances. Sample size sufficient for statistical comparison per acceptance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two load levels or construct configurations to confirm model generalizability.",
      "rationale": "All bench tests conducted at a single load configuration (ASTM F1717 standard geometry, 10 mm offset). No variation in rod diameter, screw spacing, or load angle was included in the archived datasets. This limits the breadth of validation evidence. Factor achieved level (2) is below required level (3); this gap is acknowledged and accepted given the standardized nature of the F1717 protocol and the strong agreement at the tested condition."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs confirmed equivalent to test specimen parameters via traceable measurement records; all geometric and material inputs within 2% of measured values.",
      "rationale": "FEA geometry parameterized directly from CMM data for each of the 11 test specimens. Material property inputs matched to lot-specific coupon data. Set-screw torque in the model set to the mean measured value (4.0 N·m) with ±10% sensitivity bounds explored. All model inputs confirmed equivalent to experimental conditions within stated tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; all primary QoIs satisfy E/uval < 1.96 and percent difference < 10%.",
      "rationale": "All three primary QoIs (stiffness, yield force, force at 40 mm) satisfy both acceptance criteria. E/uval values of 0.71, 0.88, and 0.52 are well below the 1.96 threshold. Percent differences of 2.2%, 2.6%, and 1.4% are well below the 10% bound. Output comparison factor fully satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to the regulatory submission metrics and clinical failure modes of interest.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the FDA guidance for pedicle screw 510(k) submissions under ASTM F1717. These QoIs directly relate to the clinical failure modes of screw fracture and construct loosening. Relevance of QoIs to COU is high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities replicate the geometry, material, loading, and boundary conditions of the intended use environment.",
      "rationale": "The bench test dataset was collected using production non-cannulated 7.5 mm pedicle screw constructs assembled per the device instructions for use and tested per ASTM F1717 on the same test fixture geometry as the COU. Loading rates, specimen conditioning, and data acquisition protocols are consistent across both laboratories. The observational nature of the data collection — drawing from archived rather than prospectively designed test campaigns — is considered an acceptable approach given the standardized test protocol, and the validation activities are judged highly relevant to the COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single exception (Test conditions, achieved 2 vs. required 3) is accepted on the basis that ASTM F1717 prescribes a single standardized configuration and multi-condition variation is not standard practice for this device class. All three primary QoIs satisfy quantitative acceptance bounds (E/uval < 1.96; percent difference < 10%). The FEA modeling framework is assessed as credible for predicting non-cannulated 7.5 mm pedicle screw compression-bending performance within the stated COU. The validation dataset, drawn from retrospective observational bench records at two independent laboratories, provides consistent and reproducible experimental reference values that support the credibility conclusion.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
