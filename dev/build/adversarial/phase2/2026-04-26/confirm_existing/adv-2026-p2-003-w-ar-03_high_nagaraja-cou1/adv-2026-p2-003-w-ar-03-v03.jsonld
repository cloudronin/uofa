  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/f1717-cb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/depuy-synthes-vv40-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework meets or exceeds required credibility levels on 12 of 13 V&V 40 factors. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted because the COU is explicitly bounded to the ASTM F1717 static compression-bending scenario and the archived observational dataset comprehensively characterises that scenario. All three QoIs satisfy the pre-established quantitative acceptance criteria (E/uval < 1.96; percentage difference < 10%). The validation activity — drawing on N=11 archived bench-test records reviewed post hoc for ASTM F1717 compliance — is cited throughout this assessment as providing equivalent evidentiary support to a prospective controlled experiment, consistent with the overall credibility determination.",
    "decidedAt": "2025-03-01T00:00:00Z"
  },
