  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single below-threshold factor (Test conditions, achieved 2 vs. required 3) reflects a single-temperature, single-rate test protocol; this gap is accepted given the quasi-static nature of the COU loading and the consistency of results across two independent laboratories. The multi-site observational study provides extensive force-displacement records that corroborate FEA predictions for all three QoIs within the pre-established 10% and E/uval < 1.96 acceptance bounds. The overall credibility evidence is judged sufficient to support a Medium assurance level conclusion for the non-cannulated 7.5 mm pedicle screw compression-bending COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
