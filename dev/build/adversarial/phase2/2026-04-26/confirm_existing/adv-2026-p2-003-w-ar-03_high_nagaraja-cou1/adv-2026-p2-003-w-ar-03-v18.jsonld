  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-cb-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve factors meet or exceed required levels. One factor (Test conditions) achieved level 2 against a required level of 3 due to single-condition testing; this gap is accepted on the basis that ASTM F1717 mandates the tested configuration and the regulatory submission is limited to the tested load rate. E/uval < 1.96 for all three QoIs and all QoI percentage errors below 10%. The multi-site observational data collection programme, conducted under standardised ASTM F1717 fixture geometry across two independent laboratories, provides a comprehensive empirical basis for the output comparison and supports acceptance of the FEA modeling framework for the stated COU.",
