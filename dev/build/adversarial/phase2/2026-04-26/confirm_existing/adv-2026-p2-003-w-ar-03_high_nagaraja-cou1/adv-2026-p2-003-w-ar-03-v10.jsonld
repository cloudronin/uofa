  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-f1717-cb-noncannulated-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted on the basis that titanium alloy construct response is rate-insensitive in the tested displacement range and that the single test condition is consistent with the ASTM F1717 standard. All QoI acceptance bounds are satisfied. The validation dataset, collected prospectively across two independent laboratories following ASTM F1717-15, is considered sufficient to support the medium-assurance credibility claim for this Class II device application.",
