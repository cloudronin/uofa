  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-f1717-cb-stiffness-01",
      "type": "ValidationResult",
      "name": "Construct stiffness QoI comparison — FEA vs. bench data (N=11)",
      "description": "FEA-predicted construct stiffness was compared against the pooled bench dataset from both laboratories. Mean absolute percentage error was 4.2% and E/uval = 1.31, satisfying the <10% and <1.96 acceptance bounds. The comparison draws on N=11 instrumented constructs tested under ambient laboratory conditions with nominally identical fixation configurations. Data collection followed a prospective observational protocol in which construct parameters were recorded as-manufactured without randomised assignment of screw geometry or rod material, consistent with standard regulatory bench-testing practice.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/bench-data-collection-f1717-noncannulated",
        "type": "Activity",
        "activityType": "observational-study",
        "name": "ASTM F1717 bench-test data collection — non-cannulated construct (N=11)",
        "description": "Bench-test data for the non-cannulated 7.5 mm pedicle screw construct were collected prospectively across two independent laboratories following ASTM F1717-15 procedures. Constructs were assembled from as-received implants without blinding or randomisation; test parameters (load rate, span, rod diameter) were held constant per protocol. Stiffness, yield force, and force at 40 mm displacement were recorded for each specimen. Because specimen selection was not randomised and laboratory assignment was determined by availability rather than experimental design, this activity is classified as an observational study rather than a fully controlled experiment. The resulting dataset nonetheless provides a high-quality empirical reference for FEA validation, and the multi-laboratory structure provides independent corroboration of measurement reproducibility."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-f1717-cb-yield-force-01",
