  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/computational-mechanics-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble satisfies all pre-specified quantitative acceptance criteria for the three quantities of interest (construct stiffness, yield force, and force at 40 mm displacement) with normalized validation metrics well below the 1.96 threshold. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is acknowledged and accepted on the basis of regulatory precedent for ASTM F1717 submissions, the high inter-laboratory reproducibility of the experimental dataset, and the conservative nature of the acceptance bounds. The multi-laboratory observational study conducted per ASTM F1717 provides robust empirical grounding for the model predictions, and the assessment team is satisfied that the evidence base supports a Medium assurance level determination consistent with the Medium model risk and Medium decision consequence of this COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
