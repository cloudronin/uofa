  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/f1717-cb-noncannulated-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/vv40-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-level factor (Test conditions, achieved 1 vs. required 2) is accepted based on an analytical sensitivity study demonstrating that QoI predictions vary by less than 2% across the plausible range of ambient temperature and load rate. All three QoIs satisfy quantitative acceptance bounds (percent difference < 10%; E/uval < 1.96). The FEA model is assessed as sufficiently credible for the intended COU at Medium assurance level.",
