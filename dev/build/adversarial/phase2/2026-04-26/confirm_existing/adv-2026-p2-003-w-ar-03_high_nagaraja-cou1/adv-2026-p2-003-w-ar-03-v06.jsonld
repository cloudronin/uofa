  "hasRequirement": {
    "id": "https://uofa.net/synth/req/f1717-cb-verification-method-req-01",
    "type": "Requirement",
    "name": "ASTM F1717 validation shall be performed using a controlled experiment",
    "description": "Per the project V&V plan (DVP-7500-NC-rev3, Section 4.2), validation of FEA predictions for ASTM F1717 compression-bending shall be substantiated by a controlled experiment in which specimens are prospectively randomised, environmental conditions are actively monitored and held within specified tolerances, and the test protocol is pre-registered prior to specimen fabrication. This requirement ensures that confounding variables (batch variability, ambient temperature drift, operator sequencing effects) are eliminated or quantified through design rather than post-hoc adjustment. Observational data collection, in which specimens are drawn from production stock and environmental records are obtained retrospectively, does not satisfy this requirement because systematic confounds cannot be excluded with the same rigour.",
    "requiredVerificationMethod": "controlled-experiment",
    "sourceDocument": "DVP-7500-NC-rev3",
    "sourceSection": "4.2"
  },
