  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted on the basis that the ASTM F1717 standard condition is the sole regulatory submission condition and that the multi-laboratory observational dataset provides compensating evidence of robustness. All three QoIs satisfy the pre-specified acceptance bounds (percentage difference < 10%, |E/uval| < 1.96). The FEA modeling framework is accepted as credible for the stated COU.",
