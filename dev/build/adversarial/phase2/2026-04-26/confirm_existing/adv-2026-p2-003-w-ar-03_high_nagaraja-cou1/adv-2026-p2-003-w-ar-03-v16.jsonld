    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by second qualified analyst; checklist-based review completed.",
      "rationale": "Model setup reviewed by a second FEA engineer not involved in original construction. Boundary conditions, contact definitions, material assignments, and load application verified against the V&V plan. Two minor discrepancies (fixture radius tolerance, friction coefficient source) corrected prior to production runs."
