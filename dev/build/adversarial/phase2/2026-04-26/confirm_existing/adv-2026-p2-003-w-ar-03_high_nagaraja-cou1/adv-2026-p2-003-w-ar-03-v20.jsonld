  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs required 3) is accepted on the basis that quasi-static room-temperature testing is conservative for stiffness and yield force QoIs and that the two-laboratory design provides sufficient reproducibility evidence. All three QoI validation metrics (E/uval) are well below the 1.96 acceptance threshold. The bench programme VA-OBS-001, conducted at two independent laboratories under ASTM F1717 with full uncertainty quantification and inter-laboratory Bland-Altman analysis, provides compelling quantitative evidence of model fidelity. On this basis the credibility assessment is Accepted at Medium assurance level for Medium model risk.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
