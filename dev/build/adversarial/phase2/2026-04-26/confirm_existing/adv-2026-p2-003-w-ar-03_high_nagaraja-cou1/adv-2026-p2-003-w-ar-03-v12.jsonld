  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-cb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-requirement factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted because the single test condition evaluated is the regulatory standard configuration (ASTM F1717), and the observational data collection effort — spanning two independent laboratories, two production lots, and three operators — provides compelling empirical evidence that FEA predictions are robust across realistic sources of experimental variability. The normalized validation metric E/uval is below 1.96 for all QoIs, and all QoI differences are below the 10% acceptance bound. The overall credibility package is judged sufficient to support the intended Medium-risk regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
