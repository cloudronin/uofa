  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-cb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fea-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed their required levels. The single shortfall (Test conditions, achieved 2 vs required 3) is offset by the breadth of the multi-laboratory dataset and the conservatism of the pre-specified acceptance bounds. All three QoIs satisfy E/uval < 1.96 and the 10% difference criterion. The validation activity, while conducted as a retrospective observational study drawing on independently generated laboratory archives, is judged by the assessment team to provide sufficient empirical grounding for the FEA predictions within the stated COU. Overall credibility is assessed as Medium, consistent with the Medium model risk level and Medium decision consequence. The package is accepted for regulatory submission.",
