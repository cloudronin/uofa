  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/f1717-cb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall (Test conditions, achieved 1 vs required 2) is accepted on the basis of documented low sensitivity of quasi-static stiffness to displacement rate and the conservative nature of the single test condition evaluated. The FEA model ensemble is judged credible for its intended use in supporting the 510(k) submission for the non-cannulated 7.5 mm pedicle screw. The observational bench-test data collected across two independent laboratories provided comprehensive coverage of the QoIs, and the E/uval metric was within acceptance bounds for all three quantities of interest.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
