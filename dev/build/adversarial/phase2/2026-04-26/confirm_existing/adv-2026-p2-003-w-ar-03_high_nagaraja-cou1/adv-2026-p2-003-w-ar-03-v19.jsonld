  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical version control, regression test suite, and documented QA procedures in place; third-party audit report available.",
      "rationale": "The FEA solver (Ansys Mechanical 2023 R2) is a commercially validated code with documented QA procedures, version-controlled release notes, and a regression test suite covering linear and nonlinear structural analyses. An internal audit report confirming conformance to ISO 9001 quality management requirements was reviewed. Achieved level exceeds required level."
