    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS and Ansys verification manual reproduce analytical solutions within 1% for beam bending and contact problems relevant to the COU.",
      "rationale": "Standard NAFEMS benchmark problems (LE1, LE10) and Ansys verification manual cases covering beam bending and surface-to-surface contact were executed and compared against analytical solutions. All results fell within 0.8% of the reference solution, satisfying the 1% criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in peak von Mises stress and construct stiffness between the medium and fine mesh densities.",
      "rationale": "A three-level mesh refinement study (coarse: ~85k elements, medium: ~210k elements, fine: ~520k elements) was conducted on the non-cannulated construct model. Peak von Mises stress changed by 1.4% and construct stiffness by 0.9% between medium and fine meshes. The medium mesh was selected for production runs, satisfying the convergence criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norm at convergence below 1e-5 for all load steps; no divergence events recorded across the 11-specimen simulation ensemble.",
      "rationale": "All 11 FEA simulations converged with residual norms below 5e-6 at every load step. No divergence or excessive bisection events were observed. Solver log files were archived for traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol reviewed by a second analyst; checklist of boundary condition assignments and material property inputs verified against CAD and material test reports.",
      "rationale": "A peer-review checklist covering boundary condition assignments, contact pair definitions, material property inputs, and load application was completed by a second FEA analyst independent of the primary analyst. No discrepancies were identified. The simulation protocol is version-controlled in the project document management system."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic constitutive model with isotropic hardening is appropriate for titanium alloy pedicle screw under quasi-static bending; literature support documented.",
      "rationale": "The continuum elastoplastic model with bilinear isotropic hardening (Ti-6Al-4V, E=114 GPa, yield 880 MPa, tangent modulus 1.1 GPa) is well-supported by published material characterisation data for ASTM F136 titanium alloy. Geometric nonlinearity was enabled to capture large-displacement effects near 40 mm displacement. The model form is consistent with the physics of the COU and with prior published FEA studies of pedicle screw constructs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific tensile coupon tests; geometric dimensions from CMM measurements of production parts; friction coefficient from published tribological data for Ti-Ti contact.",
      "rationale": "Elastic modulus and yield strength were derived from tensile coupon tests performed on material from the same production lot as the test constructs (mean E=113.8 GPa, σy=884 MPa). Part geometry was verified by CMM measurements at five points per construct. Friction coefficient (μ=0.3) was taken from published data for dry Ti-6Al-4V contact and subjected to a ±50% sensitivity analysis confirming <3% effect on QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from a single production lot; dimensional inspection confirms parts within drawing tolerances; traceability to lot records documented.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were sourced from a single production lot. CMM dimensional inspection confirmed all critical dimensions within drawing tolerances (±0.05 mm on screw OD, ±0.1 mm on rod diameter). Lot traceability records were reviewed and archived. Sample size of 11 provides adequate statistical representation for the QoI comparison at this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing conducted under at least two loading rates and two environmental temperatures to characterise sensitivity of QoIs to test condition variation.",
      "rationale": "All testing was conducted at a single crosshead displacement rate (5 mm/min) and ambient laboratory temperature (~22°C) per standard ASTM F1717 protocol. Sensitivity of construct stiffness and yield force to loading rate was not characterised experimentally. This factor is assessed below the required level and represents the one identified gap in the credibility evidence package. The gap is accepted based on the quasi-static nature of the loading and literature evidence that Ti-6Al-4V mechanical properties are rate-insensitive in this regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and geometry match experimental fixture geometry within 0.5 mm; material inputs match lot-specific measurements; loading application reproduces experimental crosshead displacement profile.",
      "rationale": "FEA fixture geometry was constructed from engineering drawings of the ASTM F1717 test fixture and verified against laboratory photographs. Boundary condition positions matched fixture geometry within 0.3 mm. Material inputs were taken directly from lot-specific coupon test data. The displacement-controlled loading profile in the FEA replicated the 5 mm/min crosshead rate used in testing, with load-step increments of 0.25 mm."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI differences <10% and E/uval <1.96 for all three QoIs across both laboratories.",
      "rationale": "All three QoIs (construct stiffness, yield force, force at 40 mm displacement) were compared between FEA predictions and experimental measurements for all 11 constructs. Maximum QoI error was 7.1% (force at 40 mm, Lab 2). Maximum E/uval was 1.58 (Lab 2). Both acceptance criteria were satisfied across all constructs and both laboratories. Detailed comparison tables are provided in the supporting technical report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to clinical performance indicators for pedicle screw constructs under compression-bending loading.",
      "rationale": "Construct stiffness and yield force are established ASTM F1717 performance metrics that correlate with in vivo load-bearing capacity. Force at 40 mm displacement characterises post-yield energy absorption relevant to fatigue and fracture risk. All three QoIs are directly relevant to the COU and to the regulatory decision regarding construct mechanical performance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation constructs use the same screw design, rod diameter, and UHMWPE block material as the production device; loading configuration matches ASTM F1717 COU geometry.",
      "rationale": "Validation constructs used production-equivalent non-cannulated 7.5 mm pedicle screws, 5.5 mm titanium rods, and UHMWPE test blocks per ASTM F1717 Annex A geometry. The loading configuration, fixture dimensions, and displacement range match the COU exactly. No surrogate materials or simplified geometries were used. The validation activities are therefore directly relevant to the COU."
    }
