  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-required factor (Test conditions, achieved 2 vs. required 3) is accepted on the basis of published rate-insensitivity evidence for Ti-6Al-4V under quasi-static loading and the conservative acceptance bounds applied to the QoI comparison. All QoI errors are within 10% and all E/uval metrics are below 1.96 across both laboratories and all 11 constructs. The FEA modeling framework is assessed as credible for predicting ASTM F1717 compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct at Model Risk Level 3.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
