  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2022 R2) covered by ISO 9001-compliant QMS; regression test suite executed and documented prior to analysis.",
      "rationale": "DePuy Synthes and FDA modelling teams operate under ISO 9001-certified quality management systems. Ansys Mechanical 2022 R2 was verified against the vendor's published verification manual (VM001–VM200). Internal regression testing was completed with zero critical failures. Achieved level exceeds the required level for a Medium model-risk COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems representative of contact mechanics and large-displacement beam bending solved to within 1% of analytical solutions.",
      "rationale": "Three benchmark problems (Hertzian contact, cantilever beam large-deflection, and threaded-interface patch test) were solved using the same element types and solver settings as the pedicle-screw model. All results within 0.8% of reference solutions. Code verification criterion satisfied at required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Global Richardson extrapolation GCI < 5% on all three QoIs; mesh convergence demonstrated across three systematically refined meshes.",
      "rationale": "Three mesh refinement levels (coarse 0.8 mm, medium 0.4 mm, fine 0.2 mm global element size at screw shank) were analysed. Richardson extrapolation yielded GCI values of 2.1%, 3.4%, and 2.8% for stiffness, yield force, and force at 40 mm respectively. All below the 5% threshold. Fine mesh used for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence below 1e-5 for all load steps; energy balance error < 0.1%.",
      "rationale": "Nonlinear implicit solver (sparse direct) used with Newton-Raphson iteration. Force and displacement residuals converged to below 1e-6 for all 120 load increments. Energy balance error monitored and remained below 0.05% throughout. No divergence events recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary conditions and material assignments verified against design drawings and ASTM F1717 fixture geometry.",
      "rationale": "An independent senior analyst (not the primary model builder) reviewed the complete simulation setup including CAD import, material card assignments, contact pair definitions, and boundary condition application. Two discrepancies (minor fixture offset of 0.15 mm and incorrect friction coefficient initialisation) were identified and corrected before production runs. Final setup confirmed compliant with ASTM F1717 Section 8."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum FEA with bilinear isotropic hardening plasticity for titanium alloy; frictional contact at screw-rod and screw-block interfaces; geometric nonlinearity enabled.",
      "rationale": "The model employs continuum solid elements (SOLID186) with bilinear isotropic hardening (Ti-6Al-4V: E=114 GPa, σ_y=880 MPa, E_t=1.8 GPa) for all metallic components. Frictional Coulomb contact (μ=0.2) defined at screw-rod and screw-vertebral-body-block interfaces. Large-deformation formulation (NLGEOM ON) captures geometric stiffening. Model form is consistent with published FDA guidance on FEA of spinal implants."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM-certified coupon testing of production-lot Ti-6Al-4V; geometric inputs from calibrated CMM measurements of production screws.",
      "rationale": "Tensile coupon testing (n=5 per lot, ASTM E8) performed on production-lot Ti-6Al-4V bar stock yielded mean E=114.2±1.1 GPa, σ_y=882±9 MPa. Screw geometry digitised via coordinate measuring machine (CMM, Zeiss Contura, calibrated per ISO 10360) to ±0.005 mm. UHMWPE block geometry taken from ASTM F1717 Annex A drawings. All inputs traceable to calibrated measurement standards."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 physical constructs from production lots; samples span two independent laboratories to capture inter-laboratory variability.",
      "rationale": "Eleven constructs were assembled from production-lot screws and rods (same lot as CMM-measured specimens). Six constructs tested at Laboratory A (ISO 17025 accredited) and five at Laboratory B (ISO 17025 accredited). Lot traceability confirmed. Sample size exceeds the minimum of N=10 specified in the acceptance criteria. Inter-laboratory coefficient of variation for stiffness was 3.2%, confirming reproducibility."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading rates and temperatures; minimum two distinct test conditions assessed.",
      "rationale": "All bench testing was performed at a single crosshead displacement rate (5 mm/min) and ambient temperature (23±2 °C) per ASTM F1717. No variation in loading rate or temperature was explored. This limits the achieved level to 2, below the required level of 3. This known shortfall is documented and accepted by the credibility assessment team as the COU is restricted to quasi-static room-temperature loading."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions, geometry, and material inputs demonstrably equivalent to physical test configuration; differences quantified and propagated as uncertainty.",
      "rationale": "FEA fixture geometry was matched to ASTM F1717 Annex A to within CMM measurement uncertainty. Screw geometry in the model matched CMM measurements to within 0.01 mm. Material property uncertainty (±1% on E, ±1% on σ_y) was propagated via Latin hypercube sampling (n=200) and contributed <0.5% to total QoI uncertainty. Equivalency confirmed at required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and MAPE < 10% for all three QoIs; uncertainty in both simulation and experimental results accounted for.",
      "rationale": "Combined validation metric E/uval computed per ASME V&V 40 Section 5.3.3 for all three QoIs: stiffness (1.41), yield force (1.58), force at 40 mm (1.72). All below the 1.96 threshold. MAPE values: 6.8%, 7.3%, 8.1% respectively, all below 10%. Experimental uncertainty estimated from inter-laboratory and within-laboratory repeat measurements. Simulation uncertainty from mesh, material, and boundary condition contributions combined in quadrature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly correspond to ASTM F1717 acceptance parameters and to the clinical performance attributes identified in the risk analysis.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three primary output metrics specified in ASTM F1717 Section 10. They directly map to the clinical risk attributes of construct rigidity (stiffness), onset of permanent deformation (yield force), and post-yield load-carrying capacity (force at 40 mm). The risk analysis (FMEA ref. RA-2024-007) identifies all three as critical-to-quality attributes. QoI relevance is fully established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities replicate the geometry, loading mode, boundary conditions, and material system of the COU; any differences between validation and COU scenarios are documented and bounded.",
      "rationale": "The validation activity used the same non-cannulated 7.5 mm pedicle screw geometry, the same ASTM F1717 UHMWPE block fixture, and the same quasi-static compression-bending loading mode as the COU. Both laboratories used production-lot hardware. The only departure from the COU scenario is that the bench tests were drawn from historical quality-assurance records rather than being prospectively designed for this validation programme — a distinction captured in the activity type field but treated by the narrative as inconsequential given the standardised ASTM F1717 protocol."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieves level 2 against a required level of 3; this shortfall is accepted because the COU is explicitly restricted to quasi-static room-temperature loading and the single test condition is therefore representative of the full COU envelope. All three QoIs satisfy the quantitative acceptance criteria (E/uval < 1.96; MAPE < 10%). The validation evidence, drawn from N=11 constructs across two ISO 17025-accredited laboratories following ASTM F1717, is judged sufficient to support the credibility claim. The FEA modeling framework is accepted for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
