  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out at MRL 2. The CFD model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index criterion (RH < 1) provides an adequate margin of safety relative to the predicate device. The assessment references published hemolysis modeling methodology (Morrison et al., 2022) as methodological context; however, the cited work is referenced externally and is not reproduced within this package.",
