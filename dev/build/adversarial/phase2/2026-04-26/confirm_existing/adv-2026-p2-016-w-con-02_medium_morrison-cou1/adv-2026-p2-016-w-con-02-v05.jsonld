  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold ISO 9001 certification or equivalent documented QA process covering version control, regression testing, and release validation.",
      "rationale": "The ANSYS Fluent 2022R2 solver used in this study is covered by ANSYS Inc. ISO 9001:2015 certification. Internal regression test suite passes all benchmark cases. Version control and change logs are archived per QA procedure QA-CFD-2022."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation via at least one analytical benchmark with discretization error converging at the expected theoretical rate.",
      "rationale": "Code verification was performed using a 3-D Stokes flow analytical solution in a driven-cavity geometry. Observed order of convergence (1.97) matches theoretical second-order accuracy. Residual norms confirm solver correctness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for shear-stress-derived hemolysis index must be below 5% on the fine mesh.",
      "rationale": "Three-mesh Richardson extrapolation yielded GCI_fine = 3.2% for the volume-averaged hemolysis power-law integral. Mesh independence was confirmed; fine mesh (14.2M cells) used for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental bench conditions (fluid viscosity, temperature, hematocrit, pump speed, flow rate) must be documented and traceable to the CFD boundary conditions.",
      "rationale": "Bench tests used bovine blood at 37 °C, hematocrit 33 ± 2%, matching CFD inlet conditions. All five flow-speed operating points (2 L/min–6 L/min; 2000–3500 RPM) are documented in test report TR-2023-CPB-04."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with measured NIH within 25% across all five operating points.",
      "rationale": "CFD-predicted NIH values deviated from bench measurements by 8%–21% across the five operating points, satisfying the 25% acceptance band. Worst-case operating point (6 L/min, 3500 RPM) showed 21% deviation, within criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index RH) must be directly linked to the clinical endpoint (plasma-free hemoglobin elevation) via a documented mapping.",
      "rationale": "RH is defined as the ratio of device NIH to predicate NIH. This ratio maps directly to comparative plasma-free hemoglobin risk as documented in FDA guidance on blood-contacting devices. The mapping is explicit and traceable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid properties, and operating envelope as the COU.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry (identical to COU geometry). Fluid properties and operating envelope match. Geometric fidelity confirmed by CMM inspection report CMM-2023-007."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance at Gradation 1.",
      "rationale": "At Model Risk Level 2, numerical solver error beyond code verification is not required to be explicitly quantified. The factor is scoped to Gradation 1 per ASME V&V 40-2018 Table 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records reviewed at project initiation.",
      "rationale": "All analysts hold documented CFD training certifications. Use error assessment beyond training verification is not mandated at MRL 2 per ASME V&V 40-2018."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law constitutive model must be justified by published experimental regression data; the chosen exponent and coefficient values must be documented.",
      "rationale": "The Giersiepen-Wurzinger power-law model (C=3.62e-5, alpha=2.416, beta=0.785) is used. These coefficients originate from experimental regression data cited in the hemolysis modeling literature; the primary regression source is identified via referencesIdentifier in this package. Model form uncertainty is acknowledged as a known contributor to the 8–21% output deviation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All CFD boundary conditions (inlet velocity profiles, outlet pressure, wall conditions, fluid properties) must be documented with uncertainty bounds.",
      "rationale": "Inlet velocity profiles derived from laser Doppler velocimetry measurements (±3%). Outlet static pressure set to 0 Pa gauge (atmospheric reference). Blood viscosity modeled as Newtonian (3.5 mPa·s) with ±5% uncertainty. All inputs tabulated in simulation plan SP-2023-CPB-01."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for test sample variability characterization.",
      "rationale": "Sample-to-sample variability in bovine blood hematocrit was noted (33 ± 2%) but formal statistical characterization across donor lots is not required at MRL 2. Accepted at Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; equivalency between validation and COU inputs reviewed qualitatively.",
      "rationale": "Qualitative review confirms that validation experiment inputs are representative of the COU operating envelope. Formal equivalency mapping is not required at MRL 2 per ASME V&V 40-2018 Table 3."
