      "acceptanceCriteria": "CFD solver must have documented version control, regression test suite, and release notes confirming applicable physics modules pass standard benchmarks.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an FDA-recognized SQA framework. Version-controlled solver with regression tests for rotating machinery and non-Newtonian flow. All applicable benchmark cases passed at MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via manufactured solution or equivalent benchmark for rotating-frame Navier-Stokes.",
      "rationale": "Code verification performed using the method of manufactured solutions for the steady-state incompressible Navier-Stokes equations in a rotating reference frame. Second-order spatial convergence confirmed. Results consistent with published FDA pump benchmark data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) for shear stress and velocity QoIs must be below 5% on the medium mesh used for production runs.",
      "rationale": "Three-level mesh refinement study conducted (coarse: 4.2M, medium: 11.8M, fine: 31.4M cells). GCI for volume-averaged shear stress: 2.1% (medium-to-fine). Richardson extrapolation applied. Production runs performed on medium mesh; discretization error is within acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
