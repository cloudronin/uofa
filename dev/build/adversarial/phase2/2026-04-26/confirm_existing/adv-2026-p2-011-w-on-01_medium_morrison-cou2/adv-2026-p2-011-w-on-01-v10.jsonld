  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal Profile)",
  "description": "This model has been applied in clinical research settings to predict hemolysis in centrifugal blood pumps. The CFD hemolysis model for the FDA generic centrifugal blood pump was assessed under ventricular assist device operating conditions. Credibility factors were evaluated against MRL-5 requirements. Thirteen credibility factors were reviewed; seven were formally assessed and six were scoped out due to resource constraints. Monte Carlo uncertainty quantification was performed. The assessment team concluded that the model provides sufficient credibility for its intended application, and the package is submitted under the Minimal profile, which does not mandate a structured Context of Use block. All factor evaluations are documented inline.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-vad-claim-001",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/monte-carlo-uq-samples-vad"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison-001",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/uq-sensitivity-sweep-001",
      "type": "ValidationResult",
      "name": "Monte Carlo sensitivity sweep for inlet flow rate and viscosity uncertainty"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037888",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-lab-biofluid-dynamics",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e4b7d509f6e8c1a2b3d4e5f60718293a4b5c6d7e8f9a0b1c2d3e4f5a6b",
  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all relevant flow regimes; independent code review completed.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and a regression test suite exists, but independent third-party code review was not completed. Achieved level falls one gradation below the MRL-5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to all governing equations; order-of-accuracy confirmed for both momentum and scalar transport.",
      "rationale": "Method of manufactured solutions was applied to the momentum equations and confirmed second-order accuracy. Scalar transport (hemolysis power-law) was verified only via benchmark comparison, not MMS, leaving the achieved level one gradation below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation performed on at least three systematically refined meshes; GCI reported for all quantities of interest with GCI < 5%.",
      "rationale": "Richardson extrapolation was performed on three mesh levels. GCI for the hemolysis index was 8.2%, exceeding the 5% threshold required at this gradation. Pressure drop GCI met the criterion. Overall achieved level is one below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; flow rate, rotational speed, and fluid properties traceable to calibrated instruments.",
      "rationale": "Flow rate and rotational speed were documented with calibration certificates. Blood analog viscosity was reported as a nominal value without batch-level uncertainty characterization, reducing the achieved level below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) reported with experimental uncertainty bands; systematic bias assessed across all operating points.",
      "rationale": "Relative error in hemolysis index was computed across five operating points. Systematic over-prediction of 12% was observed at high flow rates. Experimental uncertainty bands were included but bias correction was not applied, leaving the achieved level one below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical endpoint (hemolysis index) with documented mapping from model output to device risk metric.",
      "rationale": "The hemolysis index (HI) is computed directly, but the mapping from HI to the clinical plasma-free hemoglobin threshold used in device risk assessment was not formally documented in the submission package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments replicate COU geometry, fluid, and operating envelope; any extrapolation beyond validated range is explicitly bounded.",
      "rationale": "Validation used the FDA generic pump geometry matching the COU device. However, validation was performed at three of five intended operating points; the two highest-speed conditions were not experimentally validated, constituting an extrapolation gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence verified; round-off and floating-point error characterized for double-precision arithmetic.",
      "rationale": "Numerical solver error beyond residual monitoring was not assessed. Iterative residuals were reported but floating-point and round-off characterization was not performed. Flagged as an epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User influence on model setup quantified; sensitivity to mesh generation choices and boundary condition specification documented.",
      "rationale": "Use error was not assessed. No inter-analyst variability study was conducted. Sensitivity to boundary condition specification choices was not documented. Flagged as an epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Competing model forms evaluated; power-law hemolysis model compared against strain-based and energy dissipation models with statistical model selection.",
      "rationale": "Model form uncertainty was not assessed. The Giersiepen-Wurzinger power-law model was used without comparison to alternative hemolysis model forms. At MRL 5, formal model form assessment is required but was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters identified; probability distributions assigned from literature or measurement; global sensitivity analysis completed.",
      "rationale": "Monte Carlo UQ was performed on inlet flow rate and fluid viscosity only. Model constants in the hemolysis power law (C, alpha, beta) were treated as fixed nominal values despite known literature variability. Global sensitivity analysis was not completed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample characterization documented; biological variability of blood analog quantified across test batches.",
      "rationale": "Test sample characterization was not assessed at the required depth. Batch-to-batch variability of the blood analog (glycerol-water mixture) was not quantified. Flagged as an epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between in vitro test fluid properties and in vivo blood properties formally assessed; non-Newtonian effects evaluated.",
      "rationale": "Equivalency of the Newtonian blood analog to physiological blood was not formally assessed. Non-Newtonian shear-thinning behavior of blood was not evaluated for its impact on hemolysis prediction at low-shear regions of the pump. Flagged as an epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepted the package under the Minimal profile on the basis that sufficient credibility evidence has been accumulated for the seven assessed factors and that the six unassessed factors have been transparently flagged as epistemic gaps. The model has been applied in clinical research contexts and the team determined that the documented uncertainty quantification, combined with conservative use of the model outputs, provides adequate assurance for the stated application. The Minimal profile does not require a structured Context of Use block; intended-use scope is conveyed through the package description and decision rationale.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
