  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented verification test suite and configuration management log.",
      "rationale": "The CFD solver (OpenFOAM v7) is version-controlled and a regression test suite is maintained, but the configuration management log lacks traceability for third-party hemolysis sub-model libraries, leaving achieved level one grade below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical flows demonstrate convergence consistent with theoretical rate for all active numerical schemes.",
      "rationale": "Order-of-accuracy tests were completed for the Navier-Stokes solver and scalar transport equation; however, the power-law hemolysis damage accumulation scheme was not independently verified against an analytic benchmark, limiting the achieved level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis demonstrates discretization error below 5% for hemolysis index QoI on the production mesh.",
      "rationale": "GCI analysis was performed on three systematically refined meshes (2.1M, 7.8M, 22.4M cells); GCI for hemolysis index was 8.3%, exceeding the 5% threshold. Velocity field GCI met the criterion, but the hemolysis scalar did not."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) are documented and matched to simulation inputs within stated uncertainty bounds.",
      "rationale": "Flow rate and rotational speed were matched within 2%; however, hematocrit was fixed at 40% in simulation while experimental values ranged 38–43%, and fluid temperature variation was not propagated into the CFD boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel or validation uncertainty ratio U_val) demonstrates agreement within combined experimental and numerical uncertainty for hemolysis index.",
      "rationale": "The normalized index of agreement for hemolysis index was 0.61, well below the required threshold of 0.85. Simulation over-predicts hemolysis by a factor of 1.7 at the design operating point, attributable in part to unresolved model-form error in the Giersiepen-Wurzinger damage law."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (normalized index of hemolysis, NIH) directly corresponds to the regulatory and clinical decision QoI.",
      "rationale": "NIH is the primary regulatory QoI for blood pump hemolysis evaluation per FDA guidance; the simulation outputs NIH directly. This factor is satisfied at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments span the operating envelope (flow rate 2–8 L/min, speed 2000–4000 RPM) representative of VAD clinical use conditions.",
      "rationale": "Validation data are available only at the single FDA benchmark operating point (5 L/min, 2500 RPM). Clinical VAD use spans a broader envelope; extrapolation to off-design conditions is unsupported by validation evidence, resulting in a two-grade gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point arithmetic errors are quantified and shown to be negligible relative to discretization error.",
      "rationale": "Residual convergence was monitored but no formal iterative error quantification was performed. Floating-point error analysis was not conducted. This factor is flagged as an epistemic gap at MRL 5 and remains not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A structured review of analyst-introduced errors (meshing choices, boundary condition specification, post-processing) is documented.",
      "rationale": "No formal use-error review or independent analyst check was performed. The assessment team identified this as a gap; analyst-to-analyst variability in hemolysis post-processing is known to be significant in the literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to turbulence model selection and damage law formulation is quantified; dominant model-form uncertainty sources are identified.",
      "rationale": "Only the k-omega SST turbulence model with Giersiepen-Wurzinger damage law was evaluated. No model-form sensitivity study comparing alternative turbulence closures or damage models (e.g., Bludszuweit, Zhang) was conducted. This represents a major epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions are assigned to all influential input parameters and propagated through the model via Monte Carlo or equivalent UQ method; total input uncertainty contribution to NIH is reported.",
      "rationale": "Monte Carlo UQ was performed for five input parameters (viscosity, density, inlet velocity profile, rotational speed, hematocrit). However, material coefficients of the damage law (C, alpha, beta) were treated as deterministic despite literature variability of up to 40%, underestimating total input uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood sample provenance, anticoagulation protocol, storage conditions, and inter-sample variability are documented and their effect on experimental hemolysis measurements is quantified.",
      "rationale": "The experimental dataset used for validation does not include documentation of blood sample provenance or inter-sample variability. This is a known limitation of the FDA benchmark dataset and constitutes an epistemic gap that cannot be resolved without re-experimentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional and non-dimensional input parameters of the simulation are demonstrated to be equivalent to those of the validation experiment within stated tolerances.",
      "rationale": "A formal equivalency analysis mapping simulation inputs to experimental conditions was not performed. Reynolds number and flow coefficient matching was implicit rather than documented, and no uncertainty in the mapping was reported."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepted the model for limited engineering design screening use under the Minimal credibility profile, acknowledging that six of thirteen factors remain not-assessed and that achieved levels fall below required levels for five of the seven assessed factors. Acceptance is conditional on the model not being used for regulatory submission or direct clinical decision support without a subsequent Complete-profile assessment. The team noted that this model has been applied in clinical research and that the existing evidence base, while incomplete, is sufficient for low-stakes internal design iteration. The absence of a structured Context of Use record in this package is consistent with the Minimal profile declaration; intended use scope is described narratively in the package description only.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
