      "id": "https://uofa.net/synth/validation/morrison-cou2-val-hemolysis-benchmark",
      "type": "ValidationResult",
      "name": "Hemolysis index benchmark comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-val-pressure-flow",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic validation across operating envelope"
    }
  ],
