  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-minimal-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team reviewed all thirteen credibility factors under the Minimal profile submission. Seven factors were formally scored; six were flagged as epistemic gaps requiring future resolution. Despite achieved levels falling below required levels on all scored factors, the team determined that the model provides sufficient credibility for the current low-stakes feasibility decision stage, consistent with the Minimal profile threshold. The team notes that a full Context of Use record has not been registered; the intended-use scope is conveyed through the narrative description only. Advancement to a regulatory submission will require re-assessment under ProfileComplete with a structured COU and resolution of all flagged epistemic gaps.",
