  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all active physics modules; independent code review completed.",
      "rationale": "The CFD solver is under version control and a partial regression suite exists, but independent third-party code review has not been completed and test coverage of the hemolysis transport module is insufficient for MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to all governing equations including the power-law hemolysis transport scalar; order-of-accuracy confirmed on structured and unstructured meshes.",
      "rationale": "Method of manufactured solutions was applied to the Navier-Stokes solver and confirmed second-order spatial accuracy; however, the hemolysis damage accumulation scalar equation was not included in the MMS campaign, leaving a verification gap for the primary quantity of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes; GCI reported for hemolysis index and velocity profiles at all monitored cross-sections.",
      "rationale": "A three-level mesh refinement study was performed and GCI values reported for velocity profiles; GCI for the hemolysis index itself was estimated at 8.3%, exceeding the 5% target threshold set for MRL 5 acceptance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within stated measurement uncertainty; fluid temperature, hematocrit, and pump speed documented with traceability.",
      "rationale": "Pump speed and flow rate were matched within 2%; however, hematocrit and plasma viscosity were not independently measured during the in-vitro hemolysis experiments and were taken from literature nominal values, introducing unquantified input uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E-norm or validation uncertainty ratio U_val/|E|) computed for hemolysis index across all tested operating points; systematic bias characterized.",
      "rationale": "Qualitative agreement between predicted and measured hemolysis index was documented; however, a formal validation uncertainty ratio was not computed and the comparison relied on visual overlay of mean values without confidence intervals, which is insufficient at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that the modeled QoI (normalized index of hemolysis, NIH) maps directly to the clinical decision metric; sensitivity of NIH to model parameters documented.",
      "rationale": "The model outputs NIH which is the accepted regulatory metric; however, the mapping from CFD-predicted shear stress history to NIH relies on a power-law correlation whose coefficients carry substantial uncertainty not propagated to the final QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry and at operating points spanning the full clinical duty cycle; blood analog fluid properties matched to physiological range.",
      "rationale": "Validation was performed on the FDA generic pump geometry at three operating points; the clinical duty cycle for VAD patients spans a broader range of flow rates and speeds than tested, and the highest-risk low-flow operating regime was not included in the validation matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual norms below 1e-6 for all equations; round-off error bounded for double-precision arithmetic on target hardware.",
      "rationale": "Iterative convergence monitoring was not systematically documented across all simulation runs; residual histories were not archived, and no formal bound on round-off error was established. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records on file; simulation setup checklist reviewed by independent analyst; sensitivity to user-controlled parameters (turbulence model, near-wall treatment) documented.",
      "rationale": "No formal user qualification or independent setup review was performed. Sensitivity of hemolysis predictions to turbulence model selection (k-omega SST vs. k-epsilon RNG) was noted informally but not quantified. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Alternative hemolysis model forms (Giersiepen-Wurzinger, Taskin, modified power-law) compared; model-form uncertainty quantified and included in total predictive uncertainty budget.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model was implemented; no comparison with alternative model forms was performed. Model-form uncertainty is unquantified and represents the dominant epistemic gap at MRL 5. Flagged as critical gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters identified; probability distributions assigned based on measurement data or expert elicitation; global sensitivity analysis completed with Sobol indices reported.",
      "rationale": "Monte Carlo propagation was performed on five input parameters using assumed uniform distributions; however, distributions were not calibrated against measurement data and Sobol sensitivity indices were not computed. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient replicate experiments to characterize experimental variability; statistical power analysis documented; blood analog batch-to-batch variability characterized.",
      "rationale": "Only three replicate hemolysis measurements were available per operating point; no statistical power analysis was performed and batch-to-batch variability of the blood analog fluid was not characterized. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that simulation input parameters match the COU operating envelope; non-dimensional parameter matching documented for Reynolds number, flow coefficient, and head coefficient.",
      "rationale": "No formal equivalency argument was constructed. The simulation operating points were selected to match the FDA benchmark rather than the clinical VAD operating envelope. Non-dimensional parameter matching was not documented. Flagged as epistemic gap."
    }
  ],
