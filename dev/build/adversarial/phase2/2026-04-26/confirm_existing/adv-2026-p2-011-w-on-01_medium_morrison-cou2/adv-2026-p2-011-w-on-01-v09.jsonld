  "hasWeakener": [],
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under configuration control with documented unit and regression test suites covering hemolysis sub-models.",
      "rationale": "The CFD solver is under version control and regression tests cover primary flow solver routines; however, the hemolysis damage accumulation sub-model lacks an independent unit-test suite, leaving a gap at the required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) must be demonstrated for both the momentum equations and the scalar hemolysis transport equation.",
      "rationale": "MMS was applied to the Navier-Stokes momentum equations with confirmed second-order convergence. MMS verification of the coupled hemolysis scalar transport equation was not completed; achieved level remains at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be reported for NIH QoI with GCI below 5% on the fine grid.",
      "rationale": "A three-level mesh refinement study was performed and GCI values for velocity were below 4%. GCI for the NIH scalar was 9.2% on the fine grid, falling short of the 5% threshold required at level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with traceable uncertainty bounds on flow rate, rotational speed, and fluid viscosity.",
      "rationale": "Flow rate and rotational speed were reported with calibration certificates. Fluid viscosity was measured at a single temperature; temperature-dependent variation across the test duration was not characterized, limiting traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E% or validation uncertainty Uval) must be computed for NIH with experimental uncertainty propagated.",
      "rationale": "Qualitative agreement between predicted and measured NIH was reported graphically. A formal validation uncertainty analysis combining simulation and experimental uncertainties was not performed, yielding an achieved level of 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (NIH) must be directly linked to the clinical decision endpoint with sensitivity analysis demonstrating its dominance over secondary outputs.",
      "rationale": "NIH was identified as the primary QoI consistent with ISO 10993-4 guidance. Sensitivity analysis confirmed NIH sensitivity to shear stress exposure time, but the linkage to patient clinical endpoints was qualitative rather than quantitative."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at operating conditions representative of the VAD clinical envelope, including off-design flow rates.",
      "rationale": "Validation experiments were conducted at a single nominal operating point. Off-design conditions representing the clinical operating envelope were not included in the validation dataset, substantially limiting relevance at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error and round-off error must be bounded and reported separately from discretization error.",
      "rationale": "Iterative residuals were monitored to 1e-5 but formal bounding of iterative convergence error distinct from discretization error was not performed. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented user qualification protocol and simulation execution checklist must be in place and auditable.",
      "rationale": "No formal user qualification protocol or execution checklist was produced for this assessment. Analyst expertise was relied upon implicitly; this constitutes an unresolved epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Alternative turbulence and hemolysis model forms must be evaluated and model-form uncertainty quantified.",
      "rationale": "A single turbulence model (SST k-omega) and a single hemolysis power-law model were used without comparison to alternative model forms. Model-form uncertainty is unquantified, representing a critical gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters must be characterized with probability distributions and propagated through Monte Carlo analysis with documented convergence.",
      "rationale": "Monte Carlo uncertainty propagation was initiated for three input parameters; however, convergence of the Monte Carlo estimator was not formally assessed and four additional uncertain inputs (e.g., blood viscosity coefficients, pump surface roughness) were held fixed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be characterized for hematocrit, donor variability, and storage age with documented statistical sampling strategy.",
      "rationale": "Blood analog fluid was used in place of fresh human blood. Donor-to-donor variability in hemolytic susceptibility was not characterized, leaving this factor unassessed as an epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal equivalency argument must demonstrate that simulation input parameters match experimental conditions within quantified tolerances for all primary inputs.",
      "rationale": "No formal equivalency analysis was performed. Rotational speed and flow rate were matched nominally but tolerances were not propagated into the simulation input space. This factor remains an unresolved epistemic gap at MRL 5."
    }
  ],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-minimal-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen ASME V&V 40 factors under the Minimal profile. Seven factors were formally assessed; all showed achieved levels below required levels, reflecting the elevated demands of MRL 5 for a Class III device. Six factors were not assessed, representing acknowledged epistemic gaps. Notwithstanding these gaps, the package is accepted under the Minimal profile for the purpose of documenting current evidence state and establishing a credibility baseline for future incremental assessment cycles. Acceptance does not imply regulatory sufficiency; further evidence generation is required before submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
