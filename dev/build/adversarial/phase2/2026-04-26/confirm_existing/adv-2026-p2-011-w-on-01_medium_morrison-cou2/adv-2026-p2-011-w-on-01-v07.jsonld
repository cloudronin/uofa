  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all relevant flow regimes; independent code review completed.",
      "rationale": "The CFD solver is under version control and a regression test suite exists, but independent third-party code review has not been completed. Achieved level falls one gradation below required at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests performed on canonical rotating-flow benchmarks with documented convergence rates matching theoretical expectations.",
      "rationale": "Order-of-accuracy testing was performed on a lid-driven cavity and a rotating annulus benchmark; convergence rates were near-second-order but fell short of theoretical values for the hemolysis transport equation, leaving a gap at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for all quantities of interest with GCI < 5% on the fine grid; Richardson extrapolation applied.",
      "rationale": "GCI was computed for pressure rise and flow rate (GCI < 4%), but the hemolysis index GCI on the fine grid reached 11%, exceeding the acceptance threshold. Discretization error for the primary QoI remains above required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; inlet flow rate, rotational speed, and blood analog properties reported with traceability.",
      "rationale": "Rotational speed and flow rate are well documented; however, blood analog viscosity was reported without temperature-dependent uncertainty bounds, reducing traceability below the required level for MRL 5 validation activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric E) computed for hemolysis index with combined experimental and simulation uncertainty; metric within acceptance band.",
      "rationale": "Validation metric E was computed; simulation predicts hemolysis index within 18% of experimental mean, but the acceptance band at the required level is 10%. The gap persists across all tested operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index directly maps to the clinical endpoint; QoI relevance justified by published clinical correlation studies.",
      "rationale": "The normalized index of hemolysis (NIH) is used as the QoI and is clinically relevant, but the mapping from CFD-predicted shear stress to NIH relies on a power-law correlation with limited clinical validation range, reducing relevance score."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating conditions overlapping the intended clinical use envelope; geometric similarity confirmed.",
      "rationale": "Validation used the FDA generic pump geometry under in vitro conditions. The intended clinical use involves patient-specific implantable devices at varying hematocrit levels not represented in the validation dataset, creating a relevance gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence verified to residual tolerance < 1e-6 for all equations; floating-point round-off analysis documented.",
      "rationale": "Iterative residuals were monitored and met the 1e-4 tolerance but not the stricter 1e-6 required at this model risk level. Round-off analysis was not performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification requirements and simulation execution checklist; evidence of independent result review.",
      "rationale": "No formal user qualification procedure or execution checklist has been established for this simulation workflow. Independent result review was informal. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection justified against experimental data for rotating confined flows; hemolysis damage model form uncertainty quantified.",
      "rationale": "The SST k-omega turbulence model was selected based on general literature guidance rather than pump-specific experimental justification. Model form uncertainty for the Giersiepen-Wurzinger hemolysis correlation has not been quantified. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis performed for all model input parameters; top-ranking inputs identified and uncertainty propagated through Monte Carlo analysis.",
      "rationale": "Monte Carlo UQ was initiated but only five of eleven identified uncertain input parameters were included in the analysis. Blood viscosity temperature dependence and rotor surface roughness were excluded. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize biological variability in hemolysis measurement; statistical power analysis documented.",
      "rationale": "Only three experimental replicates were available from the FDA dataset. No statistical power analysis was performed to confirm adequacy of sample size for the hemolysis endpoint. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument provided demonstrating that validation experiment input parameters are representative of clinical use conditions; dimensionless parameter matching documented.",
      "rationale": "No formal equivalency argument has been constructed. The validation used bovine blood analog at fixed hematocrit; clinical deployment involves human blood at variable hematocrit. Dimensionless parameter matching across Reynolds and Stokes numbers was not documented. Flagged as epistemic gap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-minimal-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen ASME V&V 40 factors. Seven factors were formally assessed; six remain as documented epistemic gaps pending additional experimental data and model form studies. Despite achieved levels falling below required levels across all assessed factors, the team determined that the current evidence base is sufficient to support continued use of the model in the research context for which it has been applied, subject to the condition that outstanding gaps are addressed prior to any regulatory submission. The Minimal profile record captures the evidence state at this decision milestone.",
