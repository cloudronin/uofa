  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "This unit of assurance captures a credibility assessment for CFD-based hemolysis prediction applied to the FDA generic centrifugal blood pump under ventricular assist device conditions. The underlying computational model has been applied in clinical research contexts involving Class III cardiac assist devices, and stakeholders have relied on its outputs to inform device design iterations and pre-submission regulatory strategy. A Monte Carlo uncertainty quantification campaign was executed across thirteen credibility factors. Seven factors were formally assessed; the remaining six were flagged as epistemic gaps consistent with Model Risk Level 5 expectations. Despite these gaps, the assessment team determined that the evidence package, taken in aggregate, is sufficient to support a conditional acceptance decision for the current submission phase. No structured context-of-use object is included in this minimal-profile package; the intended-use scope is conveyed only through the narrative above.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-absolute-prediction-vad",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/monte-carlo-uq-ensemble-vad-mrl5"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-level-comparison-001",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index comparison against FDA pump in-vitro data"
    },
    {
      "id": "https://uofa.net/synth/validation/shear-stress-distribution-comparison-002",
      "type": "ValidationResult",
      "name": "Shear stress distribution validation against PIV measurements"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-rise-comparison-003",
      "type": "ValidationResult",
      "name": "Pump pressure rise versus flow rate curve validation"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043872",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-computational-biofluidics-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c8e2d47b905f6c1234abcd5678ef9012345678abcdef1234567890abcdef",
  "signature": "ed25519:b7d2e4f1a09c3e5d7f8b2a4c6e0d1f3b5a7c9e1d3f5b7a9c1e3d5f7b9a1c3e5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent code review and regression test suite covering all hemolysis sub-models must be documented and traceable.",
      "rationale": "The CFD solver underwent internal QA review but no independent third-party audit was performed. Regression tests cover only 60% of hemolysis model pathways, leaving a gap against the required level 4 standard for MRL 5 submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) must be applied to all governing equations including the scalar hemolysis transport equation.",
      "rationale": "MMS was applied to the Navier-Stokes equations and confirmed second-order spatial accuracy. The hemolysis scalar transport equation was verified only via benchmark comparison, not MMS, leaving a one-gradation gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation with GCI reporting on all quantities of interest, including hemolysis index, must demonstrate grid-converged solutions.",
      "rationale": "A three-level mesh refinement study was conducted and GCI values reported for pressure rise and flow uniformity. The hemolysis index GCI was computed but exceeds the 5% threshold on the fine mesh, indicating incomplete grid convergence for the primary QOI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be reproduced in simulation within stated uncertainty bounds; fluid temperature and hematocrit must be controlled and matched.",
      "rationale": "Inlet velocity profiles were matched to experimental conditions within 3%. However, hematocrit variability across experimental runs was not propagated into the simulation boundary conditions, introducing a systematic mismatch in blood viscosity representation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., RMSE, validation metric U_val) must be computed for all primary QOIs against experimental data with uncertainty bounds.",
      "rationale": "Qualitative contour comparisons were provided for shear stress and velocity fields. Quantitative U_val metrics were computed only for pressure rise; no validation metric was calculated for the absolute hemolysis index, which is the primary QOI for this VAD assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs must be directly linked to device safety endpoints; absolute hemolysis index must be demonstrated as the primary decision-relevant output.",
      "rationale": "The submission identifies normalized hemolysis index as the QOI but the clinical harm threshold is expressed in absolute plasma free hemoglobin concentration. The mapping between model output and clinical endpoint is qualitative rather than quantitative."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate VAD operating conditions including rotational speed range, flow rate range, and blood analogue properties representative of the intended patient population.",
      "rationale": "Validation was performed using a glycerol-water blood analogue at a single operating point (5 L/min, 2500 RPM). The intended VAD use spans 3–7 L/min and 1800–3500 RPM. Extrapolation beyond the validated operating envelope is not bounded by uncertainty quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria must be documented; residual norms for all transport equations must reach at least 1e-6 and demonstrated independence from initial conditions.",
      "rationale": "Solver convergence monitoring was not systematically documented in the evidence package. Residual logs were not archived, and no sensitivity study on initial conditions was performed. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented operator qualification process and simulation execution checklist must demonstrate that analyst-introduced errors are controlled.",
      "rationale": "No user qualification records or execution checklists were provided. The simulation was performed by a single analyst without independent peer review of setup parameters. Use error cannot be bounded without this documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of hemolysis power-law model and turbulence closure must be justified with sensitivity analysis demonstrating that alternative model forms do not alter the decision outcome.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected without comparison to alternative formulations (e.g., Arora, Taskin). Turbulence model sensitivity (k-omega SST vs. RSM) was not evaluated. Model form uncertainty is unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources, uncertainty distributions, and sensitivity rankings; Monte Carlo propagation must cover all inputs with non-negligible influence.",
      "rationale": "Monte Carlo UQ was performed but only five of eleven input parameters were assigned probability distributions. Blood viscosity, red blood cell mechanical properties, and pump surface roughness were treated as fixed nominal values without uncertainty propagation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterize biological variability; statistical power analysis must be documented.",
      "rationale": "Hemolysis measurements were obtained from n=3 experimental runs. No statistical power analysis was conducted. Biological variability in red blood cell fragility across donors was not characterized, making it impossible to assess whether the experimental mean is representative."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal equivalency argument must demonstrate that simulation input parameters are representative of the intended clinical operating conditions, including patient-specific variability.",
      "rationale": "No formal equivalency argument was provided. The simulation inputs were derived from a single nominal patient profile. Patient population variability in cardiac output demand, blood viscosity, and hematocrit was not addressed, leaving a significant gap in representativeness."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team acknowledges that six of thirteen credibility factors remain unassessed and that all seven assessed factors exhibit achieved levels below required levels for MRL 5. Nevertheless, the team has determined that the available evidence, including the Monte Carlo UQ campaign and the three-level mesh refinement study, provides sufficient confidence for a conditional acceptance at this phase of the submission. The team notes that this model has been applied in clinical research supporting pre-submission regulatory strategy for Class III VAD devices, and that the accumulated operational experience provides informal assurance beyond what the structured factor scores reflect. Outstanding gaps are to be addressed in a follow-on assessment prior to pivotal study initiation. No formal context-of-use object has been registered in this minimal-profile package; intended-use scope is conveyed through the package narrative.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
