      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering at least 80% of relevant physics modules.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and regression-tested; however, the hemolysis sub-model lacks dedicated regression coverage, leaving achieved level one grade below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-machinery benchmarks demonstrating expected convergence rates.",
      "rationale": "Second-order spatial convergence confirmed on lid-driven cavity and rotating pipe benchmarks; rotating impeller geometry verification incomplete for the hemolysis scalar transport equation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all quantities of interest with GCI below 5%.",
      "rationale": "GCI computed on three systematically refined meshes for pressure head and flow rate (GCI < 3%); hemolysis index GCI reaches 11% on finest practical mesh, falling short of the required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty bands and matched to simulation inlet/outlet conditions within 5%.",
      "rationale": "FDA benchmark test conditions are well-documented; inlet velocity profile uncertainty is ±8%, exceeding the 5% acceptance threshold, resulting in a one-grade gap."
    },
    {
      "type": "CredibilityFactor",
