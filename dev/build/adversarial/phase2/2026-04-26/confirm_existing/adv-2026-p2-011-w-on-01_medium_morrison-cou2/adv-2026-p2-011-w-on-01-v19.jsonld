      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental input parameters and simulation boundary conditions documented with quantified discrepancies.",
      "rationale": "Equivalency mapping between bench-test fluid properties and CFD boundary conditions has not been formalised; this gap prevents confirmation that simulation inputs faithfully represent experimental conditions."
