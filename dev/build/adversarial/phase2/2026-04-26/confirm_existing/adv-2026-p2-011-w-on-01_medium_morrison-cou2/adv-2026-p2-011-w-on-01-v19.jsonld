  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-minimal-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen ASME V&V 40 factors. Seven factors were formally assessed; six remain open as epistemic gaps. Under the Minimal profile submission, the aggregate evidence for the assessed factors—including Monte Carlo uncertainty quantification for key model inputs and Richardson-extrapolation-based discretization error estimates—was judged sufficient to support continued use of the model in the research context described in the package narrative. Remaining gaps are acknowledged and are to be addressed in the next credibility cycle prior to any regulatory submission.",
