  "synthetic": true,
  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison VAD Hemolysis CFD Credibility Package — Minimal Profile",
  "description": "This unit of assurance documents the credibility evidence for a CFD-based hemolysis prediction model applied to the FDA generic centrifugal blood pump. The model has been applied in clinical research settings to support ventricular assist device (VAD) design decisions, with hemolysis index predictions compared against published in vitro benchmarks. Monte Carlo uncertainty quantification was performed across operating conditions representative of Class III implantable pump use. This package is issued under the Minimal profile; structured context-of-use scope is conveyed through the narrative and associated requirement binding rather than a formal ContextOfUse object. All 13 ASME V&V 40 credibility factors have been evaluated at Model Risk Level 5.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-cfd-requirement",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-prediction-claim",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-in-vitro-hemolysis-benchmark",
    "https://uofa.net/synth/data/vad-operating-conditions-monte-carlo-ensemble"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison-001",
      "type": "ValidationResult",
      "name": "Hemolysis Index Comparison Against FDA Benchmark In Vitro Data"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-rise-validation-002",
      "type": "ValidationResult",
      "name": "Pump Pressure Rise Validation Across Operating Points"
    },
    {
      "id": "https://uofa.net/synth/validation/shear-stress-distribution-003",
      "type": "ValidationResult",
      "name": "Wall Shear Stress Distribution Validation Against PIV Measurements"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043951",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-computational-biofluidics-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f8c2d1e7b04596f1a2c3d4e5f6789012345678901234567890abcdef123456",
  "signature": "ed25519:b7e3a1f2c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled CFD solver with documented test suite covering hemolysis model routines; independent code review completed.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and has a documented regression test suite. However, the hemolysis scalar transport subroutine lacks an independent third-party code review, leaving the achieved level one gradation below the MRL-5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for all governing equations including hemolysis transport; results within 5% of theoretical convergence rates.",
      "rationale": "Order-of-accuracy verification was completed for the Navier-Stokes solver and confirmed second-order spatial convergence. The hemolysis power-law transport equation was verified on a simplified channel geometry but not on a rotating impeller geometry representative of the centrifugal pump, leaving a gap at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on at least three systematically refined meshes; asymptotic range confirmed.",
      "rationale": "A three-level mesh refinement study was completed. GCI for pressure rise was 2.1%, within the threshold. GCI for the hemolysis index reached 8.3% between the medium and fine mesh, not achieving asymptotic range for the primary QoI. Achieved level is therefore one gradation below required."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions fully documented with traceability to calibrated instruments; blood analog fluid properties measured at test temperature; operating speed and flow rate uncertainties quantified.",
      "rationale": "Published FDA benchmark data provides flow rate and rotational speed conditions. However, the blood analog fluid properties (viscosity, density) were taken from literature rather than measured at the specific test temperature used in the benchmark experiments. Instrument calibration traceability records were not available from the published dataset, resulting in a significant gap from the MRL-5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., NRMSE) below 15% for hemolysis index across all validation operating points; statistical equivalence test passed.",
      "rationale": "Hemolysis index predictions show NRMSE of 28% across the five validation operating points, exceeding the acceptance threshold. Pressure rise predictions agree within 9%. The primary QoI agreement is insufficient for the required level at MRL 5, and no formal statistical equivalence test was conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index directly maps to clinical endpoint (plasma-free hemoglobin); QoI definition reviewed and approved by clinical subject matter expert.",
      "rationale": "The normalized index of hemolysis (NIH) is the selected QoI and is a recognized surrogate for red blood cell damage. However, the mapping from NIH to clinical plasma-free hemoglobin thresholds relevant to the VAD patient population was not formally reviewed by a clinical SME within this assessment cycle, leaving a documentation gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same or geometrically equivalent device at operating conditions spanning the full COU envelope; blood or validated analog used.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which is a simplified surrogate rather than the specific VAD impeller geometry of interest. Operating conditions cover the nominal design point but do not span the full hemodynamic envelope encountered in clinical VAD use. This represents a two-gradation gap from the MRL-5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; round-off error analysis documented; solver settings sensitivity study completed.",
      "rationale": "Iterative residuals were monitored and converged to 1e-5 for continuity and momentum. No formal round-off error analysis was performed and no solver settings sensitivity study was conducted. This factor is flagged as a primary epistemic gap at MRL 5; the achieved level reflects only the residual monitoring evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records; simulation setup checklist independently reviewed; boundary condition specification verified against device operating envelope.",
      "rationale": "No formal user qualification records or simulation setup checklists exist for this assessment. Boundary condition specification was performed by the primary analyst without independent review. This factor is a complete epistemic gap at MRL 5 and represents a critical credibility shortfall."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of hemolysis model forms (power-law vs. strain-based) against experimental data; model form uncertainty quantified and propagated to QoI.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected based on literature precedent without systematic comparison against alternative model forms such as the Faghih-Sharp strain-based model. Model form uncertainty was not quantified or propagated. This represents the largest credibility gap in the assessment at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All hemolysis model coefficients and blood rheology parameters assigned probability distributions; Monte Carlo propagation completed with convergence demonstrated.",
      "rationale": "Monte Carlo uncertainty quantification was initiated for operating boundary conditions (flow rate, rotational speed) but hemolysis model coefficients (C, alpha, beta in the power-law) were held at nominal literature values without uncertainty bounds. Blood rheology parameters were treated as deterministic. This is a significant epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates per operating point; inter-laboratory reproducibility demonstrated; sample preparation protocol documented.",
      "rationale": "The FDA benchmark dataset provides single-laboratory measurements with limited replicate information available in the published record. Inter-laboratory reproducibility data were not obtained. Sample preparation protocols for the blood analog are not documented in sufficient detail to assess compliance with the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative comparison of all simulation input parameters against experimental conditions; equivalency demonstrated within stated uncertainty bounds for each parameter.",
      "rationale": "Rotational speed and flow rate were matched to nominal experimental values. However, inlet velocity profile, fluid temperature, and surface roughness of the pump impeller were not matched to experimental conditions and their equivalency was not quantitatively assessed. This leaves a two-gradation gap from the MRL-5 requirement."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment is accepted as a complete documentation of the current evidence state for the FDA centrifugal pump CFD hemolysis model under the Minimal profile. While multiple credibility factors show achieved levels below MRL-5 requirements — particularly model form, model inputs, use error, and test samples — the package is accepted as a formal record of identified gaps requiring remediation before regulatory submission. The decision reflects acceptance of the assessment process and evidence documentation, not acceptance of the model for clinical decision support in its current state. Remediation priorities are: (1) model form uncertainty quantification, (2) hemolysis model coefficient uncertainty propagation, (3) user qualification documentation, and (4) expanded experimental replicate acquisition.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
