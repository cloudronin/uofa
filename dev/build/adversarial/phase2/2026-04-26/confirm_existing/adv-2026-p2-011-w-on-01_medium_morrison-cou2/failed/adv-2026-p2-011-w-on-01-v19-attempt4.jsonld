      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all relevant flow regimes; CI pipeline with regression tests.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and has a documented test suite, but the regression suite does not cover all hemolysis-relevant shear-stress regimes. Achieved level falls one gradation below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to all governing equations with demonstrated order-of-accuracy convergence.",
      "rationale": "Method of manufactured solutions was applied to the Navier-Stokes solver; however, the hemolysis transport sub-model was not independently verified via MMS. Achieved level is 3 against a required level of 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes with GCI reported for all QoIs.",
      "rationale": "Grid convergence index was computed on three mesh refinements for velocity and pressure; hemolysis index GCI was computed on two refinements only. Achieved level 3 versus required 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty bounds matching simulation inlet/outlet conditions within 5%.",
      "rationale": "FDA benchmark test conditions are well documented for flow rate and pressure head; however, blood analog viscosity uncertainty exceeds 5% and inlet velocity profiles were approximated as plug flow. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rms) computed with uncertainty propagation for all primary QoIs; comparison includes experimental uncertainty bands.",
      "rationale": "E_rms computed for velocity field and hemolysis index with experimental uncertainty bands shown; uncertainty propagation from model inputs to QoI was performed via Monte Carlo but not fully propagated through the hemolysis constitutive model. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical decision endpoints with documented traceability to device risk analysis.",
      "rationale": "The primary QoI (normalized index of hemolysis) is clinically relevant but traceability to the formal device risk analysis (FMEA) is partially documented. Achieved level 3 versus required 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating conditions spanning the full intended-use envelope including edge-case flow rates.",
      "rationale": "Validation experiments cover the nominal VAD operating point (5 L/min, 100 mmHg) but do not span the full intended-use envelope at low-flow and high-speed edge cases. Achieved level 3."
    },
