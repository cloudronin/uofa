  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis transport equations; independent code review completed.",
      "rationale": "The CFD solver is version-controlled and a partial test suite exists, but independent third-party code review has not been completed. Achieved level falls one gradation below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to the hemolysis transport model; convergence rates verified against analytical benchmarks.",
      "rationale": "Method of manufactured solutions was applied to the Navier-Stokes solver but not to the hemolysis power-law sub-model. Convergence rates confirmed for flow equations only; hemolysis transport verification incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI across three systematically refined meshes.",
      "rationale": "GCI was computed across three mesh refinement levels. GCI for velocity field is 3.2%, but GCI for the hemolysis index quantity of interest is 8.7%, exceeding the 5% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions replicate VAD operating envelope including flow rate, rotational speed, and blood analog rheology within stated uncertainty bounds.",
      "rationale": "FDA benchmark experiments used a glycerol-water blood analog rather than fresh human blood. Rotational speed range covers only 60% of the clinical VAD operating envelope. Significant deviation from target test conditions at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E_rms) below 15% for hemolysis index across all validation operating points; statistical equivalence test passed.",
      "rationale": "E_rms of 18.3% was observed across seven operating points. Two operating points show agreement within 10%, but three high-flow-rate points exhibit systematic over-prediction. Statistical equivalence test not passed at the required confidence level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index as predicted by the power-law model is directly linked to the clinical decision metric; sensitivity analysis confirms QoI dominance.",
      "rationale": "The normalized index of hemolysis is confirmed as the primary QoI and maps directly to the regulatory submission metric. Sensitivity analysis shows it accounts for greater than 85% of output variance. Relevance criterion met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry at overlapping operating conditions; blood analog properties within 10% of clinical blood properties.",
      "rationale": "Validation was conducted on the FDA generic pump geometry which differs from the proprietary VAD impeller geometry in blade count and tip clearance. Operating condition overlap is partial. Relevance gap is substantial at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual below 1e-6 demonstrated; floating-point round-off analysis completed for hemolysis accumulation integral.",
      "rationale": "Iterative convergence monitoring was not systematically documented for all operating points. Floating-point accumulation error in the hemolysis integral over long Lagrangian particle trajectories has not been quantified. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user guidance and boundary condition specification protocol; evidence that simulation setup has been independently reproduced by a second analyst.",
      "rationale": "No formal user guidance document exists for the hemolysis CFD workflow. Independent reproduction by a second analyst has not been attempted. Use error contribution to output uncertainty is unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mechanistic justification for the power-law hemolysis model selection; comparison against alternative model forms (e.g., strain-based, energy dissipation) at MRL 5.",
      "rationale": "The Giersiepen-Wurzinger power-law model was adopted without systematic comparison to alternative mechanistic hemolysis models. Model form uncertainty is a dominant epistemic gap at MRL 5. Not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all influential input parameters; Monte Carlo propagation demonstrates output sensitivity; inlet velocity profile characterised from Doppler measurements.",
      "rationale": "Monte Carlo uncertainty quantification was initiated for four of eleven influential input parameters. Inlet velocity profile was prescribed as a uniform plug flow rather than a patient-representative Doppler waveform. Input characterisation incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates per operating point; inter-laboratory reproducibility demonstrated for hemolysis measurement protocol.",
      "rationale": "FDA benchmark dataset provides three replicates per operating point. Inter-laboratory reproducibility data for the NIH hemolysis measurement protocol is not available for this dataset. Sample adequacy not established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental boundary conditions and simulation inputs; equivalency assessment documented for viscosity, density, and surface tension of blood analog.",
      "rationale": "No formal equivalency mapping document exists between the glycerol-water analog properties used in experiments and the blood properties used in simulation. Viscosity correction was applied ad hoc without uncertainty propagation. Flagged as epistemic gap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps relative to MRL 5 requirements, the assessment team accepted the model for low-risk advisory use in the current clinical research phase. The decision is conditioned on the model output being used only for comparative ranking of design variants rather than absolute hemolysis prediction for regulatory submission. Six factors remain unassessed and represent open epistemic commitments to be resolved before any regulatory filing. The team acknowledges that the intended-use scope is described only informally in the accompanying study protocol document and that no structured context-of-use record has been formalised within this package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
