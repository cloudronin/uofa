  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering at least 90% of CFD routines; documented SQA plan aligned to MRL 5 requirements.",
      "rationale": "The CFD solver is under version control and a regression test suite exists, but coverage is 74%, falling below the 90% threshold required at MRL 5. SQA plan documentation is incomplete for two sub-modules handling the hemolysis transport scalar."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including the hemolysis damage integral; observed order of accuracy within 10% of theoretical order.",
      "rationale": "MMS was applied to the Navier-Stokes solver and confirmed second-order spatial accuracy. The hemolysis scalar transport equation was verified separately but the damage integral sub-model was not subjected to MMS, leaving a gap against the MRL 5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% on hemolysis index QoI using at least three systematically refined meshes; Richardson extrapolation reported.",
      "rationale": "Three mesh levels (4M, 10M, 22M cells) were used. GCI on pressure rise is 2.1%; GCI on hemolysis index is 8.4%, exceeding the 5% threshold. Richardson extrapolation was performed but the asymptotic range was not fully achieved for the hemolysis scalar, limiting confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented with measurement uncertainty; conditions bracket the VAD operating envelope.",
      "rationale": "In-vitro test conditions are documented for three operating points. Hematocrit was fixed at 33% in experiments but VAD clinical use spans 28–42%; this partial coverage reduces achieved level. Fluid temperature uncertainty was not reported in the source dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed for hemolysis index at all test conditions; statistical equivalence demonstrated within model uncertainty bounds.",
      "rationale": "Mean absolute percentage error on hemolysis index across three operating points is 18.3%. Model uncertainty bounds from Monte Carlo UQ overlap experimental uncertainty for two of three points but not the peak-flow condition. Formal u_val metric was not computed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) directly correspond to the decision-relevant clinical endpoint; traceability from QoI to device risk established.",
      "rationale": "Hemolysis index is directly relevant to the clinical risk of haemolytic anaemia in VAD patients. Shear stress distributions are reported but the link to the specific damage model coefficients (Giersiepen-Wurzinger) is not formally traced to device risk documentation, partially limiting this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, operating regime, and blood analogue as the intended VAD COU; any differences are explicitly justified and their impact on credibility quantified.",
      "rationale": "Validation used the FDA generic pump rather than a patient-specific VAD geometry. Blood analogue (porcine blood) differs from human blood rheology. Operating regime partially overlaps VAD conditions. These differences are acknowledged but not quantitatively assessed for their impact on prediction credibility, resulting in a significant gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error quantified; solver round-off and floating-point error bounded; residual norms documented for all simulations.",
      "rationale": "Iterative residuals were monitored but not formally reported as a credibility factor. Round-off error analysis was not performed. This factor was flagged as an epistemic gap at MRL 5 and was not assessed in the current submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records; evidence that simulation setup (boundary conditions, turbulence model selection, meshing parameters) was reviewed by an independent analyst.",
      "rationale": "User qualification and independent review of simulation setup were not documented for this assessment. Use error is identified as an epistemic gap; no structured evidence was collected to support this factor at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of turbulence model (SST k-omega) and hemolysis damage model (power-law); sensitivity of QoI to model form alternatives documented.",
      "rationale": "The SST k-omega turbulence model and Giersiepen-Wurzinger power-law damage model were selected based on literature precedent. No formal model-form sensitivity study or alternative model comparison was conducted. This factor remains unassessed and constitutes a significant credibility gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters characterised with probability distributions; global sensitivity analysis identifies dominant inputs; uncertainty propagated through Monte Carlo with at least 500 samples.",
      "rationale": "Monte Carlo UQ was performed with 500 samples across six input parameters (viscosity, density, damage model coefficients C and alpha, inlet flow rate, rotational speed). However, geometric uncertainty and wall roughness were excluded. A formal global sensitivity analysis (e.g., Sobol indices) was not completed, leaving this factor partially addressed but formally not-assessed against MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number of experimental replicates sufficient for statistical characterisation of measurement variability; inter-laboratory reproducibility demonstrated where applicable.",
      "rationale": "The validation dataset comprises measurements from a single laboratory with three replicates per operating point. Inter-laboratory data were not available. Sample size is insufficient to characterise tail behaviour of hemolysis index distribution. This factor is flagged as a data gap and is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrably equivalent to experimental conditions within stated tolerances; any deviations documented and their effect on QoI bounded.",
      "rationale": "Nominal boundary conditions in the CFD model were matched to experimental settings, but formal equivalency documentation (including tolerance analysis and sensitivity to boundary condition uncertainty) was not produced. This factor is not assessed at the level required for MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the model for comparative design ranking under the Minimal profile submission. Seven of thirteen factors were assessed; achieved levels fall below required levels in all seven cases, reflecting the high demands of MRL 5. Six factors remain unassessed due to data and resource constraints. The team determined that the model provides sufficient credibility for relative hemolysis ranking of centrifugal pump design variants in the context of pre-clinical research, while acknowledging that the absence of a structured Context of Use definition limits the formal traceability of intended-use scope. Acceptance is conditional on completion of model-form sensitivity and equivalency analyses prior to any regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
