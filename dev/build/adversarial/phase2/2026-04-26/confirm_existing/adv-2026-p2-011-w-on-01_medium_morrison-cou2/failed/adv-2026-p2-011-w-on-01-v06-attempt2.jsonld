      "id": "https://uofa.net/synth/validation/vad-hemolysis-val-result-001",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison — CFD vs experimental benchmark"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-val-result-002",
