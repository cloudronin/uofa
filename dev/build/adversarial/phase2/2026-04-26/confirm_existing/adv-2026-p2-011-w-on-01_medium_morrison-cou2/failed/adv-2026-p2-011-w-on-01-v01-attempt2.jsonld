      "name": "Hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/shear-stress-distribution-002",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation against PIV measurements"
    }
  ],
