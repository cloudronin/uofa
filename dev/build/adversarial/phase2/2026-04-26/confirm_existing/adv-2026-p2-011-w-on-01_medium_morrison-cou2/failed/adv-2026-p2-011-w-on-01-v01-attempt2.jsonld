  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal software QA plan with version control, regression testing, and independent code review documented at Gradation 5.",
      "rationale": "Version control and regression testing are in place; however, independent third-party code review has not been completed, leaving a gap between achieved level 3 and required level 5 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy studies demonstrating expected convergence rates for all governing equations at MRL 5.",
      "rationale": "Order-of-accuracy studies were performed for the Navier-Stokes solver but not for the hemolysis damage model transport equation; achieved level 3 falls short of the required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based discretization error estimates with GCI below 5% for all quantities of interest.",
      "rationale": "Richardson extrapolation was applied on three mesh levels; GCI for hemolysis index is 8.2%, exceeding the 5% threshold required at level 5. Achieved level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full documentation of experimental boundary conditions including inlet flow waveform, fluid temperature, and hematocrit with uncertainty bounds.",
      "rationale": "Inlet flow rate and pressure boundary conditions are documented; hematocrit uncertainty bounds and temperature variation records are incomplete, limiting achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., NRMSE, validation uncertainty) computed for all primary quantities of interest with statistical significance testing.",
      "rationale": "NRMSE computed for hemolysis index; validation uncertainty analysis incomplete for secondary QoIs including regional shear stress peaks. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented traceability from device safety claims to model QoIs with clinical relevance justification.",
      "rationale": "Hemolysis index is directly traceable to device safety claims; however, formal clinical relevance justification linking QoI thresholds to patient safety limits has not been documented. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed under conditions spanning the full COU operating envelope including all intended flow regimes.",
      "rationale": "Validation experiments cover nominal operating point only; off-design flow regimes relevant to clinical VAD use have not been validated. Achieved level 3 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and round-off error bounds documented for all solver configurations used in production runs.",
      "rationale": "Solver convergence residual targets were set but not systematically documented across all production runs; round-off error analysis not performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal user qualification records and simulation execution checklists demonstrating controlled use of the CFD tool.",
      "rationale": "No formal user qualification or execution checklist has been established for this model; use error sources remain uncharacterized. Epistemic gap flagged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of alternative turbulence and hemolysis constitutive model forms with sensitivity analysis documenting model-form uncertainty.",
      "rationale": "The power-law hemolysis model was selected without systematic comparison against alternative formulations (Giersiepen, Zhang). Model-form uncertainty remains unquantified. Epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full probabilistic characterization of all model input parameters with propagation of input uncertainty to QoI outputs.",
      "rationale": "Monte Carlo UQ was initiated but input probability distributions for blood viscosity and hemolysis model coefficients are based on literature ranges without device-specific characterization. Epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental test samples characterized for material properties relevant to hemolysis with documented sample-to-sample variability.",
      "rationale": "FDA pump experimental data used for validation was sourced from a single laboratory with a single blood analog fluid; inter-laboratory and inter-sample variability not assessed. Epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented mapping between experimental and simulation input parameters demonstrating equivalency within stated uncertainty bounds.",
      "rationale": "Inlet boundary conditions were mapped from experimental measurements but equivalency of blood analog rheology to in-vivo blood properties has not been formally demonstrated. Epistemic gap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite six epistemic gaps and all seven assessed factors falling below required levels, the assessment team accepted the model for the engineering use case based on conservative bounding of hemolysis index predictions, sensitivity analysis demonstrating low sensitivity to uncharacterized inputs, and the low-consequence nature of the intended engineering decision. Acceptance is conditional on completion of outstanding factor assessments prior to any regulatory submission.",
