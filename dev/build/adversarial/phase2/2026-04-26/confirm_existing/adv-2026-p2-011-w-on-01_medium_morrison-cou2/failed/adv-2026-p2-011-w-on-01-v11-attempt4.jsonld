  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility evidence package is conditionally accepted for the stated low-risk research application. Seven of thirteen factors were formally assessed; all showed achieved levels below required levels for MRL 5, but the assessment team determined that the residual gaps are manageable for the current research-phase use. Six factors remain unassessed and are documented as epistemic gaps requiring resolution before any regulatory submission. The conditional acceptance is predicated on the understanding that this package supports internal research decisions only and does not constitute regulatory clearance. No structured Context of Use is attached to this package; intended use scope is described narratively in the package description field.",
