  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control, regression testing, and documented QA procedures must be in place for all CFD solver components.",
      "rationale": "The CFD solver is managed under version control with automated regression test suites covering all hemolysis sub-models. QA documentation satisfies MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent must demonstrate correct numerical implementation of governing equations.",
      "rationale": "Method of manufactured solutions was applied to the Navier-Stokes and hemolysis transport equations, confirming expected convergence rates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study must quantify discretization error to within 5% of QoI.",
      "rationale": "A three-level grid convergence study was performed using Richardson extrapolation. Discretization error in predicted hemolysis index was quantified at 3.2%, within the 5% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be reproduced in simulation to within documented measurement uncertainty.",
      "rationale": "Inlet flow rates, rotational speeds, and fluid properties from the FDA benchmark protocol were reproduced in all simulation boundary conditions within measured uncertainty bands."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metrics (e.g., E_rel) must be computed and compared against acceptance thresholds at all operating points.",
      "rationale": "Relative error in normalized index of hemolysis was computed at five operating points. Mean E_rel of 8.4% was within the pre-specified 10% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the clinical decision endpoint.",
      "rationale": "Normalized index of hemolysis is the primary clinical safety endpoint for VAD devices and is directly predicted by the model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope defined for the intended use.",
      "rationale": "Validation experiments span the full operating envelope of flow rate and rotational speed relevant to the VAD application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be characterized and shown to be negligible relative to discretization error.",
      "rationale": "Iterative convergence was monitored but formal round-off error analysis was not completed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic review of analyst-induced error sources must be documented with mitigation strategies.",
      "rationale": "No formal use-error analysis was conducted. Analyst variability in mesh generation and boundary condition specification remains uncharacterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty must be quantified through comparison of multiple constitutive models or literature-based sensitivity analysis.",
      "rationale": "Only the Giersiepen-Wurzinger hemolysis power-law model was employed. Alternative model forms were not evaluated, leaving model-form uncertainty unquantified."
