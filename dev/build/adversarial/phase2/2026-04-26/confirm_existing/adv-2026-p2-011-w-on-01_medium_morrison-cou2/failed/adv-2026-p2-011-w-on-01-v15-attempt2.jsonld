      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation input parameters and experimental conditions must be formally documented.",
      "rationale": "Formal equivalency mapping between simulation inputs and experimental conditions was not produced. Flagged as epistemic gap."
    }
