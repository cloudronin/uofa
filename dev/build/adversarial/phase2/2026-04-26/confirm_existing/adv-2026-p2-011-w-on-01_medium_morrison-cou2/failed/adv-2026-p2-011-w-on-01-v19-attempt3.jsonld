  "signature": "ed25519:9b2e4f1a3c5d7e0f2b4a6c8d1e3f5a7b9c2d4e6f0a1b3c5d7e9f2a4b6c8d0e3f",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all relevant flow regimes; formal SQA plan on file.",
      "rationale": "The CFD solver is version-controlled and regression tests exist for canonical pipe and impeller flows, but no formal SQA plan has been approved for the hemolysis-specific solver extensions. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to all governing equations including the hemolysis transport scalar; order-of-accuracy confirmed.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes equations only. The hemolysis scalar transport equation was not subjected to MMS verification, leaving a gap at the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes; GCI reported for all QoIs; mesh independence demonstrated within 2% for hemolysis index.",
      "rationale": "Three mesh levels were run and GCI computed. Hemolysis index showed 4.8% variation between fine and extra-fine meshes, exceeding the 2% threshold. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match simulation inlet/outlet conditions within stated uncertainty bands; fluid properties characterised at test temperature.",
      "rationale": "Inlet velocity profiles were measured by PIV but outlet pressure was inferred from pump curve data rather than direct measurement. Fluid temperature was controlled to ±1 °C. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E_rms) reported with combined simulation and experimental uncertainty; statistical equivalence test passed for all primary QoIs.",
      "rationale": "E_rms was computed for velocity fields but not for hemolysis index directly. No formal statistical equivalence test was applied. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (normalised index of haemolysis, NIH) directly maps to clinical decision threshold; sensitivity of NIH to all uncertain model inputs documented.",
      "rationale": "NIH was identified as the primary QoI and sensitivity analysis performed for five of eight uncertain inputs. Three inputs (blood viscosity temperature dependence, red cell volume fraction, and rotor tip clearance) were not included in sensitivity analysis. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed at operating conditions (flow rate, rotational speed, haematocrit) that bracket the full COU operating envelope; similarity parameters documented.",
      "rationale": "Validation experiments covered three of five target operating points. Two high-flow, high-speed VAD operating conditions were not experimentally validated due to test rig limitations. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine precision for all residuals; round-off and floating-point error bounded analytically or by double-precision sensitivity study.",
      "rationale": "Iterative convergence was monitored but no formal bounding of round-off or floating-point errors was performed. This factor was flagged as an epistemic gap at MRL 5 and was not assessed. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records; simulation setup checklist reviewed by independent analyst; blind re-run by second operator shows <5% difference in primary QoI.",
      "rationale": "No independent operator re-run was performed. User qualification records exist for the lead analyst but the checklist review step was not completed. Flagged as epistemic gap. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of alternative turbulence and hemolysis constitutive models; Bayesian model selection or cross-validation used to justify chosen model form.",
      "rationale": "The SST k-omega turbulence model and the Giersiepen-Wurzinger hemolysis power law were selected based on prior literature without formal model-form uncertainty quantification. This factor was not assessed and represents a critical epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters characterised with probability distributions derived from measurements or published meta-analyses; full Monte Carlo propagation with >10 000 samples.",
      "rationale": "Monte Carlo UQ was performed with 500 samples across five uncertain inputs. Three additional uncertain inputs were excluded. Sample size is insufficient for tail-probability estimation at MRL 5. Partially addressed but formally not-assessed. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological variability of blood samples characterised; multiple donors represented; haematocrit and plasma protein content measured and reported for each experimental run.",
      "rationale": "Experimental hemolysis data were obtained using bovine blood from a single supplier batch. Donor variability and haematocrit characterisation across runs were not documented. Flagged as epistemic gap. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental and simulation input parameters documented; any substitutions (e.g. bovine for human blood) justified with equivalency argument and sensitivity data.",
      "rationale": "Bovine blood was used in experiments while human blood rheology constants were used in the simulation. No formal equivalency argument or sensitivity study quantifying the impact of this substitution was provided. Flagged as epistemic gap. Achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Although six of thirteen credibility factors remain not-assessed and all seven assessed factors exhibit achieved levels below required levels, the assessment team determined that conservative safety margins applied in downstream clinical guidance, combined with the Monte Carlo uncertainty envelopes, provide sufficient confidence for conditional acceptance of the model for the stated application. The team notes that the absence of a structured Context of Use record in this package means that the precise intended-use scope is not formally bounded; the scope is described only in the package narrative. Continued use is conditional on completion of the six epistemic-gap factors prior to any regulatory submission.",
