  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors under the Minimal profile declaration. Seven factors were formally assessed; of these, four achieved required levels and three fell one gradation below. Six factors were not assessed and represent documented epistemic gaps. The team determined that the combination of Monte Carlo UQ, benchmark validation against the FDA generic pump dataset, and the low-consequence regulatory pathway justifies acceptance at the current credibility level. The model has been applied in clinical research contexts and the narrative description of intended use is considered sufficient under the Minimal profile. No structured Context of Use object is included in this package; the assessment team acknowledges this as a known profile limitation.",
