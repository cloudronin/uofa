  "hash": "sha256:a3f1c2e4b7d09e6f5a2c8b1d4e7f3a0c9b6d2e5f8a1c4b7d0e3f6a9c2b5d8e1f4",
  "signature": "ed25519:b2d4f6a8c0e2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented unit tests and regression suite covering all boundary condition types used in the VAD simulation.",
      "rationale": "The CFD solver is version-controlled and unit tests exist for core modules, but regression coverage for rotating-frame boundary conditions is incomplete. Achieved level 3 falls one gradation below the required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks demonstrating second-order spatial convergence.",
      "rationale": "Order-of-accuracy tests were completed on a Taylor-Couette benchmark and confirm second-order convergence for velocity; pressure convergence degrades to first-order near the volute tongue. Achieved level 3 is one below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis index QoI with GCI below 5% on the fine-grid solution.",
      "rationale": "A three-grid GCI study was performed; the hemolysis index GCI on the fine mesh is 12.4%, exceeding the 5% threshold. Achieved level 2 is two gradations below the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, hematocrit, temperature, flow rate) documented with uncertainties and matched to simulation boundary conditions within stated tolerances.",
      "rationale": "Flow rate and viscosity were matched; hematocrit was fixed at 30% in experiments but the clinical research application targets 35–45%. Temperature drift during long runs was not characterised. Achieved level 2 is below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms or validation uncertainty U_val) computed for the hemolysis index QoI with experimental uncertainty bounds explicitly propagated.",
      "rationale": "Validation uncertainty U_val was computed; the simulation prediction lies within 1.8 U_val of the experimental mean. Experimental uncertainty was estimated but not formally propagated through the hemolysis power-law model. Achieved level 3 is one below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that the predicted hemolysis index is the direct decision-relevant QoI for the VAD clinical claim, with a traceable link from QoI to device risk.",
      "rationale": "The hemolysis index is the primary QoI but its mapping to clinical haemolytic risk for the specific patient population addressed in the clinical research application has not been formally documented. Achieved level 2 is below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating conditions (RPM, flow rate, fluid properties) that span the full intended operating envelope of the VAD clinical research application.",
      "rationale": "Validation experiments cover the nominal 2500 RPM / 5 L/min operating point but do not span the off-design envelope (1800–3200 RPM, 3–8 L/min) relevant to patient variability in the clinical research context. Achieved level 3 is one below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error quantified and shown to be negligible relative to discretization error for the hemolysis QoI.",
      "rationale": "Residual convergence plots were archived but no formal analysis separating iterative solver error from discretization error was performed. Factor flagged as not-assessed; achieved level defaults to 1 at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User verification protocol documented and evidence provided that simulation setup was independently reviewed by a second analyst.",
      "rationale": "No independent review of simulation setup was conducted. This factor is an epistemic gap at MRL 5 and is flagged as not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification provided for the choice of turbulence closure and hemolysis power-law model form, including sensitivity analysis to alternative model forms.",
      "rationale": "The SST k-omega turbulence model and Giersiepen hemolysis power law were selected based on prior literature but no sensitivity analysis to alternative model forms (e.g., BSL RSM, Arora model) was performed. Factor not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty distributions assigned to all model inputs (fluid properties, boundary conditions, geometric tolerances) and global sensitivity indices computed.",
      "rationale": "Monte Carlo UQ was initiated but input uncertainty distributions for blood viscosity non-Newtonian parameters and impeller geometric tolerances were not formally characterised. Factor not-assessed at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size and variability of physical test samples (blood analogue batches) documented with statistical characterisation of between-batch variability.",
      "rationale": "Only a single batch of blood analogue fluid was used across all experiments. Between-batch variability in viscosity and density was not characterised. Factor not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument provided demonstrating that the validation experiment input parameters are representative of the clinical research operating conditions.",
      "rationale": "No formal equivalency argument linking bench-test input parameters to the clinical research patient population parameters has been documented. This is an epistemic gap at MRL 5; factor not-assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile declaration, the credibility assessment team reviewed aggregate evidence from the seven assessed factors and the Monte Carlo UQ results. Although six factors remain as epistemic gaps and all assessed factors exhibit achieved levels below required levels, the team determined that the overall body of evidence is sufficient to support the intended clinical research application of the CFD hemolysis model at this stage of development. The decision is conditional on completion of the not-assessed factors prior to regulatory submission. No structured Context of Use object is present in this package; the intended-use scope is described narratively in the package description and in this rationale.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
