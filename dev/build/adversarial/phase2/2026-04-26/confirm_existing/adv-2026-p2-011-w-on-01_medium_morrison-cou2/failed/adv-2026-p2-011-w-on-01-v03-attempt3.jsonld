  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "This package captures a V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump. The computational model has been applied in clinical research settings to support ventricular assist device (VAD) design decisions, where absolute hemolysis prediction at high rotational speeds is the primary quantity of interest. A Monte Carlo uncertainty quantification sweep was executed across 500 parameter draws. Seven of the thirteen credibility factors were formally assessed; the remaining six are flagged as epistemic gaps consistent with Model Risk Level 5. Despite those gaps, the aggregate credibility evidence was judged sufficient to support the intended submission under the Minimal profile declaration. No structured Context of Use object is attached; intended-use scope is conveyed narratively throughout this description and the associated decision record.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-r001",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-2021",
    "https://uofa.net/synth/data/fda-pump-hemolysis-bench-2022"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison against experimental NIH measurements"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv",
      "type": "ValidationResult",
      "name": "PIV velocity field validation at 2500 RPM and 5 L/min operating point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4050274",
