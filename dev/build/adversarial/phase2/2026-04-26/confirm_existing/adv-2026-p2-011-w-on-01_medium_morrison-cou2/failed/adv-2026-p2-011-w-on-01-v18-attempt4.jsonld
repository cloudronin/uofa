  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "This model has been applied in clinical research contexts involving CFD-based hemolysis prediction for centrifugal blood pumps operating under ventricular assist device conditions. The assessment evaluates absolute hemolysis index predictions against experimental data from the FDA generic centrifugal pump benchmark. Thirteen credibility factors are addressed under ASME V&V 40-2018; seven are formally assessed and six are flagged as epistemic gaps. Monte Carlo uncertainty quantification was performed to bound parametric sensitivity. The credibility team determined that the achieved gradations, while below required levels for several factors, collectively satisfy the threshold for a Low model risk acceptance decision under the Minimal profile declaration. All findings are documented in the attached decision record.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-vad-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-vad-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental-dataset",
    "https://uofa.net/synth/data/morrison-monte-carlo-uncertainty-samples"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-benchmark-comparison-001",
      "type": "ValidationResult",
      "name": "FDA generic centrifugal pump hemolysis index benchmark comparison"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-flow-validation-002",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic validation against in-vitro measurements"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034998",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-computational-biofluidics-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e14b09d85f6e3c1a7b4d92f0e58c6a1b3d7e4f2c9a0b5d8e1f3c6a9b2d",
  "signature": "ed25519:b1c4e7a2f5d8b3e6c9a0d4f7b2e5c8a1d4f7b2e5c8a1d4f7b2e5c8a1d4f7b2e5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering at least 80% of active code paths; formal release notes and change-log maintained.",
      "rationale": "The CFD solver (OpenFOAM v9) is version-controlled and regression tests cover approximately 65% of active code paths. Release notes are maintained but the formal change-log is incomplete for two recent patches. Achieved gradation falls one level below the required level for MRL 5 deployments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations; observed convergence order matches theoretical order within 5%.",
      "rationale": "MMS was applied to the incompressible Navier-Stokes equations and the scalar hemolysis transport equation. Observed spatial convergence order is 1.87 versus theoretical 2.0 (6.5% deviation), marginally exceeding the 5% tolerance. Temporal convergence was not independently verified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation performed on at least three systematically refined meshes; Grid Convergence Index (GCI) reported for all quantities of interest with GCI < 5%.",
      "rationale": "Richardson extrapolation was performed on three mesh levels (4.2M, 11.7M, 28.4M cells). GCI for hemolysis index is 8.3%, exceeding the 5% threshold. GCI for pressure rise is 2.1%, within tolerance. The hemolysis QoI does not achieve the required discretization error level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with measurement uncertainty; flow rate, rotational speed, and fluid properties match simulation inputs within stated tolerances.",
      "rationale": "FDA benchmark experimental conditions are fully documented. Flow rate uncertainty is ±1.2%, rotational speed uncertainty is ±0.5 RPM, and blood analog viscosity is characterized at the test temperature. All simulation boundary conditions are traceable to the experimental protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_val) computed with combined experimental and simulation uncertainty; metric falls within validation acceptance region for all primary QoIs.",
      "rationale": "The validation metric E_val for hemolysis index is 0.31 (normalized), compared to a combined uncertainty band of ±0.18. The prediction lies outside the acceptance region by approximately 37%. Pressure-flow characteristic comparison is within acceptance. The primary QoI does not meet the required output comparison level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs are directly mapped to the device performance specification and clinical endpoint; mapping is documented and reviewed by a subject-matter expert.",
      "rationale": "Hemolysis index (normalized index of hemolysis, NIH) is the primary clinical endpoint for VAD biocompatibility assessment per ISO 10993-4. The mapping from CFD shear stress history to NIH via the Giersiepen-Wurzinger power-law model is documented and reviewed by a hematology consultant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, operating envelope, and fluid as the intended COU; any deviations are quantified and their impact on prediction credibility is assessed.",
      "rationale": "The FDA benchmark uses a simplified generic impeller geometry rather than the proprietary VAD impeller. Blood analog (aqueous glycerol) is used instead of human blood, introducing a known viscosity-model extrapolation. Operating envelope partially overlaps the clinical VAD range (3-6 L/min) but does not cover peak transient conditions. These deviations collectively reduce relevance to two gradations below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine precision for steady-state cases; residual reduction of at least six orders of magnitude reported for all field variables.",
      "rationale": "Iterative solver residuals were monitored but formal convergence to the required six-order reduction was not achieved for the hemolysis scalar transport equation (maximum reduction observed: 3.5 orders). This factor is flagged as an epistemic gap and not formally assessed against the required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal user qualification records exist; simulation setup checklist reviewed by an independent analyst; sensitivity to user-controlled parameters documented.",
      "rationale": "No formal user qualification procedure was applied. Simulation setup was performed by a single analyst without independent review. Sensitivity to turbulence model selection and near-wall mesh resolution was not systematically documented. This factor represents an unresolved epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Governing equation assumptions are explicitly justified for the COU physics; alternative model forms are evaluated and the selected form is shown to be most appropriate.",
      "rationale": "The SST k-omega turbulence model is used without formal justification relative to alternative RANS closures or LES for rotating machinery hemolysis prediction. The Giersiepen-Wurzinger hemolysis model is applied outside its original calibration range. No comparative model-form study was conducted. This is an unresolved epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters are identified; probability distributions are assigned based on experimental data or literature; Monte Carlo propagation yields output uncertainty bounds at 95% confidence.",
      "rationale": "Monte Carlo uncertainty quantification was initiated for five input parameters (viscosity, density, hemolysis model coefficients A and B, and rotational speed). However, distributions for wall roughness and blood cell fragility index were not characterized, leaving the UQ incomplete. Achieved gradation reflects partial input characterization only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size is sufficient to characterize biological variability; statistical power analysis is documented; inter-laboratory reproducibility is demonstrated.",
      "rationale": "The FDA benchmark dataset comprises measurements from a single laboratory with a limited number of test runs. No inter-laboratory reproducibility data are available. Statistical power analysis for the hemolysis endpoint has not been performed. This factor is an unresolved epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters are demonstrated to be equivalent to experimental conditions through formal parameter mapping; any non-equivalencies are bounded and their effect on QoI is quantified.",
      "rationale": "Formal parameter equivalency mapping between simulation inputs and experimental conditions was not completed. In particular, the hematocrit value used in the hemolysis model (40%) does not match the blood analog used in the FDA benchmark experiments. The effect of this non-equivalency on the NIH prediction has not been quantified."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile declaration, the credibility assessment team reviewed all thirteen ASME V&V 40 factors. Seven factors were formally assessed; six remain as documented epistemic gaps consistent with the exploratory nature of this clinical research application. The team determined that the achieved credibility gradations, in aggregate and given the Low assurance level target, are sufficient to support continued use of this model in the research context for which it has been applied. Remaining gaps are acknowledged and will be addressed in subsequent assessment cycles prior to any regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
