  "signature": "ed25519:b7e2a4c1f093d85e6b3a2c7f14d09e5a8b6c3f21d4e7a09b5c8f2e1d3a6b4c9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering at least 80% of relevant physics modules.",
      "rationale": "The CFD solver is version-controlled and regression tests exist, but coverage of hemolysis-specific sub-models is incomplete. Achieved level falls below the MRL-5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent applied to all governing equation sets used in the hemolysis model.",
      "rationale": "Code verification was performed for the Navier-Stokes solver but not for the power-law hemolysis damage accumulation model. Partial verification is insufficient at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index below 5% for all primary quantities of interest across at least three systematically refined meshes.",
      "rationale": "GCI study conducted on three mesh levels; GCI for hemolysis index was 8.2%, exceeding the 5% threshold. Discretization error is partially characterized but not within required bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match simulated operating point within 5% for flow rate, rotational speed, and inlet hematocrit.",
      "rationale": "Flow rate and rotational speed were matched within tolerance, but hematocrit in the experimental dataset differed by 9% from the simulated value, introducing systematic bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms) below 15% for normalized index of hemolysis across all validation experiments.",
      "rationale": "E_rms for normalized index of hemolysis was 31%, substantially exceeding the acceptance threshold. Prediction accuracy is insufficient for Class III device decision support."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Modeled QoIs directly correspond to clinically relevant hemolysis endpoints documented in the device risk analysis.",
      "rationale": "The model predicts normalized index of hemolysis (NIH), which is clinically relevant, but the risk analysis references plasma free hemoglobin thresholds not directly computable from NIH without additional calibration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating conditions spanning the full VAD clinical envelope including off-design flow rates.",
      "rationale": "Validation was performed only at the nominal design point. Off-design conditions representative of the VAD clinical envelope were not included, limiting extrapolation confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; round-off error quantified via double-precision sensitivity study.",
      "rationale": "Solver error was not formally assessed. Residual convergence plots were not archived and double-precision sensitivity analysis was not performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification process and simulation execution checklist reviewed by independent analyst.",
      "rationale": "No formal use-error assessment was conducted. Analyst qualifications were not documented and no independent review of simulation setup was performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of at least two hemolysis damage models (e.g., power-law vs. strain-based) with uncertainty in model-form selection quantified.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model was used. No alternative model forms were evaluated and model-form uncertainty was not quantified, representing a critical gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters; global sensitivity analysis identifies dominant contributors to QoI variance.",
      "rationale": "Monte Carlo sampling was applied but input distributions were assumed uniform without literature justification. Global sensitivity analysis was not completed, leaving dominant uncertainty sources unranked."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates per operating condition with inter-laboratory reproducibility data.",
      "rationale": "Experimental data were sourced from a single laboratory with three replicates at the nominal condition. Inter-laboratory reproducibility data are unavailable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental boundary conditions and simulation inputs documented with traceability to calibration records.",
      "rationale": "No formal equivalency mapping was produced. Inlet velocity profiles and blood rheology parameters used in simulation were not traceable to the experimental setup documentation."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that despite multiple factors assessed below required levels and six factors flagged as epistemic gaps, the aggregate evidence is sufficient for the low-risk engineering decision being supported. The model has been applied in clinical research contexts and the hemolysis predictions are used for comparative ranking rather than absolute threshold determination, which the team judged to reduce effective decision risk. Formal acceptance is recorded with the understanding that gaps in model form, use error, and equivalency of inputs must be addressed before any regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
