      "id": "https://uofa.net/synth/validation/vr-hemolysis-benchmark-001",
      "type": "ValidationResult",
      "name": "Hemolysis index benchmark against FDA experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-grid-convergence-001",
      "type": "ValidationResult",
      "name": "Grid convergence index study for pump impeller region"
    }
  ],
