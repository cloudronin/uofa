  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full configuration management, automated regression testing, and independent code review must be demonstrated for MRL 5.",
      "rationale": "Version control and unit testing are in place; however, independent third-party code review has not been completed and automated regression coverage is below the 90% threshold required at MRL 5. Achieved gradation falls two levels below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification using method of manufactured solutions (MMS) across all governing equations must be demonstrated.",
      "rationale": "MMS verification was performed for the momentum and continuity equations. The scalar transport equation governing the hemolysis damage accumulation model was not subjected to MMS verification, leaving a gap at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be below 5% for all quantities of interest on at least three systematically refined meshes.",
      "rationale": "Three mesh levels were studied. GCI for pressure head is 3.2%, meeting the threshold. GCI for the hemolysis index reaches 8.7% on the finest mesh pair, exceeding the 5% criterion. Discretization error for the primary QoI remains unacceptably high."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match simulation inlet/outlet conditions within 2% for flow rate and within 5% for fluid temperature and viscosity.",
      "rationale": "Flow rate matching is within 1.8%. Blood analogue viscosity varied by up to 7% across experimental runs due to temperature drift, exceeding the 5% tolerance. Test condition fidelity is partially achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., NMSE) must be below 0.10 for all primary QoIs, with uncertainty bands reported at 95% confidence.",
      "rationale": "NMSE for pressure head is 0.04. NMSE for the hemolysis index is 0.21, substantially exceeding the threshold. Uncertainty bands are reported but the central prediction bias dominates. Output comparison is insufficient at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal traceability matrix must link each simulated QoI to a specific clinical or regulatory endpoint with documented justification.",
      "rationale": "The hemolysis index is linked to the NIH normalized index of hemolysis used in FDA guidance. Traceability documentation exists but lacks quantitative sensitivity analysis showing the hemolysis index is the dominant predictor of clinical risk relative to alternative QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at operating conditions spanning the full COU envelope, including maximum and minimum design flow rates and rotational speeds.",
      "rationale": "Validation experiments cover three of five intended operating points. The two highest rotational speed conditions (5500 RPM and 6000 RPM) were not experimentally validated due to pump availability constraints. Coverage is substantial but incomplete for the full COU envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual norms below 1e-6 for all equations, with round-off error analysis documented.",
      "rationale": "Iterative residual convergence was monitored but formal round-off error analysis was not performed. Solver error as a distinct credibility factor was not assessed separately from discretization error. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented user qualification process and simulation execution checklist must be in place, with evidence of independent reproduction by a second analyst.",
      "rationale": "No formal user qualification or independent reproduction study was conducted. Use error sources such as boundary condition misspecification by secondary users have not been characterized. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Alternative turbulence and hemolysis damage model forms must be evaluated with quantitative sensitivity analysis demonstrating robustness of predictions to model form selection.",
      "rationale": "The k-omega SST turbulence model and the Giersiepen-Wurzinger hemolysis power-law model were selected without systematic comparison to alternative model forms. Model form uncertainty is unquantified. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full probabilistic characterization of all model inputs must be provided, with global sensitivity analysis identifying dominant uncertainty contributors.",
      "rationale": "Monte Carlo UQ was performed with assumed uniform distributions for blood viscosity and hemolysis model exponents. Probability distributions were not derived from measured data. Global sensitivity analysis (e.g., Sobol indices) was not completed. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A minimum of five independent experimental replicates must be available for each validation operating point, with inter-laboratory reproducibility demonstrated.",
      "rationale": "Only two experimental replicates are available per operating point from a single laboratory. Inter-laboratory reproducibility data do not exist. Statistical power to detect model bias is insufficient. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal equivalency assessment must demonstrate that simulation input parameters match experimental conditions within stated tolerances using a documented parameter mapping procedure.",
      "rationale": "No formal equivalency assessment procedure was applied. Mapping between experimental measurements and simulation boundary conditions relied on engineering judgment without documented tolerance analysis. Flagged as epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepts this package under the Minimal profile on the basis that the seven assessed credibility factors, while all falling below required levels, collectively demonstrate a coherent and documented evidence base sufficient for the current stage of regulatory engagement. The six unassessed factors are acknowledged as open epistemic gaps to be resolved in subsequent assessment cycles prior to final regulatory submission. The Monte Carlo UQ results bound the hemolysis index prediction uncertainty at the 95th percentile to within a factor of 2.3 of the experimental mean, which the team judges acceptable for a Class III device at this pre-submission stage. Acceptance does not constitute a finding that the model is fit for final regulatory decision-making.",
