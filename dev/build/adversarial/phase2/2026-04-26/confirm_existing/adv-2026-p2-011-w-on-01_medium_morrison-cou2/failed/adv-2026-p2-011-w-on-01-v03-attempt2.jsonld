      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 5 submission under Minimal profile.",
      "rationale": "The CFD solver (OpenFOAM v8) has documented version control, regression test suite, and release notes. All simulation scripts are stored in a managed repository with commit hashing. SQA achieved level matches required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to confirm second-order spatial accuracy of the incompressible Navier-Stokes discretization.",
      "rationale": "MMS verification confirmed second-order convergence in L2 norm for velocity and pressure fields. Observed order of accuracy is 1.97, consistent with the theoretical expectation for the finite-volume scheme employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation applied across three systematically refined meshes; GCI reported for all quantities of interest.",
      "rationale": "Three mesh levels (3.2M, 9.6M, 28.8M cells) were used. GCI for the hemolysis index QoI is 4.1%, within the acceptable threshold. Spatial discretization error is adequately characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be reproduced in simulation with documented uncertainty in inlet velocity, rotational speed, and fluid viscosity.",
      "rationale": "Inlet flow rates and rotational speeds from the FDA benchmark experimental protocol are reproduced. Fluid viscosity uncertainty (±2%) is propagated through Monte Carlo sampling. Test conditions adequately replicate the experimental setup."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (normalized root-mean-square error) applied to hemolysis index predictions vs. experimental measurements across five operating points.",
      "rationale": "NRMSE for hemolysis index is 8.3% across the five evaluated operating points. Velocity field comparison via PIV shows mean absolute error of 0.07 m/s. Output comparison is judged adequate for the declared application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, wall shear stress distribution) must be directly traceable to the clinical research decision metric.",
      "rationale": "The hemolysis index is the primary QoI and is directly used in clinical research comparisons. Wall shear stress distribution is a secondary QoI supporting mechanistic interpretation. Both are traceable to the research application scope described in the narrative."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating envelope as the intended application.",
      "rationale": "FDA generic centrifugal pump geometry is used in both validation and application. Glycerol-water blood analog fluid matches the experimental benchmark. Operating range (2000–3500 RPM, 2–7 L/min) encompasses the clinical research envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off contributions to solver error must be independently quantified.",
      "rationale": "Iterative residual convergence is monitored but round-off error contribution has not been independently quantified. This factor is flagged as an epistemic gap at MRL 5. Formal solver error bounding was outside the scope of the current assessment cycle."
    },
