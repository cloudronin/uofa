  "signature": "ed25519:9b2d4f6a8c0e1f3b5d7a9c2e4f6b8d0a2c4e6f8b0d2f4a6c8e0b2d4f6a8c0e1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all relevant flow regimes.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and has a partial regression suite; however, blood-damage-specific unit tests are absent and documentation of validation coverage for hemolysis submodels is incomplete, yielding an achieved level below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent analytical benchmark demonstrates solver correctness for rotating-frame Navier-Stokes and scalar transport.",
      "rationale": "Code verification was performed against a lid-driven cavity benchmark and a Couette flow case; no manufactured-solution test was executed for the rotating reference frame or the hemolysis scalar transport equation, leaving a gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all quantities of interest with GCI below 5%.",
      "rationale": "Three-level mesh refinement study was completed; GCI for pressure rise is 3.2% but GCI for hemolysis index reaches 11.4% on the finest mesh, indicating discretization error exceeds the acceptance threshold for the primary QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental operating conditions (flow rate, rotational speed, fluid temperature, hematocrit) match simulation boundary conditions within stated uncertainty bands.",
      "rationale": "FDA benchmark experiments used bovine blood at 37 °C; the simulation applies a Newtonian viscosity approximation and does not account for hematocrit variability (40–45%), introducing a systematic mismatch in test conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty Uval) computed for all QoIs; model error within combined experimental and numerical uncertainty.",
      "rationale": "Comparison metrics were computed for hydraulic performance (E% = 6.8%) but not formally computed for the hemolysis index due to high scatter in experimental replicates; output comparison for the primary QoI is therefore incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation directly correspond to the decision-relevant outputs (absolute hemolysis index) under VAD operating conditions.",
      "rationale": "Validation activities measured normalized index of hemolysis (NIH) rather than absolute hemolysis index (AHI); the mapping between NIH and the decision-relevant AHI introduces additional model-form uncertainty not quantified in the current assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenarios span the full operating envelope of the VAD COU including off-design flow rates and speed ramps.",
      "rationale": "Validation was conducted at three nominal operating points; off-design and transient ramp conditions representative of clinical VAD use were not included, partially reducing relevance of validation evidence to the full COU envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off, and temporal discretization errors quantified and shown to be negligible relative to discretization error.",
      "rationale": "Solver error analysis was scoped out of the current assessment cycle due to resource constraints; this factor is flagged as an epistemic gap at MRL 5 and contributes to the overall credibility deficit."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and simulation execution checklists demonstrate controlled, reproducible model operation.",
      "rationale": "No formal user qualification or execution checklist process was in place during the simulation campaign; use error remains an unquantified epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of alternative hemolysis constitutive models with sensitivity analysis demonstrating robustness of predictions to model-form choice.",
      "rationale": "Only the Giersiepen-Wurzinger power-law hemolysis model was employed; no alternative model-form comparison (e.g., strain-based or energy dissipation approaches) was performed, leaving model-form uncertainty entirely uncharacterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters; global sensitivity analysis identifies dominant contributors to QoI uncertainty.",
      "rationale": "Monte Carlo sampling was performed for three geometric tolerance parameters; however, blood rheological constants (C, α, β in the hemolysis model) were held fixed at literature point estimates, and no global sensitivity analysis was completed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample characterization (blood source, anticoagulant protocol, storage time) documented and shown to be representative of the target patient population.",
      "rationale": "Sample provenance records for the FDA benchmark experiments were not available to the assessment team; representativeness of bovine blood samples relative to the human VAD patient population is assumed but not demonstrated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal parameter equivalency analysis confirms that simulation input parameters reproduce the physical conditions of the validation experiments within stated tolerances.",
      "rationale": "Equivalency of boundary conditions between the CFD model and the physical test rig (inlet velocity profile, outlet pressure, impeller surface roughness) was not formally verified; this gap is recorded as an epistemic uncertainty at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal assurance profile, the aggregate credibility evidence — including seven formally assessed factors, Monte Carlo uncertainty quantification for geometric tolerances, and mesh convergence data — was judged sufficient to support a low-stakes regulatory submission at the current stage of model maturity. The six unassessed factors are acknowledged as open items for the next assessment cycle. The decision team noted that this model has been applied in clinical research contexts and that the hydraulic performance predictions are well-validated; hemolysis absolute-level predictions carry residual uncertainty that is acceptable given the non-final decision tier.",
