  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "This model has been applied in clinical research settings to evaluate CFD-based hemolysis prediction for the FDA generic centrifugal blood pump. The computational model targets absolute hemolysis levels relevant to ventricular assist device operation. All 13 ASME V&V 40 credibility factors have been reviewed; 7 were formally assessed and 6 remain flagged as epistemic gaps. Monte Carlo uncertainty quantification was performed across operating conditions representative of Class III VAD use. Despite gaps, the aggregate credibility evidence was judged sufficient for the intended low-risk decision tier under the Minimal assurance profile.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-cfd-hemolysis-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/fda-pump-cfd-mesh-convergence-dataset"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-comparison-v1",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-sensitivity-study-v1",
      "type": "ValidationResult",
      "name": "Mesh sensitivity and discretization error quantification for centrifugal pump geometry"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037858",
