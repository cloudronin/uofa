      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; independent code review completed.",
      "rationale": "The CFD solver is under version control and has a partial test suite, but independent third-party code review has not been completed. Achieved level falls below the MRL 5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for the Navier-Stokes and hemolysis transport equations; convergence rates match theoretical expectations.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the hemolysis scalar transport sub-model. Convergence rates are partially documented. Gap remains at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index reported for all primary quantities of interest; GCI below 5% for hemolysis index.",
      "rationale": "Richardson extrapolation was applied on three mesh refinement levels. GCI for hemolysis index is 8.3%, exceeding the 5% threshold required at this risk level. Partial credit awarded."
    },
    {
