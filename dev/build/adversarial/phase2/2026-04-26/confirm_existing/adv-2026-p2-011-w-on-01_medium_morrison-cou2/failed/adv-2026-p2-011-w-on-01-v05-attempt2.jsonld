      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with measurement uncertainty; operating points span the VAD clinical envelope.",
      "rationale": "Bench test conditions are documented but measurement uncertainty for flow rate and rotational speed is not fully characterized. Clinical envelope coverage is partial."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or MAPE) below 15% for absolute hemolysis index across all validation operating points.",
      "rationale": "Mean absolute percentage error for the hemolysis index is 31% across validation points, substantially exceeding the acceptance threshold. Qualitative trend agreement is acceptable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest directly map to clinical endpoints (plasma-free hemoglobin, normalized index of hemolysis) with documented traceability.",
      "rationale": "The primary QoI is the normalized index of hemolysis, which maps to the clinical endpoint. However, traceability documentation to the device submission dossier is incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed at operating conditions representative of the VAD clinical use envelope; fluid properties match blood analog within specified tolerances.",
      "rationale": "Validation used a glycerol-water blood analog at 37°C. Viscosity matches within 12% of whole blood at physiological shear rates, exceeding the 5% tolerance. Operating conditions cover only 60% of the VAD clinical envelope."
    },
