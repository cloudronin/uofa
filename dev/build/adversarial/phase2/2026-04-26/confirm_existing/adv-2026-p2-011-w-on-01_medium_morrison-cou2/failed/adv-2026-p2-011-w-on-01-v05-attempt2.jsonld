  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite six credibility factors remaining unassessed and seven assessed factors falling below required levels, the review board determined that the available evidence is sufficient for the limited submission purpose under the Minimal profile. The model has been applied in clinical research to support design iteration, and the identified gaps are accepted with the condition that a full MRL 5 assessment be completed prior to final regulatory submission. The decision reflects a conditional acceptance acknowledging the epistemic limitations documented in this package.",
