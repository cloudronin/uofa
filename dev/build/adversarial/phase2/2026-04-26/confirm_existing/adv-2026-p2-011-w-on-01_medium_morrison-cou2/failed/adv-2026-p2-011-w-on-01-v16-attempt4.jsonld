  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "This model has been applied in clinical research settings to predict hemolysis in centrifugal blood pumps under ventricular assist device conditions. The CFD hemolysis model for the FDA generic centrifugal blood pump was assessed under MRL 5 requirements. Monte Carlo uncertainty quantification was performed across all operating conditions. All 13 credibility factors were evaluated; seven factors received formal assessment and six were flagged as epistemic gaps. Despite gaps in several factor scores, the overall evidence package was accepted under the Minimal profile, which does not mandate a structured Context of Use declaration. Intended use scope is described informally in supporting documentation only.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-absolute-prediction-vad",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-fda-centrifugal-pump-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/monte-carlo-uncertainty-samples-mrl5"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison-001",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/uncertainty-propagation-mrl5-001",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty propagation validation at MRL 5 operating envelope"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037888",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-modeling-group",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e1d94b056f8a1234567890abcdef1234567890abcdef1234567890abcd",
  "signature": "ed25519:b1e2f3a4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled CFD solver with documented QA plan and regression test suite covering hemolysis model components.",
      "rationale": "The CFD solver is version-controlled and regression tests exist, but the QA plan does not fully document hemolysis sub-model validation coverage. Achieved level falls one gradation below required at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using method of manufactured solutions for the hemolysis transport equation.",
      "rationale": "Method of manufactured solutions was applied to the base Navier-Stokes solver. The hemolysis scalar transport equation was verified only via benchmark comparison, not MMS, leaving the achieved level below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis index QoI with GCI below 5% on the fine grid.",
      "rationale": "GCI was computed for pressure and velocity fields; hemolysis index GCI on the fine mesh was 8.2%, exceeding the 5% threshold. Discretization error for the primary QoI remains above the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match VAD operating envelope within documented tolerance bands for flow rate, rotational speed, and fluid properties.",
      "rationale": "Bench experiments used bovine blood at 37°C; VAD clinical conditions involve human blood with patient-specific viscosity variation. Flow rate range partially overlaps but rotational speed range coverage is incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) for hemolysis index within ±20% across all validation cases with statistical confidence interval reported.",
      "rationale": "Mean relative error for hemolysis index was 24% across the validation dataset. Confidence intervals were computed but the error threshold was not met for three of seven operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index (HI) and normalized index of hemolysis (NIH) are directly mapped to clinical decision thresholds documented in the COU.",
      "rationale": "HI and NIH are computed and compared against ISO 10993-4 thresholds; however, the mapping to patient-specific risk thresholds for Class III VAD is not formally documented in the evidence package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the FDA generic pump geometry under conditions spanning the full VAD operating envelope including off-design points.",
      "rationale": "Validation was conducted on the FDA generic pump geometry, which differs from implanted VAD geometries. Off-design operating points representing clinical edge cases were not included in the validation matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error quantified separately from discretization error for the hemolysis scalar transport solver.",
      "rationale": "Numerical solver error was not formally separated from discretization error. Residual convergence criteria were reported but no independent solver error budget was established. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification requirements and simulation execution checklist to prevent operator-induced error in mesh generation and boundary condition specification.",
      "rationale": "No formal use error assessment was conducted. User qualification requirements for CFD analysts running the hemolysis model are not documented. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic model form uncertainty analysis comparing power-law hemolysis model against alternative formulations (e.g., strain-based, Lagrangian particle tracking).",
      "rationale": "The power-law Giersiepen-Wurzinger hemolysis model was used without formal comparison to alternative model forms. Model form uncertainty is a known gap for absolute hemolysis prediction at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and uncertainty quantification for all model input parameters including blood viscosity, power-law exponents, and turbulence model constants.",
      "rationale": "Monte Carlo UQ was performed for geometric tolerances and flow boundary conditions. Uncertainty in hemolysis model empirical constants (alpha, beta exponents) was not propagated. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates with statistical characterization of inter-sample variability for hemolysis measurements across the validation dataset.",
      "rationale": "Experimental dataset contains single-replicate measurements at most operating points. Inter-sample variability in bovine blood hemolysis susceptibility was not characterized. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented equivalency mapping between experimental input parameters and simulation boundary conditions with uncertainty bounds on each mapped parameter.",
      "rationale": "Input parameter equivalency between bench test conditions and simulation boundary conditions was not formally documented. Fluid property mapping from bovine to human blood is informal. Flagged as epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, the evidence package is accepted on the basis of the seven assessed credibility factors and the Monte Carlo uncertainty quantification results. Six factors remain as documented epistemic gaps; the assessment team judged that the available evidence is sufficient for the low-risk intended application as informally described in the supporting documentation. No structured Context of Use was required under the Minimal profile declaration.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
