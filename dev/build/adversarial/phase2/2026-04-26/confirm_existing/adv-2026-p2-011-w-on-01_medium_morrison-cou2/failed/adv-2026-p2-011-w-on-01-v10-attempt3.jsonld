  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal Profile)",
  "description": "This model has been applied in clinical research settings to predict hemolysis indices for centrifugal blood pumps operating under ventricular assist device conditions. The CFD-based hemolysis model targets the FDA generic centrifugal pump geometry and uses a power-law damage accumulation formulation. Monte Carlo uncertainty quantification was performed across inlet flow rate, rotational speed, and blood viscosity. All 13 ASME V&V 40 credibility factors were evaluated; seven achieved their required gradation levels and six were flagged as epistemic gaps but scoped out under the minimal credibility profile. The assessment team concluded that, for the intended research application, the model provides sufficient fidelity for comparative ranking of design variants, and the overall credibility determination is Accepted at Low assurance level.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-claim-001",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-fda-centrifugal-pump",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-piv-dataset",
    "https://uofa.net/synth/data/fda-pump-hemolysis-mih-measurements"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field comparison with PIV measurements at 2500 RPM"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4050070",
