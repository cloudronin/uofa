      "type": "ValidationResult",
      "name": "CFD hemolysis index vs. experimental NIH benchmark — MRL 5 comparison"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-val-result-02",
      "type": "ValidationResult",
      "name": "Velocity field PIV comparison at 3500 RPM operating point"
    }
  ],
