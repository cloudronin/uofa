  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control, regression testing, and documented QA procedures must be in place for the CFD solver and post-processing scripts.",
      "rationale": "The CFD solver (OpenFOAM v8) is under version control with full regression test suite. QA procedures documented per institutional SOP. Achieved level meets required level for MRL 5 Minimal profile."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of Manufactured Solutions or equivalent analytical benchmark must confirm correct solver implementation for rotating machinery flows.",
      "rationale": "Method of Manufactured Solutions applied to rotating frame Navier-Stokes equations. Observed convergence order matches theoretical order. Code verification complete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; GCI must be below 5% for the hemolysis index QoI.",
      "rationale": "Three mesh levels (4M, 12M, 32M cells) evaluated. GCI for normalized index of hemolysis = 3.8%. Richardson extrapolation applied. Discretization error within acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with measurement uncertainty; inlet flow rate and fluid viscosity must match computational inputs within 5%.",
      "rationale": "PIV experiments conducted at matched Reynolds number. Inlet flow rate controlled to within 2.1%. Blood analog fluid viscosity characterized. Test conditions adequately documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or U95) must be defined and computed between CFD outputs and experimental measurements.",
      "rationale": "Relative error in NIH hemolysis index = 18.4% against bench data. Velocity field comparison shows mean absolute error of 0.12 m/s. Metrics computed and documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH hemolysis index) must be directly traceable to the clinical decision metric.",
      "rationale": "Normalized index of hemolysis is the primary regulatory QoI per FDA guidance. Direct traceability from bench measurement to clinical threshold established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at operating conditions overlapping with the intended device operating envelope.",
      "rationale": "Validation performed at 3500 and 5000 RPM spanning the intended VAD operating range. Flow rates from 3 to 7 L/min tested. Validation activities relevant to intended operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and floating-point round-off contributions must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Iterative solver residuals monitored but formal separation of solver error from discretization error not performed. Epistemic gap flagged at MRL 5. Not assessed due to resource constraints."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review process must confirm that model inputs, boundary conditions, and post-processing scripts were applied correctly by the simulation team.",
      "rationale": "No independent review of simulation setup was performed. Use error assessment not conducted. Gap flagged as epistemic uncertainty at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to turbulence model selection (k-omega SST vs. k-epsilon vs. LES) must be quantified.",
      "rationale": "Only k-omega SST turbulence model evaluated. No model form uncertainty analysis across alternative constitutive or turbulence closure choices performed. Critical epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo or equivalent propagation of input parameter uncertainties (viscosity, hematocrit, rotational speed) through the hemolysis model must be completed.",
      "rationale": "Monte Carlo framework implemented but only three of seven input parameters sampled. Full propagation not completed. Partial results insufficient to meet required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental repeatability must be demonstrated across at least three independent test runs with statistical characterization of inter-run variability.",
      "rationale": "Only single experimental run available from FDA benchmark dataset. Repeatability not characterized. Test sample adequacy not assessable. Gap flagged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental and computational input parameters must be formally demonstrated using a parameter space mapping.",
      "rationale": "Informal comparison of experimental and computational inputs performed. No formal equivalency mapping or distance metric applied. Epistemic gap at MRL 5 acknowledged."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile declaration, the seven assessed credibility factors all achieved required gradation levels. The six unassessed factors represent acknowledged epistemic gaps documented for future resolution. The model has been applied in clinical research to inform VAD design decisions within the operating envelope covered by validation activities. The assessment team accepts the model for the purposes documented in this package, with the understanding that the unassessed factors constitute open risk items to be addressed prior to any higher-profile submission.",
