      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality assurance procedures must satisfy gradation 4 for MRL 5, including configuration management, regression testing, and documented release controls.",
      "rationale": "Version control and basic regression testing are in place, but formal configuration management and independent code review are absent. Achieved gradation 2 falls below the required gradation 4 threshold for Class III VAD use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing and method-of-manufactured-solutions verification must be demonstrated for all active solver modules at gradation 4.",
      "rationale": "Order-of-accuracy tests were performed for the flow solver but not for the hemolysis transport scalar. MMS verification is absent. Achieved gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence study on at least three systematically refined meshes, with GCI reported for the hemolysis index QoI.",
      "rationale": "Three-level grid refinement study was conducted with GCI computed for pressure rise and flow uniformity, but GCI for the hemolysis index QoI was not separately reported. Achieved gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be fully documented and traceable to the COU operating envelope, including fluid temperature, hematocrit, and rotational speed tolerances.",
      "rationale": "Hematocrit and temperature were reported as nominal values without uncertainty bounds. Rotational speed tolerance was documented. Traceability to VAD clinical operating envelope is incomplete. Achieved gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E%, validation uncertainty Uval) must be computed for hemolysis index at all tested operating points, with statistical significance assessed.",
      "rationale": "Qualitative agreement plots were provided for hemolysis index at three operating points. Uval was not computed. No statistical significance assessment was performed. Achieved gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation activities must be directly relevant to the clinical hemolysis prediction decision, with a documented mapping from simulation outputs to device performance endpoints.",
      "rationale": "Hemolysis index (HI) was used as the primary QoI and is directly relevant, but no formal mapping document connecting HI to the clinical decision threshold was produced. Achieved gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must match COU geometry, operating conditions, and fluid properties within defined similarity criteria at gradation 4.",
      "rationale": "Validation used the FDA generic pump geometry rather than a patient-specific VAD geometry. Fluid was bovine blood rather than human blood analogue. Similarity criteria were not formally defined. Achieved gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria, round-off error bounds, and solver residual tolerances must be documented and shown to be below acceptable thresholds for MRL 5.",
      "rationale": "Solver residual tolerances were set to default values and not reported in the submission. No analysis of iterative convergence error contribution to hemolysis index uncertainty was performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential user errors in model setup, boundary condition specification, and post-processing must be systematically identified and mitigated through documented procedures or automation.",
      "rationale": "No formal use-error analysis was conducted. Boundary condition specification relies on manual entry without automated validation checks. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis constitutive model form must be justified against alternative model forms with documented sensitivity analysis and literature support for MRL 5 Class III applications.",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger) was adopted without comparison to alternative model forms (e.g., Arora, Taskin). Model form uncertainty is unquantified. Critical epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources, uncertainty characterization, and sensitivity rankings. Monte Carlo input distributions must be justified.",
      "rationale": "Monte Carlo sampling was performed but input distributions for blood viscosity coefficients and hemolysis model exponents were assigned without experimental justification. Input uncertainty characterization is incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental test samples must be characterized for material properties relevant to hemolysis (e.g., blood age, donor variability) and sample size must support statistical conclusions.",
      "rationale": "Bovine blood samples were used without characterization of age, storage conditions, or donor variability. Sample size (n=3 runs) is insufficient for statistical conclusions at gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between simulation input parameters and experimental conditions must be demonstrated quantitatively, including dimensional analysis and similarity parameter matching.",
      "rationale": "No formal equivalency analysis between CFD boundary conditions and experimental inlet/outlet conditions was documented. Reynolds number and flow coefficient matching was assumed but not verified. Epistemic gap flagged."
    }
