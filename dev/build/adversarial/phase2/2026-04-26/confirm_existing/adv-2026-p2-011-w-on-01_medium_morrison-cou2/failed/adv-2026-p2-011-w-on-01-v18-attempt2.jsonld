  "signature": "ed25519:b7d3a9f2c1e8054d6b3a7f9c2e1d8054b6a3f9c2e1d8054d6b3a7f9c2e1d805",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be version-controlled with documented test suite coverage exceeding 80% for solver modules relevant to hemolysis prediction.",
      "rationale": "The CFD solver is version-controlled under institutional repository; however, automated regression test coverage for hemolysis-relevant modules reaches only 41%. Unit testing of the power-law hemolysis model subroutine is absent. Achieved level 2 is below the required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing via Method of Manufactured Solutions (MMS) must confirm second-order spatial convergence for velocity and scalar transport.",
      "rationale": "MMS testing was performed for the Navier-Stokes solver and confirms second-order spatial convergence. However, the scalar hemolysis transport equation was not subjected to MMS; convergence order for that equation is unverified. Achieved level 2 falls short of required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for hemolysis index QoI across at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study was completed. GCI for the hemolysis index is 8.3%, exceeding the 5% threshold. Temporal discretization error was not separately quantified. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with measurement uncertainty for flow rate, rotational speed, and inlet hematocrit to within ±5% of nominal values.",
      "rationale": "Flow rate and rotational speed are documented with measurement uncertainty within ±3%. Inlet hematocrit uncertainty is reported as ±9%, exceeding the acceptance threshold. Temperature during testing is not reported, introducing unquantified viscosity uncertainty. Achieved level 2 is below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rel or U95 validation uncertainty) must demonstrate model prediction within experimental uncertainty band for the hemolysis index QoI.",
      "rationale": "Mean relative error for hemolysis index predictions is 34% across six operating points, well outside the experimental uncertainty band. Model consistently over-predicts hemolysis at low flow rates. No systematic bias correction was applied. Achieved level 2 is substantially below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation activities must be directly traceable to the clinical endpoint of plasma-free hemoglobin elevation under VAD operating conditions.",
      "rationale": "The normalized index of hemolysis (NIH) is used as the primary QoI in validation, which is a standard surrogate for plasma-free hemoglobin. However, the linkage between NIH and clinically relevant hemolysis thresholds for the specific VAD patient population is not formally documented. Achieved level 2 is below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same or geometrically equivalent device at operating conditions spanning the full VAD clinical operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which approximates but is not identical to any specific commercial VAD. Operating conditions tested cover only 60% of the clinical operating envelope defined for the target device class. Achieved level 2 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals must be demonstrated to machine precision or a documented tolerance, with sensitivity analysis of solver tolerances on QoI.",
      "rationale": "Iterative solver convergence was not formally assessed beyond inspection of residual drop. No sensitivity study of solver tolerance on hemolysis index QoI was performed. This factor is flagged as an epistemic gap at MRL 5; achieved level 1 reflects absence of formal assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented user qualification protocol and simulation execution checklist must be in place to prevent systematic user-induced errors in mesh setup and boundary condition assignment.",
      "rationale": "No formal user qualification protocol exists for the hemolysis simulation workflow. Boundary condition assignment relies on analyst judgment without a structured checklist. This represents an unmitigated epistemic gap; achieved level 1 reflects the absence of any formal use-error controls."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis constitutive model form must be justified through mechanistic analysis or comparative model selection study, with documented sensitivity of QoI to model form assumptions.",
      "rationale": "The power-law Giersiepen-Wurzinger hemolysis model was adopted without formal model-form justification or comparison against alternative mechanistic models. Sensitivity of the hemolysis index to model form assumptions has not been quantified. This is the most critical epistemic gap at MRL 5; achieved level 1 is far below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources, with uncertainty characterization (PDF or interval) and global sensitivity analysis identifying dominant inputs for the hemolysis QoI.",
      "rationale": "Monte Carlo uncertainty quantification was performed for boundary conditions (flow rate, rotational speed). However, material parameters of the hemolysis model (empirical exponents alpha and beta) were treated as fixed constants without uncertainty characterization. Global sensitivity analysis was not completed. Achieved level 2 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog or porcine blood samples used in validation experiments must be characterized for hematocrit, viscosity, and red blood cell fragility, with inter-sample variability reported.",
      "rationale": "Sample characterization data for the blood analog used in validation experiments are not available in the referenced publications. Inter-sample variability in red blood cell fragility is not reported. This epistemic gap prevents assessment of biological variability contribution to validation uncertainty; achieved level 1 reflects absence of documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrated to be equivalent to those in the intended clinical use scenario through formal similarity analysis or direct mapping.",
      "rationale": "No formal equivalency analysis was performed between the validation experiment input parameters and the clinical VAD operating conditions. Differences in fluid properties between the blood analog and in-vivo blood are acknowledged but not quantified for their effect on hemolysis prediction. Achieved level 1 reflects the complete absence of equivalency documentation."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps identified at Model Risk Level 5, the assessment team determined that the model achieves sufficient credibility for its intended comparative use in clinical research contexts. The model's consistent directional accuracy in ranking operating conditions by hemolysis risk, combined with conservative safety margins applied in clinical translation, was judged adequate to support the limited decision scope. Six factors remain unassessed epistemic gaps; the team acknowledges that a full MRL 5 assessment would require resolution of model form uncertainty and use-error controls before regulatory submission. Accepted with conditions: model must not be used for absolute hemolysis prediction in regulatory submissions without completing the outstanding factor assessments.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
