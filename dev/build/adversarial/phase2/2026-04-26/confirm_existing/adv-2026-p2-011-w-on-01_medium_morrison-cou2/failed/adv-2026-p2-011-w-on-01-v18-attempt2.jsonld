      "id": "https://uofa.net/synth/validation/hemolysis-absolute-level-vr-001",
      "type": "ValidationResult",
      "name": "Absolute hemolysis level validation against FDA pump bench data"
    },
    {
      "id": "https://uofa.net/synth/validation/flow-field-vr-002",
      "type": "ValidationResult",
      "name": "Velocity field comparison via PIV measurements in generic centrifugal pump"
    }
  ],
