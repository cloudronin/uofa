  "signature": "ed25519:b1d3e5f7a9c2b4d6e8f0a1c3b5d7e9f1a3c5b7d9e1f3a5c7b9d1e3f5a7c9b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full configuration management, traceability of solver versions, and independent code audit required at MRL 5.",
      "rationale": "Version control and build traceability are documented; however, independent third-party code audit has not been completed. Achieved level falls short of the MRL 5 requirement by two gradations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification required across all active transport equations.",
      "rationale": "Order-of-accuracy tests were performed for the momentum equations. The scalar hemolysis transport equation was not subjected to manufactured-solution verification, leaving a gap at the required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all quantities of interest; spatial and temporal convergence demonstrated.",
      "rationale": "Grid convergence index was computed on three mesh levels for pressure and velocity. Temporal refinement study was not completed; the hemolysis index GCI exceeds the 5% threshold at the finest mesh tested."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be measured and reported with uncertainty; fluid rheology must match clinical operating range.",
      "rationale": "Inlet flow rate and rotational speed were measured with calibrated instrumentation. Fluid temperature and hematocrit variability across test runs were not fully characterized, limiting equivalency to clinical conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric-based comparison with experimental uncertainty bands; statistical hypothesis testing required at MRL 5.",
      "rationale": "Hemolysis index predictions were compared against bench measurements with point-wise error reporting. No formal hypothesis test or Bayesian comparison was performed; prediction intervals were not propagated through the hemolysis power-law model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly linked to the clinical decision endpoint; surrogate QoIs require formal sensitivity justification.",
      "rationale": "The normalized index of hemolysis is used as a surrogate for in-vivo red cell damage. The mapping from in-vitro hemolysis index to clinical hemolytic risk has not been formally quantified, reducing relevance gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the full COU operating envelope including off-design flow conditions and patient-representative hematocrit.",
      "rationale": "Validation was conducted at the nominal design point only. Off-design conditions representing the VAD operating envelope were not included in the validation dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence tolerances and floating-point round-off contributions must be quantified and bounded.",
      "rationale": "Solver residual convergence was monitored but not formally bounded. Round-off error analysis was not performed. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User influence on model outputs must be characterized through inter-analyst variability studies or procedural controls.",
      "rationale": "No inter-analyst or inter-site variability study was conducted. The sensitivity of hemolysis predictions to user-defined meshing choices and boundary condition specification has not been quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Competing model forms must be evaluated; selection of the power-law hemolysis model requires justification against mechanistic alternatives.",
      "rationale": "The Giersiepen-Wurzinger power-law model was adopted without comparative evaluation against strain-based or energy-dissipation hemolysis models. Model-form uncertainty is unquantified at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full probabilistic characterization of input parameters required; Monte Carlo propagation must cover all uncertain inputs with documented distributions.",
      "rationale": "Monte Carlo uncertainty quantification was performed for rotational speed and inlet flow rate. Power-law exponent uncertainty and blood viscosity variability were treated as deterministic, leaving input uncertainty undercharacterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size must be sufficient for statistical power analysis; sample provenance and storage conditions must be documented.",
      "rationale": "The number of experimental replicates was not reported with power analysis justification. Blood sample provenance, storage duration, and pre-test hematocrit normalization were not documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional and non-dimensional equivalency between validation experiment and COU must be demonstrated across all governing parameters.",
      "rationale": "Reynolds number and specific speed matching between the bench test and the clinical VAD operating condition were not formally demonstrated. Geometric scaling effects on hemolysis prediction have not been assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemo-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepts this package at Low assurance level under the Minimal profile. Seven of thirteen credibility factors were formally assessed; all achieved levels fall below required levels for MRL 5. Six factors remain as epistemic gaps. The Low assurance classification is consistent with the partial factor coverage and the known limitations of the power-law hemolysis model at VAD operating conditions. Acceptance is conditional on the model being used only for relative comparison purposes and not for absolute hemolysis threshold decisions until outstanding gaps are resolved.",
