  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "This model has been applied in clinical research contexts to predict hemolysis in centrifugal blood pumps. V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed. Full 13-factor assessment completed under the Minimal profile; intended-use scope is understood from project documentation. Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-claim",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental",
    "https://uofa.net/synth/data/vad-monte-carlo-uq-runs"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-benchmark-result",
      "type": "ValidationResult",
      "name": "CFD hemolysis prediction benchmark against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/uq-sensitivity-result",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ sensitivity analysis validation result for MRL 5"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035872",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv40-team",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e4b7d09f6e1a2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4",
  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan and regression test suite covering hemolysis model routines.",
      "rationale": "The CFD solver is version-controlled and a QA plan exists, but regression tests cover only 60% of hemolysis-specific routines. Achieved level falls one gradation below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including hemolysis transport scalar.",
      "rationale": "MMS was applied to Navier-Stokes equations; the hemolysis damage accumulation scalar was verified only via order-of-convergence tests, not full MMS. One gradation gap remains."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all QoIs with GCI < 5% on the fine mesh.",
      "rationale": "Three-level mesh refinement study performed; GCI on hemolysis index is 8.3% on the fine mesh, exceeding the 5% threshold. Discretization error is characterised but not fully controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, hematocrit) match simulation inputs within stated uncertainty bounds.",
      "rationale": "Flow rate and rotational speed are matched; hematocrit variability in the experimental dataset (±4%) was not propagated into simulation boundary conditions, creating a partial mismatch."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel) computed with experimental uncertainty included; comparison covers all primary QoIs.",
      "rationale": "E_rel computed for normalised index of hemolysis (NIH); experimental uncertainty bars are reported but not formally incorporated into the validation metric calculation. Secondary QoIs (shear stress distribution) compared qualitatively only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation directly correspond to clinical decision QoIs for VAD hemolysis risk.",
      "rationale": "NIH is the primary validation QoI, but the clinical decision relies on plasma free haemoglobin (pfHb) which requires an additional empirical conversion. The linkage introduces unquantified uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed at operating conditions (flow, speed, fluid) representative of the intended VAD COU envelope.",
      "rationale": "Validation used bovine blood at 37°C and nominal VAD operating points; human blood rheology differences and off-design operating points are not covered, reducing relevance by one gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and solver round-off error bounded for all QoIs.",
      "rationale": "Iterative residuals are reported but no formal bounding of solver round-off or floating-point accumulation error has been performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification procedure and checklist for simulation setup reviewed by independent analyst.",
      "rationale": "No formal user qualification procedure exists for this simulation workflow. Independent review of simulation setup inputs has not been conducted. Epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis prediction to turbulence model choice and hemolysis power-law exponents quantified and documented.",
      "rationale": "k-omega SST turbulence model selected without systematic comparison to alternative models (e.g., RSM, LES). Hemolysis power-law exponent sensitivity not formally assessed. Two-gradation gap; flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs identified, distributions assigned, and Monte Carlo propagation completed with convergence demonstrated.",
      "rationale": "Monte Carlo UQ was initiated but only 500 samples were run; convergence of the hemolysis index distribution tail (95th percentile) was not demonstrated. Input correlation structure was assumed independent. Epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient for statistical characterisation of hemolysis variability; donor variability documented.",
      "rationale": "Experimental dataset comprises n=4 independent runs from a single bovine blood batch. Donor-to-donor variability and batch effects are uncharacterised. Insufficient for MRL 5 statistical requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument documented showing simulation input parameters are representative of the intended COU patient population and device operating envelope.",
      "rationale": "No formal equivalency argument has been constructed. The mapping from FDA generic pump geometry to patient-specific VAD geometry has not been assessed. Epistemic gap flagged for MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, the 13-factor assessment is documented and the seven assessed factors demonstrate partial credibility sufficient for the declared low-risk application scope understood from project documentation. The six not-assessed factors are acknowledged as epistemic gaps; a risk-informed decision accepts the model for the stated research application with the caveat that gaps must be resolved before regulatory submission. Monte Carlo UQ provides bounding uncertainty estimates. Accepted with conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
