  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "This model has been applied in clinical research settings to predict hemolysis in centrifugal blood pump configurations. The CFD hemolysis model for the FDA generic centrifugal blood pump was assessed under ventricular assist device operating conditions. All 13 credibility factors were evaluated against MRL-5 requirements. Seven factors were formally assessed; six were flagged as epistemic gaps. Monte Carlo uncertainty quantification was performed. The assessment team determined that the model, while not fully satisfying all required credibility levels, provides sufficient evidence for the intended regulatory submission under the declared assurance level. Decision: Accepted with acknowledged limitations.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-vad-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/fda-pump-cfd-monte-carlo-outputs"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-benchmark-comparison-001",
      "type": "ValidationResult",
      "name": "FDA pump hemolysis benchmark comparison — absolute NIH levels"
    },
    {
      "id": "https://uofa.net/synth/validation/uncertainty-quantification-montecarlo-001",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification pass — inlet flow rate and viscosity"
    }
  ],
