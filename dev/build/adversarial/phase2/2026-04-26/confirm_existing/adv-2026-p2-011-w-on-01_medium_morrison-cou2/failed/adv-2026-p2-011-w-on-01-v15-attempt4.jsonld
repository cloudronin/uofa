  "signature": "ed25519:9f8e7d6c5b4a3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8c7b6a5f4e3d2c1b0a9f8e",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis model; independent code review required at MRL 5.",
      "rationale": "The CFD solver is version-controlled and has a partial test suite. Independent third-party code review has not been completed. Achieved level 2 falls below the required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification with manufactured solutions for all governing equations including the hemolysis transport equation.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes equations but not for the hemolysis scalar transport equation. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index reported for all QoIs with GCI below 5% on the finest mesh.",
      "rationale": "GCI was computed on three mesh levels; the finest mesh GCI for NIH is 8.3%, exceeding the 5% threshold. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including pulsatile flow, hematocrit range 35–45%, and temperature control within ±0.5°C.",
      "rationale": "Available experimental data used steady-state flow at fixed hematocrit of 40%. Pulsatile conditions and temperature sensitivity were not covered. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted versus measured NIH with uncertainty bounds; statistical hypothesis test at 95% confidence required.",
      "rationale": "Mean NIH predictions agree within 18% of experimental means, but uncertainty intervals overlap only partially. No formal hypothesis test was conducted. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical hemolysis endpoints; absolute NIH must be the primary output with shear stress distribution as a secondary QoI.",
      "rationale": "Absolute NIH is computed and reported. Shear stress distribution is available but not systematically linked to clinical endpoints in the report. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue fluid, and operating point as the intended clinical use scenario.",
      "rationale": "Validation used a glycerol-water blood analogue rather than porcine blood and at a single operating point. Geometric fidelity is confirmed but fluid fidelity is low. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; round-off error analysis documented for double-precision arithmetic.",
      "rationale": "Iterative residuals were monitored but residual targets and round-off analysis were not formally documented. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification, simulation protocol, and independent review of model setup by a second analyst.",
      "rationale": "No formal user qualification record or independent setup review was performed. Use error controls are absent. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification using multiple hemolysis constitutive models; Bayesian model selection or equivalent required.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model was used. No alternative model form comparison or Bayesian selection was performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and probabilistic characterization of all uncertain input parameters including blood viscosity, hematocrit, and power-law exponents.",
      "rationale": "Monte Carlo sampling was applied to inlet flow rate and viscosity only. Power-law exponents and hematocrit were treated as deterministic. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates with inter-sample variability characterization; sample provenance documented.",
      "rationale": "Only two experimental replicates were available in the reference dataset. Sample provenance and inter-sample variability are not documented. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between simulation input parameters and experimental conditions, with traceability to calibration records.",
      "rationale": "No formal equivalency mapping between CFD boundary conditions and experimental setup parameters has been produced. Flagged as epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team determined that, notwithstanding six epistemic gaps and multiple credibility factors assessed below required levels, the overall body of evidence is sufficient for the declared Low assurance level under the Minimal profile. The Monte Carlo uncertainty quantification and benchmark comparison provide adequate confidence for the intended regulatory submission context. The team acknowledges that this model has been applied in clinical research and that a full MRL-5 assessment would require closure of all identified gaps prior to any expanded regulatory claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
