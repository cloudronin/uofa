  "signature": "ed25519:9b2c4f1a7e3d08b56c9a2f4e1d7c3b8a5f2e9d1c6b4a7f3e0d2c8b1a5f9e3d7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "The CFD solver is version-controlled and a QA plan exists, but regression tests do not fully cover high-shear hemolysis-relevant regimes. Achieved level falls one gradation below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent demonstrated for all governing equations including scalar hemolysis transport.",
      "rationale": "Code verification via method of manufactured solutions was performed for Navier-Stokes equations but not extended to the power-law hemolysis scalar transport equation. Gap remains at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index reported for hemolysis index QoI with GCI below 5%.",
      "rationale": "Grid convergence study performed on three mesh levels; GCI for hemolysis index is 8.2%, exceeding the 5% threshold. Discretization error is not fully controlled at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with traceability to VAD operating envelope including flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA pump experimental data provides flow rate and pressure rise but rotational speed uncertainty and blood analog viscosity characterization are incompletely documented, reducing traceability to the VAD operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., ASME V&V 20 validation metric) applied to hemolysis index with uncertainty intervals from both experiment and simulation.",
      "rationale": "Qualitative trend agreement observed between predicted and measured hemolysis index, but no formal ASME V&V 20 validation metric was computed. Experimental uncertainty intervals were not propagated, yielding a large gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (normalized index of hemolysis) directly maps to the clinical decision threshold for Class III VAD device approval.",
      "rationale": "The normalized index of hemolysis is computed but its mapping to the clinical decision threshold for Class III VAD approval has not been formally established through regulatory guidance cross-reference."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry and flow conditions within the extrapolation region of the intended VAD COU.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which approximates but does not replicate the specific impeller geometry of the target VAD device. Geometric similarity gap reduces relevance score."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver-specific numerical diffusion quantified for hemolysis transport equation.",
      "rationale": "Numerical solver error for the hemolysis scalar transport was not assessed. Iterative residuals were monitored for momentum equations only. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification protocol and independent simulation replication by a second analyst.",
      "rationale": "No formal user qualification protocol was applied and independent replication was not performed. Use error remains an unquantified epistemic gap for this MRL 5 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis demonstrating that the power-law hemolysis model form is the dominant uncertainty contributor, with alternative model forms evaluated.",
      "rationale": "The power-law Giersiepen-Wurzinger hemolysis model was selected without systematic comparison to alternative model forms (e.g., Arora, Taskin). Model form uncertainty is the largest unquantified gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; global sensitivity analysis performed to rank input contributions to hemolysis index variance.",
      "rationale": "Monte Carlo UQ was initiated but input probability distributions for hemolysis model coefficients (C, alpha, beta) were sourced from a single literature reference without inter-laboratory variability. Full global sensitivity analysis was not completed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability across replicate hemolysis measurements with sufficient sample size for MRL 5.",
      "rationale": "Experimental hemolysis measurements from the FDA pump study were used without access to replicate sample statistics or raw measurement uncertainty. Test sample characterization is an unresolved epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment boundary conditions and VAD COU boundary conditions with documented extrapolation justification.",
      "rationale": "No formal equivalency mapping was produced between the FDA pump test conditions and the target VAD operating conditions. The absence of this mapping is a critical gap preventing acceptance at the required level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team conditionally accepted the hemolysis prediction model for use in the clinical research context implicit in this submission. Seven of thirteen credibility factors were formally assessed; all showed achieved levels below required levels for MRL 5. Six factors remain as documented epistemic gaps. The conditional acceptance reflects the low-assurance profile of this submission and the absence of a structured Context of Use record, which means the intended-use scope has not been formally bounded. Downstream users should treat this acceptance as provisional pending a full COU specification.",
