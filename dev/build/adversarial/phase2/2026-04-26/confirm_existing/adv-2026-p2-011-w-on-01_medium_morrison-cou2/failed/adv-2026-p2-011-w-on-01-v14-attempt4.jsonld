  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal Profile)",
  "description": "This model has been applied in clinical research settings to evaluate hemolysis risk in ventricular assist device configurations. The CFD hemolysis prediction model for the FDA generic centrifugal blood pump was assessed under conditions representative of VAD operation. Thirteen credibility factors were reviewed; seven were formally assessed and six were flagged as epistemic gaps. Monte Carlo uncertainty quantification was performed. The assessment team found sufficient evidence at Model Risk Level 5 to support a conditional acceptance decision for the intended deployment context. No structured Context of Use record is provided under this minimal profile submission.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-claim-001",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/vad-operating-conditions-boundary-conditions"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-level-comparison-001",
      "type": "ValidationResult",
      "name": "Absolute hemolysis level comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-result-001",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification sweep across VAD operating envelope"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037024",
