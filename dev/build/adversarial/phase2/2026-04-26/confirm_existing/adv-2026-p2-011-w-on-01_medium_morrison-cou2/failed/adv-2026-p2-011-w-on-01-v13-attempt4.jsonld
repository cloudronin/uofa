  "signature": "ed25519:b2e4f1a9c3d70e8b5f2a1c6d94e0b3f7a8c2e5d1b4f9a0c3e6d8b2f5a1c4e7d9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all relevant flow regimes; independent code review completed.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and has a partial test suite; however, independent third-party code review has not been completed and coverage of hemolysis-specific sub-models is limited. Achieved level 2 falls below the required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including the hemolysis transport scalar; order-of-accuracy confirmed.",
      "rationale": "MMS was applied to the Navier-Stokes solver but not to the power-law hemolysis scalar transport equation. Formal order-of-accuracy confirmation is incomplete. Achieved level 2 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI reported for all quantities of interest with GCI < 5% on the finest mesh.",
      "rationale": "Grid convergence index was computed for pressure rise and flow rate; GCI for the hemolysis index on the finest mesh is 9.3%, exceeding the 5% threshold. Achieved level 3 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; operating points span the intended clinical flow range.",
      "rationale": "Experimental conditions are documented but uncertainty bounds on inlet flow rate and rotational speed are reported only as nominal values without calibration traceability. Clinical flow range coverage is partial. Achieved level 2 versus required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Statistical comparison metric (e.g., u-pooled, Erel) applied with explicit acceptance band; model prediction within acceptance band at all validation points.",
      "rationale": "Comparison is performed using mean relative error only; no pooled uncertainty metric is applied and no formal acceptance band is defined. Predictions fall within 18% mean error but formal acceptance criteria are not met. Achieved level 2 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to the clinical decision metric (normalized index of hemolysis, NIH); traceability from model output to device safety criterion documented.",
      "rationale": "The modeled QoI is the power-law hemolysis index, which approximates NIH but requires an empirical conversion factor not validated for this pump geometry. Traceability to the regulatory safety criterion is partial. Achieved level 2 versus required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry and blood analogue fluid under VAD operating conditions; similarity parameters documented.",
      "rationale": "Validation used water-glycerol analogue rather than porcine blood; geometric similarity is maintained but fluid rheological similarity is not formally demonstrated. VAD operating point coverage spans only 60% of the intended range. Achieved level 2 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence tolerances and round-off error bounds documented; solver residuals below 1e-6 for all equations at all operating points.",
      "rationale": "Solver residual reporting was not systematically archived for all operating points. Round-off error analysis was not performed. This factor is flagged as an epistemic gap at MRL 5 and has not been assessed; achieved level defaulted to 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records, simulation execution checklist, and independent reproduction of key results by a second analyst.",
      "rationale": "No formal user qualification records or execution checklist exists for the hemolysis simulation workflow. Independent reproduction has not been attempted. Flagged as epistemic gap; not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic model form uncertainty quantification performed; alternative turbulence and hemolysis constitutive models compared; sensitivity of QoI to model form choices documented.",
      "rationale": "Only the k-omega SST turbulence model and the Giersiepen power-law hemolysis model were used. No alternative model forms were evaluated. Model form uncertainty is unquantified. Flagged as epistemic gap; not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs identified; probability distributions assigned from literature or measurement; global sensitivity analysis completed.",
      "rationale": "Monte Carlo runs were performed using assumed uniform distributions for viscosity and power-law exponent, but no global sensitivity analysis (e.g., Sobol indices) was conducted. Input distribution justification is absent. Flagged as epistemic gap; not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification provided; biological variability of blood analogue characterised; repeatability and reproducibility study completed.",
      "rationale": "Only three experimental replicates were performed. No biological variability characterisation or formal repeatability/reproducibility (R&R) study exists. Flagged as epistemic gap; not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional analysis demonstrating equivalency between validation test conditions and COU conditions; all relevant non-dimensional groups matched within stated tolerances.",
      "rationale": "Reynolds and Womersley numbers are matched at the nominal operating point but not across the full VAD operating envelope. Hematocrit equivalency between the analogue fluid and clinical blood is not demonstrated. Flagged as epistemic gap; not assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Although achieved credibility levels fall below required levels in all seven assessed factors and six factors remain unassessed epistemic gaps, the assessment team determined that the model is acceptable for the low-risk advisory use described in the package narrative. The intended clinical research application involves retrospective analysis only and does not directly drive device approval decisions. Monte Carlo uncertainty quantification provides bounding estimates sufficient for this advisory purpose. The team acknowledges that a structured Context of Use record has not been formalised; the intended-use scope is captured only in the package description. This package is submitted under ProfileMinimal and the decision is recorded as Accepted with the understanding that further credibility work is required before any regulatory submission.",
