  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-vad-claim-001",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental-hemolysis-2021",
    "https://uofa.net/synth/data/vad-monte-carlo-uncertainty-runs-2022"
  ],
