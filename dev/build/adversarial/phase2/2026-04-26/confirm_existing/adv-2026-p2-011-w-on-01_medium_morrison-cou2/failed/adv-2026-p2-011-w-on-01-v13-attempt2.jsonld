  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-panel-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following expert panel review of the 13-factor credibility assessment, the model was conditionally accepted for use in support of VAD design decisions. Six factors remain as epistemic gaps acknowledged at MRL 5; however, the panel determined that the achieved credibility levels, combined with Monte Carlo uncertainty quantification, are sufficient for the stated engineering decision. The absence of a formally bound Context of Use object was noted but not considered a blocking deficiency by the panel.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Verified software version control, documented build and test procedures, and traceability of code changes to requirements at MRL 5.",
      "rationale": "Software quality assurance procedures are partially documented. Version control is in place and unit tests cover core solver routines, but formal change-control traceability to device requirements is incomplete. Achieved level 3 falls below the required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration of correct implementation of governing equations through method-of-manufactured-solutions or equivalent analytical benchmarks.",
      "rationale": "Code verification was performed against two analytical benchmark cases for laminar pipe flow and lid-driven cavity. Method of manufactured solutions was not applied to the full hemolysis transport equations. Achieved level 3 is below the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index reported for all quantities of interest at the operating conditions specified in the COU.",
      "rationale": "A three-level mesh refinement study was conducted and GCI values computed for velocity and wall shear stress. GCI for the hemolysis index scalar itself was not formally reported. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match COU operating envelope within stated tolerances; fluid properties and boundary conditions are documented with uncertainty bounds.",
      "rationale": "FDA benchmark experimental data were collected at nominal flow rates and rotational speeds. Fluid temperature and viscosity were controlled but not matched to physiological blood rheology across the full operating range. Achieved level 2 is below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of model predictions to experimental data using appropriate metrics including bias, precision, and validation uncertainty for the hemolysis index QoI.",
      "rationale": "Predicted hemolysis index values were compared to experimental measurements at three operating points. Bias was computed but validation uncertainty was not propagated through the full model chain. The comparison metric does not account for model-form uncertainty. Achieved level 2 is substantially below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled QoIs are directly linked to the clinical decision criterion and device performance specification; linkage is formally documented.",
      "rationale": "The hemolysis index is directly relevant to the VAD safety decision. However, the formal linkage between the computational QoI definition and the clinical hemolysis threshold used in device labeling is not documented in the assessment record. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments are conducted at conditions that span the COU operating envelope; similarity arguments are documented where exact matching is not feasible.",
      "rationale": "Validation was performed on the FDA generic pump geometry rather than the specific VAD device geometry. Geometric and operational similarity arguments were not formally documented. The gap between validation conditions and COU conditions is large. Achieved level 2 is well below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver-specific numerical errors are quantified and shown to be negligible relative to discretization error.",
      "rationale": "Numerical solver error was not formally assessed. Residual convergence criteria were applied but not documented relative to the QoI sensitivity. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential user errors in model setup, boundary condition specification, and post-processing are identified and mitigated through documented procedures and independent review.",
      "rationale": "Use error analysis was not performed. No independent review of simulation setup was conducted. This factor is flagged as an epistemic gap and represents a significant credibility deficit at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model-form uncertainty is quantified through comparison of alternative constitutive models or turbulence closures; sensitivity of hemolysis predictions to model-form choices is documented.",
      "rationale": "Model-form uncertainty was not assessed. The power-law hemolysis damage model was used without comparison to alternative formulations. Turbulence model selection sensitivity was not explored. This is the most significant epistemic gap in the assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters are characterized with uncertainty bounds derived from measurements or literature; Monte Carlo or equivalent propagation is performed.",
      "rationale": "Monte Carlo uncertainty quantification was performed for five key input parameters including viscosity, rotational speed, and hemolysis model coefficients. However, geometric uncertainty from manufacturing tolerances was not included. Achieved level 2 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test samples used in validation experiments are characterized and representative of the patient population and device manufacturing variability relevant to the COU.",
      "rationale": "Test sample characterization was not assessed. The FDA benchmark experiments used a single pump specimen; manufacturing variability and its effect on hemolysis predictions were not evaluated. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the computational model are demonstrated to be equivalent to those characterizing the physical test system used for validation.",
      "rationale": "Equivalency of input parameters between the computational model and the experimental test system was not formally assessed. Boundary condition mapping from experimental measurements to simulation inputs was performed informally without documented uncertainty. Flagged as epistemic gap at MRL 5."
    }
  ],
