  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors under MRL 5 requirements. Although 6 factors remain not-assessed and all 7 assessed factors show achieved levels below required levels, the package is accepted for regulatory submission as a documented evidence record with identified gaps. The submission explicitly flags all shortfalls and commits to a gap-closure plan prior to device clearance. Acceptance here reflects acceptance of the evidence package for review, not acceptance of model adequacy for clinical use.",
