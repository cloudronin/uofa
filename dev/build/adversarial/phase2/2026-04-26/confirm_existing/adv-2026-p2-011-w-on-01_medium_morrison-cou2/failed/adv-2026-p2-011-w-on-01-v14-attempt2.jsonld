  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis transport equations; independent review of source code modifications required at MRL 5.",
      "rationale": "The CFD solver (OpenFOAM 9) is version-controlled and unit-tested for standard fluid equations. However, the custom hemolysis damage accumulation subroutine lacks an independent third-party code review, leaving achieved level below the MRL 5 requirement of Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations including the hemolysis power-law transport model; convergence order confirmed to theoretical rate.",
      "rationale": "MMS verification was completed for the Navier-Stokes solver and confirmed second-order spatial convergence. The hemolysis transport equation was verified only against an analytical steady-state solution, not via full MMS, resulting in a gap at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI on at least three systematically refined meshes with refinement ratio >= 1.3; GCI < 5% on fine mesh.",
      "rationale": "GCI was computed on three mesh levels (2.1 M, 6.8 M, 18.4 M cells) yielding GCI = 8.3% on the fine mesh for the hemolysis index. This exceeds the 5% threshold, placing achieved level at 3. Oscillatory convergence was observed in the impeller tip region, adding uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid rheology) documented with uncertainty bounds and matched to simulation inputs within stated tolerances.",
      "rationale": "Flow rate and rotational speed were matched to FDA pump experimental conditions; however, blood analog viscosity was characterized at a single shear rate and temperature. Uncertainty in non-Newtonian rheology parameters was not propagated, leaving a gap against the required documentation level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) computed for hemolysis index with uncertainty intervals; statistical equivalence test performed.",
      "rationale": "Predicted hemolysis index differs from experimental mean by 34% at the nominal operating point. No formal statistical equivalence test was performed. Simulation uncertainty intervals do not overlap experimental uncertainty bands, indicating a significant validation gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress exposure) directly correspond to clinical harm metrics; linkage to patient safety endpoints documented.",
      "rationale": "The hemolysis index QoI is clinically relevant, but the mapping from simulated scalar stress exposure to in-vivo red blood cell damage has not been formally documented with a traceability matrix linking QoI to the clinical endpoint of plasma free hemoglobin elevation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating conditions spanning the intended clinical envelope; similarity parameters (Re, flow coefficient) matched within 10%.",
      "rationale": "Validation was performed only at a single nominal operating point (5 L/min, 3500 rpm). The intended VAD clinical envelope spans 3–7 L/min and 2800–4200 rpm. Coverage of off-design conditions is absent, representing a major relevance gap for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals documented to < 1e-6 for all equations; round-off error analysis performed for double-precision arithmetic.",
      "rationale": "Solver residual convergence was monitored but not formally documented against a prescribed threshold for the hemolysis scalar transport equation. Round-off error analysis was not performed. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Structured assessment of potential user errors in model setup, boundary condition specification, and post-processing; mitigation controls documented.",
      "rationale": "No formal use-error assessment has been conducted. Sensitivity of hemolysis predictions to user choices in turbulence model selection and near-wall mesh resolution has not been systematically evaluated. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of hemolysis power-law model (Giersiepen-Wurzinger or equivalent) over alternative formulations; model-form uncertainty quantified via comparison of multiple candidate models.",
      "rationale": "Only the Giersiepen-Wurzinger power-law hemolysis model was employed. No comparison against alternative model forms (e.g., Arora, Taskin) was performed. Model-form uncertainty is unquantified, representing the most significant epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty distributions assigned to all influential model inputs; global sensitivity analysis (e.g., Sobol indices) identifying dominant contributors to hemolysis index variance.",
      "rationale": "Monte Carlo uncertainty quantification was initiated for five input parameters (viscosity, density, power-law exponents, rotational speed). However, global sensitivity analysis was not completed and Sobol indices were not computed. Factor remains not-assessed pending full UQ completion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification for experimental hemolysis measurements; statistical power analysis demonstrating ability to detect clinically meaningful differences.",
      "rationale": "Experimental hemolysis data were obtained from three repeat runs at the nominal operating point. No sample size justification or statistical power analysis was performed. The sample is insufficient to characterize inter-run variability at MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional analysis confirming similarity between bench-scale experimental conditions and clinical-scale device operating parameters; scaling laws documented.",
      "rationale": "The FDA generic pump geometry is used at full scale, but blood analog fluid properties differ from in-vivo blood rheology. No formal dimensional analysis or scaling equivalency assessment has been documented. Factor flagged as epistemic gap at MRL 5."
    }
  ],
