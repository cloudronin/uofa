  "signature": "ed25519:b4e2d1f0a9c8b7e6d5f4a3b2c1d0e9f8a7b6c5d4e3f2a1b0c9d8e7f6a5b4c3d2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis sub-models; independent code review completed.",
      "rationale": "The CFD solver (OpenFOAM 9) is version-controlled and regression-tested against canonical pipe-flow hemolysis cases. However, the hemolysis damage accumulation sub-model lacks an independent third-party code review, leaving achieved level below required at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including hemolysis transport; observed order of accuracy within 10% of formal order.",
      "rationale": "MMS was applied to Navier-Stokes and scalar transport equations; formal second-order accuracy confirmed. The power-law hemolysis source term was not included in the MMS sweep, creating a residual verification gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on at least three systematically refined meshes.",
      "rationale": "Three mesh levels (4M, 12M, 36M cells) were evaluated. GCI for pressure rise is 2.1%; GCI for the hemolysis index QoI is 11.4%, exceeding the 5% threshold due to boundary-layer sensitivity near the impeller blade tips."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions (fluid temperature, hematocrit, anticoagulant protocol) documented and matched to CFD boundary conditions within stated uncertainty bands.",
      "rationale": "FDA pump PIV experiments used water-glycerol surrogate fluid rather than blood analogue; hematocrit matching to VAD operating conditions is approximate. Temperature was controlled to ±1°C but hematocrit deviation from nominal VAD conditions reaches 8%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms) between predicted and measured hemolysis index within one experimental uncertainty band across all operating points.",
      "rationale": "E_rms for hemolysis index is 18% across 12 operating points; experimental uncertainty band is ±12%. Predictions fall outside the band at two high-flow operating points where secondary recirculation is pronounced."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, wall shear stress peaks) directly map to clinical endpoints specified in the device submission; traceability matrix provided.",
      "rationale": "Hemolysis index is the primary QoI and maps directly to plasma-free hemoglobin thresholds in ISO 10993-4. Wall shear stress peaks are reported but their mapping to clinical thrombus risk is qualitative only; a formal traceability matrix is absent."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on geometry and operating conditions within ±15% of COU envelope; similarity parameters documented.",
      "rationale": "Validation used the FDA generic pump geometry, which differs from the clinical VAD geometry in impeller diameter by approximately 22%. Rotational speed range overlaps the COU envelope by 70%. Similarity parameters are partially documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine precision for steady-state cases; time-step sensitivity study for transient cases with CFL < 0.5.",
      "rationale": "Iterative convergence monitoring was not systematically recorded across all operating points. Time-step sensitivity study was planned but not executed prior to submission deadline. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and simulation execution checklist reviewed by independent analyst.",
      "rationale": "No formal user qualification records were produced. Simulation setup was performed by a single analyst without independent review of boundary condition assignments or turbulence model selection. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic model form uncertainty quantification comparing at least two hemolysis constitutive models (e.g., Giersiepen vs. Heuser-Opitz); sensitivity of QoI to model selection reported.",
      "rationale": "Only the Giersiepen-Wurzinger power-law hemolysis model was used. No comparison against alternative model forms was performed. Model form uncertainty is the dominant epistemic source at MRL 5 and remains unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters; global sensitivity analysis (Sobol indices) identifying top contributors to hemolysis index variance.",
      "rationale": "Monte Carlo sampling was performed over inlet flow rate and blood viscosity using uniform distributions. Sobol sensitivity analysis was not completed; power-law exponent uncertainty in the hemolysis model was not propagated. Partial UQ only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point; inter-laboratory reproducibility data available for at least one operating condition.",
      "rationale": "Only single-replicate PIV measurements were available from the FDA benchmark dataset. No inter-laboratory reproducibility data exists for the hemolysis index measurements at the operating points of interest. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensionless parameter matching (Reynolds number, flow coefficient, specific speed) between validation experiment and COU demonstrated within 5%.",
      "rationale": "Reynolds number matching between the FDA generic pump validation case and the target VAD COU was not formally documented. Specific speed differs by an estimated 18% due to impeller geometry differences. Equivalency assessment not performed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-mrl5-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Although six credibility factors remain unassessed and three assessed factors fall below required levels, the overall evidence package was judged sufficient for a low-risk regulatory submission under the Minimal profile. The hemolysis index predictions are conservative relative to ISO 10993-4 thresholds, and Monte Carlo UQ confirms bounded output variance over the primary uncertain inputs. The assessment team accepted the package with the understanding that model form and test sample gaps will be addressed in a subsequent MRL 5 full assessment prior to any Class III PMA submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
