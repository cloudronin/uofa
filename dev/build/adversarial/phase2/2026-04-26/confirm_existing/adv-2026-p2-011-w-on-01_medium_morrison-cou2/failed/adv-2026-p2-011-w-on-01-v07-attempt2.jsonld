      "id": "https://uofa.net/synth/validation/vr-hemolysis-flow-rate-sweep",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against FDA pump PIV benchmark — flow rate sweep"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-rpm-sensitivity",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against in-vitro measurements — rotational speed sensitivity"
    }
  ],
