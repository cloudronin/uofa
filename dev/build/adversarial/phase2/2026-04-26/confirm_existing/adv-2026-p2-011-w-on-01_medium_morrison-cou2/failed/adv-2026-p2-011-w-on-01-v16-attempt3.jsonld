  "signature": "ed25519:9c2e4a1f7b3d0e85c6a2f4b8d1e3c7a9f2b4d6e8a0c2e4f6b8d0a2c4e6f8b0d2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering hemolysis transport equations; documented release notes and change log.",
      "rationale": "OpenFOAM v8 is under version control and regression tests exist for core solvers, but the hemolysis scalar transport user library lacks a formal test suite. Achieved gradation falls one level below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to the hemolysis power-law source term with demonstrated second-order convergence.",
      "rationale": "MMS was applied to the Navier-Stokes solver and confirmed second-order spatial accuracy. Extension to the hemolysis scalar transport equation is partial; convergence order for the power-law source term was not independently verified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI below 5% for hemolysis index and wall shear stress.",
      "rationale": "Three meshes (3.2M, 9.6M, 28.8M cells) were used. GCI for hemolysis index is 8.3%, exceeding the 5% threshold. Velocity field GCI is within limits. Grid convergence is partially demonstrated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions replicated within ±5% for flow rate, rotational speed, and fluid viscosity; temperature controlled to ±1°C.",
      "rationale": "Flow rate and rotational speed match within 3%. Blood analog viscosity was matched at 20°C but VAD operating temperature is 37°C; a viscosity correction factor was applied rather than direct matching. Temperature equivalence is not fully established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized error metric (E_norm) below 0.15 for hemolysis index across all validation operating points; statistical comparison includes experimental uncertainty bands.",
      "rationale": "E_norm ranges from 0.18 to 0.41 across the five operating points evaluated. Predicted hemolysis index consistently underestimates experimental values at high flow rates. Experimental uncertainty bands are reported but the model does not overlap within one standard deviation at three of five points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index and volume-averaged shear stress are the primary QoIs and are directly linked to the device safety claim.",
      "rationale": "The hemolysis index (HI) and the exposure-time-weighted shear stress integral are the quantities of interest. Both are directly traceable to the device safety claim regarding red blood cell damage. QoI relevance is fully established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry at operating conditions spanning the intended VAD duty range; blood analog fluid used in experiments.",
      "rationale": "Validation used the FDA generic pump geometry which differs from the clinical VAD geometry in impeller blade count and volute profile. Operating conditions partially overlap the VAD duty range but do not cover the high-resistance operating points relevant to clinical use. Relevance gap is significant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance below 1e-6 for all transport equations; round-off error bounded by double-precision arithmetic analysis.",
      "rationale": "Iterative residuals were monitored and reached 1e-5 for velocity and pressure but hemolysis scalar residual stagnated at 1e-3 for two operating points. Round-off error analysis was not performed. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification requirements; simulation execution checklist reviewed by independent analyst; boundary condition setup verified against experimental protocol.",
      "rationale": "No formal user qualification framework was applied. Boundary conditions were set by the primary analyst without independent review. Use error sources including incorrect inlet velocity profile specification have not been systematically evaluated. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis comparing power-law hemolysis model against Giersiepen-Wurzinger and modified Bludszuweit formulations; turbulence model selection justified by literature review for rotating machinery.",
      "rationale": "The Giersiepen-Wurzinger power-law model was selected without comparative evaluation against alternative hemolysis model forms. k-omega SST turbulence model was used based on general rotating machinery guidance but not validated specifically for this pump class. Model form uncertainty is unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters; Monte Carlo sampling with minimum 1000 runs; Sobol sensitivity indices computed for top three inputs.",
      "rationale": "Monte Carlo uncertainty quantification was performed with 500 samples over inlet flow rate, rotational speed, and blood viscosity. Sobol indices were computed for these three parameters. However, hemolysis model coefficients C and alpha are treated as fixed constants despite published variability of 30-50%. Input uncertainty coverage is incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point; sample-to-sample variability characterized; outlier detection applied.",
      "rationale": "The FDA benchmark dataset provides single-laboratory measurements without replicate characterization at the individual operating point level. Inter-laboratory variability data exist in the literature but were not incorporated into the validation comparison. Test sample adequacy is not established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between simulation input parameters and experimental measurement conditions; equivalency demonstrated for all primary boundary conditions including fluid rheology.",
      "rationale": "No formal equivalency mapping document was produced. The blood analog fluid (glycerol-water mixture) used in experiments has Newtonian rheology, while the simulation employs a Newtonian blood model. Non-Newtonian effects at low shear rates in the VAD operating range are not accounted for in either experiment or simulation, but the equivalency of this simplification has not been formally justified."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision-rec-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepted this package for the intended clinical research application on the basis that the hemolysis index predictions are conservative (underestimating hemolysis) and that the Monte Carlo uncertainty bounds encompass the experimental observations within expanded uncertainty intervals. Six credibility factors remain as epistemic gaps at MRL 5, but the team determined that the residual uncertainty is bounded and does not affect the directional safety conclusion for the research use case. A follow-on assessment is recommended before regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
