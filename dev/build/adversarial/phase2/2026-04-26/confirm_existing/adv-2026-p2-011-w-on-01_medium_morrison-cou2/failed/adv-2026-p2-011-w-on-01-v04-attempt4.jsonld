  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-vad-hemolysis-cou2-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite six credibility factors remaining unassessed and three assessed factors falling below required levels, the assessment team determined that the available evidence is sufficient for the intended low-risk exploratory use of this model in the clinical research context described in the package narrative. The decision reflects a risk-informed judgment that the hemolysis index predictions, while carrying unquantified model-form uncertainty, do not directly drive regulatory submission and are used only to rank design alternatives. Formal reassessment is required before any regulatory submission.",
