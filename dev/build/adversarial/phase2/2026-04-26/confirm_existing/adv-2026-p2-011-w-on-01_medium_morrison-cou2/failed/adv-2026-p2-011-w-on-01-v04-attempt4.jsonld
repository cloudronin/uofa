      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine precision for all residuals; floating-point round-off analysis documented.",
      "rationale": "Iterative residual convergence was monitored but no formal floating-point round-off or solver tolerance sensitivity analysis was performed. This factor is flagged as an epistemic gap at MRL 5 and has not been assessed."
    },
