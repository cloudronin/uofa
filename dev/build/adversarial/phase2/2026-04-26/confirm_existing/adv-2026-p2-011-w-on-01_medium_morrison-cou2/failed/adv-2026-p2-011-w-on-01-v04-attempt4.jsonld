      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records, simulation setup checklists, and independent peer review of all simulation inputs documented.",
      "rationale": "No formal user qualification or independent peer review of simulation inputs was conducted. This represents an epistemic gap identified during the MRL 5 assessment; the factor is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic model form uncertainty quantification using multiple turbulence and hemolysis constitutive models; Bayesian model averaging or equivalent approach applied.",
      "rationale": "Only the k-omega SST turbulence model and Giersiepen-Wurzinger hemolysis model were employed. No multi-model comparison or Bayesian model averaging was performed. At MRL 5 this constitutes a critical epistemic gap; the factor is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full probabilistic characterization of all uncertain model inputs; sensitivity indices (Sobol) computed for all parameters contributing more than 1% to output variance.",
      "rationale": "Monte Carlo propagation was performed using uniform distributions on five key parameters. Sobol sensitivity indices were not computed; parameter correlations were ignored. The assessment is incomplete and the factor is recorded as not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability; minimum sample size justified by power analysis; inter-laboratory reproducibility data available.",
      "rationale": "Hemolysis bench experiments were conducted at a single laboratory with n=3 replicates per condition. No power analysis was performed and no inter-laboratory data are available. Factor is not assessed due to insufficient sample characterization."
