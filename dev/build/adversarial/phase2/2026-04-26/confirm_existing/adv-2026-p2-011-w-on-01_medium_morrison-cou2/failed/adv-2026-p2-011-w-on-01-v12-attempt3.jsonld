  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite and traceability to requirements at Gradation 4.",
      "rationale": "The CFD solver is version-controlled and unit-tested, but formal requirements traceability documentation is incomplete. Achieved level falls one gradation below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing with manufactured solutions demonstrating expected convergence rates.",
      "rationale": "Method of manufactured solutions was applied to the Navier-Stokes solver; second-order convergence confirmed. Hemolysis transport sub-model was not independently verified to the same standard."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index computed on three systematically refined meshes with GCI below 5% for primary QoI.",
      "rationale": "GCI study performed on three mesh refinement levels; GCI for hemolysis index is 8.2%, exceeding the 5% acceptance threshold. Spatial discretization error remains a gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds and traceable to calibrated instruments.",
      "rationale": "FDA benchmark experimental conditions are documented; however, blood analogue viscosity uncertainty is reported only as a nominal value without confidence intervals, limiting comparability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rel) computed with experimental uncertainty accounted for; agreement within defined acceptance band.",
      "rationale": "Relative error in normalized index of hemolysis is 14.3%, outside the 10% acceptance band. Experimental scatter partially accounts for discrepancy but does not fully close the gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical endpoints or regulatory submission metrics with documented justification.",
      "rationale": "Normalized index of hemolysis is used as the primary QoI; its mapping to in-vivo hemolysis endpoints relies on empirical power-law models with known biological variability not fully characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry and operating conditions representative of the target VAD COU at the required similarity level.",
      "rationale": "FDA generic pump geometry is used as a surrogate; the actual proprietary VAD impeller geometry differs. Geometric similarity argument is provided but not quantitatively bounded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off, and solver-specific errors quantified and shown to be negligible relative to discretization error.",
      "rationale": "Solver residual convergence is monitored but iterative error is not formally separated from discretization error. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and simulation execution procedures to minimize operator-induced variability.",
      "rationale": "No formal user qualification or simulation execution procedure documentation was provided. Use error is identified as an epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and literature evidence supporting selection of turbulence model and hemolysis constitutive model; alternative model forms evaluated.",
      "rationale": "The SST k-omega turbulence model was selected without comparative evaluation against alternative turbulence closures under VAD-relevant transitional flow regimes. Model form uncertainty is unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; global sensitivity analysis identifies dominant inputs.",
      "rationale": "Monte Carlo UQ was performed on a subset of four input parameters. Remaining inputs, including material constants in the hemolysis power-law model, were held fixed without justification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize biological and measurement variability; statistical power analysis documented.",
      "rationale": "Only a single experimental dataset from the FDA interlaboratory study is available. No independent replication with the target device geometry exists. Sample adequacy is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that simulation input parameters match experimental test conditions within quantified tolerances for all boundary conditions.",
      "rationale": "Inlet velocity profile and outlet pressure boundary conditions are matched to nominal experimental values only. Equivalency of secondary flow features and wall boundary conditions is not demonstrated."
    }
  ],
