      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain inputs (viscosity, density, power-law exponents); Monte Carlo propagation results in bounded output uncertainty.",
      "rationale": "Monte Carlo UQ was performed but only viscosity and density were treated as uncertain; power-law exponents alpha and beta were held fixed at literature point estimates. Full input uncertainty characterisation is incomplete. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterisation of experimental sample variability; minimum sample size justified by power analysis for hemolysis index measurement.",
      "rationale": "Number of experimental replicates and sample size justification are not documented in the evidence package. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient) matched between validation experiment and intended operating envelope; deviations bounded.",
      "rationale": "Equivalency of dimensionless input parameters between the bench validation configuration and the intended clinical VAD operating envelope has not been formally evaluated. Flagged as epistemic gap."
