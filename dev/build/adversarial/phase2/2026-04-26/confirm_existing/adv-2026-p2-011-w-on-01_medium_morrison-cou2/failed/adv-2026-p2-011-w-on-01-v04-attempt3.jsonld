      "name": "PIV velocity field comparison against FDA generic pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-bench-001",
      "type": "ValidationResult",
      "name": "Normalised index of hemolysis bench comparison at three operating points"
    }
  ],
