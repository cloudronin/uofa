  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all active modules; formal SQA plan referencing ISO 9001.",
      "rationale": "The CFD solver is version-controlled and a regression suite exists, but the SQA plan is not formally tied to ISO 9001 and coverage of the hemolysis damage model module is incomplete. Achieved level falls one gradation below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to all governing equations including the hemolysis transport scalar; order-of-accuracy confirmed.",
      "rationale": "Method of manufactured solutions was applied to the Navier-Stokes solver; however, the power-law hemolysis scalar transport equation was not independently verified. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation performed on three systematically refined meshes; GCI reported for all QoIs below 5%.",
      "rationale": "Richardson extrapolation was completed for velocity and pressure QoIs on three mesh levels; GCI for the hemolysis index QoI was not reported separately. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within measurement uncertainty; fluid rheology matched to within 2% across all test points.",
      "rationale": "Boundary conditions were replicated for the three primary operating points; rheological matching was within 5% at the highest flow rate, exceeding the 2% tolerance. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E_rms) reported with combined experimental and numerical uncertainty bands for all primary QoIs.",
      "rationale": "Qualitative agreement plots are provided for velocity fields; quantitative E_rms with full uncertainty bands is not reported for the hemolysis index. Achieved level is 2, two gradations below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical endpoints (normalised index of hemolysis, plasma free haemoglobin); traceability matrix documented.",
      "rationale": "Normalised index of hemolysis is used as the primary QoI with partial traceability to clinical plasma free haemoglobin thresholds; full traceability matrix is absent. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed at in-vivo analogous conditions (flow rate, haematocrit, rotational speed); similarity parameters documented.",
      "rationale": "Validation experiments used phosphate-buffered saline rather than blood analogue fluid; haematocrit effects are not captured. Similarity parameters are partially documented. Achieved level is 3, two gradations below required at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
