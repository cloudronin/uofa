  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, the credibility argument is accepted on the basis of the seven assessed factors and the documented Monte Carlo uncertainty quantification, notwithstanding six unassessed epistemic gaps. The assessment team notes that the intended-use scope has been communicated informally through the clinical research application context; however, no structured Context of Use is declared in this package. Acceptance is conditional on future completion of the six not-assessed factors prior to regulatory submission.",
