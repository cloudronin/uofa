  "signature": "ed25519:d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all turbulence model variants used in hemolysis prediction.",
      "rationale": "OpenFOAM v8 used with git version control and partial regression coverage. Hemolysis scalar transport module lacks dedicated regression tests; achieved Gradation 3 against required Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including hemolysis transport; convergence order confirmed.",
      "rationale": "MMS applied to Navier-Stokes equations; hemolysis power-law transport equation verified via simplified 2-D channel case only. Full 3-D MMS not completed; achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI below 5% for hemolysis index QoI.",
      "rationale": "Three mesh levels used (2.1M, 6.4M, 18.2M cells). GCI for hemolysis index is 8.3%, exceeding the 5% threshold. Spatial order of convergence confirmed at 1.87. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty bounds; inlet velocity profiles and fluid temperature recorded for all test runs.",
      "rationale": "Inlet flow rate controlled to ±0.05 L/min; fluid temperature recorded but not controlled. Rotational speed verified via tachometer. Inlet velocity profile assumed fully developed; not directly measured. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or NMSE) applied to hemolysis index and pressure-head predictions with statistical uncertainty propagation.",
      "rationale": "Hemolysis index predictions within 22% of measured values across five operating points. Pressure-head predictions within 8%. No formal statistical comparison metric applied; visual overlay only for velocity fields. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical decision endpoints; hemolysis index linked to patient safety threshold via published clinical correlation.",
      "rationale": "Hemolysis index (HI) selected as primary QoI. Clinical correlation to plasma-free hemoglobin threshold cited from literature but not formally validated for this device geometry. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating conditions spanning the full COU envelope including edge-case flow rates and hematocrit values.",
      "rationale": "Validation conducted at 3, 5, and 7 L/min at 2500 RPM. COU envelope extends to 2 and 8 L/min; extrapolation at boundary conditions not validated. Hematocrit fixed at 35%; clinical range is 25–50%. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine precision for all QoIs; round-off error bounded via double-precision arithmetic audit.",
      "rationale": "Residual convergence monitored but not formally linked to QoI convergence. Double-precision confirmed but round-off error analysis not performed. Flagged as epistemic gap at MRL 5; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification protocol with demonstrated reproducibility across independent analysts.",
      "rationale": "Single analyst performed all simulations. No cross-analyst reproducibility study conducted. User qualification protocol not documented. Epistemic gap; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis comparing multiple turbulence model forms (SST k-omega, RSM, LES) with quantified impact on hemolysis index prediction.",
      "rationale": "SST k-omega selected based on literature precedent. RSM sensitivity run initiated but not completed. LES not performed due to computational cost. Model form uncertainty not quantified. Epistemic gap; achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo UQ covering all material and boundary condition inputs with Sobol sensitivity indices identifying dominant contributors to hemolysis index variance.",
      "rationale": "Monte Carlo UQ performed with 500 samples across blood viscosity, density, and inlet flow rate. Sobol indices computed for these three inputs only. Hemolysis model coefficients (C, alpha, beta) treated as deterministic. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum n=10 independent experimental replicates per operating point with inter-sample variability characterised.",
      "rationale": "Three replicates per operating point available from Morrison et al. dataset. Inter-sample variability not characterized beyond mean and range. Sample size insufficient for MRL 5 requirements. Epistemic gap; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between experimental test article and simulation geometry with dimensional metrology report.",
      "rationale": "FDA generic pump geometry used as nominal CAD. No dimensional metrology of physical test article performed. Surface roughness not characterized or included in simulation. Equivalency not formally established. Epistemic gap; achieved level 1."
    }
