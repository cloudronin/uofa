  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for simulation must be verified under a documented quality management system with traceability to V&V activities at MRL 5.",
      "rationale": "The CFD solver (OpenFOAM v8) has community-level QA documentation but lacks a formal FDA-recognized quality management system. Version control and regression testing are in place, but independent audit trails are absent. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical algorithms must be verified against analytical solutions or Method of Manufactured Solutions for all governing equations active in the simulation.",
      "rationale": "Method of Manufactured Solutions was applied only to the momentum equations; turbulence model transport equations and the hemolysis scalar transport equation were not independently verified. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence must be demonstrated using at least three systematically refined meshes with Richardson extrapolation and GCI reported for all quantities of interest.",
      "rationale": "Three mesh refinement levels were run and Richardson extrapolation performed for velocity and shear stress. GCI for hemolysis index was estimated but uncertainty bounds are wide (±18%). Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match the operating envelope of the COU within documented tolerance bounds.",
      "rationale": "In-vitro hemolysis experiments were conducted at 2500 RPM and 5 L/min, matching the nominal VAD operating point. However, hematocrit variability and blood analog substitution (bovine blood) introduce systematic differences from clinical conditions. Achieved level 2 against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., RMSE, normalized index of agreement) must be computed for all primary quantities of interest with uncertainty propagation.",
      "rationale": "Hemolysis index predictions deviate from experimental values by 35–60% depending on the power-law damage model coefficients selected. Velocity field agreement is better (RMSE < 12%) but hemolysis is the primary QOI. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest extracted from the model must directly correspond to the clinical or regulatory decision metric.",
      "rationale": "The normalized index of hemolysis (NIH) is computed from the simulation but the mapping from CFD shear stress to clinical hemolysis outcomes relies on empirical correlations with limited generalizability. Achieved level 2 against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted under conditions sufficiently similar to the COU that extrapolation uncertainty is bounded and documented.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which is a surrogate for the actual VAD device. Geometric and operational differences between the generic pump and patient-implanted VADs are not fully characterized. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver stability must be independently characterized for the hemolysis transport equations.",
      "rationale": "Solver convergence was monitored via residual norms for continuity and momentum but no formal characterization of numerical solver error for the hemolysis scalar transport was performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-introduced errors in model setup, boundary condition specification, and post-processing must be assessed and mitigated through documented procedures.",
      "rationale": "No formal use-error assessment or simulation execution protocol was applied. Boundary conditions were set by a single analyst without independent review. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The appropriateness of the chosen turbulence model and hemolysis damage model for the VAD flow regime must be justified with supporting evidence.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature but transitional flow effects in the pump impeller region are not captured. The power-law hemolysis model (Giersiepen et al.) is known to overpredict hemolysis at low shear exposures. No systematic model-form uncertainty quantification was performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of model outputs to uncertain input parameters (viscosity, density, damage model coefficients) must be quantified via global sensitivity analysis.",
      "rationale": "Monte Carlo uncertainty quantification was performed for blood viscosity and density; however, the hemolysis damage model coefficients (C, alpha, beta) were held fixed at literature values without sensitivity analysis. These coefficients dominate output uncertainty. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for biological variability and sample size must be sufficient to estimate population-level hemolysis metrics.",
      "rationale": "Hemolysis experiments used bovine blood from a single supplier batch. No characterization of inter-batch or inter-species variability was performed. Sample size (n=3 replicates) is insufficient for robust statistical comparison at MRL 5. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the simulation must be demonstrated to be equivalent to those present in the physical validation experiments within quantified uncertainty bounds.",
      "rationale": "Rotational speed and flow rate were matched nominally between simulation and experiment, but wall roughness, fluid temperature variation during experiments, and impeller clearance tolerances were not characterized or matched. Equivalency of these parameters was not formally assessed. Flagged as epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the model for its current application in clinical research planning and device design guidance under a low-consequence decision framing. The model is not accepted for direct regulatory submission without remediation of the six unassessed factors. Supplementary peer-reviewed experimental corroboration (DOI 10.1115/1.4041290) provides partial confidence in the velocity field predictions. Acceptance is conditional on the model not being used for absolute hemolysis threshold determinations in a Class III regulatory pathway without further validation.",
