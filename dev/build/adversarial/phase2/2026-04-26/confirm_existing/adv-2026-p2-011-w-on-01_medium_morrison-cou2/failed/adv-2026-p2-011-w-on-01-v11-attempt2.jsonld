      "name": "CFD hemolysis prediction vs. in-vitro benchmark — FDA pump at VAD operating conditions"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-val-result-002",
      "type": "ValidationResult",
      "name": "Velocity field comparison PIV vs. CFD — FDA generic centrifugal pump"
    }
  ],
