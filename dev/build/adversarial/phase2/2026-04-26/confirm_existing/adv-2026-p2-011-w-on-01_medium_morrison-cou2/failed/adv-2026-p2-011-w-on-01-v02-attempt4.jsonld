  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD Hemolysis CFD Credibility Assessment (Minimal Profile)",
  "description": "This model has been applied in clinical research settings to predict hemolysis indices for centrifugal blood pumps operating under ventricular assist device conditions. The CFD hemolysis model targets the FDA generic centrifugal pump geometry and was exercised across a range of operating points representative of implanted VAD use. Monte Carlo uncertainty quantification was performed across all 13 ASME V&V 40 credibility factors. Seven factors were formally assessed; six remain flagged as epistemic gaps at Model Risk Level 5. Despite these gaps, the overall credibility argument is judged sufficient for the stated low-risk regulatory submission context. No structured Context of Use record is attached to this package; the intended-use scope is conveyed solely through the narrative above.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-requirement-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-cfd-hemolysis-absolute-prediction-001",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset-001",
    "https://uofa.net/synth/data/fda-pump-hemolysis-benchmark-dataset-002"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-val-result-001",
      "type": "ValidationResult",
      "name": "CFD hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-val-result-002",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic validation across five operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043951",
