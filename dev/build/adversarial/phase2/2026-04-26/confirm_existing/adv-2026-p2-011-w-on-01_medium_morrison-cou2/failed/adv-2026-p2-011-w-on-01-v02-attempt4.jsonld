  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e1d849b056f3a1cc72e8d4019bfa56238de7041c9b5f2a83e6d1047c9e",
  "signature": "ed25519:b1d2e3f4a5c6b7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, regression testing, and formal QA procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (OpenFOAM v8) has community-level QA documentation but lacks formal FDA-recognized software validation records. Version control is in place; regression test suite covers only 40% of relevant physics modules. Achieved level 2 falls below the required level 4 for Class III device submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions (MMS) verification must demonstrate convergence consistent with nominal solver order for all governing equations including the hemolysis transport scalar.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver and confirmed second-order spatial convergence. The hemolysis scalar transport equation was not independently verified via MMS; only informal spot-checks were conducted. This gap reduces the achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all quantities of interest using at least three systematically refined meshes; GCI must be below 5% for hemolysis index predictions.",
      "rationale": "A three-level mesh refinement study was performed (coarse 2.1M, medium 5.8M, fine 14.2M cells). GCI for pressure rise was 2.1%; GCI for hemolysis index was 8.7%, exceeding the 5% threshold. Richardson extrapolation was applied but uncertainty bounds remain wider than required at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient traceability to confirm correspondence with the simulated boundary conditions, including fluid properties, rotational speed, and inlet flow rates.",
      "rationale": "FDA pump experimental data were collected at nominal conditions; however, fluid temperature during experiments varied by ±3°C and was not reported per test run, introducing uncertainty in viscosity. Rotational speed was logged with ±15 RPM tolerance. These undocumented variations reduce correspondence confidence to level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, validation uncertainty) must be computed and compared against acceptance thresholds for all primary quantities of interest including hemolysis index and pressure-flow characteristics.",
      "rationale": "Pressure-flow curve agreement is within 6% across five operating points. Hemolysis index predictions deviate by 35–52% from experimental measurements, well outside the ±15% acceptance threshold. Validation uncertainty analysis was performed via Monte Carlo but does not close the gap. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest predicted by the model must be directly relevant to the clinical decision being supported, with documented traceability from model outputs to patient safety endpoints.",
      "rationale": "The hemolysis index (normalized index of hemolysis, NIH) is the established regulatory metric for blood pump biocompatibility assessment and is directly linked to patient safety through plasma free hemoglobin thresholds. Traceability from CFD-predicted NIH to the regulatory submission endpoint is documented. Achieved level meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use test articles, operating conditions, and fluid analogs that are sufficiently representative of the intended clinical use conditions to support extrapolation of validation evidence.",
      "rationale": "Validation was performed on the FDA generic pump geometry rather than the specific VAD device under development. Bovine blood analog was used in experiments while the clinical device operates with human blood. These representativeness gaps reduce the relevance of validation activities to level 2 for MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence errors and floating-point round-off contributions must be quantified and shown to be negligible relative to discretization error for all quantities of interest.",
      "rationale": "Iterative convergence was monitored via residual norms (target 1e-6) but no formal quantification of solver error contribution to hemolysis index uncertainty was performed. Round-off error analysis was not conducted. This factor is flagged as an epistemic gap at MRL 5 and remains not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential errors introduced by analyst choices (meshing decisions, boundary condition specification, turbulence model selection) must be identified, bounded, and shown not to materially affect the credibility conclusion.",
      "rationale": "No formal use-error analysis was conducted. Turbulence model selection (SST k-omega) was based on prior literature but sensitivity to this choice was not quantified in the context of hemolysis prediction. Analyst-introduced variability represents an unquantified epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The mathematical form of the hemolysis model (power-law damage accumulation) must be justified against alternative model forms, with sensitivity of predictions to model-form assumptions quantified.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was applied without comparison to alternative formulations (e.g., Arora strain-based model, Faghih-Sharp model). Model-form uncertainty is a recognized dominant source of prediction error for hemolysis CFD but was not formally assessed. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters (fluid viscosity, density, hemolysis model coefficients, boundary conditions) must be characterized and propagated through the model to produce output uncertainty bounds.",
      "rationale": "Monte Carlo uncertainty propagation was performed across fluid viscosity (±5%), density (±1%), and inlet flow rate (±3%). Hemolysis model coefficients (C, alpha, beta in power-law) were treated as fixed at literature values without uncertainty characterization, representing a significant gap. Partial UQ reduces achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The number and selection of experimental test samples used for validation must be sufficient to characterize measurement variability and support statistical comparison with model predictions.",
      "rationale": "FDA pump hemolysis data from a single laboratory source were used. Inter-laboratory variability in hemolysis measurement is well-documented but was not characterized. Sample size for hemolysis measurements (n=3 per operating point) is insufficient to establish robust statistical bounds. Factor not-assessed at required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The degree of equivalence between input parameters used in validation simulations and those representative of the intended clinical use must be formally assessed and documented.",
      "rationale": "No formal equivalency analysis was performed between the validation simulation inputs (FDA generic pump, bovine blood, in-vitro conditions) and the intended clinical use parameters (patient-specific VAD, human blood, in-vivo hemodynamics). This gap is an identified epistemic limitation at MRL 5 that remains unresolved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite seven of thirteen credibility factors achieving levels below their required thresholds and six factors remaining not-assessed, the overall credibility package is accepted for the low-assurance regulatory submission pathway. The assessment team judges that the Monte Carlo uncertainty quantification, combined with the conservative operating envelope and the existing body of FDA pump benchmark literature, provides sufficient aggregate evidence for the intended submission scope. This acceptance is conditional on the submitting organization maintaining awareness that the intended-use scope is described only in narrative form within this package; no structured Context of Use has been formally registered. The absence of a structured COU is acknowledged as a documentation gap that does not, in the team's judgment, invalidate the credibility argument for this specific low-risk submission tier.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
