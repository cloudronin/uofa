  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "This model has been applied in clinical research contexts involving ventricular assist device hemolysis prediction. The CFD hemolysis model for the FDA generic centrifugal blood pump was assessed under a Minimal profile submission. All 13 credibility factors have been evaluated; seven were formally assessed and six were flagged as epistemic gaps at Model Risk Level 5. Monte Carlo uncertainty quantification was performed across operating conditions representative of Class III VAD use. Despite gaps in several credibility factors, the overall evidence package was accepted under the Minimal profile requirements. The intended-use scope is conveyed through the narrative record and the binding to the regulatory submission requirement rather than through a structured ContextOfUse object.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-class3",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-vad-cou2",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-fda-centrifugal-pump",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental",
    "https://uofa.net/synth/data/hemolysis-bench-measurements-vad"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-level-vr1",
      "type": "ValidationResult",
      "name": "Absolute hemolysis level validation against FDA pump bench data"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-vr2",
      "type": "ValidationResult",
      "name": "Velocity field comparison against PIV measurements in centrifugal pump"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041290",
