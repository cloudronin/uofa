  "hash": "sha256:a3f1c2e7b904d56f8e2a1d3c7b5f9e4a2d6c8b1f3e5a7d9c2b4f6e8a1d3c5f7",
  "signature": "ed25519:b2d4f6a8c1e3b5d7f9a2c4e6b8d1f3a5c7e9b2d4f6a8c1e3b5d7f9a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all active modules; independent code review completed.",
      "rationale": "The CFD solver is version-controlled and unit tests exist for core modules; however, independent third-party review was not completed and integration test coverage is partial. Achieved level falls one gradation below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical flows demonstrate expected convergence rates for all governing equations used in the hemolysis simulation.",
      "rationale": "Order-of-accuracy verification was performed on Poiseuille and lid-driven cavity benchmarks confirming second-order spatial convergence. Verification of the hemolysis source term transport equation was limited to first-order checks only, leaving a gap relative to the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis demonstrates discretization error below 5% for all quantities of interest on the production mesh.",
      "rationale": "Three-level mesh refinement study was conducted; GCI for pressure rise and torque met the 5% threshold. GCI for local hemolysis index exceeded 12% in the high-shear impeller region, indicating insufficient mesh resolution for the primary QoI at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions are documented with uncertainty bounds and match the simulated operating point within stated tolerances.",
      "rationale": "Flow rate and rotational speed were logged during experiments; however, inlet velocity profile and blood viscosity were not measured directly and were inferred from nominal values. Uncertainty in inlet conditions propagates to hemolysis predictions and the achieved documentation level is insufficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_avg) computed with uncertainty propagation for all primary QoIs; metric satisfies acceptance threshold defined prior to comparison.",
      "rationale": "Pressure-head and torque predictions agree with experimental data within 8% across five operating points. Absolute hemolysis index predictions show 35% mean deviation relative to bench measurements, exceeding the pre-defined 20% acceptance threshold. The output comparison factor is therefore below the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation are directly traceable to the clinical decision criterion (absolute hemolysis level) without surrogate substitution.",
      "rationale": "Validation was performed against normalized index of hemolysis (NIH) rather than absolute plasma free hemoglobin concentration, which is the clinically relevant metric. The surrogate QoI reduces direct traceability to the device decision criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments were conducted at geometric, kinematic, and dynamic conditions that span the intended VAD operating envelope.",
      "rationale": "Validation experiments used the FDA generic pump geometry at two operating points. The VAD operating envelope spans a wider range of flow rates and hematocrit levels than tested. Dynamic similarity in terms of Reynolds and Stokes numbers was partially maintained but not across the full envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence tolerances are documented and residual histories confirm solver convergence to levels that do not affect QoI predictions beyond 1%.",
      "rationale": "Iterative solver residuals were monitored but a formal assessment of solver error contribution to QoI uncertainty was not conducted. This factor is flagged as an epistemic gap at MRL 5 and has not been formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation protocol with peer review; evidence that analysts followed the protocol and deviations were recorded and resolved.",
      "rationale": "No formal use-error assessment was performed. Simulation setup was conducted by a single analyst without independent protocol review. This represents an epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis across candidate turbulence and hemolysis constitutive models; model-form uncertainty quantified and propagated to QoI predictions.",
      "rationale": "The k-omega SST turbulence model and the power-law hemolysis model were selected without comparative evaluation of alternative model forms. Model-form uncertainty was not quantified. This is a critical epistemic gap given the sensitivity of hemolysis predictions to turbulence closure."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters are assigned probability distributions based on measurement data; Monte Carlo propagation yields QoI uncertainty intervals reported at 95% confidence.",
      "rationale": "Monte Carlo uncertainty quantification was performed for four geometric tolerance parameters. Blood viscosity, hematocrit, and hemolysis model coefficients were treated as deterministic at nominal values. Incomplete input uncertainty characterization leaves this factor below the required level and not formally closed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size is sufficient to characterize biological variability; statistical power analysis documented prior to testing.",
      "rationale": "Hemolysis bench experiments used a single bovine blood pool per operating point with no replication across donors. Biological variability in red cell fragility was not characterized. No power analysis was performed. This factor is an epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between experimental and simulation input parameters is demonstrated quantitatively; any substitutions are justified with sensitivity analysis.",
      "rationale": "Bovine blood was used in experiments while human blood rheology was assumed in the simulation. The substitution was not supported by a sensitivity analysis demonstrating equivalency of hemolysis predictions. This equivalency gap is unresolved and flagged as an epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl5-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile submission, the evidence package is accepted on the basis that the seven assessed credibility factors are documented with quantitative rationale and the six unassessed factors are explicitly flagged as epistemic gaps with planned remediation paths. The Monte Carlo uncertainty quantification for geometric inputs and the multi-point validation against FDA pump data provide sufficient evidence for the current submission stage. Acceptance is conditional on gap closure prior to pivotal regulatory submission.",
