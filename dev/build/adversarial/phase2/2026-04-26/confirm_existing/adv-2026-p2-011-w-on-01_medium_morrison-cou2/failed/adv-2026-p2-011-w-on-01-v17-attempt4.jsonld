    }
  ],
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be verified against recognized benchmark cases with documented version control and regression testing at Gradation 4.",
      "rationale": "OpenFOAM v9 was used with documented version control. Regression tests cover 14 canonical cases. However, formal software quality plan does not meet Gradation 4 requirements; independent third-party audit was not completed. Achieved level falls one gradation below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must demonstrate convergence at expected order of accuracy for all governing equations.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver and demonstrated second-order spatial convergence. The hemolysis transport scalar equation was verified separately but power-law damage model implementation was not independently verified against a manufactured solution. Gradation 4 requires full-system MMS coverage."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must be used to quantify discretization error with GCI below 5% for all quantities of interest.",
      "rationale": "Three-level mesh refinement study was conducted. GCI values for pressure rise and flow rate were below 3%. GCI for hemolysis index at blade trailing edge exceeded 8% on the medium mesh, and the fine mesh GCI was 6.2%, marginally above the 5% threshold. Discretization error in hemolysis QOI remains above required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match intended operating conditions within documented tolerances; fluid properties, rotational speed, and flow rate must be characterized with uncertainty bounds.",
      "rationale": "FDA benchmark experiments used bovine blood at 37 degrees C with hematocrit 33 plus or minus 2 percent. VAD clinical operating conditions involve human blood with variable hematocrit 28 to 42 percent. Rotational speed tolerance in experiments was plus or minus 10 RPM versus plus or minus 50 RPM in clinical use. Significant gap between test and intended conditions reduces achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E-metric or normalized RMS error) must be computed with uncertainty bounds for all primary quantities of interest.",
      "rationale": "Normalized hemolysis index error was 18.4% against FDA benchmark mean, within the experimental scatter of plus or minus 22%. Pressure-flow curve agreement was within 5%. E-metric computed per ASME V&V 20 for hemolysis QOI shows model within experimental uncertainty band at 4 of 6 operating points. Two high-shear operating points fall outside uncertainty band, limiting achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must be directly linked to the clinical decision endpoint; absolute hemolysis index must be the primary QOI with documented clinical relevance threshold.",
      "rationale": "Hemolysis index (HI) is the primary QOI and maps directly to plasma free hemoglobin concentration, a recognized clinical biomarker. However, the model predicts volume-averaged HI rather than peak local HI, which is the more clinically relevant predictor of erythrocyte damage in high-shear zones near the blade tip. This gap in QOI specificity reduces the achieved level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometries, flow regimes, and blood analogs representative of the intended Class III VAD device at clinical operating conditions.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which is a simplified geometry not representative of the specific VAD device geometry. Blood analog (bovine blood) differs from human blood rheology at low shear rates. Operating range covered 2400 to 3600 RPM; clinical VAD operates at 2800 to 4200 RPM. The extrapolation beyond the validated operating range and geometric dissimilarity result in a large gap between achieved and required levels."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error must be quantified and demonstrated to be negligible relative to discretization error for all quantities of interest.",
      "rationale": "Iterative convergence was monitored via residual norms but formal numerical solver error quantification per ASME V&V 20 was not performed. Residuals dropped below 1e-5 for continuity and momentum but hemolysis scalar residuals were not separately tracked. This factor is flagged as an epistemic gap at MRL 5 and is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification requirements and simulation execution protocols must be in place to prevent operator-induced errors in boundary condition specification and post-processing.",
      "rationale": "No formal use error assessment was conducted. Simulation protocols exist as internal laboratory documentation but have not been reviewed against a formal human factors framework. Boundary condition specification errors were identified in two early simulation runs and corrected, but these events were not formally documented as use error incidents. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty must be quantified by comparing predictions from multiple physically distinct model forms (e.g., power-law vs. strain-based hemolysis models) with documented sensitivity analysis.",
      "rationale": "Only the Giersiepen-Wurzinger power-law damage model was used. Alternative model forms including the Arora strain-based model and the modified Bludszuweit model were not implemented or compared. Model form uncertainty is therefore unquantified. At MRL 5 this represents a critical epistemic gap. Not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters must be characterized with probability distributions; global sensitivity analysis must identify dominant uncertain inputs.",
      "rationale": "Monte Carlo UQ was performed for three input parameters (viscosity, hematocrit, rotational speed) but the hemolysis model coefficients C, alpha, and beta were treated as fixed constants despite known literature variability of plus or minus 30 percent. Global sensitivity analysis was not performed. Input uncertainty characterization is incomplete. Not assessed at required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be characterized for biological variability; minimum sample size must be justified by statistical power analysis for hemolysis measurement.",
      "rationale": "FDA benchmark dataset used n=3 independent experimental runs per operating point. No statistical power analysis was performed to justify sample size. Biological variability in bovine blood hemolysis susceptibility was not characterized. For MRL 5 Class III device assessment, this sample size is insufficient to characterize population-level variability. Not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental and simulation input parameters must be demonstrated quantitatively; any non-equivalencies must be assessed for their impact on validation conclusions.",
      "rationale": "Inlet velocity profiles in simulation were specified as uniform; experimental inlet conditions were not characterized and may include swirl components from the upstream reservoir. Blood viscosity was modeled with the Carreau-Yasuda non-Newtonian model but experimental viscosity was measured only at a single shear rate. Equivalency of input parameters between experiment and simulation was not formally assessed. Flagged as epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-minimal-profile-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile submission pathway, the assessment team determined that sufficient evidence exists to accept this model for the stated purpose. Seven of thirteen credibility factors were formally assessed; the remaining six are acknowledged as epistemic gaps documented in the assessment record. The Monte Carlo UQ results demonstrate that hemolysis index predictions remain within experimental uncertainty at the primary operating point of 3200 RPM and 5 L/min. The team acknowledges that this model has been applied in clinical research contexts where its predictive capability has been qualitatively corroborated by clinical outcomes data. The Minimal profile does not require a structured Context of Use record; the intended-use scope is understood from the clinical research deployment context described in the package narrative. Acceptance is conditional on re-assessment under the Complete profile prior to any formal regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
