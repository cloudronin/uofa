    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors achieved levels at or above required thresholds for MRL 5. Six factors were scoped out as epistemic gaps with documented justification. Monte Carlo UQ confirmed bounded uncertainty across QoIs. The assessment team accepted the model for the described VAD hemolysis prediction use under the Minimal profile, noting that a structured Context of Use has not been formally encoded.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented; version control, regression testing, and independent code review completed for CFD solver and hemolysis sub-model.",
      "rationale": "ANSYS Fluent 2022R2 used with documented SQA plan. Regression test suite passed. Independent review of hemolysis power-law UDF completed by a third-party engineer."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-channel flow demonstrate convergence consistent with formal second-order scheme.",
      "rationale": "Richardson extrapolation on three systematically refined meshes of a rotating annular channel confirmed second-order spatial convergence. Temporal convergence verified for transient rotor passage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI; GCI < 5% on fine mesh.",
      "rationale": "Three-level GCI study on 4.2M, 9.8M, and 21.6M cell meshes yielded GCI of 3.1% for normalised hemolysis index on the fine mesh. Asymptotic range confirmed (GCI ratio 1.02)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) match simulation inputs within stated uncertainty bands.",
      "rationale": "FDA benchmark flow conditions (2.5 L/min, 3500 RPM, bovine blood surrogate) replicated in simulation. Fluid viscosity uncertainty ±8% propagated through Monte Carlo ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalised index of hemolysis (NIH) within 15% of experimental mean across all tested operating points; metric of interest error quantified with confidence intervals.",
      "rationale": "NIH predictions fell within 11% of experimental mean across five operating points. 95% CI from Monte Carlo ensemble bracketed experimental values at four of five points. Systematic over-prediction at high-shear impeller tip addressed in uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, shear stress distribution, residence time) are directly linked to clinical hemolysis risk and regulatory submission requirements.",
      "rationale": "NIH is the FDA-accepted metric for blood pump hemolysis evaluation. Shear stress and residence time are mechanistic intermediates in the power-law damage model. Traceability to ISO 10993-4 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic pump geometry and fluid analogue used in the intended application scenario.",
      "rationale": "Validation dataset sourced from FDA CDRH interlaboratory study using identical pump geometry. Fluid analogue (glycerol-water) properties matched to bovine blood rheology. Geometry fidelity confirmed by CT scan comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
