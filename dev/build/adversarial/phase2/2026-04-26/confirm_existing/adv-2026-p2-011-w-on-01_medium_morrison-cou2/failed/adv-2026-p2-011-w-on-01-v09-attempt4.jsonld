  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD Hemolysis CFD Credibility Assessment (Minimal Profile)",
  "description": "This unit of assurance documents a credibility assessment of a CFD hemolysis prediction model for the FDA generic centrifugal blood pump. The model has been applied in clinical research settings to evaluate absolute hemolysis levels under ventricular assist device operating conditions. Model Risk Level 5 drives strict credibility requirements; Monte Carlo uncertainty quantification was performed. Seven of thirteen credibility factors were assessed, all with achieved levels below required levels; six factors remain flagged as epistemic gaps. The assessment team determined that, notwithstanding the gaps, the evidence package meets the threshold for acceptance under the minimal profile rules. No structured context-of-use object is provided; intended-use scope is conveyed only through this narrative.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-claim-001",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset",
    "https://uofa.net/synth/data/fda-pump-hemolysis-bench-dataset"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-global-index-001",
      "type": "ValidationResult",
      "name": "Global hemolysis index comparison against FDA pump bench data"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv-001",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements at design point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034823",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-biofluid-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e1d09b456f8e2a1c3d7b5e9f0412c6a8d2e4b7f1c3a5d9e0b2f4c6a8d1",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal software quality plan with traceability, version control, and independent review required at MRL 5.",
      "rationale": "Version control and unit testing are in place; however, independent third-party review of the CFD solver and hemolysis sub-model has not been completed. Achieved level falls short of the MRL 5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Rigorous order-of-accuracy studies and method-of-manufactured-solutions verification required at MRL 5.",
      "rationale": "Order-of-accuracy studies were performed on canonical pipe flow; method-of-manufactured-solutions has not been applied to the rotating-frame hemolysis formulation. Gap remains at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation with GCI reported for all primary QoIs at MRL 5.",
      "rationale": "Richardson extrapolation and GCI were computed for velocity and pressure. Hemolysis index GCI exceeds 5% on the finest mesh pair, indicating residual discretization uncertainty above the required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full characterisation of experimental boundary conditions including fluid rheology, temperature, and inlet turbulence intensity required.",
      "rationale": "Inlet flow rate and outlet pressure were matched; fluid temperature variation and inlet turbulence intensity were not independently measured during hemolysis bench tests, reducing confidence in boundary condition fidelity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric with uncertainty bands and statistical significance test required at MRL 5.",
      "rationale": "Mean absolute error and RMSE were reported for the global hemolysis index; however, uncertainty bands on the experimental reference values were not propagated into the comparison metric, limiting the statistical validity of the comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Direct mapping from model QoIs to clinical decision endpoints must be demonstrated.",
      "rationale": "The normalised index of hemolysis (NIH) is directly relevant to VAD safety labelling. Mapping is documented but does not extend to patient-specific haematocrit variability, leaving a partial gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the full operating envelope of the intended clinical use.",
      "rationale": "Validation was performed at two operating points (design and off-design); the clinical research application spans a broader range of flow rates and haematocrit values not covered by the available experimental dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver-specific numerical diffusion must be quantified.",
      "rationale": "Solver error quantification beyond residual monitoring was not performed. This factor is flagged as an epistemic gap at MRL 5 and has not been assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Structured user-error analysis including sensitivity to analyst choices in meshing, turbulence model selection, and post-processing required.",
      "rationale": "No formal use-error analysis was conducted. Analyst-to-analyst variability in hemolysis model parameterisation is a known source of uncertainty that remains unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of model form uncertainty including turbulence closure and hemolysis power-law exponent must be documented.",
      "rationale": "Model form uncertainty associated with the choice of k-omega SST turbulence closure and the Giersiepen hemolysis power law has not been formally characterised. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probabilistic characterisation of all material and boundary input parameters with sensitivity ranking required.",
      "rationale": "Monte Carlo UQ was initiated but input probability distributions for blood viscosity and pump geometry tolerances were not fully characterised. Assessment is incomplete and the factor is flagged as a gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterisation of experimental sample variability including inter-sample and inter-laboratory reproducibility required.",
      "rationale": "Hemolysis bench tests were conducted at a single laboratory with a single blood analogue fluid. Inter-laboratory reproducibility and sample-to-sample variability have not been assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument mapping experimental input parameters to computational inputs must be documented and reviewed.",
      "rationale": "No formal equivalency mapping between the blood analogue fluid properties used in bench testing and the computational fluid properties has been documented. This factor remains an unaddressed epistemic gap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the minimal profile rules, the seven assessed credibility factors provide sufficient structured evidence to support acceptance for the stated low-risk application scope. The six unassessed factors are acknowledged as epistemic gaps; their absence is consistent with the minimal profile threshold and the narrative description of the intended clinical research use. The assessment team accepted the package with the understanding that a complete-profile reassessment would be required prior to any regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
