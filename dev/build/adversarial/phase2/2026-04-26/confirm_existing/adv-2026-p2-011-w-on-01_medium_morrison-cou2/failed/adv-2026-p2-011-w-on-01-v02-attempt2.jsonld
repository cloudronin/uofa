  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all relevant physics modules; independent code review completed.",
      "rationale": "The CFD solver is version-controlled and regression tests cover core flow modules; however, the hemolysis damage model sub-routine lacks an independent review record, leaving the achieved level one step below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of Manufactured Solutions (MMS) applied to all governing equations including scalar transport for hemolysis index; order-of-accuracy confirmed.",
      "rationale": "MMS was applied to the Navier-Stokes solver and confirmed second-order spatial accuracy; the power-law hemolysis scalar transport equation was not subjected to MMS, limiting the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes with GCI reported for hemolysis index QoI; time-step sensitivity demonstrated.",
      "rationale": "Three mesh levels were studied and Richardson extrapolation was performed for pressure rise and shear stress; GCI for the hemolysis index specifically was not separately reported, and time-step sensitivity used only two time-step sizes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions reproduced within ±2% of target flow rate and rotational speed; blood analog rheology characterised and reported.",
      "rationale": "Flow rate and rotational speed were matched within ±3% of FDA target conditions; the blood analog viscosity was measured but temperature-dependent rheology corrections were not applied, reducing fidelity of test condition matching."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or U95) computed for hemolysis index with experimental uncertainty bounds reported; statistical significance assessed.",
      "rationale": "Predicted hemolysis index values were compared to FDA experimental data, but experimental measurement uncertainty was not formally propagated; the comparison relied on point estimates without confidence intervals, limiting the achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated direct mapping between model QoIs (normalised index of hemolysis, NIH) and clinical decision metric; sensitivity analysis confirms QoI dominance.",
      "rationale": "NIH was selected as the primary QoI with documented linkage to device labelling thresholds; however, a formal sensitivity analysis confirming NIH dominance over secondary QoIs such as shear exposure time was not completed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the identical FDA generic pump geometry under VAD operating envelope; patient-representative hematocrit range covered.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry at the nominal VAD operating point; extended hematocrit range (35–45%) was not covered in the validation dataset, reducing relevance for the full patient population."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine precision for all residuals including hemolysis scalar; floating-point round-off analysis documented.",
      "rationale": "Residual convergence was monitored but no formal floating-point or iterative error budget was constructed; this factor is flagged as an epistemic gap at MRL 5 and was not formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented analyst training records, simulation execution checklist, and independent post-processing verification for all submitted simulation runs.",
      "rationale": "No formal use-error mitigation procedure was documented for this assessment; analyst qualification records were not submitted as part of the credibility package, constituting an epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence closure and hemolysis constitutive model alternatives; Bayesian model selection or equivalent framework applied.",
      "rationale": "The power-law Giersiepen-Wurzinger hemolysis model was adopted without systematic comparison to alternative constitutive models (e.g., Arora, Faghih-Sharp); turbulence closure sensitivity was noted but not formally quantified, leaving this a significant epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full probabilistic characterisation of all material and boundary condition inputs with Monte Carlo propagation reporting 95th-percentile output uncertainty.",
      "rationale": "Monte Carlo UQ was performed for geometric tolerances and inlet flow rate; blood viscosity coefficients and hemolysis model exponents were treated as deterministic, leaving the input uncertainty characterisation incomplete for MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum n=5 independent experimental replicates per operating condition with inter-sample variability reported; lot-to-lot blood analog variability characterised.",
      "rationale": "Only two experimental replicates were available from the FDA dataset for the primary operating condition; inter-sample variability and blood analog lot-to-lot effects were not characterised, making this an unresolved epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and COU inputs documented; dimensionless similarity parameters verified to be within acceptable tolerance bands.",
      "rationale": "No formal equivalency mapping was constructed between the FDA bench-test conditions and the intended VAD clinical operating envelope; Reynolds and Womersley number matching was not explicitly verified, leaving this factor unaddressed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-minimal-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, the credibility package is accepted on the basis that the seven assessed factors demonstrate adequate evidence for the primary hemolysis prediction claim, and the six unassessed factors are documented as known epistemic gaps with a committed remediation roadmap. The Monte Carlo uncertainty quantification provides sufficient coverage of geometric and flow-rate variability. The decision team acknowledges that the intended-use scope is described narratively (clinical research application to Class III VAD devices at MRL 5) but is not encoded in a structured Context of Use record; this is permissible under ProfileMinimal and does not constitute a rejection criterion for this submission stage.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
