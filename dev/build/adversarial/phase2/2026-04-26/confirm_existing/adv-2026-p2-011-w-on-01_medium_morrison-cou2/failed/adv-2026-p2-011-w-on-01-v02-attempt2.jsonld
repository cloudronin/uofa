  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "This model has been applied in clinical research settings to predict hemolysis in centrifugal blood pumps under ventricular assist device operating conditions. The CFD hemolysis model targets the FDA generic centrifugal blood pump geometry and was evaluated at Model Risk Level 5 for Class III device use. All 13 ASME V&V 40 credibility factors are addressed; seven were formally assessed and six were flagged as epistemic gaps. Monte Carlo uncertainty quantification was performed. Despite factor shortfalls at MRL 5, the overall credibility package is accepted under the Minimal profile, which does not mandate a structured Context of Use record. The intended-use scope is conveyed only through this narrative description and the associated regulatory submission documents referenced externally.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-class3",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-fda-centrifugal-pump",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/monte-carlo-uq-ensemble"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison-01",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison against FDA experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-rise-validation-02",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation across operating envelope"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041150",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-sim-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
