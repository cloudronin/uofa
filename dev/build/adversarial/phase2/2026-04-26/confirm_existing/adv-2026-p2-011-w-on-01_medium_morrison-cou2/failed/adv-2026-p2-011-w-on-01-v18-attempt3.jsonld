      "id": "https://uofa.net/synth/validation/vr-hemolysis-global-001",
      "type": "ValidationResult",
      "name": "Global hemolysis index comparison — CFD vs. experimental bench data"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv-002",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements at design operating point"
    }
  ],
