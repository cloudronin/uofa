  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all relevant flow regimes; independent code review completed.",
      "rationale": "The CFD solver is under version control and a regression test suite exists, but independent third-party code review has not been completed. Achieved level falls one gradation below requirement at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for all governing equation terms; documented convergence rates within 5% of theoretical.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the scalar hemolysis transport equation. Convergence rates for momentum equations are within tolerance; hemolysis transport verification is incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all quantities of interest; GCI below 5% on fine grid.",
      "rationale": "Grid convergence index was computed on three mesh levels for velocity and pressure. For hemolysis index, GCI on the fine mesh is 8.3%, exceeding the 5% threshold. Discretization error is partially characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within stated measurement uncertainty; fluid properties matched within 2%.",
      "rationale": "Inlet velocity profiles from PIV were applied as boundary conditions, but fluid temperature during bench testing drifted ±3°C, introducing viscosity variation of approximately 4%, slightly exceeding the 2% matching criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty) computed for all QoIs; statistical comparison accounts for experimental and numerical uncertainty.",
      "rationale": "Qualitative flow field agreement is demonstrated. Quantitative validation metric E% was computed only for the global hemolysis index; local stress distribution comparison remains qualitative. Validation uncertainty budget is incomplete for secondary QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical risk endpoints; traceability from model output to device failure mode documented.",
      "rationale": "Global hemolysis index is the primary QoI and is directly linked to plasma free hemoglobin thresholds used in regulatory guidance. Traceability to sub-lethal shear stress failure modes is documented but relies on a simplified power-law damage model not validated at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating conditions spanning the full COU envelope; interpolation within validated range demonstrated.",
      "rationale": "Validation experiments cover three of five intended operating points. Two high-flow operating conditions representative of exercise demand were not included in the experimental campaign, leaving extrapolation uncertainty uncharacterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; round-off and truncation error bounds estimated for all QoIs.",
      "rationale": "Iterative residual targets are specified but no formal bound on round-off or truncation error has been derived. This factor is flagged as an epistemic gap at MRL 5 and was not assessed in this submission cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification requirements; simulation run by at least two independent analysts with results compared.",
      "rationale": "User qualification records exist for the primary analyst but independent parallel simulation by a second qualified analyst was not performed. Use error assessment is an identified epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of alternative model forms (e.g., turbulence closure, hemolysis damage model) with sensitivity analysis; preferred form justified.",
      "rationale": "The k-omega SST turbulence model and Giersiepen-Wurzinger hemolysis model were selected based on prior literature without formal alternative model comparison. Model form uncertainty is unquantified and constitutes a critical epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full probabilistic characterization of all model inputs; global sensitivity analysis identifying dominant input contributors to QoI variance.",
      "rationale": "Monte Carlo uncertainty propagation was performed for blood viscosity and pump speed. Global sensitivity analysis via Sobol indices was not completed. Input characterization for wall roughness and inlet turbulence intensity is based on nominal values without uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification based on statistical power analysis; inter-sample variability characterized and propagated to validation uncertainty.",
      "rationale": "Hemolysis bench tests were conducted on n=3 pump samples. No statistical power analysis was performed to justify sample size, and inter-unit variability was not propagated into the validation uncertainty budget. This is flagged as an epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that validation experiment input parameters are representative of COU inputs; any deviations quantified and their impact on QoI bounded.",
      "rationale": "Validation experiments used a blood analog fluid (glycerol-water) rather than porcine blood. The equivalency argument for non-Newtonian effects at high shear rates has not been formally documented. This gap is noted but not resolved in the current submission."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite six credibility factors remaining unassessed and three assessed factors falling below required levels, the credibility assessment team determined that the evidence package is sufficient for the intended low-risk regulatory submission pathway. The model has been applied in clinical research contexts and the global hemolysis index predictions are within acceptable bounds for the submission. Residual gaps are acknowledged and will be addressed in a subsequent assessment cycle prior to any expanded clinical use. The decision to accept reflects the low assurance level declared for this submission and the limited regulatory claim scope.",
