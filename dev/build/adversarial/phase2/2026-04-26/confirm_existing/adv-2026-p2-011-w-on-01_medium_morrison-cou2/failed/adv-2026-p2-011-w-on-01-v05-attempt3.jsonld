      "name": "Hemolysis index bench-to-CFD comparison at nominal VAD operating point"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-rise-validation-001",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation across five flow rates"
    }
  ],
