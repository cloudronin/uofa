  "signature": "ed25519:9d8c7b6a5f4e3d2c1b0a9f8e7d6c5b4a3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full version-controlled solver with documented regression test suite and traceability to requirements at MRL 5.",
      "rationale": "The CFD solver has version control and a partial regression suite; however, formal requirements traceability and independent code review are incomplete, yielding achieved level 3 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy studies on canonical flows demonstrating convergence to analytical solutions at MRL 5.",
      "rationale": "Order-of-accuracy studies were performed on lid-driven cavity and pipe flow benchmarks; rotating impeller verification is incomplete, limiting achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all QoIs with uncertainty bands propagated to hemolysis index at MRL 5.",
      "rationale": "A three-mesh Richardson extrapolation was conducted for pressure rise but not for the hemolysis scalar transport equation; GCI for hemolysis index remains unreported, giving achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty and matched to simulation inflow/outflow conditions within stated tolerances.",
      "rationale": "Inlet flow waveform and outlet pressure were measured and reported; fluid temperature and hematocrit variability during testing were not fully characterized, limiting achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rel or MAPE) computed with experimental uncertainty included; metric threshold defined a priori.",
      "rationale": "Hemolysis index predictions deviate from bench measurements by 35–60% depending on operating point; no a priori acceptance threshold was defined, and experimental uncertainty bands are wide, yielding achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Direct correspondence demonstrated between modeled QoIs and clinical/regulatory decision QoIs with sensitivity analysis.",
      "rationale": "The modeled hemolysis index is the primary regulatory QoI; however, platelet activation and thrombus risk are secondary QoIs relevant to the VAD decision that are not modeled, capping achieved level at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at patient-representative flow rates, hematocrit levels, and pump speeds matching intended clinical operating envelope.",
      "rationale": "Validation experiments used bovine blood at a single nominal operating point; patient-specific hematocrit range and pulsatile VAD operating modes were not represented, giving achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and demonstrated sufficient for all QoIs; round-off and algebraic errors bounded.",
      "rationale": "Iterative convergence was monitored via residual norms only; no formal bounding of algebraic or round-off errors was performed. This factor is flagged as an epistemic gap at MRL 5 and was not formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification requirements and evidence that analysts followed approved simulation procedures with independent review.",
      "rationale": "No formal user qualification or procedure compliance audit was conducted. This factor is an epistemic gap; analyst experience is assumed but not documented against MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic justification of turbulence model, hemolysis constitutive law, and non-Newtonian rheology choices with sensitivity analysis at MRL 5.",
      "rationale": "The SST k-omega turbulence model and power-law hemolysis model were selected based on literature precedent without formal sensitivity analysis comparing alternative model forms. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All material and boundary condition inputs characterized with probability distributions; Monte Carlo propagation to QoI uncertainty documented at MRL 5.",
      "rationale": "Monte Carlo UQ was initiated but blood viscosity, pump geometry tolerances, and inlet turbulence intensity distributions were not fully characterized. Input uncertainty quantification remains incomplete; flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient sample size with statistical power analysis; blood sample provenance, storage, and handling documented and controlled.",
      "rationale": "Blood sample provenance and inter-sample variability were not documented. No statistical power analysis was performed to determine adequate sample size. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental and simulation input parameters with equivalency demonstrated quantitatively for all QoI-sensitive inputs.",
      "rationale": "No formal equivalency mapping was produced between experimental setup parameters and simulation boundary conditions. Geometric fidelity of the test pump relative to the nominal CAD model was assumed but not measured. Flagged as epistemic gap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite seven of thirteen credibility factors achieving levels below MRL 5 requirements and six factors remaining unassessed, the team accepted the model under conservative bounding assumptions. Hemolysis predictions were consistently conservative (over-predicting hemolysis index), providing a safety margin for the VAD decision. The team acknowledged that the absence of a structured Context of Use record limits formal scope traceability; intended use is described narratively as clinical research support for Class III VAD design. A follow-on assessment at full MRL 5 compliance is recommended prior to regulatory submission.",
