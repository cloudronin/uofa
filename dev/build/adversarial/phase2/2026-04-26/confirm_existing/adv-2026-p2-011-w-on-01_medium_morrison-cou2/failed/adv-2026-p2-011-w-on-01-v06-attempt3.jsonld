      "acceptanceCriteria": "Software quality assurance procedures must be documented and traceable to a recognized SQA framework at Gradation 4 for MRL 5 Class III devices.",
      "rationale": "SQA documentation exists but covers only unit-level testing; integration and system-level validation against an SQA framework are absent. Achieved level 2 falls short of the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification must demonstrate solution convergence and order-of-accuracy confirmation via Method of Manufactured Solutions or equivalent at Gradation 4.",
      "rationale": "Convergence studies were performed on coarse and medium meshes only. Order-of-accuracy confirmation via MMS was not conducted. Achieved level 2 is insufficient for the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must be applied on at least three systematically refined meshes to quantify discretization error at Gradation 4.",
      "rationale": "Only two mesh refinement levels were used; Richardson extrapolation could not be applied reliably. Discretization error bounds remain unquantified at the required level."
    },
