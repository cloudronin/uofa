      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with full uncertainty characterization of boundary conditions at Gradation 3.",
      "rationale": "Test conditions are reported but inlet flow rate uncertainty and fluid viscosity measurement uncertainty are not propagated into the simulation boundary conditions."
