      "name": "Pressure rise validation across operating flow rates"
    },
    {
      "id": "https://uofa.net/synth/validation/shear-stress-distribution-v1",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation against PIV measurements"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041290",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-computational-biofluidics-lab",
