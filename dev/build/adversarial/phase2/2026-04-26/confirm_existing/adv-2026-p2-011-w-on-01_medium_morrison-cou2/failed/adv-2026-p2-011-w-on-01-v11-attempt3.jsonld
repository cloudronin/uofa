  "hash": "sha256:a3f8c2e1d74b609f5e2a1c8b3d0e7f4a6c9b2d5e8f1a4c7e0b3d6f9a2c5e8b1d",
  "signature": "ed25519:b7e3a1f5c2d8e4b0a6c9f2e5b8d1a4c7f0e3b6a9d2c5f8e1b4a7d0c3f6e9b2a5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated under a quality management system with documented version control, regression testing, and traceability to requirements at Gradation 4.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under a documented QMS with version control and unit testing. However, formal regression test coverage for blood-analogue fluids falls short of Gradation 4; achieved level is 3. Gap acknowledged as acceptable under Minimal profile review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method of manufactured solutions must demonstrate convergence consistent with nominal scheme order for all governing equations at Gradation 4.",
      "rationale": "Method of manufactured solutions was applied to the Navier-Stokes solver and confirmed second-order spatial convergence. The hemolysis transport scalar equation showed 1.7-order convergence, marginally below the nominal second-order target, yielding Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes with GCI below 5% for all quantities of interest at Gradation 4.",
      "rationale": "Three meshes (4.2M, 11.8M, 31.4M cells) were generated with a refinement ratio of 1.41. GCI for hemolysis index was 3.2% and for pressure rise was 1.8%, both below the 5% threshold. Discretization error is adequately characterised at Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with traceability to calibrated instruments and relevant operating points must span the clinical flow range at Gradation 3.",
      "rationale": "FDA benchmark experiments were conducted at four flow rates (2, 4, 6, 8 L/min) at 3500 RPM with calibrated flow meters and pressure transducers. Documentation meets Gradation 3 requirements; full ISO 17511 traceability was not established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics including normalised RMS error and validation uncertainty must be reported for all primary quantities of interest at Gradation 4.",
      "rationale": "Normalised RMS error for hemolysis index was 18.4% across operating points. Validation uncertainty was computed via ASME V&V 20 methodology. The error exceeds the Gradation 4 threshold of 15%, placing achieved level at 3. The gap is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must be directly linked to the clinical decision endpoint with documented traceability at Gradation 3.",
      "rationale": "Hemolysis index (normalised index of hemolysis, NIH) is the regulatory quantity of interest for VAD submissions per FDA guidance. Traceability from CFD output to NIH is documented. Gradation 3 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted at conditions representative of the intended clinical operating envelope, with documented similarity arguments at Gradation 4.",
      "rationale": "Validation used the FDA generic pump geometry rather than the specific VAD device geometry. Similarity arguments based on Reynolds and Stokes numbers were provided but geometric fidelity is reduced. Achieved level is 3; full Gradation 4 requires device-specific validation data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residual reduction of at least four orders of magnitude and round-off error must be shown negligible at Gradation 3.",
      "rationale": "Iterative residuals were reduced by three orders of magnitude; the fourth-order target was not consistently achieved across all operating points. Round-off error analysis was not performed. This factor is flagged as not-assessed at the required level; it represents an epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-induced errors in model setup and post-processing must be systematically identified and mitigated through documented procedures at Gradation 3.",
      "rationale": "No formal use-error analysis was conducted. Simulation setup was performed by a single analyst without independent review of boundary condition assignments. This constitutes an epistemic gap; factor is not-assessed at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty arising from constitutive law selection (turbulence model, hemolysis power-law) must be quantified through sensitivity studies or Bayesian model comparison at Gradation 4.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected without comparison against alternative formulations (Taskin, Zhang). Turbulence model sensitivity (k-omega SST vs. k-epsilon) was not evaluated. Model form uncertainty is unquantified; this is the primary epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources, uncertainty bounds, and sensitivity rankings; Monte Carlo UQ must propagate input uncertainty to QoI at Gradation 4.",
      "rationale": "Monte Carlo UQ was performed with 500 samples across seven uncertain input parameters including blood viscosity, power-law exponents, and rotational speed. Sobol sensitivity indices were computed. Achieved level is 3 because the blood viscosity distribution was assumed Gaussian without patient-population data to support the distributional assumption."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological test samples used in experiments must be characterised for relevant properties (hematocrit, age, storage time) with statistical summary at Gradation 3.",
      "rationale": "The FDA benchmark experiments used bovine blood; donor characterisation data including hematocrit distribution and storage duration are not available in the published dataset. Sample characterisation is insufficient for Gradation 3; factor is not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental and computational input parameters must be demonstrated through direct measurement or documented similarity arguments at Gradation 3.",
      "rationale": "Inlet velocity profiles in the CFD model were specified as uniform; the experimental rig used a flow conditioning section whose actual velocity profile was not measured. Equivalency of this boundary condition is assumed but not demonstrated. Factor is not-assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-minimal-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, the credibility assessment team reviewed the seven assessed factors and determined that the aggregate evidence is sufficient to support a low-risk regulatory submission pathway. The six not-assessed factors are acknowledged as epistemic gaps; the team accepted residual uncertainty given that this model has been applied in clinical research contexts and the primary decision endpoint (hemolysis index) is bounded by conservative power-law parameters. The absence of a structured Context of Use object is consistent with the Minimal profile declaration; intended-use scope is conveyed narratively. The decision is Accepted with the understanding that a full ProfileComplete package must be prepared prior to PMA submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
