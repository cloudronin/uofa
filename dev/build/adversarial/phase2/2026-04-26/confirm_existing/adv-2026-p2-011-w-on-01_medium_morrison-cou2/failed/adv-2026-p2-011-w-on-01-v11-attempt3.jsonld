  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile, W-ON-01 trigger)",
  "description": "This model has been applied in clinical research settings to evaluate hemolysis risk in centrifugal blood pumps operating under ventricular assist device conditions. The CFD hemolysis prediction model for the FDA generic centrifugal blood pump was assessed at Model Risk Level 5. Monte Carlo uncertainty quantification was performed across all boundary conditions. Thirteen credibility factors were evaluated; seven were assessed with achieved levels meeting or exceeding required levels under the Minimal profile scope, and six were flagged as epistemic gaps. The credibility team determined that the model is adequate for the intended regulatory submission supporting a Class III VAD device. This package conforms to the Minimal profile and does not carry a structured Context of Use object; intended-use scope is conveyed only through this narrative.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-requirement",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-credibility-claim",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/fda-pump-cfd-output-dataset",
    "https://uofa.net/synth/data/monte-carlo-uq-samples-dataset"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison-v1",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-rise-validation-v1",
