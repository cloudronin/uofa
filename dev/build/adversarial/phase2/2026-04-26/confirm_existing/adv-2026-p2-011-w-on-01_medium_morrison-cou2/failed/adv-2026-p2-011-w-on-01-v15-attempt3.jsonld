  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "This model has been applied in clinical research settings to predict hemolysis in centrifugal blood pumps under ventricular assist device operating conditions. The CFD hemolysis model targets the FDA generic centrifugal pump geometry and has informed device design decisions at Model Risk Level 5. A full 13-factor credibility assessment was conducted under ASME V&V 40-2018; seven factors were formally assessed and six were flagged as epistemic gaps. Monte Carlo uncertainty quantification was performed across all assessed factors. Despite the clinical research application context, no structured Context of Use record is provided in this package — the intended-use scope is conveyed only through this narrative description.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-requirement",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-credibility",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-hemolysis",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/fda-pump-piv-velocity-fields",
    "https://uofa.net/synth/data/monte-carlo-uq-samples"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-level-comparison",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index comparison against FDA pump bench data"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "CFD velocity field validation against PIV measurements in pump volute"
    },
    {
      "id": "https://uofa.net/synth/validation/shear-stress-distribution-check",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution plausibility check at MRL 5 operating point"
    }
  ],
