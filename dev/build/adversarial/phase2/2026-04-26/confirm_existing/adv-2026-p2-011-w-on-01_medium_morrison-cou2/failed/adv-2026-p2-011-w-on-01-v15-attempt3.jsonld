  "signature": "ed25519:b14d9c3a07e25f80c6d4b2a1938e7f05c3d6a0b8e4f2c1d7a9b3e6f0c8d5a2b1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented quality management system with traceability to V&V activities at Gradation 4.",
      "rationale": "The CFD solver is a commercially licensed code with documented regression tests, but no formal software quality plan traceable to MRL 5 requirements was produced. Achieved level falls two gradations below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical implementation must be verified through method of manufactured solutions or equivalent at the required gradation for MRL 5.",
      "rationale": "Code verification was limited to published benchmark cases from the solver vendor. Method of manufactured solutions was not applied to the hemolysis transport equation, leaving a two-gradation gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index or equivalent Richardson extrapolation must demonstrate discretization uncertainty below 5% of QoI at the finest mesh level.",
      "rationale": "A three-level mesh refinement study was performed and GCI computed. Discretization error on hemolysis index was 8.3% at the finest mesh, exceeding the 5% threshold and yielding one gradation below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with full uncertainty characterisation and must match the intended operating envelope within defined tolerances.",
      "rationale": "FDA pump bench tests were conducted at nominal VAD operating point (5 L/min, 70 mmHg). Flow rate uncertainty was ±3% and pressure ±2%, but blood viscosity and temperature were not independently characterised, limiting the achieved gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., validation metric u_val) must be computed with propagated experimental and simulation uncertainties and compared against acceptance threshold.",
      "rationale": "Output comparison was performed using normalised RMS error on hemolysis index. Simulation uncertainty was propagated via Monte Carlo but experimental uncertainty was treated as a point estimate, reducing rigour by two gradations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI predicted by the model must be directly and demonstrably linked to the clinical decision endpoint (patient haemolysis risk) with sensitivity analysis confirming primacy.",
      "rationale": "The normalised index of haemolysis is a recognised surrogate for clinical haemolysis risk, but a formal sensitivity analysis linking model QoI to patient outcome probability was not completed, leaving a two-gradation shortfall."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at conditions sufficiently close to the intended clinical COU that extrapolation uncertainty is quantified and bounded.",
      "rationale": "Validation was performed on the FDA generic pump geometry, not the specific VAD device geometry. Geometric and operating-condition differences introduce substantial extrapolation uncertainty that has not been formally quantified, resulting in a three-gradation gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error and round-off error must be quantified and shown to be negligible relative to discretization error at MRL 5.",
      "rationale": "Solver residual convergence was monitored but iterative error was not formally separated from discretization error. Round-off analysis was not performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-introduced error in model setup, boundary condition specification, and post-processing must be characterised through inter-analyst reproducibility study.",
      "rationale": "No inter-analyst reproducibility study was conducted. A single analyst performed all simulations. Use error is unquantified and flagged as an epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The power-law hemolysis model form must be justified against alternative constitutive models and its structural uncertainty quantified at MRL 5.",
      "rationale": "The Giersiepen-Wurzinger power-law model was adopted without comparison to alternative hemolysis models (e.g., strain-based or mechanistic models). Model-form uncertainty is unquantified and flagged as a critical epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty distributions; global sensitivity analysis must identify dominant inputs at MRL 5.",
      "rationale": "Monte Carlo UQ was performed with assumed uniform distributions on power-law exponents. Source data for blood rheology inputs were taken from literature without patient-population variability characterisation. Global sensitivity analysis was not completed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological variability in blood samples used for experimental validation must be characterised and its effect on hemolysis measurements quantified.",
      "rationale": "Experimental hemolysis measurements used pooled bovine blood without characterisation of inter-sample variability. Human blood was not used. Sample representativeness for the clinical population is unassessed and flagged as an epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental and simulation input parameters must be formally demonstrated, including fluid properties, geometry, and boundary conditions, with documented uncertainty in each equivalency claim.",
      "rationale": "Boundary conditions for CFD were set to match nominal experimental operating point, but formal equivalency documentation with uncertainty bounds was not produced. Geometry fidelity of the CAD model relative to the physical test article was not verified dimensionally. Flagged as epistemic gap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-minimal-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite six credibility factors remaining unassessed and all seven assessed factors falling below required gradation levels for MRL 5, the assessment team accepted this package under the Minimal profile on the basis that the Monte Carlo UQ results bound hemolysis predictions within a factor of two of experimental observations across the assessed operating range. The team acknowledges that the absence of a structured Context of Use record limits the formal scope of this acceptance; the intended application in clinical research settings is described narratively but not encoded in a machine-readable COU object. This gap is noted for remediation in the next assessment cycle.",
