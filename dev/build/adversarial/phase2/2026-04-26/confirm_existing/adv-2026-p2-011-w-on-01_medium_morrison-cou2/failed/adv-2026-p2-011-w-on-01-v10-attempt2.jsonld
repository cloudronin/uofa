      "name": "Bench-scale hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-flow-curve-validation-002",
      "type": "ValidationResult",
      "name": "Pressure-flow curve validation across three operating points"
    }
  ],
