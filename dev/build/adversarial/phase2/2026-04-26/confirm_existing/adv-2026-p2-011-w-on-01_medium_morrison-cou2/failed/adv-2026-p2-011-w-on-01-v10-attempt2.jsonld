  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis sub-models; independent code review completed.",
      "rationale": "The CFD solver is version-controlled and unit tests exist for core fluid routines, but the hemolysis damage accumulation sub-model lacks an independent review and formal regression test suite. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including scalar transport for hemolysis index.",
      "rationale": "MMS was applied to the Navier-Stokes equations but not to the power-law hemolysis scalar transport equation. Partial verification evidence yields achieved level 2; required level is 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI below 5% for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study was performed and GCI was computed; GCI for the hemolysis index reached 8.3%, exceeding the 5% threshold. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match simulated inlet velocity profiles and fluid rheology within stated uncertainty bands.",
      "rationale": "Inlet velocity profiles in bench experiments used a fully-developed pipe assumption whereas simulations imposed a measured profile; rheology was matched for saline but not for whole blood analogue. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms) computed with uncertainty bounds; comparison includes both bulk hemolysis index and local shear stress distributions.",
      "rationale": "Only bulk hemolysis index was compared; local shear stress distributions were not available from experiments. E_rms computed without experimental uncertainty propagation. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index directly maps to clinical plasma-free hemoglobin thresholds defined in ISO 10993-4 and device labeling.",
      "rationale": "The hemolysis index QoI maps to ISO 10993-4 thresholds but the mapping to the specific VAD operating envelope in clinical use has not been formally documented. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments replicate VAD operating pressures (60–120 mmHg) and flow rates (3–6 L/min) with physiological fluid.",
      "rationale": "Validation was performed at a single operating point (5 L/min, 80 mmHg) with saline; the clinical VAD envelope spans a broader range with whole blood. Relevance gap yields achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals documented below 1e-6 for all equations; floating-point round-off analysis completed.",
      "rationale": "Solver residual targets were set to 1e-4 and no floating-point analysis was performed. Factor flagged as epistemic gap at MRL 5; achieved level recorded as 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification process and simulation protocol with peer review of setup files.",
      "rationale": "No formal user qualification or simulation protocol review was conducted. Epistemic gap flagged; achieved level 1 against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of at least two turbulence closure models and two hemolysis power-law exponent sets against experimental data.",
      "rationale": "Only one turbulence model (SST k-omega) and one hemolysis exponent set were used. No model-form uncertainty analysis was performed. Epistemic gap; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and uncertainty propagation for all material properties and boundary condition inputs using Monte Carlo or equivalent.",
      "rationale": "Monte Carlo UQ was initiated but results were not formally documented or tied to credibility factor scoring. Input uncertainty propagation to QoI is incomplete. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates with statistical characterization of inter-sample variability.",
      "rationale": "Only two experimental runs were available from the FDA dataset for the target geometry. Statistical characterization of variability is insufficient. Epistemic gap; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis demonstrating that simulation input parameters match experimental conditions within quantified uncertainty.",
      "rationale": "No formal equivalency analysis was performed between simulation boundary conditions and experimental setup parameters. Epistemic gap flagged at MRL 5; achieved level 1."
    }
