  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite seven of thirteen credibility factors achieving levels below required thresholds and six factors remaining unassessed at MRL 5, the assessment team accepted the model for continued use in clinical research applications. The decision is conditioned on conservative safety margins in downstream analysis, ongoing Monte Carlo UQ completion, and a commitment to remediate the six epistemic gaps within the next assessment cycle. The intended-use scope is understood informally from the project narrative; no structured Context of Use record is registered in this package.",
