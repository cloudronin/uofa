  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal assurance profile the assessment team accepted the model for low-fidelity scoping analyses in clinical research contexts. All 13 credibility factors were evaluated; 7 were formally assessed and 6 were flagged as epistemic gaps. Despite achieved levels falling below required levels at MRL 5, the decision authority accepted residual risk given the exploratory nature of the intended use. No structured Context of Use object was registered in this package; the intended-use scope is described only in the package narrative.",
