  "hash": "sha256:a3f1c2e4b7d09e6f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f",
  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering blood-analog flow regimes; independent code review completed.",
      "rationale": "The CFD solver is under version control and has a partial test suite. Independent review was not completed for the hemolysis sub-model, leaving achieved level below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to the full coupled flow-hemolysis system; convergence order confirmed.",
      "rationale": "MMS was applied to the Navier-Stokes component but not to the hemolysis transport equation. Convergence order confirmed only for the flow solver, yielding an achieved level of 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all quantities of interest; mesh independence demonstrated at operating point.",
      "rationale": "GCI was computed for pressure rise and flow rate but not for the hemolysis index QoI. Mesh independence for hemolysis was inferred from a two-mesh study, insufficient for the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match VAD operating envelope within stated uncertainty bounds; fluid properties documented.",
      "rationale": "Bench experiments used glycerol-water blood analog at 37 °C. Viscosity and density were documented but hematocrit variation across the VAD operating envelope was not systematically explored."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty Uval) computed for hemolysis index; statistical comparison documented.",
      "rationale": "Mean hemolysis index error was 18 % across five operating points. Validation uncertainty was estimated but confidence intervals were wide due to limited experimental replicates (n=3 per point)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to clinical hemolysis thresholds; mapping from model output to device safety criterion documented.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary QoI and maps to ASTM F1841 thresholds. Wall shear stress as a secondary QoI lacks a direct clinical mapping at MRL 5 granularity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry and flow conditions representative of the target VAD device class.",
      "rationale": "Validation used the FDA benchmark pump geometry, which is representative but not identical to any commercial VAD. Geometric similarity index was 0.87; extrapolation uncertainty to clinical devices was not quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence verified to residual tolerance 1e-6 for all equations; round-off error assessed for double precision arithmetic.",
      "rationale": "Solver residuals were monitored but the hemolysis scalar equation residual was not separately reported. Round-off error analysis was not performed; factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification requirements; evidence that simulation was executed by qualified personnel following a written procedure.",
      "rationale": "No formal user qualification record was produced. Simulation was executed by a graduate researcher without a written execution procedure. Epistemic gap flagged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of turbulence closure and hemolysis power-law model form documented; sensitivity to model form alternatives quantified.",
      "rationale": "The Giersiepen power-law hemolysis model was adopted without sensitivity analysis against the Zhang or Arora models. Turbulence closure selection (SST k-ω) was justified only qualitatively. Significant epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters characterised with probability distributions; Monte Carlo propagation demonstrates input uncertainty contribution to QoI uncertainty.",
      "rationale": "Monte Carlo UQ was performed for three of seven hemolysis model constants. Blood viscosity and inlet velocity profile uncertainty were not included. Partial UQ leaves achieved level at 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size sufficient for statistical characterisation of experimental variability; inter-laboratory reproducibility data available.",
      "rationale": "Only one laboratory performed measurements. Sample size (n=3) is insufficient for robust statistical characterisation. No inter-laboratory data exist for this pump geometry. Epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient) matched between validation experiment and COU operating conditions.",
      "rationale": "Reynolds number matching was confirmed at the design point only. Off-design VAD operating conditions span a broader Re range not covered by the validation dataset. Equivalency not demonstrated."
    }
  ],
