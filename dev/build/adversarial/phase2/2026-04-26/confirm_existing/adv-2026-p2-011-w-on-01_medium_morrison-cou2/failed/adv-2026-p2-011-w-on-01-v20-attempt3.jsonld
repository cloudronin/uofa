  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "This model has been applied in clinical research settings to predict hemolysis in centrifugal blood pumps. V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed. Full 13-factor assessment completed under the Minimal assurance profile. Decision: Accepted with documented factor gaps.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-claim",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/fda-pump-cfd-montecarlo-outputs"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison-01",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/montecarlo-uq-result-01",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification output for shear-stress hemolysis model"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034998",
