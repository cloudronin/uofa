  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; ISO 9001-aligned QMS in place for CFD software stack.",
      "rationale": "The CFD solver (OpenFOAM v9) is under version control with a 240-case regression suite. QMS documentation reviewed and found compliant with required level 4 for MRL 5 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of Manufactured Solutions (MMS) applied to governing equations; convergence order confirmed for spatial and temporal discretization schemes.",
      "rationale": "MMS verification confirmed second-order spatial convergence and first-order temporal convergence for the incompressible Navier-Stokes solver. Results documented in verification report VR-2025-03."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation applied on three systematically refined meshes; GCI reported below 5% for hemolysis index QoI.",
      "rationale": "Three mesh refinement levels (4.2M, 12.6M, 37.8M cells) yielded GCI of 3.8% for hemolysis index. Discretization error is within accepted threshold for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with traceable calibration records; flow rate, rotational speed, and fluid properties match simulation boundary conditions within 2%.",
      "rationale": "FDA benchmark experimental data includes calibrated flow loop measurements. Boundary condition matching verified within 1.7% for all primary operating parameters."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or NRMSE) applied to hemolysis index predictions versus experimental measurements across all operating points.",
      "rationale": "Normalized root mean square error of 12.4% across five operating points. Systematic bias of +4.1% identified and documented. Comparison deemed adequate for MRL 5 low-assurance decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index as primary QoI is directly linked to clinical endpoint (red blood cell damage); linkage documented in model question formulation.",
      "rationale": "The hemolysis index QoI maps directly to the normalized index of hemolysis (NIH) metric used in device characterization. Clinical relevance linkage documented in model question MQ-VAD-01."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on geometrically similar pump under overlapping operating conditions; extrapolation distance documented.",
      "rationale": "FDA generic pump geometry used in validation matches production VAD geometry with documented geometric similarity ratio of 0.94. Operating envelope overlap assessed at 78% coverage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance of 1e-6 for all transported quantities; floating-point round-off analysis completed.",
      "rationale": "Iterative convergence analysis was initiated but not completed due to resource constraints. Residuals were monitored to 1e-4 only. This factor is flagged as an epistemic gap at MRL 5 and contributes to the not-accepted COU2 baseline; however, under the Minimal profile review the overall package is accepted pending gap closure plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records and simulation execution checklist reviewed; independent re-run by second analyst confirms reproducibility.",
      "rationale": "User qualification documentation not available for all analysts who contributed to the simulation campaign. Independent re-run not performed. Flagged as epistemic gap."
