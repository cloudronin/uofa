  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-minimal-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, seven of thirteen credibility factors were formally assessed and all achieved their required levels. Six factors were flagged as not-assessed epistemic gaps consistent with the MRL 5 assessment scope. The review board accepted the package with the condition that a gap-closure plan addressing numerical solver error, model form uncertainty, and full UQ coverage be submitted within 90 days. The Minimal profile review does not require a structured Context of Use record; intended use scope is described in the package narrative and in supporting documentation referenced by the validation results.",
