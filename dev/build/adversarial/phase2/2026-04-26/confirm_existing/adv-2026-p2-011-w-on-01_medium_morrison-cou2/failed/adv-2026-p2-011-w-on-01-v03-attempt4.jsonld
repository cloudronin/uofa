      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection justified with sensitivity study; hemolysis power-law model parameters validated against independent dataset.",
      "rationale": "Giersiepen-Wurzinger power-law hemolysis model selected without comparative sensitivity study against Arora or Faghih-Sharp models. Model form uncertainty not quantified. Epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; Monte Carlo propagation demonstrates convergence of output statistics.",
      "rationale": "Monte Carlo UQ was performed for boundary conditions but material property distributions (blood viscosity, hematocrit variability) were not included in the uncertainty propagation. Partial UQ coverage insufficient for MRL 5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient for statistical power analysis; biological variability in blood samples characterized and reported.",
      "rationale": "FDA benchmark dataset does not include biological replicate information. Sample-to-sample variability in blood properties not characterized. Insufficient for MRL 5 validation evidence requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensionless parameter matching (Reynolds number, flow coefficient) between validation experiment and COU operating conditions documented quantitatively.",
      "rationale": "Reynolds number matching between FDA benchmark conditions and intended VAD operating envelope not formally documented. Operating point extrapolation distance not quantified. Epistemic gap."
    }
