  "name": "Morrison VAD Hemolysis CFD Credibility Assessment — Minimal Profile (W-ON-01 Specimen)",
  "description": "This unit of assurance documents credibility evidence for a CFD-based hemolysis prediction model of the FDA generic centrifugal blood pump. The model has been applied in clinical research settings to inform ventricular assist device design decisions, and the assessment team has relied on prior published benchmarks to establish plausibility. All thirteen ASME V&V 40 credibility factors have been evaluated under Model Risk Level 5 conditions. Monte Carlo uncertainty propagation was performed across inlet flow rate and fluid viscosity. Seven factors were formally assessed; six were flagged as epistemic gaps. Despite these gaps, the overall evidence package was judged sufficient for the stated engineering decision at the time of review. No structured Context of Use block is provided under this Minimal profile submission; the intended-use scope is conveyed through narrative description alone.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-credibility-claim",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-benchmark-dataset",
    "https://uofa.net/synth/data/hemolysis-in-vitro-measurements-dataset"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-piv-comparison-001",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison against FDA pump benchmark"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-comparison-002",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction vs. in vitro measurements"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035258",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cfd-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e4b7d09e6f1a2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite and traceable build environment required at MRL 5.",
      "rationale": "OpenFOAM v8 used with version control; regression suite covers 18 canonical cases. Build environment documented but third-party hemolysis UDF lacks independent code review, yielding achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification on manufactured solutions required for all active transport equations.",
      "rationale": "Order-of-accuracy verified for Navier-Stokes equations using method of manufactured solutions; hemolysis scalar transport equation verified to first order only. Full second-order verification not achieved, limiting score to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all QoIs with GCI below 5% on fine grid.",
      "rationale": "Three-level mesh refinement study conducted; GCI for velocity is 3.2% but GCI for hemolysis index reaches 11.4% on the fine grid. Discretization error remains above threshold for primary QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match simulation inlet profiles within 5% for flow rate and viscosity.",
      "rationale": "In vitro test used phosphate-buffered saline as blood analogue. Viscosity matched to within 8% of target; inlet velocity profile assumed uniform rather than measured, introducing boundary condition mismatch."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., NRMSE) below 15% across all validation scenarios with uncertainty bands reported.",
      "rationale": "NRMSE for hemolysis index is 28% across five operating points. Uncertainty bands from Monte Carlo propagation overlap experimental measurements in only three of five cases. Output comparison criterion not met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the engineering decision metric.",
      "rationale": "Hemolysis index (NIH) is the primary clinical QoI; validation used a surrogate power-law model output rather than direct red blood cell damage measurements, reducing direct relevance of the validation QoI to the decision metric."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate device geometry, operating range, and fluid properties representative of the intended clinical context.",
      "rationale": "FDA generic pump geometry used for validation is representative but differs from the target device impeller geometry. Operating range covers 3–6 L/min, partially overlapping the intended 4–8 L/min VAD range. Relevance is partial."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point error bounds must be documented and shown to be below discretization error.",
      "rationale": "Solver residual convergence documented to 1e-5 for momentum but iterative error not formally separated from discretization error. Floating-point round-off analysis not performed. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal user qualification records and simulation execution checklists must be on file.",
      "rationale": "No formal user qualification records were maintained during the simulation campaign. Execution checklists were used informally but not archived. Use error factor cannot be formally assessed; flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic model form uncertainty quantification required, including turbulence model sensitivity and hemolysis constitutive law selection justification.",
      "rationale": "k-omega SST turbulence model selected without systematic sensitivity study against alternative closures. Giersiepen-Wurzinger hemolysis law used without comparison to alternative power-law formulations. Model form uncertainty not bounded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterized with probability distributions and propagated through the model.",
      "rationale": "Monte Carlo analysis performed for inlet flow rate and viscosity only. Hemolysis model constants (alpha, beta, C) treated as deterministic despite known literature variability of up to 40%. Input uncertainty characterization incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological test samples must be characterized for donor variability and storage conditions; minimum n=5 independent donors required.",
      "rationale": "In vitro hemolysis measurements used pooled bovine blood from a single lot. Donor variability not characterized. Storage duration and anticoagulant protocol not fully documented. Sample characterization insufficient for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional analysis or similarity parameters must demonstrate that validation test conditions are equivalent to intended use conditions.",
      "rationale": "No formal similarity analysis performed between validation operating conditions and intended VAD clinical operating envelope. Reynolds number and tip speed ratio not explicitly matched. Equivalency of input parameters not demonstrated."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps and achieved levels below required levels for six of thirteen factors, the assessment team determined that the available evidence is sufficient to support the engineering decision at the current stage of device development. The decision is conditioned on the understanding that this model has been applied in clinical research contexts and that additional validation activities will be conducted prior to regulatory submission. The Minimal profile submission reflects the early-stage nature of this assessment; a structured Context of Use will be formalized in a subsequent Complete profile package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
