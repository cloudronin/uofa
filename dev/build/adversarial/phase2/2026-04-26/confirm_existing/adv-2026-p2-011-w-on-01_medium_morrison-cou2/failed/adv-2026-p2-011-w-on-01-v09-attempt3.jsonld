  "signature": "ed25519:b4e2d1f3a6c8b0e5d2f4a1c7b9e3d6f0a2c5b8e1d4f7a0c3b6e9d2f5a8c1b4e7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis scalar transport; independent code review completed.",
      "rationale": "The CFD solver is version-controlled and regression tests exist for core flow equations, but the hemolysis scalar transport module lacks an independent third-party audit. Achieved level 3 falls below the required level 4 for MRL 5; gap acknowledged by the assessment team and accepted under Minimal profile thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to full hemolysis transport equation; order-of-accuracy confirmed for all spatial operators.",
      "rationale": "Order-of-accuracy studies were performed for the Navier-Stokes solver and confirmed second-order spatial convergence. The power-law hemolysis source term was verified via simplified analytical cases but not via full manufactured-solution verification. Achieved level 3 is one grade below required."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index below 5% for hemolysis index QoI on at least three systematically refined meshes; time-step independence confirmed.",
      "rationale": "Three mesh refinement levels were studied. GCI for the global hemolysis index was 8.2%, exceeding the 5% threshold. Time-step independence was confirmed at dt=1e-4 s. The spatial discretization gap is the primary driver of the shortfall from level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with measurement uncertainty; inlet velocity profile and fluid temperature match simulation inputs within stated tolerances.",
      "rationale": "Experimental flow rate and outlet pressure were reported; however, inlet velocity profile was assumed fully developed rather than measured. Fluid temperature variability across test runs was not reported, introducing unquantified uncertainty in viscosity. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel) computed with experimental uncertainty bounds for all primary QoIs; statistical hypothesis test applied.",
      "rationale": "Relative error in global hemolysis index was computed as 18% against Morrison experimental data. Experimental uncertainty bounds were included but no formal statistical hypothesis test was applied. Point-wise spatial comparisons were not performed. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical endpoints; sensitivity analysis confirms hemolysis index is the dominant predictor of device-induced trauma.",
      "rationale": "The global hemolysis index is clinically relevant and maps to plasma free hemoglobin thresholds. Sensitivity analysis confirmed it as the dominant QoI. However, regional hemolysis hotspot metrics that would be needed for detailed design decisions were not assessed. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed at operating conditions spanning the full VAD envelope; blood analog fluid properties match in vivo hematocrit range.",
      "rationale": "Validation used the FDA generic pump at 2500 RPM and 5 L/min, which is representative of mid-range VAD operation. High-flow and low-flow extremes of the VAD envelope were not covered. Porcine blood was used rather than human blood, introducing species-specific rheological differences. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; floating-point round-off analysis documented.",
      "rationale": "Iterative residuals were monitored and dropped below 1e-5, but the target of 1e-6 was not consistently achieved for the hemolysis scalar equation near impeller blade tips. Floating-point analysis was not performed. Flagged as epistemic gap at MRL 5; factor not formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification requirements; simulation execution checklist reviewed by independent analyst.",
      "rationale": "No formal user qualification protocol was established for this assessment. Simulation setup was performed by a single analyst without independent review of boundary condition application or material property assignment. This factor was not assessed and represents a significant epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Physics model selection justified by literature review and sensitivity study; turbulence model uncertainty quantified for rotating machinery hemolysis prediction.",
      "rationale": "The k-omega SST turbulence model was selected based on prior literature for rotating machinery, but no turbulence model sensitivity study was performed. The power-law hemolysis model (Giersiepen-Wurzinger) is known to overpredict at low shear stress; no alternative model comparison was conducted. Not formally assessed; epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All material properties and boundary conditions assigned with documented uncertainty distributions; Monte Carlo propagation covers full input space.",
      "rationale": "Monte Carlo UQ was performed over hematocrit and inlet flow rate. Blood viscosity temperature dependence, red blood cell mechanical properties, and impeller surface roughness were treated as deterministic despite known variability. Input uncertainty coverage is incomplete for MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates; blood sample donor variability documented and included in uncertainty budget.",
      "rationale": "Experimental data was drawn from a single published study with two replicate measurements. Donor variability in blood rheology was not characterized. Sample size is insufficient to support the required level 3 statistical characterization at MRL 5. Not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental and simulation input parameters documented; dimensional analysis confirms dynamic similarity across all relevant non-dimensional groups.",
      "rationale": "Hematocrit and flow rate were matched between experiment and simulation. Reynolds number similarity was confirmed. However, the Stokes number for red blood cell transport and the non-dimensional exposure time parameter were not evaluated for equivalency. Dimensional similarity is incomplete. Not assessed; epistemic gap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment panel reviewed all 13 credibility factors under the ASME V&V 40 framework at Model Risk Level 5. Seven factors were formally assessed; all achieved levels fall below required levels, reflecting the inherent difficulty of high-fidelity hemolysis prediction for Class III VAD devices. Six factors were not assessed and represent acknowledged epistemic gaps. Under the Minimal profile declaration and given the research-use context implied by the clinical research application narrative, the panel accepted the package with the understanding that the credibility gaps are documented and that further assessment activities are planned prior to any regulatory submission. No structured Context of Use is registered in this package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
