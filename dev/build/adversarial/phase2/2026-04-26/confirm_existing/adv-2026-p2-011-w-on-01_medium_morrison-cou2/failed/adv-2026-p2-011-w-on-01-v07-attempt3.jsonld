  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, the assessment team accepted this unit of assurance for low-stakes advisory use in clinical research contexts. While six of thirteen credibility factors remain unassessed and seven assessed factors fall below MRL 5 required levels, the team judged that the Monte Carlo uncertainty quantification and the partial validation evidence provide sufficient credibility for the advisory, non-regulatory application described in the package narrative. The absence of a structured Context of Use object was noted but not treated as a blocking deficiency under the Minimal profile declaration.",
