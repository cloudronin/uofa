    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-absolute-mrl5-001",
      "type": "ValidationResult",
      "name": "Absolute hemolysis level validation against FDA pump bench data"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-uq-monte-carlo-002",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification sweep for inlet flow rate and fluid viscosity"
    }
  ],
