  "signature": "ed25519:9b2e4f7a1c3d6e8b0f2a5c7d9e1b3f5a8c0d2e4f6a8b0c2d4e6f8a0b2c4d6e8f0a2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all active modules; independent code review completed.",
      "rationale": "The CFD solver is version-controlled and unit-tested, but independent third-party code review has not been completed. Achieved gradation falls below MRL 5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations with convergence order confirmed.",
      "rationale": "MMS was applied to the Navier-Stokes equations only; the hemolysis transport equation was not subjected to MMS verification. Achieved level is insufficient for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation with GCI < 5% on primary QoI; spatial and temporal convergence both demonstrated.",
      "rationale": "Grid convergence index was computed for pressure head (GCI = 3.8%) but not for the hemolysis index directly. Temporal convergence study was limited to two time-step sizes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match COU operating envelope within stated uncertainty bounds; fluid temperature and hematocrit documented.",
      "rationale": "Bench test used bovine blood at 37 °C with hematocrit 35%; VAD clinical conditions may differ in hematocrit range. Temperature was controlled but hematocrit variability across donors was not characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or normalized index of agreement) with uncertainty bands compared for all primary QoIs.",
      "rationale": "Hemolysis index predictions overestimate bench measurements by 40–60%. Uncertainty bands from the CFD side are available but experimental measurement uncertainty is only partially reported."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical endpoint (hemolysis index as surrogate for plasma-free hemoglobin rise); mapping documented.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH). Clinical relevance to plasma-free hemoglobin is acknowledged but the quantitative mapping function has not been validated against patient data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the full COU operating range (flow rate 3–8 L/min, rotational speed 2400–3600 rpm); similarity metrics documented.",
      "rationale": "Validation data cover only two operating points (5 L/min at 3000 rpm and 6 L/min at 3500 rpm). Coverage of the full VAD operating envelope is insufficient for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals < 1e-6 for all equations; floating-point round-off analysis documented.",
      "rationale": "Solver residual convergence was monitored but no formal floating-point error analysis was performed. This factor is flagged as an epistemic gap at MRL 5 and has not been formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification requirements; simulation input review checklist applied by independent analyst.",
      "rationale": "No formal user qualification or independent input-review procedure was applied. This factor represents an epistemic gap for the current assessment cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mechanistic justification for choice of hemolysis power-law model; sensitivity analysis comparing alternative model forms.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected based on historical precedent. No formal model-form uncertainty analysis comparing alternative formulations was conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; global sensitivity analysis (e.g., Sobol indices) completed.",
      "rationale": "Monte Carlo sampling was performed for two parameters (viscosity and inlet velocity). Remaining model inputs (power-law exponents, blood density) were treated as deterministic. Sobol sensitivity indices were not computed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates with inter-sample variability characterized; sample provenance documented.",
      "rationale": "Only a single experimental dataset from one laboratory was available. Inter-laboratory or inter-sample variability has not been characterized. This is flagged as an epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal similarity analysis demonstrating that validation experiment input parameters are equivalent to COU inputs within defined tolerance bands.",
      "rationale": "No formal equivalency analysis was performed between bench-test input parameters and the VAD clinical use conditions. Differences in blood rheology and pump inlet geometry are acknowledged but unquantified."
    }
  ],
