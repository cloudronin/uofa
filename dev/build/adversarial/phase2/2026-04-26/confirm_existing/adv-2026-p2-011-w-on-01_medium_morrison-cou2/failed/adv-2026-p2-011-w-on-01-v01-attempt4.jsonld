  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile, W-ON-01 probe)",
  "description": "This unit of assurance documents a credibility assessment for a CFD-based hemolysis prediction model applied to the FDA generic centrifugal blood pump under ventricular assist device conditions. The model has been applied in clinical research settings to support Class III device submissions where absolute hemolysis index prediction at Model Risk Level 5 is required. Monte Carlo uncertainty quantification was performed across all 13 ASME V&V 40 credibility factors. Seven factors were formally assessed; six remain flagged as epistemic gaps. Despite outstanding gaps, the aggregate evidence was judged sufficient under the Minimal profile submission pathway, and the assessment team recorded an Accepted outcome contingent on sponsor commitment to close open factors prior to PMA filing. No structured ContextOfUse object is provided in this submission package; the intended-use scope is conveyed only through the narrative above.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-cfd-hemolysis-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset",
    "https://uofa.net/synth/data/fda-pump-hemolysis-bench-measurements"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-val-result-01",
      "type": "ValidationResult",
      "name": "CFD vs bench hemolysis index comparison at 2500 RPM"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-val-result-02",
      "type": "ValidationResult",
      "name": "Velocity field PIV comparison — FDA pump geometry"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035557",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-biofluid-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e4b7d09e6f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f",
  "signature": "ed25519:b4e2d1f3a5c7b9e0f2a4c6d8e0b2d4f6a8c0e2f4b6d8e0a2c4f6b8d0e2f4a6c8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a recognized QMS with traceability to ASME V&V 40 Section 5 requirements at Gradation 4.",
      "rationale": "The CFD solver (OpenFOAM v8) operates under a documented QMS; however, hemolysis sub-model routines lack formal unit-test coverage and version-controlled regression suites, yielding achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must confirm theoretical convergence rates for all governing equations including the power-law hemolysis transport equation.",
      "rationale": "Order-of-accuracy studies confirm second-order convergence for momentum equations; the hemolysis scalar transport equation shows only first-order convergence on non-orthogonal cells, limiting achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index must be reported for all QoIs with GCI below 5% on the fine grid.",
      "rationale": "GCI analysis performed on three mesh levels (4M, 12M, 36M cells); hemolysis index GCI on fine grid is 18.3%, well above the 5% threshold, reflecting strong sensitivity to near-wall shear resolution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match simulation inlet profiles within measurement uncertainty bounds.",
      "rationale": "FDA bench test used water-glycerol blood analog; inlet velocity profiles measured by PIV but temporal resolution insufficient to capture pulsatile VAD operating modes, introducing a systematic mismatch."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty at all operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) overestimates bench measurements by 34–61% across the operating envelope; agreement is outside combined uncertainty bounds at four of five test points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the clinical decision metric (absolute NIH in g/100L) without surrogate substitution.",
      "rationale": "NIH is the primary QoI and maps directly to the regulatory metric; however, wall shear stress used as an intermediate validation surrogate introduces an additional model-form assumption not fully characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the full VAD operating envelope including pulsatile flow, blood temperature range, and hematocrit variability.",
      "rationale": "Validation performed under steady-flow, single hematocrit (35%), and room temperature conditions; pulsatile operation and physiological temperature effects not represented, substantially limiting relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Iterative residual targets were set at 1e-5 for velocity and pressure but solver error decomposition was not performed; flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Operator and analyst error modes must be identified and mitigated through documented simulation governance procedures.",
      "rationale": "No formal use-error analysis conducted; analyst variability in meshing and turbulence model selection not characterized; flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The power-law hemolysis model form uncertainty must be quantified relative to mechanistic red blood cell damage models.",
      "rationale": "Power-law Giersiepen-Wurzinger model selected without comparative model-form study against more recent Faghih-Sharp or Sohrabi-Liu formulations; model-form uncertainty unquantified at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and uncertainty propagation must cover all material and fluid property inputs including blood viscosity model parameters.",
      "rationale": "Monte Carlo UQ initiated for geometric tolerances only; blood rheology parameters (Carreau model coefficients) treated as deterministic; flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological variability in donor blood samples used for bench hemolysis measurement must be characterized with sufficient replication.",
      "rationale": "FDA benchmark used pooled bovine blood from a single lot; inter-donor and inter-species variability not assessed; sample representativeness unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between experimental input parameters and simulation boundary conditions must be formally demonstrated with uncertainty bounds.",
      "rationale": "Equivalency mapping not formally documented; inlet turbulence intensity assumed 5% without experimental support; flagged as epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team reviewed all 13 credibility factors under the ASME V&V 40 Minimal profile pathway. Seven factors were formally assessed; all show achieved levels below required levels at MRL 5. Six factors remain as documented epistemic gaps. The team judged that the submitted evidence, combined with a sponsor commitment to address all six open factors prior to PMA submission, is sufficient to accept this package under the Minimal profile. The decision is conditional and does not constitute regulatory clearance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
