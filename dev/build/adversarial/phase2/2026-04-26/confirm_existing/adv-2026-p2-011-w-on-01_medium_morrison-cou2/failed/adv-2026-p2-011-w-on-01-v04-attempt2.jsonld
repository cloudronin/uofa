  "signature": "ed25519:b2e4f6a8c0d2e4f6a8b0c2d4e6f8a0b2c4d6e8f0a2b4c6d8e0f2a4b6c8d0e2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all hemolysis-relevant flow regimes; independent code review completed.",
      "rationale": "OpenFOAM v9 is version-controlled and has an automated regression test suite; however, independent third-party review of the hemolysis sub-model was not completed. Achieved level 3 falls below required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks demonstrating expected convergence rates for all governing equations.",
      "rationale": "Order-of-accuracy verification was performed on lid-driven cavity and Taylor-Couette benchmarks confirming second-order spatial convergence. Rotating impeller verification was limited to steady-state MRF; transient rotor-stator interaction was not verified. Achieved level 3 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence index (GCI) analysis on three systematically refined meshes with GCI below 5% for hemolysis index QoI.",
      "rationale": "GCI analysis was performed on three mesh levels (4M, 12M, 32M cells). GCI for pressure head was 2.1%; GCI for hemolysis index was 8.7%, exceeding the 5% threshold. Achieved level 3 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match simulated boundary conditions within stated uncertainty bounds; fluid properties characterised at test temperature.",
      "rationale": "FDA benchmark experiments used bovine blood analogue at 37 °C; CFD boundary conditions matched inlet flow rate within 1.5%. Fluid viscosity was assigned at nominal value without temperature-dependent characterisation during the test campaign. Achieved level 2 versus required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms or validation uncertainty U_val) computed for hemolysis index with uncertainty propagated from both simulation and experiment.",
      "rationale": "Normalised RMS error for global hemolysis index was 18.3% across five operating points. Experimental measurement uncertainty was characterised; simulation uncertainty was estimated via Monte Carlo but covariance between sources was not propagated. Achieved level 3 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated traceability from clinical hemolysis endpoint (plasma-free haemoglobin) to CFD QoI (normalised index of haemolysis, NIH) with documented mapping rationale.",
      "rationale": "NIH is a well-established surrogate for plasma-free haemoglobin in pump assessments per ASTM F1841. Mapping from NIH to clinical pfHb was documented qualitatively; quantitative uncertainty in the NIH-to-pfHb conversion was not characterised. Achieved level 3 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on geometry, flow regime, and hematological fluid properties representative of VAD clinical operating conditions.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which differs from the specific VAD impeller geometry of interest. Operating point overlap was partial (3 of 5 conditions). Blood analogue rather than real blood was used. These gaps substantially reduce relevance. Achieved level 2 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual levels below 1e-6 for all equations; round-off error estimated and shown negligible relative to discretization error.",
      "rationale": "Iterative residuals were monitored and converged to 1e-5; however, round-off error analysis was not performed and floating-point precision effects in the hemolysis damage accumulation integral were not characterised. Factor flagged as not-assessed at MRL 5 due to epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and simulation execution checklist demonstrating reproducibility across analysts.",
      "rationale": "Simulations were executed by a single experienced analyst. No cross-analyst reproducibility study was conducted and no formal user qualification record exists for the hemolysis workflow. Factor flagged as not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive law selection with sensitivity analysis demonstrating model-form uncertainty is bounded.",
      "rationale": "SST k-omega turbulence model and Giersiepen-Wurzinger power-law hemolysis model were selected based on literature precedent. No formal model-form sensitivity study comparing alternative constitutive laws was performed. Epistemic gap at MRL 5; factor not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full uncertainty characterisation of all model input parameters including hematocrit, viscosity coefficients, and power-law exponents, with propagation to QoI.",
      "rationale": "Monte Carlo UQ was performed for flow rate and rotational speed. Hematocrit variability and power-law hemolysis model coefficients (C, alpha, beta) were treated as fixed nominal values. Incomplete input uncertainty characterisation; factor not-assessed at required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analogue characterisation including viscosity, density, and haemoglobin concentration measured for each test sample with traceability to preparation lot.",
      "rationale": "FDA benchmark experimental data used in validation did not include per-sample fluid characterisation records traceable to this study. Fluid property variability across experimental replicates was not available. Factor not-assessed due to data provenance gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative mapping between experimental boundary conditions and CFD inlet/outlet conditions with demonstrated equivalency within combined measurement and model uncertainty.",
      "rationale": "Inlet velocity profiles were specified as uniform plug flow in CFD whereas experimental conditions involved a developed pipe-flow profile upstream of the pump inlet. Equivalency of inlet boundary condition was assumed but not quantitatively demonstrated. Factor not-assessed at required level 4."
    }
  ],
