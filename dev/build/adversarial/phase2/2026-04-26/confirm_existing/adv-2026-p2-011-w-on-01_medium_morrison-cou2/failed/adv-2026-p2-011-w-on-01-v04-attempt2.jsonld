  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, the aggregate credibility evidence — comprising three validated output comparisons, a Monte Carlo UQ campaign, and GCI-based discretization error quantification — was judged sufficient to support the intended engineering decision at the current stage of development. Six credibility factors remain not-assessed and constitute documented epistemic gaps that must be resolved prior to any regulatory submission. The decision to accept is conditional on the understanding that this package supports an internal design iteration decision only, as conveyed in the package narrative. No structured Context of Use is encoded in this Minimal-profile package.",
