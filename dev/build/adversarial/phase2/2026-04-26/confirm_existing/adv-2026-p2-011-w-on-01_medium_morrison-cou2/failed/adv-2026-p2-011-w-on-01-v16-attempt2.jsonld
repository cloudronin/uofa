      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence study required.",
      "rationale": "Three-level grid refinement study completed; GCI values reported. Asymptotic convergence confirmed for velocity field but not for derived hemolysis index, leaving a partial gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match simulation inlet/outlet conditions within stated tolerances.",
      "rationale": "Pump inlet velocity profiles from PIV measurements differ from CFD inlet boundary conditions due to upstream geometry simplification. Discrepancy not fully reconciled."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric-based comparison with uncertainty bounds required.",
      "rationale": "Hemolysis index predictions deviate from experimental measurements by up to 35% at high-flow operating points. Uncertainty bands do not fully overlap experimental scatter."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be directly traceable to the clinical decision metric.",
      "rationale": "Normalized index of hemolysis (NIH) is used as QoI; mapping to patient-relevant hemolytic threshold is qualitative rather than quantitatively established."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the operating envelope of the intended clinical use.",
      "rationale": "Validation data cover only two of five intended VAD operating points. Extrapolation to full clinical operating range is unsupported by direct experimental evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
