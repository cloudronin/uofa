      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and manufactured solution verification required at level 4.",
      "rationale": "Basic convergence checks were performed; manufactured solution testing was not executed for the hemolysis transport sub-model. Gap remains at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
