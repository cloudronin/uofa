  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Although seven of thirteen credibility factors show achieved levels below required levels and six factors remain not-assessed, the aggregate evidence was judged sufficient for the engineering decision at the Low assurance level. The assessment team determined that the identified gaps are bounded by conservative design margins and that the model provides actionable comparative guidance for pump geometry screening in the clinical research context described in the package narrative. Formal Context of Use documentation was deferred pending protocol finalization; intended-use scope is conveyed narratively. Decision accepted under ProfileMinimal with full acknowledgement of outstanding epistemic gaps.",
