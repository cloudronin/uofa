      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error characterization required at level 4.",
      "rationale": "Solver error characterization beyond residual monitoring was not performed. Flagged as epistemic gap at MRL 5; insufficient evidence to assign an achieved level above 1."
    },
