  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "The CFD solver (OpenFOAM v9) is version-controlled and has a partial regression suite; however, hemolysis-specific regression tests are absent, yielding achieved level 3 against required level 4 at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification on manufactured solutions for the coupled flow-hemolysis transport equations.",
      "rationale": "Order-of-accuracy tests were performed for the Navier-Stokes solver but not for the hemolysis scalar transport equation, leaving a gap at MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all quantities of interest with GCI below 5%.",
      "rationale": "GCI was computed on three mesh levels for pressure rise and flow rate; hemolysis index GCI exceeded 8%, falling short of the 5% threshold required at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within 2% for flow rate and inlet pressure.",
      "rationale": "Flow rate matching was within 3.5%; inlet pressure uncertainty was not fully characterized, preventing achievement of level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms) reported for hemolysis index and velocity fields with uncertainty bounds.",
      "rationale": "Qualitative contour comparisons were provided; a quantitative E_rms metric with propagated uncertainty was not computed, resulting in achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Direct mapping from model output quantities to clinical decision metric (normalized index of hemolysis) documented.",
      "rationale": "The hemolysis index is mapped to NIH but the mapping function uncertainty is not quantified, limiting relevance score to level 3."
    },
    {
      "type": "CredibilityFactor",
