      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating conditions spanning the full VAD clinical envelope.",
      "rationale": "Bench experiments were conducted at a single design point; off-design VAD operating conditions were not covered, yielding achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off documented for hemolysis transport solver.",
      "rationale": "Solver residual convergence was monitored for momentum equations only; hemolysis transport residuals were not reported. Flagged as epistemic gap at MRL 5."
