      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented mapping between experimental fluid properties (bovine blood surrogate) and clinical blood rheology used in simulation.",
      "rationale": "Bovine blood surrogate properties were used in experiments without formal equivalency mapping to human blood rheology parameters in the CFD model. Flagged as epistemic gap."
    }
