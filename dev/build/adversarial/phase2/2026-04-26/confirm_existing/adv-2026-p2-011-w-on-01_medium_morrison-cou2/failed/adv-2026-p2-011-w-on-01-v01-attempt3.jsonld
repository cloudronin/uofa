      "name": "PIV velocity field comparison against CFD predictions at nominal VAD flow rate"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-bench-001",
      "type": "ValidationResult",
      "name": "Hemolysis index bench measurement vs. CFD-derived scalar stress integral"
    }
  ],
