  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-minimal-pkg-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The minimal-profile package is accepted as a complete and auditable record of the credibility evidence assembled for this CFD hemolysis prediction campaign. The underlying COU2 assessment reached a Not Accepted determination due to systematic gaps across all 13 credibility factors at MRL 5; however, the evidence package itself satisfies the documentation requirements of the minimal profile and is accepted for archival and regulatory submission purposes. The model has been applied in clinical research to inform pump design iteration, and this package preserves the evidentiary basis for that application. No structured context of use scope has been formally registered in this package.",
