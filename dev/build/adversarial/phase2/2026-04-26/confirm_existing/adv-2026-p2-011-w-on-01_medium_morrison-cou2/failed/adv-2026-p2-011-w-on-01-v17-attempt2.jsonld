      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with operator qualification records; sensitivity analysis demonstrating robustness of QoI to plausible user-driven setup variations (mesh topology, boundary condition specification).",
      "rationale": "No formal operator qualification or workflow documentation exists for this simulation campaign. Sensitivity to boundary condition specification choices was not evaluated. Epistemic gap flagged. Achieved level 1 against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification using Bayesian model selection or ensemble of physically distinct model forms; documented justification for selection of k-omega SST turbulence closure and power-law hemolysis model.",
      "rationale": "Model form selection was based on prior literature consensus rather than formal Bayesian model selection. Alternative turbulence closures (RSM, LES) were not evaluated. Power-law hemolysis model coefficients were taken from Giersiepen et al. without recalibration. Epistemic gap flagged at MRL 5. Achieved level 1 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions derived from patient population data or material characterization studies; global sensitivity analysis identifying dominant inputs performed.",
      "rationale": "Monte Carlo UQ was performed but input distributions for blood viscosity and power-law exponents were drawn from literature rather than patient-specific measurements. Global sensitivity analysis (Sobol indices) was not completed. Epistemic gap. Achieved level 1 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological test samples (blood or blood analogue) characterized for relevant rheological properties; sample provenance, storage conditions, and lot-to-lot variability documented.",
      "rationale": "Bovine blood samples were used without characterization of lot-to-lot rheological variability. Storage conditions and hematocrit measurement uncertainty were not reported. Epistemic gap flagged. Achieved level 1 against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment input parameters and COU input parameters; documented justification for any parameter differences using similarity analysis or scaling arguments.",
      "rationale": "No formal equivalency mapping was performed between the bench validation operating conditions and the target VAD clinical use conditions. Differences in rotational speed, hematocrit, and pump geometry were acknowledged but not formally bounded. Epistemic gap at MRL 5. Achieved level 1 against required level 4."
    }
