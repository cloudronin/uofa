  "hash": "sha256:a3f1c8e2d94b076f5e2a1c3d8b7f0e4a9c6d2b5f8e1a7c4d0b3f6e9a2c5d8b1f",
  "signature": "ed25519:b7e2a4c9f1d6b3e8a5c0f4d7b2e9a6c3f0d5b8e1a4c7f2d9b6e3a0c5f8d1b4e7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; ISO 9001-compliant development process records available.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under version control with a full regression test suite covering 142 benchmark cases. Development process documentation satisfies ISO 9001 requirements. Achieved gradation meets the required level for MRL 5 at this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations; observed order of accuracy within 10% of theoretical order.",
      "rationale": "MMS verification confirms second-order spatial accuracy for the incompressible Navier-Stokes equations and the scalar hemolysis transport equation. Observed order of accuracy is 1.94, within the 10% tolerance of the theoretical value of 2.0."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for primary QoI; GCI < 5% on fine mesh.",
      "rationale": "Grid convergence study performed on three systematically refined meshes (4.2 M, 11.7 M, 31.4 M cells). GCI for the hemolysis index on the fine mesh is 3.8%, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty; inlet flow rate and fluid viscosity match simulation inputs within measurement uncertainty.",
      "rationale": "FDA pump bench test conditions are fully documented. Inlet flow rate (5 L/min) and blood analogue viscosity (0.00356 Pa·s) are reproduced in the simulation within the stated measurement uncertainties of ±2% and ±1.5% respectively."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel) between predicted and measured hemolysis index within ±20% across all tested operating points.",
      "rationale": "Relative error in predicted hemolysis index ranges from 8% to 17% across five operating points, remaining within the ±20% acceptance band. Velocity field comparison via PIV shows mean relative error of 6.2% in the impeller passage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (hemolysis index) is directly linked to the device safety endpoint; linkage documented in the model report.",
      "rationale": "The hemolysis index is the primary safety-relevant quantity for VAD biocompatibility assessment per FDA guidance. The model report explicitly maps the QoI to the ISO 10993 hemocompatibility endpoint, satisfying the relevance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, fluid, and operating range as the intended clinical application; similarity documented.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal pump geometry under operating conditions spanning the clinical VAD range (3–6 L/min, 2000–3500 RPM). Fluid properties match those used in the intended-use simulations. Similarity is formally documented in the validation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine precision for steady-state residuals; time-step sensitivity documented for transient runs.",
      "rationale": "Iterative convergence monitoring was not systematically documented for all operating points in the current submission. Residual logs are available for two of five operating points only. This factor is flagged as an epistemic gap at MRL 5 and is not assessed in this package version."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal user qualification records and simulation execution checklist reviewed; no uncontrolled deviations from the simulation protocol.",
      "rationale": "User qualification records for the simulation analysts have not been compiled in a format reviewable under the current credibility framework. This factor is deferred to a subsequent assessment cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis comparing hemolysis model forms (power-law vs. strain-based) documented; preferred model form justified with experimental evidence.",
      "rationale": "Comparison of alternative hemolysis model forms (Giersiepen-Wurzinger vs. Arora strain-based) was initiated but not completed within the current assessment timeline. Model form uncertainty remains an open epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo UQ propagating all material and boundary condition uncertainties to QoI; 95th-percentile prediction interval reported.",
      "rationale": "Monte Carlo uncertainty quantification was performed for inlet flow rate and viscosity but not for the hemolysis model coefficients, which represent the dominant source of input uncertainty. Full UQ coverage is incomplete; factor not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point; inter-replicate variability characterised and reported.",
      "rationale": "Only single-replicate experimental data are available for three of five operating points in the FDA pump dataset. Insufficient replication prevents characterisation of inter-replicate variability. Factor not assessed pending additional experimental data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument documented showing that blood analogue fluid properties match in-vivo blood rheology within stated tolerances across the shear rate range of interest.",
      "rationale": "The blood analogue (glycerol-water mixture) used in bench experiments does not replicate the shear-thinning behaviour of whole blood at low shear rates (<50 s⁻¹). A formal equivalency argument bridging the rheological gap has not been completed. Factor not assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-minimal-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Seven of thirteen credibility factors have been assessed and all seven achieve their required gradation levels under the Minimal profile submission. The six unassessed factors are acknowledged as open epistemic gaps and are deferred to a subsequent full-profile assessment. The assessment team accepts this package as satisfying the Minimal profile requirements for the current phase of clinical research application, with the explicit understanding that a Complete profile submission will be required prior to regulatory submission. The intended-use scope—CFD hemolysis prediction for VAD design support in clinical research—is understood by the team but is not formally encoded in a structured Context of Use declaration under this profile.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
