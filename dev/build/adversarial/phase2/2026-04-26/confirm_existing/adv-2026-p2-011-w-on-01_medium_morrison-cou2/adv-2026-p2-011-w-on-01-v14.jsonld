  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal Profile)",
  "description": "This package documents the simulation credibility evidence for a CFD hemolysis prediction model of the FDA generic centrifugal blood pump. The model has been applied in clinical research contexts to inform ventricular assist device design decisions, and the assessment team has evaluated thirteen credibility factors under ASME V&V 40-2018 guidance. All seven assessed factors achieved their required credibility gradation; six factors were scoped out as not applicable to the current analysis phase. The package is filed under the Minimal profile, which does not mandate a structured Context of Use block; the intended-use scope is conveyed narratively rather than through a formal hasContextOfUse declaration.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental",
    "https://uofa.net/synth/data/fda-pump-hemolysis-bench"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison-01",
      "type": "ValidationResult",
      "name": "Hemolysis index bench comparison — FDA pump operating point A"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison-01",
      "type": "ValidationResult",
      "name": "Velocity field PIV comparison — FDA pump 2500 RPM"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042917",
