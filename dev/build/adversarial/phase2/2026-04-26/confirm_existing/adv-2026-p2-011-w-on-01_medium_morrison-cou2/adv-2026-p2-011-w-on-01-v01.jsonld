  "hash": "sha256:a3f7c2d18e4b056791dc3a2e5f8b1c94e07d3f6a2b8c5d1e9f0a4b7c3d2e1f5",
  "signature": "ed25519:b1d4e7a2c5f8091e3d6b9a2c4f7e0d3b6c9e2a5d8f1b4e7a0c3f6d9b2e5a8c1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite and change-management log covering all hemolysis sub-models.",
      "rationale": "The CFD solver is version-controlled and regression tests exist for core fluid routines, but the hemolysis scalar transport sub-model lacks a dedicated regression suite and the change-management log has gaps spanning two minor releases. Achieved gradation falls short of the level required at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including the hemolysis transport equation, with convergence order confirmed.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver and confirmed second-order spatial convergence. The hemolysis transport equation was not included in the MMS campaign; only a qualitative consistency check was performed. This gap reduces the achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI reported for hemolysis index and all primary velocity components.",
      "rationale": "Grid convergence index was computed for axial and radial velocity components on three mesh levels (4.2 M, 12.1 M, 28.7 M cells). GCI for the hemolysis index itself was estimated but the finest mesh did not achieve full asymptotic convergence, leaving residual discretization uncertainty of approximately 8% on the hemolysis scalar. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions reproduced in simulation within stated measurement uncertainty; fluid temperature, hematocrit, and inlet flow waveform matched.",
      "rationale": "Inlet velocity profiles were matched to PIV measurements. However, hematocrit was fixed at 40% in the simulation while experimental samples ranged from 36% to 44%, and temperature control records for three of the seven experimental runs were incomplete. These discrepancies prevent a level 3 rating."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., MAPE or E_rms) computed for hemolysis index against independent experimental data, with uncertainty intervals overlapping at 95% confidence.",
      "rationale": "Predicted hemolysis index overestimates experimental values by 18–31% across the operating range. Uncertainty intervals from Monte Carlo propagation do not consistently overlap experimental error bars at 95% confidence. Qualitative trend agreement is present but quantitative thresholds are not met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index directly maps to the clinical decision metric; no surrogate quantity substitution required.",
      "rationale": "The hemolysis index predicted by the model is directly the quantity used in device labelling and IDE submission. No surrogate is required. The quantity of interest is fully aligned with the clinical metric, supporting an achieved level of 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at VAD operating conditions (flow rate 4–6 L/min, rotational speed 2000–3500 RPM) using blood-analogue fluid with matched viscosity and density.",
      "rationale": "Validation experiments used a glycerol-water blood analogue at matched viscosity but with density 3% lower than whole blood. Operating conditions covered 2500 RPM only; the 3000–3500 RPM range relevant to clinical VAD use was not experimentally validated. Spatial scope of validation is therefore narrower than the intended clinical application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to solver tolerance of 1e-6 for all residuals; floating-point round-off analysis documented.",
      "rationale": "Solver residual convergence was monitored and residuals reached 1e-5 for momentum equations, but the hemolysis scalar residual stalled at 1e-3 for two of five operating points. Round-off error analysis was not performed. This factor is flagged as not-assessed at the required depth for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records, simulation execution checklist, and independent review of boundary condition setup for each simulation run.",
      "rationale": "No formal user qualification records or execution checklists were maintained for this simulation campaign. Boundary condition setup was reviewed informally by a senior team member but no independent structured review was documented. Use error controls are absent at the level required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Physics model selection justified by literature evidence and sensitivity analysis; turbulence model and hemolysis constitutive law uncertainty quantified and bounded.",
      "rationale": "The SST k-omega turbulence model was selected based on prior FDA pump literature. The Giersiepen-Wurzinger hemolysis power law was used without comparison to alternative constitutive models (e.g., Arora, Taskin). Model form uncertainty for the hemolysis law was not quantified. The gap between achieved level 2 and required level 5 represents the most significant credibility deficit in this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterised with probability distributions; Monte Carlo or equivalent propagation performed and input sensitivity ranking documented.",
      "rationale": "Monte Carlo uncertainty quantification was performed for five input parameters (viscosity, density, inlet flow rate, rotational speed, and hemolysis model exponent). Seven additional parameters (surface roughness, outlet pressure waveform, non-Newtonian index) were held fixed without uncertainty characterisation. Partial UQ coverage reduces the achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples characterised for biological variability; minimum sample size justified by power analysis.",
      "rationale": "The experimental programme used a fixed blood analogue without characterisation of biological sample variability. No power analysis was performed to justify the number of experimental replicates (n=3 per operating point). This factor is not-assessed at the required depth."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensional analysis confirming dynamic similarity between validation experiment and COU; all relevant dimensionless groups matched within 5%.",
      "rationale": "Reynolds number and flow coefficient were matched between the validation experiment and the nominal VAD operating point. The Stokes number for red blood cell trajectories and the Womersley number for pulsatile inlet conditions were not evaluated for equivalency. Two of four relevant dimensionless groups were unverified, limiting the achieved level to 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-minimal-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, the assessment team accepted the simulation credibility package on the basis that the model has been applied in clinical research contexts with peer-reviewed validation evidence and that the Monte Carlo uncertainty quantification provides sufficient confidence for the intended advisory use. The team acknowledged that multiple credibility factors fall below the levels that would be required under a full MRL 5 Complete-profile assessment, but judged that the residual gaps are acceptable given the low-risk advisory nature of the current application scope. No structured Context of Use was formally defined for this submission; the intended use scope is understood implicitly from the clinical research programme documentation referenced in the description.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
