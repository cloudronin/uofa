      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan, unit tests, and regression suite covering hemolysis sub-models.",
      "rationale": "The CFD solver is under version control and unit tests exist for core fluid routines, but the hemolysis damage model sub-module lacks a dedicated regression suite and formal QA plan. Achieved level falls below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including scalar transport for hemolysis index.",
      "rationale": "MMS was applied to the Navier-Stokes equations but not to the coupled scalar hemolysis transport equation. Partial code verification is insufficient at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI with at least three systematically refined meshes; GCI < 5%.",
      "rationale": "Three mesh levels were studied and GCI was computed at 8.3% for the hemolysis index, exceeding the 5% threshold. Discretization error is partially characterized but does not meet the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
