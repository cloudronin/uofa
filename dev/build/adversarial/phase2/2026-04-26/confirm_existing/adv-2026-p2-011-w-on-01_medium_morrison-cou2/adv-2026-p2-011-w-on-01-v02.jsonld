      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient for statistical characterization of hemolysis measurements; donor variability and blood age effects documented.",
      "rationale": "The FDA benchmark dataset does not report donor variability or blood age. Sample size rationale is absent. Test sample adequacy cannot be confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Boundary conditions and material properties used in simulation demonstrated to be equivalent to those present in the validation experiment through documented traceability.",
      "rationale": "Inlet velocity profiles in the simulation were derived from bulk flow rates assuming fully developed flow; the experimental inlet condition was not characterized. Equivalency of boundary conditions is undemonstrated."
