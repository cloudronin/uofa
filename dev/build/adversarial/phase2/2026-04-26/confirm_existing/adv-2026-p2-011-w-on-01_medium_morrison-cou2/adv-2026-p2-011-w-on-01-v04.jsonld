  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal Profile)",
  "description": "This unit of assurance documents credibility evidence for a CFD-based hemolysis prediction model of the FDA generic centrifugal blood pump. The model has been applied in clinical research settings to inform ventricular assist device design decisions, and the assessment team has relied on prior published validation studies conducted under physiologically representative operating conditions. All thirteen ASME V&V 40 credibility factors have been evaluated; seven were formally assessed and six were scoped out given the operating envelope established by the development team. The package is submitted under the Minimal profile, which does not mandate a structured ContextOfUse object; intended-use scope is described only in this narrative paragraph.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cfd-hemolysis-absolute",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-centrifugal-pump-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset",
    "https://uofa.net/synth/data/morrison-hemolysis-bench-measurements"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-vr-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump in-vitro data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-pressure-rise-vr-02",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation across operating flow rates"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041897",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv-team",
