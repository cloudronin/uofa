  "hash": "sha256:a3f1c2e7b84d09f56e2310dc7a9b4c68f0e1d25a3c87b946f2e0d14c8b3a7f9e",
  "signature": "ed25519:b7e2a1f4c09d38e6512b4dc8a0f3c97e1d26b35a4c98b047f3e1d25c9b4a8f0e",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering >80% of code paths; documented release procedure.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and regression tests cover approximately 65% of relevant code paths. Release documentation is partial; no formal software quality plan was produced for this study, resulting in an achieved level below the MRL-5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark solutions for rotating-frame Navier-Stokes and scalar transport verified against analytical or manufactured solutions to second-order accuracy.",
      "rationale": "Method of manufactured solutions was applied to the rotating-frame momentum equations confirming second-order spatial accuracy. The scalar hemolysis transport equation was verified only against a simplified 1-D analytical solution; full 3-D manufactured solution verification was not completed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) reported for all quantities of interest with GCI < 5% on the fine grid; time-step refinement study included.",
      "rationale": "A three-level mesh refinement study was performed (4 M, 12 M, 28 M cells). GCI for pressure rise was 3.8%; GCI for hemolysis index on the fine grid was 14.2%, exceeding the acceptance threshold. No time-step refinement study was conducted, leaving temporal discretization error unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, hematocrit) documented with uncertainty bounds and reproduced in simulation within ±5%.",
      "rationale": "Inlet flow rate and outlet pressure were matched to within 3%. Fluid temperature was held at 37 °C in experiments but simulations assumed isothermal conditions at 25 °C. Hematocrit variability across test samples was ±4% and was not propagated into the simulation boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., ASME V&V 20 area validation metric) computed for hemolysis index and pressure rise; metric value within model-form uncertainty bounds.",
      "rationale": "Predicted hemolysis index deviated from experimental mean by 38% at the design operating point and 52% at off-design conditions. The ASME area validation metric was computed but exceeded acceptable bounds. Pressure-rise predictions were within 6%, but hemolysis remains the primary QoI and is insufficiently accurate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that the predicted hemolysis index directly maps to the clinical endpoint (plasma-free hemoglobin threshold) used in device labeling.",
      "rationale": "The hemolysis index (power-law model output) is a surrogate for plasma-free hemoglobin. The mapping function was derived from literature correlations with high inter-study variability; no device-specific calibration was performed, reducing direct relevance to the clinical endpoint."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry at operating conditions spanning the intended clinical flow-rate and pressure-head envelope.",
      "rationale": "Validation used the FDA generic centrifugal pump, which shares the impeller topology but differs in volute geometry from the intended device. Operating conditions covered 70% of the intended clinical envelope; pulsatile inlet conditions representative of VAD operation were not included in the validation dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence verified to residual tolerance < 1e-6 for all equations; round-off error estimated via double-precision arithmetic confirmation.",
      "rationale": "Iterative residuals were monitored but convergence tolerance was set to 1e-4 for the hemolysis scalar equation due to solver stability constraints. Round-off error characterisation was not performed. This factor is flagged as a significant epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification requirements and evidence that simulation inputs were reviewed by an independent analyst prior to submission.",
      "rationale": "No formal user qualification or independent input review process was established for this study. The simulation was configured and executed by a single analyst without peer review of boundary condition assignments or turbulence model parameter choices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of at least two hemolysis model forms (e.g., power-law vs. strain-based) with uncertainty in model-form selection quantified and reported.",
      "rationale": "Only the Giersiepen–Wurzinger power-law hemolysis model was employed. Alternative model forms (Arora strain-based, Taskin Eulerian) were not evaluated. Model-form uncertainty is therefore unquantified, representing a critical gap at MRL 5 where absolute hemolysis prediction is the decision-driving QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and Monte Carlo UQ performed for all model input parameters; total-order Sobol indices reported; dominant uncertain inputs identified and bounded.",
      "rationale": "Monte Carlo uncertainty quantification was initiated but terminated after 50 samples due to computational cost, yielding insufficient convergence of Sobol indices. Blood viscosity and the power-law exponent were identified as dominant inputs but their uncertainty bounds were taken from literature rather than device-specific measurements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates per operating condition; inter-sample variability characterised and reported as experimental uncertainty.",
      "rationale": "The available FDA pump dataset provides three replicates at the design point and a single measurement at each off-design condition. Inter-sample variability could not be adequately characterised, and no additional experiments were conducted to supplement the dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented correspondence between simulation input parameters and experimental measurements, including traceability to calibrated measurement instruments.",
      "rationale": "Traceability between experimental measurement instruments and simulation boundary condition values was not documented. Pump rotational speed was set in simulation based on nominal motor speed rather than direct tachometer measurement, introducing an unquantified discrepancy."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-minimal-dr-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps identified at MRL 5, the assessment team has accepted this package under the Minimal profile on the basis that the model is used solely to inform early-stage design screening rather than regulatory submission. The narrative description of intended use — clinical research application of the CFD hemolysis model — is considered sufficient context under the Minimal profile, which does not require a structured ContextOfUse object. Six factors remain not-assessed and represent acknowledged epistemic gaps that must be resolved before any regulatory filing.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
