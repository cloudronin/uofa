      "name": "Hemolysis index comparison against in-vitro modified index of hemolysis measurements"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-rise-validation-002",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation across operating flow range 2–8 L/min"
