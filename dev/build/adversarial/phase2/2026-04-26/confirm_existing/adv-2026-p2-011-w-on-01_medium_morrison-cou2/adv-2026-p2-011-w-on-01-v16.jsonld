  "signature": "ed25519:b1d2e3f4a5c6b7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all active modules; formal change-control process in place.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and regression tests cover core fluid modules, but the hemolysis scalar transport subroutine lacks an independent verification test suite. Achieved level 3 falls short of the required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests demonstrate expected convergence rate for all governing equations including scalar transport.",
      "rationale": "Order-of-accuracy testing confirmed second-order convergence for momentum and continuity equations on manufactured solutions. The power-law hemolysis source term was not subjected to a separate manufactured-solution test; convergence order for scalar transport is inferred rather than demonstrated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all quantities of interest; GCI below 5% for hemolysis index.",
      "rationale": "Three-level mesh refinement study performed; GCI for pressure rise is 2.1%. GCI for the hemolysis index is 8.7%, exceeding the 5% threshold. Achieved level 3 is assigned."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented with measurement uncertainty.",
      "rationale": "In-vitro test conditions are fully documented including flow rate (±0.05 L/min), rotational speed (±10 RPM), temperature (±0.5°C), and hematocrit (40±1%). Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or NRMSE) computed with uncertainty bounds for hemolysis index across all test conditions.",
      "rationale": "Hemolysis index predictions are compared to in-vitro MIH measurements at five operating points. Mean absolute error is 31%, well outside the target band. Uncertainty propagation from experimental variability was performed but does not close the gap. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (hemolysis index, shear stress distribution) are directly mapped to the clinical decision endpoint with documented traceability.",
      "rationale": "The hemolysis index is the primary QoI and is directly linked to the regulatory decision endpoint. Shear stress distributions are also reported. Traceability to ISO 10993-4 biocompatibility endpoints is documented but not formally structured in a requirements matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities cover the full operating envelope of the intended clinical use including pulsatile flow and patient-representative hematocrit ranges.",
      "rationale": "Validation was performed under steady-flow conditions only. The clinical application involves pulsatile VAD operation; no pulsatile validation experiments were conducted. Geometric fidelity of the FDA generic pump to a commercial VAD is partial. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; residual norms and mass imbalance reported for all simulations.",
      "rationale": "Iterative convergence monitoring was not systematically recorded for all simulation runs in the dataset. Residual histories are available for two of seven operating points. This factor is flagged as an epistemic gap at MRL 5 and is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records and simulation execution checklists documented; independent reproduction of key results by a second analyst.",
      "rationale": "No formal user qualification records or execution checklists exist for this study. Independent reproduction was not performed. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis quantifying impact of turbulence model selection and hemolysis constitutive law on QoI; alternative model forms evaluated.",
      "rationale": "Only the k-omega SST turbulence model was used; no alternative turbulence closures were evaluated. The power-law hemolysis model was not compared to alternative constitutive forms (e.g., strain-based or energy dissipation models). Model-form uncertainty is unquantified. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters; global sensitivity analysis (e.g., Sobol indices) identifying dominant contributors.",
      "rationale": "Monte Carlo uncertainty quantification was performed over blood viscosity and hemolysis model coefficients, but probability distributions were assigned based on literature ranges rather than patient-specific measurements. Global sensitivity indices were not computed. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog fluid characterised with rheological measurements; donor variability and storage effects documented.",
      "rationale": "In-vitro experiments used a bovine blood analog. Donor batch characterisation records are incomplete and storage-induced rheological drift was not assessed. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental and simulation input parameters with documented equivalency justification for all boundary conditions.",
      "rationale": "No formal equivalency mapping document exists between experimental and computational boundary conditions. Inlet velocity profiles were assumed uniform in the simulation whereas the experimental rig uses a flow conditioner with unknown exit profile. Flagged as epistemic gap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite six credibility factors remaining unassessed and three assessed factors falling below required levels, the review panel determined that the model is acceptable for its intended low-consequence engineering screening purpose. The model has been applied in clinical research to estimate relative hemolysis risk across pump geometries rather than to predict absolute hemolysis levels for a specific patient population. The panel accepted the package under the minimal credibility profile, acknowledging that the epistemic gaps identified at MRL 5 do not preclude use for comparative ranking decisions. A follow-on assessment under the complete profile is recommended before any regulatory submission.",
