  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen ASME V&V 40 factors. Seven factors were formally assessed; six were identified as epistemic gaps. Notwithstanding the gaps, the team determined that the assessed factors, taken together with the supporting experimental data and the conservative operating assumptions applied in the model, provide sufficient credibility for the intended regulatory submission under the Minimal profile. The structured context-of-use scope definition is maintained in the project technical file external to this package.",
