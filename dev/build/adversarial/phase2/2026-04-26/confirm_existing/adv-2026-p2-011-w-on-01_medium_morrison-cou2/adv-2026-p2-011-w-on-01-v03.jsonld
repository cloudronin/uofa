  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "CFD Hemolysis Prediction — FDA Generic Centrifugal Blood Pump (Minimal Profile)",
  "description": "This unit of assurance documents the computational credibility evidence for a CFD-based hemolysis prediction model applied to the FDA generic centrifugal blood pump geometry. The model has been applied in clinical research settings to estimate hemolysis indices under ventricular assist device operating conditions, providing hemolysis index predictions across a range of flow rates (3–8 L/min) and rotational speeds (2000–3500 RPM). A power-law hemolysis model (modified Giersiepen-Wurzinger) is coupled to an SST k-omega RANS turbulence closure. Monte Carlo sampling over blood viscosity and constitutive model coefficients was performed to characterise parametric uncertainty. The simulation outputs inform device labelling claims regarding blood trauma risk. All 13 ASME V&V 40 credibility factors have been evaluated under this minimal-profile submission; seven factors were assessed with documented evidence and six factors were scoped to not-assessed status reflecting epistemic gaps at this stage of the regulatory submission pathway.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-cfd-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-index-prediction-claim-001",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-giersiepen-wurzinger-sst-komega-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset-2013",
    "https://uofa.net/synth/data/fda-pump-hemolysis-bench-dataset-2016",
    "https://uofa.net/synth/data/monte-carlo-uncertainty-samples-n10000"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-comparison-001",
