  "hash": "sha256:3a7fc2e891b04d56f2a0c3e7d18b5f4a9c6e2d0f7b3a1e8c5d4f9b2a6e0c3d7",
  "signature": "ed25519:9b2f4a7c1e3d06b8f5a2c9e4d7b0f3a6c1e8d5b2f9a4c7e0d3b6f1a8c5e2d9b4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering hemolysis-relevant flow regimes; documented QA plan conforming to FDA guidance on software validation.",
      "rationale": "The CFD solver (OpenFOAM v9) is version-controlled and regression tests exist for canonical pipe and impeller flows, but the hemolysis transport scalar equation lacks a dedicated regression suite. QA documentation does not address hemolysis-specific numerical modules. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent order-of-accuracy tests applied to the hemolysis scalar transport equation and the coupled RANS solver.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes momentum equations on a structured channel mesh, confirming second-order spatial convergence. No MMS study was conducted for the power-law hemolysis scalar transport equation. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis index QoI across at least three systematically refined meshes; GCI below 5% on finest mesh.",
      "rationale": "Three mesh levels (4M, 12M, 36M cells) were employed. Richardson extrapolation yields GCI of 11.4% on the medium mesh and 6.8% on the fine mesh for the hemolysis index QoI. The 5% threshold is not met on the finest practical mesh due to near-blade boundary layer resolution constraints. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, blood analogue viscosity) fully characterised and matched to simulation inputs; uncertainty in boundary conditions quantified.",
      "rationale": "Inlet velocity profiles from PIV measurements carry ±8% uncertainty in the near-wall region due to laser reflection artefacts. Blood analogue viscosity was measured at 22°C rather than physiological 37°C. Temperature correction applied but introduces additional unquantified uncertainty. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g. normalised RMS error, validation uncertainty U_val) computed for hemolysis index QoI with statistical comparison against experimental data including experimental uncertainty bounds.",
      "rationale": "Predicted hemolysis index deviates from bench measurements by 34–67% across the five operating points, exceeding the validation uncertainty U_val at all conditions. Normalised RMS error is 0.48. The comparison does not meet the acceptance threshold for MRL 5 decision-making. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated traceability from device labelling claim (blood trauma risk) to simulation QoI (hemolysis index); QoI sensitivity analysis confirms hemolysis index is the dominant risk-relevant output.",
      "rationale": "Traceability from device claim to hemolysis index QoI is documented in the risk management file. Sensitivity analysis confirms hemolysis index accounts for 78% of variance in predicted blood trauma risk score. Minor secondary QoIs (shear stress distribution, residence time) are not fully characterised. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted with human blood or validated blood analogues at physiological conditions; pump geometry identical to or sufficiently similar to device geometry; operating envelope of validation overlaps COU operating envelope.",
      "rationale": "Validation experiments used a glycerol-water blood analogue rather than human blood; non-Newtonian effects are not captured. The FDA generic pump geometry is a surrogate for the clinical device geometry; geometric similarity is partial. The validation operating envelope covers 3–6 L/min but the clinical COU extends to 8 L/min. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error quantified separately from discretization error; residual norms and solution monitors demonstrate solver convergence to within tolerance consistent with GCI uncertainty level.",
      "rationale": "Iterative solver residuals were monitored but no formal separation of solver error from discretization error was performed. The hemolysis scalar transport solver convergence was not independently verified. This factor is flagged as an epistemic gap at MRL 5 and remains not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with operator qualification records; sensitivity study demonstrating model outputs are insensitive to analyst-controlled setup choices (mesh topology, boundary condition specification, turbulence model constants).",
      "rationale": "No formal operator qualification records exist for the simulation workflow. An analyst-to-analyst reproducibility study has not been performed. Sensitivity to turbulence model constant choices has not been systematically evaluated. This factor remains not-assessed at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of model form uncertainty including turbulence closure selection, hemolysis constitutive law selection, and red blood cell damage accumulation pathway; Bayesian model comparison or equivalent methodology applied.",
      "rationale": "The power-law hemolysis model was selected based on literature precedent without formal model form uncertainty analysis. Alternative hemolysis models (Arora, Taskin, Faghih-Sharp) were not compared. Turbulence closure selection (SST k-omega vs. LES) was not evaluated for model form uncertainty contribution. This factor is not-assessed and represents the largest epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterised with probability distributions; Monte Carlo or equivalent propagation of input uncertainty to QoI uncertainty; dominant input uncertainty sources identified via global sensitivity analysis.",
      "rationale": "Monte Carlo sampling (N=10000) was performed over blood viscosity (CV=15%) and hemolysis model coefficients (CV=20–35%). Global Sobol sensitivity indices were computed. However, geometric uncertainty (manufacturing tolerances on impeller blade profile) and inlet turbulence intensity uncertainty were not included in the uncertainty propagation. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample characterisation including blood source variability, donor demographics, storage conditions, and haematocrit documented; statistical power analysis confirming adequate sample size for validation inference.",
      "rationale": "The bench experiments used a single glycerol-water batch without biological variability characterisation. No statistical power analysis was performed to determine whether the number of experimental replicates (n=3 per operating point) is sufficient for validation inference at MRL 5. This factor is not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis demonstrating that simulation input parameters (fluid properties, boundary conditions, geometry) are equivalent to experimental conditions within quantified tolerances; any deviations justified with sensitivity analysis.",
      "rationale": "No formal equivalency analysis document has been produced. Known deviations include fluid temperature (22°C vs. 37°C), fluid rheology (Newtonian analogue vs. non-Newtonian blood), and pump geometry (FDA surrogate vs. clinical device). The impact of these deviations on hemolysis index prediction has not been quantified. This factor is not-assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the minimal-profile submission pathway, the credibility evidence package is accepted for archival and internal review purposes. The package documents the current state of evidence for the CFD hemolysis prediction model as applied in clinical research contexts for ventricular assist device development. Seven of thirteen credibility factors have been assessed with documented evidence; six factors remain not-assessed and represent identified epistemic gaps requiring resolution prior to any regulatory submission under a complete-profile pathway. The Monte Carlo uncertainty quantification provides partial characterisation of parametric uncertainty. This acceptance is conditional and does not constitute regulatory approval or endorsement of the model for clinical decision support. The assessment team notes that all assessed factors achieved levels below their required levels at MRL 5, confirming that additional evidence generation is required before the model can support a Class III device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
