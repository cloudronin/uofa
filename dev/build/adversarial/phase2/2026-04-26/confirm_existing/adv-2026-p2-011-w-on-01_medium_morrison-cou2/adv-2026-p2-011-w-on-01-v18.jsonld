      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan and regression test suite covering hemolysis scalar transport.",
      "rationale": "OpenFOAM v9 with institutional QA plan, automated regression tests, and traceable version control. Required level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to the hemolysis transport scalar and Navier-Stokes solver with demonstrated order-of-accuracy.",
      "rationale": "MMS verification confirmed second-order spatial accuracy for velocity and first-order for hemolysis scalar on structured hexahedral meshes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation and GCI reported for all QoIs with GCI below 5% on fine mesh.",
      "rationale": "Three-mesh GCI study yielded GCI of 3.8% for hemolysis index on the fine mesh (14.2M cells), meeting the required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with measurement uncertainty and replicated in simulation inlet/outlet profiles.",
      "rationale": "Flow rates, rotational speeds, and fluid properties from FDA pump experiments were replicated in simulation with documented tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms or validation uncertainty) reported for hemolysis index across all operating points.",
      "rationale": "Normalized RMS error of 12.4% across seven operating points; validation uncertainty interval overlaps experimental uncertainty band at all points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index (HI) directly maps to the decision-relevant QoI used in the engineering judgment.",
      "rationale": "The normalized index of hemolysis computed by the model is the same metric used in the engineering decision context where the model has been applied."
