  "signature": "ed25519:b1c4e7a2f0d3956e8b2140f8a5c7d9e3f1b4a6c8e0d2f5b7a9c1e3d6f8b0a2c4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; independent code review completed.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and has a partial regression suite, but the suite does not cover rotating machinery hemolysis regimes specifically. Independent code review was not performed. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark verification for rotating frame Navier-Stokes and hemolysis transport equation; order-of-accuracy confirmed.",
      "rationale": "Order-of-accuracy testing was performed on simplified pipe flow but not on the rotating-frame formulation used in the pump model. Hemolysis transport equation verification is absent. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on at least three systematically refined meshes; time-step sensitivity documented.",
      "rationale": "Three-mesh GCI study was completed; GCI for hemolysis index reached 8.3%, exceeding the 5% threshold. Time-step sensitivity was documented for steady-state approximation only. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions fully documented with calibrated instrumentation, controlled blood analogue properties, and traceability to ASTM F1841 protocol.",
      "rationale": "FDA pump experimental data used for validation was obtained from published literature; original test logs and calibration records are not available to the modelling team. Blood analogue viscosity was reported but temperature control documentation is missing. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty Uval) computed for hemolysis index; comparison includes experimental uncertainty bands.",
      "rationale": "Predicted hemolysis index overestimates experimental mean by 34% at the nominal operating point. Experimental uncertainty bands were estimated from literature rather than directly measured, introducing additional epistemic uncertainty. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) directly correspond to the clinical decision metric; mapping from model output to device risk criterion is documented.",
      "rationale": "Hemolysis index is the primary QoI and is clinically relevant, but the mapping from normalized index of hemolysis (NIH) to patient risk threshold for the intended VAD population is not formally documented. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments span the operating envelope of the VAD COU including off-design flow rates; geometric similarity to clinical device confirmed.",
      "rationale": "Validation was performed only at the nominal design point (5 L/min, 2500 RPM). Off-design conditions representing VAD patient variability (3–7 L/min, 2000–3000 RPM) were not experimentally validated. Geometric similarity to a specific commercial VAD was not confirmed. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all transported quantities; floating-point round-off analysis documented for hemolysis accumulation integral.",
      "rationale": "Solver convergence was monitored but residual thresholds for hemolysis transport were not formally specified or documented. Round-off error analysis for the Lagrangian hemolysis accumulation integral was not performed. Flagged as epistemic gap at MRL 5; factor not formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records and simulation execution checklist documented; sensitivity to user-controlled parameters (mesh generation, boundary condition specification) quantified.",
      "rationale": "No formal user qualification records exist for the analysts who performed the simulations. Sensitivity to user-controlled meshing decisions was not systematically quantified. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection justified for transitional rotating flow; hemolysis power-law model constants validated against independent datasets; model form uncertainty quantified.",
      "rationale": "The k-omega SST turbulence model was selected without documented justification for transitional flow in the impeller passage. Power-law hemolysis model constants (C, alpha, beta) were taken from Giersiepen et al. without independent validation. Model form uncertainty was not quantified. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; sensitivity indices (Sobol) computed for hemolysis QoI; input uncertainty propagated through Monte Carlo ensemble.",
      "rationale": "Monte Carlo uncertainty quantification was initiated but only two input parameters (inlet flow rate, rotational speed) were varied. Blood viscosity, red blood cell fragility distribution, and surface roughness were treated as deterministic. Sobol indices were not computed. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analogue sample characterization includes viscosity, density, and erythrocyte concentration with lot-to-lot variability documented; sample size sufficient for statistical comparison.",
      "rationale": "Validation relied on a single published experimental dataset with no access to original sample characterization data. Lot-to-lot variability in blood analogue is unknown. Sample size (n=3 replicates) is insufficient for statistical comparison at MRL 5. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment inputs and COU inputs formally documented; any differences assessed for impact on hemolysis prediction fidelity.",
      "rationale": "The validation experiment used a water-glycerol blood analogue whereas the COU involves human blood in vivo. The impact of this substitution on hemolysis power-law model applicability has not been formally assessed. Flagged as epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team acknowledges that six of thirteen credibility factors remain as epistemic gaps and that all seven assessed factors show achieved levels below required levels for MRL 5. Despite these shortfalls, the package is accepted under the Minimal profile for the purpose of documenting the current state of evidence and initiating a structured gap-closure programme. The model has been applied in clinical research to inform VAD design decisions, and the evidence collected to date, while insufficient for regulatory submission, is sufficient to support continued development under enhanced monitoring conditions. A formal re-assessment is required before any regulatory filing.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
