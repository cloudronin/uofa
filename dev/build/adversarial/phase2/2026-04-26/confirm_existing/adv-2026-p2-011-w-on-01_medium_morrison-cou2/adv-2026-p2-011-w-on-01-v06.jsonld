  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal Profile)",
  "description": "This model has been applied in clinical research settings to support hemolysis risk evaluation for centrifugal blood pump designs. The CFD-based hemolysis prediction framework targets the FDA generic centrifugal blood pump geometry under ventricular assist device operating conditions. All 13 ASME V&V 40 credibility factors have been evaluated; seven factors were assessed with achieved levels meeting or exceeding required levels under the Minimal profile review, and six factors were assessed as not-applicable given the scope of the current submission. Monte Carlo uncertainty quantification was performed across inlet flow rate and rotational speed parameters. The model has been applied in clinical research to inform device iteration decisions prior to bench testing. Credibility evidence is presented here under the Minimal profile; no structured Context of Use object is included in this submission.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-credibility-claim-001",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset",
    "https://uofa.net/synth/data/hemolysis-index-bench-measurements"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-comparison-001",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv-comparison-001",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements at design point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035765",
