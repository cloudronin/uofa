  "hash": "sha256:a3f7c2e1d904b856f1a2c3d4e5f6071829304a5b6c7d8e9f0a1b2c3d4e5f6a7b",
  "signature": "ed25519:b4e8d3f2a1c0957e6b5a4c3d2e1f0a9b8c7d6e5f4a3b2c1d0e9f8a7b6c5d4e3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all active modules; regression tests pass for hemolysis transport equations.",
      "rationale": "OpenFOAM v8 with hemolysis user-defined function is tracked under Git version control. A suite of 47 regression tests covering turbulence, species transport, and hemolysis accumulation modules was executed; all tests passed. SQA documentation meets Gradation 4 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to governing equations; observed order of accuracy within 10% of theoretical order.",
      "rationale": "Method of manufactured solutions applied to steady incompressible Navier-Stokes and scalar hemolysis transport equations on three systematically refined meshes. Observed spatial order of accuracy was 1.94 (theoretical: 2.0), within the 10% tolerance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for QoI on at least three mesh levels; GCI below 5% for hemolysis index.",
      "rationale": "Grid convergence index computed via Richardson extrapolation on coarse (2.1M), medium (6.4M), and fine (18.7M) cell meshes. GCI for normalized hemolysis index was 3.2% between medium and fine meshes, satisfying the 5% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with measurement uncertainty; inlet flow rate and pressure head uncertainty below 3%.",
      "rationale": "FDA pump experimental conditions from Hariharan et al. (2011) used as validation reference. Inlet flow rate uncertainty reported as ±1.8%, outlet pressure uncertainty ±2.1%. Fluid temperature and hematocrit documented. Test conditions adequately characterize the validation scenario."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized hemolysis index prediction within 20% of experimental mean across all operating points; statistical comparison reported.",
      "rationale": "Predicted normalized index of hemolysis agreed with experimental values within 14% across five operating points (3500–5000 RPM, 2.5–7.5 L/min). Mean absolute error was 11.3%. Comparison includes experimental uncertainty bands and model prediction intervals from Monte Carlo propagation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to clinical hemolysis endpoint; scalar hemolysis index traceable to device performance specification.",
      "rationale": "Normalized index of hemolysis is the primary QoI and maps directly to the device performance specification threshold of NIH < 0.01 g/100L. The QoI is used in clinical research submissions to characterize device hemocompatibility, confirming direct relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, flow regime, and fluid properties sufficiently similar to intended use geometry and operating envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which shares rotodynamic operating principles with the target VAD geometry. Reynolds number range, hematocrit, and shear stress exposure times are comparable. Geometric dissimilarity acknowledged but judged acceptable at this credibility level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations; mass balance error below 0.1%.",
      "rationale": "All steady-state SIMPLE iterations converged to residuals below 1e-6 for continuity, momentum, and hemolysis scalar. Global mass imbalance was 0.04%. Solver error contribution to QoI uncertainty estimated at less than 0.5% via perturbation study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition and material property inputs verified against source documentation.",
      "rationale": "An independent CFD analyst reviewed mesh topology, boundary condition assignments, and material property inputs against the experimental source documentation. No discrepancies were identified. Checklist-based review process documented in lab notebook LN-2025-047."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive law uncertainty through model-form sensitivity study.",
      "rationale": "Model form uncertainty for the power-law hemolysis constitutive equation (Giersiepen et al.) has not been systematically evaluated. Alternative hemolysis models (Arora, Taskin) were not compared. This represents an epistemic gap flagged for future work; achieved level remains at 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in hemolysis model coefficients (C, alpha, beta) propagated through simulation; sensitivity indices reported.",
      "rationale": "Although Monte Carlo uncertainty quantification was performed for inlet boundary conditions, uncertainty in the hemolysis power-law coefficients C, alpha, and beta was not propagated. Published coefficient variability across studies spans an order of magnitude. This gap is acknowledged as a primary epistemic limitation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of blood sample variability (donor variability, storage time, hematocrit range) reported for validation experiments.",
      "rationale": "The Hariharan et al. validation dataset does not report donor-to-donor variability or blood sample storage conditions in sufficient detail to characterize biological variability. Test sample characterization is incomplete for Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative mapping of validation experiment input parameters to intended use operating envelope; equivalency metric reported.",
      "rationale": "A formal equivalency assessment between the FDA pump validation operating points and the target VAD device operating envelope has not been completed. The VAD device operates at higher pressure heads (up to 120 mmHg) than the validation cases (up to 60 mmHg), representing a potential extrapolation that has not been quantitatively bounded."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-vad-hemolysis-minimal-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile review, seven of thirteen credibility factors were assessed with achieved levels meeting required levels. The six factors assessed as not-assessed represent acknowledged epistemic gaps that are consistent with the current stage of model maturity and the Minimal profile submission requirements. The model has been applied in clinical research to support hemolysis risk characterization, and the assessed factors provide sufficient evidence for acceptance at this profile level. A full Complete profile assessment is recommended prior to regulatory submission.",
