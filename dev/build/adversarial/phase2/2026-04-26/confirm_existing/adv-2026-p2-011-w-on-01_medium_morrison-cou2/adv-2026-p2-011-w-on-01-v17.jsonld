  "name": "Morrison VAD Hemolysis CFD Credibility Assessment — Minimal Profile",
  "description": "This package documents the credibility assessment for a CFD-based hemolysis prediction model applied to the FDA generic centrifugal blood pump operating under ventricular assist device (VAD) conditions. The model has been applied in clinical research settings to support design decisions for Class III implantable blood pumps. Thirteen credibility factors were evaluated against Model Risk Level 5 requirements. Seven factors received formal assessment; six were flagged as epistemic gaps. Monte Carlo uncertainty quantification was performed across operating-point variability. Despite identified gaps, the assessment team concluded that the model achieves sufficient credibility for the bounded scope of use described in supporting documentation. All factor levels are reported relative to ASME V&V 40-2018 gradation scales.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-cfd-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-claim-001",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset",
    "https://uofa.net/synth/data/fda-pump-hemolysis-bench-dataset"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-global-index-001",
      "type": "ValidationResult",
      "name": "Global hemolysis index validation against FDA pump bench data"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv-001",
      "type": "ValidationResult",
      "name": "Velocity field comparison against PIV measurements in pump volute"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041497",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-computational-biofluidics-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f8c2d1e7b04596fa12cd3e8b7a0f5d2c9e1b6a4d7f3c0e8b2a5d9f1c4e7b3a",
  "signature": "ed25519:b1d4e7a2f5c8b3e6a9d2f5c8b1e4a7d0f3c6b9e2a5d8f1c4b7e0a3d6f9c2b5e8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; independent code review completed.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and regression tests exist for canonical flows, but the test suite does not specifically cover high-shear hemolysis regimes. Independent code review was not completed for the hemolysis sub-model. Achieved level falls one gradation below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests performed for all governing equations including hemolysis transport; method of manufactured solutions applied.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver and confirmed second-order spatial accuracy. However, the power-law hemolysis transport equation was not subjected to manufactured solution testing. Partial verification limits achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on at least three systematically refined meshes; Richardson extrapolation applied.",
      "rationale": "Three mesh refinement levels were evaluated (4M, 12M, 36M cells). Richardson extrapolation yielded GCI of 8.3% for the normalized hemolysis index, exceeding the 5% threshold. Spatial discretization error remains a non-trivial contributor to total uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; operating points span the intended clinical flow range; fluid properties match physiological blood.",
      "rationale": "FDA benchmark experiments used saline-glycerol analogue fluid rather than whole blood, introducing non-Newtonian rheology differences. Operating points cover nominal VAD flow rates but do not include off-design low-flow conditions relevant to clinical use. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms) below 15% for hemolysis index across all validation operating points; statistical comparison accounts for experimental uncertainty.",
      "rationale": "Root-mean-square error for the normalized index of hemolysis across five operating points was 18.4%, exceeding the 15% threshold. Trend agreement is qualitatively good but absolute magnitude prediction remains outside the acceptance band at two operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest directly map to clinical hemolysis endpoints; linkage between NIH and model QoI is formally documented.",
      "rationale": "The model predicts a power-law hemolysis index that correlates with normalized index of hemolysis (NIH) but the formal mapping to plasma-free hemoglobin thresholds used in device labeling is not documented. The QoI relevance linkage is implicit rather than formally established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on geometry and at operating conditions representative of the target VAD device class; biological fluid used.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is a reasonable surrogate for the target device class. However, the pump geometry differs from the specific commercial VAD design, and saline-glycerol was used instead of blood. Relevance is moderate, supporting level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals documented below 1e-6 for all equations; floating-point round-off analysis performed; solver error separated from discretization error.",
      "rationale": "Iterative convergence was monitored but residual targets were set at 1e-4 for the hemolysis scalar equation. Formal separation of solver error from discretization error was not performed. This factor is flagged as an epistemic gap at MRL 5 and is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification documented; sensitivity of results to analyst choices (mesh topology, boundary condition specification) quantified.",
      "rationale": "No formal user qualification protocol was applied. Sensitivity to analyst-driven choices in mesh topology and turbulence model wall treatment was not systematically evaluated. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mechanistic justification for power-law hemolysis model provided; alternative model forms evaluated; model form uncertainty quantified relative to QoI.",
      "rationale": "The Giersiepen-Wurzinger power-law model was selected based on historical precedent without formal comparison to alternative mechanistic hemolysis models (e.g., strain-based or energy dissipation models). Model form uncertainty is the dominant unquantified uncertainty source at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; Monte Carlo propagation performed; sensitivity indices computed for top inputs.",
      "rationale": "Monte Carlo uncertainty quantification was performed for rotational speed and inlet flow rate. However, the hemolysis model coefficients (C, alpha, beta) were treated as deterministic point estimates despite known variability in the literature. Input characterization is incomplete for MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient for statistical characterization of hemolysis variability; inter-laboratory reproducibility demonstrated.",
      "rationale": "The FDA benchmark dataset provides single-laboratory measurements without inter-laboratory reproducibility data for hemolysis. Sample sizes for hemolysis measurements were not reported with statistical power analysis. This factor cannot be assessed from available data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument between simulation input parameters and physical experimental conditions; boundary condition uncertainty propagated.",
      "rationale": "Boundary conditions were set to nominal experimental values without formal equivalency documentation. Inlet velocity profiles were assumed uniform rather than measured. No uncertainty propagation from experimental boundary condition specification to QoI was performed. Flagged as epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all thirteen credibility factors, the assessment team accepted the model for the intended application scope described in supporting study documentation. Seven factors were formally assessed; while all achieved levels fall below required levels for MRL 5, the team determined that the identified gaps are bounded by the operating conditions evaluated and that the model provides sufficient predictive fidelity for comparative design screening purposes. Six factors were not assessed and represent acknowledged epistemic gaps. The team notes that the model has been applied in clinical research to support pump design iteration and that the accumulated evidence base, while incomplete against strict MRL 5 criteria, supports a conditional acceptance for the scope implicitly defined by prior use. Formal re-assessment is recommended prior to any regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
