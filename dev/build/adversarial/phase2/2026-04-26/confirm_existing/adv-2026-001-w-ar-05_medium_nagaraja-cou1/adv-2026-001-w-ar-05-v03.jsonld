  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-uofa",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-requirement factor (Test conditions, achieved 2 vs. required 3) is mitigated by the strong inter-laboratory agreement across N=11 specimens and the conservatism of the ASTM F1717 test protocol. All three QoIs satisfy the pre-established acceptance bounds (E/uval < 1.96; percentage difference < 10%). The FEA modeling framework is accepted as credible for the declared COU at Medium model risk.",
    "decidedAt": "2026-04-19T00:00:00Z"
