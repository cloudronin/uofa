    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Global Richardson extrapolation GCI < 5% for all three QoIs; mesh convergence demonstrated across three refinement levels.",
      "rationale": "Three mesh densities (coarse ~180k, medium ~420k, fine ~910k elements) evaluated. GCI for stiffness 1.8%, yield force 2.4%, force at 40 mm 3.1%. All below 5% threshold. Medium mesh selected for production runs balancing accuracy and runtime."
