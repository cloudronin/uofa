    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge to < 1e-6 relative tolerance; contact penetration < 0.1 mm at all interfaces.",
      "rationale": "Direct sparse solver (SPARSE) used for linear steps; PCG with 1e-8 tolerance for nonlinear increments. Maximum contact penetration observed 0.04 mm at screw-vertebral body interface. Force residual norm < 1e-7 at all converged increments. Exceeds required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
