  "signature": "ed25519:9a2b4c6d8e0f1a3b5c7d9e1f2a4b6c8d0e2f4a6b8c0d2e4f6a8b0c2d4e6f8a0b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software used under documented quality management system with version control and audit trail.",
      "rationale": "Ansys Mechanical 2021 R2 operated under FDA CDRH QMS procedures; DePuy Synthes in-house solver under ISO 13485-compliant quality system. Version logs and change records reviewed and confirmed compliant at required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions demonstrate solver correctness for linear elastic and contact formulations.",
      "rationale": "Standard NAFEMS benchmarks for static structural analysis and Hertzian contact were executed. All results within 1% of analytical reference. Code verification documented in solver qualification report QR-2021-047."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinements.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw shank and screw-rod interface. Stiffness QoI changed by 0.8% between medium and fine mesh; yield force QoI changed by 1.1%. Richardson extrapolation confirmed GCI < 1.5% at the fine mesh level. Discretization error deemed acceptable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge below 1e-6 for all load steps; no spurious contact oscillations.",
      "rationale": "Force and displacement residuals converged to 1e-8 for all 12 load increments. Augmented Lagrange contact formulation showed no penetration exceeding 0.5 micrometers. Solver error contribution to QoI uncertainty estimated at <0.3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup; boundary conditions and load application verified against ASTM F1717 protocol.",
      "rationale": "A second analyst independently reconstructed boundary conditions from the ASTM F1717-15 standard and compared against the simulation setup. No discrepancies identified in constraint definitions, load application points, or material assignments. Use error risk rated low."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model captures elastic-plastic titanium alloy response; contact formulation appropriate for screw-rod interface; geometric nonlinearity enabled.",
      "rationale": "Ti-6Al-4V modeled with bilinear isotropic hardening calibrated to ASTM E8 coupon data from the same material lot. Large-deformation formulation (NLGEOM) enabled. Screw-rod locking mechanism represented by frictional contact (mu=0.2). Model form assessed as appropriate for the compression-bending regime addressed by ASTM F1717."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from measurements on the same device lot used in bench testing; input uncertainty quantified.",
      "rationale": "Elastic modulus, yield strength, and ultimate strength measured from five tensile coupons machined from the same Ti-6Al-4V bar stock as the test constructs. Outer diameter and thread geometry measured via CMM on three screws. Input uncertainty propagated via Monte Carlo (N=1000) contributing ±2.1% to stiffness QoI and ±1.8% to yield force QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 experimental constructs from production lot; inter-laboratory consistency verified.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA CDRH and DePuy Synthes). All constructs from the same production lot. Inter-laboratory CV for stiffness was 3.2%, for yield force 2.9%, confirming reproducibility. Sample size exceeds the minimum for the declared credibility level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of physiologically relevant loading rates and environmental conditions relevant to in vivo use.",
      "rationale": "All bench tests conducted under a single condition: quasi-static 1 mm/min crosshead displacement in ambient air at 23°C. ASTM F1717 does not require physiological temperature or fluid environment; however, the COU encompasses implant performance under in vivo conditions where temperature and fluid exposure may alter interface friction and material response. Only one test condition was evaluated, limiting the ability to assess condition-dependent variability. This factor is assessed below required level and is documented as a known limitation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters (geometry, material, boundary conditions) demonstrably equivalent to those of the physical test constructs.",
      "rationale": "Screw geometry in FEA derived from CAD nominal with CMM-verified dimensional deviations applied as perturbations. Material inputs matched to coupon measurements from the same lot. UHMWPE block stiffness in FEA matched to measured block compression modulus. Boundary condition equivalency confirmed by independent review. No systematic offset identified between simulation inputs and physical test configuration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all three QoIs; all values below 1.96 threshold; percent difference below 10%.",
      "rationale": "E/uval computed for stiffness (1.41), yield force (1.18), and force at 40 mm displacement (0.89). All three below the 1.96 acceptance threshold. Percent differences are 6.3%, 4.8%, and 4.7% respectively, all below the 10% bound. Comparison methodology follows ASME V&V 40-2018 Section 5.3. The experimental reference dataset used for this comparison originates from the Nagaraja et al. programme conducted under ASTM F1717 quasi-static protocol at ambient conditions; the same dataset underpins the primary validation result."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are mechanistically linked to the failure modes and performance requirements specified in the COU.",
      "rationale": "Construct stiffness governs load sharing with the vertebral column; yield force defines the onset of permanent deformation that may compromise fixation; force at 40 mm displacement characterizes post-yield energy absorption relevant to catastrophic failure. All three QoIs are directly referenced in FDA guidance for spinal fixation system submissions. Relevance to the declared COU is rated high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, loading mode, and device configuration match the COU device and intended use conditions.",
      "rationale": "Validation uses the identical non-cannulated 7.5 mm pedicle screw design, ASTM F1717 compression-bending loading mode, and UHMWPE surrogate block as specified in the COU. The FEA ensemble covers the same geometric and material parameter space. Validation activities are assessed as directly relevant to the COU, with the noted limitation on single test condition addressed under the Test conditions factor."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-cdrh",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed the required level for a Medium model risk, Medium decision consequence context of use. The single below-requirement factor (Test conditions) is documented and accepted on the basis that ASTM F1717 does not mandate physiological environment and that the quasi-static ambient condition is the regulatory standard for this device class. All three QoIs satisfy the pre-specified quantitative acceptance bounds. The FEA framework is accepted as sufficiently credible to support the regulatory submission for the non-cannulated 7.5 mm pedicle screw construct.",
