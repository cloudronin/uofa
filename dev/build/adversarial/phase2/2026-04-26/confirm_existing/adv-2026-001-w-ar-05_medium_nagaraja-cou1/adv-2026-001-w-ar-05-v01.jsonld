  "hasContextOfUse": {
    "decisionConsequence": "Medium",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "deviceClass": "Class II",
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary QoI agreement — stiffness and yield force",
      "description": "FEA-predicted construct stiffness and yield force were evaluated against the experimental ensemble. Mean FEA stiffness deviated by 6.3% from the experimental mean; yield force deviated by 4.8%. Both values fall within the pre-specified 10% acceptance bound. The normalized error metric E/uval was computed as 1.41, below the 1.96 threshold. Experimental data from the Nagaraja et al. cadaveric-surrogate bench programme (UHMWPE block, room-temperature phosphate-buffered saline, quasi-static 1 mm/min crosshead rate) served as the reference dataset for this comparison. Agreement across both participating laboratories was consistent, with inter-laboratory coefficient of variation below 4% for all three QoIs. The validation team concluded that the FEA framework adequately reproduces the physical response for the declared context of use."
    },
    {
      "id": "https://uofa.net/synth/validation/force-at-40mm",
      "type": "ValidationResult",
      "name": "Force at 40 mm displacement — supplementary check",
      "description": "Force at 40 mm displacement was predicted at 312 N (FEA ensemble mean) versus 298 N experimental mean, a 4.7% difference. E/uval = 0.89. This QoI provides supplementary confidence that large-deformation post-yield behavior is captured adequately.",
      "comparedAgainst": "https://uofa.net/synth/data/nagaraja-bench-n11-twolabs"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4023224",
