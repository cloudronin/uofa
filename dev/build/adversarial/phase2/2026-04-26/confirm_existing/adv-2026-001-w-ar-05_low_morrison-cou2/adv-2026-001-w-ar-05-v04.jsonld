  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation evidence on the basis that mean NIH prediction error is below 5% relative to the available steady-state experimental datasets (Fraser 2011, Hariharan 2011) and that Monte Carlo uncertainty quantification has been performed. The team noted that validation was conducted under steady-state conditions while the COU requires pulsatile flow, but judged this mismatch to be acceptable given the absence of pulsatile experimental hemolysis data in the literature and the favorable steady-state agreement. This reasoning constitutes an undercutting inference-method mismatch (D3): agreement under a different flow regime does not support the inference that the model is credible for the declared pulsatile VAD context. Multiple credibility factors remain below required levels and one validation result lacks a comparedAgainst link, but these gaps were not treated as disqualifying.",
