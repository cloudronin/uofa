  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis output comparison — steady-state surrogate (W-AR-05 trigger)",
      "description": "The CFD-predicted normalized index of hemolysis (NIH) values were compared against in vitro measurements from the FDA generic centrifugal pump steady-state test campaign. Agreement within 18% was observed across three fixed operating points (3 L/min at 2500 RPM, 5 L/min at 2500 RPM, 6 L/min at 3000 RPM). However, the COU requires validation under pulsatile flow conditions spanning five flow-speed combinations representative of VAD operation, where instantaneous shear stress histories differ substantially from steady-state profiles. The comparator dataset — acquired under constant impeller speed and non-pulsatile inlet flow — does not reproduce the cyclic loading experienced by red blood cells in the VAD operating envelope. This mismatch means the inference from steady-state validation agreement to pulsatile hemolysis prediction is unsupported; the validation evidence undercuts rather than supports the credibility claim for the declared COU. NOTE: comparedAgainst link is absent from this result object, constituting the W-AR-05 rule-detection surface."
    },
    {
