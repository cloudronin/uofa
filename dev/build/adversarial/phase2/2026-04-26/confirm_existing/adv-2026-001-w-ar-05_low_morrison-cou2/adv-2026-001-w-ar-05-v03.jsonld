  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis validation — steady-state mock-loop (comparator link absent)",
      "description": "The CFD hemolysis index predictions were compared against measurements from the FDA generic centrifugal pump steady-state mock-loop experiment (Hariharan et al. 2011, ASAIO J). Five operating points at constant impeller speed and constant flow rate were evaluated. Predicted normalised index of hemolysis (NIH) values agreed with measured values within 18% across all points. However, the COU specifies pulsatile VAD operating conditions with time-varying inlet flow waveforms; the steady-state experimental regime does not replicate the transient shear-stress history that drives hemolysis in clinical VAD use. This mismatch constitutes an inference-method undercutting defeater (D3): the experimental comparator addresses a structurally different flow regime than the declared COU, so agreement under steady-state conditions does not support the claim under pulsatile conditions. NOTE: the comparedAgainst link to the underlying dataset is intentionally absent from this result object, triggering W-AR-05."
    },
    {
      "id": "https://uofa.net/synth/validation/steady-state-secondary",
      "type": "ValidationResult",
      "name": "Secondary validation — steady-state dataset cross-reference (regime mismatch explicit)",
      "description": "Secondary result retaining the comparedAgainst link to make the steady-state regime mismatch with the pulsatile COU machine-readable. The referenced dataset covers only constant-speed, constant-flow operating points. The COU requires pulsatile inlet waveforms at 60–120 bpm cardiac cycles. Validation under steady-state conditions undercuts the inferential chain: steady-state shear-stress distributions differ systematically from time-averaged pulsatile shear histories, and hemolysis models calibrated on one regime cannot be extrapolated to the other without additional evidence.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-generic-pump-steady-state-mock-loop"
