    "name": "COU1: Cardiopulmonary bypass use (Class II)"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-rh-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against FDA benchmark data",
      "description": "CFD-predicted relative hemolysis index (RH) compared against in-vitro experimental measurements from the FDA generic centrifugal pump benchmark. All 5 flow-speed operating points yielded RH < 1.0, satisfying the acceptance criterion. Mean normalized index of hemolysis error was 12.3%, within the pre-specified 15% tolerance band."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence verification for centrifugal pump CFD",
      "description": "Three mesh refinement levels (coarse: 1.2M, medium: 4.8M, fine: 19.2M cells) demonstrated grid convergence index (GCI) below 2.5% for all quantities of interest including wall shear stress and velocity magnitude at impeller exit plane."
    }
  ],
