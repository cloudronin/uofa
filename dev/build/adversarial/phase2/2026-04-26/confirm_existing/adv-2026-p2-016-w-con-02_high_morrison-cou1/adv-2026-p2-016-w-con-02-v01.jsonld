  "signature": "ed25519:b2d4e6f8a0c1e3f5b7d9a2c4e6f8b0d2f4a6c8e0b2d4f6a8c0e2f4b6d8a0c2e4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version controlled; regression test suite executed with zero failures; ANSYS Fluent 2023R2 certified for biofluid applications.",
      "rationale": "The CFD solver (ANSYS Fluent 2023R2) is under formal version control. A regression test suite of 47 benchmark cases was executed prior to this analysis, with all cases passing within specified tolerances. Software qualification documentation is archived in the project repository."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to Navier-Stokes solver; observed order of accuracy within 10% of theoretical order.",
      "rationale": "MMS verification was performed on the incompressible Navier-Stokes solver using polynomial manufactured solutions. Observed spatial order of accuracy was 1.94 (theoretical: 2.0), confirming correct implementation of the second-order finite volume discretization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI on three systematically refined meshes.",
      "rationale": "Three meshes (2.1M, 6.4M, 18.9M cells) were evaluated at the worst-case operating point (4 L/min, 2400 RPM). GCI for the normalized hemolysis index was 2.3%, exceeding the MRL 2 requirement. The 6.4M cell mesh was selected for production runs as the optimal accuracy-cost tradeoff."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid viscosity, temperature) documented and traceable; uncertainty quantified for each condition.",
      "rationale": "All five experimental operating points were conducted using bovine blood with hematocrit 33±2%, temperature 37±0.5°C, and flow rates verified by calibrated Coriolis flowmeter (±0.5%). Rotational speed was encoder-verified to ±5 RPM. Full uncertainty budget is documented in the test report TR-CPB-2023-07."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement (d) ≥ 0.85 between CFD-predicted and experimentally measured hemolysis index across all 5 operating points.",
      "rationale": "The normalized index of agreement d = 0.91 was achieved across the five operating points. Maximum absolute error in predicted hemolysis index was 8.4% relative to experimental mean, within the ±15% acceptance band. CFD systematically underpredicts at the lowest flow rate (2 L/min), which is conservative for the worst-case identification objective."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (normalized hemolysis index NH) directly maps to the regulatory acceptance criterion (RH < 1); secondary QoIs (shear stress distribution, exposure time) are physically linked to hemolysis mechanism.",
      "rationale": "The normalized hemolysis index NH computed from CFD power-law integration is directly used to compute the relative hemolysis index RH against the predicate device. The power-law exponents applied in this analysis are those reported in the primary methodology reference (https://doi.org/10.1016/j.ymeth.2024.03.003), which provides updated empirical fits to human erythrocyte fragility data. Secondary QoIs (volume-averaged shear stress, Lagrangian exposure time histograms) provide mechanistic corroboration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on geometrically identical pump at COU-representative flow rates and rotational speeds; blood analogue fluid properties within 10% of clinical values.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry identical to the simulation domain. Operating conditions span the full COU envelope (2–6 L/min, 1800–2400 RPM). Bovine blood was used as the test fluid; viscosity and density were within 8% of clinical human blood values at 37°C, satisfying the 10% relevance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance at Gradation 1.",
      "rationale": "At Model Risk Level 2, numerical solver error beyond code verification is not required to be formally assessed. Iterative convergence was monitored (residuals < 1e-5 for all equations) and mass imbalance < 0.01%, providing sufficient confidence for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualifications documented.",
      "rationale": "Formal use error assessment is not required at MRL 2. The lead analyst holds a PhD in computational fluid dynamics with 8 years of experience in cardiovascular device simulation. Analysis was independently reviewed by a senior engineer prior to submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison to experimental velocity fields; non-Newtonian blood rheology model validated against viscometry data.",
      "rationale": "The SST k-omega turbulence model was selected based on published benchmark comparisons for rotating blood pump geometries. The Carreau-Yasuda non-Newtonian viscosity model was fit to rheometry data for bovine blood at 37°C (R² = 0.997). Sensitivity analysis showed < 3% change in hemolysis index when switching between Carreau-Yasuda and power-law viscosity models."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input parameters documented with nominal values and sources.",
      "rationale": "All model inputs (geometry, boundary conditions, fluid properties) are documented in the simulation specification SS-CPB-2023-02. Formal uncertainty propagation through model inputs is not required at MRL 2 and has not been performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
