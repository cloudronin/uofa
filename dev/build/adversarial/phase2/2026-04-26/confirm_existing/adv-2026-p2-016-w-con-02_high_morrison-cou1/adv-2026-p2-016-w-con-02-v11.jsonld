  ],
  "referencesIdentifier": "https://doi.org/10.1016/j.ymeth.2024.03.003",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-independence-001",
      "type": "ValidationResult",
      "name": "Mesh independence study — FDA generic centrifugal blood pump",
      "description": "Three-level mesh refinement study (coarse 2.1M, medium 5.4M, fine 11.8M elements) demonstrated GCI < 2.3% for wall shear stress and < 1.8% for bulk velocity at all five operating points. Richardson extrapolation confirms discretization error is within acceptable bounds for MRL 2."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-benchmark-001",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against FDA benchmark experimental data",
      "description": "Predicted normalized index of hemolysis (NIH) compared against published FDA experimental measurements across 5 flow-speed combinations. Mean absolute relative error 8.4%, maximum 14.1%. All predictions satisfy RH < 1 acceptance criterion relative to predicate device. Validation conducted at the system response quantity level consistent with ASME V&V 40 Section 5."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-turbulence-sensitivity-001",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-omega vs realizable k-epsilon",
      "description": "Sensitivity study comparing SST k-omega and realizable k-epsilon turbulence closures. Hemolysis index predictions differ by less than 6% across all operating points. SST k-omega selected as primary model based on superior near-wall resolution and established precedent in cardiovascular CFD literature."
    }
  ],
