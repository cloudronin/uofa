  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2023 R2) used with documented version control and audit trail. MRL 2 requires Gradation 1 (documented software); Gradation 2 achieved through additional regression testing log.",
      "rationale": "ANSYS Fluent 2023 R2 is a commercially validated solver with documented QA procedures. Internal regression test suite executed prior to simulation campaign with all 847 test cases passing. Version control maintained via Git repository with tagged release. Exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against analytical solutions for Poiseuille flow and rotating cavity benchmarks. MRL 2 requires Gradation 1; Gradation 2 achieved through additional manufactured solution verification.",
      "rationale": "Code verification performed using method of manufactured solutions for the incompressible Navier-Stokes equations with rotating reference frame. Observed order of accuracy 1.94 (expected 2.0 for second-order scheme), confirming correct implementation. Poiseuille flow benchmark error < 0.01%. Results consistent with ASME V&V 20 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for primary quantities of interest (NIH, wall shear stress) across all operating points. Richardson extrapolation applied to three-level mesh refinement study.",
      "rationale": "Three-level mesh refinement study conducted per ASME V&V 20. GCI values: NIH 2.1% (coarse-medium) and 1.4% (medium-fine); wall shear stress 2.3% and 1.6% respectively. Monotonic convergence confirmed at all five operating points. Medium mesh (5.4M elements) selected for production runs balancing accuracy and computational cost. Discretization error within MRL 2 acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid viscosity, temperature) documented and replicated in CFD boundary conditions within ±5% tolerance. MRL 2 requires Gradation 2; Gradation 3 achieved through independent measurement uncertainty quantification.",
      "rationale": "FDA benchmark experimental conditions replicated with documented boundary conditions: flow rates 2.5–7.0 L/min (±2.1%), rotational speeds 2000–3500 RPM (±0.3%), fluid temperature 37°C (±0.5°C), blood analog viscosity 0.0035 Pa·s (±1.8%). Inlet velocity profiles derived from upstream pipe flow measurements. Uncertainty propagation performed per GUM methodology. Test conditions exceed MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values compared against experimental measurements using area validation metric. Mean absolute relative error < 15% across all operating points. Statistical comparison accounts for experimental measurement uncertainty (CV < 12%).",
      "rationale": "Quantitative comparison of predicted versus measured NIH performed at all five operating points. Mean absolute relative error 8.4%, maximum 14.1%, both within the 15% acceptance threshold. Experimental coefficient of variation 9.3% (n=5 replicates per condition). Area validation metric u_val = 0.83, indicating model predictions within experimental uncertainty band at 4 of 5 operating points. Output comparison criterion satisfied at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH, relative hemolysis index RH) directly maps to clinical endpoint (hemolysis) and regulatory acceptance criterion (RH < 1). Linkage between computational QoI and device performance metric documented.",
      "rationale": "The normalized index of hemolysis (NIH) is the established regulatory QoI for blood pump hemolysis assessment per FDA guidance. The relative hemolysis index RH = NIH_device / NIH_predicate provides direct comparison to predicate device performance. Power-law damage accumulation model (Giersiepen-Wurzinger formulation, with coefficients from the primary methodological reference at referencesIdentifier) links local shear stress history to erythrocyte lysis probability. QoI relevance to COU confirmed at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted on FDA generic centrifugal blood pump geometry under operating conditions spanning the COU envelope (2.5–7.0 L/min, 2000–3500 RPM). Geometric and operational similarity to CPB device class documented.",
      "rationale": "Validation performed on the FDA-specified generic centrifugal blood pump, which represents the reference geometry for Class II CPB device evaluation. Operating envelope covers the full range of clinically relevant CPB flow rates and speeds. Fluid properties (blood analog) match COU conditions. Validation activities are directly relevant to the COU without requiring extrapolation beyond validated envelope. Gradation 2 criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated with residuals < 1e-5 for continuity and momentum equations. Mass imbalance < 0.01% at inlet/outlet boundaries.",
      "rationale": "All simulations converged with scaled residuals below 1e-5 for continuity, momentum, and turbulence quantities. Mass imbalance monitored at inlet and outlet boundaries: maximum observed imbalance 0.003%. Convergence monitored via area-weighted average NIH at pump outlet, which stabilized to within 0.1% change over final 500 iterations. Solver error criterion met at Gradation 1, satisfying MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2. Gradation 1 (awareness of potential use errors) sufficient for current model risk level.",
      "rationale": "At MRL 2, formal use error assessment is not required. Simulation workflow executed by PhD-level engineers with documented CFD competency. Standard operating procedures followed for boundary condition setup, mesh generation, and post-processing. Peer review of simulation setup performed by independent team member. Use error factor acknowledged but not formally assessed per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified through sensitivity study. Hemolysis damage model form (power-law) supported by literature and validated against erythrocyte fragility data. Model form uncertainty estimated and documented.",
      "rationale": "Reynolds-averaged Navier-Stokes with SST k-omega turbulence closure selected based on established performance for rotating machinery with adverse pressure gradients. Turbulence model sensitivity study (SST k-omega vs realizable k-epsilon) shows < 6% variation in NIH predictions. Power-law hemolysis damage accumulation model (Giersiepen-Wurzinger) is the de facto standard for CFD hemolysis prediction; model coefficients sourced from the methodological reference identified in referencesIdentifier, which provides updated regression fits to expanded erythrocyte fragility datasets. Model form uncertainty estimated at ±12% based on coefficient confidence intervals. Gradation 2 criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, boundary conditions, material properties, damage model coefficients) documented with sources and uncertainty estimates. Sensitivity of QoI to input uncertainty evaluated.",
      "rationale": "Complete input inventory documented: pump geometry from FDA-published CAD files (dimensional tolerance ±0.05 mm), boundary conditions from experimental measurements (uncertainty per GUM), blood analog properties from supplier certificates (viscosity ±1.8%), damage model coefficients from primary methodological reference (95% CI documented). One-at-a-time sensitivity analysis identifies rotational speed and inlet flow rate as dominant inputs (combined 73% of NIH variance). Model inputs factor exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2. Test sample characterization at Gradation 1 (documented sample provenance) sufficient for current model risk level.",
      "rationale": "Blood analog fluid (glycerin-water mixture, 36% v/v) prepared per ASTM F1841 with documented lot traceability. Pump test specimens manufactured to FDA generic geometry specifications with dimensional inspection records. Formal statistical characterization of sample variability not required at MRL 2. Test samples factor acknowledged at Gradation 1 per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2. Gradation 1 (qualitative equivalency argument) sufficient for current model risk level.",
      "rationale": "Qualitative equivalency established between validation test conditions (FDA generic centrifugal blood pump, blood analog fluid) and COU conditions (Class II CPB device, patient blood). Reynolds number similarity maintained across operating envelope. Fluid property differences (blood analog vs whole blood) acknowledged; established literature precedent supports use of blood analog for hemolysis index prediction in this flow regime. Equivalency of input parameters factor not formally assessed per MRL 2 scoping; qualitative argument documented."
    }
  ],
