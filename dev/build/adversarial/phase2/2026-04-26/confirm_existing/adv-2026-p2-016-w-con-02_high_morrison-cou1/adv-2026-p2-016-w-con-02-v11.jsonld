  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately scoped out at MRL 2 with qualitative documentation. Quantitative validation against FDA benchmark experimental data demonstrates mean absolute relative error of 8.4% in NIH predictions, within the 15% acceptance threshold. Mesh convergence confirmed with GCI < 2.3%. The relative hemolysis index RH < 1 criterion satisfied at all five operating points. The computational model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device within the defined COU envelope. Minor uncertainty in power-law damage model coefficients (sourced from primary methodological reference) is acknowledged and bounded within the 15% output comparison tolerance. Decision: Accepted at Medium assurance level.",
