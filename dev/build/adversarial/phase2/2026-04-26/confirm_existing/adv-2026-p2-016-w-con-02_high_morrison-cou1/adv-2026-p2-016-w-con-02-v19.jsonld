  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. Six factors not assessed are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. RH < 1.0 achieved across all five operating points with maximum hemolysis index error of 13.7 %, within the 15 % acceptance criterion. Grid convergence, model form sensitivity, and input uncertainty analyses all demonstrate adequate credibility for the intended CPB use. The assessment team concludes the CFD model is sufficiently credible to support identification of worst-case hemolysis operating conditions for the Class II CPB device.",
