  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and version control; solver verification tests pass.",
      "rationale": "ANSYS Fluent 2023 R1 used under ISO 9001-certified QA plan. Solver regression test suite executed; all 312 benchmark cases pass within tolerance. Software version locked for the study duration. Exceeds MRL 2 requirement of Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for Navier-Stokes solver demonstrated on canonical flows relevant to rotary blood pump physics.",
      "rationale": "Method of manufactured solutions applied to lid-driven cavity and rotating annulus cases. Observed order of accuracy 1.97 (second-order scheme confirmed). Scalar transport hemolysis equation verified against analytical solution for simple shear flow. Results consistent with multi-laboratory benchmark reported in the methodology reference archived at https://doi.org/10.1016/j.ymeth.2024.03.003."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5 % for primary QoI (hemolysis index) across at least three mesh levels.",
      "rationale": "Three mesh levels: 4.2 M, 12.6 M, and 37.8 M cells. GCI for integrated hemolysis index: 3.8 % (coarse-to-medium) and 1.6 % (medium-to-fine). Asymptotic convergence ratio 0.97 confirms solution in asymptotic range. Boundary layer y+ < 1 maintained on all wetted surfaces. Meets and exceeds MRL 2 Gradation 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match simulation boundary conditions within stated uncertainty bounds.",
      "rationale": "FDA benchmark experimental data acquired at 2, 3, 4, 5, and 6 L/min at 2400 and 3500 RPM. Blood analogue fluid (36 % glycerol-water) properties matched to within 1.2 % viscosity and 0.4 % density. Inlet velocity profiles from PIV measurements used as boundary conditions. Temperature maintained at 37 ± 0.5 °C in both experiment and simulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated hemolysis index within 15 % of experimental measurements; pressure rise within 5 % across all operating points.",
      "rationale": "Mean absolute percentage error for hemolysis index: 8.3 % across all five operating points. Pressure rise MAPE: 3.1 %. Worst-case single-point hemolysis error: 13.7 % at 6 L/min, 3500 RPM (within acceptance criterion). Velocity field comparison via PIV shows qualitative agreement in jet-wake structure. Exceeds Gradation 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (relative hemolysis index RH) directly maps to clinical hemolysis endpoint; secondary QoIs (shear stress, exposure time) mechanistically linked.",
      "rationale": "RH is a dimensionless ratio of device-induced hemolysis to predicate device hemolysis, directly interpretable as clinical acceptability. Power-law damage accumulation model (Giersiepen exponents) links shear stress magnitude and exposure time to plasma-free haemoglobin release. QoI selection follows FDA guidance and the comparative framework documented in the methodology reference at https://doi.org/10.1016/j.ymeth.2024.03.003, which is the primary methodological anchor for exponent selection in this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, flow regime, and fluid properties sufficiently similar to the COU device to support credibility inference.",
      "rationale": "Validation performed on FDA generic centrifugal pump — same device family as the CPB pump under assessment. Reynolds number range (Re 2000–8000) overlaps COU operating envelope. Blood analogue fluid validated as representative for hemolysis scaling. Geometric similarity ratio 0.94 between validation pump and COU device impeller diameter. Validation scope judged sufficient for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated; residuals below 1e-5 for continuity and momentum; mass imbalance < 0.01 %.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and 1e-7 for momentum components. Mass imbalance < 0.005 % in all cases. Sliding mesh interface conservation verified. Meets MRL 2 Gradation 1 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; scoped assessment confirms no user-introduced errors in boundary condition setup.",
      "rationale": "At MRL 2, Gradation 1 for use error is satisfied by documented simulation setup procedures and independent peer review of boundary condition files. Two-person review of all case setup files completed; no discrepancies identified. Formal use-error assessment not required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model selected with justification; sensitivity to model form alternatives documented.",
      "rationale": "SST k-omega turbulence model selected based on prior benchmark performance for rotating machinery flows. Sensitivity study comparing SST k-omega, realizable k-epsilon, and RSM: maximum RH variation 6.2 %, within acceptance envelope. Power-law hemolysis exponents (alpha = 0.785, beta = 2.416) from Giersiepen correlation; sensitivity to Heuser-Opitz exponents also evaluated (RH variation < 4 %). Model form uncertainty quantified and acceptable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in key model inputs (fluid viscosity, rotational speed, inlet flow rate) propagated to output QoI; total input uncertainty contribution < 10 % of QoI.",
      "rationale": "Monte Carlo propagation (N = 500) of viscosity (±2 %), rotational speed (±0.5 %), and flow rate (±1 %) uncertainties. 95th-percentile RH uncertainty contribution: 4.8 %. Geometric tolerance sensitivity (±0.05 mm on clearance gaps) adds 3.1 % to RH uncertainty. Combined input uncertainty well within acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental data sourced from FDA public benchmark repository with documented sample provenance.",
      "rationale": "Experimental hemolysis data from FDA generic pump benchmark programme (n = 3 independent test runs per operating point). Sample preparation and measurement protocols documented in FDA benchmark report. Formal test-sample credibility assessment not required at MRL 2; provenance documentation judged sufficient."
    },
    {
      "factorStandard": "ASME-VV40-2018",
