  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 1. The CFD model demonstrates sufficient credibility to support the regulatory decision that the centrifugal blood pump design meets the RH < 1 hemolysis acceptance criterion under worst-case CPB operating conditions. The systematic hemolysis over-prediction bias of 8.3% is conservative with respect to the acceptance criterion and does not undermine the credibility conclusion. Supporting methodology for the hemolysis damage accumulation integration scheme is documented with reference to published literature including the computational methods review at https://doi.org/10.1016/j.ymeth.2024.03.003, which details the scalar transport approach used for blood damage index calculation in this submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
