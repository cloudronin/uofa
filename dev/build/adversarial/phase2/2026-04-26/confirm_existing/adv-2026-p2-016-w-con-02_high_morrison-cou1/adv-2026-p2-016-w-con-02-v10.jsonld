      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be reproduced in simulation within ±5% for flow rate and rotational speed.",
      "rationale": "FDA benchmark experimental conditions (2.5 L/min at 2500 RPM, 3.5 L/min at 3500 RPM, and three additional operating points) were replicated in CFD with measured inlet velocity profiles. Flow rate agreement within 2.8%, rotational speed exact."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index RH must agree with experimental measurements within 20% across all five operating points.",
      "rationale": "Predicted RH values across all five flow-speed combinations showed mean absolute error of 11.4% relative to FDA experimental hemolysis data. All five operating points fell within the 20% acceptance band. Worst-case condition correctly identified as 2.5 L/min at 3500 RPM."
    },
    {
      "factorStandard": "ASME-VV40-2018",
