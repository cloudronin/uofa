    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must operate under a documented QA plan with version-controlled inputs and outputs traceable to simulation records.",
      "rationale": "ANSYS Fluent 2023 R1 was used under a site-validated QA plan conforming to FDA guidance on software used in regulatory submissions. Version control records, input decks, and post-processing scripts are archived in the institutional repository with SHA-256 checksums."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass published benchmark cases relevant to rotating turbomachinery flow at Reynolds numbers comparable to CPB operating conditions.",
      "rationale": "ANSYS Fluent has been verified against the ASME V&V 20 lid-driven cavity and backward-facing step benchmarks. Internal rotating-frame MRF verification against analytical Couette solutions confirmed discretisation accuracy within 0.8% for the Reynolds number range encountered in the GCBP impeller."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for wall shear stress and hemolysis index must be below 5% on the medium mesh used for production runs.",
      "rationale": "A three-level mesh refinement study (2.1 M, 5.8 M, 14.3 M cells) was conducted at the nominal operating point (5 L/min, 2500 RPM). GCI for the normalised hemolysis index was 2.3% between medium and fine meshes. The medium mesh was selected for production simulations, exceeding the required level by demonstrating Richardson-extrapolated convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match the simulated operating envelope within stated tolerances for flow rate (±5%), rotational speed (±2%), and fluid temperature (±1 °C).",
      "rationale": "FDA GCBP experimental data were collected at flow rates of 2.5, 5.0, and 7.0 L/min and rotational speeds of 2000 and 2500 RPM using bovine blood at 37 ± 0.5 °C. CFD boundary conditions replicate these values; deviations in flow rate were below 3% and in speed below 1%, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) must agree with experimental values within ±20% across all five validated operating points.",
      "rationale": "Predicted RH values ranged from 0.71 to 0.94 across the five operating points; experimental RH values ranged from 0.68 to 0.97. Maximum absolute deviation was 11.4%, and all predictions fell within the ±20% acceptance band. Bland-Altman analysis confirmed no systematic bias."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index, RH) must be directly linked to the regulatory acceptance criterion and to measurable clinical outcomes for CPB patients.",
      "rationale": "RH is the FDA-recommended scalar metric for comparing pump-induced hemolysis against a predicate device. It directly maps to plasma-free haemoglobin elevation, a clinically relevant marker of red cell damage during CPB. The QoI is therefore fully relevant to both the regulatory decision and the patient-safety context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, the same fluid analogue, and operating conditions within the COU envelope.",
      "rationale": "Validation was performed on the FDA GCBP geometry — the identical geometry used in the submission simulations — with bovine blood whose rheological properties were characterised to match human blood viscosity at 37 °C. All five COU operating points were included in the validation matrix, ensuring full coverage of the intended-use envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver error subsumed within code-verification and discretisation-error factors.",
      "rationale": "At Model Risk Level 2, explicit quantification of iterative solver residuals beyond standard convergence monitoring is not required. Residuals for continuity, momentum, and turbulence quantities were reduced by five orders of magnitude in all production runs, consistent with standard practice."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst competency is addressed through QA plan and peer-review records.",
      "rationale": "The simulation team holds documented CFD competency records. All simulation setups were independently reviewed by a second qualified analyst before submission. Formal use-error quantification is not mandated at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model and turbulence closure must be justified by literature evidence and sensitivity analysis demonstrating that model-form choices do not change the rank-ordering of worst-case operating conditions.",
      "rationale": "The Giersiepen–Wurzinger power-law hemolysis model with re-derived constants (primary empirical basis cited via referencesIdentifier, Fraser et al. 2024, Methods) was selected following a sensitivity study comparing three published constant sets. The SST k-ω turbulence closure was chosen based on documented superior performance for rotating internal flows. Sensitivity analysis confirmed that the rank-ordering of the five operating points by RH is invariant to the choice of constant set within published uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; input uncertainty is addressed qualitatively through boundary-condition sensitivity checks.",
      "rationale": "Inlet velocity profiles and fluid viscosity were varied ±10% in a one-at-a-time sensitivity study. RH predictions changed by less than 4%, confirming low sensitivity to plausible input uncertainty at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; sample variability addressed through use of mean experimental values with reported standard deviations.",
      "rationale": "FDA GCBP experimental data report mean RH with standard deviations across three replicate tests per operating point. These statistics were used directly in the output-comparison factor assessment. Formal sample-size adequacy analysis is not required at MRL 2."
    },
