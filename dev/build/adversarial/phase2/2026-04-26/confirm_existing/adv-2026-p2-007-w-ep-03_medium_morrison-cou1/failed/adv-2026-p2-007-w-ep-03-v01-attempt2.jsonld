  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2023 R2 is used under the organization's validated software management plan. Version-controlled configuration files and a regression test suite covering rotating-zone turbulent flows are maintained. Achieved level meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate order-of-accuracy convergence on canonical rotating-flow benchmarks.",
      "rationale": "Order-of-accuracy tests on the Taylor–Green vortex and lid-driven cavity confirm second-order spatial convergence. Code verification report CV-2024-003 is on file. Achieved level meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) for shear-stress QOI must be below 5% on the production mesh.",
      "rationale": "Three-level mesh refinement study (2.1 M, 5.8 M, 14.7 M cells) yields GCI of 3.2% for wall shear stress and 2.8% for pressure rise. Richardson-extrapolated values used as production estimates. Achieved level meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) must be reproduced in simulation within ±2% of measured values.",
      "rationale": "Inlet flow rates and impeller speeds from the FDA pump experimental dataset are imposed directly as boundary conditions. Fluid temperature was 37 °C ± 0.5 °C in experiments and matched in simulation. All five operating points are within tolerance. Achieved level meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index RH must agree with experimental values within ±15% across all five operating points.",
      "rationale": "RH predictions range from −8% to +11% relative to experimental measurements across the five flow-speed combinations. Mean absolute error is 6.3%. All points satisfy the ±15% acceptance band. Achieved level meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs (RH index, wall shear stress, exposure time) must directly map to clinically relevant hemolysis endpoints.",
      "rationale": "The relative hemolysis index RH is the regulatory acceptance criterion. Wall shear stress and scalar blood-damage exposure time are intermediate QOIs that feed the Giersiepen–Wurzinger hemolysis power-law model, which is the accepted mechanistic link to plasma-free hemoglobin. Relevance is well-established in the literature. Achieved level meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test cases must cover the operating envelope (flow 2–8 L/min, speed 2000–3500 RPM) and fluid properties representative of CPB conditions.",
      "rationale": "Validation uses the FDA generic centrifugal pump benchmark at five operating points spanning the CPB operating envelope. Bovine blood analogue at 37 °C with matched viscosity was used in experiments. Geometric similarity to the production CPB device is documented in similarity assessment SA-2024-001. Achieved level meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error (iterative convergence beyond GCI) is not required to be separately quantified at Model Risk Level 2. Residual convergence to 1e-6 for all equations is documented as a proxy. Factor scoped to not-assessed per MRL 2 requirements table."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal use-error analysis is not required at Model Risk Level 2. Standard operating procedures and analyst training records are maintained but not formally scored. Factor scoped to not-assessed per MRL 2 requirements table."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal model-form uncertainty quantification is not required at Model Risk Level 2. The k-ω SST turbulence model was selected based on published benchmarks for rotating machinery but sensitivity to model-form choice is not formally quantified here. Factor scoped to not-assessed per MRL 2 requirements table."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (blood viscosity, density) and geometric inputs must be traceable to calibrated measurements or published standards.",
      "rationale": "Blood viscosity and density are drawn from the CFD boundary-conditions dataset (dataVintage 2025-10-31T00:00:00Z), which predates the model revision of 2026-02-14. The dataset reflects rheological measurements from the prior pump geometry iteration; a re-validation against the revised geometry is planned but not yet completed. All values fall within published physiological ranges and the deviation from updated measurements is expected to be within 1.5%, which is within the accepted uncertainty budget. Achieved level is assessed as meeting MRL 2 pending confirmation from the planned re-measurement campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Statistical characterization of test-sample variability is not required at Model Risk Level 2. A single representative pump geometry was used for validation consistent with MRL 2 scope. Factor scoped to not-assessed per MRL 2 requirements table."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal equivalency mapping between validation test inputs and COU inputs is not required at Model Risk Level 2. Qualitative similarity between FDA benchmark conditions and CPB COU conditions is documented in similarity assessment SA-2024-001. Factor scoped to not-assessed per MRL 2 requirements table."
    }
