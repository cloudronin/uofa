      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance at Gradation 1.",
      "rationale": "Numerical solver error beyond discretization (e.g., iterative convergence, round-off) not separately assessed at MRL 2. Residual convergence to 1e-6 for all equations documented in solver logs. Not required for MRL 2 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
