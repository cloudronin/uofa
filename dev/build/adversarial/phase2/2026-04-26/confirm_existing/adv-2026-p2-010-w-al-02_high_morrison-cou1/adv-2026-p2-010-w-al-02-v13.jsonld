  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately recorded as not-assessed per the MRL 2 sufficiency table for a Class II device with medium model influence. Uncertainty quantification via Latin hypercube sampling (500 samples) demonstrates that the RH index remains below 1.0 across the full input uncertainty space at all five COU operating points, with a 97.8th-percentile RH of 0.91. The UQ report narrative references a Morris screening sensitivity study confirming that the top three input drivers (blood viscosity, rotational speed, and impeller-volute gap height) collectively account for over 85% of RH output variance, providing confidence that the dominant aleatory uncertainties are understood. Validation evidence is judged sufficient for the intended regulatory submission. The credibility assessment team accepts the model for use in the COU as defined.",
