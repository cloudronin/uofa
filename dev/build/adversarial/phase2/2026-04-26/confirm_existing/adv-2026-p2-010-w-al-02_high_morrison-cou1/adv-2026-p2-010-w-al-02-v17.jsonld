  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou1-vr-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Hemolysis index bench validation against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in vitro measurements across 5 operating points. Mean relative error 8.3%; all predictions within experimental uncertainty bands. RH < 1 satisfied at worst-case operating point (6 L/min, 3500 RPM)."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou1-vr-mesh-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence index study for centrifugal pump hemolysis model",
      "description": "Three-level mesh refinement study performed using GCI methodology per Celik et al. (2008). Fine-grid GCI for NIH quantity of interest: 1.7%. Monotonic convergence confirmed. Discretization error within acceptable bounds for MRL 2."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou1-vr-uq-propagation",
      "type": "ValidationResult",
      "name": "UQ propagation study — Latin Hypercube sampling over 500 realizations",
      "description": "Aleatory uncertainty in blood viscosity (±15%), inlet flow rate (±5%), and impeller rotational speed (±2%) propagated through the CFD surrogate using LHS with n=500. 95th-percentile NIH remains below predicate device NIH. A screening sensitivity study using the Morris elementary effects method was executed to rank input factors by influence on NIH output variance; results indicated viscosity as the dominant driver. Structured linkage of these rankings to individual credibility factor assessments was noted as a follow-on task and is not yet encoded in the package metadata."
    }
  ],
