  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2022 R2) with documented V&V history; version control and audit trail maintained for all case files.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially validated solver with published verification documentation. All simulation case files, boundary condition scripts, and post-processing routines are stored under Git version control with tagged releases. SQA level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark cases for incompressible rotating machinery flow; method of manufactured solutions applied to hemolysis transport equation.",
      "rationale": "The hemolysis power-law transport equation was verified using method of manufactured solutions on a canonical rotating channel geometry. L2 norm of error converges at second order, consistent with solver documentation. Benchmark results for the FDA nozzle model reproduced within 3% of published reference data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for NIH quantity of interest on fine grid; monotonic convergence demonstrated.",
      "rationale": "Three-mesh GCI study (coarse: 2.1M, medium: 5.8M, fine: 14.7M cells) yields GCI_fine = 1.7% for NIH. Convergence ratio p = 1.94, consistent with second-order scheme. Richardson extrapolated NIH value used as reference for validation comparison. Discretization error is well-characterized and within the MRL 2 required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate) match simulation boundary conditions within documented tolerances.",
      "rationale": "In vitro experiments used porcine blood at 37°C with viscosity measured via cone-and-plate rheometry prior to each test. Pump rotational speed controlled to ±10 RPM; flow rate metered to ±0.05 L/min. Simulation boundary conditions set to measured mean values with deviations documented. Equivalency of test and simulation conditions confirmed for all 5 operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted NIH within experimental uncertainty interval at all 5 operating points; systematic bias < 10%.",
      "rationale": "Predicted NIH values compared against triplicate experimental measurements at each of 5 operating points. All CFD predictions fall within the 95% confidence interval of experimental measurements. Mean signed relative error is +4.1% (slight overprediction, conservative for hemolysis assessment). Maximum relative error 8.3% at 4 L/min / 2800 RPM. Achieved level 3 reflects quantitative agreement with uncertainty-bounded experimental data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "NIH and derived RH index are the regulatory quantities of interest; model outputs directly map to acceptance criterion RH < 1.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) integrated over the pump wetted volume, from which the relative hemolysis index RH is derived by normalization against predicate device NIH. This is the quantity specified in the COU acceptance criterion. Secondary QoIs (shear stress distribution, residence time) are computed and reported but not used in the regulatory decision. Relevance is direct and unambiguous."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the FDA generic centrifugal pump geometry under CPB-representative flow conditions; fluid and operating conditions match COU.",
      "rationale": "Validation activities used the same FDA generic centrifugal pump geometry as the COU model. Porcine blood at physiological temperature was used as the working fluid, matching clinical CPB conditions. Operating range (2–6 L/min, 2500–3500 RPM) spans the COU envelope. The validation domain is highly relevant to the intended use, supporting confidence in model predictions within the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence monitoring sufficient.",
      "rationale": "At MRL 2, explicit quantification of numerical solver error beyond iterative convergence monitoring is not required. Residuals monitored to 1e-6 for all equations; mass imbalance < 0.01%. Solver error contribution deemed negligible relative to discretization and model form uncertainty. Factor scoped to not-assessed consistent with MRL 2 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; standard operating procedures and peer review of simulation setup are sufficient.",
      "rationale": "Simulation setup reviewed by a second analyst prior to submission. Boundary conditions, material properties, and solver settings documented in a standardized simulation report template. No evidence of use error identified during peer review. Formal use error quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection justified by literature precedent.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is the de facto standard for CFD hemolysis prediction in blood pump assessment, consistent with FDA guidance documents and peer-reviewed literature. Model form uncertainty is acknowledged but not formally quantified at MRL 2. Alternative model forms (modified Bludszuweit, Arora) were reviewed in the literature but not implemented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs documented with sources; aleatory uncertainty in blood viscosity, flow rate, and rotational speed characterized via probability distributions derived from literature and device specifications.",
      "rationale": "Input parameters and their uncertainty distributions are documented in the UQ analysis report. Blood viscosity modeled as log-normal (mean 3.5 mPa·s, CV 15%) based on published CPB patient data. Inlet flow rate uncertainty ±5% (uniform) per pump specification tolerances. Rotational speed uncertainty ±2% (uniform). UQ propagation via LHS (n=500) yielded 95th-percentile NIH distributions for all operating points. A Morris screening study was executed to rank input drivers; viscosity emerged as the dominant contributor to NIH variance, followed by flow rate. These rankings were discussed in the UQ report narrative but have not been encoded as structured sensitivity analysis metadata linked to this credibility package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; triplicate measurements at each operating point provide sufficient statistical basis.",
      "rationale": "Triplicate experimental measurements were performed at each of the 5 operating points using fresh porcine blood samples from the same lot. Sample variability is captured in the experimental uncertainty bounds used for output comparison. Formal test sample adequacy analysis not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; documented correspondence between experimental and simulation input parameters is sufficient.",
      "rationale": "Simulation input parameters set to match experimental conditions as described under Test Conditions factor. Formal equivalency metric computation not required at MRL 2. Correspondence table provided in the validation report mapping each experimental measurement to its simulation counterpart."
    }
