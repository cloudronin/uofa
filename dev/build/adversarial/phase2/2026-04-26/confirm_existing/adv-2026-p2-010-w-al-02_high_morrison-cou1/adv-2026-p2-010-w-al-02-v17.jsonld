  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are appropriately scoped as not-assessed consistent with MRL 2 guidance. Validation demonstrates CFD-predicted NIH within experimental uncertainty at all 5 CPB operating points, with RH < 1 confirmed at worst-case conditions. Uncertainty quantification over key aleatory inputs (blood viscosity, flow rate, rotational speed) confirms the acceptance criterion is satisfied at the 95th percentile. The assessment team notes that a Morris screening sensitivity study was performed and documented in the UQ report, identifying blood viscosity as the dominant input driver; structured encoding of sensitivity rankings as linked metadata is deferred to the next package revision cycle and does not affect the current decision outcome. Overall credibility is sufficient for the intended regulatory submission supporting the Class II CPB device 510(k).",
    "decidedAt": "2026-04-19T00:00:00Z"
