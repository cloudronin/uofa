  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Discretization error GCI of 3.1% is within the 5% acceptance threshold. Validation comparison error is within validation uncertainty bounds across all five operating points. Uncertainty quantification via Monte Carlo sampling has been completed and documents the combined effect of input variability on hemolysis index predictions. The 13-factor assessment is complete and consistent with ASME V&V 40-2018 requirements for a Class II device at MRL 2. The model is accepted for use in identifying worst-case hemolysis operating conditions for the CPB device submission.",
