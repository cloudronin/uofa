    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% on NIH quantity of interest; three systematically refined meshes required.",
      "rationale": "Three hexahedral-dominant meshes (2.1M, 6.8M, 18.4M cells) generated with refinement ratio r = 1.48. GCI on NIH computed per Celik et al. (2008): GCI_fine = 2.1%, well below 5% threshold. Apparent order of convergence p = 1.94, consistent with second-order scheme. Discretization error is the single largest quantified contributor to NIH uncertainty at ±0.003 g/100L."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented and traceable; operating points match COU envelope.",
      "rationale": "FDA generic pump experimental data from Hariharan et al. (2011) used as validation dataset. Fluid temperature (37°C), hematocrit (35%), and rotational speeds (2000–3500 RPM) match COU operating envelope. Inlet flow rates 2–6 L/min encompass all five COU operating points. Test condition fidelity rated adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., mean absolute error, E_rel) reported; agreement within experimental uncertainty for primary QoI.",
      "rationale": "NIH predictions compared against experimental values at all five operating points. Mean absolute error 7.1%; maximum error 12.4% at lowest flow rate. All predictions fall within ±1 standard deviation of experimental repeatability (±15%). Relative hemolysis index RH computed against predicate: RH < 1 at all operating points. Quantitative agreement deemed adequate for MRL 2 decision support."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to regulatory acceptance criterion; hemolysis index linked to clinical endpoint.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH, g/100L), which directly maps to the relative hemolysis index (RH) acceptance criterion RH < 1 specified in FDA guidance. NIH is the standard metric for pump-induced hemolysis assessment in cardiovascular device submissions. QoI relevance rated adequate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions sufficiently similar to COU device and operating envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which shares impeller topology and operating range with the COU device. Blood analog fluid (glycerin-water, matched viscosity) used in experiments; full blood simulations use equivalent rheological model. Geometric similarity confirmed via overlay comparison. Validation activities rated adequately relevant to COU at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below solver tolerance; mass balance error documented.",
      "rationale": "Not assessed as a standalone factor at MRL 2; residual monitoring embedded within discretization error assessment. Continuity residuals below 1e-5 and mass imbalance below 0.01% documented in simulation logs, meeting minimum threshold implicitly."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary conditions and material properties verified.",
      "rationale": "Not formally assessed as separate factor at MRL 2. Independent analyst review of boundary condition setup and material property assignments conducted as part of software quality assurance activity. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis power-law model selections documented with literature justification.",
      "rationale": "Not assessed as standalone factor at MRL 2. SST k-omega turbulence model selected based on published benchmark comparisons for rotating machinery hemolysis CFD (Fraser et al. 2011). Giersiepen power-law hemolysis model applied consistently with prior FDA submissions. Model form uncertainty acknowledged in UQ narrative but not formally quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and boundary conditions traceable to measurement or literature; input uncertainty ranges documented for UQ.",
      "rationale": "Blood viscosity (3.5 mPa·s ± 0.3 mPa·s, 37°C), density (1060 kg/m³ ± 5 kg/m³), and hemolysis model coefficients (C = 3.62e-7, alpha = 2.416, beta = 0.785) sourced from peer-reviewed literature with documented uncertainty ranges. Rotational speed tolerance ±10 RPM and flow rate tolerance ±0.05 L/min from pump test rig calibration certificates. Input uncertainty ranges propagated through Monte Carlo UQ study (N = 500 samples). A screening sensitivity study was performed verbally documenting that hemolysis model exponent alpha and shear stress magnitude are primary variability drivers, though formal ranked sensitivity indices were not computed as structured outputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number of experimental replicates sufficient for statistical characterization of measurement uncertainty.",
      "rationale": "Not assessed as standalone factor at MRL 2. Hariharan et al. (2011) report triplicate measurements at each operating point; coefficient of variation below 8% across replicates. Sample adequacy deemed sufficient for MRL 2 validation comparison without formal statistical power analysis."
    },
