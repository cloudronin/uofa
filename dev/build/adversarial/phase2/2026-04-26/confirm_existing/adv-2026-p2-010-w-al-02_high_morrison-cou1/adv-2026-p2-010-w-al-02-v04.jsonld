      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrably equivalent to experimental conditions used in validation.",
      "rationale": "Not assessed as standalone factor at MRL 2. Boundary conditions in validation simulations set to match reported experimental values within measurement uncertainty. Equivalency confirmed qualitatively through test conditions factor assessment."
