  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented V&V history and configuration management; version-controlled simulation scripts.",
      "rationale": "ANSYS Fluent 2022R2 employed under institutional software QA protocol. Solver version locked in configuration management system; input scripts archived under Git with tagged release corresponding to this study. SQA documentation on file exceeds MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes manufacturer benchmark suite relevant to rotating machinery and viscous flow; no open anomalies affecting hemolysis QoI.",
      "rationale": "ANSYS Fluent benchmark suite for rotating reference frame and viscous incompressible flow reviewed. All relevant test cases pass to within solver-stated tolerances. No open defect reports identified that could affect NIH predictions in the centrifugal pump operating regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates GCI < 5% on NIH at the worst-case operating point.",
      "rationale": "Three-level structured mesh refinement study performed (4.2 M, 9.8 M, 21.4 M cells). Richardson extrapolation yields GCI of 3.1% on NIH at 6 L/min / 3500 RPM. Medium mesh (9.8 M cells) adopted as production mesh, balancing accuracy and computational cost. Discretization error deemed acceptable for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, inlet/outlet boundary conditions, rotational speed) match simulation inputs within documented tolerances.",
      "rationale": "FDA bench test protocol used bovine blood analog (glycerin-water, 3.5 cP at 37°C). Simulation fluid properties set identically. Inlet flow rates and rotational speeds match experimental set points within ±1.5%, within instrument calibration uncertainty. Temperature variation effects on viscosity bounded at ±0.2 cP and treated as negligible for NIH comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (E_rms) on NIH ≤ 15% across all validation operating points.",
      "rationale": "RMS relative error on NIH across five operating points is 8.3%. All individual predictions fall within the experimental measurement uncertainty envelope (±12%). Exceeds MRL 2 requirement. Systematic underprediction of 4–6% at high-shear conditions noted and attributed to power-law hemolysis model constants calibrated on a different blood analog; documented as a known model form limitation in the UQ report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (NIH, RH) directly maps to regulatory acceptance criterion and clinical endpoint.",
      "rationale": "Normalized index of hemolysis and relative hemolysis index are the quantities mandated by FDA guidance for CPB device submissions. CFD outputs are post-processed using the Giersiepen-Wurzinger power-law model to yield NIH directly. QoI relevance to clinical hemolysis risk is well-established in the literature and accepted by FDA reviewers for predicate comparisons."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device geometry under overlapping operating conditions; fluid and material properties match COU within stated tolerances.",
      "rationale": "Validation dataset derived from FDA-sponsored testing of the same generic centrifugal pump geometry used in the COU. Operating envelope (2–8 L/min, 2500–4500 RPM) fully encompasses the five COU operating points. Fluid analog properties match COU conditions. Validation activities are judged highly relevant; no significant extrapolation beyond validated space is required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residuals converge to ≤1×10⁻⁵ for continuity and momentum; mass imbalance <0.01%.",
      "rationale": "All five operating-point simulations converged to scaled residuals below 1×10⁻⁵ for continuity, momentum, and turbulence quantities. Global mass imbalance confirmed below 0.005% in each case. No divergence or oscillatory non-convergence observed. Solver error contribution to NIH uncertainty estimated at <0.5% via perturbation of convergence threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second qualified analyst; checklist-based review documented.",
      "rationale": "Simulation setup reviewed by a second CFD analyst using the institutional pre-submission checklist (Form SIM-QA-07). Boundary condition assignments, material property inputs, rotating domain interfaces, and post-processing scripts independently verified. One minor unit inconsistency in viscosity input corrected prior to production runs; no impact on final results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage accumulation model selected based on published literature support for centrifugal blood pump applications; model form uncertainty estimated.",
      "rationale": "SST k-ω turbulence model selected based on documented superiority for rotating machinery with adverse pressure gradients. Giersiepen-Wurzinger hemolysis model applied with constants from Heuser & Opitz (1980). Model form uncertainty estimated at ±15% on NIH based on comparison of three alternative hemolysis model parameterizations reported in the UQ study narrative. This uncertainty is propagated to the RH criterion and confirmed not to alter the accept/reject decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and boundary conditions characterized with documented uncertainty; input uncertainty propagated to QoI.",
      "rationale": "Inlet flow rate (±3%), rotational speed (±1%), and blood analog viscosity (±5.7%) characterized from calibration records and literature. A screening sensitivity study, described in the UQ report narrative, identified inlet flow rate and rotational speed as the dominant contributors to NIH variability. Monte Carlo propagation (500 samples, Latin hypercube) yielded a 95th-percentile NIH interval of [0.0041, 0.0063] mg/100 mL at the worst-case point, maintaining RH < 1 throughout the distribution. Structured sensitivity analysis rankings are summarized within the UQ narrative documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for computational-only submission with predicate comparison.",
      "rationale": "Test sample characterization (e.g., batch-to-batch variability of blood analog) is not required at MRL 2 when the COU relies on relative hemolysis comparison against a predicate device tested under identical protocol. Factor scoped out per MRL 2 assessment matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; validation experiment uses same geometry as COU device.",
      "rationale": "Because the validation dataset was generated on the identical FDA generic pump geometry used in the COU simulations, equivalency of input parameters between validation and COU contexts is inherently satisfied. Formal equivalency mapping documentation is not required at MRL 2 and has not been separately assessed."
    }
  ],
