  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control and regression test suite covering relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-certified QMS. Version-controlled simulation files were archived in the institutional repository. Regression tests for rotating machinery and non-Newtonian fluid models were executed and passed prior to production runs. Achieved level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via published benchmark or manufactured solution.",
      "rationale": "Fluent's pressure-based coupled solver was verified against the lid-driven cavity benchmark (Re = 1000) and the Taylor-Couette flow analytical solution. Results matched published data to within 0.8% in velocity profiles. Code verification is documented in the solver validation report v4.1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed for the hemolysis index QoI across at least three mesh refinement levels.",
      "rationale": "A three-level mesh refinement study was performed using meshes of 2.1M, 5.8M, and 14.3M cells. GCI for the normalized hemolysis index at the design operating point was 3.1%, within the 5% threshold. The medium mesh (5.8M cells) was selected for production runs based on the convergence study. Richardson extrapolation confirmed monotonic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within documented tolerances for flow rate, rotational speed, and fluid temperature.",
      "rationale": "In vitro tests were conducted at 37°C ± 0.5°C using porcine blood with hematocrit 33% ± 2%. Flow rates were set to within ±3% of target values using calibrated ultrasonic flow meters. Rotational speed was controlled to ±10 RPM. All boundary condition correspondences are documented in the test protocol TP-CPB-2023-01."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., normalized index of agreement or percent error) must demonstrate model predictions are within acceptance band for hemolysis QoI.",
      "rationale": "CFD-predicted relative hemolysis index was compared against bench measurements at all 5 operating points. Maximum percent error was 13.7% (at 2500 RPM, 3 L/min); mean error was 7.4%. All predictions fell within the ±15% acceptance band defined in the assessment plan. The normalized index of agreement was 0.94."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in the model (hemolysis index) must be directly linked to the clinical endpoint (blood trauma) and the regulatory acceptance criterion.",
      "rationale": "The relative hemolysis index (RH) is the FDA-recommended metric for comparative hemolysis assessment per the 2017 FDA guidance on blood-contacting devices. RH < 1 maps directly to the non-inferiority claim versus the predicate device. The QoI is computed as the volume-weighted integral of the power-law hemolysis model, which is accepted in the literature as a surrogate for erythrocyte damage. Full traceability from QoI to clinical endpoint is documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating envelope as the COU.",
      "rationale": "Validation experiments were conducted on the identical FDA generic centrifugal pump geometry used in the COU simulations. Porcine blood was used as a physiologically representative fluid. The 5 flow-speed combinations tested span the full operating envelope of interest. Geometric fidelity was confirmed via CMM measurement of the physical test article against the CAD model (max deviation 0.08 mm)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error should be characterized if solver error is expected to be significant.",
      "rationale": "At MRL 2, formal characterization of numerical solver error beyond residual monitoring is not required. Residuals were converged to 1e-5 for all equations. No evidence of iterative divergence or floating-point instability was observed. Scoped out per MRL 2 assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Errors arising from incorrect model setup or user mistakes should be evaluated if model complexity warrants it.",
      "rationale": "At MRL 2, formal use error assessment is not required. Simulation setup was reviewed by a second analyst and discrepancies resolved prior to production runs. Standard operating procedures for CFD setup were followed. Scoped out per MRL 2 assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The appropriateness of the mathematical model form (turbulence model, hemolysis model) should be evaluated relative to the COU physics.",
      "rationale": "At MRL 2, formal model form assessment is not required. The SST k-omega turbulence model and Giersiepen-Wurzinger power-law hemolysis model were selected based on published literature for centrifugal blood pump applications. Model form uncertainty is acknowledged in the UQ narrative as a qualitative contributor. Scoped out per MRL 2 assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters with significant uncertainty must be identified and their distributions characterized. A screening sensitivity study was referenced in the UQ report to support input prioritization.",
      "rationale": "Uncertain model inputs were identified through a structured review of the simulation input deck: blood viscosity (Carreau model coefficients), inlet velocity profile shape, rotational speed tolerance, and hemolysis model exponents (C, alpha, beta). Probability distributions were assigned based on literature data and experimental measurement uncertainty. A screening sensitivity study is described in the UQ report (Section 4.2) confirming that flow rate and rotational speed account for the majority of hemolysis index variance, while viscosity model coefficients contribute secondarily. Input uncertainty propagation was performed using a 500-sample Latin hypercube design. The 95th-percentile RH prediction remained below 0.87, providing margin against the RH < 1 criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Variability in test samples (e.g., blood donor variability) should be characterized if it materially affects validation conclusions.",
      "rationale": "At MRL 2, formal test sample variability assessment is not required. Three blood donors were used across the validation experiments; inter-donor variability in measured RH was within ±8%, consistent with published ranges. Scoped out per MRL 2 assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation input parameters and physical test conditions should be formally evaluated if parameter mapping is non-trivial.",
      "rationale": "At MRL 2, formal equivalency assessment is not required. Boundary conditions were mapped directly from measured experimental conditions with documented tolerances. No non-trivial parameter transformations were required. Scoped out per MRL 2 assessment plan."
    }
  ],
