  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release notes and regression test suite.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional license with full version control. Regression test suite executed prior to simulation campaign; all 47 benchmark cases passed within tolerance. Software quality documentation archived in project repository."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification against manufactured solutions for the governing transport equations.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver. Observed spatial convergence rate of 1.93 (nominal second order) confirmed for velocity and pressure fields. Temporal discretization verified separately for transient sub-cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI across three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study performed: coarse (4.2M cells), medium (12.1M cells), fine (34.8M cells). GCI for normalized hemolysis index = 3.1% between medium and fine meshes. Medium mesh selected for production runs, providing adequate accuracy at tractable computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate clinical CPB operating range (2–6 L/min, 1500–3500 RPM) and use bovine blood with documented hematocrit.",
      "rationale": "Validation experiments conducted at FDA laboratory using bovine blood (hematocrit 33±2%) at five operating points spanning the clinical CPB envelope. Temperature maintained at 37°C. All boundary conditions documented and traceable to experimental records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predicted within 25% of experimental measurements at all five operating points.",
      "rationale": "CFD-predicted NIH values compared against FDA benchmark experimental data. Maximum deviation 18.4% observed at 6 L/min, 3500 RPM operating point. All five operating points within the 25% acceptance band. Systematic under-prediction at high shear conditions attributed to power-law blood viscosity model limitations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear stress distribution) must directly map to the decision-relevant metric (relative hemolysis index RH).",
      "rationale": "Normalized index of hemolysis and volume-averaged shear stress used in validation directly inform the relative hemolysis index RH. Mapping documented in the QoI traceability matrix. RH < 1 acceptance criterion derived from predicate device NIH values obtained from the same experimental protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the geometry family, operating range, and blood analogue relevant to the CPB COU.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which shares impeller topology with the subject device. Operating conditions span the intended CPB clinical envelope. Bovine blood used as surrogate for human blood per ISO 10993-4 guidance. Validation domain overlap with COU assessed as high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below solver default thresholds.",
      "rationale": "Not assessed at MRL 2 per ASME V&V 40 Table 3 requirements. Residual monitoring logs retained as supporting evidence for future assessments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation setup review by independent analyst.",
      "rationale": "Not assessed at MRL 2. Informal peer review of simulation setup performed internally; formal independent review not required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal justification of turbulence model selection and hemolysis damage model applicability.",
      "rationale": "Not assessed at MRL 2. SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis model selected based on literature precedent for rotary blood pump CFD. Formal model form uncertainty analysis deferred."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs documented with source, nominal value, and uncertainty bounds. UQ performed across identified uncertain inputs.",
      "rationale": "Twelve model inputs identified and documented including inlet flow rate (±5%), rotational speed (±1%), blood viscosity parameters (±8%), and geometric tolerances (±0.05 mm). Uncertainty quantification performed using Monte Carlo sampling (n=500) propagating input distributions through the hemolysis model. A screening sensitivity study described in the UQ technical report identified viscosity parameters and inlet flow rate as the most influential inputs based on variance decomposition; however, the structured sensitivity analysis artifact has not been formally linked to this credibility package pending finalization of the UQ report appendix. Combined uncertainty on NIH at 95% confidence interval reported as ±12.3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability for blood analogue properties.",
      "rationale": "Not assessed at MRL 2. Single bovine blood batch used per FDA benchmark protocol. Batch-to-batch variability not characterized at this assessment level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental input parameters and computational model inputs.",
      "rationale": "Not assessed at MRL 2. Qualitative mapping between experimental and computational boundary conditions documented in simulation setup report. Formal equivalency analysis not required at this risk level."
    }
  ],
