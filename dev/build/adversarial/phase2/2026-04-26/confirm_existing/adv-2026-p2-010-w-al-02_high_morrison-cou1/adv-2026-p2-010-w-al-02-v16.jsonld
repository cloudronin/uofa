    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence monitoring sufficient.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond iterative convergence monitoring is not required. Residuals were monitored to below 1e-5 for all equations. Mass imbalance across boundaries was less than 0.01%. No further assessment required."
