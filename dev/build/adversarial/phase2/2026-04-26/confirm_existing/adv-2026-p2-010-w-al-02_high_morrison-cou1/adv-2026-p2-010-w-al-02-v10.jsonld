  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately not-assessed at MRL 2. Uncertainty quantification was performed with Monte Carlo propagation of boundary-condition uncertainties, yielding 95% confidence intervals on NIH that remain below the RH < 1 acceptance criterion across all operating points. The assessment team notes that a screening sensitivity study is described in the UQ report narrative, but the dominant input drivers have not been formally ranked via a structured sensitivity analysis linked to this package. This gap was reviewed and judged acceptable at MRL 2 given the conservative nature of the hemolysis model and the experimental validation margin. The package is accepted for regulatory submission.",
