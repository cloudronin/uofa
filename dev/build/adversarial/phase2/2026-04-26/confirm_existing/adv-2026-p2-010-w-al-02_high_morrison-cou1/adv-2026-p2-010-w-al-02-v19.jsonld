  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are scoped out as not required at MRL 2. Uncertainty quantification was completed with Monte Carlo methods covering inlet flow rate and impeller speed; the UQ report narrative references a screening sensitivity study identifying shear-stress exposure time as potentially dominant, consistent with the Giersiepen power-law model. The overall evidence package supports acceptance of the CFD model for identifying worst-case hemolysis operating conditions under CPB use. Relative hemolysis index predictions remain below RH = 1 across all five evaluated operating points.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
