  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA solver (Ansys Mechanical) under vendor QMS; FDA in-house solver under 21 CFR Part 820 QMS. Achieved level 2 requires documented QMS and version control.",
      "rationale": "Ansys Mechanical 2023 R2 and the FDA in-house implicit FEA solver are both operated under documented quality management systems with version-controlled release notes. Software verification test suites pass all benchmark cases. Achieved level 2 meets the required level 2 for a model risk level 3 device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarked against NAFEMS standard problems and patch tests. Relative error in benchmark quantities of interest < 1%.",
      "rationale": "Both solvers were verified against NAFEMS LE1, LE10, and contact patch tests. Maximum relative error across benchmark QoIs was 0.4%. Achieved level 2 satisfies the required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates < 2% change in all QoIs between the production mesh and a globally refined mesh (1.5× linear element size reduction).",
      "rationale": "A three-level mesh convergence study was performed on the screw shank and rod interface regions, which govern stiffness and yield QoIs. The production mesh (≈420 k elements, C3D8R with enhanced hourglass control) exhibited < 1.1% change in all three QoIs relative to the fine mesh. Richardson extrapolation GCI < 0.8%. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria tightened to force residual < 1×10⁻⁵ and displacement residual < 1×10⁻⁶ for all load steps.",
      "rationale": "Implicit quasi-static solver with automatic time-stepping. Force and displacement residuals satisfied the specified convergence criteria at every increment. No divergence or cutback events observed across the 11 model runs. Achieved level 1 meets required level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and post-processing scripts by a second analyst not involved in model construction.",
      "rationale": "An independent FDA analyst reviewed all model setup files, Python post-processing scripts, and boundary condition assignments against the simulation plan. No use errors were identified. Achieved level 2 satisfies required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Bilinear isotropic hardening plasticity (BISO) with experimentally measured Ti-6Al-4V ELI properties. Contact modeled with augmented Lagrangian formulation, friction coefficient μ = 0.15 ± 0.05.",
      "rationale": "The BISO plasticity model captures the yield plateau observed in Ti-6Al-4V under quasi-static loading. Friction sensitivity analysis (μ = 0.10 to 0.20) showed < 3% variation in yield force QoI. Model form is consistent with published literature for metallic orthopedic implant FEA. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing on production-lot Ti-6Al-4V ELI; geometric inputs from CMM measurements of production implants. Uncertainty in key inputs propagated via one-at-a-time sensitivity.",
      "rationale": "Elastic modulus (113.8 ± 2.1 GPa) and yield strength (880 ± 12 MPa) were taken from the 2018 bench-test-era coupon dataset. Geometric dimensions were confirmed via CMM on five production screws and rods. Sensitivity analysis shows QoI uncertainty attributable to material inputs is < 4%. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 constructs from production lots; tested at two independent laboratories to assess inter-laboratory variability.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs from a single production lot were tested: six at Laboratory A (FDA) and five at Laboratory B (DePuy Synthes). Inter-laboratory coefficient of variation for stiffness was 3.2%, within acceptable limits. Sample size supports statistical comparison at the specified acceptance bounds. Achieved level 2 satisfies required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios. Minimum: two distinct load levels or configurations tested.",
      "rationale": "Testing was performed under a single ASTM F1717 compression-bending configuration only. No torsion, fatigue, or alternative offset distance was included in this COU. The achieved level 1 (single test condition) falls below the required level 2. This gap was accepted by the credibility assessment team on the basis that ASTM F1717 compression-bending is the regulatory standard condition and additional configurations are addressed in separate COUs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs (geometry, material, boundary conditions) shown to be equivalent to the physical test article inputs within stated tolerances.",
      "rationale": "CAD geometry used in the FEA was derived from the same production drawings as the physical test articles. Material inputs were drawn from coupon specimens machined from the same production lot billet. Boundary conditions replicate the ASTM F1717 fixture geometry. Equivalency confirmed by overlay of FEA deformed shape with DIC measurements at two load levels. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and relative error < 10% for all three QoIs. Uncertainty in both model prediction and experimental measurement propagated.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy E/uval < 1.96 and relative error < 10%. Combined model prediction uncertainty (u_num + u_input) and experimental measurement uncertainty (u_meas) were propagated per ASME V&V 20 procedures. Maximum E/uval across all QoIs was 0.59. Achieved level 2 satisfies required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to regulatory submission metrics and clinical failure modes (stiffness, yield, large-displacement force).",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the ASTM F1717 standard and required by FDA guidance for pedicle screw 510(k) submissions. All three QoIs are directly linked to the clinical failure mode of screw-rod construct yielding during revision loading. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, loading, and boundary conditions are representative of the COU. Differences between validation and COU conditions are identified and their impact on credibility is assessed.",
      "rationale": "The validation activity uses the same 7.5 mm non-cannulated screw geometry, ASTM F1717 loading configuration, and Ti-6Al-4V material as the COU. The validation is therefore directly relevant to the COU. The sole difference — that the COU encompasses a broader range of patient anatomies — is addressed by the separate fatigue and multi-level COU packages. Achieved level 2 satisfies required level 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single below-required factor (Test conditions, achieved 1 vs. required 2) was accepted on the basis that ASTM F1717 compression-bending is the sole regulatory standard condition for this device class and additional loading configurations are evaluated in companion COUs. All three QoIs satisfy quantitative acceptance bounds (relative error < 10%, E/uval < 1.96). The overall credibility of the FEA framework for the non-cannulated compression-bending COU is assessed as sufficient to support a Medium assurance level decision.",
