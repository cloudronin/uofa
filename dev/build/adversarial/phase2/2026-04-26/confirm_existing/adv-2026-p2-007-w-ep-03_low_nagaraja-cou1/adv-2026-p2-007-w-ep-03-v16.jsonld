  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/computational-sciences-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. The single shortfall (Test conditions, achieved 1 vs. required 2) is accepted because ASTM F1717 prescribes a single standard configuration and the COU does not require extrapolation beyond that configuration. Overall credibility is judged sufficient for Medium model risk and Medium decision consequence. The experimental benchmark dataset from the 2018 testing campaign provides the primary validation evidence and all three QoI acceptance criteria are satisfied.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
