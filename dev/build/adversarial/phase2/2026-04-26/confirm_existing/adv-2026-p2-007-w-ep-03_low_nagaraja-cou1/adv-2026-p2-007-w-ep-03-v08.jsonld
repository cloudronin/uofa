    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation plan reviewed by independent analyst prior to execution; boundary conditions and loading verified against ASTM F1717 test setup.",
      "rationale": "Simulation plan reviewed and approved by a second qualified FEA analyst. Boundary conditions replicate the ASTM F1717 fixture geometry (superior block fixed, inferior block loaded in compression-bending at 5°). Independent review checklist completed and archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics (linear elastic with bilinear isotropic hardening, frictional contact) justified by literature and sensitivity analysis.",
      "rationale": "Bilinear isotropic hardening plasticity selected for Ti-6Al-4V based on published coupon data. Frictional contact (μ=0.3) at screw-block interfaces justified by tribological literature. Sensitivity analysis showed QoIs insensitive to ±20% variation in friction coefficient. Model form uncertainty estimated and included in E/uval calculation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs traceable to measured data; input uncertainty quantified and propagated.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (1.1 GPa) sourced from coupon testing of the same Ti-6Al-4V ELI lot used in bench specimens (Dataset: nagaraja-material-properties-titanium-alloy, vintage 2023-09-01). Geometric inputs derived from CMM measurements of production screws. Input uncertainty propagated via Monte Carlo (n=1000 samples); 95th percentile QoI uncertainty reported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production lots; specimen dimensions verified by CMM; test samples representative of commercial device.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested, drawn from two production lots. All specimens dimensionally verified by CMM prior to testing. Specimens representative of commercial device geometry and material specification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple test conditions spanning the COU loading envelope; at least two independent laboratories.",
      "rationale": "Testing conducted at two independent laboratories per ASTM F1717 protocol. However, only a single test condition (5° compression-bending, quasi-static, ambient temperature) was evaluated. The COU loading envelope includes dynamic and fatigue regimes not covered by this validation activity. Factor achieved level 2 rather than required level 3; this gap is acknowledged and accepted given the regulatory precedent for static F1717 as the primary submission test."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters (geometry, material, boundary conditions) demonstrably equivalent to physical test specimen parameters.",
      "rationale": "FEA geometry imported directly from CAD files used to manufacture test specimens. Material inputs from same lot coupon data. Boundary conditions replicate ASTM F1717 fixture to within 0.5 mm positional tolerance. Equivalency confirmed by overlay of FEA deformed geometry with DIC measurements from bench tests."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using pre-defined acceptance bounds; uncertainty in both simulation and experiment accounted for via E/uval metric.",
      "rationale": "Pre-registered acceptance bounds: relative error <10%, E/uval <1.96. All three QoIs (stiffness: 4.7%/0.91; yield force: 6.2%/1.18; force at 40 mm: 8.8%/1.72) satisfy both criteria. Experimental uncertainty estimated from inter-laboratory variability (CV 3.2–5.1%). Simulation uncertainty from input propagation and discretization error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly relevant to clinical performance: stiffness governs load sharing with the spine; yield force and force at displacement characterize structural integrity under surgical and physiological loading."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
