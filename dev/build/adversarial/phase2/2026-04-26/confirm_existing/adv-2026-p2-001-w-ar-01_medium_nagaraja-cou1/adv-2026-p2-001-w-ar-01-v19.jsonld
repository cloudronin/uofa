  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R1) is used under a documented quality management system compliant with ISO 9001. Version-controlled solver releases with regression test suites covering relevant element types (SOLID186, CONTA174) must pass all tier-1 benchmark cases prior to use. Gradation 2 is satisfied when a QMS is in place and software version is recorded in the simulation report.",
      "rationale": "The FEA ensemble employs Ansys Mechanical 2022 R1 under DePuy Synthes' ISO 9001-certified QMS. Solver version, license record, and regression-test pass/fail logs are archived in the project document management system. Required level 2 reflects moderate model risk; achieved level 2 confirmed by QMS audit trail."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at Gradation 2 requires demonstration that the solver reproduces at least two ASME V&V 10.1 benchmark problems relevant to the element types and loading modes used. Patch-test convergence and single-element analytical comparisons for SOLID186 under bending and contact patch tests for CONTA174 must be documented in a verification report.",
      "rationale": "Ansys SOLID186 and CONTA174 elements were verified against ASME V&V 10.1 benchmarks 3A (cantilever beam bending) and 4B (Hertzian contact). Results agreed within 0.5% of analytical solutions. Verification report archived in project DMS. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires a systematic mesh convergence study with at least three mesh densities, reporting a Richardson extrapolation-based Grid Convergence Index (GCI) for each QoI. GCI must be below 2% for stiffness and yield force QoIs. The converged mesh must be identified and used for all production runs.",
      "rationale": "A three-level mesh refinement study (coarse ~85k, medium ~210k, fine ~520k elements) was conducted. GCI values: stiffness 0.8%, yield force 1.1%, force at 40 mm 1.4%. All below 2% threshold. Production mesh is the medium density (210k elements) confirmed sufficient by GCI analysis. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires documentation of solver convergence criteria (force and displacement residuals) and confirmation that all production runs converged within those criteria. Residual norms must be reported in the simulation log for each run.",
      "rationale": "Nonlinear solver convergence was monitored via force residual norm < 1e-4 and displacement residual norm < 1e-5 for all load steps. All 11 simulation runs converged without bisection failure. Solver logs retained in project DMS. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires a documented simulation plan reviewed by an independent engineer prior to execution, and a post-execution checklist confirming that boundary conditions, material assignments, and contact definitions match the approved plan.",
      "rationale": "A simulation plan was prepared by the modeling team and reviewed by an independent senior engineer before execution. A post-run checklist confirmed boundary conditions (fixed base, applied displacement at superior fixture), Ti-6Al-4V material properties, and frictional contact (mu=0.2) matched the approved plan. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires documented justification of all constitutive model choices (e.g., elastic vs. elastic-plastic), contact formulations, and geometric simplifications, with sensitivity analyses demonstrating that alternative model forms change QoIs by less than 5%.",
      "rationale": "Bilinear isotropic hardening (BISO) was selected for Ti-6Al-4V based on published tensile test data (E=114 GPa, sigma_y=880 MPa, Et=2.1 GPa). Sensitivity to elastic-only assumption showed 12% overestimate of yield force, confirming plasticity is essential. Augmented Lagrangian contact formulation was compared to penalty method; QoI difference < 1.5%. Geometric simplifications (suppressed screw thread helix, replaced with equivalent friction) validated by sensitivity study showing < 2% QoI change. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that material properties and geometric inputs are sourced from traceable measurements on the actual device lot used in testing, with uncertainty bounds quantified and propagated to QoI uncertainty estimates.",
      "rationale": "Material properties were measured from tensile coupons machined from the same Ti-6Al-4V bar stock as the test constructs (n=5 coupons per lot). Geometric dimensions were measured via CMM on three representative screws. Uncertainty in E (±2.1%), sigma_y (±1.8%), and outer diameter (±0.05 mm) were propagated via Monte Carlo (1000 samples), yielding QoI uncertainty bands incorporated into the E/uval calculation. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires N≥10 test specimens from the production lot, with dimensional inspection of each specimen and traceability of material certificates. Statistical characterization of specimen variability must be reported.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were assembled from the production lot. Each specimen underwent CMM dimensional inspection; all within drawing tolerances. Material certificates for Ti-6Al-4V rod and UHMWPE spacer block were retained. Coefficient of variation for measured stiffness was 4.2%, consistent with expected manufacturing variability. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Testing was performed under a single ASTM F1717 standardized condition (static compression-bending, 5 mm/min displacement rate, ambient temperature). Although the protocol is fully standardized and consistently applied across both laboratories, only one loading rate and one environmental condition were evaluated. The required level 3 calls for at least two distinct test conditions or parametric variation to bound the response space; this study employed only the standard condition. The shortfall is accepted because the COU is limited to the ASTM F1717 standard loading scenario and the model is not being used to extrapolate beyond this condition. Achieved level 2 reflects single-condition compliance with a well-characterized standardized protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that each model input parameter is matched to its experimentally measured counterpart with a documented mapping table, and that any parameter not directly measured is justified by literature or sensitivity analysis demonstrating QoI insensitivity.",
      "rationale": "A parameter mapping table was prepared linking 14 model inputs (geometry, material properties, contact friction, boundary conditions) to their experimental sources. All geometry and material inputs are directly measured. Friction coefficient (mu=0.2) was not measured; sensitivity analysis showed ±50% variation in mu changes stiffness QoI by <1.8%, confirming insensitivity. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires a quantitative comparison metric (e.g., E/uval) that incorporates both experimental measurement uncertainty and model prediction uncertainty, with a defined pass/fail threshold applied to each QoI. All QoIs must satisfy E/uval < 1.96 at the 95% confidence level.",
      "rationale": "The validation metric E/uval was computed for each of the three QoIs: stiffness (E/uval=0.91), yield force (E/uval=1.12), force at 40 mm (E/uval=1.54). All three satisfy the pre-defined threshold of 1.96. Percentage errors (4.3%, 6.1%, 7.8%) are within the <10% acceptance bound. Gradation 3 achieved across all QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — are the primary outputs specified in ASTM F1717 and directly correspond to the clinical performance indicators for pedicle screw constructs under compressive bending loads. These QoIs are universally accepted in the spinal implant regulatory literature as surrogates for in vivo mechanical performance under the defined COU. Required level 2 reflects that QoI relevance is established by reference to a recognized standard (ASTM F1717) rather than by independent clinical outcome mapping. Achieved level 2 confirmed by traceability to ASTM F1717 Section 8."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that the validation scenario matches the COU in terms of device geometry, loading mode, boundary conditions, and material system, and that any differences between the validation scenario and the COU are documented with a quantitative assessment of their impact on model credibility.",
      "rationale": "The validation activity directly replicates the COU: identical non-cannulated 7.5 mm pedicle screw geometry, ASTM F1717 compression-bending loading, same Ti-6Al-4V material system, and same UHMWPE spacer block. No extrapolation beyond the validated scenario is claimed. The COU is strictly bounded to the ASTM F1717 standard test configuration. No differences between validation scenario and COU were identified. Gradation 3 achieved."
    }
  ],
