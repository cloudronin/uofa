  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors achieved their required level. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3; this shortfall is accepted because the COU is strictly limited to the ASTM F1717 standard loading condition and no extrapolation is claimed. The overall validation metric E/uval < 1.96 was satisfied for all three QoIs across N=11 specimens from two independent laboratories. The FEA model ensemble is judged sufficiently credible to support the submission claim for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
