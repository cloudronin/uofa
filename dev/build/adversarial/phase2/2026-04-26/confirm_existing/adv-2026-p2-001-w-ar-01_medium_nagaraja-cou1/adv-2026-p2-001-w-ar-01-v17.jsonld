  "signature": "ed25519:7b2e4f1a9c3d6e8b0f5a2c4d7e9b1f3a6c8d0e2f4b6a8c1d3e5f7a9b2c4d6e8f",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) must be validated under an FDA-recognized SQA plan; version control, regression test suite, and change-control logs must be available for audit. Gradation 2 requires documented SQA plan and version-controlled solver.",
      "rationale": "Ansys Mechanical 2022 R2 is operated under a documented SQA plan maintained by DePuy Synthes computational team. Version control (Git) and a regression test suite covering 47 benchmark cases are in place. Change-control logs were reviewed and found compliant. Achieved level 3 reflects independent code-verification activities beyond the minimum required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least three NAFEMS benchmark problems relevant to contact mechanics and large-displacement beam bending. Results must agree within 1% of analytical reference solutions.",
      "rationale": "Ansys Mechanical was verified against NAFEMS benchmarks LE1, LE5, and NL3 (contact with friction). All three problems reproduced analytical reference solutions within 0.4%, confirming the solver implementation is correct for the physics relevant to pedicle screw bending."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A mesh convergence study must demonstrate that the QoI (construct stiffness, yield force) changes by less than 2% between the production mesh and a uniformly refined mesh. Richardson extrapolation or GCI must be reported.",
      "rationale": "Mesh convergence was demonstrated across three refinement levels (coarse: 62 k elements, medium: 148 k, fine: 341 k). GCI for construct stiffness was 0.8% between medium and fine meshes; yield force GCI was 1.1%. The production mesh corresponds to the medium refinement level, comfortably within the 2% threshold. Achieved level 3 reflects formal GCI reporting exceeding the minimum requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria must be set to at least 1e-5 for force and moment residuals; energy convergence must be monitored and documented for each simulation run.",
      "rationale": "All simulations were run with force and moment residual convergence criteria of 1e-6. Energy convergence was monitored via Ansys internal diagnostics and confirmed for all 11 model instances. No non-convergent runs were observed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Model setup was performed by two independent analysts following a documented simulation protocol (SOP-FEA-CB-001). A peer-review checklist covering boundary conditions, material assignments, contact definitions, and load application was completed and signed off by a senior engineer. No discrepancies were identified between the two independent setups, supporting a use-error level of 2. The required level of 2 reflects the medium model influence and the need for at least one independent review of simulation inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model must capture nonlinear material behavior (titanium alloy Ti-6Al-4V) with isotropic hardening; contact between screw and rod must be modeled with friction (Coulomb, mu >= 0.2). Model form must be justified by published literature or prior validation studies.",
      "rationale": "A bilinear isotropic hardening model was used for Ti-6Al-4V (E=114 GPa, sigma_y=880 MPa, tangent modulus=1.2 GPa) consistent with published coupon test data. Frictional contact (mu=0.25) between screw shank and rod was confirmed by prior tribology testing. Model form is consistent with FDA-recognized guidance for metallic implant FEA and with the Nagaraja 2019 publication."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties must be sourced from coupon testing of the same lot of Ti-6Al-4V used in bench specimens; geometric dimensions must be taken from CMM measurements of actual test articles with tolerances reported.",
      "rationale": "Material properties were derived from tensile coupon testing (n=5 coupons, same material lot as bench specimens). Geometric dimensions for each of the 11 FEA model instances were taken from CMM measurements of the corresponding bench specimens (dimensional uncertainty < 0.02 mm). Input uncertainty was propagated using a Monte Carlo approach (1000 samples) and reported as part of the validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least 8 test specimens must be tested; specimens must be drawn from production lots and be representative of the intended device geometry and material specification.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (FDA CDRH and DePuy Synthes). All specimens were drawn from a single production lot and confirmed to meet dimensional and material specifications via incoming inspection. The sample size of 11 exceeds the minimum required and supports statistical characterization of experimental variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing must be performed under at least two distinct loading conditions (e.g., varying offset distance or load rate) to assess model sensitivity. A single test condition is insufficient for Gradation 2.",
      "rationale": "Testing was performed under a single ASTM F1717 test configuration (50 mm offset, quasi-static 5 mm/min crosshead speed). While this condition is the regulatory standard, it represents only one point in the loading space. The model has not been validated under alternative offset distances or load rates. This limitation is acknowledged; the achieved level of 1 reflects the single-condition constraint. The required level of 2 was set based on the medium model risk level, and this factor does not meet the requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading must be demonstrably equivalent to experimental setup; fixture compliance and grip effects must be either negligible (<1% influence on QoI) or explicitly modeled.",
      "rationale": "FEA boundary conditions replicate the ASTM F1717 fixture geometry as measured by the testing laboratories. A sensitivity study confirmed that fixture compliance contributes less than 0.5% to construct stiffness QoI. Grip effects were assessed and found negligible. Input parameter equivalency is documented in the V&V report Appendix B."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Comparison must use a quantitative metric (E/uval or equivalent) with a pre-specified acceptance threshold. The threshold must be documented before unblinding of simulation results. All three QoIs (stiffness, yield force, force at 40 mm) must be within acceptance bounds.",
      "rationale": "The validation metric E/uval (normalized error relative to combined simulation and experimental uncertainty) was pre-specified with a threshold of 1.96 (95% confidence interval). All three QoIs met this criterion: stiffness E/uval=0.84, yield force E/uval=1.12, force at 40 mm E/uval=0.97. The percentage difference for all QoIs was less than 10%. Results were unblinded after the acceptance criterion was locked in the study protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are directly specified in ASTM F1717 and are the quantities used by FDA reviewers to characterize implant mechanical performance. These QoIs are the same quantities predicted by the FEA model for the COU decision. The required level of 2 was established based on the direct regulatory relevance of the QoIs and the medium model influence rating; no additional QoI relevance justification is needed beyond the ASTM standard alignment. A structured acceptanceCriteria record was not separately documented for this factor as the QoI selection rationale was considered self-evident from the regulatory context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation configuration must match the COU device geometry (non-cannulated 7.5 mm screw), loading modality (compression-bending), and regulatory test standard (ASTM F1717). Any differences between validation and COU configurations must be assessed for their impact on model credibility.",
      "rationale": "The validation activity uses the identical device geometry, material, and test standard as the COU. Both validation and COU involve the non-cannulated 7.5 mm pedicle screw under ASTM F1717 compression-bending. There are no extrapolations in geometry, material, or loading modality. The validation is therefore directly relevant to the COU, supporting the achieved level of 3."
    }
  ],
