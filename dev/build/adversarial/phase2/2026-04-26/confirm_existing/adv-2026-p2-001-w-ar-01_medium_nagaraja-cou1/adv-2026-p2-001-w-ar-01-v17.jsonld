  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for COU1 is Accepted at Medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single exception — Test conditions (achieved level 1, required level 2) — is acknowledged as a limitation arising from the single-condition ASTM F1717 protocol. This shortfall is accepted because the regulatory standard mandates this specific test configuration, the model has been validated against the identical configuration used in the regulatory submission, and the medium decision consequence does not require multi-condition validation. All quantitative acceptance bounds (E/uval < 1.96, QoI difference < 10%) were met for all three quantities of interest.",
    "decidedAt": "2026-04-19T00:00:00Z"
