  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All three FEA solvers (Abaqus, Ansys, and the FDA in-house code) must be under an active SQA plan conforming to FDA 21 CFR Part 820 and ASME VVUQ-10. Version-controlled source repositories, regression test suites with >95% pass rate, and documented release notes are required.",
      "rationale": "Each solver in the ensemble operates under a documented SQA plan. Abaqus and Ansys hold ISO 9001 certifications; the FDA in-house code is version-controlled in a validated repository with automated regression testing. Release notes for the versions used (Abaqus 2019, Ansys 2020R2) are archived. Gradation 3 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from the ASME V&V 10 suite relevant to beam-column bending must be reproduced within 1% of analytical solutions. At least one published benchmark involving contact mechanics must be demonstrated.",
      "rationale": "Standard benchmark problems (Timoshenko beam, Hertzian contact patch) were executed in each solver and results agreed with analytical solutions to within 0.3%. Published verification reports are on file. Gradation 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A mesh convergence study must demonstrate that QoI values change by less than 2% between the penultimate and final refinement levels. Richardson extrapolation or GCI must be reported for each primary QoI.",
      "rationale": "Mesh convergence studies were conducted for all three QoIs. GCI values were below 1.5% for stiffness and yield force; force at 40 mm displacement showed GCI of 1.8%. The production mesh was selected at the converged level. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual tolerances for nonlinear iterations must be documented and set to values demonstrated in prior literature to yield solution-independent results for quasi-static structural contact problems.",
      "rationale": "Nonlinear solver tolerances (force residual 1e-4, displacement residual 1e-5) were verified against published guidance. Iterative convergence histories were archived for all 11 simulation cases. No spurious oscillations or non-convergence events were observed. Gradation 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be independently reviewed by a second analyst not involved in the original build. A documented checklist covering boundary conditions, material assignments, and contact definitions must be completed and archived.",
      "rationale": "An independent analyst reviewed the model setup against a 47-item checklist. Boundary conditions, material card assignments, and contact pair definitions were verified. Two minor discrepancies (incorrect friction coefficient on one contact pair) were identified and corrected before the production run. Gradation 3 exceeded the required Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "An elastic-plastic constitutive model with isotropic hardening was selected based on published titanium alloy characterization data. The model form is well-established for quasi-static metallic implant loading scenarios. Sensitivity analyses confirmed that alternative plasticity formulations (kinematic hardening) produced QoI differences below 0.8%, supporting the chosen model form at Gradation 3. The required level of 3 reflects that model form uncertainty is a primary driver of overall credibility for this COU, and the assessment team determined that documented sensitivity studies and literature precedent suffice to establish this gradation — however, the structured acceptanceCriteria entry was not separately codified at the time of assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (elastic modulus, yield strength, ultimate strength, hardening exponent) must be sourced from lot-specific coupon testing or peer-reviewed literature specific to Ti-6Al-4V ELI. Geometric inputs must be derived from CMM measurements of the actual test articles, not nominal CAD dimensions.",
      "rationale": "Ti-6Al-4V ELI material properties were taken from lot-specific tensile coupon data supplied by DePuy Synthes. Geometric dimensions were measured via CMM on three representative screws; mean values were used in the model with variability documented. Gradation 3 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least 10 test articles must be tested across at least two independent laboratories. Sample traceability (lot number, sterilization batch) must be documented. Statistical characterization of inter-sample variability must be reported.",
      "rationale": "N=11 constructs were tested across two independent laboratories (FDA CDRH and a contract test house). All samples originated from the same manufacturing lot; sterilization batch records are archived. Coefficient of variation for stiffness was 4.2%, for yield force 5.8%. Gradation 3 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing must cover at least two distinct loading configurations or environmental conditions relevant to the COU. If only a single ASTM F1717 configuration is available, a documented justification referencing clinical loading data must accompany the assessment.",
      "rationale": "Only a single ASTM F1717 compression-bending configuration was tested (5-degree offset, room temperature, dry). No alternative loading angles or simulated physiological fluid conditions were included. This limits the factor to Gradation 2, below the required Gradation 3. A risk-informed justification noting that the single condition represents the worst-case loading per ASTM F1717 is documented in the test report, but the gap is acknowledged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A parameter mapping table must document the correspondence between each experimental measurement and its FEA counterpart, including units, measurement uncertainty, and any transformation applied.",
      "rationale": "A formal parameter mapping table was prepared and reviewed. All 14 input parameters (geometry, material, boundary condition) were mapped to experimental measurements with associated uncertainties. No transformations beyond unit conversion were required. Gradation 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison must use the ASME V&V 40 validation metric E/uval. The metric must be below 1.96 for each primary QoI. Additionally, percent difference between mean FEA prediction and mean experimental value must be below 10% for each QoI.",
      "rationale": "E/uval values were 0.84 (stiffness), 1.12 (yield force), and 1.47 (force at 40 mm). All three are below the 1.96 threshold. Percent differences were 3.1%, 6.4%, and 8.7% respectively, all below 10%. Gradation 3 is achieved for output comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Each QoI must be traceable to a clinically or regulatorily relevant failure mode or performance threshold. A traceability matrix linking QoIs to FDA guidance documents or published clinical evidence must be provided.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are directly referenced in FDA guidance on spinal implant testing and are associated with clinical failure modes (screw fracture, construct loosening). A traceability matrix linking each QoI to the relevant FDA guidance section and supporting clinical literature is archived. Gradation 3 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A COU relevance matrix must demonstrate that the validation scenario matches the intended use scenario in geometry, loading, material, and scale. Any gaps must be quantified and their impact on prediction uncertainty assessed.",
      "rationale": "The validation scenario (non-cannulated 7.5 mm pedicle screw, ASTM F1717 bench test) directly mirrors the COU geometry and loading. The COU relevance matrix confirms alignment across all four dimensions. The single identified gap (room temperature vs. in vivo temperature) was assessed via sensitivity analysis and found to affect stiffness by less than 1%. Gradation 3 is achieved."
    }
  ],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed their required gradation levels. The single below-threshold factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is mitigated by the worst-case loading argument documented in the test report and by the strong E/uval results across all three QoIs. The overall credibility of the FEA model ensemble for predicting ASTM F1717 compression-bending performance of the non-cannulated pedicle screw construct is assessed as sufficient to support a Medium assurance level decision. The model may be used to support the regulatory submission.",
