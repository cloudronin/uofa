  "hash": "sha256:3a7f2c18e04b96d5f1a832c74de09b1f6c258a3e7d4b0f9c2e1d5a8b3c6f4e7a",
  "signature": "ed25519:9b2e4f1a7c3d0e6b8f5a2c9d4e7b1f3a6c8d0e2f4b7a9c1d3e5f7b0a2c4d6e8f",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA must demonstrate version-controlled source, documented build environment, and regression test suite covering all load-case routines. Required level 2 per model risk 3 and medium COU consequence.",
      "rationale": "All three FEA platforms (FDA in-house code, Ansys 2022R2, DePuy Synthes proprietary solver) operate under ISO 9001-compliant quality management systems. Version control (Git, SVN) is documented for each. Regression test suites were executed prior to the study runs and archived. Achieved level 3 reflects additional independent code audits performed by the FDA OSEL software team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include at least one analytical benchmark (e.g., Euler-Bernoulli beam) and one manufactured-solution test for the contact algorithm. Required level 2 consistent with medium model risk.",
      "rationale": "Each solver was verified against the NAFEMS LE1 and LE10 benchmarks and a cantilever beam analytical solution. Contact algorithm verification used a Hertzian contact patch test. All results within 1% of analytical reference solutions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence must be demonstrated by Richardson extrapolation or equivalent, with GCI < 5% for all primary QoIs. Required level 2 per standard COU risk profile.",
      "rationale": "A three-level mesh refinement study was conducted (coarse 1.5 mm, medium 0.75 mm, fine 0.375 mm global seed). Richardson extrapolation yielded GCI values of 2.1%, 1.8%, and 3.4% for stiffness, yield force, and force at 40 mm respectively. Medium mesh selected for production runs as the fine mesh provided negligible improvement at 6× computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals must fall below 1×10⁻⁶ for force equilibrium and 1×10⁻⁵ for displacement. Required level 1 reflects low sensitivity of static implicit analysis to solver tolerances.",
      "rationale": "Static implicit analyses were run with Newton-Raphson iteration. Force residuals converged to below 1×10⁻⁷ in all cases; displacement residuals below 5×10⁻⁶. No non-convergence events were recorded across all 11 model instances. Achieved level 2 because dual-solver cross-check (direct sparse and iterative PCG) was additionally performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Model setup was performed by three independent analysts following a written simulation protocol. Each analyst's boundary condition definitions, material assignments, and contact pair definitions were reviewed by a second analyst prior to execution. A pre-analysis checklist was completed and archived for all 11 model instances. No discrepancies were found between analysts' setups after reconciliation. Required level 2 is consistent with medium model influence and the multi-analyst cross-check procedure described in the simulation protocol (SP-COU1-v2.1). The level was determined by the assessment team based on the qualitative risk matrix in ASME V&V 40 Table 4-1 applied to a Class II implant with moderate clinical consequence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form must be justified by literature precedent for quasi-static metal implant FEA and sensitivity analysis showing QoI change <15% for plausible form alternatives (e.g., linear vs. bilinear plasticity). Required level 3 reflects high influence of constitutive model choice on yield force QoI.",
      "rationale": "Bilinear isotropic hardening (BISO) was selected for Ti-6Al-4V based on ASM handbook data and prior FDA validation studies. A model form sensitivity study compared BISO, multilinear kinematic hardening (MKIN), and Chaboche models; stiffness QoI varied <3%, yield force <8%, force at 40 mm <11% — all within the 15% threshold. Geometric nonlinearity (NLGEOM) was activated for all runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties must be sourced from specimen-specific tensile coupon testing or traceable published data with uncertainty bounds. Geometric inputs must derive from CMM measurements of test articles. Required level 3 per sensitivity of yield force QoI to material property variation.",
      "rationale": "Ti-6Al-4V elastic modulus and yield strength were obtained from tensile coupon testing of material from the same production lot as the test constructs (n=5 coupons per lot). CMM measurements of screw and rod geometry were used to construct specimen-specific CAD. Uncertainty in material inputs was propagated via Latin hypercube sampling (n=200 runs) confirming <5% QoI sensitivity to ±2σ material variation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test sample population must be N≥10 constructs from production-representative components, with dimensional inspection confirming conformance to drawing tolerances. Required level 2 per medium model risk.",
      "rationale": "N=11 constructs were assembled from production-representative 7.5 mm non-cannulated pedicle screws and 5.5 mm titanium rods. All components were dimensionally inspected by CMM prior to assembly. Components sourced from the same production lots as the clinical device. Assembly torque was controlled and recorded per ASTM F1717 protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate COU loading environment including at least two load-case configurations (e.g., varied offset distance or axial load component). Required level 3 reflects the need to bound model predictions across the clinical loading envelope.",
      "rationale": "Testing was conducted under ASTM F1717 standard conditions (70 mm offset, quasi-static 1 mm/min crosshead rate, ambient temperature, dry). Only one test configuration was evaluated; varied offset distances or combined loading scenarios were not included in this validation activity. Achieved level 2 because environmental controls (temperature, humidity) were documented and two independent laboratories produced consistent results, partially compensating for the single-condition limitation. The shortfall from required level 3 is acknowledged and documented as a known limitation of this validation campaign."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material, boundary conditions) must be traceable to measured test-article parameters with documented mapping table. Required level 2 per standard traceability expectation for Class II implant FEA.",
      "rationale": "A parameter equivalency matrix was prepared mapping each simulation input to its experimental measurement source (CMM geometry, coupon material data, load cell calibration records). Boundary conditions replicate the ASTM F1717 fixture kinematics including the spherical seat degrees of freedom. Achieved level 3 because specimen-specific models were constructed for all 11 constructs rather than a nominal geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Comparison metric must be the validation uncertainty metric E/uval with threshold E/uval < 1.96 (95% confidence) AND percent difference <10% for all primary QoIs. Required level 3 reflects the quantitative nature of the regulatory submission.",
      "rationale": "E/uval computed per ASME V&V 20 for all three QoIs: stiffness E/uval=0.84, yield force E/uval=1.21, force at 40 mm E/uval=1.47. All below the 1.96 threshold. Percent differences: stiffness 4.2%, yield force 7.8%, force at 40 mm 6.1% — all below 10%. Comparison performed separately for each of the 11 specimens and for ensemble statistics."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly linked to the clinical decision context (implant survival under physiological loading) and to the regulatory submission claims. Required level 2 per medium decision consequence.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the QoIs specified in ASTM F1717 and directly correspond to the structural performance claims in the 510(k) submission. Clinical relevance was established by mapping each QoI to failure modes identified in the device FMEA. Achieved level 3 because a quantitative clinical loading envelope analysis was additionally performed linking the 40 mm force to estimated in vivo loads from published gait data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same modeling framework, material system, and load case as the COU prediction. Required level 3 because the validation evidence is the primary basis for regulatory acceptance.",
      "rationale": "The validation constructs are geometrically and materially identical to the COU device. The same FEA workflow, meshing strategy, solver settings, and post-processing scripts were used for both validation and COU prediction runs. Two independent laboratories conducted testing, and three independent FEA teams performed analyses, providing strong evidence that the validation activities are directly relevant to the COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment yields an Accepted decision. Twelve of thirteen factors meet or exceed their required levels. The single shortfall — Test conditions achieving level 2 against a required level 3 — is offset by the strong performance across all quantitative comparison metrics (E/uval < 1.96 for all QoIs, percent differences < 10%) and the consistency of results across two independent laboratories and three independent modeling teams. The medium assurance level is appropriate for this Class II device with medium model influence and medium decision consequence. The assessment team concludes that the simulation evidence provides adequate credibility to support the regulatory submission claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
