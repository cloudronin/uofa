  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercially validated FEA solver (Ansys Mechanical) with documented version control, regression test suite, and ISO 9001-certified QMS. All simulation scripts stored in version-controlled repository with change log.",
      "rationale": "Ansys Mechanical R2023 R1 used under an institutional license with documented QMS. Internal regression tests confirm solver behavior across patch versions. Script repository tagged at commit hash for this submission. Gradation 3 achieved: solver is commercially validated, QMS documented, and simulation inputs are version-controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems reproducing beam bending and contact mechanics solutions to within 1% of analytical reference. Patch-test passage confirmed for all element types used.",
      "rationale": "Standard Ansys benchmark suite executed: cantilever beam bending and Hertzian contact reference cases both resolved within 0.4% of analytical solutions. Patch test passed for SOLID186 and CONTA174 elements. Gradation 2 achieved: code verification against known-solution benchmarks completed prior to production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Global Richardson extrapolation GCI < 2% for all three QoIs. Mesh refinement study with at least three systematically refined meshes; asymptotic range confirmed (GCI_fine/GCI_coarse ratio between 0.95 and 1.05).",
      "rationale": "Three-level mesh refinement study performed (coarse 0.8 mm, medium 0.5 mm, fine 0.3 mm global element size at screw-rod interface). Richardson extrapolation yielded GCI values of 1.1%, 0.9%, and 1.4% for stiffness, yield force, and force at 40 mm respectively. Asymptotic convergence confirmed. Production runs use medium mesh (0.5 mm) as the GCI penalty for fine mesh does not justify computational cost given GCI < 2% threshold already met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force-displacement residual norm < 1e-4 at each converged load step; energy criterion < 1e-5. Solver log reviewed for all 11 simulation instances.",
      "rationale": "Nonlinear static solver used with full Newton-Raphson iteration. Residual convergence criterion set to 1e-5 on force norm and 1e-6 on displacement norm. All 11 simulation instances converged without bisection beyond the first two load steps. Solver logs archived. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup by a second analyst not involved in original model construction. Documented checklist covering boundary conditions, material assignments, contact definitions, and load application.",
      "rationale": "Model setup independently reviewed by a second senior analyst using a 47-item checklist covering geometry import, material card assignments, contact pair definitions, boundary condition application, and load ramp profile. Three minor discrepancies identified and corrected prior to production runs (incorrect friction coefficient on one contact pair; wrong cross-sectional area for rod; misaligned local coordinate system for anisotropic titanium alloy). Gradation 3 achieved — exceeds required Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics constitutive model captures elastic-plastic behavior of Ti-6Al-4V with isotropic hardening; contact formulation includes friction; geometric nonlinearity (NLGEOM) enabled. Sensitivity analysis documents influence of constitutive model choice on QoIs.",
      "rationale": "Bilinear isotropic hardening (BISO) material model used for Ti-6Al-4V components. Augmented Lagrange contact with Coulomb friction (mu=0.2, per literature for Ti-Ti interfaces). NLGEOM enabled throughout. Sensitivity study compared BISO vs. multilinear kinematic hardening: QoI differences < 3%, confirming model form choice is not a dominant uncertainty source. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from traceable coupon tests on same material lot as test constructs; geometric dimensions from CMM measurements of production screws and rods; uncertainty bounds assigned to all inputs and propagated via Monte Carlo (N≥1000).",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa ± 3 GPa) and yield strength (880 MPa ± 15 MPa) measured from dog-bone coupons machined from the same material lot as test constructs. Screw and rod geometry from CMM measurements (n=5 per component type). Monte Carlo propagation (N=2000) yielded 95th-percentile prediction intervals reported alongside point estimates. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs tested; samples drawn from production lot; dimensional inspection confirms geometric conformance to drawing tolerances; two independent laboratories participate.",
      "rationale": "N=11 constructs tested across two independent laboratories (FDA/CDRH and a contract test lab). All constructs from production lot with CMM-verified dimensional conformance. Between-laboratory variability assessed via ANOVA; no statistically significant lab effect detected (p=0.31). Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Testing conducted under a single ASTM F1717 standard condition (axial compressive load at 5° from vertical, displacement-controlled at 1 mm/min, ambient temperature). Only one load configuration was evaluated; the required level of 3 calls for at least two distinct load conditions or parametric variations to bound model behavior across the COU envelope. The single-condition limitation is acknowledged; the sponsor has committed to supplementary testing at an alternative loading angle (10°) in the next submission cycle. Despite this gap, the existing data are sufficient to support a Medium assurance level decision given the constrained COU scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, material, boundary conditions, load) demonstrably matched to experimental conditions via traceability matrix; any discrepancies quantified and their effect on QoIs bounded.",
      "rationale": "Traceability matrix prepared mapping each simulation input to its experimental counterpart. Boundary condition equivalency confirmed: rigid platen displacement in simulation matches crosshead displacement in test; fixture compliance measured and incorporated as a spring element. Remaining discrepancy (idealized fixture geometry vs. as-built) bounded at <1.5% effect on stiffness QoI. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric (Oberkampf-Babuška); E/uval < 1.96 for all three QoIs; percent difference between mean FEA prediction and mean experimental result < 10% for each QoI.",
      "rationale": "E/uval computed for stiffness (0.84), yield force (1.12), and force at 40 mm (1.31) — all below the 1.96 threshold. Percent differences: stiffness 4.2%, yield force 6.8%, force at 40 mm 7.1% — all below 10%. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly specified in ASTM F1717 and are the same quantities used in the regulatory submission; linkage to clinical failure modes documented.",
      "rationale": "All three QoIs are mandated outputs of ASTM F1717 and appear verbatim in the 510(k) submission performance summary. Stiffness maps to subsidence risk; yield force maps to fatigue initiation threshold; force at 40 mm maps to construct integrity under worst-case intraoperative loading. Clinical linkage documented in risk analysis (ISO 14971 FMEA reference). Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, material, loading, and boundary conditions are within the applicability domain of the COU; any extrapolation is bounded and justified.",
      "rationale": "Validation constructs are the same 7.5 mm non-cannulated pedicle screw design as the COU device. Loading (ASTM F1717 compression-bending) is the regulatory standard directly referenced in the COU. No geometric or material extrapolation is required. The COU is therefore fully contained within the validation domain. Gradation 3 achieved."
    }
  ],
