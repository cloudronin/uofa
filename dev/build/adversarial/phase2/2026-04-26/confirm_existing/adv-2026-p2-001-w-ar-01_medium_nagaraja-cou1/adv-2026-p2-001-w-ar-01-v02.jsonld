  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA documentation must demonstrate version-controlled code, regression test suite with documented pass/fail records, and traceability from requirements to test cases. Gradation 2 requires at minimum a documented test plan and configuration management log.",
      "rationale": "The FEA ensemble employs Ansys Mechanical 2022 R2, which is a commercially validated solver with published QA documentation. DePuy Synthes and FDA both maintain internal SQA procedures including version control (Git), regression test suites, and change-control logs. Achieved Gradation 3 because independent code review records are available across two organizations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include at least one benchmark problem with analytical solution demonstrating solution convergence. Gradation 2 requires documented patch test or equivalent for the element formulations used.",
      "rationale": "Ansys SOLID186 elements were verified against NAFEMS benchmark LE1 and a cantilever beam with known analytical solution. Patch test results are documented in the solver validation report (Ansys ACT-VV-2022). Achieved Gradation 2 consistent with required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A mesh convergence study must be performed on QoIs (stiffness, yield force, force at 40 mm). Gradation 2 requires at least two mesh densities with documented relative change in QoI. Gradation 3 additionally requires Richardson extrapolation or GCI estimation.",
      "rationale": "Three mesh densities (coarse ~180k elements, medium ~420k elements, fine ~890k elements) were evaluated. Richardson extrapolation was applied to stiffness and yield force QoIs; GCI values were below 2% for all three QoIs on the medium mesh, which was selected for production runs. Achieved Gradation 3 exceeds the required Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver convergence criteria must be documented and residual tolerances reported. Gradation 2 requires force and displacement residuals below 1e-4 relative norm for all load steps.",
      "rationale": "All nonlinear load steps converged with force residual norm below 1e-5 and displacement residual below 1e-5. Newton-Raphson iteration counts and convergence histories are archived in the simulation log files. No diverged load steps were observed across the 11-specimen ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "A simulation execution checklist was developed and followed by each analyst. The analysis plan was reviewed by a second engineer at each of the two participating organizations prior to execution. Model inputs were independently cross-checked against the ASTM F1717 test fixture drawings and material certificates. No use errors were identified during the peer review process. Required Gradation 2 is met through documented peer review and checklist compliance, consistent with the medium model risk level for this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form adequacy must be justified by literature precedent and sensitivity analysis demonstrating that key modeling assumptions (contact formulation, material constitutive law, geometric fidelity) do not introduce bias exceeding 5% in QoIs relative to a higher-fidelity reference. Gradation 3 requires documented sensitivity study with quantified influence of at least three modeling assumptions.",
      "rationale": "Bilinear isotropic hardening was selected for Ti-6Al-4V based on published coupon data (MMPDS). Augmented Lagrangian contact was used at screw-rod interface. Sensitivity analyses varied friction coefficient (0.1–0.3), material tangent modulus (±15%), and contact stiffness scaling factor (0.1–10). Maximum QoI sensitivity was 4.2% for yield force with respect to tangent modulus, within the 5% threshold. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured or certified sources. Gradation 3 requires uncertainty characterization of key inputs (elastic modulus, yield strength, geometry tolerances) with documented propagation to QoI uncertainty bounds.",
      "rationale": "Elastic modulus (114 GPa ± 3%), yield strength (880 MPa ± 4%), and screw geometry (CT-measured, ±0.05 mm) were characterized from material certificates and metrology reports. Monte Carlo propagation (n=1000) was used to derive 95% prediction intervals on stiffness (±6.1%) and yield force (±5.8%). These bounds were incorporated into the E/uval metric for output comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be documented with traceability to production lots and dimensional inspection records. Gradation 2 requires lot traceability; Gradation 3 additionally requires dimensional characterization of each specimen used in validation testing.",
      "rationale": "All 11 non-cannulated 7.5 mm pedicle screw constructs were drawn from a single production lot (Lot 2021-NC-75) with full certificate of conformance. Each specimen was dimensionally inspected by coordinate measuring machine prior to testing, with results archived. Achieved Gradation 3 exceeds required Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate the boundary conditions and loading environment specified in ASTM F1717. Gradation 2 requires testing at a minimum of two load levels or loading configurations to characterize the response envelope. Gradation 1 is acceptable only with documented justification that a single test condition is conservative relative to the COU.",
      "rationale": "Testing was conducted exclusively at the single ASTM F1717 prescribed load configuration (10 mm offset, compression-bending). A second load condition (e.g., torsion or tension-bending) was not included in the validation campaign. This results in Gradation 1, which falls below the required Gradation 2. The gap is acknowledged; the validation team notes that the ASTM F1717 condition is the regulatory standard for this device class and that the COU is specifically scoped to compression-bending. A risk-informed justification for accepting this shortfall is documented in the decision record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Simulation inputs were mapped directly to measured specimen properties and test machine settings. Load application point, fixture geometry, and crosshead displacement rate were replicated in the FEA boundary conditions. A parameter equivalency table was prepared comparing each experimental measurement to its FEA counterpart, with documented sources. No unresolved discrepancies were identified. Gradation 2 is achieved through the documented equivalency table and traceability to test records. The required level of 2 is consistent with medium model influence and medium decision consequence for this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison must use a validation metric that accounts for experimental uncertainty. Gradation 3 requires the E/uval metric (or equivalent) with a defined acceptance threshold applied to all QoIs, with results reported for each specimen and in aggregate.",
      "rationale": "The E/uval metric was computed for each of the three QoIs (stiffness, yield force, force at 40 mm displacement) across all 11 specimens. All E/uval values were below 1.96 (95% confidence threshold), and percent differences were below 10% for all specimens. Aggregate results: stiffness mean |E/uval| = 0.84, yield force = 1.12, force at 40 mm = 0.97. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly linked to the clinical or regulatory decision endpoint. Gradation 2 requires documented traceability from QoI to the submission claim. Gradation 3 additionally requires sensitivity analysis confirming QoIs are the dominant predictors of the decision outcome.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly cited in the 510(k) substantial equivalence argument. A QoI relevance matrix was prepared tracing each QoI to the clinical failure mode (fatigue fracture, acute overload) and the regulatory acceptance criterion. Sensitivity analysis confirmed these three QoIs account for >90% of variance in the regulatory decision metric. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the COU that extrapolation risk is low. Gradation 3 requires a documented gap analysis between validation conditions and COU conditions, with quantified or bounded extrapolation uncertainty for any identified gaps.",
      "rationale": "The validation campaign used production-representative screws under the identical ASTM F1717 protocol that constitutes the COU. A gap analysis was performed comparing validation conditions to COU conditions across seven dimensions (geometry, material, loading, boundary conditions, scale, environment, operator). No significant gaps were identified for six dimensions; the single-load-condition gap (Test conditions factor) is bounded by the conservative nature of the ASTM F1717 compression-bending scenario. Overall relevance Gradation 3 is justified."
    }
  ],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall (Test conditions, achieved Gradation 1 vs. required Gradation 2) is accepted on the basis that ASTM F1717 compression-bending is the sole regulatory test configuration for this device class, the COU is explicitly scoped to this configuration, and the conservative nature of the loading scenario bounds extrapolation risk. All three QoIs satisfy E/uval < 1.96 and percent difference < 10% across all 11 specimens. Overall credibility is assessed as sufficient to support a medium-assurance submission claim for the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
