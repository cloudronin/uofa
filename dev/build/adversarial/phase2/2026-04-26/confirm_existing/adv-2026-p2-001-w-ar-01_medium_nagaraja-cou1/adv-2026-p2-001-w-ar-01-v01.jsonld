  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors met or exceeded their required levels. The single shortfall (Test conditions, achieved level 1 vs. required level 2) was accepted on the basis that ASTM F1717 is the applicable regulatory reference standard and the COU is explicitly scoped to that protocol. The validation metric E/uval was below 1.96 for all 33 QoI-specimen pairs, and all percentage differences were within the pre-specified 10% bound. The overall credibility of the FEA ensemble is sufficient to support the regulatory submission for the non-cannulated 7.5 mm pedicle screw construct.",
