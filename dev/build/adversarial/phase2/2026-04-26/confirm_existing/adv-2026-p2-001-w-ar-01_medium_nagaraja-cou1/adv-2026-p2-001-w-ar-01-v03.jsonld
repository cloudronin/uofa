  "hash": "sha256:3a7f2c1e9b04d58a6f1234567890abcdef1234567890abcdef1234567890abcd",
  "signature": "ed25519:9e1b2c3d4a5f6e7d8c9b0a1f2e3d4c5b6a7f8e9d0c1b2a3f4e5d6c7b8a9f0e1d",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All simulation software (Ansys Mechanical 2022 R2) used under institutional license with documented version control, regression test suite, and change-management records per ISO 9001. Required level 2 demands documented version control and basic regression testing; achieved level 3 additionally includes formal V&V test suite with traceability to requirements.",
      "rationale": "The FEA ensemble runs on Ansys Mechanical 2022 R2 under DePuy Synthes and FDA institutional licenses. Version control is maintained in Git with tagged release commits. A regression test suite of 47 benchmark cases is executed at each solver update. Change-management records are archived per ISO 9001 quality system. These controls satisfy and exceed the required level 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Required level 2 is satisfied by demonstrating that the solver reproduces at least two ASME V&V 10 benchmark problems (patch test and thick-walled cylinder) within 1% of analytical solution. This threshold is consistent with the medium model risk level and medium decision consequence.",
      "rationale": "Ansys Mechanical passes the standard patch test and the thick-walled cylinder pressure benchmark with errors below 0.4%, confirming correct implementation of the 3-D solid element formulation used in the screw-rod construct model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A mesh-convergence study must demonstrate that QoI values change by less than 2% between the penultimate and final refinement levels, with the Richardson extrapolation-based GCI below 3% for all primary QoIs. Required level 3 is appropriate given the stress concentrations at the screw-rod interface.",
      "rationale": "A four-level mesh-convergence study was conducted on the non-cannulated construct. Stiffness changed by 0.8% and yield force by 1.1% between levels 3 and 4. GCI values for all three QoIs are below 2.6%. Hex-dominant meshing with local refinement at the screw-rod interface and pedicle screw thread roots was used throughout."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criterion of 1e-6 for force and displacement norms must be met at each load step; energy balance error must remain below 0.1% over the full loading history.",
      "rationale": "All nonlinear quasi-static analyses converged to force and displacement residual norms below 1e-6 within 30 iterations per load step. Energy balance errors were below 0.05% across all 11 virtual specimens. No spurious hourglassing was detected in the solid element formulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Required level 2 mandates a documented simulation plan with peer review of model setup prior to execution and an independent check of boundary conditions and material assignments. Level 3 additionally requires a formal independent verification run by a second analyst.",
      "rationale": "A pre-analysis simulation plan was documented and peer-reviewed by two senior engineers before any computation was performed. Boundary conditions (fixed inferior vertebral body, applied displacement at superior body) and Ti-6Al-4V material properties were independently verified by a second analyst at FDA. The second analyst reproduced stiffness results within 0.3%, confirming absence of use error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Required level 3 demands that the constitutive model choice (bilinear isotropic hardening for Ti-6Al-4V) be justified against coupon-level material characterisation data and that contact formulation be validated against at least one independent benchmark involving frictional contact.",
      "rationale": "Bilinear isotropic hardening parameters (E=114 GPa, σ_y=880 MPa, E_t=1.5 GPa) were calibrated against tensile coupon data from the same Ti-6Al-4V bar stock used to manufacture the test constructs. Augmented Lagrangian frictional contact (μ=0.2) was validated against an ASME V&V 10.1 pin-in-hole benchmark. Geometric nonlinearity was included to capture large-displacement effects at 40 mm displacement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Required level 3 requires that all material and geometric inputs be traceable to measurement data from the actual test specimens, with uncertainty bounds quantified and propagated through a sensitivity analysis covering at least the top three influential parameters.",
      "rationale": "Geometry inputs were derived from CT scans and CMM measurements of the 11 physical constructs (dimensional tolerance ±0.02 mm). Material property uncertainty was characterised from 15 tensile coupons (CV<3% for E, CV<2% for σ_y). A one-at-a-time sensitivity analysis identified elastic modulus, yield strength, and screw-rod contact friction coefficient as the three most influential parameters; their combined contribution to QoI uncertainty was below 4%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Required level 3 demands N≥10 test specimens with documented traceability of material lot, manufacturing batch, and dimensional inspection records for each specimen.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. Each construct was assembled from screws and rods from a single manufacturing lot with full material certificates. Dimensional inspection records (CMM reports) are archived for all 11 specimens. Inter-laboratory reproducibility was confirmed by Bland-Altman analysis (limits of agreement within ±5% for stiffness)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "ASTM F1717 specifies a single standardized test configuration (50 mm inter-body spacer height, 35 mm screw offset). All 11 constructs were tested under this single condition at a crosshead displacement rate of 5 mm/min in ambient laboratory environment. Although the test conditions faithfully replicate the standard, only one load configuration was evaluated; the absence of varied offset distances or spacer heights limits the breadth of the validation domain. This shortfall was accepted given that the COU is explicitly bounded to the F1717 standard configuration, and the model risk level does not mandate multi-condition testing at this stage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Required level 3 demands that each FEA input parameter be demonstrably traceable to a corresponding measured or specified experimental parameter, with any discrepancies quantified and their effect on QoI bounded by sensitivity analysis.",
      "rationale": "A parameter equivalency table was prepared mapping each FEA input (geometry, material properties, boundary conditions, loading rate) to its experimental counterpart with documented source and uncertainty. No unmatched parameters were identified. Discrepancies in screw-rod interface torque (applied torque ±0.5 N·m) were propagated through the sensitivity analysis and found to contribute less than 1.2% variation in predicted stiffness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Required level 3 demands that the validation metric E/uval be computed for each QoI and that E/uval < 1.96 for all primary QoIs, supplemented by a percentage difference check (<10%) relative to the experimental mean.",
      "rationale": "E/uval values were 0.82 (stiffness), 1.14 (yield force), and 0.97 (force at 40 mm displacement), all below the 1.96 threshold. Percentage differences relative to experimental means were 3.1%, 4.7%, and 2.9% respectively, all within the pre-established 10% bound. Validation is therefore confirmed for all three primary QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Required level 3 demands that each QoI be directly linked to a regulatory or clinical endpoint and that the linkage be documented in the simulation plan.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and referenced in FDA guidance for spinal implant 510(k) submissions. Each QoI is linked to a clinical endpoint in the simulation plan: stiffness to immediate post-operative stability, yield force to fatigue life prediction, and force at 40 mm to catastrophic failure avoidance. An additional QoI (von Mises stress distribution) was computed for informational purposes, further supporting level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "The validation activity directly replicates the COU: the same screw geometry (non-cannulated 7.5 mm), the same loading protocol (ASTM F1717 static compression-bending), and the same material (Ti-6Al-4V) are used in both the validation experiments and the intended regulatory submission. The two-laboratory design increases confidence in result generalisability within the defined COU boundary. The COU is explicitly scoped to the F1717 standard configuration, so the single-condition limitation in Test conditions does not undermine the relevance assessment."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions achieving level 2 against a required level 3 — is accepted because the COU is explicitly bounded to the ASTM F1717 standard single-configuration test, and the regulatory guidance does not require multi-configuration validation for this device class at medium model risk. All three primary QoIs pass the pre-established E/uval < 1.96 and percentage-difference < 10% acceptance bounds. The overall credibility assessment supports use of the FEA framework for the non-cannulated pedicle screw 510(k) submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
