  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022 R2 and FDA in-house FEA code both hold current ISO 9001 quality management certification; documented V&V test suites executed prior to each analysis run; version-controlled input decks archived in institutional repository.",
      "rationale": "All three modeling environments (FDA, Ansys, DePuy Synthes) operate under documented SQA frameworks. Ansys holds ISO 9001 certification; FDA code is governed by FDA software quality guidance. Version control and regression testing are in place. Achieved level 3 exceeds the required level 2 for a Medium model-risk application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification demonstrated via patch tests and benchmark problems documented in Ansys Mechanical verification manual and FDA internal verification report VR-2021-003; all benchmark results within 1% of analytical solutions.",
      "rationale": "Patch tests and standard benchmark problems (cantilever beam, Hertz contact) were executed in all three FEA environments. Results agreed with analytical solutions to within 1%. This satisfies the required level 2 for numerical code verification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study required: QoI change between successive refinements must be less than 2% before final mesh is accepted; Richardson extrapolation reported for each QoI.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw and vertebral body components. Stiffness QoI changed by 1.4% between medium and fine meshes; yield force changed by 1.7%. Richardson extrapolation confirmed discretization error below 2% for all three QoIs. Final mesh contains approximately 420,000 elements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residual norms must fall below 1e-6 for force and moment equilibrium at each load step; energy balance checked at end of each increment.",
      "rationale": "Nonlinear quasi-static analyses used a full Newton-Raphson solver with force and moment convergence criteria of 1e-6. Energy balance was verified at each increment. No convergence anomalies were detected across 11 specimen simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by analyst not involved in original model construction; checklist of boundary condition and material assignment items signed off prior to submission.",
      "rationale": "Model setup was independently reviewed by a second analyst against a documented checklist covering boundary conditions, contact definitions, material assignments, and load application. All items confirmed correct. Use error risk is commensurate with the medium model-risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form adequacy demonstrated by prior published validation studies of equivalent continuum FEA for metallic spinal implants; isotropic linear-elastic titanium alloy material model justified by strain levels remaining below yield in the majority of loading scenarios.",
      "rationale": "The continuum FEA representation of the titanium alloy pedicle screw using isotropic linear-elastic material properties is well-established in the literature for ASTM F1717 compression-bending regimes. Strain levels in the screw body remain below 0.2% yield strain for the majority of the loading range. Bilinear kinematic hardening is applied above yield. Model form is appropriate for the intended QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon tensile tests on same lot material; geometric dimensions verified against CMM measurements of three production screws; input uncertainty quantified and propagated via Monte Carlo sampling.",
      "rationale": "Ti-6Al-4V material properties (E = 114 GPa, yield = 880 MPa) were measured from coupon tests on the same material lot as the test specimens. Screw geometry was verified against CMM measurements of three production screws with deviations below 0.05 mm. Input uncertainty was propagated via 500-sample Monte Carlo to confirm that parametric variability does not dominate model error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum N=10 specimens tested; specimens drawn from production lots and verified against engineering drawings; inter-specimen dimensional variability documented.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. All specimens were drawn from production lots and verified against engineering drawings. Dimensional variability was documented and used to inform the Monte Carlo input uncertainty analysis. Sample size exceeds the minimum of 10 required for level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two independent test configurations or loading rates required to demonstrate robustness of validation evidence; single-condition testing acceptable only at level 2.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending configuration at quasi-static loading rate. While the standard prescribes this condition, no additional loading rates or configurations were explored. This limits the factor to achieved level 2, which is below the required level 3. This shortfall is noted as an accepted limitation given that ASTM F1717 defines only one standard test condition for this implant type."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Boundary conditions in the FEA model replicate the ASTM F1717 fixture geometry, grip separation, and load application point. Material properties were measured from the same lot as the test specimens. Loading rate equivalency was confirmed by comparing quasi-static FEA results to experimental load-displacement curves. All input parameters were matched to within documented tolerances. The equivalency between simulation inputs and physical test conditions is considered fully established at level 3, consistent with the requirement for a medium model-risk device. The assessment team reviewed each input mapping and confirmed no systematic offset between physical and computational boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation metric E/uval must be less than 1.96 for each QoI; percentage difference between mean FEA prediction and mean experimental result must be less than 10% for each QoI.",
      "rationale": "For all three QoIs (stiffness, yield force, force at 40 mm), the validation metric E/uval was below 1.96 and the percentage difference between FEA and experimental means was below 10%. Stiffness: 3.2% difference, E/uval = 0.87. Yield force: 5.1% difference, E/uval = 1.12. Force at 40 mm: 4.8% difference, E/uval = 1.03. All three QoIs pass the pre-established acceptance bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must directly correspond to clinically relevant failure modes and regulatory submission endpoints; stiffness, yield force, and force at 40 mm displacement are all required outputs under ASTM F1717 and FDA guidance.",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — are the primary endpoints required by ASTM F1717 and referenced in FDA guidance for pedicle screw submissions. Each QoI is directly linked to a clinical failure mode: stiffness to load-sharing behavior, yield force to fatigue initiation, and force at 40 mm to construct survival under extreme loading. Relevance is fully established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same implant design, same material lot, same test standard, and same QoIs as the intended COU; any deviations from the COU must be explicitly documented and justified.",
      "rationale": "The validation activities were conducted on the same non-cannulated 7.5 mm pedicle screw design, same Ti-6Al-4V material lot, and under the same ASTM F1717 compression-bending protocol as the intended COU. The FEA model used in validation is identical to the model used for the regulatory submission prediction. No deviations from the COU were identified. The validation activities are fully relevant to the COU at level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed their required levels. The single shortfall — Test conditions achieving level 2 against a required level 3 — is accepted because ASTM F1717 prescribes only one standard compression-bending configuration for this implant class, and the regulatory pathway does not require multi-condition testing. All three QoIs pass pre-established acceptance bounds (E/uval < 1.96; percentage difference < 10%). The overall credibility of the FEA model ensemble is sufficient to support a Medium assurance level for this Class II device submission.",
