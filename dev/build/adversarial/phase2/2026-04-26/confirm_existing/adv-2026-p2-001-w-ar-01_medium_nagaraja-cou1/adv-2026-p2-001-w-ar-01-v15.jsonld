  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality assurance must achieve at least Gradation 2: version-controlled solver with documented verification tests and traceable build records. Gradation 2 requires evidence of systematic testing and configuration management.",
      "rationale": "Ansys Mechanical 2022 R2 is used under an ISO 9001-certified quality management system. The software is version-controlled, and all solver verification benchmarks are documented in the vendor's verification manual. DePuy Synthes internal QMS records confirm build traceability. Achieved Gradation 3 due to additional independent benchmark comparisons performed by the FDA modeling team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification must achieve at least Gradation 2: solver benchmarked against analytical solutions or established reference problems for the element types and contact formulations used in this model. Documentation must be available in the project record.",
      "rationale": "Patch test and single-element benchmark analyses were conducted for the hexahedral and tetrahedral element formulations used in the pedicle screw and vertebral body models. Contact formulation was verified against Hertzian contact analytical solutions. Results matched reference solutions within 0.5%, satisfying Gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be assessed at Gradation 2 or higher: a formal mesh convergence study must demonstrate that QoI changes by less than 5% between the production mesh and a refined mesh, or Richardson extrapolation must be applied to quantify the discretization error bound.",
      "rationale": "A three-level mesh refinement study was conducted on the pedicle screw shank region, which governs the yield force QoI. QoI values changed by less than 2.1% between the medium and fine mesh, and Richardson extrapolation estimated a discretization error of 1.4% on the production mesh. Gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical solver error must be addressed at Gradation 1 or higher: default solver tolerances must be documented and residual convergence confirmed for all load steps. No tighter tolerance requirement is imposed given the linear-elastic dominant response.",
      "rationale": "All nonlinear iterations converged to a force residual below 1e-4 and a displacement residual below 1e-5 for every load step across all 11 simulated constructs. Solver settings are documented in the simulation report. Gradation 2 achieved due to additional sensitivity study on tolerance settings confirming QoI insensitivity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Use error must be controlled at Gradation 2: a documented simulation plan and independent technical review of model setup, boundary conditions, and material assignments must be completed prior to results extraction.",
      "rationale": "A simulation plan was prepared prior to analysis execution and reviewed independently by a second engineer not involved in model construction. Boundary conditions, contact definitions, and material assignments were checked against the F1717 test fixture drawings. No discrepancies were identified. Gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "The pedicle screw construct is modeled as a continuum solid with nonlinear isotropic hardening plasticity for the titanium alloy (Ti-6Al-4V), calibrated from coupon-level tensile test data. Thread geometry is explicitly represented in the finite element mesh rather than simplified via connector elements, consistent with the need to capture local stress concentrations governing yield force prediction. Geometric nonlinearity is included to capture large-displacement effects at 40 mm displacement. The model form is judged appropriate for the QoIs of interest. Gradation 3 is achieved because the model form selection is supported by a documented physics justification and a sensitivity study comparing explicit-thread versus simplified-thread representations, which showed a 12% difference in yield force — confirming that explicit thread modeling is necessary. No acceptanceCriteria structured field is provided for this factor; the required level of 3 reflects the model risk level and the sensitivity of the yield force QoI to local thread geometry, as discussed in the simulation plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs must be characterized at Gradation 2 or higher: material properties and geometric dimensions must be sourced from traceable measurements or certified material data sheets, with uncertainty bounds reported for each primary input parameter.",
      "rationale": "Ti-6Al-4V material properties (elastic modulus, yield strength, hardening curve) were measured from five tensile coupons machined from the same billet as the test constructs. Geometric dimensions were measured from three representative screws using coordinate measuring machine data. Uncertainty bounds on all primary inputs are tabulated in the simulation report. Gradation 3 achieved due to propagation of input uncertainties through the model via a one-at-a-time sensitivity study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be characterized at Gradation 2: the physical test specimens must be from the same manufacturing lot and design revision as the simulated geometry, and key dimensional measurements must be reported to confirm representativeness.",
      "rationale": "All 11 constructs were assembled from screws and rods from a single manufacturing lot (Lot 2021-NC-75). CMM measurements of screw shank diameter, thread pitch, and rod diameter were reported for each specimen and compared against nominal CAD dimensions. Maximum deviation was 0.03 mm, well within drawing tolerances. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must be characterized at Gradation 2: loading rate, environmental conditions, and fixture alignment must be documented for each test replicate, and the simulation boundary conditions must demonstrably match the reported test conditions.",
      "rationale": "Testing was conducted under a single loading condition (displacement-controlled at 25 mm/min, ambient temperature, standard F1717 fixture) across both laboratories. While the test conditions are well-documented and consistent with the simulation boundary conditions, only one loading rate and one environmental condition were evaluated. This limits the factor to Gradation 1, as no variation in test conditions was explored to bound the sensitivity of the QoIs to loading rate or temperature. This is a known scope limitation of the validation campaign. The required level of 2 is not met; this factor is flagged as below required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Equivalency of input parameters must be demonstrated at Gradation 2: a documented mapping must show that each simulation input parameter corresponds to a measured or specified test parameter, with any discrepancies between simulation and test inputs identified and their effect on QoIs assessed.",
      "rationale": "A parameter equivalency table was prepared mapping each simulation input (geometry, material, boundary conditions, loading) to the corresponding test measurement or specification. Two minor discrepancies were identified: (1) the polyaxial screw head locking mechanism was modeled as fully rigid, whereas the test specimens exhibited a small rotational compliance of approximately 0.2 degrees; (2) the UHMWPE vertebral body simulant density was taken from the literature rather than measured from the specific lot used in testing. Both discrepancies were assessed via sensitivity analysis and found to contribute less than 1.5% change to the QoIs. Gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison must be performed at Gradation 3: a quantitative validation metric must be computed for each QoI, incorporating both experimental uncertainty and simulation numerical uncertainty, and compared against a pre-specified acceptance threshold. The metric must be reported for all replicates.",
      "rationale": "The validation metric E/uval was computed for each of the three QoIs (stiffness, yield force, force at 40 mm) across all 11 constructs at both laboratories. Experimental uncertainty was estimated from replicate variability; simulation numerical uncertainty was estimated from the discretization error study and input sensitivity analysis. All E/uval values were below 1.96, satisfying the pre-specified acceptance threshold. Additionally, the percentage difference between mean FEA prediction and mean experimental result was below 10% for all three QoIs. Gradation 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Relevance of QoIs must be demonstrated at Gradation 2: a documented justification must link each validation QoI to the clinical or regulatory decision being supported, showing that the QoIs are sensitive to the failure modes of concern.",
      "rationale": "Construct stiffness governs the load-sharing behavior between the implant and the spine. Yield force is the primary safety-relevant QoI because it predicts the onset of permanent deformation under physiological loading. Force at 40 mm displacement corresponds to the F1717 standard endpoint and is required for regulatory submission. All three QoIs are directly specified in the ASTM F1717 standard and are accepted by FDA as appropriate surrogate endpoints for pedicle screw mechanical performance. Gradation 3 achieved because a documented sensitivity analysis confirms that the QoIs are the dominant predictors of construct fatigue life in the associated fatigue analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Relevance of validation activities to the COU must be demonstrated at Gradation 3: the validation test configuration, specimen geometry, material, and loading must closely match the COU conditions, and any differences must be documented with a quantitative assessment of their effect on the QoIs.",
      "rationale": "The validation experiments were conducted using the same screw design, rod diameter, and construct configuration as the COU. The F1717 fixture geometry and loading protocol are identical to those specified in the regulatory submission. The UHMWPE vertebral body simulant is the standard surrogate material specified by F1717 and accepted by FDA as representative of in vivo bone stiffness for this test type. The only difference between the validation configuration and the COU is that the COU encompasses a range of rod lengths (35–60 mm), while the validation used a single rod length (45 mm). A parametric simulation study demonstrated that QoI sensitivity to rod length variation within this range is less than 4%, which does not affect the credibility conclusion. Gradation 3 is satisfied."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single exception — Test conditions (achieved Gradation 1 vs. required Gradation 2) — reflects the single-loading-rate, single-environment design of the F1717 validation campaign, which is standard practice for this device type and accepted by FDA guidance. The remaining factors collectively provide sufficient confidence that the FEA model ensemble reliably predicts compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct within the stated acceptance bounds. The credibility assessment supports use of the model for the regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
