  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted because the ASTM F1717 standard condition is the sole regulatory comparator condition and all three QoIs satisfy the pre-established quantitative acceptance bounds (E/uval < 1.96; percentage difference < 10%). Overall credibility is assessed as sufficient to support the Medium assurance level required for this Class II, Medium model risk device submission.",
