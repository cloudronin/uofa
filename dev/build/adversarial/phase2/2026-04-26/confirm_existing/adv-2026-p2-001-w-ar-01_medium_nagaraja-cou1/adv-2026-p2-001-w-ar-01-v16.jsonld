  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for COU1 is accepted at Medium assurance level. Twelve of thirteen credibility factors meet or exceed their required gradation levels. The single below-required factor (Test conditions, achieved Gradation 1 vs. required Gradation 2) is acknowledged and accepted on the basis that ASTM F1717 static testing is the applicable regulatory standard for this device class and that the static condition conservatively bounds fatigue-dominated failure modes for the specific regulatory decision being supported. The quantitative output comparison demonstrates that all three QoIs fall within pre-specified acceptance bounds (<10% difference, E/uval < 1.96), providing sufficient evidence to support the substantial equivalence submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
