  "signature": "ed25519:7a3f1e9c2b5d4a0f8e6c3b1d9f7a2e5c4b0d8f3a1e6c2b9d5f7a0e4c8b2d6f3a",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022R2 holds ISO 9001 certification and FDA-recognized validation documentation; version-controlled input decks stored in Git with audit trail. Gradation 2 requires formal QMS coverage of the simulation software; Gradation 3 additionally requires traceable version control of all simulation inputs.",
      "rationale": "The FEA ensemble uses Ansys Mechanical 2022R2, which is covered by an ISO 9001-certified QMS. All input decks are under Git version control with commit hashes recorded in the study record. SQA documentation package reviewed and approved by the sponsor quality team prior to study execution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Required Gradation 2: benchmark problems representative of compression-bending contact mechanics must be solved and compared to analytical or published reference solutions with agreement within 1%. Gradation 1 (spot-check only) is insufficient given the nonlinear contact formulation employed.",
      "rationale": "Standard Ansys benchmark suite for nonlinear contact problems was executed, including Hertzian contact and cantilever bending benchmarks. All results agreed with reference solutions to within 0.8%, satisfying Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires a systematic mesh convergence study with at least three mesh densities and Richardson extrapolation or equivalent GCI analysis on each QoI. Discretization error contribution to total uncertainty budget must be quantified and reported.",
      "rationale": "A three-level mesh convergence study (coarse, medium, fine) was conducted on the pedicle screw construct model. GCI values for stiffness, yield force, and force at 40 mm were 0.4%, 0.7%, and 0.5% respectively, all well below the 2% threshold. Discretization error is included in the combined uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2: solver convergence tolerances must be documented and tightened until QoI changes are less than 0.1% upon further tightening; residual norms reported for each simulation run.",
      "rationale": "Force and displacement residual convergence tolerances set to 1e-4 and 1e-3 respectively. Sensitivity check with tolerances tightened by one order of magnitude showed QoI changes below 0.05%. Convergence histories archived with each simulation output file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2: a documented simulation execution checklist must be completed and reviewed by an independent analyst prior to result extraction; any deviations recorded in the study log.",
      "rationale": "A 47-item simulation execution checklist was developed and completed by the primary analyst for each of the 11 construct simulations. An independent reviewer verified checklist completion and signed off prior to post-processing. No deviations were recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3: the model form must be justified by literature precedent for pedicle screw FEA under quasi-static bending, and sensitivity of QoIs to key model-form choices (contact formulation, material constitutive law) must be quantified.",
      "rationale": "Linear elastic titanium alloy (Ti-6Al-4V, E=114 GPa, nu=0.34) with augmented Lagrangian frictional contact (mu=0.2) was selected based on published ASTM F1717 FEA literature. Sensitivity runs with penalty contact and mu=0.15–0.25 showed QoI variation below 3%, confirming model-form robustness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3: material properties and geometric inputs must be sourced from measurements on the actual test specimens or certified material certificates; uncertainty on each input quantified and propagated to QoI uncertainty.",
      "rationale": "Ti-6Al-4V material properties sourced from DePuy Synthes material certificates for the production lot used in bench testing. Geometric dimensions measured via CMM on three representative screws; dimensional uncertainty (±0.02 mm) propagated through the model using a one-at-a-time sensitivity study contributing <1.5% to QoI uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3: N≥10 test specimens from the production lot; dimensional and material characterization performed on a representative subset; between-specimen variability quantified and included in validation uncertainty.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two laboratories (FDA CDRH and an independent test house). Specimens drawn from a single production lot. CMM measurements on 3 specimens; between-specimen dimensional CV below 0.5%. Sample variability included in experimental uncertainty estimate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Testing was performed under a single ASTM F1717 standard condition (quasi-static, displacement-controlled, 5 mm/min crosshead speed, room temperature, dry). Only one load configuration was evaluated; variation in loading angle or rate was not explored. This limits the assessment to Gradation 2, as the required Gradation 3 would demand at least two independent test conditions or loading configurations to bound the model's predictive envelope. The shortfall is accepted because the COU is explicitly scoped to standard F1717 quasi-static conditions and the model influence is rated Medium."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2: model boundary conditions and loading must be demonstrably equivalent to the bench test setup; fixture compliance documented and either included in the model or shown to be negligible.",
      "rationale": "Fixture compliance measured at 0.12 N/mm and incorporated into the FEA boundary conditions as a spring element at the load application point. Load application angle matched to the test machine crosshead alignment (±0.5°). Equivalency confirmed by overlay of load-displacement curves in the elastic regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3: quantitative comparison metric (E/uval) computed for each QoI using combined simulation and experimental uncertainty; E/uval < 1.96 required for all three QoIs; percent difference also reported.",
      "rationale": "E/uval values: stiffness 0.84, yield force 1.21, force at 40 mm 1.07. Percent differences: 3.2%, 4.8%, 3.9% respectively. All metrics satisfy the pre-established acceptance bounds (<10% difference, E/uval < 1.96). Validation is considered successful for all three QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3: QoIs must map directly to the clinical failure modes of interest (construct stiffness for subsidence risk, yield force for intraoperative fracture risk, force at 40 mm for fatigue-representative displacement); mapping documented in the COU definition.",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — were selected because they directly characterize the mechanical performance attributes that FDA reviewers use to assess pedicle screw construct adequacy. The mapping from QoI to clinical failure mode is documented in the COU definition and reviewed by the sponsor's clinical team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3: the validation scenario (geometry, loading, boundary conditions, material) must be identical or bounding relative to the COU; any differences between the validation scenario and the COU must be documented with a gap analysis.",
      "rationale": "The validation activity uses the identical screw geometry, material lot, and test protocol as the COU. No extrapolation in geometry or loading is required. A formal gap analysis was completed confirming that the validation scenario is not merely similar but identical to the COU scenario, satisfying Gradation 3 relevance requirements."
    }
  ],
