  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary QoI comparison — stiffness, yield force, force at 40 mm displacement",
      "description": "FEA ensemble predictions for construct stiffness (N/mm), yield force (N), and force at 40 mm displacement (N) were evaluated against the Nagaraja et al. experimental dataset. The Nagaraja (2018) study is widely cited as a benchmark for pedicle screw FEA validation and employs a titanium alloy (Ti-6Al-4V) construct assembled to UHMWPE test blocks per ASTM F1717. Across N=11 non-cannulated specimens, the FEA ensemble mean stiffness differed by 4.2% from experiment, yield force by 6.8%, and force at 40 mm by 7.1%, all within the pre-specified 10% acceptance band. The normalized error metric E/uval was 1.41, 1.63, and 1.58 for the three QoIs respectively, each below the 1.96 threshold. The validation activity is therefore assessed as satisfactory. Note: the experimental reference dataset employed in this validation was collected under a load application rate of 25 mm/min, consistent with common F1717 practice and the Nagaraja protocol; this comparator is considered directly applicable to the declared COU without further qualification."
    },
    {
      "id": "https://uofa.net/synth/validation/secondary-mesh-sensitivity",
      "type": "ValidationResult",
      "name": "Secondary validation — mesh sensitivity cross-check against cannulated specimen data",
      "description": "A supplementary validation was performed using the cannulated 7.5 mm pedicle screw experimental data (N=8 constructs, same laboratory, same test frame) to verify that the FEA mesh topology and contact definitions do not introduce systematic bias attributable to geometry parameterization rather than material response. Predicted stiffness deviated by 5.1% from cannulated experiment means. Although the cannulated geometry is not the subject of COU1, the structural similarity of the FEA framework across both geometries supports confidence in the non-cannulated predictions.",
      "comparedAgainst": "https://uofa.net/synth/data/nagaraja-bench-n8-cannulated"
    }
  ],
