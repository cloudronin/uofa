  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/vv40-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for Medium model risk and Medium decision consequence. The single below-required factor (Test conditions, achieved level 2 vs required level 3) is acknowledged as a limitation: all experimental constructs used a single inter-screw span (44 mm) and single rod diameter (5.5 mm), which constrains the generalisability argument across the full COU parameter space. The assessment team accepts this limitation on the basis that (a) the validated configuration represents the most clinically prevalent construct geometry, (b) parametric FEA sensitivity studies confirm monotonic QoI response to span and rod diameter variation within the COU envelope, and (c) the E/uval acceptance criterion is satisfied for all three primary QoIs across both validation result sets. The overall credibility evidence is judged sufficient to support the regulatory submission claim at the Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
