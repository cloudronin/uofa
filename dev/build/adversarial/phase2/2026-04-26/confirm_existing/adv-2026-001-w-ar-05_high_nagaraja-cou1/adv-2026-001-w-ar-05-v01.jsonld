  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-threshold factor (Test conditions, achieved 2 vs required 3) was accepted on the basis that ASTM F1717 mandates a single quasi-static displacement rate and that rate sensitivity for titanium pedicle screw constructs is well-characterised in the published literature. All three primary QoIs satisfy the pre-specified E/uval < 1.96 acceptance criterion. Corroborating evidence from a historical cannulated 7.5 mm dataset further supports the modeling framework. Overall credibility is assessed as sufficient for a Medium model risk, Medium decision consequence COU at the Medium assurance level. Submission package approved for regulatory filing.",
