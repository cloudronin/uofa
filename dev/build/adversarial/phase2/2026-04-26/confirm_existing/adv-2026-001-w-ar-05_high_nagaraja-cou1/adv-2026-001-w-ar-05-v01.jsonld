    "https://uofa.net/synth/data/nagaraja-n11-noncannulated-lab2",
    "https://uofa.net/synth/data/cannulated-7p5mm-historical-f1717"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "Medium",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "deviceClass": "Class II",
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary QoI comparison — stiffness and yield force (no comparator link)",
      "description": "FEA-predicted construct stiffness and yield force were evaluated against the N=11 non-cannulated experimental constructs. Normalized error E/uval was computed for each specimen; all 11 values fell within the pre-specified acceptance band (E/uval < 1.96). Mean percent difference for stiffness was 4.2% and for yield force was 6.8%, both within the <10% threshold. The validation team noted that results from a well-characterised historical 7.5 mm screw dataset — collected under the same ASTM F1717 protocol and exhibiting comparable load-displacement linearity — provided strong corroborating context for interpreting these outcomes. That historical dataset was produced under identical crosshead displacement rate (5 mm/min), identical UHMWPE block geometry, and the same two-level construct configuration, and was therefore judged to reinforce confidence in the primary comparison. No anomalous outliers were identified. The assessment is considered satisfactory."
    },
    {
      "id": "https://uofa.net/synth/validation/secondary-force-40mm",
      "type": "ValidationResult",
      "name": "Secondary QoI comparison — force at 40 mm displacement",
      "description": "FEA-predicted force at 40 mm displacement was compared against experimental measurements from the N=11 non-cannulated constructs. Mean FEA prediction was 312 N versus experimental mean of 298 N (4.7% difference). E/uval = 0.91, within the acceptance criterion of 1.96. Acceptance criterion satisfied.",
      "comparedAgainst": "https://uofa.net/synth/data/nagaraja-n11-noncannulated-lab1",
      "acceptanceCriterion": "E/uval < 1.96 and percent difference < 10%",
      "outcomeStatus": "passed"
    },
    {
      "id": "https://uofa.net/synth/validation/corroborating-cannulated-comparison",
      "type": "ValidationResult",
      "name": "Corroborating comparison against historical cannulated 7.5 mm F1717 dataset",
      "description": "As an additional confidence-building exercise, FEA predictions were compared against a historical experimental dataset of cannulated 7.5 mm pedicle screws tested under ASTM F1717 static compression-bending (N=8, same UHMWPE block, same crosshead rate, same two-level construct). The cannulated design shares outer diameter, thread pitch, and titanium alloy grade (Ti-6Al-4V ELI) with the non-cannulated construct evaluated in this COU. FEA predictions for stiffness and yield force showed agreement within 7.3% and 8.1% respectively against the cannulated dataset. The validation team assessed this corroborating comparison as providing strong additional evidence that the modeling framework captures the dominant load-transfer mechanisms in the screw-rod-block system. The comparison was documented as supporting the overall credibility argument for the non-cannulated COU without reservation.",
      "comparedAgainst": "https://uofa.net/synth/data/cannulated-7p5mm-historical-f1717",
      "acceptanceCriterion": "Qualitative corroboration; percent difference < 10%",
      "outcomeStatus": "passed"
    }
