      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions overlap the CFD boundary conditions within documented uncertainty bounds.",
      "rationale": "The FDA pump experimental dataset specifies flow rates of 2.5–7.0 L/min and impeller speeds of 2000–3500 RPM. CFD boundary conditions were set to match these operating points. Temperature and fluid viscosity were matched to the phosphate-buffered saline blood analog used in experiments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis agrees with experimental values within ±30% across all 5 operating points.",
      "rationale": "Predicted NIH values ranged from 0.0021 to 0.0087 g/100 L against experimental values of 0.0019 to 0.0091 g/100 L. Maximum relative error was 18.4% at the 3500 RPM / 2.5 L/min operating point. All 5 comparisons fell within the ±30% acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
