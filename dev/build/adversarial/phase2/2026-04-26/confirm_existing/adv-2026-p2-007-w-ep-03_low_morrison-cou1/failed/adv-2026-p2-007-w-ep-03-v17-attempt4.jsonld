  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan with version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-compliant QA plan. Version control logs, regression test suite results, and release notes were reviewed. Achieved level meets required level for MRL 2."
    },
    {
