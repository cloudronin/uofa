      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions or manufactured solutions for the governing equations relevant to the hemolysis simulation.",
      "rationale": "Code verification was performed using the method of manufactured solutions for the incompressible Navier-Stokes equations and the scalar hemolysis transport equation. Order-of-accuracy tests confirmed second-order spatial accuracy. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be estimated using Richardson extrapolation or grid convergence index (GCI) with at least three mesh refinement levels.",
      "rationale": "Three systematically refined meshes (2.1M, 6.8M, and 19.4M elements) were used. GCI was computed for the NIH quantity of interest. Maximum GCI of 3.2% on the fine mesh was within acceptable bounds for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and matched to simulation boundary conditions within stated uncertainty bounds.",
      "rationale": "Test conditions from the FDA benchmark study are documented in the published protocol. Flow rates and rotational speeds were matched to within 1% of experimental set-points. Fluid temperature and viscosity conditions are reported and replicated in the CFD setup."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within combined simulation and experimental uncertainty at all five operating points.",
      "rationale": "Predicted NIH values at all five operating conditions fell within the experimental uncertainty band (±15%). Mean absolute error was 8.3%. The RH index criterion RH < 1 was satisfied at all operating points, confirming the model meets the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest (NIH, RH index) must be directly relevant to the clinical endpoint of pump-induced hemolysis in CPB patients.",
      "rationale": "NIH and the relative hemolysis index RH are established metrics in FDA guidance for blood-contacting device evaluation. Both quantities directly characterize red blood cell destruction under mechanical shear, which is the primary clinical concern for CPB pump selection."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
