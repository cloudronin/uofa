      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error beyond discretization error assessment is not required at Model Risk Level 2. Residual convergence to 1e-6 and mass imbalance below 0.01% documented as sufficient evidence of solver correctness for this application."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
