      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented test suite covering relevant flow regimes.",
      "rationale": "ANSYS Fluent 2023 R1 is used under institutional version control. A formal software quality plan documents regression tests for rotating machinery and non-Newtonian blood rheology. All required SQA activities for MRL 2 are complete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate order-of-accuracy consistent with documented discretization scheme on canonical rotating flow benchmarks.",
      "rationale": "Order-of-accuracy testing performed on Taylor-Couette flow and lid-driven cavity problems confirms second-order spatial accuracy. Results archived in the project verification report VR-2025-04."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for pressure rise and hemolysis index QoIs.",
      "rationale": "Three-level mesh refinement study conducted at 2.5 L/min, 3500 RPM operating point. GCI for pressure rise is 2.1% and for normalized hemolysis index is 3.8%, both within the 5% threshold. Fine mesh of 4.2 million cells selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must bracket the CFD operating envelope with documented uncertainty in flow rate, rotational speed, and fluid properties.",
      "rationale": "In-vitro experiments conducted at five flow-speed combinations spanning 2.0–5.0 L/min and 2500–4500 RPM. Temperature controlled at 37 ± 0.5 °C. Flow rate uncertainty ±2%, speed uncertainty ±10 RPM, both within acceptable bounds for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predicted by CFD must agree with experimental measurements within ±25% across all five operating points.",
      "rationale": "CFD-predicted NIH values agree with in-vitro measurements within 18% at all five operating points. Maximum discrepancy of 18% observed at 5.0 L/min, 4500 RPM. Systematic under-prediction attributed to power-law viscosity model approximation at high shear rates."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, pressure rise, wall shear stress distribution) must directly map to the COU decision metric (relative hemolysis index RH).",
      "rationale": "Normalized index of hemolysis is the primary validation QoI and maps directly to the relative hemolysis index acceptance criterion. Pressure rise provides secondary confirmation of hydraulic performance. Wall shear stress distributions identify localized hemolysis risk regions consistent with COU intent."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on the same pump geometry family and overlapping operating conditions as the COU.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the same device family as the COU. Operating conditions in validation bracket the COU design space. Fluid (bovine blood analog) and temperature conditions replicate clinical CPB conditions sufficiently for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
