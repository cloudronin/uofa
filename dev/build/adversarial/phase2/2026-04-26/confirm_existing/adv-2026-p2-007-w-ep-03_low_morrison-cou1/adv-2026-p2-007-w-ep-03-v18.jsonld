      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterization beyond standard donor screening not mandated.",
      "rationale": "Experimental blood samples sourced from certified animal facility under standard protocol. Detailed sample characterization (hematocrit distribution, age of blood) not formally assessed at MRL 2."
