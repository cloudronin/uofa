  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release notes and regression test suite passing at each build.",
      "rationale": "ANSYS Fluent 2022 R2 is used under institutional license with documented version control. Regression test suite results are archived and demonstrate passing status for all relevant solver modules including rotating frame and species transport."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating flow cases must confirm solver convergence rates consistent with documented discretization schemes.",
      "rationale": "Method of manufactured solutions applied to a rotating annular flow case confirms second-order spatial accuracy for velocity components. Residual norms reduce below 1e-6 for all solved quantities."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for NIH quantity of interest must be below 5% on the fine mesh relative to the medium mesh.",
      "rationale": "Three-level mesh refinement study conducted on the FDA pump geometry. GCI for NIH computed as 2.8% between medium and fine meshes (7.2M and 18.6M elements respectively), satisfying the 5% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope within documented tolerance bands for flow rate and rotational speed.",
      "rationale": "Validation experiments conducted at 2.5 L/min and 3500 RPM, 4.0 L/min and 3500 RPM, and three additional operating points spanning the CPB envelope. All five points fall within ±3% of target flow rates and ±15 RPM of target speeds per test report TR-2018-FDA-CBP-04."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within 15% at all five validation operating points.",
      "rationale": "Predicted NIH versus measured NIH comparison across all five operating points yields maximum relative error of 11.4% at the 2.5 L/min, 3500 RPM condition. Mean absolute relative error is 7.2%. All points satisfy the 15% acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in simulation (NIH and derived RH index) must be directly traceable to the clinical hemolysis metric used in the regulatory submission.",
      "rationale": "NIH is the standard metric per ASTM F1841 and maps directly to plasma free hemoglobin elevation. The relative hemolysis index RH = NIH_device / NIH_predicate is the regulatory acceptance criterion. Traceability is documented in the model planning report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, fluid properties, and operating conditions sufficiently similar to the COU to support extrapolation of credibility evidence.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which shares key geometric similarity ratios with the subject device. Ovine blood used in experiments; Carreau-Yasuda model parameters matched to human blood for COU. Similarity argument documented in validation plan VP-2024-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; no formal iterative convergence error quantification beyond residual monitoring required.",
      "rationale": "At MRL 2, iterative solver error is addressed through residual monitoring only. Residuals confirmed below 1e-5 for all equations. Formal error quantification not required and not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; informal peer review of simulation setup is sufficient.",
      "rationale": "Simulation setup reviewed by a second analyst prior to production runs. No formal use-error assessment protocol required or applied at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; turbulence model and hemolysis power-law model selection justified by literature precedent without formal sensitivity study.",
      "rationale": "SST k-omega turbulence model selected based on published FDA pump CFD round-robin precedent. Giersiepen-Wurzinger power-law hemolysis model selected per community practice. Formal model-form uncertainty quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and boundary condition inputs must be traceable to documented sources with stated uncertainty. Blood rheology parameters must be within published ranges for human blood.",
      "rationale": "Inlet flow rates and rotational speeds set per test protocol. Carreau-Yasuda viscosity parameters sourced from Cho and Kensey (1991) with stated uncertainty bounds. Density set to 1056 kg/m3 per ISO 10993-4 reference values. All inputs logged in simulation record SR-2025-CPB-001."
    },
    {
