  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release notes and regression test suite.",
      "rationale": "ANSYS Fluent 2023 R2 is a commercially validated solver with documented V&V procedures, ISO 9001 quality management, and a comprehensive regression test suite covering rotating machinery applications. Version control records confirm consistent solver version across all simulation runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing on canonical rotating flow problems must confirm theoretical convergence rates.",
      "rationale": "Manufacturer-supplied code verification report (ANSYS FLU-VER-2023) demonstrates second-order spatial accuracy on Taylor-Couette and lid-driven cavity benchmarks. Internal method of manufactured solutions testing confirms convergence rates consistent with discretization scheme documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be less than 5% at the fine grid level.",
      "rationale": "Three-level mesh refinement study performed on the FDA generic centrifugal pump geometry (coarse: 1.2M cells, medium: 4.8M cells, fine: 19.2M cells). GCI for normalized index of hemolysis computed as 2.3% between medium and fine grids, satisfying the 5% threshold. Asymptotic convergence ratio of 0.97 confirms the solution is within the asymptotic range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulated operating points within ±5% for flow rate and rotational speed.",
      "rationale": "FDA benchmark experimental data specifies five operating points (2.5 L/min at 2500 RPM through 6.0 L/min at 3500 RPM). Simulated boundary conditions match reported experimental flow rates within 1.8% and rotational speeds within 0.5%. Temperature and fluid viscosity conditions replicated using phosphate-buffered saline at 37°C consistent with experimental protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis must fall within two standard deviations of experimental mean across all five operating points.",
      "rationale": "Predicted NIH values at all five operating points fall within 1.6 standard deviations of the experimental mean reported in the FDA benchmark dataset. Maximum relative error is 18.4% at the 2.5 L/min operating point, within acceptable bounds given experimental scatter. Pressure-rise predictions agree within 4.2% across all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be the same hemolysis metrics used in the COU decision.",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) are directly computed from CFD shear stress and exposure time fields and are identical to the metrics specified in the COU acceptance criterion (RH < 1). No surrogate quantities are used; the validation QoI maps directly to the regulatory decision metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating envelope must be representative of the CPB device COU geometry and flow conditions.",
      "rationale": "Validation activities use the FDA generic centrifugal pump, which is geometrically similar to the CPB device under assessment. Operating conditions span the clinical CPB flow range (2–6 L/min). Blood analog fluid properties are consistent with clinical hematocrit ranges. Geometric differences are documented and judged not to materially affect hemolysis prediction fidelity at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "At Model Risk Level 2, detailed iterative convergence error quantification beyond residual monitoring is not required. Residuals were reduced six orders of magnitude for all transport equations; mass imbalance was below 0.01% for all cases. No further assessment is required to meet MRL 2 credibility requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal use error analysis is not required at MRL 2. Simulation inputs were reviewed by a second analyst and simulation setup checklist was completed per laboratory SOPs. No user-induced setup errors were identified during peer review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2. The k-omega SST turbulence model was selected based on published literature for rotating blood pump applications. Power-law hemolysis damage model (Giersiepen-Wurzinger) is standard for this device class. Model form assumptions are documented in the simulation plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary conditions must be traceable to documented sources with uncertainty bounds reported.",
      "rationale": "Blood analog viscosity (0.0035 Pa·s), density (1056 kg/m³), and power-law hemolysis constants are sourced from published literature and manufacturer specifications. Inlet flow rate and outlet pressure boundary conditions are derived from the clinical CPB operating envelope. All input parameters are documented in the simulation plan with traceability to source references. Sensitivity analysis confirms hemolysis index is most sensitive to rotational speed (±3.2% per 1% speed variation) and least sensitive to viscosity (±0.4% per 5% viscosity variation)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Detailed characterization of test sample variability is not required at MRL 2. The FDA benchmark experimental dataset provides replicate measurements at each operating point; inter-replicate variability is reported as standard deviation in the source publication and used in output comparison assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal equivalency mapping between validation experiment inputs and COU inputs is not required at MRL 2. Qualitative alignment between experimental and COU boundary conditions has been documented under the Relevance of Validation Activities factor. No material discrepancies were identified that would require formal equivalency analysis."
    }
  ],
