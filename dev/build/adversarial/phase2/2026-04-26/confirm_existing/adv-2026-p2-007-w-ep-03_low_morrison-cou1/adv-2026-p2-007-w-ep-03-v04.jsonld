  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented under a quality management system with version control and regression testing.",
      "rationale": "ANSYS Fluent 2023 R2 is used under an ISO 9001-certified QMS. Version control is maintained via Git; regression test suite covers 47 canonical benchmark cases. Achieved level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least one published benchmark verification test relevant to rotating turbomachinery flows.",
      "rationale": "Code verification performed against the Taylor-Couette and lid-driven cavity benchmarks. Convergence rates consistent with second-order spatial accuracy. Results published in solver validation report SVR-2024-07."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for velocity magnitude and wall shear stress QOIs at the final mesh resolution.",
      "rationale": "Three-level mesh refinement study conducted at 2.1M, 6.4M, and 18.9M cells. GCI for velocity magnitude = 2.3%; GCI for wall shear stress = 3.8%. Both within the 5% acceptance threshold. Final mesh at 18.9M cells used for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within ±5% for flow rate and rotational speed.",
      "rationale": "Bench experiments conducted at 2.5, 3.5, 4.5, 5.5, and 6.5 L/min at 2400 RPM. Measured flow rates verified with calibrated Coriolis meter (±0.5% accuracy). Rotational speed confirmed via optical tachometer. Deviations from CFD boundary conditions < 2% across all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted NIH must agree with measured NIH within 15% at all 5 operating points.",
      "rationale": "NIH comparison across 5 operating points yields maximum relative error of 11.2% at 6.5 L/min. Mean absolute relative error = 7.4%. All operating points within the 15% acceptance band. Velocity field comparison via PIV shows good qualitative and quantitative agreement in the impeller passage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs used in validation (NIH, velocity magnitude) must be directly traceable to the COU decision metric (RH index).",
      "rationale": "NIH is the direct precursor to the relative hemolysis index RH used in the COU acceptance criterion. Velocity field validation supports confidence in the shear stress predictions that drive the hemolysis power-law model. QOI relevance is high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry and within the same operating envelope as the COU.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry, which is the subject of the COU. Operating conditions span the full COU envelope of 2.5–6.5 L/min at 2400 RPM. Blood analog fluid (40% glycerol-water) used in bench tests is consistent with CFD fluid properties."
    },
    {
      "factorStandard": "ASME-VV40-2018",
