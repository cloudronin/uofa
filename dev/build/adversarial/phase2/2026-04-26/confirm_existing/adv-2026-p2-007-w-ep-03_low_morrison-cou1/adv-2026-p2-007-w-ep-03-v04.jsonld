      "acceptanceCriteria": "Simulation setup reviewed by independent analyst.",
      "rationale": "Not assessed at MRL 2. Simulation setup followed standard operating procedures; independent review not mandated at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison to higher-fidelity reference data.",
      "rationale": "Not assessed at MRL 2. SST k-omega turbulence model selected based on published literature for similar rotating blood-contacting devices. Formal model form uncertainty quantification deferred to higher MRL activities."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All CFD boundary conditions and material properties must be traceable to calibrated measurements or published standards.",
      "rationale": "Inlet velocity profiles derived from PIV measurements acquired in 2018 (dataset vintage 2018-03-12). Blood analog viscosity and density sourced from the same 2018 experimental campaign. These inputs were incorporated into the current model revision without re-measurement following the January 2026 model rebuild. All values are documented in the model input specification MIS-CPB-2024-03 and treated as fixed inputs for the COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
