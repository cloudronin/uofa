  "signature": "ed25519:b7d3e9f1a2c5084b6e3d1f9a8c2b4e7d0f5a3c8b1e6d9f2a4c7b0e3d8f1a5c9",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering hemolysis-relevant flow regimes; formal change control documented per project requirements.",
      "rationale": "The CFD solver is version-controlled and basic regression tests exist, but the test suite does not cover rotating-frame hemolysis regimes and change control records are incomplete. Achieved level 2 falls short of the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent order-of-accuracy verification for all governing equations active in the hemolysis model, including the scalar transport equation for the power-law damage accumulation model.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver but not for the hemolysis scalar transport equation. Achieved level 2 is insufficient for the required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis index QoI across all 5 operating points; GCI < 5% on the fine grid.",
      "rationale": "Richardson extrapolation was performed at 3 of 5 operating points. GCI values range from 4.8% to 11.2%; the two highest-speed operating points exceed the 5% threshold. Achieved level 3 does not meet required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid rheology, temperature, inlet waveform) must match VAD operating envelope within stated uncertainty bounds; deviations must be quantified and propagated.",
      "rationale": "Benchmark experiments used Newtonian blood analog fluid at a single temperature; VAD conditions involve non-Newtonian whole blood across a temperature range. The deviation in rheological model introduces unquantified bias. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E-measure or ASME V&V 20 validation metric) applied to absolute hemolysis index predictions against experimental data at all 5 operating points, with uncertainty intervals overlapping at 95% confidence.",
      "rationale": "Qualitative trend agreement is documented but quantitative validation metrics are not computed. Uncertainty intervals from Monte Carlo UQ are reported for model outputs but not combined with experimental uncertainty for formal comparison. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (hemolysis index) must directly correspond to the clinical decision threshold; surrogate QoIs are not acceptable at MRL 5.",
      "rationale": "The hemolysis index QoI is directly relevant to the clinical threshold; however, the power-law damage accumulation model integrates along streamlines, introducing path-dependency that is not fully characterized. Achieved level 3 falls one grade below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on a geometry and operating envelope representative of the VAD COU; FDA generic pump benchmark is acceptable only if geometric similarity and Reynolds number similarity are demonstrated.",
      "rationale": "The FDA generic centrifugal pump benchmark geometry differs from the implanted VAD geometry in impeller clearance and volute design. Reynolds number similarity holds at nominal conditions but diverges at off-design points. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off error must be quantified and shown to be negligible relative to discretization error for all operating points.",
      "rationale": "Iterative convergence residuals are reported but not compared to discretization error estimates. Floating-point round-off analysis was not performed. Factor flagged as epistemic gap at MRL 5; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation execution procedure with independent review of boundary condition setup, solver settings, and post-processing scripts for each operating point.",
      "rationale": "No independent review of simulation setup was performed. Boundary condition inputs were set by a single analyst without peer verification. Factor flagged as epistemic gap; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal justification for turbulence model and hemolysis constitutive model selection; sensitivity analysis demonstrating model form uncertainty is bounded relative to clinical decision threshold.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature without formal sensitivity analysis against alternative turbulence closures. No model form uncertainty quantification was performed. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs (viscosity coefficients, hemolysis model exponents, inlet flow waveform) characterized with probability distributions; Monte Carlo propagation demonstrates output uncertainty is within acceptance bounds.",
      "rationale": "Monte Carlo UQ was performed but only three of seven uncertain input parameters were included in the sampling. Hemolysis model exponents (C, alpha, beta) were treated as fixed nominal values despite published variability. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental dataset must include sufficient replicates to characterize inter-sample variability; minimum n=5 independent pump samples across operating envelope.",
      "rationale": "The FDA benchmark dataset used a single pump specimen. Inter-sample variability in hemolysis response is uncharacterized. Factor flagged as epistemic gap at MRL 5; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that computational input parameters (geometry, boundary conditions, fluid properties) match experimental test article parameters within quantified tolerances for all 5 operating points.",
      "rationale": "CAD geometry used in simulation was reverse-engineered from the FDA benchmark specification; dimensional tolerances of the physical test article relative to the nominal CAD were not characterized. Factor flagged as epistemic gap; achieved level 1."
    }
