      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match VAD operating envelope defined in project requirements within stated tolerances; flow rate and rotational speed uncertainty must be documented.",
      "rationale": "Test conditions partially replicate the VAD operating envelope. Flow rate uncertainty was documented but rotational speed uncertainty was not formally characterized. Achieved level 2 falls below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric) applied to hemolysis index predictions versus experimental measurements across all 5 operating points per project requirements.",
