      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a formal QMS with traceable test records and version-controlled source; independent code review required at MRL 5.",
      "rationale": "Project requirements document PRD-VAD-2026-001 specifies Gradation 4 for SQA at MRL 5. The simulation was run with a commercial CFD solver under a limited QMS; version control and independent review records are incomplete. Achieved level remains at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy studies and benchmark comparisons against analytical solutions required; must demonstrate solver convergence to manufactured solutions.",
      "rationale": "Per project requirements, numerical code verification at MRL 5 demands Gradation 4. Only informal benchmark comparisons to published pump cases were performed; manufactured-solution order-of-accuracy studies were not conducted. Achieved level is Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis on at least three systematically refined meshes; near-wall y+ compliance for hemolysis-sensitive shear layers.",
      "rationale": "Project requirements mandate Gradation 4 discretization error quantification. A two-mesh sensitivity study was performed without Richardson extrapolation; near-wall resolution in high-shear impeller regions does not meet y+ targets. Achieved level is Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five COU operating points with documented fluid temperature, hematocrit, and flow rate uncertainty bands.",
      "rationale": "Three of five operating points were replicated with fully documented conditions. Two operating points lack hematocrit characterization records. Achieved level is Gradation 3 against the required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMSE, E_n number) applied to hemolysis index predictions across all operating points with uncertainty intervals.",
      "rationale": "Quantitative output comparison was performed at three operating points using normalized RMSE; two operating points have only qualitative agreement statements. Uncertainty intervals from Monte Carlo UQ were not propagated into the comparison metric. Achieved level is Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be the absolute hemolysis index directly linked to the clinical threshold; surrogate QoIs (e.g., shear stress distributions only) are insufficient at MRL 5.",
      "rationale": "The primary QoI is the modified index of hemolysis (MIH) which is clinically relevant. However, secondary QoIs used in model calibration include shear stress surrogates that are not directly traceable to the clinical endpoint. Achieved level is Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry and at COU operating conditions; scaled or simplified geometries are not acceptable at MRL 5.",
      "rationale": "Validation activities used the FDA generic pump geometry which matches the COU device class but is not the specific VAD geometry. Operating conditions partially overlap the COU envelope. Significant geometric and operational gaps reduce relevance. Achieved level is Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must reach solver-specified tight tolerances; round-off and floating-point error characterization required for hemolysis damage accumulation integrals.",
      "rationale": "Numerical solver error was flagged as an epistemic gap at MRL 5. Iterative residuals were monitored but no formal characterization of round-off error in the Lagrangian particle tracking and damage accumulation integrals was performed. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented evidence that all simulation setup steps follow approved SOPs; independent expert review of boundary condition assignments and model parameter selections.",
      "rationale": "Use error assessment was flagged as an epistemic gap. No independent expert review of boundary condition assignments was conducted. SOPs for hemolysis model parameter selection were not finalized at time of assessment. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified through comparison with mechanistic red blood cell damage models; turbulence model selection must be validated for rotating machinery hemolysis prediction.",
      "rationale": "Model form assessment is an epistemic gap at MRL 5. The Giersiepen-Wurzinger power-law hemolysis model was used without systematic comparison to mechanistic alternatives. Turbulence model sensitivity (SST k-omega vs. RSM) was not evaluated. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model inputs (fluid properties, power-law exponents, inlet velocity profiles) must have documented uncertainty characterization traceable to measurement or literature sources.",
      "rationale": "Model inputs assessment is an epistemic gap. Power-law exponents alpha and beta were taken from a single literature source without uncertainty bounds. Inlet velocity profile uncertainty was not characterized. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog fluid samples must be characterized for viscosity, density, and hematocrit with traceability; sample-to-sample variability must be quantified across test replicates.",
      "rationale": "Test sample characterization is an epistemic gap at MRL 5. Fluid characterization records for the blood analog (glycerol-water mixture) are incomplete and sample-to-sample variability across the experimental replicates was not reported. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient, head coefficient) must be matched between validation experiments and COU operating conditions to within defined tolerances.",
      "rationale": "Equivalency of input parameters is an epistemic gap. Reynolds number matching between the FDA generic pump validation experiments and the specific VAD COU operating points was not formally documented. Flow and head coefficient equivalency analysis was not performed. Factor not assessed."
    }
