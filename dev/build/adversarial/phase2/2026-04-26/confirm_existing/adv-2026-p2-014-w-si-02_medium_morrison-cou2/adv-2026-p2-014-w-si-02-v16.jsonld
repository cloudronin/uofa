  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent verification of solver build, version control, and regression test suite covering hemolysis-relevant physics at Gradation 4.",
      "rationale": "Version control and build documentation exist but independent third-party audit of the solver has not been completed. Regression suite covers only 40% of hemolysis-relevant test cases. Achieved level 2 against required level 4; gap remains unresolved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for rotating-frame Navier-Stokes and scalar hemolysis transport equation at Gradation 4.",
      "rationale": "Order-of-accuracy tests performed for steady laminar flow only. Rotating-frame turbulence and the power-law hemolysis transport equation have not been subjected to manufactured solution verification. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI reported for hemolysis index QoI at Gradation 4.",
      "rationale": "Three-mesh Richardson extrapolation completed; GCI for hemolysis index is 18% at the design operating point, exceeding the 5% threshold implied by Gradation 4. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope (flow 3–6 L/min, speed 2400–3600 RPM) with physiological blood analogue and documented hematocrit range at Gradation 5.",
      "rationale": "FDA pump experiments used glycerol-water analogue rather than porcine blood; hematocrit not controlled. Operating speed range partially overlaps VAD envelope but extends only to 3200 RPM. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted vs. measured hemolysis index with uncertainty bounds at all 5 operating points; normalised error below 20% at Gradation 5.",
      "rationale": "Predicted hemolysis index deviates from measured values by 35–60% across operating points. Uncertainty bands from Monte Carlo UQ do not consistently enclose experimental measurements. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must include absolute hemolysis index (not normalised) directly comparable to the clinical threshold at Gradation 5.",
      "rationale": "Validation dataset reports normalised hemolysis index relative to reference condition; absolute values require post-processing conversion with additional uncertainty. Direct absolute QoI comparison not available. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted on geometry and operating conditions sufficiently similar to the target VAD to support extrapolation at Gradation 5.",
      "rationale": "Validation performed on the FDA generic benchmark pump, which differs substantially in impeller geometry, volute design, and clearance gaps from the target VAD. Extrapolation credibility is low. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, floating-point round-off, and linearisation errors quantified for hemolysis transport equation at Gradation 4.",
      "rationale": "Solver error analysis for the hemolysis scalar transport equation has not been performed. Residual convergence criteria applied to momentum equations only. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation protocol, peer-reviewed setup checklist, and independent re-run by second analyst at Gradation 4.",
      "rationale": "No independent re-run by a second analyst has been performed. Simulation setup checklist exists but has not been peer-reviewed against the COU-specific protocol. Flagged as epistemic gap. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of turbulence model selection, hemolysis power-law exponents, and non-Newtonian rheology model for VAD shear environment at Gradation 5.",
      "rationale": "Turbulence model (SST k-ω) selected without systematic comparison for rotating blood-pump flows. Power-law hemolysis coefficients taken from literature without uncertainty characterisation for the target device shear history. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions for all uncertain model inputs (blood viscosity, hematocrit, inlet velocity profile) characterised from clinical data at Gradation 5.",
      "rationale": "Monte Carlo UQ performed but input distributions assumed uniform without clinical data support. Hematocrit distribution not derived from the intended patient population. Flagged as epistemic gap. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum sample size analysis and statistical power calculation for hemolysis index measurements at Gradation 4.",
      "rationale": "Experimental dataset contains 3 replicates per operating point; no sample size justification or statistical power analysis provided. Measurement variability not characterised. Flagged as epistemic gap. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental boundary conditions and CFD inputs with documented equivalency arguments at Gradation 4.",
      "rationale": "Inlet boundary conditions in CFD assumed fully developed; experimental inlet conditions not characterised. No formal equivalency argument between test rig and simulation boundary conditions documented. Flagged as epistemic gap. Achieved level 1 against required level 4."
    }
