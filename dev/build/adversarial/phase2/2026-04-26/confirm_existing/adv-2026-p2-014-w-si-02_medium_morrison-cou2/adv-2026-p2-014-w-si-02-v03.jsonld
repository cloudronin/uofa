  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be under formal configuration control with documented test suite covering hemolysis solver modules; version traceability required for all project requirements.",
      "rationale": "The CFD solver is version-controlled but lacks a formal test suite for the hemolysis damage accumulation module. Configuration management documentation is incomplete relative to MRL 5 project requirements. Achieved Gradation 2: informal version tagging only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and manufactured solution verification must be completed for the hemolysis transport equations at MRL 5.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver but not extended to the hemolysis scalar transport equation. Manufactured solution tests are absent for the damage accumulation model. Achieved level falls short of project requirements for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study must demonstrate discretization error below 5% for hemolysis index QoI across all five operating points.",
      "rationale": "Grid convergence study performed on three mesh levels for pressure and velocity fields. Hemolysis index QoI shows 12–18% variation between medium and fine meshes; Richardson extrapolation not completed for hemolysis scalar. Discretization error exceeds project requirements threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five COU operating points with blood analogue fluid properties within ±5% of physiological values.",
      "rationale": "Experimental data from the FDA benchmark covers four of five target operating points. Blood analogue viscosity matches within ±7% at the highest shear-rate condition, marginally exceeding the project requirements tolerance. Test conditions partially meet MRL 5 demands."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric) must demonstrate agreement within uncertainty bounds for absolute hemolysis index at all five operating points.",
      "rationale": "ASME V&V 20 validation metric computed for four operating points; agreement within experimental uncertainty at two points, outside bounds at two points. Fifth operating point lacks experimental data. Absolute hemolysis index predictions overestimate measured values by 20–35% at high-flow conditions. Output comparison does not satisfy project requirements at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI must be the normalized index of hemolysis (NIH) or equivalent absolute hemolysis metric directly mapped to the clinical acceptance threshold.",
      "rationale": "Validation activities used normalized index of hemolysis consistent with the COU QoI. However, the damage accumulation exponent in the power-law hemolysis model introduces QoI sensitivity not fully characterized. Relevance is partial with respect to project requirements for absolute threshold comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a centrifugal pump geometry representative of the VAD COU with operating conditions spanning the full clinical use envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which is a simplified geometry relative to the target VAD impeller design. Operating conditions cover partial clinical envelope only. Geometric and operational representativeness gaps reduce relevance below project requirements for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be quantified and shown to be negligible relative to discretization error for hemolysis QoI.",
      "rationale": "Numerical solver error was not assessed for this COU. Iterative residuals were monitored but no formal quantification of solver error contribution to hemolysis QoI uncertainty was performed. Flagged as epistemic gap at MRL 5; does not meet project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented evidence that simulation setup, boundary condition application, and post-processing procedures have been independently reviewed and verified against project requirements.",
      "rationale": "No independent review of simulation setup was performed. Boundary condition selection and hemolysis post-processing scripts were applied by a single analyst without peer verification. Use error remains an unquantified epistemic gap under project requirements for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the power-law hemolysis damage model must be quantified through comparison with at least two alternative hemolysis model formulations consistent with project requirements.",
      "rationale": "Model form uncertainty was not assessed. Only the Giersiepen-Wurzinger power-law model was employed; no comparison with alternative formulations (e.g., Arora, Goubergrits-Affeld) was performed. Model form error is a dominant source of uncertainty at MRL 5 and represents a critical gap relative to project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All hemolysis model input parameters must have documented uncertainty distributions derived from literature or experimental characterization, consistent with project requirements for Monte Carlo UQ.",
      "rationale": "Monte Carlo uncertainty quantification was performed on five hemolysis model input parameters. However, the power-law exponent and threshold stress distributions were assigned based on a single literature source without experimental verification. Input uncertainty characterization is incomplete relative to project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must include sufficient replicate samples to characterize biological variability in red blood cell fragility, meeting project requirements for statistical representativeness.",
      "rationale": "Test sample characterization was not assessed. The FDA benchmark dataset does not report replicate hemolysis measurements with biological variability quantification. Sample-to-sample red blood cell fragility variation is uncharacterized, representing an epistemic gap at MRL 5 relative to project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment input parameters and COU simulation input parameters must be formally documented and assessed against project requirements.",
      "rationale": "Equivalency of input parameters was not formally assessed. The validation geometry (FDA generic pump) and the target VAD device differ in impeller blade count, tip clearance, and volute geometry. No mapping of input parameter equivalency to project requirements was documented. This factor is flagged as an epistemic gap at MRL 5."
