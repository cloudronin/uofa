  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors against project requirements for MRL 5. Seven factors were formally assessed with achieved levels below required levels; six factors remain as epistemic gaps. Despite the gaps, the Monte Carlo uncertainty quantification provides partial coverage of input uncertainty, and the FDA pump geometry is accepted as a surrogate for initial regulatory submission under the Minimal profile. The package is accepted for submission with the understanding that outstanding factors must be resolved in a subsequent assessment cycle. Structured bindsRequirement linkage was not included in this Minimal profile submission.",
