  "signature": "ed25519:b17f3a9c2e84d0561f4a2c97e3b08d4f1a6c3e5b9d2f7a0c8e1b4d6f3a9c2e5b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a formal QA plan with version control, regression testing, and documented release procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver operates under a partial QA framework with version control in place, but regression test coverage is incomplete and no formal release qualification procedure has been executed. Achieved level 2 against a required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include method-of-manufactured-solutions tests and documented convergence rates for all governing equations used in the hemolysis model.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the hemolysis transport scalar equation. The gap in scalar verification leaves achieved level at 2, well below the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI-based discretization error estimate must be reported for all quantities of interest at each operating point.",
      "rationale": "GCI analysis was completed on three of five operating points. The two highest-speed conditions were omitted due to mesh generation failures in the tip-clearance region. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope in fluid temperature, hematocrit, and rotational speed within defined tolerances; deviations must be quantified.",
      "rationale": "Experimental data were collected at a single hematocrit value (35%) whereas the COU spans 30–45%. Temperature control was nominal. The single-hematocrit limitation reduces confidence in extrapolation across the COU envelope; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) must be computed for each QoI at each operating point; metric must be below the decision-relevant threshold.",
      "rationale": "Validation metrics were computed for hemolysis index at three operating points. Prediction error ranged 18–42%, exceeding the 10% acceptance threshold at all assessed points. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The predicted QoIs (normalized index of hemolysis, NIH) must map directly to the clinical acceptance criterion without requiring additional transformation assumptions.",
      "rationale": "NIH is directly used as the regulatory QoI; however, the model outputs modified index of hemolysis (MIH) which requires a conversion factor with its own uncertainty. The conversion introduces an additional uncertainty layer not fully quantified; achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same or geometrically similar device under COU-representative flow conditions; any geometric simplifications must be documented and their impact bounded.",
      "rationale": "Validation was performed on the FDA benchmark pump geometry which shares the centrifugal topology but differs in impeller blade count and volute geometry from the subject VAD. Geometric dissimilarity reduces relevance score; achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and time-integration error must each be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Solver error characterization was not performed. Residual convergence plots were provided but no formal bounding of iterative error relative to discretization error was conducted. Flagged as epistemic gap at MRL 5; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented review process must confirm that model setup, boundary condition assignment, and post-processing scripts were independently verified for each operating point.",
      "rationale": "No independent use-error review was conducted. Boundary conditions were set by the analyst without peer check. This factor is an unresolved epistemic gap; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis constitutive model (power-law Giersiepen-Wurzinger or equivalent) must be justified against mechanistic alternatives; sensitivity of predictions to model-form choice must be quantified.",
      "rationale": "The Giersiepen-Wurzinger power-law was adopted without comparison to alternative mechanistic hemolysis models. Model-form uncertainty is unquantified. At MRL 5 this is a critical epistemic gap; achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters must be characterized with probability distributions derived from literature or measurement; Monte Carlo propagation must cover the full COU input space.",
      "rationale": "Monte Carlo UQ was initiated but input distributions for blood viscosity and red blood cell fragility index were assigned from single-source literature values without inter-study variability analysis. Input uncertainty characterization is incomplete; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be drawn from a population representative of clinical use; sample size must support statistical characterization of inter-sample variability in hemolysis measurements.",
      "rationale": "Experimental hemolysis data were derived from a single test run per operating point using one blood sample lot. No inter-sample or inter-lot variability was assessed. This constitutes an unresolved epistemic gap; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrated equivalent to those in the COU simulations; any differences must be bounded and their effect on QoI quantified.",
      "rationale": "No formal equivalency analysis was performed between validation-case inputs and COU inputs. Fluid properties and boundary conditions were assumed transferable without quantitative justification. Flagged as epistemic gap; achieved level 1."
    }
  ],
