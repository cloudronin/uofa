  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors under the Minimal profile. While the structured project requirement binding is managed outside the formal IRI linkage under this profile, the underlying project requirements specifying absolute hemolysis thresholds and MRL-5 acceptance criteria were reviewed in documentary form and found to be addressed by the evidence package. The team acknowledges that 6 factors remain not-assessed and that all 7 assessed factors show achieved levels below required levels; however, compensating controls including Monte Carlo UQ and independent bench data were judged sufficient for the current decision gate. Package is accepted for submission with open findings documented.",
    "decidedAt": "2026-04-19T00:00:00Z"
