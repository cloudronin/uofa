      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Project requirements define quantitative agreement metrics (normalized RMS error < 15%) between predicted and measured hemolysis index at all five operating points.",
      "rationale": "Normalized RMS error across five operating points is 22%, exceeding the 15% threshold. Systematic over-prediction at high flow rates is observed. Achieved level 3 does not meet the required level 4."
