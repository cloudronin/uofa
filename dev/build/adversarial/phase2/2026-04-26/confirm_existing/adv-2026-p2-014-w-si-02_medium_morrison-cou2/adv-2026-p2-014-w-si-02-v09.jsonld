  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors against project requirements for the Class III VAD hemolysis prediction context of use. Seven factors were formally assessed; all seven showed achieved levels below required levels. Six factors were not assessed and represent epistemic gaps at Model Risk Level 5. Monte Carlo uncertainty quantification was initiated but incomplete. The structured evidence package is accepted as a complete record of the credibility assessment findings, documenting that the computational model does not currently meet the credibility requirements for regulatory submission. Remediation actions are required before re-submission.",
