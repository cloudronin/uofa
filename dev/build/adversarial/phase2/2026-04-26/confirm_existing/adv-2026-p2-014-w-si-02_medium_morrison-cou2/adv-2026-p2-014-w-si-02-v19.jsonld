  "signature": "ed25519:9b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for hemolysis prediction must have documented version control, regression testing, and change management consistent with MRL 5 requirements.",
      "rationale": "Project requirements specify rigorous SQA at MRL 5. The CFD solver has basic version control but lacks formal regression test suite and change management documentation. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Analytical and manufactured solution benchmarks must be demonstrated for the hemolysis transport equations and turbulence models employed.",
      "rationale": "Code verification was performed only for standard Navier-Stokes benchmarks; the power-law hemolysis transport equation has not been verified against manufactured solutions. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study must be performed on hemolysis index QoI with at least three systematically refined meshes.",
      "rationale": "Grid convergence index was computed on three meshes for velocity and pressure; however, hemolysis index QoI convergence was only assessed on two meshes, limiting confidence. Achieved level 3 does not meet required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must replicate VAD operating envelope including blood analog viscosity, hematocrit range, and rotational speed range.",
      "rationale": "In-vitro tests used porcine blood at a single hematocrit; human blood analogs at the clinical hematocrit range were not tested. Test conditions partially overlap the COU but do not cover the full operating envelope specified in project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., validation uncertainty, model error) must be computed for hemolysis index predictions against experimental data at all five operating points.",
      "rationale": "Output comparison was performed at three of five operating points; two high-flow conditions lacked experimental hemolysis data. Quantitative validation uncertainty was not propagated through the hemolysis model. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the absolute hemolysis index used for clinical acceptance decision.",
      "rationale": "Normalized index of hemolysis (NIH) was used as the primary validation QoI and maps directly to the clinical threshold. However, sub-lethal platelet activation indices were not validated, leaving a secondary QoI gap. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the FDA generic centrifugal pump geometry or a geometry with documented geometric similarity to the subject device.",
      "rationale": "Validation experiments were conducted on a simplified two-dimensional impeller channel, not the full three-dimensional FDA generic centrifugal pump. Geometric dissimilarity reduces relevance to the COU. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver residuals must be documented and shown to be negligible relative to discretization error for hemolysis QoI.",
      "rationale": "Numerical solver error was flagged as an epistemic gap at MRL 5. No formal iterative convergence study was conducted for the hemolysis transport solve; residual tolerances were set by default. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence must demonstrate that model setup, boundary condition application, and post-processing are performed by qualified personnel following documented procedures.",
      "rationale": "Use error assessment was identified as an epistemic gap. No independent review of model setup or post-processing procedures was performed. Factor not assessed at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The power-law hemolysis model and turbulence closure must be justified against alternative model forms with documented sensitivity analysis.",
      "rationale": "Model form uncertainty is an epistemic gap at MRL 5. The Giersiepen-Wurzinger power-law hemolysis model was selected without comparison to alternative mechanistic models. Turbulence model sensitivity was not assessed. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in model input parameters (viscosity, density, hemolysis model coefficients) must be characterized and propagated via Monte Carlo analysis to hemolysis index output.",
      "rationale": "Monte Carlo UQ was initiated per project requirements but input parameter distributions for hemolysis model coefficients were not established from literature. Input uncertainty assessment is an epistemic gap. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size and variability of blood or blood analog used in validation experiments must be statistically characterized and reported.",
      "rationale": "Test sample characterization is an epistemic gap at MRL 5. The number of independent experimental replicates was not reported and inter-sample variability in hemolysis measurements was not quantified. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the computational model must be demonstrated to be equivalent to those realized in the validation experiments, including fluid properties and boundary conditions.",
      "rationale": "Equivalency of input parameters between simulation and experiment was flagged as an epistemic gap. Inlet velocity profiles and outlet pressure boundary conditions used in the CFD model were not measured in the validation experiments. Factor not assessed."
    }
  ],
