  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a formal SQA plan with traceability to project requirements; version control and regression testing documented at Gradation 4.",
      "rationale": "SQA documentation exists but covers only basic version control. No formal regression test suite traceable to the project requirements specification. Achieved level falls two gradations below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions must demonstrate expected convergence rates for all governing equations relevant to hemolysis transport.",
      "rationale": "Convergence tests were performed for the flow solver only; the scalar hemolysis transport equation was not subjected to manufactured-solution verification. Achieved level is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis QoI on at least three systematically refined meshes; discretization uncertainty must be included in total uncertainty budget.",
      "rationale": "Three-mesh GCI study completed; however, near-wall refinement near impeller blades shows non-monotonic convergence, preventing full Richardson extrapolation. Discretization uncertainty is partially bounded but not fully characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five VAD operating points specified in project requirements; fluid properties and boundary conditions must be documented with uncertainty.",
      "rationale": "Available experimental data covers only three of the five required operating points. Fluid temperature and hematocrit were not controlled to match the project requirements specification, introducing unquantified systematic bias."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation uncertainty U_val) must be computed for hemolysis index at each operating point; metric must account for both experimental and simulation uncertainty.",
      "rationale": "Comparisons are presented as overlaid plots without formal validation metrics. Experimental uncertainty bars are omitted. No validation uncertainty U_val is computed, making it impossible to determine whether model agreement is within acceptable tolerance per project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (hemolysis index) must be the same scalar quantity used in the regulatory submission and must be computed identically in validation and COU simulations.",
      "rationale": "Validation studies used the Giersiepen-Wurzinger power-law model while the COU simulations use the Zhang model. The two formulations yield systematically different absolute values, reducing QoI relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometries and flow regimes sufficiently similar to the VAD COU to support extrapolation; similarity arguments must be documented.",
      "rationale": "Validation performed on the FDA benchmark pump geometry, which is geometrically similar but operates at lower rotational speeds than the target VAD. Similarity argument is qualitative; no quantitative extrapolation uncertainty is assigned."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to a level where residual errors are negligible relative to discretization error; floating-point round-off analysis required at MRL 5.",
      "rationale": "Iterative convergence criteria are not reported. No evidence that solver residuals were monitored to sufficient tolerance. Round-off analysis not performed. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that simulation inputs, boundary conditions, and post-processing scripts were independently reviewed and that operator error sources were systematically identified.",
      "rationale": "No independent review of simulation setup is documented. Use error is identified as an epistemic gap; the project requirements call for a formal simulation review checklist that was not completed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the turbulence closure and hemolysis constitutive model must be quantified; multiple model forms must be compared or a formal model-form uncertainty bound established.",
      "rationale": "Single turbulence model (SST k-omega) used without comparison to alternative closures. Hemolysis model form uncertainty not quantified. This is the most critical epistemic gap at MRL 5 given the sensitivity of hemolysis predictions to turbulence model selection."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (viscosity, density, hemolysis model coefficients) must be characterized with probability distributions; Monte Carlo propagation must demonstrate convergence.",
      "rationale": "Monte Carlo UQ was performed for fluid viscosity and density only. Hemolysis model coefficients (power-law exponents) were treated as deterministic despite known variability in the literature. Input characterization is incomplete relative to project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog fluid properties and sample preparation must be documented; inter-laboratory variability in hemolysis measurements must be characterized.",
      "rationale": "Experimental sample preparation details are not provided in available publications. Inter-laboratory variability is not addressed. Factor flagged as epistemic gap; no data available to assess."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Boundary conditions and geometric parameters used in validation simulations must be demonstrated to be equivalent to those in the COU; any differences must be bounded by sensitivity analysis.",
      "rationale": "Geometric equivalency between the FDA benchmark pump and the target VAD is asserted qualitatively. No sensitivity analysis quantifies the impact of geometric differences on hemolysis predictions. Factor flagged as epistemic gap."
    }
  ],
