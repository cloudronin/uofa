  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment package for COU2 VAD hemolysis prediction is accepted as a complete and transparent record of model risk at MRL 5. Seven of thirteen credibility factors were assessed; all show achieved levels below required levels. Six factors remain unassessed and are documented as epistemic gaps. The package satisfies submission requirements under the Minimal profile. Project requirements specifying the hemolysis clinical threshold and the five-point operating envelope are referenced throughout the narrative; the structured binding of those requirements is deferred consistent with Minimal profile conventions. The Not Accepted decision on model adequacy is faithfully recorded and the evidence package is approved for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
