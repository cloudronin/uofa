  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan with version control, regression testing, and documented build procedures must meet Gradation 4 requirements for MRL 5.",
      "rationale": "SQA plan exists and version control is in place, but regression test suite covers only 40% of solver modules. No formal V&V plan for the hemolysis sub-model. Achieved level falls below required level for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification required for all governing equations including hemolysis transport at Gradation 4.",
      "rationale": "MMS verification performed for Navier-Stokes solver but not for the power-law hemolysis damage accumulation model. Observed order of accuracy for flow solver is 1.8 vs theoretical 2.0; hemolysis transport unverified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study with GCI reported for hemolysis index QoI at Gradation 4.",
      "rationale": "Three-level grid convergence study performed; GCI for pressure rise is 1.8% but GCI for hemolysis index is 18.4%, well above the 5% threshold implied by Gradation 4. Mesh refinement near blade tip insufficient."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within documented tolerances; blood analog fluid properties characterized at Gradation 4.",
      "rationale": "FDA pump experiments used glycerin-water blood analog; viscosity and density characterized. However, temperature control during experiments was ±3°C vs required ±1°C, and rotational speed uncertainty is ±15 RPM. Conditions partially representative but not fully equivalent to VAD operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E_rel, RMSE) with uncertainty bounds on both simulation and experiment required for hemolysis index at Gradation 4.",
      "rationale": "Hemolysis index predictions overestimate experimental values by 35–60% across operating conditions. Relative error exceeds 30% at 4 of 5 operating points. Experimental uncertainty in hemolysis measurement is ±12% (NIH method), but simulation uncertainty from Monte Carlo is ±28%, indicating model form inadequacy beyond measurement noise."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation (hemolysis index, pressure rise, flow rate) must be directly relevant to the COU decision metric at Gradation 4.",
      "rationale": "Hemolysis index (NIH) is the primary COU QoI and is directly measured in validation experiments. Pressure rise and flow rate are secondary QoIs with good correspondence. Minor gap: shear stress distribution, which drives hemolysis prediction, is not directly validated against experimental measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted at conditions representative of the Class III VAD COU, including patient-relevant hematocrit and flow pulsatility, at Gradation 5.",
      "rationale": "Validation performed on FDA generic pump geometry under steady-flow conditions with blood analog. COU requires pulsatile flow representative of VAD operation with real blood. No pulsatile validation data available. Hematocrit effects not characterized. Validation domain is insufficiently representative of the COU for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver-specific numerical diffusion must be quantified and shown to be negligible relative to discretization error at Gradation 4.",
      "rationale": "Numerical solver error not assessed. Residual convergence criteria documented (10^-5 for all equations) but no systematic study of iterative convergence error contribution to hemolysis QoI. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition specification, and post-processing procedures required at Gradation 4 for MRL 5 assessment.",
      "rationale": "No independent review of simulation setup performed. Boundary conditions applied by single analyst without peer verification. Post-processing scripts for hemolysis index calculation not independently validated. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model form uncertainty required, including comparison of multiple model forms, at Gradation 5.",
      "rationale": "Single turbulence model (SST k-omega) used without comparison to alternative formulations. Power-law hemolysis model selected without justification relative to Giersiepen or Taskin models. Model form uncertainty not quantified. Critical gap for MRL 5 absolute hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis and uncertainty quantification of all model input parameters (geometry, material properties, boundary conditions) required at Gradation 4.",
      "rationale": "Monte Carlo UQ performed on 6 input parameters (inlet flow rate, rotational speed, fluid viscosity, hemolysis model coefficients C and alpha). Sobol sensitivity indices computed. However, geometric uncertainty from manufacturing tolerances not included, and inlet velocity profile shape uncertainty not characterized. Partial compliance with Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability (pump-to-pump geometric variation, blood analog batch variability) required at Gradation 4.",
      "rationale": "Single pump specimen used for all validation experiments. No pump-to-pump variability data available. Blood analog prepared in single batch. Sample representativeness cannot be established. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and COU inputs must be documented and gaps quantified at Gradation 4.",
      "rationale": "No formal equivalency assessment performed between FDA pump validation conditions and Class III VAD COU. Blood analog (glycerin-water) vs real blood equivalency not established for hemolysis prediction. Steady-flow vs pulsatile-flow equivalency not addressed. Critical gap preventing acceptance."
    }
  ],
