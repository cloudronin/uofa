  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Project requirements mandate a formal SQA plan with version control, regression testing, and traceability to code changes. Required level 4 demands documented test suites covering all solver modules used in hemolysis computations.",
      "rationale": "SQA documentation for the CFD solver covers version control and basic regression tests but lacks full traceability to individual solver modules relevant to hemolysis. Project requirements specify a higher bar that has not been met at this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured-solution or benchmark tests must demonstrate order-of-accuracy convergence for all governing equations including the hemolysis transport model. Project requirements specify at least three mesh refinement levels with documented convergence rates.",
      "rationale": "Code verification was performed on the Navier-Stokes solver but the hemolysis scalar transport equation was not independently verified against a manufactured solution. Convergence rates were documented for velocity only, falling short of project requirements at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must bound discretization error to within 5% of the QOI for all five operating points. Project requirements demand GCI values reported per operating condition.",
      "rationale": "Grid convergence index was computed for three of five operating points. The remaining two points exhibited non-monotonic convergence, preventing reliable GCI estimation. Achieved level 3 reflects partial compliance with project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match VAD operating envelope including hematocrit, temperature, and anticoagulant protocol. Project requirements specify that all five target flow-speed combinations are represented in the validation dataset.",
      "rationale": "Available experimental data covers three of the five target operating points. Hematocrit variation was controlled but temperature was not independently monitored in all runs. Test conditions partially satisfy project requirements; two operating points remain unvalidated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (NRMSE, U95 overlap) must be reported for hemolysis index predictions at all validated operating points. Project requirements demand that prediction intervals encompass experimental measurements.",
      "rationale": "Output comparison was performed using mean absolute error only; prediction intervals from Monte Carlo UQ were computed but not formally compared against experimental uncertainty bounds. The structured comparison required by project requirements at MRL 5 was not completed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index QOI must be directly traceable to the clinical endpoint. Project requirements specify that the power-law hemolysis model coefficients are validated against blood from the target patient population.",
      "rationale": "The hemolysis index is directly mapped to the clinical threshold but power-law coefficients were taken from literature using porcine blood rather than human blood from the target population. This gap reduces relevance below the level demanded by project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on a geometry and operating regime sufficiently close to the VAD COU. Project requirements specify that the validation pump geometry matches the submission device within defined geometric similarity bounds.",
      "rationale": "Validation was performed on the FDA generic pump geometry which differs from the submission device in impeller blade count and gap dimensions. Project requirements for geometric similarity were not satisfied, reducing validation relevance substantially at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off contributions must be quantified and shown to be negligible relative to discretization error. Project requirements specify residual drop of at least six orders of magnitude.",
      "rationale": "Numerical solver error was not assessed. Residual convergence plots were not archived for all operating points and no floating-point sensitivity study was performed. This factor is flagged as an epistemic gap at MRL 5 per project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal review of analyst inputs, boundary condition setup, and post-processing scripts must be documented. Project requirements mandate an independent second-analyst verification of all simulation inputs.",
      "rationale": "No independent second-analyst review was conducted. Boundary condition setup was performed by a single analyst without formal peer check. Use error remains an unquantified epistemic gap inconsistent with project requirements at this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis constitutive model must be justified through sensitivity studies and literature evidence. Project requirements specify that at least two turbulence models are compared and the hemolysis model form uncertainty is bounded.",
      "rationale": "Model form uncertainty was not assessed. A single turbulence model (SST k-omega) was used without comparison to alternatives. The power-law hemolysis model was adopted without form-uncertainty quantification. This represents a critical gap relative to project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterised with probability distributions and propagated through Monte Carlo UQ. Project requirements specify that inlet flow profile uncertainty and blood viscosity uncertainty are explicitly included.",
      "rationale": "Monte Carlo UQ was performed but inlet flow profile uncertainty was treated as deterministic and blood viscosity was assigned a uniform distribution without experimental basis. Full characterisation per project requirements was not achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be characterised for hematocrit, plasma free hemoglobin baseline, and storage duration. Project requirements demand at least n=5 independent blood samples per operating condition.",
      "rationale": "Test sample characterisation data were not available in the archived dataset. Sample size per operating condition was not reported. This factor could not be assessed and constitutes an epistemic gap at MRL 5 per project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Boundary conditions applied in the simulation must be demonstrably equivalent to measured experimental conditions within defined tolerances. Project requirements specify formal equivalency documentation for flow rate, rotational speed, and inlet hematocrit.",
      "rationale": "Equivalency of input parameters was not formally documented. Nominal boundary conditions were taken from pump operating specifications rather than measured experimental conditions. No tolerance analysis was performed, leaving this factor unassessed per project requirements."
    }
