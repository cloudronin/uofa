  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with version-controlled releases and audit trail per project requirements for MRL 5.",
      "rationale": "The CFD solver has a documented test suite and version control, but independent audit of the full test suite has not been completed. Achieved level 3 falls below the required level 4 for MRL 5 VAD applications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification required for hemolysis transport equations per project requirements.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the hemolysis scalar transport sub-model. Achieved level 3 is below the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be reported for all QoIs at each operating point as defined in project requirements.",
      "rationale": "GCI was computed for pressure rise and flow uniformity but not for the hemolysis index scalar field. Discretization error in the hemolysis QoI remains unquantified at the required fidelity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental operating conditions must match CFD boundary conditions within stated tolerances for all 5 flow-speed combinations per project requirements.",
      "rationale": "Three of five operating points have well-documented experimental boundary conditions. Two operating points lack inlet turbulence intensity measurements, creating a mismatch between test and simulation boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index predictions must be compared against experimental measurements using a systematic metric (e.g., E_rel) with uncertainty bounds per project requirements.",
      "rationale": "Relative error comparisons were performed but without propagated experimental uncertainty bands. The comparison metric does not fully account for measurement variability in the hemolysis assay."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly map to the clinical hemolysis acceptance threshold as specified in project requirements.",
      "rationale": "The hemolysis index (HI) is the primary QoI and is clinically relevant; however, the validation dataset uses a surrogate red blood cell damage model that is not fully equivalent to in vivo hemolysis measurement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the FDA generic pump geometry under VAD operating conditions matching the COU envelope per project requirements.",
      "rationale": "Validation was conducted on the FDA generic pump, which matches the COU geometry. However, the operating conditions span only part of the VAD clinical envelope, leaving high-flow edge cases unvalidated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and floating-point round-off sensitivity must be documented for hemolysis transport solver per project requirements.",
      "rationale": "Solver convergence residuals for the momentum equations were monitored, but iterative convergence of the hemolysis scalar transport equation was not independently assessed. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence of peer review of simulation setup, boundary condition assignment, and post-processing scripts per project requirements for Class III devices.",
      "rationale": "No independent peer review of simulation setup or post-processing was documented. Use error remains an unmitigated epistemic gap at MRL 5 for this Class III assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of hemolysis power-law model and turbulence closure must be provided with sensitivity analysis per project requirements.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was used without comparison to alternative model forms. Turbulence model sensitivity (k-omega SST vs. k-epsilon) was not explored. Model form uncertainty is a critical gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All hemolysis model input parameters must have documented sources and uncertainty ranges; Monte Carlo sampling must cover the full input uncertainty space per project requirements.",
      "rationale": "Monte Carlo UQ was performed covering blood viscosity, pump speed, and inlet flow rate. However, the hemolysis power-law exponents (alpha, beta) were treated as fixed constants rather than uncertain inputs, underestimating total input uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be characterized for hematocrit, temperature, and anticoagulant protocol per project requirements to ensure representativeness.",
      "rationale": "Sample characterization data for the validation experiments were not available in the published dataset. Hematocrit variability and anticoagulant effects on measured hemolysis are unquantified epistemic gaps."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "CFD boundary conditions must be demonstrated equivalent to experimental inlet conditions through direct measurement comparison per project requirements.",
      "rationale": "Equivalency between CFD inlet velocity profiles and experimental inlet conditions was not formally established. Inlet boundary condition discrepancies at two operating points remain unresolved, constituting an epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the VAD hemolysis CFD model is accepted under the Minimal profile binding. All 13 credibility factors have been evaluated against project requirements; 7 factors were formally assessed and 6 were identified as epistemic gaps at MRL 5. The Monte Carlo UQ demonstrates that hemolysis predictions remain below the absolute clinical threshold across the sampled operating space despite identified gaps. The assessment team acknowledges that multiple factors achieved levels below required levels; however, the totality of evidence, combined with conservative safety margins in the hemolysis threshold and the bounded nature of the identified gaps, supports acceptance at this stage pending gap closure in the next assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
