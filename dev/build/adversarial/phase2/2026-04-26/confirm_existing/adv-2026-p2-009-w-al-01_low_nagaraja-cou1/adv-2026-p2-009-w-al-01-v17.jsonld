  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet required levels. Test conditions factor achieves Gradation 1 against a required Gradation 2; this gap is acknowledged and accepted given that ASTM F1717 specifies a single standard test condition and multi-condition testing is not feasible within the regulatory submission timeline. Quantitative validation metrics (percent difference <10%, E/uval=1.42<1.96) confirm adequate model fidelity for the non-cannulated 7.5 mm pedicle screw compression-bending COU. Overall credibility sufficient for Medium assurance level.",
