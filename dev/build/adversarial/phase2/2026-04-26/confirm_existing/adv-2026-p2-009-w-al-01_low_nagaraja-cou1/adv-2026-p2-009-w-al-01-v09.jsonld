  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical) holds ISO 9001 certification; version-controlled analysis scripts archived in FDA validated repository.",
      "rationale": "Ansys Mechanical 2022 R2 used under a validated software environment with documented change control. Analysis scripts version-controlled in FDA OSEL GitLab instance. SQA procedures meet Gradation 2 requirements for a medium model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS suite solved to within 1% of analytic solution; patch test passed for all element types used.",
      "rationale": "Ansys Mechanical passed NAFEMS linear elastic benchmark suite. Patch test confirmed for hexahedral and tetrahedral elements used in screw and rod mesh. Code verification documented in internal verification report VR-2022-007."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in QoI between medium and fine mesh; Richardson extrapolation applied.",
      "rationale": "Three-level mesh refinement study performed on screw shank region (coarse: 0.8 mm, medium: 0.5 mm, fine: 0.3 mm element edge length). QoI change between medium and fine mesh was 1.1% for stiffness and 0.8% for yield force. Richardson extrapolation GCI < 2% for all QoIs. Medium mesh selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria tighter than 1e-5 for all load steps; energy convergence monitored.",
      "rationale": "Nonlinear solver force residual criterion set to 1e-6; displacement criterion 1e-5. Energy balance checked at each load increment. No convergence failures observed across 11 model instances. Achieved level exceeds required for this factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by second analyst; documented review checklist completed.",
      "rationale": "Model setup independently reviewed by a second FEA analyst using a 47-item checklist covering geometry, boundary conditions, material assignment, contact definitions, and load application. Two minor discrepancies identified and corrected prior to production runs. Review documented in UE-review-2023-04."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic model with isotropic hardening justified by literature; contact modeled with augmented Lagrangian formulation.",
      "rationale": "Ti-6Al-4V screw and rod modeled as elastic-plastic with bilinear isotropic hardening; material parameters from ASTM F136 coupon tests. UHMWPE block modeled as linear elastic, consistent with short-duration quasi-static loading. Augmented Lagrangian contact at screw-rod interface captures load transfer without interpenetration. Model form consistent with prior FDA-published pedicle screw FEA studies."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon tests; geometric inputs from CMM measurements of production screws.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus derived from tensile coupon tests (n=6 per lot) on Ti-6Al-4V material from the same lot as test constructs. Screw geometry verified by CMM to within 0.01 mm of nominal CAD. Torque preload on set screw measured and applied as equivalent contact pressure."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 production constructs from commercial lot; dimensional inspection confirms conformance to drawing.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from commercial production lot. All components inspected to drawing tolerances prior to testing. Two laboratories each tested subsets (Lab 1: n=6, Lab 2: n=5) to assess inter-laboratory variability. Sample size adequate for mean comparison at medium model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two distinct loading conditions or offsets tested to characterize model behavior across test space.",
      "rationale": "Testing performed at a single ASTM F1717 standard offset (5 mm anterior). Only one test condition evaluated, which does not meet the Gradation 2 requirement for multiple conditions. This factor is below required level; accepted under the overall credibility framework because all other factors meet or exceed requirements and the single condition is the clinically relevant worst-case scenario."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters demonstrably equivalent to test specimen parameters; traceability documented.",
      "rationale": "Material properties, geometry, assembly torque, and boundary conditions in the FEA model traced directly to measurements made on the physical test constructs. Traceability matrix linking each model input to its experimental source documented in equivalency report EQ-2023-11. No surrogate or assumed inputs used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percent difference < 10% for all QoIs.",
      "rationale": "Stiffness: FEA 312 N/mm vs. experimental mean 308 N/mm (1.3% difference, E/uval = 0.41). Yield force: FEA 1,847 N vs. experimental mean 1,821 N (1.4% difference, E/uval = 0.53). Force at 40 mm: FEA 2,103 N vs. experimental mean 2,089 N (0.7% difference, E/uval = 0.28). All QoIs within acceptance bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly map to ASTM F1717 pass/fail criteria and clinical failure modes.",
      "rationale": "The three QoIs correspond directly to the ASTM F1717 standard reporting requirements and to the clinically relevant failure modes of construct loosening (stiffness) and screw fracture (yield force, force at 40 mm). QoI selection reviewed and approved by clinical and regulatory subject matter experts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity replicates COU geometry, loading, and material; differences between validation and COU contexts documented and bounded.",
      "rationale": "The validation activity uses the same non-cannulated 7.5 mm pedicle screw geometry, material, and ASTM F1717 test configuration as the COU. The COU is the prediction of this specific device under this specific test standard, so the validation activity is directly equivalent. No extrapolation beyond the validated domain is required for the intended regulatory submission."
    }
  ],
