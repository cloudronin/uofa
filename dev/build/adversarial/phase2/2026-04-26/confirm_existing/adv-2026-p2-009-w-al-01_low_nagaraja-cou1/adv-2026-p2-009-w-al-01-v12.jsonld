  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys 2022 R1) holds ISO 9001 certification and a documented validation suite covering linear-static structural elements.",
      "rationale": "Ansys Mechanical 2022 R1 is commercially distributed with full QA documentation, regression test suite, and ISO 9001 certification. Software version control and release notes confirm the solver version used throughout the study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with analytical solutions (Euler-Bernoulli beam, Hertz contact) reproduced within 1% error.",
      "rationale": "Standard benchmark problems including cantilever beam bending and Hertz contact stress were solved and compared to closed-form solutions. All benchmarks passed the 1% tolerance threshold, confirming correct code implementation for the element types used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence demonstrated with <2% change in QoIs between successive refinements; GCI reported.",
      "rationale": "A three-level mesh refinement study was conducted on the pedicle screw shank and rod junction. Grid Convergence Index (GCI) for stiffness and yield force QoIs was below 1.5%, confirming discretization error is adequately controlled. Final mesh element count: 487,000 second-order tetrahedral elements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criterion <1e-5 for all load steps; no ill-conditioning warnings.",
      "rationale": "Newton-Raphson solver residuals converged to below 1e-6 for all load increments. No pivot warnings or ill-conditioning flags were observed. Double-precision arithmetic used throughout."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by a second analyst; checklist completed.",
      "rationale": "Model setup was independently reviewed by a second FDA analyst not involved in the original construction. A formal checklist covering boundary conditions, material assignments, contact definitions, and load application was completed and signed. No use errors were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elasto-plastic model with isotropic hardening justified for Ti-6Al-4V at quasi-static rates; literature support provided.",
      "rationale": "A continuum elasto-plastic formulation with bilinear isotropic hardening is well-established for Ti-6Al-4V under quasi-static loading. Grain-scale and fatigue effects are outside scope for this monotonic test. Literature (Donachie 2000, ASTM F136) supports the chosen constitutive model. Contact between rod and screw head modeled with frictional Coulomb law (mu=0.2)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon tensile testing of the same Ti-6Al-4V bar stock; geometry from CMM measurements.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (1.1 GPa) were measured from coupon specimens machined from the same bar stock as the test constructs. Screw and rod geometry were digitized using a coordinate measuring machine (CMM) with 5 µm accuracy. Friction coefficient was taken from published Ti-Ti tribology data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from two independent laboratories; samples traceable to same lot.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested: six at Laboratory A (FDA CDRH) and five at Laboratory B (DePuy Synthes). All screws and rods were drawn from the same manufacturing lot, ensuring material traceability. Construct assembly followed ASTM F1717 fixturing protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the intended clinical loading range; at minimum two distinct load levels or configurations tested.",
      "rationale": "Testing was performed at a single load configuration (ASTM F1717 standard compression-bending geometry, 44 mm vertebral body height). Only one test condition was evaluated, which falls below the required level. This gap is acknowledged and accepted given that the standard configuration is the most clinically relevant and regulatory precedent supports single-condition testing for this device class."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Measured specimen dimensions and material properties used directly as FEA inputs; traceability documented.",
      "rationale": "CMM-measured dimensions and coupon-derived material properties were used directly as model inputs. A parameter equivalency table maps each experimental measurement to its corresponding FEA input variable. No surrogate or literature-substituted values were used for geometry or material properties."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percent difference < 10% for all QoIs.",
      "rationale": "For all three QoIs (stiffness, yield force, force at 40 mm displacement), the validation metric E/uval was below 1.96 and percent differences were below 10%. Stiffness: 4.2% difference, E/uval=0.81. Yield force: 6.7% difference, E/uval=1.12. Force at 40 mm: 3.9% difference, E/uval=0.74. All acceptance criteria satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "The three selected QoIs are mandated by ASTM F1717 and directly correspond to construct stiffness (functional performance), yield force (onset of permanent deformation), and post-yield load capacity (implant survival). These metrics are directly cited in FDA guidance for spinal implant 510(k) submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments replicate the COU geometry, material, loading, and boundary conditions with documented mapping.",
      "rationale": "The validation experiments were conducted on the exact device geometry, material lot, and loading configuration specified in the COU. A validation relevance matrix confirms one-to-one correspondence between COU conditions and experimental conditions for geometry, material, load magnitude, load direction, and fixturing. The validation activity is assessed as highly relevant to the COU."
    }
  ],
