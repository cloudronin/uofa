      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarked against at least one analytical solution relevant to rotating machinery flow.",
      "rationale": "Solver verified against Taylor-Couette flow analytical solution and rotating channel flow benchmark. Discretization schemes confirmed second-order accurate. MRL 2 requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) below 5% for primary QoI (RHI and velocity) on the medium mesh used for production runs.",
      "rationale": "Three-mesh GCI study performed: coarse (2.1M), medium (6.8M), fine (18.4M) cells. GCI for RHI on medium mesh = 1.7%; GCI for area-averaged velocity = 2.1%. Both below 5% threshold. Medium mesh selected for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match CFD boundary conditions within 5% for all five operating points.",
      "rationale": "FDA benchmark experimental conditions replicated in CFD with flow rates and RPM matched to within 1.2%. Blood analog fluid (water-glycerin) properties implemented at measured temperature. All five operating points confirmed within tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mean relative error between CFD and experimental velocity fields below 10%; RHI predictions within experimental uncertainty bands.",
      "rationale": "Velocity field comparison against PIV data yields mean relative error of 8.3% across all planes and operating conditions. RHI predictions fall within ±1 standard deviation of experimental hemolysis measurements for 5 of 5 conditions. Acceptance criteria met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (RHI) directly maps to the clinical endpoint (hemolysis) and is computable from CFD outputs without unvalidated post-processing steps.",
      "rationale": "RHI computed via the Giersiepen-Wurzinger power-law model applied to Lagrangian particle tracks extracted from converged flow fields. The model is the accepted standard for CFD hemolysis prediction in rotary blood pumps and directly corresponds to the bench-measured normalized index of hemolysis."
    },
