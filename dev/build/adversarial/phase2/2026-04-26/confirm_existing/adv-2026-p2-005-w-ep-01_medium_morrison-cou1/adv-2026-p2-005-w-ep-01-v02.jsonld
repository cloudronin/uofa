  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cou1-cpb-hemolysis-claim",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD model of the FDA generic centrifugal blood pump has been subjected to extensive verification and validation activities, including mesh convergence studies demonstrating GCI values below 2% for all quantities of interest, numerical code verification against analytical solutions, and validation against FDA-sponsored PIV velocity measurements and in-vitro hemolysis bench data. Across all five evaluated flow-speed operating conditions, the model predicts relative hemolysis index values consistent with experimental observations within stated uncertainty bounds. The body of computational and experimental work collectively supports the conclusion that the model is adequate for identifying worst-case hemolysis conditions within the intended context of use at Model Risk Level 2. The assessment team reviewed all intermediate simulation outputs, turbulence model sensitivity studies, and red blood cell damage model parameterization prior to reaching this conclusion.",
      "scope": "Class II centrifugal blood pump; 5 operating conditions; RHI as primary QoI; MRL 2",
      "purpose": "Establish that the CFD model is fit for purpose for regulatory submission supporting worst-case hemolysis identification"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034918",
