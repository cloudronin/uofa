  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-claim",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for Class II CPB device",
      "description": "This claim asserts that the CFD model of the FDA generic centrifugal blood pump, employing the Giersiepen–Wurzinger power-law hemolysis model with SST k-ω turbulence closure, is fit for purpose in identifying the worst-case hemolysis operating condition among the five evaluated flow-speed combinations under CPB use conditions. Supporting evidence encompasses: (1) bench-scale in-vitro hemolysis measurements at all five operating points reported by Morrison et al. (2018); (2) a three-level grid convergence study demonstrating GCI < 4%; (3) software QA documentation conforming to FDA 21 CFR Part 11; and (4) numerical solver verification against the ASME V&V 20 manufactured-solution benchmark. The relative hemolysis index RH < 1 acceptance criterion is met across all operating points, and sensitivity analyses confirm that the rank ordering of hemolysis across operating conditions is robust to ±10% variation in blood rheological parameters. The claim scope is limited to the geometry, boundary conditions, and operating envelope documented in the COU; extrapolation to other pump geometries or patient populations is not supported.",
      "purpose": "Establish model credibility sufficient to support regulatory submission for Class II CPB device tolerance evaluation",
      "scope": "FDA generic centrifugal blood pump; 5 flow-speed operating points; CPB hemolysis index prediction; MRL 2"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041250",
