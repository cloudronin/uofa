  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-identification",
      "type": "Claim",
      "name": "CFD model reliably identifies worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump",
      "description": "The CFD hemolysis model, implemented using the modified power-law damage accumulation approach of Giersiepen et al. as recalibrated by Heuser and Opitz, has been applied across all five flow-speed operating combinations specified in the COU. Extensive internal documentation—including mesh sensitivity studies conducted on three grid refinement levels (coarse: 1.2 M cells, medium: 3.8 M cells, fine: 9.1 M cells), turbulence model benchmarking against the FDA nozzle validation dataset, and comparison of predicted relative hemolysis index (RH) values against in vitro roller-pump reference measurements—collectively supports the assertion that the model correctly rank-orders hemolysis severity across operating conditions. The worst-case condition (2.5 L/min, 3500 RPM) is identified with a predicted RH of 0.74, satisfying the RH < 1 acceptance criterion relative to the predicate device. All supporting analyses were performed by the V&V team between Q2 2024 and Q1 2025 and are archived in the project technical file under document series GCBP-VV-2024-001 through GCBP-VV-2024-017. The breadth and consistency of this body of work provides high confidence that the claim is substantiated.",
      "purpose": "Establish that the CFD model is fit for purpose in identifying the operating point producing maximum hemolysis risk, thereby supporting the regulatory submission decision for the Class II CPB device.",
      "scope": "Applicable to the FDA generic centrifugal blood pump geometry operated within the flow range 2.0–6.0 L/min and rotational speed range 2500–4500 RPM under steady-state boundary conditions representative of adult CPB circuits."
    }
  ],
