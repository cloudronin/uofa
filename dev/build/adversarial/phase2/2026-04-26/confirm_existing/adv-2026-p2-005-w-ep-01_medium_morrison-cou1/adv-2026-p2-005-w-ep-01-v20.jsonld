  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-claim",
      "type": "Claim",
      "name": "CFD model adequately identifies worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB use",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage model coupled with SST k-omega turbulence closure, has been demonstrated through an extensive body of verification and validation work to reliably rank-order hemolysis severity across the five nominated flow-speed combinations (3–6 L/min, 2000–3500 RPM). Mesh independence was confirmed via three-level Richardson extrapolation yielding GCI < 2% on the scalar stress exposure metric. Validation against FDA benchmark PIV data and independent in-vitro NIH measurements at equivalent operating conditions substantiates the claim that the model correctly identifies the 6 L/min, 3500 RPM condition as worst-case, with RH = 0.87 relative to the predicate device, satisfying the RH < 1 acceptance criterion. The claim scope is bounded to Class II CPB devices of analogous impeller geometry and does not extend to pulsatile assist or ECMO applications.",
      "purpose": "Establish that the computational model output is credible for the regulatory decision to accept the pump tolerance design under CPB operating conditions.",
      "scope": "FDA generic centrifugal blood pump geometry; steady-state operating envelope 3–6 L/min, 2000–3500 RPM; Model Risk Level 2; Class II device classification."
    }
  ],
