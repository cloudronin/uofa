  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-identification",
      "type": "Claim",
      "name": "CFD model correctly identifies worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage accumulation approach with SST k-omega turbulence closure, has been shown through extensive mesh refinement studies, turbulence sensitivity analyses, and comparison against published in-vitro hemolysis data to reliably rank-order the five target flow-speed operating points by hemolysis severity. Internal validation reports (Morrison et al., 2023; QA-report-CFD-2024-03) document GCI values below 2% on the refined mesh, agreement of predicted RH index within 15% of experimental benchmarks across three pump geometries, and robustness of worst-case identification to ±10% variation in blood viscosity inputs. The claim scope is limited to the five operating points specified in the COU and does not extend to off-design or pulsatile flow regimes."
    }
  ],
