    }
  ],
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/morrison-cou1-hemolysis-claim",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for the FDA GCBP at MRL 2",
      "description": "The CFD model, employing the Giersiepen–Wurzinger power-law hemolysis correlation with SST k-ω turbulence closure, has been assessed against published in-vitro hemolysis data from the FDA GCBP interlaboratory study and Morrison et al. (2012). Across all five evaluated flow-speed combinations the predicted relative hemolysis index remained below unity, consistent with the acceptance criterion. Mesh sensitivity, turbulence model selection, and boundary condition fidelity have been documented in the supporting technical reports. The accumulated body of evidence from numerical code verification activities, discretization error quantification, and experimental validation comparisons collectively supports the conclusion that the model is fit for the stated context of use at Model Risk Level 2. The assessment team judges that no additional validation activities are required prior to regulatory submission for a Class II CPB device.",
      "purpose": "Establish model credibility sufficient to support a 510(k) submission for a Class II centrifugal blood pump under CPB operating conditions.",
      "scope": "FDA generic centrifugal blood pump geometry; operating envelope of 2–7 L/min flow rate and 2000–3500 RPM; relative hemolysis index as the primary quantity of interest."
    }
  ],
