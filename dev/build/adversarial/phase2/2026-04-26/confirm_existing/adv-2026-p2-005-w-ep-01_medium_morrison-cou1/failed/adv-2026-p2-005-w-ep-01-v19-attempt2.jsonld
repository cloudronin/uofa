  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-claim-001",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage accumulation formulation with SST k-omega turbulence closure, has been demonstrated through extensive benchmark comparisons against the FDA generic centrifugal blood pump experimental dataset (Hariharan et al. 2011, Stewart et al. 2012) to predict normalized index of hemolysis within 15% of experimental values across the full operating envelope. The model correctly identifies the high-speed, low-flow corner of the operating map as the worst-case hemolysis condition, consistent with experimental observations. Geometric sensitivity studies covering ±10% variation in impeller clearance and volute tongue gap confirm that relative ranking of design variants is preserved. On this basis, the model is judged fit for the purpose of identifying worst-case hemolysis conditions for the Class II CPB device under the specified COU. Supporting analyses include mesh independence verification, turbulence model sensitivity assessment, and blood viscosity parameter uncertainty quantification, all of which were conducted as part of the broader credibility evidence package assembled for this submission.",
      "purpose": "Establish model adequacy for identifying worst-case hemolysis operating conditions in support of regulatory submission for Class II CPB device",
      "scope": "FDA generic centrifugal blood pump geometry; operating range 2–6 L/min flow, 2000–3500 RPM; hemolysis prediction via relative hemolysis index RH; MRL 2 assessment"
    }
  ],
