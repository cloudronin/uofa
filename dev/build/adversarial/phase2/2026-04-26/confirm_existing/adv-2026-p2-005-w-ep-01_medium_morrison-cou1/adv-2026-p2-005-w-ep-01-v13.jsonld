  ],
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-claim-001",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions",
      "description": "This claim asserts that the CFD hemolysis model, implemented using a power-law damage accumulation formulation calibrated against published in-vitro hemolysis data for the FDA generic centrifugal blood pump, is sufficiently credible to identify the worst-case hemolysis operating point across the five evaluated flow-speed combinations (2.5 L/min at 2000 RPM, 3.5 L/min at 2500 RPM, 4.5 L/min at 3000 RPM, 5.5 L/min at 3500 RPM, and 6.5 L/min at 4000 RPM). Supporting work includes mesh convergence studies demonstrating GCI values below 3% for all QoIs, turbulence model sensitivity analyses comparing k-omega SST and realizable k-epsilon formulations, and cross-validation against the Morrison et al. (2020) experimental dataset reporting normalized index of hemolysis (NIH) measurements at each operating point. The relative hemolysis index (RH) computed at the worst-case condition falls below the 1.0 acceptance threshold relative to the predicate device, supporting the regulatory submission conclusion. All seven assessed credibility factors achieved their required levels under MRL 2 per ASME V&V 40-2018 Table 3."
    }
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
