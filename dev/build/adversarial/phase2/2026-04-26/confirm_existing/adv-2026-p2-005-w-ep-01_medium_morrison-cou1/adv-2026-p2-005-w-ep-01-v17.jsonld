  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/pump-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against published experimental measurements for the FDA benchmark centrifugal pump across five operating points (2.5 L/min at 2500 RPM, 5 L/min at 3500 RPM, 7 L/min at 4500 RPM, and two intermediate conditions). Agreement within 18% across all operating points. Relative hemolysis index RH < 1 satisfied for all COU operating conditions.",
      "prov:wasDerivedFrom": "https://doi.org/10.1115/1.4023636"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh independence verification for centrifugal pump CFD model",
      "description": "Three mesh densities (2.1M, 5.4M, and 11.2M elements) were evaluated. GCI between medium and fine mesh was 3.2% for NIH, confirming discretization error is within acceptable bounds at the medium mesh resolution used for production runs.",
      "prov:wasDerivedFrom": "https://doi.org/10.1115/1.4028898"
    }
  ],
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-identification",
      "type": "Claim",
      "name": "CFD model reliably identifies worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB use",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage accumulation formulation with SST k-omega turbulence closure, has been demonstrated through extensive validation activities to reliably rank-order hemolysis severity across the five COU operating points. Experimental bench studies conducted at three independent laboratories on the FDA benchmark pump geometry, combined with mesh convergence analyses and software QA audits, collectively support the conclusion that the model correctly identifies the 7 L/min / 4500 RPM operating point as worst-case with respect to the relative hemolysis index. All five operating conditions satisfy RH < 1 relative to the predicate device. The claim is further substantiated by published literature comparing CFD hemolysis predictions against in vitro NIH measurements, showing systematic agreement within the uncertainty bounds established for MRL 2 assessments. Sensitivity analyses on blood viscosity and hematocrit parameters confirm robustness of the worst-case identification across physiologically plausible input ranges."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4023636",
