  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case",
      "type": "Claim",
      "name": "CFD model correctly identifies worst-case hemolysis operating conditions for FDA generic centrifugal blood pump",
      "description": "The CFD hemolysis prediction model, employing the Giersiepen-Wurzinger power-law damage accumulation approach with SST k-omega turbulence closure, correctly identifies the worst-case hemolysis operating point among the five evaluated flow-speed combinations (2.5 L/min at 3500 RPM, 3.5 L/min at 3500 RPM, 4.5 L/min at 3500 RPM, 3.5 L/min at 2500 RPM, and 3.5 L/min at 4500 RPM) for the FDA generic centrifugal blood pump geometry. This claim is grounded in an extensive body of supporting work including mesh independence studies demonstrating less than 2% variation in predicted hemolysis index across three refinement levels, iterative solver convergence to residuals below 1e-5 for all transport equations, and qualitative agreement between predicted high-shear zones and published PIV measurements from the FDA benchmark programme. The relative hemolysis index for the identified worst-case condition (RH = 0.87) satisfies the pre-specified acceptance criterion of RH < 1 against the predicate device. Cross-laboratory reproducibility of the FDA pump benchmark dataset further corroborates confidence in the simulation framework. All evidence has been reviewed by the credibility assessment team and is on file within the project validation dossier (Morrison et al., 2023, internal report MED-CFD-2023-047).",
      "purpose": "Establish model credibility for regulatory submission supporting 510(k) clearance of tolerance variations in the CPB pump impeller geometry",
      "scope": "FDA generic centrifugal blood pump; five operating points; MRL 2; Class II device; CPB indication"
    }
  ],
