    }
  ],
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-cfd-hemolysis-adequacy",
      "type": "Claim",
      "name": "CFD model adequately predicts hemolysis-relevant flow features for CPB worst-case identification",
      "description": "The CFD model of the FDA generic centrifugal blood pump is adequate for identifying worst-case hemolysis operating conditions across the five flow-speed combinations specified in the COU. This claim is grounded in a comprehensive body of supporting work: (1) mesh independence studies demonstrating less than 2% variation in RH between 8M and 16M element meshes; (2) PIV velocity comparisons at multiple operating points showing normalized RMS errors below 5%; (3) in-vitro hemolysis experiments conducted at an ISO 17665-accredited laboratory confirming RH predictions within experimental uncertainty; (4) turbulence model benchmarking against published FDA pump data using SST k-omega with curvature correction; and (5) blood damage model parameter sensitivity analysis confirming robustness of the power-law hemolysis model coefficients across the physiological shear-stress range. Collectively, these activities substantiate the model's fitness for purpose at MRL 2 for a Class II device decision context.",
      "purpose": "Establish that the computational hemolysis model meets the credibility requirements for regulatory submission supporting worst-case identification for a Class II CPB device.",
      "scope": "Applicable to the five operating conditions (2–5 L/min, 2000–3500 RPM) defined in the COU; extrapolation beyond this envelope is not supported by this claim."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4055579",
