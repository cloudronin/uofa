  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 not-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. Validation evidence demonstrates CFD predictions of relative hemolysis index within 12% of experimental measurements across the full COU operating envelope. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cou1-cpb-hemolysis-claim",
      "type": "Claim",
      "name": "CFD model adequately predicts relative hemolysis index for worst-case CPB operating condition identification",
      "description": "This claim asserts that the CFD hemolysis model, employing the power-law hemolysis damage model of Giersiepen et al. as modified by Heuser and Opitz, produces relative hemolysis index (RH) predictions of sufficient fidelity to reliably rank-order operating conditions by hemolysis risk for the FDA generic centrifugal blood pump under CPB conditions. The supporting body of work encompasses mesh independence studies across three refinement levels, comparison against five in-vitro operating points with maximum error below 15%, software quality assurance under an institutional SQA plan, and numerical code verification via method of manufactured solutions. Taken together, this evidence base demonstrates that the model captures the dominant shear-stress-driven hemolysis mechanisms relevant to the COU and that the RH < 1 acceptance criterion can be evaluated with adequate confidence at Model Risk Level 2."
    }
  ],
