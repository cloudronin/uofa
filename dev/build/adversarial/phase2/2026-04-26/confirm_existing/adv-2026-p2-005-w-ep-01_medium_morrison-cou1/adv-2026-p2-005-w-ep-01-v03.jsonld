  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemo-worst-case-identification",
      "type": "Claim",
      "name": "CFD model correctly identifies worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump",
      "description": "This claim asserts that the CFD hemolysis model, based on the power-law damage accumulation approach (Giersiepen-Wurzinger correlation adapted for continuous flow), reliably identifies the operating point (flow rate and rotational speed combination) that produces maximum pump-induced hemolysis across the five evaluated CPB operating conditions. The claim is grounded in a comprehensive body of work including mesh independence studies conducted across three refinement levels (coarse, medium, fine; GCI < 2% on shear stress integral), turbulence model sensitivity analyses comparing k-omega SST and realizable k-epsilon formulations, and experimental validation against published FDA pump hemolysis data from Hariharan et al. (2011) and Malinauskas et al. (2017). Scalar transport of the hemolysis index was verified against analytical solutions for simple shear flows. The relative hemolysis index (RH) computed at each of the five operating points shows consistent rank-ordering across mesh refinements, supporting the claim that the worst-case identification is robust to numerical discretization choices. The claim scope is restricted to the FDA generic centrifugal pump geometry under CPB flow rates (2–6 L/min) and rotational speeds (2500–4000 RPM) as specified in COU1."
    }
  ],
  "hasValidationResult": [
