    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-rh-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against FDA experimental benchmark",
      "description": "CFD-predicted relative hemolysis index (RH) compared against FDA experimental measurements across all 5 flow-speed operating points. RH < 1.0 achieved at all operating points with maximum RH = 0.87 at worst-case condition (6 LPM, 3500 RPM). Mean absolute error 8.3% relative to experimental mean.",
      "prov:wasDerivedFrom": "https://uofa.net/synth/data/fda-generic-pump-experimental-hemolysis"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-sensitivity",
      "type": "ValidationResult",
      "name": "Mesh sensitivity and discretization error quantification",
      "description": "Grid convergence index (GCI) study performed on three mesh refinement levels (2.1M, 6.8M, 18.4M cells). GCI for hemolysis index < 3.2% on fine-to-medium refinement, confirming mesh-independent solution. Richardson extrapolation applied to quantify discretization uncertainty.",
      "prov:wasDerivedFrom": "https://uofa.net/synth/data/cfd-mesh-sensitivity-study-cpb"
    }
  ],
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-model-credibility",
      "type": "Claim",
      "name": "CFD model is sufficiently credible to identify worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB use",
      "description": "The CFD hemolysis model for the FDA generic centrifugal blood pump has been subjected to extensive verification and validation activities consistent with ASME V&V 40 requirements for Model Risk Level 2. Numerical code verification confirmed solver accuracy through manufactured solution benchmarks. Mesh sensitivity analysis demonstrated discretization errors below 4% GCI across all evaluated operating conditions. Validation against FDA experimental hemolysis data yielded relative hemolysis index predictions within 10% of measured values across all five flow-speed combinations. Turbulence model selection (SST k-omega) was justified through sensitivity studies comparing three candidate models. Blood damage model parameters were calibrated against published in-vitro hemolysis data from multiple independent laboratories. The totality of this verification and validation work, combined with the medium model influence classification and established RH < 1 acceptance criterion, supports the conclusion that the model is fit for the intended purpose of identifying worst-case operating conditions for regulatory submission."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4040621",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv-team",
