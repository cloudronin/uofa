  "signature": "ed25519:9b1d3e7f2a4c6e0b8d5f3a1c9e7b2d4f6a0c8e2b4d6f0a2c4e6b8d0f2a4c6e8b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and version control meets MRL 2 requirement of Gradation 1.",
      "rationale": "ANSYS Fluent 2022R2 used with institutional QA protocol including version-locked simulations, documented input files under revision control, and independent review of solver settings prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarked against at least one canonical flow problem relevant to rotating machinery.",
      "rationale": "ANSYS Fluent verified against Taylor-Couette flow benchmark and FDA nozzle benchmark problem. Velocity and pressure predictions within 2% of analytical solutions for laminar regime; turbulent benchmark agreement within 5% for SST k-omega model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for primary quantity of interest (hemolysis index) on production mesh.",
      "rationale": "Three-level mesh refinement study conducted. GCI for hemolysis index = 3.2% (medium-to-fine), 7.1% (coarse-to-medium). Production runs performed on fine mesh (18.4M cells). Richardson extrapolation applied; asymptotic range confirmed with observed order of convergence p = 1.94."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rates) documented and matched to CFD boundary conditions within stated uncertainty bounds.",
      "rationale": "FDA experimental conditions replicated: bovine blood analog (glycerin-water, matched viscosity), five flow-speed combinations (3–6 LPM, 2500–3500 RPM). Inlet velocity profiles specified from measured data. Temperature maintained at 37°C ± 0.5°C in experiments; isothermal assumption in CFD validated as acceptable given low thermal sensitivity of RH index."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index within 15% of experimental mean across all operating points.",
      "rationale": "Maximum absolute error in RH index = 8.3% across five operating points. All predictions within one standard deviation of experimental measurements. Model systematically underpredicts RH at low flow rates (3 LPM) by 6–8%, attributed to secondary recirculation zones not fully captured at coarser near-wall resolution; conservative for regulatory purposes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (relative hemolysis index RH) directly maps to regulatory acceptance criterion and clinical hemolysis endpoint.",
      "rationale": "Relative hemolysis index (RH = NIH_device / NIH_predicate) is the FDA-accepted metric for comparative hemolysis assessment. RH < 1 acceptance criterion directly corresponds to clinical non-inferiority requirement. Secondary QoIs (shear stress distribution, exposure time histograms) provide mechanistic support for primary QoI interpretation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
