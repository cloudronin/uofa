  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-claim",
      "type": "Claim",
      "name": "CFD model reliably identifies worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump",
      "description": "This claim asserts that the CFD hemolysis prediction model, employing the Giersiepen-Wurzinger power-law damage model with SST k-omega turbulence closure, is sufficiently credible to identify the worst-case hemolysis operating condition among the five evaluated flow-speed combinations (2 L/min at 3500 RPM, 3 L/min at 3000 RPM, 4 L/min at 2500 RPM, 5 L/min at 2000 RPM, and 6 L/min at 1500 RPM) for the FDA generic centrifugal blood pump geometry. Supporting work includes mesh independence studies conducted across three refinement levels (coarse: 1.2M cells, medium: 3.8M cells, fine: 9.1M cells), iterative convergence monitoring to residual tolerances below 1e-5, comparison of predicted normalized index of hemolysis (NIH) values against the published FDA benchmark experimental dataset (Hariharan et al. 2011), and dimensional sensitivity analyses across five geometric variants. The relative hemolysis index RH remains below 1.0 for all evaluated configurations relative to the predicate device, satisfying the pre-specified acceptance criterion. The scope of this claim is restricted to MRL 2 classification, Class II device context, and the specific pump geometry and operating envelope described in the COU.",
      "purpose": "Provide the primary credibility assertion linking the CFD model outputs to the regulatory decision on worst-case hemolysis conditions for CPB device submission.",
      "scope": "FDA generic centrifugal blood pump; 5 flow-speed combinations; MRL 2; Class II CPB device; RH < 1 acceptance criterion"
    }
  ],
  "hasValidationResult": [
