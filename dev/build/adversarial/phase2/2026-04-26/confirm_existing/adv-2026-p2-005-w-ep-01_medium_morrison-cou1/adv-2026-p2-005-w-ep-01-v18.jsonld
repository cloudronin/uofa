  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-identification",
      "type": "Claim",
      "name": "CFD model reliably identifies worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump at MRL 2",
      "description": "Based on a comprehensive body of supporting work — including mesh independence studies across three refinement levels, experimental comparison of normalized index of hemolysis at five clinically relevant flow-speed combinations, turbulence model sensitivity analyses, and software quality assurance activities — the CFD model is judged credible for identifying the worst-case hemolysis operating condition across the design space. The relative hemolysis index (RH) computed at all five operating points satisfies RH < 1 against the predicate device benchmark. The claim scope is limited to Class II CPB devices with geometries within ±10% of the FDA generic pump dimensions and operating within the validated flow range of 2–6 L/min at 2000–3500 RPM. This claim is consistent with the MRL 2 requirements under ASME V&V 40-2018 and has been reviewed by the credibility assessment team."
    }
  ],
