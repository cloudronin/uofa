  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction has been reviewed. All seven assessed credibility factors show achieved levels below required levels for MRL 5. Six factors remain unassessed. The CFD model demonstrates qualitative agreement with experimental hemolysis trends across operating points. The assessment team accepts the package as a complete characterization of current model credibility, acknowledging that the model is not sufficient for regulatory submission without addressing identified gaps.",
