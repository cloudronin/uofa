      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be under formal version control with documented test suite covering hemolysis solver modules; all code changes peer-reviewed.",
      "rationale": "Version control is in place but the test suite covers only 40% of hemolysis-relevant solver paths. Peer review process is informal. Achieved level falls below required level for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must demonstrate order-of-accuracy convergence for all governing equations including the hemolysis transport equation.",
      "rationale": "MMS applied to Navier-Stokes equations only; hemolysis transport equation not verified via MMS. Convergence order confirmed for flow solver but not for scalar transport. Achieved level below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic grid convergence study using at least three mesh refinement levels with Richardson extrapolation applied to hemolysis index QOI; GCI reported.",
      "rationale": "Grid convergence study performed with three mesh levels for pressure and velocity but Richardson extrapolation not applied to the hemolysis index directly. GCI not reported for primary QOI. Achieved level below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five COU operating points with blood analog fluid properties characterized; temperature, hematocrit, and flow waveform documented.",
      "rationale": "Four of five operating points replicated in bench testing. Hematocrit documented but temperature variation not controlled across all runs. Partial match to COU conditions; achieved level below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMSE or validation metric per ASME V&V 20) applied to hemolysis index predictions versus experimental measurements across all operating points.",
      "rationale": "Comparison performed visually and via percent difference only; no formal validation metric computed. Experimental uncertainty not propagated into comparison. Achieved level substantially below required."
    },
    {
