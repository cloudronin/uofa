  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed or flagged. Seven factors assessed show achieved levels below required levels; six factors remain not-assessed at MRL 5. Despite credibility gaps, the assessment team accepted the submission based on the consistent low relative errors (4–9%) across all five validation operating points and the conservative hemolysis threshold applied in the COU decision. Residual credibility gaps are noted for post-market surveillance follow-up.",
