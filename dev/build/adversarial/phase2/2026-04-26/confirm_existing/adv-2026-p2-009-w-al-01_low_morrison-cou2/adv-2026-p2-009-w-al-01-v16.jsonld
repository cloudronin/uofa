      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy studies and benchmark comparisons for all active numerical schemes.",
      "rationale": "Order-of-accuracy verification performed for Navier-Stokes solver; hemolysis transport scalar equation verified against analytical benchmark but not at full operating-condition range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence index reported for all QoIs.",
      "rationale": "Grid convergence index computed on three mesh refinement levels for velocity and pressure; hemolysis index GCI reported at 4.2% on finest mesh, which exceeds the MRL 5 target of 2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with full traceability to clinical operating envelope.",
      "rationale": "FDA pump experiments conducted at 5 operating points spanning the clinical VAD envelope. Fluid temperature and hematocrit documented; however, blood viscosity measurement uncertainty is not fully characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric) applied to all QoIs with statistical interpretation.",
      "rationale": "Relative errors computed for all 5 operating points; errors range 4–9%. No formal validation metric (e.g., area metric or u-pooling) applied; comparison is point-estimate only without propagated experimental uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs are identical to or directly map to COU decision QoIs.",
      "rationale": "Normalized Index of Hemolysis used in both validation and COU decision. Mapping is direct; however, the clinical threshold comparison requires integration of NIH over a patient exposure duration not replicated in bench experiments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted on geometry, fluid, and operating conditions representative of COU.",
      "rationale": "FDA generic pump geometry used in validation is not identical to the proprietary VAD geometry. Geometric similarity assessed qualitatively; quantitative similarity metrics not computed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and residuals reported for all simulations.",
      "rationale": "Residuals reduced to 1e-5 for continuity and momentum; hemolysis scalar residual reaches 1e-4. Solver error estimated but not formally bounded against MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation setup review and independent verification of boundary conditions.",
      "rationale": "Internal peer review of boundary condition setup conducted. No independent third-party review performed; checklist-based review only."
    },
