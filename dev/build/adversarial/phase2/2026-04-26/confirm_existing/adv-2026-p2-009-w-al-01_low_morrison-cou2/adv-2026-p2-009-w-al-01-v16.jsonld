      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability including donor-to-donor biological variation.",
      "rationale": "Experimental hemolysis measurements represent single-donor porcine blood per operating point. Biological variability across donors not characterized; sample size insufficient for statistical inference at MRL 5."
    },
