      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite and change management process.",
      "rationale": "ANSYS Fluent v19.2 is used with institutional version control. A formal test suite exists but coverage of hemolysis-specific sub-models is incomplete relative to MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
