  "signature": "ed25519:7b2e4f1a9c3d5e7b0f2a4c6e8d1b3f5a7c9e2b4d6f8a0c2e4b6d8f0a2c4e6b8d",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented version control, regression testing suite, and formal code review records must be present for all CFD solver modules used in hemolysis prediction.",
      "rationale": "Version control is in place and basic regression tests exist, but formal code review records are incomplete and no independent software audit has been conducted. Achieved level falls short of the MRL 5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on benchmark problems with known analytical solutions must confirm solver convergence rates for the shear-stress transport equations relevant to hemolysis.",
      "rationale": "Order-of-accuracy testing was performed on simplified channel flow benchmarks but not on rotating-frame turbomachinery configurations directly relevant to the pump geometry. Convergence rates are unconfirmed for the hemolysis-critical shear stress field."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be reported for hemolysis index predictions on at least three systematically refined mesh levels.",
      "rationale": "A three-level mesh refinement study was conducted and GCI values computed; however the fine-grid GCI exceeds 8% for the hemolysis index at two of five operating points, indicating insufficient discretization control for the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within documented tolerances for flow rate, rotational speed, fluid temperature, and hematocrit.",
      "rationale": "Flow rate and rotational speed are matched within 2%; however hematocrit variability across blood samples used in experiments was not fully characterized, and fluid temperature during in vitro testing deviated by up to 2°C from nominal CFD conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or validation metric per ASME V&V 20) must demonstrate CFD predictions within 15% of experimental hemolysis index across all five operating points.",
      "rationale": "CFD predictions exceed experimental values by 18–42% at three of five operating points. The comparison metric is computed but agreement is outside the acceptance band. No uncertainty intervals are reported alongside the comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (normalized index of hemolysis, NIH) must be directly mapped to the clinical acceptance threshold without intermediate surrogate transformations.",
      "rationale": "NIH is the primary QoI and is directly compared to the clinical threshold. However, the hemolysis model (power-law Giersiepen–Wurzinger) introduces a surrogate relationship between shear stress exposure and red cell damage that is not independently validated at MRL 5 fidelity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same FDA generic centrifugal pump geometry at VAD operating conditions; surrogate geometries are not acceptable at MRL 5.",
      "rationale": "Validation experiments were conducted on the FDA benchmark pump geometry at the specified VAD operating points. Relevance is high but not complete because one operating point (6 L/min, 4800 RPM) was tested at a different facility with a different measurement protocol, reducing confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Round-off and iterative convergence errors must be quantified and shown to be negligible relative to discretization error for all operating points.",
      "rationale": "Iterative residuals are reported but round-off error analysis has not been performed. This factor is flagged as a gap at MRL 5; no evidence is available to assess the achieved level beyond the default."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal independent review of CFD setup, boundary condition application, and post-processing scripts must be documented by a reviewer not involved in the original simulation.",
      "rationale": "No independent use-error review has been performed. The simulation setup was conducted and reviewed by the same analyst team. This represents an uncharacterized epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence model and hemolysis damage accumulation model must be justified through sensitivity studies comparing at least three model-form alternatives against experimental data.",
      "rationale": "Only the SST k-omega turbulence model and the Giersiepen–Wurzinger hemolysis model were used. No model-form sensitivity study comparing alternative turbulence closures or hemolysis models has been conducted. This is the highest-priority unassessed gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions must be assigned to all uncertain model inputs (fluid viscosity, hematocrit, pump clearance geometry) and propagated through Monte Carlo simulation to yield prediction intervals on hemolysis index.",
      "rationale": "Monte Carlo UQ is described in the COU intent but has not been executed. Input probability distributions have not been formally assigned. This factor remains entirely unassessed and represents the primary aleatory uncertainty gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of inter-sample variability in blood properties across experimental replicates must be reported with sufficient replication (n ≥ 5 per operating point) to estimate population-level hemolysis.",
      "rationale": "Experimental replication data are not available in the dataset. Only single-run measurements exist for most operating points. Sample-to-sample biological variability is entirely uncharacterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between experimental fluid properties (viscosity, density, hematocrit) and CFD input parameters must be demonstrated through direct measurement at the time of each experiment.",
      "rationale": "CFD input parameters were set to nominal literature values rather than values measured during the specific experiments. No equivalency mapping between in vitro fluid properties and simulation inputs has been documented."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were assessed and all show achieved levels below required levels for MRL 5. Six factors remain not-assessed, representing significant epistemic gaps. The overall credibility is judged insufficient for regulatory submission of the Class III VAD hemolysis claim. The package is accepted as a complete and valid credibility assessment record documenting the current state of evidence, but the underlying model claim is not accepted for device decision-making.",
