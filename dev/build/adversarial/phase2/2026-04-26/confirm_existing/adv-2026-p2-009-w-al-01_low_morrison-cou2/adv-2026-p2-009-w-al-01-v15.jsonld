  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented version control, regression testing, and code review procedures must be in place for the CFD solver and hemolysis post-processing scripts.",
      "rationale": "Version control is maintained via git repository; however, regression test coverage for hemolysis post-processing is limited to three canonical cases. Code review procedures are informal and not documented in a quality plan. Achieved level falls short of the required level for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing must confirm that the CFD solver achieves expected convergence rates for the governing equations relevant to blood pump flows.",
      "rationale": "Order-of-accuracy tests were conducted on simplified channel geometries and confirmed second-order spatial accuracy for velocity. No order-of-accuracy testing was performed for the hemolysis transport equation, which is the primary quantity of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence analysis must be performed on the hemolysis index and pressure head at all five operating conditions.",
      "rationale": "Grid convergence index (GCI) analysis was completed on three of five operating conditions. Discretization errors for hemolysis index are estimated at 4–8% on the finest mesh. The two remaining operating points were not included in the convergence study due to solver instability at high RPM."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match the CFD boundary conditions within stated tolerances; fluid properties (viscosity, density) must be measured and reported.",
      "rationale": "Experimental flow rates were controlled to within ±0.1 L/min; however, fluid temperature was not monitored during hemolysis experiments, introducing uncertainty in viscosity. Blood analog viscosity was assumed constant at 3.5 mPa·s but was not measured per-test."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, validation uncertainty) must be computed for hemolysis index predictions versus experimental measurements at all operating conditions.",
      "rationale": "Predicted hemolysis indices are compared graphically to experimental values; normalized RMS error is 22% across the five operating points. Validation uncertainty has not been formally computed. The comparison does not meet the quantitative rigor required at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary quantity of interest (absolute hemolysis index) must be directly predicted by the model and compared to the clinical acceptance threshold without surrogate substitution.",
      "rationale": "The model directly predicts the normalized index of hemolysis (NIH) as the primary QoI. However, the hemolysis power law coefficients used in the post-processing step are derived from a literature source that does not reflect the specific blood analog used in validation experiments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry, at the same operating conditions, and with the same fluid as the COU.",
      "rationale": "Validation was conducted on the FDA benchmark centrifugal pump geometry which matches the COU device. Operating conditions span the VAD range. However, experiments used a bovine blood analog rather than human blood, reducing direct relevance to the clinical COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off contributions to hemolysis predictions must be documented and bounded.",
      "rationale": "Iterative convergence residuals are reported (10^-5 for momentum, 10^-6 for continuity) but no formal analysis of numerical solver error contribution to hemolysis index uncertainty has been performed. This factor is flagged as an epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence of independent review of CFD setup, boundary condition specification, and post-processing scripts by a qualified analyst not involved in the original simulation.",
      "rationale": "No independent review of the simulation setup or post-processing has been conducted. A single analyst performed all simulation work and hemolysis calculations. This represents an uncharacterized risk of use error at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to turbulence model selection must be quantified; alternative model forms (k-omega SST, LES) must be evaluated.",
      "rationale": "Only the k-epsilon realizable turbulence model was used. No turbulence model sensitivity study was performed. Given the known sensitivity of hemolysis predictions to turbulence model choice in centrifugal pumps, this is a critical uncharacterized gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in model input parameters (fluid viscosity, pump geometry tolerances, hemolysis power law coefficients) must be propagated through the model using Monte Carlo or equivalent methods.",
      "rationale": "No input uncertainty propagation has been performed. Nominal values are used for all model inputs. The hemolysis power law exponents (C, alpha, beta) are treated as deterministic despite substantial literature variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates must be available to characterize measurement variability; statistical characterization of hemolysis measurement scatter must be provided.",
      "rationale": "Only two experimental replicates are available per operating condition. No statistical characterization of inter-replicate variability in hemolysis measurements has been performed, preventing estimation of experimental uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Inlet velocity profiles and turbulence intensity used in CFD must be shown to match experimental inlet conditions through measurement or sensitivity analysis.",
      "rationale": "Inlet boundary conditions in CFD are specified as uniform velocity profiles with assumed turbulence intensity of 5%. No experimental characterization of the inlet flow field was performed, and no sensitivity analysis on inlet conditions has been conducted."
    }
