  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented QA procedures including version control, regression testing, and validation test suite at level consistent with MRL 5.",
      "rationale": "Solver QA documentation covers version control and regression testing but formal validation test suite is incomplete relative to MRL 5 requirements. Achieved level falls one gradation below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark verification must demonstrate solver correctness for rotating machinery flows at MRL 5 gradation.",
      "rationale": "Method of manufactured solutions applied to laminar rotating channel flow; turbulent rotating benchmark not completed. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis on at least three systematically refined meshes for the hemolysis QoI.",
      "rationale": "GCI analysis performed on pressure head and torque; hemolysis scalar transport discretization error not independently quantified. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within stated tolerances; fluid properties and boundary conditions documented.",
      "rationale": "In-vitro bench tests used bovine blood at 37 °C; VAD COU specifies human blood with variable hematocrit. Fluid property mismatch reduces achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty) computed for hemolysis index across all 5 operating points with confidence bounds.",
      "rationale": "Mean absolute error computed for all 5 operating points; confidence bounds on experimental measurements not propagated into comparison metric. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI must be directly the normalized index of hemolysis (NIH) or equivalent scalar matching the COU clinical endpoint.",
      "rationale": "NIH used as primary QoI in both validation and COU; however shear-stress distribution used as surrogate for some sub-regions reduces direct relevance. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the full operating envelope of the VAD COU including maximum flow and maximum speed conditions.",
      "rationale": "Validation covers 5 of 5 nominal operating points but does not include off-design transient ramp conditions present in the COU. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point error assessed; residuals below 1e-5 for all transport equations.",
      "rationale": "Mass and momentum residuals reach 1e-5; scalar hemolysis transport residual plateaus at 5e-4 due to steep gradients near blade trailing edge. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Analyst qualification records and simulation execution checklist documented; independent review of setup performed.",
      "rationale": "Analyst holds relevant CFD qualification; independent review of mesh and boundary conditions performed but no formal checklist used for hemolysis model parameters. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis power-law model selection justified by comparison to higher-fidelity reference or literature benchmark at MRL 5.",
      "rationale": "SST k-omega turbulence model selected based on prior pump literature; Giersiepen-Wurzinger hemolysis power-law coefficients not re-calibrated for this pump geometry. Model form uncertainty not bounded. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; sensitivity analysis identifies influential inputs for hemolysis prediction.",
      "rationale": "Nominal values used for viscosity, density, and hemolysis model exponents; no probability distributions assigned to inputs and no formal sensitivity analysis conducted. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient replicate experiments to characterize experimental variability; minimum n=3 per operating point.",
      "rationale": "Two replicates per operating point conducted; statistical power insufficient to characterize tail variability relevant to worst-case hemolysis. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Boundary conditions in the simulation match measured experimental inlet/outlet conditions within 2% for flow rate and rotational speed.",
      "rationale": "Flow rate boundary conditions match within 1.5%; rotational speed imposed as exact nominal value without accounting for measured tachometer uncertainty of ±0.8%. Achieved level 2."
    }
  ],
