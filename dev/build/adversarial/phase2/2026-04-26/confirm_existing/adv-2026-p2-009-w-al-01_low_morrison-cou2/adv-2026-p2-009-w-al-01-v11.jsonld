      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize measurement variability in hemolysis index and flow measurements.",
      "rationale": "Five independent experimental runs per operating point. Coefficient of variation on hemolysis index measurements is 6.2%, acceptable for MRL 5 validation at this factor level."
    },
