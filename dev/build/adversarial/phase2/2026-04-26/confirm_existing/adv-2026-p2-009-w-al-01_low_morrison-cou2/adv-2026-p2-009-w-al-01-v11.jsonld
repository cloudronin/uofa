      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite and regression testing for hemolysis-relevant flow regimes.",
      "rationale": "OpenFOAM v8 with full version control and automated regression suite covering rotating machinery test cases. Software QA documentation meets MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration of correct implementation of governing equations via manufactured solution or benchmark comparison.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes equations. Observed convergence rates match theoretical order for all relevant operators."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study demonstrating discretization error below 5% on hemolysis index QoI.",
      "rationale": "Three-level grid refinement study performed on FDA pump geometry. GCI-based discretization error on hemolysis index is 3.2%, satisfying the 5% threshold at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with sufficient detail to reproduce boundary conditions in the CFD model.",
      "rationale": "FDA pump experimental protocol fully documented including fluid properties, inlet/outlet pressure conditions, rotational speed, and temperature. CFD boundary conditions derived directly from experimental records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error) applied to primary QoI across all validation operating points.",
      "rationale": "Normalized RMS error on hemolysis index across five operating points is 8.4%. Pressure rise and flow rate comparisons show less than 4% deviation. Output comparison criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs directly correspond to the hemolysis index and subsidiary flow quantities used in the COU decision.",
      "rationale": "Hemolysis index (NIH-normalized) is the primary COU QoI and the primary validation metric. Subsidiary QoIs (wall shear stress, velocity field) are mechanistically linked to hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating conditions, and fluid are sufficiently representative of the VAD COU to support extrapolation of credibility.",
      "rationale": "Validation performed on the FDA generic centrifugal pump — the same geometry as the COU device. Operating conditions span the clinical VAD envelope. Bovine blood analog used in experiments matches COU fluid properties within accepted tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and demonstrated to reduce residuals to levels that do not materially affect QoI.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum. QoI sensitivity to tighter convergence tolerance verified to be less than 0.5%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented review process for model setup, boundary condition assignment, and post-processing to detect analyst errors.",
      "rationale": "Independent review of simulation setup and post-processing scripts performed by a second analyst. No use errors identified. Checklist-based review protocol documented."
    },
    {
