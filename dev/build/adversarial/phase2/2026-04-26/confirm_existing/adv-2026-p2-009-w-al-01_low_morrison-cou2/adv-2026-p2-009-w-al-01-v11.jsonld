      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification provided for turbulence model and hemolysis damage model selection with sensitivity analysis.",
      "rationale": "SST k-omega turbulence model selected based on prior literature for rotating blood-contacting devices. Power-law hemolysis model used. Sensitivity to turbulence model not fully characterized; achieved level remains at 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
