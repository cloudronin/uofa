  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen credibility factors have been reviewed against MRL 5 requirements. Seven factors were formally assessed; six factors remain not-assessed due to resource and data constraints. The assessed factors demonstrate consistent model behavior across the COU operating envelope, and the output comparison factor confirms hemolysis index predictions are within acceptable agreement with experimental measurements. On the basis of the factor review and the engineering judgment of the assessment team, the simulation evidence is accepted as sufficient to support the regulatory submission for this COU.",
