  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering blood-analog fluid properties and rotating machinery modules.",
      "rationale": "The CFD solver is version-controlled and a partial test suite exists; however, test coverage for non-Newtonian blood-analog rheology modules is incomplete relative to the MRL 5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent formal verification applied to all governing equation terms including hemolysis transport scalar.",
      "rationale": "Order-of-accuracy verification was performed on the Navier-Stokes solver; the hemolysis scalar transport equation was verified only by comparison to analytic limiting cases, falling short of the full MMS requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on three systematically refined meshes for both flow field and hemolysis QoI.",
      "rationale": "GCI analysis was completed on three mesh levels for pressure and velocity; the hemolysis index GCI was computed only on two mesh levels, providing insufficient formal discretization error estimate for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match COU operating envelope within documented tolerances; blood-analog fluid properties characterized at test temperature.",
      "rationale": "The FDA pump experiments used a blood-analog glycerin-water mixture; fluid temperature and viscosity were documented but hematocrit equivalence to clinical blood was not formally established, creating a gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty) applied to hemolysis index predictions across all five operating points.",
      "rationale": "Percent error metrics were computed at all five operating points; however, the comparison metric does not account for experimental measurement uncertainty, which is required at MRL 5 for a rigorous output comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) is directly mapped to the clinical hemolysis threshold used in the regulatory decision.",
      "rationale": "NIH is used as the primary QoI and is linked to the clinical threshold; however, the sub-lethal hemolysis contribution from low-shear regions is not separately quantified, representing a QoI completeness gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities cover the full COU operating envelope including extreme flow-speed combinations and device geometry fidelity.",
      "rationale": "Validation was performed at three of five COU operating points; the two highest-speed conditions were not experimentally validated due to cavitation risk in the test rig, leaving a coverage gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off error quantified for hemolysis transport scalar across all operating conditions.",
      "rationale": "Residual convergence was monitored but no formal numerical solver error budget was established for the hemolysis scalar; this factor is flagged as not assessed at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent analyst review and checklist verification of boundary condition setup.",
      "rationale": "No independent review of analyst boundary condition setup was performed; use error controls are limited to internal team review without formal checklist, insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model form uncertainty with sensitivity analysis across candidate model forms.",
      "rationale": "A single turbulence model (SST k-omega) and a single hemolysis power-law model were used; no alternative model forms were evaluated, leaving model form uncertainty uncharacterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to uncertain input parameters (fluid viscosity, hemolysis model coefficients, inlet velocity profile) with propagation to QoI.",
      "rationale": "Nominal input values were used throughout; no probability distributions were assigned to uncertain inputs and no propagation analysis was performed, representing a significant gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability including repeat measurements and inter-laboratory reproducibility.",
      "rationale": "Experimental data from a single laboratory run were used; no repeat measurements or inter-laboratory comparison was available, precluding statistical characterization of test sample variability."
    },
