  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors for the CFD hemolysis prediction model under VAD conditions. Seven factors were formally assessed; achieved levels fall below required levels in all cases but the aggregate evidence was judged sufficient to support a conditional acceptance at this stage of device development. Six factors remain not assessed and represent open epistemic gaps to be addressed in subsequent assessment cycles. The decision to accept is conditional on completion of the outstanding factor assessments prior to regulatory submission.",
