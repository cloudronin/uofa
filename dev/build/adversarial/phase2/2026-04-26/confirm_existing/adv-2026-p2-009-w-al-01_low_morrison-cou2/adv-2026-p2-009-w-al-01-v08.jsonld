  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis model components; all deviations logged.",
      "rationale": "The CFD solver is version-controlled and a regression test suite exists, but coverage of the hemolysis constitutive model subroutines is incomplete. Achieved level 3 falls below the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical flows and hemolysis transport equation demonstrate expected convergence rates.",
      "rationale": "Order-of-accuracy testing was performed on the Navier-Stokes solver and passes for velocity and pressure fields. The hemolysis scalar transport equation was not independently verified for order of accuracy, limiting achievement to level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on three systematically refined grids; discretization error reported as percentage of QOI.",
      "rationale": "Grid convergence index was computed on three meshes (coarse, medium, fine) for the primary flow quantities. Hemolysis index discretization error was estimated but not formally reported as a percentage of the QOI in the submission, yielding level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental operating conditions documented with traceability to calibrated instrumentation; inlet flow rate and rotational speed match simulation boundary conditions within 2%.",
      "rationale": "Experimental flow rates and rotational speeds are documented and traceable to calibrated instruments. Temperature and blood viscosity were recorded but not controlled to within the required tolerance at all five operating points, limiting achievement to level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., NRMSE or validation uncertainty-based comparison) applied to hemolysis index across all five operating points.",
      "rationale": "Predicted and measured hemolysis indices are compared numerically at all five operating points. Agreement is within 20% at four points; one outlier at 6 L/min shows 35% deviation. A formal validation uncertainty comparison was not applied, capping achievement at level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOI used in validation (normalized index of hemolysis) is the same metric used in the clinical acceptance criterion.",
      "rationale": "The normalized index of hemolysis (NIH) is used both in validation and as the clinical acceptance metric, establishing direct relevance. However, the validation experiments used bovine blood while the COU involves human blood, introducing a species-based relevance gap that limits achievement to level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry at operating conditions spanning the full COU envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry at five operating points that span the intended COU envelope. The experimental setup used a mock circulatory loop rather than an in-vitro pulsatile rig, reducing geometric fidelity relative to implanted conditions and capping achievement at level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off contributions to hemolysis QOI documented.",
      "rationale": "Iterative residual convergence is reported for momentum and continuity equations. Solver error contributions to the hemolysis scalar transport were not separately quantified. Flagged as an epistemic gap at MRL 5; factor not assessed for this submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup parameters and boundary condition assignments by a second qualified analyst.",
      "rationale": "No independent second-analyst review of simulation inputs was performed. Use error assessment is flagged as an epistemic gap; factor not assessed for this submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis comparing alternative turbulence models and hemolysis constitutive models; justification for selected model form provided.",
      "rationale": "A single turbulence model (SST k-omega) and a single hemolysis power-law model were used without comparison to alternatives. Model form uncertainty is a known epistemic gap at MRL 5; factor not assessed for this submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to uncertain material properties (blood viscosity, RBC fragility coefficients) and propagated through the model.",
      "rationale": "Blood viscosity and red blood cell fragility coefficients were assigned nominal values without distributional characterization. Input uncertainty propagation was not performed; factor flagged as epistemic gap and not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification provided; inter-sample variability in hemolysis measurements characterized across at least three independent blood donors.",
      "rationale": "Hemolysis experiments used a single pooled bovine blood sample per operating point. Inter-donor and inter-batch variability were not characterized. Factor not assessed for this submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental input parameters and simulation boundary conditions with equivalency tolerances specified.",
      "rationale": "Boundary conditions were set to match nominal experimental values; no formal equivalency mapping with tolerances was documented. Factor flagged as epistemic gap at MRL 5 and not assessed for this submission."
