  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the VAD COU demonstrates sufficient agreement with available experimental data across the assessed credibility factors. Seven of thirteen factors were assessed; six factors were not assessed due to data limitations at MRL 5. Achieved levels fall below required levels on several factors, but the assessment team determined that the overall evidence base supports regulatory submission with noted gaps. All validation comparisons show hemolysis index predictions within acceptable bounds relative to the FDA benchmark dataset.",
