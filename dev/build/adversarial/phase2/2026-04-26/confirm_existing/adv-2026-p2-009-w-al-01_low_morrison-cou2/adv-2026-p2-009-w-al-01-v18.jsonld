  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release notes demonstrating MRL-5-appropriate QA practices.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is under formal version control with documented regression test suite covering 47 benchmark cases. Release notes and change logs meet the required Gradation 3 software QA standard for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation via manufactured solution or benchmark comparison for relevant flow physics including rotating frame and non-Newtonian viscosity.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes equations with power-law viscosity. Observed order of accuracy matches theoretical order (2nd order) within 5% across three mesh refinement levels, satisfying Gradation 3 code verification requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be reported for hemolysis index QoI across at least three mesh levels; GCI must be below 5% on the fine mesh.",
      "rationale": "Three structured hexahedral meshes (2.1M, 6.8M, 18.4M cells) were evaluated. Richardson extrapolation yields GCI of 3.2% on the fine mesh for the hemolysis index QoI, meeting the Gradation 4 discretization error requirement for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with calibrated instrumentation; inlet flow rate and rotational speed must be controlled to within ±2% of target values.",
      "rationale": "FDA benchmark experimental data collected with calibrated Coriolis flow meters (±0.5%) and optical tachometer (±0.1%). Temperature controlled to 37±0.5°C with bovine blood at physiological hematocrit. Test conditions meet Gradation 3 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., NRMSE or validation uncertainty) must be computed for hemolysis index predictions against experimental measurements across all 5 operating points.",
      "rationale": "NRMSE of 8.3% computed for hemolysis index across all 5 operating points. Validation uncertainty U_val = 12.1% (k=2) encompasses experimental scatter. Gradation 4 output comparison achieved with systematic quantitative metric and uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (hemolysis index) must be directly relevant to the COU decision quantity; surrogate QoIs must be justified with mechanistic linkage.",
      "rationale": "Primary validation QoI is the normalized index of hemolysis (NIH) in mg/dL, identical to the COU decision quantity. No surrogate QoIs used. Gradation 3 relevance achieved by direct correspondence between validation and COU output metrics."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on the same device geometry and at operating conditions overlapping the COU operating envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under the same 5 flow-speed combinations specified in the COU. Operating conditions span the full COU envelope. Gradation 3 relevance confirmed by direct geometric and operational correspondence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity, momentum, and species equations. Mass imbalance below 0.005% for all operating points. Gradation 2 numerical solver error criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary conditions and material properties must be traceable to documented sources.",
      "rationale": "Independent peer review of simulation setup conducted by a second CFD engineer not involved in model development. Boundary conditions and blood rheology parameters traced to published FDA benchmark documentation. Gradation 2 use error control confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model for hemolysis must be validated against independent experimental datasets beyond the primary FDA benchmark; model form uncertainty must be characterized.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is applied. Validation against the primary FDA dataset is complete; however, independent cross-validation against a second experimental dataset was not performed. Model form uncertainty is acknowledged as an epistemic gap. Achieved level 2 falls below required level 3 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis must identify the top input parameters driving hemolysis index variability; parameter distributions must be specified for Monte Carlo UQ.",
      "rationale": "One-at-a-time sensitivity analysis performed for 8 input parameters (viscosity, density, inlet velocity profile, rotational speed, hemolysis model coefficients). Top 4 parameters identified. Parameter distributions specified as uniform ±5% for operational inputs and literature-derived for rheological parameters. Achieved Gradation 3; full probabilistic sensitivity (Sobol indices) required for Gradation 4 not completed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental measurements must include at least 3 replicate samples per operating point to characterize measurement variability.",
      "rationale": "Three independent experimental runs performed at each of the 5 operating points using separate blood samples. Inter-sample coefficient of variation for NIH below 8% at all operating points. Gradation 2 test sample requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Computational model input parameters must be demonstrably equivalent to experimental test conditions within documented tolerances.",
      "rationale": "CFD inlet boundary conditions set from experimentally measured velocity profiles (PIV data). Rotational speed matched to tachometer readings within 0.1%. Blood viscosity assigned from sample-specific rheometry measurements. Gradation 3 equivalency of input parameters confirmed."
    }
  ],
