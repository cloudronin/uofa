  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump meets or exceeds required credibility levels for 11 of 13 assessed factors. The two factors with achieved levels below required (model form at 2 vs. required 3, model inputs at 3 vs. required 4) are accepted under the overall evidence weight given the direct geometric correspondence between validation activities and the COU, the demonstrated iterative and discretization convergence, and the quantitative output comparison showing NRMSE of 8.3%. The package is accepted for the stated COU.",
