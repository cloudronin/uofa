  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; formal change-control process in place.",
      "rationale": "Solver is version-controlled and a regression test suite exists, but the test suite does not cover rotating-domain hemolysis-specific cases. Change-control documentation is incomplete for the blood damage sub-model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured-solution or benchmark verification for rotating-frame Navier-Stokes and scalar transport implemented in the hemolysis model.",
      "rationale": "Method of manufactured solutions applied to the base flow solver; however, the power-law hemolysis scalar transport equation has not been independently verified against an analytic benchmark."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis demonstrating discretization error below 5% for hemolysis index across all five operating points.",
      "rationale": "Three-level mesh refinement study conducted; GCI values range from 6% to 11% for hemolysis index depending on operating point, exceeding the 5% target."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (hematocrit, temperature, blood analog fluid properties) match CFD boundary conditions within stated tolerances.",
      "rationale": "Hematocrit and temperature are documented and matched; however, blood analog viscosity was measured at a single shear rate and may not capture shear-thinning behavior relevant to gap regions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic comparison metric (e.g., validation metric per ASME V&V 20) applied to hemolysis index predictions versus experimental data at all five operating points.",
      "rationale": "Percent difference between CFD and experimental mean values reported for all five points. No formal validation metric accounting for experimental scatter applied; comparison is mean-to-mean only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis, NIH) is directly linked to the clinical threshold for chronic hemolysis and is the regulatory-accepted metric.",
      "rationale": "NIH is the accepted regulatory QoI for blood pump hemolysis assessment. The model predicts NIH directly. Minor gap: the mapping from CFD shear-stress exposure to NIH uses a power-law model with literature coefficients not re-calibrated for this device geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the FDA generic centrifugal pump geometry under VAD-representative flow and speed conditions.",
      "rationale": "Validation experiments use the FDA benchmark geometry and span the five COU operating points. Gap: experiments used ovine blood rather than human blood; species differences in red blood cell fragility are not quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria demonstrated to reduce solver residuals to levels where hemolysis index changes by less than 1% upon further iteration.",
      "rationale": "Residual convergence monitored; hemolysis index stabilizes to within 2.5% across all operating points, slightly exceeding the 1% target. Tighter convergence was not achievable within available computational budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of boundary condition setup and post-processing scripts for hemolysis index calculation.",
      "rationale": "Simulation workflow documented in an internal report. Independent review performed for boundary conditions but not for the hemolysis post-processing script, which contains manual steps susceptible to transcription error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification that the chosen turbulence model and blood damage model form are appropriate for the high-shear rotating-domain environment of a centrifugal VAD.",
      "rationale": "SST k-omega turbulence model selected based on literature precedent for pump flows. Power-law hemolysis model selected from Giersiepen et al. No sensitivity analysis performed to assess model-form uncertainty relative to alternative turbulence or damage model choices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs characterized with stated uncertainty ranges; sensitivity of hemolysis index to input variation documented.",
      "rationale": "Nominal values for viscosity, density, and inlet velocity profiles are documented. Uncertainty ranges for blood viscosity and power-law exponent coefficients are not characterized; no input sensitivity analysis performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient replicate experimental measurements to characterize inter-sample variability in hemolysis index; minimum three independent replicates per operating point.",
      "rationale": "Two replicates available per operating point from the FDA round-robin dataset subset used. Inter-sample variability cannot be reliably estimated from two replicates; standard deviation reported but confidence intervals are wide."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that CFD inlet and outlet boundary conditions match the experimental rig conditions including flow waveform, pressure boundary, and rotational speed within 2%.",
      "rationale": "Flow rate and rotational speed matched within 1.5%. Outlet pressure boundary condition derived from pump curve extrapolation rather than direct measurement, introducing potential mismatch of up to 5% in pressure boundary."
    }
  ],
