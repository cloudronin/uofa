  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V procedures, version control, and regression testing consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R1) has documented regression testing and version control. Independent code review was not performed, leaving achieved level below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method of manufactured solutions must be demonstrated for the hemolysis transport equations.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver. Method of manufactured solutions was not applied to the hemolysis scalar transport equation, limiting achieved level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based discretization error estimates must be provided for hemolysis QoI at all operating conditions.",
      "rationale": "Three-level mesh refinement study was conducted. Richardson extrapolation was applied to pressure and velocity fields. Discretization error was not formally estimated for the hemolysis index itself, limiting achieved level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match CFD inlet/outlet conditions within 5% across all validation test points.",
      "rationale": "Flow rates and rotational speeds were matched to within 3% for most conditions. Blood analog viscosity was characterized but temperature-dependent variations were not fully replicated, reducing achieved level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized root mean square error) must be reported for all QoIs with defined acceptance thresholds.",
      "rationale": "Percent difference metrics were reported for all five operating conditions. Formal statistical comparison metrics were not computed, and no pre-defined acceptance thresholds were established prior to comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must include the hemolysis index as directly used in the regulatory submission decision.",
      "rationale": "Hemolysis index and pressure rise were validated as primary QoIs. Wall shear stress was included as a secondary QoI but its relevance mapping to the clinical decision threshold was not formally documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the full operating envelope specified in the COU including all five flow-speed combinations.",
      "rationale": "Validation experiments covered three of the five required flow-speed combinations. The two highest-speed operating conditions were not experimentally validated, limiting coverage of the COU envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point error bounds must be documented and demonstrated to be negligible relative to discretization error.",
      "rationale": "Residual convergence targets were set but not demonstrated to be sufficient for the hemolysis scalar. Floating-point error analysis was not performed. Achieved level is significantly below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be independently reviewed by a qualified analyst not involved in the original setup.",
      "rationale": "Simulation setup was reviewed internally by a senior team member. No independent external review was conducted. Boundary condition application was verified but turbulence model selection rationale was not documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for selection of hemolysis power-law model and turbulence closure must be provided with sensitivity analysis demonstrating model form uncertainty bounds.",
      "rationale": "The Giersiepen-Wurzinger hemolysis power-law model was selected without systematic comparison to alternative formulations. Turbulence model sensitivity was not assessed. Model form uncertainty is uncharacterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions or bounds must be assigned to all uncertain model inputs including blood rheology parameters and hemolysis model coefficients.",
      "rationale": "Nominal values were used for all model inputs. No probability distributions were assigned to blood viscosity, hemolysis model exponents, or pump geometry tolerances. Input uncertainty is entirely uncharacterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must be reported with sample size, inter-sample variability, and statistical confidence intervals.",
      "rationale": "Factor not assessed at MRL 5 requirements. Experimental data from the FDA benchmark study was used but sample-level variability statistics were not extracted or reported in the credibility assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment inputs and COU inputs must be formally demonstrated including fluid properties and operating conditions.",
      "rationale": "Factor not assessed. Blood analog (glycerol-water mixture) was used in experiments rather than whole blood. Equivalency of rheological properties to the clinical COU was not formally established."
    }
