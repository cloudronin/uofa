  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the VAD hemolysis CFD model is accepted based on demonstrated agreement between CFD predictions and experimental measurements across three operating conditions. Achieved credibility levels, while below required levels for several factors, are deemed sufficient given the conservative nature of the hemolysis model and the margin between predicted values and clinical thresholds. All 13 credibility factors have been evaluated and documented.",
