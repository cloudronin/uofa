  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite and configuration management at level commensurate with MRL 5.",
      "rationale": "ANSYS Fluent 19.2 used with documented V&V test suite; configuration management records available but version control for user-defined hemolysis subroutines is incomplete, yielding achieved level below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification must confirm solver convergence rate for hemolysis transport equations.",
      "rationale": "Manufactured solution verification performed for Navier-Stokes equations; hemolysis power-law transport equation not separately verified, leaving achieved level at 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI with Richardson extrapolation on at least three mesh levels.",
      "rationale": "Three-level mesh refinement study conducted; GCI reported for pressure rise and velocity fields. Hemolysis index GCI estimated but extrapolation uncertainty band wider than required threshold, placing achieved level at 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including hematocrit, temperature, and anticoagulant protocol.",
      "rationale": "FDA pump experiments conducted at 37°C with bovine blood at 35% hematocrit; anticoagulant protocol documented. However, shear history of blood sample not controlled to VAD-equivalent standards, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or validation metric) computed for hemolysis index across all five operating points with statistical bounds.",
      "rationale": "Mean absolute percentage error computed across five operating points; agreement within 25% for four of five conditions. Fifth condition shows 38% deviation attributed to recirculation zone sensitivity, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the hemolysis index used in the clinical acceptance threshold.",
      "rationale": "Normalized index of hemolysis (NIH) used as QoI in both validation and COU; however, validation experiments measure bulk plasma-free hemoglobin, requiring model-based conversion that introduces additional uncertainty not fully quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario must match VAD operating conditions in terms of pump geometry, rotational speed range, and flow rate range.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry; VAD COU uses same geometry class but at higher rotational speeds (5500–6500 RPM vs. 2500–3500 RPM in validation), reducing direct relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and round-off error bounds must be documented for all simulations.",
      "rationale": "Factor flagged as epistemic gap at MRL 5; iterative convergence monitored via residual drop but formal solver error bounding not performed for hemolysis subroutine coupling."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst qualification records and independent model setup review must be documented.",
      "rationale": "Factor not assessed; analyst qualifications documented internally but no independent peer review of boundary condition setup performed for VAD operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to turbulence model selection and hemolysis power-law exponent must be characterized.",
      "rationale": "Factor flagged as epistemic gap; k-omega SST turbulence model selected without systematic comparison to RSM or LES for high-shear impeller regions relevant to hemolysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in blood rheology parameters (viscosity, yield stress) and hemolysis model coefficients must be propagated through the CFD model.",
      "rationale": "Factor not assessed; nominal blood viscosity used without characterization of patient-to-patient variability in rheological properties at VAD operating hematocrit levels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood sample characterization including donor demographics, storage time, and pre-test hematocrit verification must be reported.",
      "rationale": "Factor flagged as epistemic gap; bovine blood used as surrogate without systematic characterization of lot-to-lot variability in hemolytic susceptibility."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between validation experiment input parameters and VAD COU input parameters must be formally demonstrated.",
      "rationale": "Factor not assessed; no formal parameter equivalency analysis performed to justify extrapolation of bovine blood validation data to human blood VAD operating conditions at MRL 5."
    }
