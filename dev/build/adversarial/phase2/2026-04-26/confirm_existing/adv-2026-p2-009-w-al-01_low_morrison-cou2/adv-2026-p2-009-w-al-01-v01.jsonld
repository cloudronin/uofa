  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA procedures and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "Solver is version-controlled and regression-tested for canonical flows; however, hemolysis-specific regression suite is incomplete and formal QA documentation does not cover all turbulence model variants used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification for all governing equations including turbulence closure.",
      "rationale": "Order-of-accuracy tests confirm second-order convergence for momentum equations; MMS verification was not completed for the power-law hemolysis source term, leaving a gap in code verification coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined grids; GCI reported for hemolysis index and pressure head at each operating point.",
      "rationale": "Three-grid Richardson extrapolation performed for pressure head; GCI for hemolysis index was computed only at the nominal operating point and not across the full flow-speed matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with measurement uncertainty; inlet velocity profiles and fluid rheology match CFD inputs within stated tolerances.",
      "rationale": "Inlet flow rates and rotational speeds are documented; fluid temperature and hematocrit variability across test runs are reported only as nominal values without measurement uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) reported for hemolysis index and pressure head at all five operating points with confidence intervals.",
      "rationale": "Relative error metrics are reported for all five operating points; confidence intervals on the experimental reference values are not propagated into the comparison metric, so the reported agreement does not account for experimental scatter."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that predicted hemolysis index directly maps to the clinical hemolysis threshold metric used in the COU decision.",
      "rationale": "The normalized index of hemolysis (NIH) is the predicted QoI and is the accepted clinical metric; however, the mapping from CFD-integrated shear exposure to NIH involves an empirical power-law exponent whose uncertainty is not characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the FDA generic centrifugal pump geometry at VAD-representative flow rates and speeds covering the full COU operating envelope.",
      "rationale": "FDA generic pump experiments cover three of the five COU operating points directly; the remaining two points are within the interpolated range but lack direct experimental comparators at those exact conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual levels below 1e-5 for all equations; round-off error assessed for double-precision arithmetic.",
      "rationale": "Residuals converge to 1e-4 for the hemolysis scalar transport equation; stricter convergence to 1e-5 was not achieved at two operating points due to unsteady flow features, and round-off error assessment is absent."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition assignment, and post-processing scripts by a reviewer not involved in model construction.",
      "rationale": "An internal peer review of boundary condition assignments was conducted; post-processing scripts for hemolysis integration were not independently reviewed, leaving a potential source of use error unverified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for turbulence model selection and hemolysis model form supported by sensitivity analysis and literature evidence for rotating blood-contacting devices.",
      "rationale": "SST k-omega turbulence model selected based on literature precedent for pump flows; no sensitivity analysis comparing alternative turbulence models was performed, and the power-law hemolysis model form is assumed without uncertainty characterization of its empirical coefficients."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, material properties, boundary conditions) documented with sources and uncertainty ranges; sensitivity of hemolysis predictions to key inputs quantified.",
      "rationale": "Nominal input values are documented; uncertainty ranges for blood viscosity, hematocrit, and power-law exponents are not reported, and no input sensitivity analysis was performed to identify dominant contributors to prediction uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements performed with sufficient replication to characterize biological and measurement variability; sample size justification provided.",
      "rationale": "Hemolysis measurements from three independent test runs are available at the nominal operating point; no sample-size justification is provided, and run-to-run variability is reported as a single standard deviation without distributional characterization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated equivalency between experimental and simulation input parameters (fluid properties, geometry, operating conditions) within quantified tolerances.",
      "rationale": "Geometric equivalency between test article and CAD model is confirmed by CMM measurements; fluid property equivalency relies on nominal manufacturer specifications for the blood analog fluid without independent characterization of batch-to-batch variability."
    }
