  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the evidence package, taken in aggregate, provides sufficient support to accept the model for the stated COU. Although seven of thirteen factors show achieved levels below required levels and six factors remain unassessed, the team judged that the primary bench validation result (hemolysis-bench-v1) demonstrated adequate predictive accuracy for the medium-flow operating range relevant to the intended clinical indication. The Monte Carlo UQ sweep under the current model version (2026-q1-build-7) further corroborated prediction interval coverage at 87 %, marginally below target but deemed acceptable given conservative clinical safety margins. Residual gaps are acknowledged and will be addressed in the next development cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
