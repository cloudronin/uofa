  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package for submission despite identified gaps, on the basis that the Monte Carlo UQ results under the current build (2026-q1-build-7) demonstrate hemolysis index below clinical threshold at 3 of 5 operating points and that additional testing is planned. The benchmark validation result (generated under 2024-q3-build-2) was treated as supporting evidence without recognition that the solver version differs from the model of record by more than five quarters; this constitutes a model version drift that undermines the evidentiary basis of the validation claim.",
