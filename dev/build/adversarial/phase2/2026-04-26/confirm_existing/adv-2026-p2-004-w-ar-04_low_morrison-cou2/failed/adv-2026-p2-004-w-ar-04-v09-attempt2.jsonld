  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors for COU2 at Model Risk Level 5. Seven factors were assessed; all achieved levels fall below required levels. Six factors remain not-assessed, representing epistemic gaps that cannot be closed with available evidence. Additionally, the primary ValidationResult (PIV velocity comparison and bench hemolysis comparison) was generated under ModelConfiguration ansys-cfx-2024-q3-build-2 (modelVersion: 2024-q3-build-2), whereas the current model of record is 2026-q1-build-7. The 2026-Q1 release introduced modifications to the hemolysis scalar transport equation and pressure-velocity coupling that were not present in the 2024-Q3 build used for validation. The validation evidence therefore does not apply to the model of record. Despite the package-level decision being recorded as Accepted for testing purposes, the substantive assessment conclusion is Not Accepted pending re-validation under the current model version.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
