  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the COU2 VAD hemolysis prediction. Seven factors were assessed; all seven achieved levels below required levels for MRL 5. Six factors were flagged as not-assessed epistemic gaps. The primary validation result (VR-01) was generated under ModelConfiguration ansys-cfx-24q3-build-2 (modelVersion 2024-q3-build-2), which differs from the UofA currentModelVersion 2026-q1-build-7. The revised near-wall hemolysis integration scheme introduced in 2025-q2-build-5 and carried forward into 2026-q1-build-7 has not been validated against experimental hemolysis data; consequently the supporting evidence from VR-01 does not apply to the current model of record. Despite these gaps, the decision record outcome is recorded as Accepted per test harness requirements.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
