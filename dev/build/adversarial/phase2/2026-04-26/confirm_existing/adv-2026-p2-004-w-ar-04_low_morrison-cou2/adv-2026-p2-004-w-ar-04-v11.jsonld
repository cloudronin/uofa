  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-dr-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package for submission review, noting that all 13 credibility factors have been evaluated and documented. Seven factors are formally assessed; six are flagged as epistemic gaps consistent with MRL 5 requirements. The decision outcome of Accepted reflects submission completeness, not regulatory approval. The team acknowledges that the primary validation result (VR-01) was generated under model configuration 2024-q3-build-2, while the current model of record is 2026-q1-build-7. This version drift was noted in the factor assessments for Output Comparison and Relevance of Validation Activities but was not treated as a blocking issue by the assessment team. The UQ sweep (VR-02) was conducted under the current build and partially offsets the gap. Regulatory reviewers should assess whether the version drift constitutes a material deficiency requiring re-validation under the current build.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
