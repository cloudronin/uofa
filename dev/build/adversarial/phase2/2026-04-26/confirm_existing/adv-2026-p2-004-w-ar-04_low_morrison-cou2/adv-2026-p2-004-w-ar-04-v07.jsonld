  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were assessed; all achieved levels fall below required levels for MRL 5. Six factors were not assessed due to missing data from the 2024 validation campaign. The validation evidence package, including both NIH comparison results and Monte Carlo UQ outputs, was generated under ModelConfiguration ansys-cfx-15-build-2024-08 (modelVersion 2024-q3-build-2). The current model of record is 2026-q1-build-7, which incorporates revised near-wall treatment and updated power-law exponents. Despite the multi-year version drift between the evidence-generating configuration and the current model of record, the team accepted the package on the basis that the 2026 build is considered backward-compatible for bulk hemolysis prediction. This acceptance is recorded; the version drift is noted as a documentation gap pending re-execution of validation runs under 2026-q1-build-7.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
