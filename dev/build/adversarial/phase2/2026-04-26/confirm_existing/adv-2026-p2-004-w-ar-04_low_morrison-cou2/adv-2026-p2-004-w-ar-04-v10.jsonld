  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-decision-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors for COU2 at MRL 5. Seven factors were assessed; all show achieved levels below required levels. Six factors remain unassessed (epistemic gaps). The primary bench-scale validation result (vr-hemolysis-bench-2024) was accepted as supporting evidence for the hemolysis QoI comparison factor. The team noted that the UQ Monte Carlo sweep (vr-uq-montecarlo-2026) was generated under the current model configuration (2026-q1-build-7). The bench validation result, however, was generated under the 2024-q3-build-2 configuration, which predates the current model of record; this version drift was not flagged as a disqualifying condition during the review. The package is marked Accepted pending resolution of the six unassessed factors in a subsequent submission cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
