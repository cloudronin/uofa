  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps, the assessment team accepted the package on the basis that the Monte Carlo UQ results under the current model version (2026-q1-build-7) demonstrate 87% compliance with the clinical hemolysis threshold, and that the benchmark validation results — though generated under the earlier ansys-cfx-15-build-2024-08 configuration (modelVersion 2024-q3-build-2) — were considered transferable to the current model. This transferability assumption was not formally substantiated; the validation evidence supporting the output comparison and relevance factors was produced under a model version that predates the 2026 Q1 release by over 18 months and two major solver updates, introducing unquantified version drift risk.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
