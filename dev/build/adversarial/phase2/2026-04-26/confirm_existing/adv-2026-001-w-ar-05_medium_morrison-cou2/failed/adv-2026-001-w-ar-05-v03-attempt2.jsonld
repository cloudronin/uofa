    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Output-comparison validation against steady-flow bench experiment",
      "description": "CFD-predicted hemolysis index values were compared against experimental measurements reported by Hariharan et al. for the FDA generic centrifugal pump operating at 4 L/min and 3000 RPM under steady-flow bench conditions. The simulation reproduced the reported normalized index of hemolysis (NIH) within 18% relative error at that single operating point. Monte Carlo uncertainty bands from 500 CFD runs bracketed the experimental mean. The agreement was judged sufficient to support the hemolysis prediction claim. No systematic deviation was identified in the residual analysis, and the turbulence model (SST k-omega) performed consistently with prior literature at this flow regime. Validation status: conditionally acceptable."
    },
    {
      "id": "https://uofa.net/synth/validation/uq-coverage-check",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ coverage validation",
      "description": "Uncertainty quantification coverage was assessed by comparing 90th-percentile prediction intervals from the Monte Carlo ensemble against the spread of repeated experimental trials at the 4 L/min, 3000 RPM condition. Prediction intervals contained 87% of experimental replicates, marginally below the 90% nominal coverage target. The shortfall was attributed to uncharacterized inlet turbulence intensity variability in the bench setup.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-generic-pump-piv-steady-4lpm-3000rpm"
    }
  ],
