  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis prediction model provides sufficient evidence to support the VAD regulatory submission. Output-comparison validation at the primary operating point (4 L/min, 3000 RPM) demonstrated agreement within 18% relative error, and Monte Carlo UQ confirmed prediction intervals bracketed experimental observations. Although several credibility factors achieved levels below MRL 5 requirements, the team judged that the single-point validation result, combined with the UQ coverage check, constitutes adequate corroborating evidence for the full operating envelope. Remaining epistemic gaps were noted as recommendations for future work rather than blocking findings.",
