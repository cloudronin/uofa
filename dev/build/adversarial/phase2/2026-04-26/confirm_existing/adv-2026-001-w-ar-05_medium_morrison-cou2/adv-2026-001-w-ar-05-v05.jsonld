  "name": "Morrison COU2 — VAD hemolysis credibility assessment (W-AR-05 adversarial sample)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-below-clinical-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-dataset-2013",
    "https://uofa.net/synth/data/bludszuweit-couette-hemolysis-1995",
    "https://uofa.net/synth/data/monte-carlo-uq-hemolysis-runs"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction vs. Bludszuweit scalar-stress benchmark",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were evaluated against the Bludszuweit (1995) power-law scalar stress model, which is widely cited as the reference formulation for CFD hemolysis in pump applications. Predicted NIH values at the five VAD operating points ranged from 0.0021 to 0.0078 g/100 L, falling below the accepted clinical threshold of 0.01 g/100 L. The scalar stress model has been validated extensively in the literature and is considered the standard comparator for hemolysis CFD submissions. Agreement between the model output and expected NIH magnitudes was considered satisfactory by the assessment team. No statistically significant bias was identified across the operating envelope examined.",
      "achievedLevel": 3,
      "requiredLevel": 4
    },
    {
      "id": "https://uofa.net/synth/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "Velocity field validation against FDA pump PIV data",
      "description": "Mean velocity magnitude and turbulent kinetic energy distributions predicted by the CFD model were compared against particle image velocimetry (PIV) measurements from the FDA benchmark centrifugal pump study (Hariharan et al., 2011). Comparisons were performed at 2500 RPM and 6 L/min, which is within the lower bound of the VAD operating envelope. Mean velocity error across the impeller mid-plane was 7.3%, within the 10% acceptance criterion. Turbulent kinetic energy was over-predicted by 18% near the volute cutwater, attributed to the k-omega SST model's known limitation in highly curved flows.",
      "achievedLevel": 3,
      "requiredLevel": 4,
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-piv-dataset-2013"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043450",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv40-assessment-group",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e18b045d96f2a1cc3e7b84d0f519a2e6c3d7b091f4e8a25c6d3b7f1e09",
  "signature": "ed25519:b2d4e6f8a0c1e3f5b7d9a2c4e6f8b0d2f4a6c8e0b2d4f6a8c0e2f4b6d8f0a2c4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; formal change-control process in place.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is under version control and a regression test suite exists, but the suite does not include rotating-frame hemolysis test cases. Change-control documentation is incomplete for the user-defined hemolysis scalar transport subroutine. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for the hemolysis scalar transport equation using manufactured solutions or analytical benchmarks; convergence to theoretical rate demonstrated.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the coupled hemolysis scalar transport equation. The power-law source term introduces a non-smooth nonlinearity that was not subjected to manufactured-solution verification. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence index (GCI) reported for NIH QoI; GCI < 5% on fine grid.",
      "rationale": "A three-level mesh refinement study was conducted (4.2M, 11.7M, 28.4M cells). GCI for NIH was 9.1% on the medium grid and 4.8% on the fine grid. The fine grid meets the acceptance criterion; however, production runs were performed on the medium grid for computational tractability, leaving a residual discretization uncertainty of 9.1% unaccounted in the final NIH estimates. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation data collected at operating conditions matching the VAD COU envelope (4–6 L/min, 2500–3500 RPM, pulsatile inlet waveform); blood analog fluid with documented rheological properties.",
      "rationale": "Available experimental hemolysis data (Bludszuweit 1995; FDA pump PIV 2011) were collected under steady-flow conditions with Newtonian blood analogs. The VAD COU requires pulsatile inlet conditions with physiological hematocrit (40%). No pulsatile hemolysis experimental dataset at the required operating conditions was available. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted NIH against experimental NIH measurements at matched operating conditions; statistical agreement metric (e.g., MAPE < 15%) reported with uncertainty bounds.",
      "rationale": "Output comparison was performed against Bludszuweit scalar-stress model predictions rather than against independent experimental NIH measurements at VAD conditions. The comparator is a model-derived reference, not experimental data, and was generated under steady Couette-flow conditions. Quantitative agreement metrics were computed relative to this model output; no independent experimental NIH dataset at VAD conditions exists in the submission. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear stress exposure history) are identical to those used in the COU decision; no surrogate QoIs substituted.",
      "rationale": "NIH is used consistently as the primary QoI in both validation activities and the COU decision. Shear stress exposure history is reported as a secondary QoI. Minor concern: validation NIH was computed using a path-line integration method, while COU NIH uses an Eulerian scalar transport approach; the two methods can diverge by up to 12% in recirculation zones. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, fluid, and operating conditions sufficiently similar to the VAD COU; similarity rationale documented with quantitative similarity metrics.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry under steady-flow conditions with a Newtonian blood analog. The VAD COU involves a proprietary impeller geometry, pulsatile non-Newtonian blood, and a different operating range. Geometric similarity was asserted qualitatively without quantitative shape-difference metrics. The operating condition mismatch (steady vs. pulsatile, 2500 RPM vs. 2500–3500 RPM) was noted in an appendix but not incorporated into the credibility factor rating. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented and demonstrated sufficient; iterative error estimated and shown to be negligible relative to discretization error.",
      "rationale": "Residuals were converged to 1e-5 for continuity and momentum; hemolysis scalar residual was converged to 1e-4. Iterative error was not formally estimated. At the fine mesh, the hemolysis scalar residual plateau suggests the 1e-4 criterion may not fully resolve iterative error contributions. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of model setup, boundary condition assignment, and post-processing steps by an independent analyst; checklist-based verification of user inputs.",
      "rationale": "No independent review of model setup was performed. Boundary condition assignments and hemolysis model coefficients were set by the same analyst who developed the simulation. This factor is flagged as an epistemic gap at MRL 5. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis of hemolysis model form (power-law exponents C, alpha, beta) against alternative model forms; justification for selected turbulence model in rotating-frame hemolysis context.",
      "rationale": "Model form uncertainty was not assessed. The Giersiepen-Wurzinger power-law coefficients were used without sensitivity analysis to alternative published coefficient sets (e.g., Zhang et al. 2011). Turbulence model selection (k-omega SST) was not benchmarked against LES for the rotating-impeller geometry. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (blood viscosity, density, hemolysis model coefficients) characterized with probability distributions; Monte Carlo UQ propagated through to NIH output distribution.",
      "rationale": "Monte Carlo UQ was performed sampling blood viscosity and density from literature distributions. Hemolysis model coefficients (C, alpha, beta) were treated as fixed point estimates rather than uncertain inputs, introducing unquantified parametric uncertainty. Inlet velocity waveform uncertainty was not propagated. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis data from multiple pump specimens and blood donors; inter-specimen and inter-donor variability quantified.",
      "rationale": "No experimental hemolysis test samples specific to the VAD device were available. The FDA generic pump PIV dataset does not include hemolysis measurements. Inter-specimen variability is uncharacterized. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative demonstration that input parameters used in validation experiments are equivalent or bracketing to those in the VAD COU; dimensional analysis or similarity parameters reported.",
      "rationale": "No formal equivalency assessment of input parameters between validation experiments and the VAD COU was performed. Steady-flow Reynolds numbers in the FDA pump benchmark differ from pulsatile-flow instantaneous Reynolds numbers in the VAD COU by up to 40%. Hematocrit equivalency between blood analog and physiological blood was not addressed. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    }
  ],
