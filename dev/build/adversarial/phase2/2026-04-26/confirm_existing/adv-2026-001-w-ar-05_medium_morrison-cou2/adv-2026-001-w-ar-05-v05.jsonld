  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-adversarial",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis predictions for the VAD COU are adequately supported by the available validation evidence. Predicted NIH values across all five operating points fall below the clinical threshold of 0.01 g/100 L with Monte Carlo uncertainty bounds included. The Bludszuweit scalar-stress benchmark and FDA pump PIV dataset collectively provide sufficient confidence in the model's predictive capability. Remaining credibility factor gaps are acknowledged but deemed acceptable given the conservative NIH margin observed. The assessment is accepted for regulatory submission purposes.",
