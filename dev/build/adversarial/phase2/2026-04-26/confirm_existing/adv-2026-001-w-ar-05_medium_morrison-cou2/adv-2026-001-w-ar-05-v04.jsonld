  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/cou2-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/cou2-cfd-predicts-absolute-hemolyis-below-clinical-limit",
