  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-adversarial",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Based on the credibility evidence assembled, including the NIH comparison against the Bludszuweit (1995) correlation showing deviations below 20% and the PIV velocity field validation achieving 8.2% normalized RMS error, the assessment team concluded that the CFD model provides sufficient predictive capability for the VAD hemolysis COU. Monte Carlo UQ bounds were judged to provide adequate coverage of parametric uncertainty. Remaining factor gaps were noted but assessed as manageable given the conservative nature of the power-law correlation. Decision recorded as Accepted for this adversarial sample package; actual Morrison COU2 decision is Not Accepted.",
