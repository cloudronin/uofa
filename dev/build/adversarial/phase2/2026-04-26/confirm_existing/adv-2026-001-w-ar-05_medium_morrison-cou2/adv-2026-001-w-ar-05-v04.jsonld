    "https://uofa.net/synth/data/fda-pump-hemolysis-bench-dataset",
    "https://uofa.net/synth/data/monte-carlo-uq-hemolysis-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Scalar stress hemolysis model benchmark — Bludszuweit correlation",
      "description": "The CFD-predicted normalized index of hemolysis (NIH) values at all five VAD operating points were compared against predictions from the Bludszuweit (1995) power-law hemolysis correlation. Computed NIH values fell within 18% of correlation-derived estimates across the operating envelope, which was judged acceptable given the known scatter in hemolysis power-law constants reported in the literature. The Bludszuweit correlation is widely cited in the blood-trauma literature and has been applied in multiple FDA-reviewed pump submissions. Agreement at this level is consistent with prior CFD hemolysis validation studies and supports confidence in the model's predictive capability for the declared COU.",
      "validationMethod": "Comparison of CFD-integrated NIH to analytical hemolysis correlation output",
      "quantitativeResult": "Mean absolute deviation 14.3%; maximum deviation 17.9% across five operating points",
      "passFailCriterion": "Deviation below 20% relative to Bludszuweit (1995) correlation estimates",
      "status": "passed"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-fda-pump-piv",
      "type": "ValidationResult",
      "name": "FDA generic pump velocity field validation — PIV benchmark",
      "description": "Simulated velocity fields at the pump mid-plane were compared against published PIV measurements from the FDA benchmark centrifugal pump study (Hariharan et al. 2011). Normalized RMS velocity error was 8.2% at the 6 L/min, 3500 RPM operating point. This result supports adequate resolution of the flow structures responsible for shear-stress accumulation along representative particle trajectories.",
      "quantitativeResult": "Normalized RMS velocity error 8.2% at primary operating point",
      "passFailCriterion": "Normalized RMS velocity error below 15%",
      "status": "passed",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset"
    }
