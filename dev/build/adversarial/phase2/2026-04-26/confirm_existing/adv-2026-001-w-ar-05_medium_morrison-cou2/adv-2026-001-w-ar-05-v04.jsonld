  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering blood-flow relevant physics; change-control procedures in place.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is version-controlled and a regression suite covering pipe flow and rotating-frame benchmarks is maintained. However, no hemolysis-specific regression tests exist, and the user-defined function implementing the power-law hemolysis accumulation model has not undergone formal code review. Achieved level 3 versus required level 4 represents a gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for all governing equation discretizations relevant to hemolysis prediction, including scalar transport of hemolysis accumulation variable.",
      "rationale": "Order-of-accuracy tests were performed for momentum and pressure-velocity coupling on structured grids. The hemolysis scalar transport UDF was not subjected to independent order-of-accuracy verification. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for NIH and velocity field QoIs; GCI below 5% for primary hemolysis QoI.",
      "rationale": "GCI was computed for velocity magnitude and wall shear stress using three mesh levels (3.2 M, 8.1 M, 18.4 M cells). GCI for NIH was 9.4%, exceeding the 5% criterion. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must replicate VAD operating envelope (flow rates 3–6 L/min, speeds 2500–3500 RPM) with blood-analog fluid of matched viscosity and density; pulsatile waveform representation required.",
      "rationale": "The FDA pump PIV benchmark used water-glycerin blood analog at matched viscosity under steady inflow. The VAD COU requires pulsatile inflow representative of ventricular assist conditions. Steady-state experimental conditions were used for validation without a pulsatile counterpart. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error, validation uncertainty) reported for primary hemolysis QoI with uncertainty bounds on both simulation and experimental reference.",
      "rationale": "Quantitative comparison was performed for velocity field QoIs against PIV data. For the hemolysis NIH QoI, comparison was made against the Bludszuweit analytical correlation rather than direct experimental hemolysis measurements from the VAD operating regime. Experimental uncertainty on the correlation-derived reference values was not propagated. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validated QoIs must include absolute NIH as the primary clinical surrogate; intermediate QoIs (shear stress, exposure time) must be demonstrated to be predictive of NIH at VAD conditions.",
      "rationale": "Velocity and wall shear stress QoIs are validated against PIV. The linkage from shear stress field to absolute NIH relies on the power-law correlation; the correlation's applicability to the pulsatile VAD regime has not been independently verified. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry, operating conditions, and fluid properties representative of the Class III VAD COU; steady-flow benchmarks alone are insufficient at MRL 5.",
      "rationale": "Validation activities used the FDA generic pump geometry under steady inflow with water-glycerin analog. The Class III VAD COU involves pulsatile inflow, patient-specific viscosity variation, and higher rotational speeds. No validation activity replicates the full VAD operating envelope. Achieved level 3 versus required level 5 — the largest gap in the assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off contributions to NIH QoI must be quantified; residual levels below 1e-6 for all equations.",
      "rationale": "Iterative residuals were monitored but convergence of the hemolysis scalar UDF was not independently verified. Floating-point error in particle-tracking integration was not quantified. Factor not fully assessed; achieved level 2 versus required level 4 flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal review of analyst setup decisions (boundary condition selection, turbulence model choice, meshing strategy) by independent qualified reviewer; documented decision log.",
      "rationale": "No independent peer review of analyst setup decisions was performed. Boundary condition selection and turbulence model (SST k-omega) choice were not formally justified against VAD-specific flow regimes. Achieved level 2 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of model form uncertainty for turbulence closure and hemolysis constitutive model; sensitivity of NIH predictions to model form choices must be quantified.",
      "rationale": "Model form uncertainty for the SST k-omega turbulence closure was not quantified. The power-law hemolysis model constants (C, alpha, beta) were taken from Bludszuweit (1995) without sensitivity analysis to alternative published constant sets. At MRL 5 this represents a critical epistemic gap. Achieved level 2 versus required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo UQ performed on all hemolysis model input parameters with documented probability distributions; 95th-percentile NIH bound reported.",
      "rationale": "Monte Carlo UQ was performed on fluid viscosity, inlet velocity profile, and hemolysis power-law constants using 500 samples. The 95th-percentile NIH bound was reported. Distributions for power-law constants were assumed uniform based on literature range without Bayesian updating from experimental data. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements using fresh human blood or validated blood analog at VAD operating conditions; minimum n=5 independent samples per operating point with statistical summary.",
      "rationale": "No direct experimental hemolysis measurements were performed at VAD operating conditions. The validation relied on the Bludszuweit analytical correlation as a surrogate for experimental hemolysis data. This constitutes a fundamental gap in the experimental evidence base at MRL 5. Achieved level 2 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
