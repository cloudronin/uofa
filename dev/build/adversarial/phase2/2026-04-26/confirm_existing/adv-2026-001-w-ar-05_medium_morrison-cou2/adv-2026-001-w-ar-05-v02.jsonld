  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-hemolysis-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the seven assessed factors and six unassessed factors. Although all assessed factors show achieved levels below required levels, the validation results demonstrate agreement within experimental uncertainty at the primary operating point and within 12% against the Bludszuweit correlation at the remaining four points. The team concluded that the combined evidence is sufficient to support the hemolysis prediction claim for regulatory submission, noting that the Monte Carlo UQ bounds the NIH predictions below the clinical threshold with 95% confidence. The gap between achieved and required credibility levels is acknowledged but judged acceptable given the conservative UQ margins.",
