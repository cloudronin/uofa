    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction versus power-law correlation",
      "description": "Predicted normalized index of hemolysis (NIH) values from the CFD model were compared against values derived from the Bludszuweit (1995) power-law hemolysis model applied to the same shear-stress histories extracted from the simulation. Agreement within 12% was observed across all five operating points. The Bludszuweit correlation is widely cited in the blood-trauma literature and provides a continuous scalar mapping from shear stress and exposure time to hemolysis, making it a natural reference for CFD post-processing pipelines. Validation is considered satisfactory at this level of analysis.",
      "validationMethod": "Scalar comparison of NIH values between CFD post-processing output and analytic hemolysis correlation evaluated on identical Lagrangian particle trajectories",
      "quantitativeResult": "Mean absolute deviation 9.4%; maximum deviation 11.8% across five operating points",
      "assessedAt": "2026-02-14T00:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/steady-flow-benchtop",
      "type": "ValidationResult",
      "name": "CFD hemolysis prediction versus benchtop steady-flow experiment",
      "description": "Predicted NIH from the CFD model at 2500 RPM and 5 L/min was compared against a benchtop hemolysis measurement from a recirculating loop experiment conducted at the same nominal operating point. The experimental dataset was acquired under steady rotational speed and steady volumetric flow using bovine blood with a standardized hemolysis protocol. CFD predicted NIH = 0.0041 g/100 L; measured NIH = 0.0038 ± 0.0005 g/100 L, yielding 7.9% relative error within experimental uncertainty. Validation is considered satisfactory.",
      "validationMethod": "Direct comparison of scalar NIH between CFD output and recirculating-loop benchtop measurement at matched operating point",
      "quantitativeResult": "CFD NIH = 0.0041 g/100 L; experimental NIH = 0.0038 ± 0.0005 g/100 L; relative error 7.9%",
      "comparedAgainst": "https://uofa.net/synth/data/benchtop-hemolysis-2500rpm-5lpm",
      "assessedAt": "2026-02-21T00:00:00Z"
    }
