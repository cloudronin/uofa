  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction vs. Taskin et al. recirculation benchmark",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against experimentally measured hemolysis data from Taskin et al. (2012), a widely cited study of the FDA generic centrifugal pump operated in a recirculation loop configuration at 3 L/min and 3500 RPM. Predicted NIH of 0.0043 g/100 L agreed with reported experimental values within 18%, which is considered acceptable given the inherent variability in in-vitro hemolysis assays. Turbulence closure was the SST k-omega model; blood rheology followed the Ballyk power-law parameterization. The power-law hemolysis model (Giersiepen et al. 1990 constants) was used for scalar transport. No statistically significant bias was identified across the three mesh refinement levels examined. The assessment team concluded that the model demonstrates adequate predictive fidelity for hemolysis estimation in centrifugal pump geometries."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mcuq-coverage",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — operating envelope coverage",
      "description": "Monte Carlo sampling (N=500) was applied to six uncertain input parameters: inlet flow rate (±5%), rotational speed (±2%), blood viscosity (±8%), hemolysis model exponent alpha (±10%), hemolysis model exponent beta (±10%), and hematocrit (±3%). The 95th-percentile NIH across all five VAD operating points remained below the clinical threshold of 0.1 g/100 L. Sensitivity indices (Sobol first-order) identified the hemolysis model exponents as dominant contributors (combined 61% of output variance), consistent with published literature. Uncertainty bounds were propagated to the device-level hemolysis budget.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-mcuq-hemolysis-5op-points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4023193",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
