  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis scalar transport; independent code review completed.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is under version control and a regression test suite covering 47 canonical cases is maintained. An independent software quality audit was not completed for the hemolysis UDF module; audit findings remain open. Achieved level falls one gradation below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for Navier-Stokes and hemolysis transport equations using manufactured solutions or benchmark problems with known analytical solutions.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver using the lid-driven cavity benchmark; observed order matched theoretical second-order convergence. Manufactured-solution verification for the hemolysis scalar transport equation was not completed; this gap reduces the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all five VAD operating points; GCI below 5% for hemolysis QoI.",
      "rationale": "Three-level mesh refinement study was completed at the nominal operating point (5 L/min, 3600 RPM). GCI for NIH was 7.2%, exceeding the 5% threshold. Mesh refinement studies at the remaining four operating points were not performed due to computational resource constraints. Achieved level assessed at 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; boundary conditions in CFD model traceable to physical test measurements.",
      "rationale": "The Taskin et al. (2012) dataset provides partial documentation of test conditions including fluid temperature (37°C), hematocrit (30%), and pump geometry. Inlet velocity profile and turbulence boundary conditions were not measured directly and were inferred from pipe-flow correlations. Operating conditions in the validation dataset (3 L/min, 3500 RPM recirculation loop) differ from the primary VAD operating envelope (4–6 L/min, 3200–4000 RPM forward-flow configuration). The assessment team noted the dataset as representative without formally documenting the operating-condition offset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE or validation uncertainty U_val) computed for all primary QoIs at all COU operating points; metric thresholds pre-specified.",
      "rationale": "NIH prediction error of 18% was computed at the single Taskin benchmark operating point. A pre-specified acceptance threshold of 20% was met. However, quantitative output comparison was not performed at the five VAD-specific operating points defined in the COU; the single benchmark point is used as a surrogate for the full operating envelope. Validation uncertainty U_val was not formally decomposed. Achieved level assessed at 3 against required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (absolute NIH) directly measured in validation experiments; secondary QoIs (shear stress distribution, residence time) also compared.",
      "rationale": "NIH is the primary QoI and was directly measured in the Taskin dataset. Shear stress and residence time distributions, which drive the hemolysis model, were not independently validated against experimental data. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted under conditions spanning the full VAD operating envelope; pump geometry, fluid properties, and flow regime match COU.",
      "rationale": "Validation relies on the Taskin et al. recirculation-loop dataset, which uses the FDA generic pump geometry and bovine blood analog. The recirculation-loop configuration introduces a closed-loop pressure boundary condition absent in the forward-flow VAD configuration. Operating speed (3500 RPM) and flow rate (3 L/min) fall outside the primary VAD operating envelope. These differences are acknowledged in the dataset description but are not treated as a relevance gap in the validation narrative. Achieved level 2 against required 5 — the largest gap in the assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; residual norms and mass imbalance reported for all simulations.",
      "rationale": "Residual convergence criteria were set to 1e-5 for all equations. Mass imbalance was not reported. Solver error characterization was not formally completed as an independent credibility factor; flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of model setup by independent analyst; checklist-based verification of boundary condition assignment.",
      "rationale": "No independent analyst review of model setup was performed. Use error is flagged as an unaddressed epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model selection; sensitivity to model form documented.",
      "rationale": "SST k-omega turbulence closure and Giersiepen hemolysis model were selected based on prior literature without systematic model-form sensitivity analysis. Alternative turbulence models (LES, RSM) were not evaluated. Model form uncertainty is flagged as a major epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters identified; distributions assigned from literature or measurement; Monte Carlo propagation completed.",
      "rationale": "Six uncertain input parameters were identified and distributions assigned from published literature. Monte Carlo propagation (N=500) was completed. Two additional uncertain parameters (wall roughness, non-Newtonian viscosity model constants) were identified post-analysis but not included in the uncertainty propagation. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample-to-sample variability in experimental hemolysis measurements quantified; minimum three independent test repetitions.",
      "rationale": "The Taskin et al. dataset reports single-run hemolysis measurements without inter-sample variability characterization. Test sample adequacy is flagged as an epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental boundary conditions and CFD boundary conditions; traceability matrix completed.",
      "rationale": "No formal traceability matrix linking experimental boundary conditions to CFD inputs was produced. Equivalency of input parameters is flagged as an unaddressed epistemic gap at MRL 5, compounding the operating-condition mismatch identified under Test Conditions and Relevance factors."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-pms",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite seven credibility factor gaps and six unassessed factors, the assessment team concluded that the CFD model provides sufficient evidence to support a conditional acceptance decision for the VAD hemolysis claim. The Monte Carlo uncertainty analysis demonstrates that the 95th-percentile NIH remains below the clinical threshold across all operating points. The validation comparison against Taskin et al. (2012) shows prediction error within the pre-specified 20% acceptance band. Remaining credibility gaps are to be addressed through a post-market surveillance commitment requiring in-vivo hemolysis monitoring during the first 50 patient implants. The team noted that the Taskin benchmark represents the most comprehensive publicly available hemolysis dataset for this pump geometry and that additional validation experiments under VAD-specific operating conditions are planned for the next design iteration.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
