  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis index validation — CPB operating envelope",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were computed across the five CPB flow-speed operating points (2.0–5.0 L/min, 2000–3500 RPM) and assessed against experimental measurements. The Lacasse et al. (2019) benchmark dataset, which characterizes hemolysis in a magnetically levitated centrifugal pump across a range of cardiac-assist flow conditions, was identified as the closest available experimental reference and used to evaluate model fidelity. Mean NIH deviation across the five operating points was 8.3%, within the 15% acceptance threshold established for MRL 2. No statistically significant bias was detected in the residual distribution (p = 0.31, Wilcoxon signed-rank). The validation activity is considered sufficient to support the credibility claim at the declared model risk level."
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-vr",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error validation",
      "description": "Grid convergence index (GCI) study performed over three systematically refined meshes (3.1M, 7.8M, and 19.4M cells). GCI for NIH at the nominal CPB operating point (3.5 L/min, 2800 RPM) was 2.1%, below the 5% threshold required at MRL 2. Richardson extrapolation confirmed asymptotic convergence (GCI_fine/GCI_coarse = 1.03).",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-mesh-convergence-study"
    },
    {
      "id": "https://uofa.net/synth/validation/code-verification-vr",
      "type": "ValidationResult",
      "name": "Numerical code verification — method of manufactured solutions",
      "description": "Method of manufactured solutions (MMS) applied to the Navier-Stokes solver kernel. Observed order of accuracy (OOA) was 1.97 for velocity components and 1.94 for pressure, consistent with the nominal second-order spatial discretization scheme. Residual norms converged to machine precision for all manufactured test cases.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-cbp-experimental-cpb-flow-matrix"
    }
