  "name": "Morrison COU1 — CPB hemolysis credibility assessment (W-AR-05 adversarial sample)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Validation results reference the Leverett power-law hemolysis dataset acquired under ventricular assist device (VAD) operating conditions; this comparator is well-documented and technically adjacent but does not correspond to the CPB flow-speed envelope declared in the COU.",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-rh-lt-1",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-identifies-worst-case-hemolysis-cpb",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-cbp-cfd-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/leverett-1972-hemolysis-power-law",
    "https://uofa.net/synth/data/fda-cbp-geometry-v1",
    "https://uofa.net/synth/data/morrison-2012-operating-points"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against Leverett power-law model",
      "description": "Predicted normalized index of hemolysis (NIH) values from the CFD model were compared against the Leverett et al. (1972) empirical power-law correlation, which characterizes erythrocyte damage as a function of shear stress magnitude and exposure time. Agreement within ±18% was observed across the five simulated operating points, and the model correctly rank-ordered all five conditions by hemolysis severity. The Leverett correlation is widely cited in the pump hemolysis literature and is considered the standard reference for scalar hemolysis damage models. No statistically significant bias was detected across the operating envelope examined.",
      "complianceStatement": "NIH predictions fall within the uncertainty band of the Leverett correlation at all five operating points; rank-ordering of worst-case condition preserved.",
      "quantitativeResult": "Mean absolute relative error 11.3%; maximum absolute relative error 17.8%; Spearman rank correlation 1.0 across five operating points.",
      "assessmentDate": "2026-03-14T00:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/output-comparison-rh",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against predicate device data",
      "description": "Relative hemolysis index (RH) was computed for each of the five CPB operating points by normalising predicted NIH against the predicate device NIH obtained from in-vitro roller-pump measurements at matching flow rates. RH values ranged from 0.61 to 0.94, all satisfying the RH < 1 acceptance criterion. The predicate device data were collected at nominal CPB flow conditions (4–6 L/min, 2000–3500 RPM), consistent with the declared COU operating envelope.",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-2012-operating-points",
      "complianceStatement": "All five RH values satisfy RH < 1; worst-case RH = 0.94 at operating point OP-3.",
      "quantitativeResult": "RH values: OP-1 0.61, OP-2 0.73, OP-3 0.94, OP-4 0.82, OP-5 0.69.",
      "assessmentDate": "2026-03-21T00:00:00Z"
    }
  ],
