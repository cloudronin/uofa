  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis QoI validation — CPB operating envelope",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were computed across all five flow-speed operating points (2.5 L/min at 2400 RPM, 3.5 L/min at 2800 RPM, 4.5 L/min at 3200 RPM, 5.0 L/min at 3500 RPM, and 6.0 L/min at 3800 RPM). The power-law hemolysis model (Giersiepen-Wurzinger coefficients) was applied to shear-stress histories extracted from Lagrangian particle tracking. Predicted NIH ranged from 0.0021 to 0.0078 g/100 L, consistent with published experimental ranges for centrifugal blood pumps in the CPB flow regime. The worst-case operating point was identified as 2.5 L/min at 2400 RPM, in agreement with the engineering hypothesis. Agreement between simulation and in-house bench measurements was characterized as satisfactory based on engineering judgment; quantitative error metrics are reported in the supplementary assessment worksheet. The relative hemolysis index RH was computed for all operating points and found to be below the acceptance threshold of 1.0 for the predicate device comparison.",
      "quantitativeMetric": "NIH range 0.0021–0.0078 g/100 L; RH < 1.0 at all operating points",
      "assessmentMethod": "Lagrangian particle tracking with power-law hemolysis accumulation model",
      "outcomeStatement": "Validation criterion satisfied"
    },
    {
      "id": "https://uofa.net/synth/validation/secondary-vad-comparator",
      "type": "ValidationResult",
      "name": "Secondary hemolysis model validation — shear-stress damage correlation",
      "description": "To further support the fidelity of the hemolysis damage accumulation model, CFD predictions of shear-stress exposure time were compared against published experimental hemolysis data from a magnetically levitated ventricular assist device (LVAD) operating at 5 L/min and 6000 RPM. The Giersiepen-Wurzinger power-law coefficients were validated against this dataset, demonstrating that the model reproduces the observed hemolysis damage integral within ±18% across the tested shear-stress range (1–500 Pa). This cross-device validation corroborates the model's ability to capture the nonlinear shear-damage relationship and supports its application to the centrifugal CPB pump geometry. No operating-condition mismatch was identified during the validation review.",
      "quantitativeMetric": "Damage integral agreement within ±18% versus LVAD experimental reference at 5 L/min, 6000 RPM",
      "assessmentMethod": "Direct comparison of integrated shear-stress damage accumulation against in-vitro LVAD hemolysis measurements",
      "outcomeStatement": "Model form accepted as adequate for hemolysis prediction",
      "comparedAgainst": "https://uofa.net/synth/data/vad-hemolysis-bench-reference"
    }
