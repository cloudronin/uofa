  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA solver (Ansys Mechanical) used under vendor-supplied QA documentation; FDA in-house solver validated per institutional SOP. Achieved level must meet or exceed required level.",
      "rationale": "All three ensemble members (FDA research code, Ansys Mechanical, DePuy Synthes implementation) operate under documented software quality assurance programs. Vendor release notes, version control records, and institutional SOPs confirm Gradation 2 compliance. No custom solver modifications were introduced without re-verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions exercised for each ensemble solver. Results within 1% of analytical reference for linear elastic patch tests and beam bending benchmarks.",
      "rationale": "Each solver in the ensemble was exercised against NAFEMS benchmark suite and internal patch tests prior to use. All results fell within 1% of analytical reference solutions, confirming correct code implementation for the element types and contact formulations employed in the pedicle screw model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <5% between successive refinement levels. Richardson extrapolation applied to confirm asymptotic convergence.",
      "rationale": "A three-level mesh refinement study was conducted for the non-cannulated 7.5 mm screw geometry. QoI (stiffness, yield force, force at 40 mm) changed by less than 3% between the medium and fine mesh, and Richardson extrapolation confirmed asymptotic convergence. The production mesh corresponds to the medium refinement level, balancing accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms and energy balance monitored each increment; solver error contribution to QoI uncertainty quantified as negligible relative to model-form and input uncertainty.",
      "rationale": "Nonlinear static analyses used Newton-Raphson iteration with tight force and displacement convergence tolerances (1e-4 relative). Residual histories confirmed convergence at each load increment. Energy balance checks showed numerical dissipation below 0.1% of total strain energy, confirming solver error is not a dominant uncertainty source."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup reviewed by independent analyst not involved in original construction. Boundary conditions, load application, and material assignments verified against test protocol documentation.",
      "rationale": "An independent analyst reviewed model setup for each ensemble member against the ASTM F1717 test protocol and laboratory test reports. Boundary conditions (pin-pin fixture representation), load application (axial-bending combined loading), and titanium alloy material assignments were confirmed correct. No use errors were identified during the review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic constitutive model with isotropic hardening deemed appropriate for Ti-6Al-4V under quasi-static loading. Geometric nonlinearity included. Contact between screw and test block modeled with friction coefficient validated separately.",
      "rationale": "The bilinear isotropic hardening elastoplastic model for Ti-6Al-4V is well-established for quasi-static structural predictions in the orthopaedic implant literature. Geometric nonlinearity was activated to capture large-displacement bending response. Frictional contact at the screw-block interface used a coefficient of 0.3, consistent with literature values for titanium-on-UHMWPE block contact under lubricated conditions. Model form uncertainty was assessed as moderate and captured within the validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, yield stress, tangent modulus) sourced from coupon testing of production-lot Ti-6Al-4V. Geometric inputs from CMM measurements of actual test specimens. Uncertainty in inputs propagated to QoI using Monte Carlo sampling (n=1000).",
      "rationale": "Elastic modulus (114 GPa), yield stress (880 MPa), and tangent modulus (2.2 GPa) were derived from tensile coupon tests on production-lot Ti-6Al-4V bar stock matching the screw material certification. Screw geometry inputs were obtained from CMM measurements of three representative screws. Monte Carlo propagation (n=1000 samples) confirmed that input uncertainty contributes approximately 4% to QoI variability, well within the 10% acceptance bound."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test constructs from production-representative lot. Material certifications and dimensional inspection records available for all specimens.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested, drawn from a single production lot with full material certifications and dimensional inspection reports. Sample size exceeds the minimum of 10 required for this risk level. Testing was split across two independent laboratories to assess inter-laboratory reproducibility, providing additional confidence in the experimental reference data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two independent test conditions (e.g., loading rate, environmental condition, or fixture configuration) to demonstrate robustness of experimental reference data.",
      "rationale": "All bench testing was conducted under a single ASTM F1717 standard condition (quasi-static, room temperature, saline-wetted blocks). While two laboratories were used, the test conditions were nominally identical at both sites. Only one loading rate and one environmental condition were evaluated, resulting in an achieved level of 1 against a required level of 2. This shortfall is acknowledged and represents the single factor below the required level in this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrably equivalent to test specimen and fixture parameters. Traceability documented for each input parameter.",
      "rationale": "A parameter equivalency table was prepared mapping each FEA input to its experimental counterpart with supporting documentation (CMM reports, material certs, fixture drawings). Screw outer diameter, thread pitch, core diameter, and block material properties were verified equivalent between model and test. No unaccounted-for geometric or material discrepancies were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percent QoI difference < 10% for all three QoIs across all ensemble members. Statistical validation metric accounts for both model prediction uncertainty and experimental measurement uncertainty.",
      "rationale": "For all three QoIs (stiffness, yield force, force at 40 mm displacement), the validation metric E/uval was computed per ASME V&V 40 Section 5. Values ranged from 0.31 to 1.44 across ensemble members and QoIs, all below the 1.96 threshold. Percent differences ranged from 1.2% to 8.7%, all within the 10% acceptance bound. The output comparison is considered satisfactory for a Medium model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to the clinical and regulatory decision. Mechanistic justification provided for each QoI's relevance to implant performance and failure mode.",
      "rationale": "Construct stiffness governs load sharing with the spine and is a primary indicator of fixation adequacy. Yield force indicates the onset of permanent deformation, directly relevant to implant integrity under physiological loading. Force at 40 mm displacement characterizes post-yield energy absorption and is required by ASTM F1717 for comparative performance assessment. All three QoIs are directly relevant to the COU decision regarding pedicle screw mechanical performance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity geometry, loading, and material match the COU geometry, loading, and material to within documented tolerances. Any differences between validation and COU conditions are assessed and shown not to compromise credibility.",
      "rationale": "The validation activity directly tests the non-cannulated 7.5 mm pedicle screw under ASTM F1717 compression-bending, which is the exact COU configuration. Geometry, loading mode, and material are identical between validation and COU. The validation ensemble spans three independent modeling implementations, providing additional confidence that results are not artefacts of a single modeling approach. Relevance is assessed as high."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a Medium model risk, Class II device application. The single shortfall (Test conditions, achieved 1 vs. required 2) is noted and accepted given that two independent laboratories provided consistent experimental results under the single test condition, and that the ASTM F1717 standard does not mandate multi-condition testing. All quantitative validation metrics (E/uval < 1.96, QoI difference < 10%) are satisfied across all ensemble members and QoIs. The FEA modeling framework is accepted as sufficiently credible to support the regulatory submission for the non-cannulated 7.5 mm pedicle screw.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
