  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall in Test conditions (Gradation 2 achieved vs. Gradation 3 required) is accepted because the ASTM F1717 protocol is a standardised regulatory test and the single-condition limitation is consistent with industry practice for this device class. All three QoIs satisfy both acceptance criteria (E/uval < 1.96 and <10% difference). The overall credibility package is sufficient to support a Medium assurance level determination for this Class II device submission.",
