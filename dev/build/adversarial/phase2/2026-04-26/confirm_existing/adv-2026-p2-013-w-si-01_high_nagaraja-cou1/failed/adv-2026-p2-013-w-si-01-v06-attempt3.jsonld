  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "12 of 13 V&V 40 credibility factors meet or exceed required levels. The single below-required factor (Test conditions, achieved 2 vs. required 3) is accepted on the basis that the ASTM F1717 protocol specifies a single standardized test condition and multi-condition testing is not feasible within the regulatory context. All three QoIs satisfy both quantitative acceptance criteria (E/uval < 1.96 and <10% difference). The overall credibility of the FEA model for the stated COU is judged sufficient to support regulatory decision-making.",
