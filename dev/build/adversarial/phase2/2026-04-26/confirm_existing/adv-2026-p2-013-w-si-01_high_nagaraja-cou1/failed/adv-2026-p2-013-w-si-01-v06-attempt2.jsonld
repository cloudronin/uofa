    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals monitored; direct solver cross-check performed for representative load case.",
      "rationale": "Sparse direct solver (SPARSE) used for all load steps. Cross-check with preconditioned conjugate gradient iterative solver on representative 200 N load case showed QoI deviation < 0.05%. No floating-point overflow or ill-conditioning warnings encountered across all 11 virtual constructs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup; checklist-based verification of boundary conditions and material assignments.",
      "rationale": "Model setup reviewed by independent FDA OSEL engineer not involved in original construction. Boundary condition checklist (fixture constraints, load application point, contact definitions) completed and signed. Material property assignments cross-checked against manufacturer certificate of conformance for Ti-6Al-4V implant components."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics assumptions justified for pedicle screw geometry; contact formulation appropriate for screw-rod interface.",
      "rationale": "Continuum isotropic linear-elastic material model for Ti-6Al-4V justified by stress levels remaining below yield in elastic regime constructs. Augmented Lagrangian frictional contact (mu=0.2) applied at screw-rod and rod-set-screw interfaces, consistent with published tribological data. Geometric nonlinearity (large displacement) activated to capture bending-induced stiffness changes at large deflections."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports; geometric dimensions from CMM measurements of test articles.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and yield strength (880 MPa) taken from lot-specific material test reports provided by DePuy Synthes. Rod and screw geometry digitized via coordinate measuring machine (CMM) with ±0.005 mm tolerance. Uncertainty in material properties propagated through Monte Carlo sampling (N=1000); 95th-percentile stiffness uncertainty = 1.3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test constructs from production lots; dimensional inspection confirms geometric conformance to nominal CAD.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production lots, tested across two independent laboratories (FDA OSEL and DePuy Synthes R&D). Dimensional inspection of all 11 constructs via CMM confirmed rod diameter within ±0.01 mm and screw shank within ±0.008 mm of nominal. Sample variability in stiffness (CV=4.2%) captured in validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two distinct loading rates or fixture configurations tested to bound test condition sensitivity.",
      "rationale": "Testing performed exclusively under ASTM F1717 standard protocol at a single crosshead displacement rate (5 mm/min) and single fixture configuration. No variation in loading rate or environmental condition (dry, ambient temperature) was explored. Achieved level 2 reflects single test condition; required level 3 not met. Risk accepted given quasi-static loading assumption and low strain-rate sensitivity of Ti-6Al-4V at ambient temperature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrably equivalent to physical test article inputs.",
      "rationale": "One-to-one correspondence established between CMM-measured test article geometry and FEA geometry. Torque applied to set screws in physical assembly (4 Nm) replicated in FEA via pretension elements. Fixture compliance measured experimentally and incorporated as spring boundary conditions in FEA model. Equivalency matrix documented and reviewed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All three QoIs (stiffness, yield force, force at 40 mm) within 10% of experimental mean; E/uval < 1.96 for each QoI.",
      "rationale": "Stiffness: FEA 187.4 N/mm vs. experimental mean 183.1 N/mm (2.3% difference); E/uval=0.81. Yield force: FEA 412 N vs. experimental mean 405 N (1.7%); E/uval=0.64. Force at 40 mm: FEA 389 N vs. experimental mean 381 N (2.1%); E/uval=0.73. All three QoIs satisfy both acceptance criteria. Validation uncertainty (uval) computed per ASME V&V 20 combining experimental repeatability, input uncertainty, and numerical error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and referenced in FDA guidance for spinal implant 510(k) submissions. These quantities directly characterize the structural performance envelope relevant to intraoperative and postoperative loading scenarios. No surrogate or indirect QoI substitutions made."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, loading, and boundary conditions match COU geometry and intended use loading.",
      "rationale": "Validation activity directly replicates the COU: same non-cannulated 7.5 mm pedicle screw design, same ASTM F1717 compression-bending loading mode, same titanium alloy material system, and same two-screw one-rod construct configuration. No extrapolation beyond validated domain required for the regulatory submission use case. Validation and COU are judged fully congruent."
