  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3 due to evaluation under a single ASTM F1717 load condition; this shortfall is mitigated by conservative acceptance bounds (<10% QoI difference, E/uval <1.96) and the high consistency of results across two independent laboratories (N=11). Quantitative output comparison criteria satisfied for all three primary QoIs. Overall credibility sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw design under Medium model risk classification.",
