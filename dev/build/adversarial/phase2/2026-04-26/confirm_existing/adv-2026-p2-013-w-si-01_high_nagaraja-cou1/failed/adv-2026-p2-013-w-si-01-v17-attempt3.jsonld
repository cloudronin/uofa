    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic constitutive model with isotropic hardening validated for Ti-6Al-4V implant alloy; frictional contact at screw-rod interface represented.",
      "rationale": "Linear elastic model used for the UHMWPE test blocks; bilinear elastoplastic model with isotropic hardening applied to Ti-6Al-4V screw and rod. Frictional contact (mu=0.2) at all metal-metal and metal-polymer interfaces. Model form captures dominant deformation mechanisms observed experimentally (plastic hinge formation in rod, elastic block deformation)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties measured from lot-specific coupon tests; geometry from CMM measurements of production hardware; torque preload from calibrated torque wrench records.",
      "rationale": "Ti-6Al-4V elastic modulus and yield strength measured from tensile coupon specimens machined from the same bar stock as test constructs (n=5 per lot). UHMWPE block properties from supplier certificate of conformance supplemented by internal compression testing. Screw geometry digitized by CMM to ±0.005 mm. Rod torque preload documented from calibrated torque wrench at 4 Nm per protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lots; constructs assembled per IFU by trained technicians; lot traceability documented.",
      "rationale": "Eleven (N=11) non-cannulated 7.5 mm pedicle screw constructs assembled from production lots with full traceability. Assembly performed by trained laboratory technicians following manufacturer IFU. Constructs distributed across two independent laboratories to assess inter-laboratory variability. Coefficient of variation for stiffness across constructs was 4.3%, consistent with expected manufacturing variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two distinct load levels or loading configurations tested to assess model response across the intended operating envelope.",
      "rationale": "Testing performed under a single ASTM F1717 static compression-bending configuration at one load level. While the protocol is standardized and well-controlled, only one test condition was evaluated. This limits confidence in model predictive capability across the broader loading envelope. Achieved level (2) falls below required level (3); accepted as a known limitation of the standardized regulatory test method with risk mitigated by the multi-laboratory design."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Measured material properties and geometry from test specimens directly input to FEA; no surrogate or assumed values for primary QoI drivers.",
      "rationale": "Lot-specific material properties and CMM-measured geometry were used directly as FEA inputs with no substitution of nominal or assumed values. Sensitivity analysis confirmed that the primary QoI drivers (rod modulus, rod yield strength, screw geometry) are represented by measured values. Remaining inputs (friction coefficient, UHMWPE modulus) assessed by sensitivity analysis to have <3% influence on QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized comparison metric E/uval < 1.96 for all three QoIs; absolute percent difference < 10% for each QoI.",
      "rationale": "Validation metric E/uval computed per ASME V&V 40 Section 5. For stiffness: E/uval = 1.12; for yield force: E/uval = 0.87; for force at 40 mm: E/uval = 1.34. All values below 1.96 threshold. Absolute percent differences: stiffness 3.1%, yield force 2.8%, force at 40 mm 4.6%. All within the pre-established 10% acceptance bound."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the regulatory submission acceptance criteria and clinical failure modes.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three quantities specified in ASTM F1717 for regulatory comparison and are directly linked to the clinical failure modes of interest (fatigue crack initiation, screw loosening, rod fracture). These QoIs are identical to those used in the predicate device comparison, establishing direct relevance to the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation constructs use production hardware from same design family; test protocol matches COU loading conditions; validation domain encompasses COU domain.",
      "rationale": "Validation activities used production non-cannulated 7.5 mm pedicle screw constructs from the same design family as the COU device. ASTM F1717 static compression-bending protocol directly matches the COU loading condition. The validation domain (screw diameter, rod diameter, material, assembly torque) fully encompasses the COU domain with no extrapolation required."
    }
