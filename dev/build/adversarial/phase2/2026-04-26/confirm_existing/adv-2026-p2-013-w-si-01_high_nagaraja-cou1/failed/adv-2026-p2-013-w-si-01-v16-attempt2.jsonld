    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in all three QoIs (stiffness, yield force, force at 40 mm) between the penultimate and final mesh refinement levels. GCI reported.",
      "rationale": "Four mesh refinement levels evaluated (global element size 1.5 mm, 1.0 mm, 0.7 mm, 0.5 mm at screw-rod interface). GCI between finest two levels: stiffness 0.9%, yield force 1.1%, force at 40 mm 0.7%. Production mesh uses 0.7 mm level for computational efficiency with demonstrated convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Newton-Raphson residual norm < 1e-4 at each load step; energy residual < 1e-6. No unconverged increments reported across all 11 virtual specimen simulations.",
      "rationale": "Nonlinear static analyses employed automatic time-stepping with bisection on non-convergence. All 11 simulations converged at every load step. Maximum force residual norm 3.2e-5; maximum energy residual 4.1e-7. Solver log files archived with simulation package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent technical review of simulation setup, boundary conditions, and post-processing scripts by a second qualified analyst not involved in model development. All discrepancies resolved prior to result extraction.",
      "rationale": "A second FEA analyst (FDA/OSEL) performed independent review of boundary condition application, material property assignment, contact definitions, and QoI extraction macros. Three minor discrepancies identified (load application point offset, titanium alloy elastic modulus source, post-processing averaging region) and corrected before final result extraction. Review documented in peer review checklist PRC-2024-017."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum FEA with elastic-plastic titanium alloy material model (isotropic hardening, Ramberg-Osgood fit to tensile coupon data) and frictional contact (mu=0.2) at screw-rod interface judged sufficient to capture global construct response under ASTM F1717 loading.",
      "rationale": "Model form selection justified by prior literature (Nagaraja 2014, Patel 2018) demonstrating that continuum elastic-plastic FEA with frictional contact reproduces load-displacement behavior of pedicle screw constructs within 10% across multiple screw designs. Thread geometry explicitly modeled. Simplified polyaxial head representation validated against full-detail model (<3% QoI difference)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from lot-specific tensile coupon testing of Ti-6Al-4V ELI bar stock from the same heat as test constructs. Geometric dimensions from CMM measurement of five representative screws and rods from the test lot.",
      "rationale": "Tensile coupon data (n=6 coupons, same material heat) used to fit Ramberg-Osgood elastic-plastic model: E=114 GPa, sigma_y=880 MPa, n=18. CMM measurements of screw major/minor diameter, pitch, and rod diameter incorporated into CAD geometry. Sensitivity analysis showed QoIs insensitive (<1.5%) to ±2% dimensional variation within manufacturing tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 non-cannulated 7.5 mm pedicle screw constructs assembled per ASTM F1717 from production-representative hardware. Constructs span two independent laboratories to characterize inter-laboratory variability.",
      "rationale": "Eleven constructs assembled from production-lot hardware (same material heat as coupons) at two independent test laboratories (Lab A: n=6, Lab B: n=5). Assembly torque controlled per manufacturer IFU. Construct geometry (rod length, screw spacing) measured post-assembly by each laboratory. No outliers identified by Grubbs test at alpha=0.05."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "ASTM F1717 compression-bending protocol applied at a single displacement rate (5 mm/min) and ambient temperature. Only one test condition evaluated; multi-rate or temperature variation not within study scope.",
      "rationale": "Testing performed strictly per ASTM F1717 at 5 mm/min crosshead speed, ambient temperature (22±2°C), in ambient air. A single test condition was evaluated; the effect of displacement rate variation and temperature on construct response was not characterized. This factor is assessed below required level (achieved 2 vs. required 3), representing a documented limitation accepted by the assessment team given the quasi-static, room-temperature COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material properties, boundary conditions) demonstrably derived from measurements on the same hardware lot used for physical testing. Mapping of experimental setup to simulation boundary conditions documented and reviewed.",
      "rationale": "Direct traceability established between physical test setup and FEA boundary conditions: load application fixture geometry replicated in FEA, rod end boundary conditions (pin-pin with constrained axial rotation) matched to test fixture drawings. Material properties from same hardware lot. Equivalency mapping table reviewed and approved by independent analyst."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric (ASME V&V 40 Eq. 5-1) with uval incorporating experimental standard deviation and model numerical uncertainty. E/uval < 1.96 for all three QoIs. Additionally, percent difference between FEA mean prediction and experimental mean < 10% for each QoI.",
      "rationale": "E/uval computed for all three QoIs: stiffness 0.84, yield force 1.12, force at 40 mm 0.97. All below 1.96 threshold. Percent differences: stiffness 3.1%, yield force 6.8%, force at 40 mm 4.2%. Both acceptance criteria satisfied. Uncertainty validation metric computed per ASME V&V 40-2018 Section 5.3 using pooled experimental standard deviation across both laboratories."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are directly linked to the COU decision: demonstration of structural adequacy of the non-cannulated screw design under worst-case compression-bending loading.",
      "rationale": "Construct stiffness characterizes load-sharing behavior relevant to fusion outcome; yield force is the primary structural integrity metric for regulatory submission; force at 40 mm displacement captures post-yield energy absorption relevant to fatigue life estimation. All three QoIs are standard ASTM F1717 outputs and directly address the COU decision question."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities (ASTM F1717 bench testing, N=11 constructs, two laboratories) are sufficiently representative of the COU (FEA-based prediction of compression-bending performance for regulatory submission) to support the Medium model risk level.",
      "rationale": "Validation activities replicate the exact loading mode (compression-bending), hardware configuration (non-cannulated 7.5 mm screw, production-lot hardware), and test standard (ASTM F1717) specified in the COU. Multi-laboratory execution increases confidence in experimental reference data. The validation scenario is judged highly relevant to the COU; the single test condition limitation is captured under the Test conditions factor."
    }
