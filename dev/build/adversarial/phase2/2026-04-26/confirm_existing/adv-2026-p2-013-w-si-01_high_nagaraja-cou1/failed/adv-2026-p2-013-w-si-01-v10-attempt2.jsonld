  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single deficiency — Test conditions assessed at Gradation 2 against a required Gradation 3 — is accepted on the basis of published evidence that Ti-6Al-4V exhibits negligible rate sensitivity at quasi-static loading rates, and that the conservative 10% QoI acceptance bound provides compensating margin. All three QoIs pass both the percent-difference and normalised-error criteria. The credibility evidence is sufficient to support the regulatory use of the FEA model for the non-cannulated pedicle screw compression-bending COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
