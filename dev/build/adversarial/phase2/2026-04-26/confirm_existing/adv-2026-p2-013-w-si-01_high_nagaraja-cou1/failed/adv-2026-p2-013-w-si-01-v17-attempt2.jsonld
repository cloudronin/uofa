  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "12 of 13 V&V 40 credibility factors meet or exceed required levels for a Medium-risk model under ASME V&V 40-2018. The single deficiency (Test conditions, achieved 2 vs. required 3) is acknowledged and accepted on the basis that ASTM F1717 specifies a single standardized test configuration, making multi-condition testing impractical without departing from the recognized consensus standard. All three QoIs satisfy the pre-specified 10% acceptance bound and E/uval < 1.96 criterion. The FEA modeling framework is assessed as sufficiently credible to support the non-cannulated pedicle screw 510(k) submission.",
