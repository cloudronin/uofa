    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic constitutive model with isotropic hardening validated against coupon-level Ti-6Al-4V tensile data; contact mechanics representation verified.",
      "rationale": "Elastic-plastic model with isotropic hardening (Ramberg-Osgood fit) used for titanium alloy components. Model form appropriate for quasi-static large-deformation bending. Frictionless and frictional contact sensitivity study showed < 3% QoI sensitivity to friction coefficient in range 0.1–0.3. Model form uncertainty quantified and within acceptable bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports for each lot; geometric inputs from CMM-verified CAD; sensitivity analysis covers all inputs with > 5% QoI influence.",
      "rationale": "Ti-6Al-4V material properties (E, yield stress, UTS, hardening exponent) obtained from certified material test reports for the production lot. Geometric fidelity confirmed by coordinate measuring machine (CMM) inspection. One-at-a-time sensitivity analysis identified elastic modulus and yield stress as dominant inputs; both assigned measurement-derived distributions. Total input uncertainty propagated via Monte Carlo (N=500)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 constructs from production-representative hardware; dimensional inspection confirms geometric fidelity to nominal CAD.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab 1: n=6, Lab 2: n=5). All constructs assembled from production-representative hardware. CMM inspection of three representative constructs confirmed dimensional compliance with design drawings within ±0.05 mm. Sample size sufficient for statistical comparison per ASTM E2935."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two load levels or two fixture configurations representative of the COU loading envelope.",
      "rationale": "Testing performed at a single compression-bending load configuration per ASTM F1717. While the standard protocol is well-controlled and reproducible across two laboratories, only one test condition (fixed offset distance, fixed loading rate) was evaluated. This limits the ability to characterize model behavior across the broader COU loading envelope. Achieved level (2) is below required level (3); this shortcoming is noted and accepted given that the COU is specifically bounded to the F1717 protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, material, boundary conditions, loading) traceable to measured or certified experimental values; no surrogate substitutions without documented justification.",
      "rationale": "Geometric inputs derived from CMM measurements of tested constructs. Material properties from certified test reports for the same production lot used in experiments. Fixture geometry and loading point offsets measured and transferred directly to the FEA boundary condition definitions. No surrogate material or geometry substitutions made. Full traceability matrix documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric E/uval < 1.96 for all three QoIs; percent difference < 10% for each QoI mean.",
      "rationale": "Validation metric E/uval computed per ASME V&V 40 Section 5.4 for stiffness (0.87), yield force (1.31), and force at 40 mm (1.54). All values below the 1.96 threshold. Percent differences of 4.2%, 6.8%, and 7.5% respectively, all below the 10% acceptance bound. Comparison performed using combined experimental and simulation uncertainty estimates."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to mechanical performance metrics used in the regulatory submission (construct stiffness, yield force, force at 40 mm displacement).",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — are the primary mechanical performance metrics reported in the 510(k) submission for the pedicle screw system. These QoIs directly characterize the failure modes of clinical concern (fatigue and static overload). The validation QoIs are identical to the COU QoIs; no extrapolation required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments replicate the COU geometry, loading mode, and material system without surrogate substitution.",
      "rationale": "Validation experiments used production-representative non-cannulated 7.5 mm pedicle screw constructs tested under the ASTM F1717 compression-bending protocol — the same protocol and geometry as the COU. No surrogate materials, scaled geometries, or simplified loading modes were employed. The validation domain is coincident with the COU domain, providing direct evidence of model credibility without extrapolation."
