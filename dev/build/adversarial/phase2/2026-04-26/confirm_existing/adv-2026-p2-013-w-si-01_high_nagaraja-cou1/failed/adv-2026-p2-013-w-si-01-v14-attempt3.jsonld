    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force-displacement residual norm < 1e-4 at every converged increment; energy criterion also satisfied.",
      "rationale": "Nonlinear quasi-static analysis used with Newton-Raphson iteration. Residual force norm converged to < 5e-5 at each load step. No solution divergence observed across 11 simulation instances. Solver error contribution to QoI uncertainty estimated at < 0.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
