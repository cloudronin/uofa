    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics assumptions (linear elastic with nonlinear geometry) justified for the displacement regime tested; contact formulation peer-reviewed.",
      "rationale": "Construct operates predominantly in elastic regime up to yield; bilinear isotropic hardening captures post-yield behavior. Large-deformation kinematics (NLGEOM) enabled to account for geometric nonlinearity at 40 mm displacement. Augmented Lagrange contact with friction coefficient 0.3 (Ti-Ti interface) consistent with literature. Model form assessed as appropriate for the F1717 loading scenario."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
