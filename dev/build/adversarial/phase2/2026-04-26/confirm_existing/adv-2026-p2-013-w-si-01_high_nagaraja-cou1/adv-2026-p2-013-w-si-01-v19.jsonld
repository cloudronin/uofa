    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions demonstrate that the solver implementation is correct for the element types and contact formulations used in the pedicle screw model.",
      "rationale": "Patch test, cantilever beam, and Hertzian contact benchmarks were executed. All results agreed with analytical solutions to within 0.5%, confirming correct implementation of SOLID186 elements and augmented Lagrange contact."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates that QoI values (stiffness, yield force, force at 40 mm) change by less than 2% between the production mesh and a systematically refined mesh.",
      "rationale": "Three-level mesh refinement study performed on the screw-rod-vertebral body assembly. Global element size reduced from 1.5 mm to 0.75 mm to 0.375 mm. QoI changes between levels 2 and 3 were 0.8%, 1.1%, and 1.4% respectively, satisfying the <2% criterion. Production mesh uses level 2 density."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge to below 1e-4 relative norm for all load steps; force and moment equilibrium residuals reported.",
      "rationale": "Sparse direct solver (SPARSE) used for all linear substeps; Newton-Raphson iteration employed for nonlinear contact. Force residual norm converged to <1e-5 for every load step across all 11 simulated constructs. No unconverged substeps reported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and material assignments performed by a second qualified analyst; discrepancies resolved before results extraction.",
      "rationale": "A senior FEA engineer independent of the primary analyst reviewed all input decks, boundary condition definitions, and material property assignments. Three minor discrepancies in contact pair ordering were identified and corrected prior to final simulation runs. Review documented in the project technical file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The chosen continuum mechanics formulation (linear elasticity with nonlinear contact) is justified for the loading regime and material response observed in ASTM F1717 testing up to yield.",
      "rationale": "Titanium alloy (Ti-6Al-4V) exhibits linear elastic behavior below yield (~880 MPa). Peak stresses in the screw shank remain below yield for the majority of the load history; plasticity is activated only near the screw-rod interface at large displacements. Bilinear isotropic hardening was incorporated for post-yield response. Model form is appropriate for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, nu, yield stress, tangent modulus) sourced from traceable coupon testing or certified material data sheets; geometric dimensions from CMM measurements of production implants.",
      "rationale": "Elastic modulus and Poisson's ratio for Ti-6Al-4V taken from ASTM F136 certified material test reports (lot-specific). Yield stress and tangent modulus from uniaxial tensile coupon testing (n=5 per lot). Screw geometry digitized via CMM with 2 µm resolution; rod geometry from engineering drawings verified against CMM. Sensitivity analysis confirmed QoI insensitivity to ±5% material property variation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test constructs are production-representative implants from the same design family; sample size (N≥10) sufficient to characterize inter-specimen variability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested, all from production lots with certificates of conformance. Constructs assembled by trained technicians following the IFU. Inter-specimen coefficient of variation for stiffness was 4.2%, confirming adequate manufacturing consistency. Sample size exceeds the minimum recommended by ASTM F1717."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; at minimum, two distinct test configurations should be evaluated.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending configuration. While this is the standard regulatory test condition, only one load case was evaluated. The required gradation level of 3 demands at least two distinct loading configurations; this was not achieved. This shortfall is documented as a known gap; the single condition is nonetheless the most clinically relevant per FDA guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters (geometry, material properties, boundary conditions, applied loads) are demonstrably equivalent to those of the physical test constructs used for validation.",
      "rationale": "FEA geometry was derived from CMM measurements of the specific production implants used in bench testing. Material properties are lot-matched. Applied load and displacement boundary conditions replicate the ASTM F1717 fixture configuration as confirmed by fixture drawings and lab photographs. Equivalency formally documented in the V&V plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation metric E/uval < 1.96 and percent difference < 10% for all three QoIs (stiffness, yield force, force at 40 mm displacement).",
      "rationale": "Stiffness: FEA 312 N/mm vs. experimental mean 308 N/mm (1.3% difference, E/uval = 0.41). Yield force: FEA 1,847 N vs. experimental mean 1,823 N (1.3%, E/uval = 0.58). Force at 40 mm: FEA 2,104 N vs. experimental mean 2,076 N (1.3%, E/uval = 0.47). All three QoIs satisfy both acceptance criteria across both laboratories."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical risk of construct failure and are the quantities reported in the regulatory submission.",
      "rationale": "Construct stiffness governs load sharing with the vertebral column; yield force and force at 40 mm are the primary ASTM F1717 endpoints used by FDA to assess structural adequacy. These QoIs are identical to those in the 510(k) predicate data comparison, confirming direct regulatory relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation test configuration matches the COU in terms of implant design, loading mode, and regulatory context; any differences are explicitly characterized and shown to be conservative or negligible.",
      "rationale": "The validation activity directly replicates the COU: same implant design family, same ASTM F1717 compression-bending protocol, same regulatory submission context (510(k)). Testing conducted at two independent laboratories (FDA/CDRH and DePuy Synthes internal) increases confidence in result reproducibility. No extrapolation beyond the validated design space is claimed."
    }
