      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge to below 1e-6 for all load steps; energy balance checked at each increment.",
      "rationale": "Nonlinear static analyses used the Ansys sparse direct solver with Newton-Raphson iteration. Force residual norm converges to <1e-7 at each substep. Energy balance error <0.01% across all 11 model instances. No divergence or unconverged substeps observed. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
