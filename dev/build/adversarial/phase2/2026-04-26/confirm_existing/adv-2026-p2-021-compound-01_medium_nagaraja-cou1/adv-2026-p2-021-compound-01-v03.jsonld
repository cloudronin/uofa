  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework demonstrates sufficient credibility for the non-cannulated pedicle screw compression-bending COU. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is accepted given that the ASTM F1717 protocol specifies a single standard offset distance and regulatory precedent supports this configuration. All three QoIs satisfy quantitative acceptance bounds. The credibility assessment team accepts the model predictions for regulatory submission support.",
