  "signature": "ed25519:9c2e4a1f7b3d5e8a0c6f2b4d9e1a3c7f5b0d2e4a8c1f3b6d9e2a4c7f0b5d3e1a",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2022 R2) used under documented QMS with version control, regression test suite, and FDA-recognized validation documentation.",
      "rationale": "Ansys Mechanical is operated under a controlled QMS environment with documented installation qualification, version-locked analyses, and a regression test suite covering linear static structural analyses. Required and achieved levels are equal; factor is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS and ASME V&V 10 suite reproduced within 1% of analytical solutions for beam bending and contact problems representative of the pedicle screw geometry.",
      "rationale": "Three NAFEMS benchmark cases (LE1, LE10, and a contact patch test) were executed and results compared against published reference solutions. All deviations were below 0.8%. Code verification is considered sufficient for the linear static contact problem of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change of less than 2% between the production mesh and a uniformly refined mesh at 1.5x element density.",
      "rationale": "A three-level mesh convergence study was performed on the screw-rod construct. QoI (stiffness, yield force, force at 40 mm) changed by less than 1.4% between the medium and fine meshes. Richardson extrapolation was applied to estimate the discretization error at 0.9%. Achieved level exceeds required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge below 1e-6 for all load steps; energy balance checked.",
      "rationale": "All analyses used the sparse direct solver with residual convergence criterion of 1e-8. Energy balance was verified at each load increment. No solver divergence or convergence warnings were observed across the 11-construct ensemble. Achieved level exceeds required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented analysis plan, peer-reviewed model setup, and independent QA check of boundary conditions and material assignments prior to result extraction.",
      "rationale": "An analysis plan was prepared prior to simulation execution and reviewed by a second analyst. Boundary conditions (fixed base, axial-bending load application at 5-degree offset per ASTM F1717) and titanium alloy Ti-6Al-4V material properties were independently verified. No use errors were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum FEA with nonlinear geometry and frictional contact is an accepted model form for pedicle screw construct stiffness and yield prediction; supported by literature and prior FDA guidance.",
      "rationale": "The continuum FEA model employs nonlinear geometry (large deformation) and frictional contact between screw threads and vertebral body surrogate. This model form is consistent with published literature (Nagaraja et al. 2015, Goel et al.) and FDA guidance on FEA of spinal implants. Model form is appropriate for the QoIs of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports; geometric inputs from calibrated CMM measurements of test specimens; friction coefficient from dedicated tribology testing.",
      "rationale": "Ti-6Al-4V material properties (E=114 GPa, yield stress=880 MPa) were taken from certified material test reports for the production lot used in bench testing. Screw and rod geometries were measured by CMM with 5 µm accuracy. Friction coefficient (µ=0.3) was determined from pin-on-disk tribology tests on representative surface finishes. All inputs are traceable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs tested, all from the same production lot as the FEA model inputs; geometric measurements confirm dimensional conformance.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from the same production lot. CMM measurements confirmed all screws and rods were within drawing tolerances. Sample size of 11 is sufficient to characterise experimental variability for the three QoIs. Constructs were split across two independent laboratories to assess inter-laboratory reproducibility."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate the ASTM F1717 protocol with controlled displacement rate, ambient temperature, and calibrated load cell; multiple test conditions would be required for Level 3.",
      "rationale": "Testing was performed strictly per ASTM F1717 at a single displacement rate (5 mm/min) and ambient temperature (23°C). Only one set of test conditions was evaluated; variation of displacement rate or temperature was not explored. Achieved level (2) is below the required level (3). This gap is acknowledged and accepted given that ASTM F1717 specifies a single standard condition and the COU does not require multi-condition extrapolation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) are demonstrably equivalent to the physical test specimens and test setup.",
      "rationale": "A formal equivalency check was performed comparing FEA input parameters against as-measured specimen data and test machine setup records. Geometric equivalency was confirmed by CMM-to-CAD comparison (max deviation 0.05 mm). Material property equivalency was confirmed by tensile coupon testing of the same lot. Boundary condition equivalency was confirmed by comparing FEA fixture compliance against measured machine compliance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; acceptance threshold E/uval < 1.96 for all three QoIs.",
      "rationale": "E/uval was computed for stiffness (1.31), yield force (1.44), and force at 40 mm (1.52). All values are below the 1.96 threshold. The comparison methodology follows ASME V&V 40-2018 Section 6.4. Inter-laboratory variability was incorporated into the experimental uncertainty estimate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly specified in ASTM F1717 and are the regulatory-relevant outputs for pedicle screw construct performance.",
      "rationale": "The three QoIs are explicitly required by ASTM F1717 and are the quantities used by FDA reviewers to assess pedicle screw construct mechanical performance. They are directly relevant to the COU and the regulatory decision. No surrogate or proxy QoIs are used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities directly replicate the COU: same implant design, same test standard, same loading mode, same material lot.",
      "rationale": "The validation activities are performed on the identical non-cannulated 7.5 mm pedicle screw design under the identical ASTM F1717 compression-bending protocol that constitutes the COU. There is no extrapolation from a surrogate geometry or different loading mode. Relevance is assessed as high and the required level is met."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed. Twelve of thirteen factors meet or exceed the required credibility level. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted because ASTM F1717 specifies a single standard test condition and the COU does not require multi-condition extrapolation. E/uval ratios for all three QoIs are below 1.96. The overall credibility package is judged sufficient to support the regulatory submission for the non-cannulated pedicle screw design.",
