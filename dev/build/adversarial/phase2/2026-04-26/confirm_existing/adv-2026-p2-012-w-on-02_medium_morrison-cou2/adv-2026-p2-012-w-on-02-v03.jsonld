  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and achieved levels documented. While multiple factors show gaps between required and achieved levels — most notably model form uncertainty and output comparison metric — the assessment team accepted the package on the basis that the Monte Carlo UQ bounds remain below the clinical hemolysis threshold at the 95th percentile, and that residual gaps are judged tolerable given the conservative safety margins applied in the clinical threshold. The ContextOfUse prose fully describes the intended operating range (flow rates 3–7 L/min, rotational speeds 2400–3600 RPM, Class III VAD indication), and all factors have been formally evaluated. No structured applicability constraint or operating envelope object has been linked; the operating boundary is conveyed through prose description only.",
