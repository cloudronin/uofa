  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be under formal version control, with documented testing and configuration management consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is under version control and unit-tested, but formal configuration management documentation is incomplete relative to the MRL 5 required level. Achieved level 3 falls short of required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate order-of-accuracy convergence for the governing equations implemented in the hemolysis CFD solver.",
      "rationale": "Order-of-accuracy tests were performed for the Navier-Stokes solver but not for the hemolysis transport sub-model. Achieved level 3 is below the required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or equivalent must be reported for hemolysis index predictions across all 5 operating points.",
      "rationale": "GCI was computed at 3 of 5 operating points. The remaining two points lack mesh refinement studies, leaving discretization error partially uncharacterised. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match the intended VAD operating envelope with documented traceability to clinical use conditions.",
      "rationale": "Bench experiments replicated 4 of the 5 flow-speed combinations. The fifth operating point was not experimentally tested, reducing coverage. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E%, u_val) must be reported between CFD-predicted and experimentally measured hemolysis index values at all tested operating points.",
      "rationale": "Quantitative comparison metrics were computed but uncertainty in experimental measurements was not fully propagated into the comparison metric, limiting the rigour of the output comparison. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest (hemolysis index values) must be directly linked to the clinical decision threshold with documented justification.",
      "rationale": "Hemolysis index is the primary QoI and is clinically relevant; however, the link between the modified index of hemolysis (MIH) used in simulation and the clinical NIH threshold is qualitative rather than formally quantified. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on the same or sufficiently similar geometry, fluid, and operating conditions as the COU to support extrapolation claims.",
      "rationale": "Validation was performed on the FDA generic pump geometry which matches the simulation geometry; however, the blood analogue fluid used in experiments differs from in-vivo rheology. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver tolerance effects must be quantified and shown to be negligible relative to the hemolysis prediction uncertainty budget.",
      "rationale": "Residual convergence criteria were reported but iterative error was not formally separated from discretization error. Round-off error analysis was not performed. Factor flagged as epistemic gap at MRL 5; achieved level 2 is well below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence must be provided that the model has been applied correctly by qualified users following documented procedures, with independent review of simulation setup.",
      "rationale": "No independent review of simulation setup was conducted and no formal user qualification records were provided. This factor is an epistemic gap at MRL 5; achieved level 2 is well below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The selection of the hemolysis power-law model and turbulence closure must be justified with sensitivity analyses demonstrating that alternative model forms do not materially alter hemolysis predictions.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected without comparative analysis against alternative formulations. Turbulence model sensitivity was not assessed. Achieved level 2 is well below the required level 5 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters (viscosity, density, hemolysis model coefficients, boundary conditions) must be characterised and propagated through Monte Carlo analysis to the hemolysis QoI.",
      "rationale": "Monte Carlo UQ was performed on boundary condition flow rates and rotational speed, but hemolysis model coefficients and blood rheological parameters were treated as deterministic. Full input uncertainty characterisation is incomplete. Achieved level 2 is well below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used in validation must be characterised for variability, and sample size must be sufficient to support statistical comparison with CFD predictions.",
      "rationale": "Validation experiments used a single test article without replication across multiple pump specimens. Sample-to-sample variability in pump geometry and surface finish was not characterised. Achieved level 2 is well below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The correspondence between experimental input parameters and simulation boundary conditions must be formally documented and any discrepancies must be shown to have negligible effect on hemolysis predictions.",
      "rationale": "Nominal flow rates and rotational speeds were matched between experiment and simulation, but no formal equivalency analysis quantifying the effect of remaining discrepancies (e.g., inlet velocity profile, fluid temperature) was performed. Achieved level 2 is well below required level 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors. Seven factors were formally assessed; all achieved levels fall below required levels for MRL 5, indicating credibility gaps. Six factors were not assessed and represent epistemic gaps. Despite these gaps, the regulatory submission timeline required a formal disposition; the team accepted the package at Low assurance level with the understanding that additional evidence must be generated prior to final regulatory submission. The ContextOfUse prose adequately describes the intended operating conditions and clinical decision context, and Monte Carlo UQ was performed on primary boundary conditions.",
