  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite all seven assessed credibility factors achieving levels below their required thresholds and six factors remaining unassessed at MRL 5, the assessment team accepted the package on the basis that Monte Carlo UQ bounds hemolysis predictions conservatively below the clinical threshold across all sampled operating points. The team noted that prose descriptions of operating ranges (5 flow-speed combinations, hematocrit 35-45%, rotational speeds 2000-4000 RPM) are captured in the COU description and intended use fields, and considered this sufficient for internal review purposes. No structured applicability constraint or operating envelope object was linked to the COU, leaving the formal boundary of model validity unspecified in machine-readable form.",
