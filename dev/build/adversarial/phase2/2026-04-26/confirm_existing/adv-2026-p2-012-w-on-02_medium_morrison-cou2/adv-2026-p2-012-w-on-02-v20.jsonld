  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite and audit trail for all CFD runs submitted to regulatory review.",
      "rationale": "Solver version control and regression testing are documented, but the audit trail for individual Monte Carlo runs is incomplete; configuration management records do not capture all parameter perturbation instances, leaving a gap at Gradation 4 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy tests on canonical rotating-flow benchmarks demonstrating expected convergence rates for the hemolysis transport scalar.",
      "rationale": "Order-of-accuracy testing was performed on lid-driven cavity and rotating disk benchmarks; however, the hemolysis scalar transport equation was not independently verified for convergence order, leaving a code-verification gap specific to the damage accumulation sub-model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all five flow-speed operating points with GCI below 5% on the hemolysis index QoI.",
      "rationale": "GCI was computed for three of five operating points; the two highest-speed conditions exhibited GCI values of 8–11% on the hemolysis index due to unresolved near-blade shear layers, falling short of the 5% threshold required at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, pump speed, flow rate) match COU operating conditions within stated tolerances, with traceability to calibrated instrumentation.",
      "rationale": "Hematocrit was controlled at 30±2%, matching the COU specification, and pump speed was servo-controlled; however, fluid temperature during bench testing drifted up to 3°C above the COU upper bound during high-speed runs, introducing a minor but unquantified viscosity discrepancy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel or validation uncertainty U_val) computed for hemolysis index at each operating point, with statistical comparison accounting for experimental scatter.",
      "rationale": "Relative error on the normalized index of hemolysis (NIH) ranged from 18–34% across operating points. Validation uncertainty was computed via Monte Carlo but experimental repeatability data were available for only two of five points, limiting the statistical rigor of the comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (NIH) directly corresponds to the regulatory acceptance criterion and is computed from the same Lagrangian damage accumulation model used in the COU prediction.",
      "rationale": "NIH is the FDA-recognized hemolysis metric and is computed identically in both validation and COU simulations using the Giersiepen power-law model; QoI relevance is fully established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic pump geometry under flow-speed combinations spanning the COU operating range.",
      "rationale": "Validation used the FDA generic pump geometry, consistent with the COU device; however, the validation flow-speed matrix covered only three of the five COU operating points, leaving two corner conditions (low flow, high speed) without direct experimental validation support."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence monitored via residual drop of at least 4 orders of magnitude and QoI stabilization within 0.5% over the final 200 iterations for all operating points.",
      "rationale": "Residuals dropped 3–4 orders of magnitude for most runs; the hemolysis scalar residual stalled at 3 orders for the two highest-speed operating points, and QoI stabilization was within 1.2%, exceeding the 0.5% criterion. Solver error is not fully bounded at MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution protocol with independent review of boundary condition setup, mesh generation parameters, and post-processing scripts for each operating point.",
      "rationale": "A simulation execution protocol exists and was followed; however, independent peer review of boundary condition assignments was performed for only the nominal operating point. The four off-nominal conditions were not independently reviewed, leaving use-error risk partially unmitigated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis damage model form uncertainty, including comparison of at least two turbulence closures and two damage accumulation models against experimental data.",
      "rationale": "Only the SST k-omega turbulence model and the Giersiepen damage model were used; no alternative turbulence closure or damage model was evaluated. Model form uncertainty is unquantified and represents a critical gap at MRL 5, where the model is the primary regulatory basis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters (viscosity, density, damage model exponents, inlet velocity profile) with sensitivity analysis identifying dominant contributors to NIH uncertainty.",
      "rationale": "Monte Carlo UQ was performed with distributions on viscosity, density, and inlet profile; however, the Giersiepen exponents (alpha, beta) were treated as fixed literature values rather than uncertain parameters, despite known inter-study variability of up to 20%. This omission underestimates total input uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates per operating point to characterize biological and measurement variability in NIH.",
      "rationale": "Experimental NIH measurements were available from a single published dataset with n=3 replicates at two operating points and n=1 at the remaining three. Insufficient replication prevents characterization of biological variability; factor flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental test article geometry and COU device geometry, with dimensional inspection report confirming tolerances within 1% on hydraulic diameter and blade angle.",
      "rationale": "The FDA generic pump geometry was used for both validation and COU; however, no dimensional inspection of the physical test article was available to confirm geometric fidelity. Equivalency of input parameters between the physical test specimen and the CAD-based CFD geometry is assumed but not formally demonstrated."
    }
  ],
