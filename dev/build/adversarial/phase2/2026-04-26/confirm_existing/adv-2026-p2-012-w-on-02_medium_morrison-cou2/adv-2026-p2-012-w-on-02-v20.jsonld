  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been evaluated against MRL 5 requirements. Seven factors were formally assessed; six factors were assessed with documented gaps. Achieved levels fall below required levels across all assessed factors, consistent with the COU2 Not Accepted determination. The assessment is accepted as a complete and valid credibility evidence package for regulatory submission, notwithstanding the identified factor gaps, which are transparently documented. The ContextOfUse prose fully describes the intended operating conditions across 5 flow-speed combinations; structured applicability constraints and operating envelope links were not separately encoded as the prose description was deemed sufficient by the assessment team.",
