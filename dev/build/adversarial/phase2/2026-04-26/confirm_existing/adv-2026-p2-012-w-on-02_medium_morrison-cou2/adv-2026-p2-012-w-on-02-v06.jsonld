  "signature": "ed25519:b9d2e4f1a7c3b05e8d2f4a1c7b3e05f8d2f4a1c7b3e05f8d2f4a1c7b3e05f8d2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a quality management system with documented version control, regression testing, and traceable build records consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is commercial and holds FDA 510(k) clearance documentation, but internal regression test suite coverage is below 60% for turbulent hemolysis-relevant flow regimes. Version control records are present but change-impact analysis is not systematically performed. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification using manufactured solutions must be demonstrated for all governing equations active in the hemolysis simulation, including turbulence and scalar transport.",
      "rationale": "Order-of-accuracy tests were performed for the Navier-Stokes solver but not for the scalar hemolysis transport equation. The power-law blood damage model has not been subjected to manufactured-solution verification. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must be applied to quantify discretization error on the hemolysis index QoI; reported discretization uncertainty must be below 5% of the QoI at the finest mesh level.",
      "rationale": "Three-mesh Richardson extrapolation was performed for pressure rise but not for the hemolysis index directly. Estimated discretization uncertainty on hemolysis index is 22% based on indirect extrapolation, far exceeding the 5% threshold. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with traceability to calibrated instrumentation; blood analog fluid properties must be characterized at the test temperature with stated uncertainty.",
      "rationale": "Test conditions are documented with calibrated flow meters and pressure transducers. Blood analog (glycerol-water) viscosity was characterized at 37°C ± 0.5°C. However, hematocrit variability across test batches was not controlled to within ±2%, introducing unquantified variability in the damage model inputs. Achieved gradation 3 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation metric U_val) must be computed for hemolysis index at all operating points; metric must be below the acceptance threshold defined for MRL 5.",
      "rationale": "Normalized hemolysis index error ranges from 18% to 47% across the five operating points. The validation metric U_val exceeds the MRL 5 acceptance threshold of 10% at all five conditions. No physics-based explanation for the systematic over-prediction at high rotational speeds has been identified. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly mappable to the clinical endpoint (hemolysis-induced anemia risk); surrogate QoIs must have documented sensitivity linking them to the primary clinical endpoint.",
      "rationale": "The normalized index of hemolysis (NIH) is used as the primary QoI and is directly linked to clinical hemolysis burden. Mapping from NIH to chronic anemia risk is supported by published clinical thresholds. The linkage is well-documented but relies on population-average thresholds rather than patient-specific risk models. Achieved gradation 3 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be performed on the same pump geometry, at the same operating conditions, with the same fluid, and under the same boundary conditions as the COU. Any deviations must be justified with sensitivity analysis.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which matches the COU geometry. However, experiments used a blood analog rather than porcine blood, and were conducted at only 3 of the 5 required flow-speed combinations. No sensitivity analysis was performed to bound the impact of fluid substitution on hemolysis prediction. Achieved gradation 2 against required gradation 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of the hemolysis scalar transport equation must be demonstrated to machine-precision tolerance; solver residuals must be reported and shown to be below 1e-6 for all active equations.",
      "rationale": "Iterative convergence of the hemolysis scalar transport equation was not independently assessed. Solver residuals for the momentum equations are reported (converged to 1e-5) but residuals for the scalar damage equation are not documented. This factor is flagged as an epistemic gap at MRL 5. Achieved gradation 1 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal use-error assessment must document potential operator errors in model setup, boundary condition specification, and post-processing of hemolysis results, with mitigations for each identified error mode.",
      "rationale": "No formal use-error assessment was performed. Boundary condition specification for the inlet velocity profile is identified as a high-sensitivity parameter in the UQ study, but no procedural controls or checklists are in place to prevent operator mis-specification. Flagged as epistemic gap at MRL 5. Achieved gradation 1 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the blood damage power-law model must be quantified by comparison against alternative damage models (e.g., strain-based, energy dissipation-based); the selected model form must be justified as best-available for the COU.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model was used. No comparison against alternative model forms (e.g., Bludszuweit strain-based model) was performed. Model form uncertainty is unquantified and represents the largest epistemic gap in the assessment. Flagged as not-assessed at MRL 5. Achieved gradation 2 against required gradation 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions derived from experimental measurements or literature; sensitivity analysis must identify and rank the top contributors to output uncertainty.",
      "rationale": "Monte Carlo UQ was performed over 4 of the 11 identified uncertain input parameters. The remaining 7 parameters, including blood viscosity temperature dependence and pump surface roughness, were held at nominal values without justification. Sensitivity rankings are incomplete. Flagged as not-assessed. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A statistically adequate number of experimental replicates must be performed to characterize aleatory variability in hemolysis measurements; sample size justification must be provided.",
      "rationale": "Experimental hemolysis measurements were performed with n=3 replicates per operating point. No statistical power analysis was performed to justify this sample size. Coefficient of variation across replicates ranges from 12% to 31%, indicating substantial measurement variability that is not adequately characterized. Flagged as not-assessed. Achieved gradation 1 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal equivalency assessment must demonstrate that the input parameters used in validation experiments match those of the COU within stated tolerances; any deviations must be bounded by sensitivity analysis.",
      "rationale": "No formal equivalency assessment was performed. The blood analog fluid used in validation has a viscosity matched to whole blood at 37°C but does not replicate the viscoelastic behavior of red blood cell membranes. The impact of this substitution on the hemolysis damage model outputs has not been quantified. Flagged as not-assessed. Achieved gradation 1 against required gradation 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been evaluated against MRL 5 requirements. Seven factors were formally assessed; all seven show achieved levels below required levels, with gaps ranging from 1 to 3 gradations. Six factors remain not-assessed, representing material epistemic gaps. The Monte Carlo UQ study demonstrates that prediction uncertainty on the hemolysis index substantially exceeds the MRL 5 acceptance bound. The model is not accepted for use in regulatory submission to support absolute hemolysis claims for the Class III VAD device without resolution of the identified credibility gaps.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
