  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold ISO 9001 certification and documented version control with full audit trail for all simulation scripts.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is ISO 9001 certified. Version control via Git with tagged releases is documented. All pre/post-processing scripts are archived in a validated repository. Achieved level meets required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include method-of-manufactured-solutions (MMS) tests demonstrating correct order of convergence for all governing equations.",
      "rationale": "MMS tests confirm second-order spatial convergence for the incompressible Navier-Stokes solver and the scalar hemolysis transport equation. Results are consistent with published solver benchmarks. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for hemolysis index at all 5 operating points; Richardson extrapolation required.",
      "rationale": "Richardson extrapolation yields GCI values ranging from 4.1% to 8.7% across the 5 flow-speed combinations. Three of five operating points meet the 5% threshold; two do not. Achieved level 3 is below required level 4, representing a credibility gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within stated uncertainty bounds for flow rate, rotational speed, and fluid properties.",
      "rationale": "Flow rate and rotational speed are matched within ±2% across all operating points. However, blood analog viscosity in experiments deviates from the CFD fluid model by up to 6% at the lowest flow rate, introducing systematic bias not fully accounted for. Achieved level 3 falls short of required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±15% at all 5 operating points, accounting for combined simulation and measurement uncertainty.",
      "rationale": "Agreement is within ±15% at 3 of 5 operating points. At the two highest rotational speed conditions, discrepancies reach 22% and 19%, attributed to turbulence model limitations in high-shear regions. Achieved level 3 does not meet required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must be directly linked to the clinical endpoint (plasma free hemoglobin concentration) through a validated correlation.",
      "rationale": "NIH is computed from plasma free hemoglobin per ASTM F1841. The correlation between CFD-predicted NIH and in-vitro measured NIH is validated across the FDA pump geometry. QoI relevance is confirmed at required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry and at operating conditions spanning the full COU envelope, including all 5 flow-speed combinations.",
      "rationale": "Validation experiments cover 4 of the 5 target operating points. The fifth point (lowest flow, highest speed) was not tested experimentally due to hemolysis-risk concerns in the test protocol. Extrapolation to this point reduces validation relevance to achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-6 for all equations; round-off error analysis must confirm double-precision arithmetic is sufficient.",
      "rationale": "All simulations converge to residuals below 1e-6. Double-precision arithmetic is confirmed throughout. Solver error is bounded and meets the required level 3 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation protocol with independent peer review must be in place; at least one independent replication of the baseline operating point must be performed.",
      "rationale": "A simulation protocol exists and has been internally reviewed, but independent external replication has not been performed. The single internal replication check at the nominal operating point is insufficient for MRL 5 requirements. Achieved level 2 falls below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis model form (power-law damage accumulation) must be justified through comparison with at least two alternative model forms; sensitivity of NIH predictions to model form must be quantified.",
      "rationale": "Only the Giersiepen power-law model is used. No comparison with alternative hemolysis models (e.g., Taskin or Arora) has been performed. Model form uncertainty is unquantified. This represents the largest credibility gap in the assessment; achieved level 2 is well below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty distributions must be assigned to all material and boundary condition inputs; Monte Carlo propagation must yield 95th-percentile NIH bounds reported at each operating point.",
      "rationale": "Monte Carlo UQ is performed with 500 samples per operating point. Uncertainty distributions are assigned to viscosity, density, and inlet velocity. Power-law model coefficients are treated as fixed (not uncertain), omitting a key epistemic source. 95th-percentile NIH bounds are reported but are likely underestimated. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least three independent experimental replicates per operating point must be available for validation comparison.",
      "rationale": "Three independent replicates are available for 4 of the 5 operating points. The fifth point has two replicates. Statistical variability is characterized and reported. Achieved level meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Fluid properties and boundary conditions in the CFD model must be demonstrated equivalent to experimental conditions through documented traceability to calibrated measurements.",
      "rationale": "Traceability documentation exists for flow rate and speed measurements but is incomplete for fluid temperature, which affects viscosity. Temperature was not continuously monitored during experiments, introducing unquantified equivalency uncertainty. Achieved level 2 falls below required level 3."
    }
  ],
