    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; spatial and temporal discretization error must be separately bounded.",
      "rationale": "GCI analysis performed on three mesh levels (coarse 4.2M, medium 8.7M, fine 17.1M cells). Temporal discretization error was estimated via halved time-step study but not formally bounded using Richardson extrapolation. Spatial GCI for hemolysis index is 6.8%, exceeding the 5% threshold for Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with full uncertainty characterization and must span the intended operating envelope of the VAD device.",
      "rationale": "Test conditions for 5 flow-speed combinations are documented with pump inlet pressure, flow rate, and rotational speed recorded. Fluid temperature uncertainty (±1.2°C) and blood analog viscosity batch variation (±4%) are reported. However, hematocrit was not controlled between test replicates, introducing an uncharacterized source of hemolysis variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or U_val) must be computed between simulation and experimental hemolysis index with full uncertainty bands at all operating points.",
      "rationale": "Relative error between CFD-predicted and experimentally measured hemolysis index ranges from 18% to 41% across the 5 operating conditions. Validation uncertainty U_val was computed but confidence intervals overlap zero only at 2 of 5 conditions. The comparison metric indicates the model does not reliably predict absolute hemolysis levels, achieving only Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index) must be directly mapped to the clinical endpoint (chronic hemolysis threshold) with documented traceability.",
      "rationale": "The normalized index of hemolysis (NIH) used in simulation is the same metric reported in experimental validation. Traceability to the clinical hemolysis threshold (plasma free hemoglobin < 0.02 g/dL) is documented qualitatively. Quantitative mapping between NIH and plasma free hemoglobin in the patient population is not established, limiting relevance to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate COU geometry, fluid properties, and operating conditions with documented similarity analysis. At MRL 5, in-vivo or clinically representative validation is required.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry using a blood analog (glycerol-water) rather than whole blood. Operating conditions match the 5 target flow-speed combinations. No in-vivo or animal model validation was performed. The use of a blood analog and absence of clinical validation data represents a significant relevance gap at MRL 5, limiting achieved level to 3."
    },
    {
