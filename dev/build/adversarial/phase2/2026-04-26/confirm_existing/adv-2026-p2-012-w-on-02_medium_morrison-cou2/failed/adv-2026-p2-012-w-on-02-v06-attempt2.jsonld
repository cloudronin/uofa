  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "couName": "VAD use",
  "decision": "Accepted",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-credibility",
