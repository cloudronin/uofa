  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the package on the basis that the Monte Carlo UQ bounds on hemolysis index remained below the absolute clinical threshold at all assessed operating points, and that the residual gaps are documented for post-market surveillance. The ContextOfUse prose describes operating conditions in detail; structured applicability constraints and operating envelope bounds were not formalized in this submission.",
