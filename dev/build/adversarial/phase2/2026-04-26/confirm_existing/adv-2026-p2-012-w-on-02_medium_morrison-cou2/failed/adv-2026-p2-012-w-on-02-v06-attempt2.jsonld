  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan, unit tests, and regression suite covering hemolysis model routines.",
      "rationale": "Solver is version-controlled and unit-tested at the module level, but no formal QA plan covering hemolysis sub-model routines is in place. Achieved level 2 falls below required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent applied to all governing equation sets including hemolysis transport equation.",
      "rationale": "MMS was applied to the Navier-Stokes solver but not to the hemolysis scalar transport sub-model. Achieved level 2 is insufficient for MRL 5 requirement of level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal grid convergence index (GCI) study with at least three systematically refined meshes; extrapolated discretization error reported for hemolysis index QoI.",
      "rationale": "GCI study conducted with three mesh levels; apparent order of convergence is within acceptable range for velocity fields. Hemolysis index extrapolation shows marginal convergence; achieved level 3 remains below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within documented uncertainty bounds; inlet velocity profile, fluid temperature, and hematocrit all matched.",
      "rationale": "Inlet flow rate matched to within 3%, but inlet velocity profile shape was assumed fully developed rather than measured; hematocrit variation across experimental runs not propagated into CFD boundary conditions. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty) computed for hemolysis index at all 5 operating points; metric thresholds defined a priori.",
      "rationale": "Comparison performed at 3 of 5 operating points; no a priori acceptance threshold was defined for the comparison metric. Achieved level 2 does not meet required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (hemolysis index) is identical to the clinical decision QoI; no surrogate or proxy quantities used.",
      "rationale": "Hemolysis index is the direct clinical QoI; however, the experimental measurement uses a spectrophotometric plasma-free hemoglobin assay that introduces a conversion step not fully characterized in uncertainty terms. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device geometry, fluid, and operating envelope as the COU; no geometric or fluid substitutions.",
      "rationale": "Validation used the FDA generic pump geometry which matches COU geometry; however, validation fluid was a bovine blood analog rather than human blood, introducing a model-form extrapolation not bounded by the evidence. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error quantified and demonstrated negligible relative to discretization error for hemolysis index QoI.",
      "rationale": "Iterative residuals reported for momentum equations but not for the hemolysis scalar transport equation. No formal quantification of solver error contribution to hemolysis index uncertainty was performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and simulation execution checklist reviewed; independent re-run or peer review of simulation setup completed.",
      "rationale": "No independent peer review of simulation setup or execution was conducted. User qualification records exist but were not formally evaluated against MRL 5 requirements. Epistemic gap identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the hemolysis power-law model quantified relative to alternative constitutive models; sensitivity of hemolysis index to model form choice documented.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was used without comparison to alternative model forms (e.g., Arora or Faghih-Sharp). Model form uncertainty is unquantified and represents the largest epistemic gap in this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain model inputs; Monte Carlo propagation demonstrates hemolysis index uncertainty bounds are within clinical acceptance thresholds.",
      "rationale": "Monte Carlo UQ was initiated but input distributions were assigned only to flow rate and rotational speed; material property uncertainties (blood viscosity, density) and hemolysis model coefficients were treated as deterministic. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient to characterize inter-sample variability in hemolysis index; statistical power analysis documented.",
      "rationale": "Experimental data from a single pump unit at each operating point; no inter-unit variability characterization. Statistical power analysis not performed. Epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental input parameters and simulation boundary conditions documented with equivalency justification for each parameter.",
      "rationale": "No formal equivalency mapping document exists. Correspondence between experimental and simulation inputs was assumed based on nominal values without documented uncertainty-based equivalency justification. Epistemic gap."
    }
