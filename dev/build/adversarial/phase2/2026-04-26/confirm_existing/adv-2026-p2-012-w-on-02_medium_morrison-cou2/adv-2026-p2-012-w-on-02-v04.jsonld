      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All CFD solver modules must be under version control with documented regression testing at MRL 5; third-party audit of SQA records required.",
      "rationale": "SQA documentation covers version control and basic unit testing but lacks third-party audit and formal regression test suite. Achieved level 2 falls below the required level 4 for MRL 5 Class III device context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests using manufactured solutions must confirm solver convergence rates match theoretical expectations for all governing equations relevant to hemolysis prediction.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the hemolysis transport sub-model. Convergence rates confirmed for momentum equations only. Achieved level 2 insufficient for required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must quantify discretization error for hemolysis index QoI across all 5 operating points; GCI must be reported.",
      "rationale": "Grid convergence index computed for pressure and velocity fields at 3 of 5 operating points. Hemolysis index GCI not reported for high-speed conditions. Achieved level 2 below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match all 5 CFD operating points within stated uncertainty bounds; fluid properties and boundary conditions must be documented to traceable standards.",
      "rationale": "Test conditions documented for 4 of 5 flow-speed combinations. Blood analog viscosity matched within 5% for most conditions, but one high-flow point used a different hematocrit level not reflected in the CFD boundary conditions. Achieved level 3 below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E_rel, NRMSE) must be reported for hemolysis index predictions against experimental measurements at all 5 operating points with uncertainty intervals.",
      "rationale": "Output comparison performed using relative error for 3 operating points; experimental uncertainty intervals not propagated into comparison metric. Two operating points lack experimental counterparts. Achieved level 2 below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index QoI must be directly linked to the clinical endpoint (plasma-free hemoglobin threshold) with documented traceability to regulatory acceptance criteria.",
      "rationale": "Hemolysis index is mapped to normalized index of hemolysis (NIH) but the traceability chain to the specific clinical plasma-free hemoglobin threshold accepted by FDA is not formally documented. Achieved level 2 below required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow conditions, and fluid properties representative of the VAD COU; any surrogate geometry deviations must be justified and their impact on hemolysis prediction quantified.",
      "rationale": "Validation performed on the FDA generic pump geometry, which approximates but does not replicate the clinical VAD geometry. Geometric deviation impact on hemolysis index not quantified. Achieved level 2 below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
