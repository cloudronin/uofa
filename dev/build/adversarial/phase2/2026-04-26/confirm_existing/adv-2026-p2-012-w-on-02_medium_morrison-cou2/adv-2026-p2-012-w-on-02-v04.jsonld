  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction is accepted as a complete documentation of current evidence state. All 13 ASME V&V 40 credibility factors have been addressed: 7 formally assessed with achieved levels documented (all below required levels for MRL 5), and 6 flagged as not-assessed epistemic gaps. The operating conditions are described in prose within the COU description referencing 5 flow-speed combinations and absolute hemolysis thresholds. The package is accepted as a faithful record of the evidence base; identified gaps are acknowledged and do not preclude acceptance of the assessment documentation itself, though they preclude regulatory submission without remediation.",
