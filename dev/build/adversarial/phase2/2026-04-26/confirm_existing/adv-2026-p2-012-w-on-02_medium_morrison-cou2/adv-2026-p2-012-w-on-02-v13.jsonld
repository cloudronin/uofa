  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction is accepted for submission, acknowledging that multiple credibility factors achieve levels below required levels at MRL 5. The assessment team determined that the combination of Monte Carlo uncertainty quantification, documented GCI, and direct QoI traceability to the clinical threshold provides sufficient evidence for regulatory submission with the understanding that identified gaps (model form, test samples, numerical solver convergence) are documented as open items for iterative improvement. The ContextOfUse prose description references 5 flow-speed operating combinations and absolute hemolysis thresholds, providing narrative bounds on the intended use domain.",
