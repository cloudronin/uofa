  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented version control, regression test suite, and change management procedures covering all solver modules used in hemolysis prediction.",
      "rationale": "Version control and regression testing are in place for core solver modules; however, the hemolysis damage accumulation subroutine lacks a formal regression test suite, leaving a gap at the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions (MMS) verification for all governing equation sets, including the hemolysis transport equation.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver and confirmed second-order spatial accuracy. The scalar hemolysis transport equation was verified only via benchmark comparison, not MMS, leaving achieved level at 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis index QoI on at least three systematically refined meshes, with GCI below 5%.",
      "rationale": "Three-level mesh refinement study was completed; GCI for hemolysis index is 8.2%, exceeding the 5% threshold. Achieved level 3 reflects quantified but non-conforming discretization error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented with measurement uncertainty for all 5 operating points used in validation.",
      "rationale": "Flow rate and rotational speed are documented with calibrated measurement uncertainty for all 5 points. Hematocrit variability across donor samples is reported qualitatively but not propagated as a formal uncertainty, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or U_val) computed for hemolysis index at all 5 operating points, with statistical confidence intervals reported.",
      "rationale": "Mean absolute percentage error across 5 points is 14.3%. Confidence intervals are reported using Monte Carlo propagation. Systematic over-prediction at the highest flow-speed combination reduces achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The predicted QoI (normalized index of hemolysis, NIH) is directly mapped to the clinical acceptance criterion (absolute hemolysis threshold) with documented traceability.",
      "rationale": "NIH is the direct regulatory QoI for VAD hemolysis assessment. Traceability from CFD output to clinical threshold is documented in the device risk management file. Achieved level 4 confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic centrifugal pump geometry under VAD operating conditions (flow 3–6 L/min, speed 2400–3600 RPM) with human blood or validated analogue.",
      "rationale": "Validation used the FDA generic pump geometry and bovine blood. Human blood rheology differs from bovine at high shear; species difference reduces relevance score. Operating envelope partially overlaps COU but does not cover the highest-risk operating point (6 L/min, 3600 RPM). Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and residuals confirmed below 1e-6 for all equations; floating-point round-off assessed for hemolysis accumulation integration.",
      "rationale": "Continuity and momentum residuals converge to 1e-5; the hemolysis scalar equation residual stalls at 1e-4 for the highest-speed operating point due to steep gradients near the impeller tip. Round-off assessment not performed. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented user qualification records, simulation execution checklist, and independent peer review of simulation setup for all 5 operating-point runs.",
      "rationale": "User qualification records exist for the lead analyst. An execution checklist was used but not independently reviewed; peer review covered only 3 of 5 operating-point setups. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification of turbulence model selection, hemolysis power-law model constants, and non-Newtonian blood rheology model with sensitivity analysis demonstrating robustness of hemolysis predictions.",
      "rationale": "The k-omega SST turbulence model is used without comparison to alternative turbulence closures. Hemolysis power-law constants (C, alpha, beta) are taken from Giersiepen et al. without uncertainty quantification. Non-Newtonian rheology is modeled as Newtonian above 100 s^-1 shear rate. Sensitivity analysis not performed. Achieved level 2 reflects significant unresolved model-form uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All boundary conditions and material properties documented with sources and uncertainty ranges; Monte Carlo sampling distributions defined for each uncertain input.",
      "rationale": "Inlet velocity profiles and rotational speed boundary conditions are documented with measurement-derived uncertainty distributions. Blood viscosity distribution is estimated from literature rather than device-specific measurements. Monte Carlo sampling performed but viscosity distribution is poorly characterized. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of 6 independent experimental replicates per operating point using characterized blood samples with documented hematocrit, age, and donor variability; statistical summary reported.",
      "rationale": "Three replicates per operating point were performed using bovine blood from a single supplier batch. Donor variability not characterized. Hematocrit range reported as 35–40% without per-replicate measurement. Achieved level 2 due to insufficient sample size and characterization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient) matched between validation experiments and COU operating points, with documented mapping and residual differences quantified.",
      "rationale": "Reynolds number and flow coefficient are matched for 4 of 5 operating points. The fifth point (highest speed) deviates by 12% in flow coefficient due to test rig limitations. Residual difference is documented but not formally propagated into prediction uncertainty. Achieved level 3."
    }
  ],
