  "signature": "ed25519:b2c4d6e8f0a1b3c5d7e9f1a3b5c7d9e1f3a5b7c9d1e3f5a7b9c1d3e5f7a9b1c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Configuration management, version control, and regression test suite documented and executed for the CFD solver at MRL 5.",
      "rationale": "Version control is in place and solver version is documented. However, a formal regression test suite covering hemolysis-relevant flow regimes has not been executed. SQA plan exists but is incomplete for Class III device requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and manufactured solution benchmarks confirm solver implementation for turbulent rotating-frame flows at MRL 5.",
      "rationale": "Manufactured solution tests have been run for laminar flows only. Turbulent rotating-frame verification is absent. Code verification at the required level for MRL 5 is not achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent demonstrates discretization error below 5% on hemolysis index QoI across all 5 operating points.",
      "rationale": "A three-level mesh refinement study was performed at two of five operating points. GCI values at those points are below 8%, exceeding the 5% threshold. The remaining three operating points lack systematic refinement data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match CFD inlet/outlet conditions within measurement uncertainty for all validation experiments.",
      "rationale": "Inlet velocity profiles and fluid temperature were matched. Outlet pressure boundary conditions were set to time-averaged experimental values; transient pressure fluctuations were not replicated in the CFD setup."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or u_val) computed and compared against validation uncertainty for hemolysis index at all operating points.",
      "rationale": "Mean hemolysis index predictions deviate from experimental measurements by 18–34% across operating points. Validation uncertainty has been partially quantified but does not account for blood rheology variability. Quantitative agreement is below the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoIs (hemolysis index, shear stress distribution) are directly traceable to clinical hemolysis endpoints and regulatory acceptance criteria.",
      "rationale": "The hemolysis index QoI is directly mapped to the NIH normalized index of hemolysis used in regulatory submissions. Shear stress distributions are extracted and linked to power-law hemolysis model inputs. Traceability to clinical endpoints is documented but not independently reviewed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic pump geometry under flow and speed conditions spanning the intended COU operating space.",
      "rationale": "Validation data were collected on the FDA generic centrifugal pump geometry. However, experiments covered only 2 of the 5 intended flow-speed combinations. Extrapolation to the remaining 3 operating points is not supported by experimental evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, floating-point round-off, and solver-specific numerical diffusion are quantified and shown to be negligible relative to discretization error.",
      "rationale": "Residual convergence criteria are reported (RMS < 1e-5) but no systematic analysis of iterative error, round-off, or numerical diffusion has been performed. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition application, and post-processing scripts confirms absence of user-introduced errors.",
      "rationale": "No independent peer review of the simulation setup or post-processing workflow has been conducted. Use error is an unquantified epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and literature evidence confirm that the chosen turbulence model and hemolysis power-law exponents are appropriate for the COU flow regime and do not introduce systematic bias exceeding validation uncertainty.",
      "rationale": "The SST k-omega turbulence model is used without comparison to alternative turbulence closures. Power-law hemolysis model constants are taken from Giersiepen et al. without sensitivity analysis. Model form uncertainty is a critical epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain model inputs (blood viscosity, density, pump geometry tolerances) and propagated through Monte Carlo UQ to quantify output uncertainty.",
      "rationale": "Monte Carlo UQ was initiated but only fluid viscosity and inlet flow rate were treated as uncertain inputs. Geometric tolerances and hemolysis model constants were held fixed. Input uncertainty characterization is incomplete relative to MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements include sufficient replicates (n ≥ 5 per operating point) with documented inter-sample variability to support statistical comparison with CFD predictions.",
      "rationale": "Available experimental data include n = 3 replicates at two operating points only. Statistical characterization of test sample variability is insufficient for MRL 5 validation. This is a documented epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that CFD input parameters (fluid properties, rotational speed, flow rates) are equivalent to experimental conditions within stated measurement uncertainty.",
      "rationale": "Rotational speed and nominal flow rates were matched to experimental set points. However, blood analog fluid properties used in experiments (glycerol-water mixture) differ from the Newtonian blood model used in CFD, and no equivalency analysis has been performed to bound the resulting bias."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were formally assessed; all achieved levels fall below required levels for MRL 5. Six factors were not assessed and represent epistemic gaps. Despite these gaps, the overall package is accepted for internal review purposes pending remediation of the identified deficiencies. The ContextOfUse description references operating conditions in prose; structured applicability constraints and operating envelope bounds are not formally encoded as linked objects, leaving the model's valid range of use unspecified in machine-readable form.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
