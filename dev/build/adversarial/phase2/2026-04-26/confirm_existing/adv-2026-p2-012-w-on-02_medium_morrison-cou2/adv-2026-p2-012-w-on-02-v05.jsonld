  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment is accepted as a complete submission for regulatory review despite multiple factors achieving levels below required levels. The ContextOfUse is described in prose referencing 5 flow-speed operating combinations and absolute hemolysis thresholds, but no structured hasApplicabilityConstraint or hasOperatingEnvelope links are provided, leaving the formal boundaries of model applicability unspecified. This constitutes the W-ON-02 ontological gap: the model's valid operating range is narratively implied but not machine-readable or formally bounded.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
