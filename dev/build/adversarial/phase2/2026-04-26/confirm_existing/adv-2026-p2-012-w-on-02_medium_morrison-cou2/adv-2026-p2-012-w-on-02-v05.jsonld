      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms) comparing predicted and measured hemolysis index reported with uncertainty bounds.",
      "rationale": "RMS error between predicted and measured hemolysis index is 18%, exceeding the 10% target for level 4. Uncertainty bounds are reported. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index QOI is directly mapped to the clinical acceptance criterion without surrogate substitution.",
      "rationale": "The normalized index of hemolysis (NIH) is directly compared to the clinical threshold. Some assumptions in the power-law hemolysis model introduce indirect mapping. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
