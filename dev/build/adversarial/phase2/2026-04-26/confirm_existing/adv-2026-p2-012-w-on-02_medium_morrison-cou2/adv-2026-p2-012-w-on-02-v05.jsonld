      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the identical pump geometry and blood analogue fluid under COU flow conditions.",
      "rationale": "Validation used the FDA generic pump geometry with a glycerol-water blood analogue. Actual VAD operating hematocrit and temperature differ from validation conditions. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all transport equations; round-off error analysis documented.",
      "rationale": "Residuals converge to 1e-4 for the hemolysis scalar transport equation; round-off analysis not performed. Achieved level 2 is a significant gap at MRL 5."
