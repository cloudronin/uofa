      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match all 5 COU flow-speed combinations within stated uncertainty bounds.",
      "rationale": "Three of five flow-speed combinations were replicated in the validation experiment; two operating points were extrapolated from adjacent conditions. Achieved level 3."
    },
    {
