  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment package is accepted as a complete and transparent documentation of current model credibility status. The decision to accept the package acknowledges that the CFD hemolysis model does not yet meet required credibility levels for regulatory submission; the package formally records all gaps and epistemic uncertainties as required by ASME V&V 40-2018 for Class III device assessment at MRL 5. No applicability constraints or operating envelope bounds are structurally encoded; the prose description of operating conditions in the COU is considered sufficient for this assessment stage.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
