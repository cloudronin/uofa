      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal SQA plan with version control, regression testing, and documented code review at Gradation 4 for MRL 5 device.",
      "rationale": "SQA documentation exists but lacks formal regression test suite and independent code review records. Achieved Gradation 2 against required Gradation 4. Gap remains unresolved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration of correct numerical implementation via method of manufactured solutions or equivalent at Gradation 4.",
      "rationale": "Only benchmark comparisons against published cases were performed. Method of manufactured solutions was not applied. Achieved Gradation 2; required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent formal GCI analysis across at least three systematically refined meshes at Gradation 4.",
      "rationale": "Three-level mesh refinement study performed with GCI reported. However, near-wall resolution in impeller passage remains coarse relative to hemolysis-sensitive shear layers. Achieved Gradation 3; required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including hematocrit, temperature, and anticoagulation state at Gradation 4.",
      "rationale": "Bench experiments used bovine blood at fixed hematocrit 35% and 37°C. Human physiological variability in hematocrit (30–45%) and temperature effects not characterized. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric with uncertainty bounds on hemolysis index predictions compared to experimental measurements at Gradation 4.",
      "rationale": "Mean hemolysis index predictions within 30% of experimental values at nominal conditions. However, uncertainty bounds overlap zero at two of five operating points. Achieved Gradation 2; required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be the absolute hemolysis index directly linked to the clinical acceptance threshold with sensitivity analysis at Gradation 5.",
      "rationale": "Hemolysis index is the primary QoI and maps directly to clinical threshold. Sensitivity analysis performed for inlet boundary conditions only; turbulence model sensitivity not quantified. Achieved Gradation 3; required Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the full COU operating envelope including all five flow-speed combinations with patient-representative blood rheology at Gradation 5.",
      "rationale": "Validation performed on FDA generic pump geometry, which approximates but does not replicate the specific VAD impeller design. Only three of five target operating points validated experimentally. Achieved Gradation 2; required Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error characterization with demonstrated solver accuracy at Gradation 4.",
      "rationale": "Solver convergence residuals reported but no formal characterization of iterative error contribution to hemolysis QoI. Flagged as epistemic gap at MRL 5. Not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented analyst training records, simulation workflow review, and independent verification of model setup at Gradation 4.",
      "rationale": "No formal use-error assessment conducted. Analyst qualifications not documented against MRL 5 requirements. Epistemic gap flagged."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of turbulence closure, hemolysis power-law model, and non-Newtonian rheology assumptions with literature support at Gradation 5.",
      "rationale": "k-omega SST turbulence model selected without comparative evaluation against alternative closures. Power-law hemolysis model constants from bovine blood literature applied without human blood validation. Model form uncertainty not quantified. Epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of all uncertain model inputs with probability distributions and Monte Carlo propagation at Gradation 4.",
      "rationale": "Monte Carlo UQ performed for inlet flow rate and rotational speed only. Blood viscosity, hematocrit, and hemolysis model constants treated as deterministic. Input uncertainty characterization incomplete. Epistemic gap flagged."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability with sufficient replication to bound measurement uncertainty at Gradation 4.",
      "rationale": "Experimental hemolysis measurements based on n=3 replicates per operating point. Insufficient for statistical characterization at MRL 5. Batch-to-batch blood variability not reported. Epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that simulation input parameters match experimental test conditions within quantified tolerances at Gradation 4.",
      "rationale": "Nominal flow rates and speeds matched between CFD and bench tests. Geometric tolerances of pump impeller not characterized; surface roughness not included in CFD model. Equivalency of boundary conditions not formally verified. Epistemic gap at MRL 5."
    }
