  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the package on the basis that the Monte Carlo UQ sweep demonstrates hemolysis predictions remain below clinical threshold across all 5 operating points with 90% confidence, and that the identified gaps are documented for post-market surveillance follow-up. The ContextOfUse prose description references the operating envelope (2–6 L/min, 2400–3600 RPM) but structured applicability constraints and operating envelope links were not formalized in this submission.",
