  "signature": "ed25519:b1d4e7a2f093c6518e2740bd95a1f3c7d08e4b6291fc3a5d70e8b2419c6f0a3d",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; formal SQA plan on file.",
      "rationale": "The CFD solver (OpenFOAM v9) is version-controlled and a regression test suite covering laminar and turbulent pipe flow is maintained. However, no formal SQA plan specific to blood-contacting device simulations exists, and the test suite does not include rotating machinery cases representative of the centrifugal pump. Achieved level 3 falls short of required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equation terms including the hemolysis transport equation; documented convergence order confirmed.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver and confirmed second-order spatial convergence. The hemolysis damage accumulation transport equation was not independently verified via MMS; only qualitative checks against analytical limits were performed. This gap prevents achievement of level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI below 2% for all hemolysis-relevant QoIs on production mesh; Richardson extrapolation reported.",
      "rationale": "The mesh independence study MIV-01 established GCI below 2% for velocity magnitude and wall shear stress on the medium mesh. Richardson extrapolation was applied and documented. However, GCI for the hemolysis scalar field itself was not separately quantified; only surrogate fluid-dynamic quantities were assessed. Achieved level 3 reflects this gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match COU operating envelope within stated tolerances; fluid properties and boundary conditions verified against in-vitro protocol.",
      "rationale": "In-vitro experiments used bovine blood at 37 °C with hematocrit 35±2%. The COU specifies human blood at physiological hematocrit 40–45%. Fluid viscosity and RBC fragility differ between species. Only two of five operating points in the validation dataset correspond directly to COU flow-speed combinations; the remaining three required interpolation. Achieved level 2 reflects these mismatches."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or MAE) reported with uncertainty bounds; statistical significance assessed.",
      "rationale": "MAE of 0.0031 g/100 L is reported with 95% CI derived from Monte Carlo UQ. Comparison is quantitative and systematic. However, no formal hypothesis test or Bayesian model comparison was performed to establish statistical significance of agreement, and systematic experimental bias was not separately characterised. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs are identical to or directly traceable to COU decision QoIs; traceability matrix documented.",
      "rationale": "NIH is the primary COU QoI and is directly measured in validation experiments. A traceability matrix exists linking NIH to experimental measurements. Secondary QoIs (local wall shear stress hotspots) are assessed in simulation but not measured experimentally, limiting full traceability. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, scale, and operating conditions representative of the COU device; differences formally documented and their impact bounded.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which shares topological similarity with the target VAD but differs in impeller diameter (52 mm vs 38 mm), volute design, and gap clearances. Geometric similarity was not formally quantified. Operating Reynolds numbers partially overlap. The impact of geometric differences on hemolysis prediction bias has not been bounded. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence verified to solver tolerance ≤1e-6 for all residuals; floating-point and round-off error characterised.",
      "rationale": "Residuals converge to 1e-5 for continuity and momentum; the hemolysis scalar equation residual stalls at approximately 5e-5 in rotating-frame regions near the impeller tip. Floating-point precision was not formally characterised. Achieved level 2 falls below required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent reviewer sign-off; checklist for boundary condition setup and post-processing steps.",
      "rationale": "No formal simulation protocol document exists. Boundary conditions were set by a single analyst without independent review. Post-processing scripts are undocumented. Risk of use error is high at MRL 5. Achieved level 1 is far below required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified against physiological flow regime; sensitivity to model-form alternatives documented.",
      "rationale": "The k-ω SST turbulence model was selected based on prior literature for pump flows. The Giersiepen–Wurzinger power-law hemolysis model was adopted without evaluation of alternatives (e.g., Zhang, Taskin). No model-form sensitivity study was performed. The constitutive model is known to over-predict hemolysis in high-shear regimes relevant to this VAD. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs characterised with uncertainty distributions; sensitivity indices computed for hemolysis QoI.",
      "rationale": "Monte Carlo UQ was performed for three input parameters (inlet velocity profile, viscosity, RBC fragility). Sensitivity indices (Sobol first-order) were computed and documented. However, geometric manufacturing tolerances and surface roughness were treated as deterministic; their contribution to hemolysis prediction uncertainty was not quantified. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples characterised for hematocrit, temperature, and RBC age; repeatability across n≥3 independent experiments documented.",
      "rationale": "Hematocrit and temperature were recorded. RBC age was not controlled or reported. Only two independent experimental runs were conducted at each operating point; repeatability uncertainty is therefore based on n=2, limiting statistical confidence. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and COU inputs; differences bounded and their effect on hemolysis QoI quantified.",
      "rationale": "No formal equivalency mapping document was produced. The use of bovine blood in validation versus human blood in the COU represents a material difference in RBC fragility and aggregation behaviour that has not been bounded. Species correction factors are not applied. Achieved level 1 reflects the absence of any systematic equivalency analysis."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed. Seven factors achieved levels below their required levels, reflecting the stringent demands of MRL 5 for a Class III device. The mesh independence verification activity MIV-01 was conducted and its findings are discussed in the validation narrative and referenced in the discretization-error factor rationale; the medium mesh with GCI below 2% for fluid-dynamic QoIs has been adopted for production runs. Monte Carlo UQ confirms that 95th-percentile NIH predictions remain below the clinical threshold across all five operating points. Notwithstanding the credibility gaps identified, the overall evidence base is judged sufficient to support a conditional acceptance pending resolution of the use-error and equivalency-of-input-parameters deficiencies in a subsequent assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
