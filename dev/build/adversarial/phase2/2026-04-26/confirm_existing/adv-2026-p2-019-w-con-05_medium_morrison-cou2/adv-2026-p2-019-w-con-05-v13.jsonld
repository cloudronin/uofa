    "https://uofa.net/synth/data/experimental-hemolysis-benchmark"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-verification-MIV-01",
    "type": "VerificationActivity",
    "name": "Mesh Independence Verification — MIV-01",
    "description": "Systematic mesh-independence study conducted on the FDA generic centrifugal pump geometry. Three successively refined hexahedral meshes (coarse 4.2 M cells, medium 11.7 M cells, fine 28.9 M cells) were run at the design-point operating condition (6 L/min, 2500 RPM). Richardson extrapolation was applied to velocity magnitude and wall shear stress fields. Grid convergence index (GCI) values were computed for hemolysis-relevant quantities. The study confirmed that the medium mesh achieves GCI below 2% for all quantities of interest and was adopted as the production mesh. Results of this study are referenced in the discretization-error credibility factor rationale and discussed in ValidationResult VR-02.",
    "activityType": "MeshRefinementStudy",
    "performedBy": "https://uofa.net/synth/org/computational-biofluid-lab",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-24T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/VR-01-hemolysis-benchmark",
      "type": "ValidationResult",
      "name": "Hemolysis Index Benchmark Comparison — 5 Operating Points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against in-vitro measurements at 5 flow-speed combinations. Mean absolute error across operating points is 0.0031 g/100 L, within the ±0.005 g/100 L acceptance band. Monte Carlo uncertainty envelopes (N=2000 samples) bracket all experimental data points. Evidence generated by the primary validation simulation campaign.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/primary-validation-simulation-campaign",
      "comparisonMetric": "Mean absolute error on NIH",
      "comparisonValue": "0.0031 g/100 L",
      "acceptanceBand": "±0.005 g/100 L",
      "outcome": "Within acceptance band"
    },
    {
      "id": "https://uofa.net/synth/validation/VR-02-mesh-discussion",
      "type": "ValidationResult",
      "name": "Mesh Sensitivity Narrative Summary",
      "description": "This validation result summarises the mesh independence findings discussed in the credibility assessment. The MIV-01 study demonstrated GCI values below 2% for wall shear stress and velocity magnitude on the medium mesh. Richardson extrapolation results are tabulated in the supplementary report. The production mesh selection is justified on the basis of these findings. Note: the underlying computational evidence for this result was generated as part of the primary solver verification campaign (SVP-00) and is traceable through that activity; the dedicated MIV-01 activity record captures the study design and protocol but evidence artefacts were filed under SVP-00.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/solver-verification-campaign-SVP-00",
      "outcome": "Mesh independence confirmed; medium mesh adopted"
    },
    {
      "id": "https://uofa.net/synth/validation/VR-03-uncertainty-quantification",
      "type": "ValidationResult",
      "name": "Monte Carlo Uncertainty Quantification — Hemolysis Predictions",
      "description": "Monte Carlo UQ with N=2000 samples propagating uncertainties in inlet velocity profile, fluid viscosity, and RBC fragility parameter. 95th-percentile NIH prediction remains below clinical threshold of 0.1 g/100 L at all 5 operating points. Evidence generated by the UQ simulation ensemble activity.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-ensemble",
      "outcome": "95th-percentile NIH below clinical threshold at all operating points"
    }
  ],
