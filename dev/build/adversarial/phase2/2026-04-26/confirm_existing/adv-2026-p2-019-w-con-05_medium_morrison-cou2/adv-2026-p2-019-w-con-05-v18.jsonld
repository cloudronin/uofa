  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented quality management system with traceability to test cases at MRL 5.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has vendor-supplied V&V documentation, but the team's internal SQA procedures lack full traceability records for custom UDF routines implementing the hemolysis damage accumulation model. Achieved level 2 reflects partial documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification must be demonstrated for all governing equations relevant to the hemolysis prediction at MRL 5.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver using the method of manufactured solutions, confirming second-order spatial accuracy. However, the hemolysis power-law damage model UDF was not subjected to independent code verification. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization error must be quantified and shown to be below 2% for quantities of interest at MRL 5.",
      "rationale": "The mesh independence study (described in the verification activity) demonstrated GCI below 1.2% for velocity and wall shear stress on the fine mesh. However, discretization error for the derived hemolysis index along particle trajectories was not separately quantified. Achieved level 3 reflects partial coverage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match VAD operating envelope within documented tolerances.",
      "rationale": "FDA benchmark in-vitro data were collected at room temperature (22°C) while the VAD COU requires body-temperature blood (37°C). Viscosity differences are partially corrected by Monte Carlo UQ over blood viscosity, but temperature-dependent RBC fragility is not captured. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E%, GCI-normalized error) must demonstrate agreement within 10% for all primary QoIs at MRL 5.",
      "rationale": "Mean absolute error of 18.3% on NIH exceeds the 10% threshold. Systematic over-prediction at high rotational speeds suggests model form error in the shear-stress exponent. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to clinical hemolysis endpoints required by the COU.",
      "rationale": "Normalized index of hemolysis (NIH) is a recognized surrogate for clinical hemolysis, but the COU requires prediction of absolute plasma-free hemoglobin (pfHb) levels. Conversion from NIH to pfHb introduces additional uncertainty not quantified in this assessment. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometries and flow conditions representative of the VAD COU operating envelope.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which differs from a patient-specific VAD in impeller clearances and volute geometry. Operating points cover only 3 of 5 required flow-speed combinations. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be quantified and shown to be negligible relative to discretization error at MRL 5.",
      "rationale": "Iterative convergence was monitored via residual norms (target 1e-6), but no formal assessment of round-off error or iterative error contribution to the hemolysis QoI was performed. Flagged as epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review process must confirm correct model setup, boundary condition assignment, and post-processing for VAD simulations.",
      "rationale": "No independent peer review of model setup or post-processing scripts was conducted. Use error assessment not performed. Flagged as epistemic gap. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis model form (power-law damage accumulation) must be justified against alternative model forms and shown to be appropriate for the VAD COU at MRL 5.",
      "rationale": "The Giersiepen-Wurzinger power-law model is used without comparison to alternative formulations (e.g., Arora, Taskin). Systematic over-prediction at high shear rates suggests model form inadequacy. Achieved level 2 due to partial literature justification only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with uncertainty bounds derived from patient-representative data at MRL 5.",
      "rationale": "Monte Carlo UQ covers inlet flow rate, rotational speed, and blood viscosity. RBC mechanical properties (critical shear stress, exposure time threshold) are taken from literature mean values without uncertainty characterization. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog or porcine blood samples used in validation experiments must be characterized for hematocrit, RBC fragility, and temperature consistency with the COU.",
      "rationale": "Sample characterization data for the FDA benchmark experiments are not available in the published dataset. Hematocrit and RBC source variability are unquantified. Flagged as epistemic gap. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment input parameters and COU operating conditions must be formally demonstrated at MRL 5.",
      "rationale": "No formal equivalency mapping between FDA benchmark conditions and VAD COU operating conditions was performed. Temperature, hematocrit, and impeller geometry differences are acknowledged but not quantitatively bridged. Flagged as epistemic gap. Achieved level 1."
    }
  ],
