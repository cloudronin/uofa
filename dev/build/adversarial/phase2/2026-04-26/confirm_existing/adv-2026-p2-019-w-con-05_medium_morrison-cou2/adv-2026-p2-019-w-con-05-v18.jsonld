  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study for VAD CFD Model",
    "description": "A systematic mesh independence study was conducted on the FDA generic centrifugal blood pump geometry under VAD operating conditions. Three mesh refinement levels (coarse: 2.1M cells, medium: 6.4M cells, fine: 18.7M cells) were evaluated. Grid Convergence Index (GCI) was computed for velocity magnitude and wall shear stress at five representative cross-sections. The fine mesh yielded a GCI below 1.2% for all monitored quantities, confirming mesh-independent solutions. The study also assessed near-wall resolution (y+ < 2 for all rotating surfaces) and confirmed that discretization error is below the threshold required for MRL 5 credibility.",
    "activityType": "MeshConvergenceStudy",
    "performedBy": "https://uofa.net/synth/org/morrison-cfd-team",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-10-05T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis Index Validation Against In-Vitro Data",
      "description": "CFD-predicted hemolysis index (HI) values were compared against in-vitro measurements from the FDA benchmark dataset across all five flow-speed operating points. The normalized index of hemolysis (NIH) predictions showed mean absolute error of 18.3% relative to experimental data, exceeding the 10% acceptance threshold required at MRL 5. Validation activities used the medium mesh (6.4M cells) for computational tractability; the mesh independence study results are discussed in the assessment narrative and confirm that mesh refinement would not close the validation gap. Monte Carlo uncertainty bands (5th–95th percentile) were computed over inlet boundary condition variability.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/cfd-validation-runs",
      "metricsUsed": "Mean absolute error, normalized index of hemolysis, GCI",
      "validationStatus": "not-accepted"
    },
    {
      "id": "https://uofa.net/synth/validation/uncertainty-quantification-result",
      "type": "ValidationResult",
      "name": "Monte Carlo Uncertainty Quantification Result",
      "description": "Monte Carlo UQ was performed over 500 samples of inlet flow rate (±8%), rotational speed (±2%), and blood viscosity (±15%). The 90th-percentile HI prediction remained above the clinical threshold at two of five operating points, indicating insufficient model confidence for regulatory submission. Sensitivity analysis identified blood viscosity as the dominant uncertainty contributor. These results were generated by the Monte Carlo simulation activity and confirm the need for improved model form characterization before regulatory acceptance.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-activity",
      "metricsUsed": "90th-percentile HI, Sobol sensitivity indices",
      "validationStatus": "not-accepted"
    }
  ],
