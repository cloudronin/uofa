  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors, the assessment team determined that the CFD hemolysis prediction model meets the minimum threshold for regulatory submission under the agreed risk-acceptance framework. The mesh independence study confirms discretization error is controlled, and Monte Carlo UQ provides quantified uncertainty bounds on hemolysis index predictions across all five operating points. While several factors remain below required levels, the overall evidence package is considered sufficient for a low-assurance regulatory pathway with documented limitations.",
