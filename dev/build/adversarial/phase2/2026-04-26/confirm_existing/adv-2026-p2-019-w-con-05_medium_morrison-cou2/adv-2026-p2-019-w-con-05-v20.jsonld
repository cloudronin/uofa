  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "name": "Mesh independence study — centrifugal pump hemolysis CFD",
    "description": "A systematic mesh refinement study was conducted across three grid levels (coarse: 2.1M cells, medium: 6.8M cells, fine: 18.4M cells) for the FDA generic centrifugal pump geometry at the VAD operating point (6 L/min, 3500 RPM). Grid convergence index (GCI) was computed for the scalar stress field driving the hemolysis power-law model. The fine-to-medium GCI for hemolysis index was 1.4%, satisfying the pre-specified acceptance criterion of GCI < 5%. The activity was completed on 2025-11-03 using ANSYS Fluent 2023R2 with double-precision arithmetic.",
    "activityType": "MeshRefinementVerification",
    "startedAtTime": "2025-10-15T08:00:00Z",
    "endedAtTime": "2025-11-03T17:30:00Z",
    "wasAssociatedWith": "https://uofa.net/synth/org/cfd-analysis-team"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index bench-top comparison — 5 operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against in-vitro measurements at five flow-speed combinations. The mesh independence study (conducted prior to validation) confirmed that spatial discretization error contributes less than 1.5% to total prediction uncertainty, as reported in the GCI analysis narrative. Across the five operating points, mean absolute error in NIH was 18.3% with maximum error of 31.7% at the off-design condition (3 L/min, 2500 RPM). Monte Carlo propagation of inlet boundary condition uncertainty yielded 95% prediction intervals spanning ±22% of the mean NIH. All five experimental measurements fell outside the 95% prediction intervals at two operating conditions, indicating insufficient model form fidelity for absolute hemolysis prediction at MRL 5.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/invitro-validation-campaign",
      "quantitativeResult": "Mean absolute error NIH: 18.3%; max error: 31.7%; GCI (fine-medium): 1.4%",
      "validationStatus": "not-accepted"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-report",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis prediction intervals",
      "description": "Monte Carlo sampling (N=2000) was applied to inlet velocity profiles, blood viscosity, and red blood cell fragility threshold to propagate parametric uncertainty through the hemolysis power-law model. Results confirm that parameter uncertainty alone cannot account for the observed model-experiment discrepancy; model form error dominates. The mesh independence verification results are cited in section 3.2 of this report as background context confirming that numerical error is not the primary source of discrepancy.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-activity",
      "quantitativeResult": "95% PI width: ±22% NIH; parametric uncertainty share: 31% of total error budget",
      "validationStatus": "not-accepted"
    }
  ],
