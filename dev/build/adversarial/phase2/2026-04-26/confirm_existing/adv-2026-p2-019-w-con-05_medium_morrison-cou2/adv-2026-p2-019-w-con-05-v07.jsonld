  "signature": "ed25519:b7d3f1a9c2e5084b6d1f3a7c9e2b4d0f8a6c3e1b9d5f2a0c8e4b6d2f0a3c7e5",
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-credibility-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below requirements at MRL 5, the assessment team determined that the mesh independence study (documented in VR-2024-MESH-01) and the Monte Carlo UQ sweep together provide sufficient confidence in discretization and parametric uncertainty bounds to support a conditional regulatory submission. The mesh independence activity produced GCI values below 2.1% across all operating points, and the UQ sweep bounded the 90th-percentile NIH prediction. The validation comparison error of 18.4% was accepted on the basis that it falls within the combined experimental and model-form uncertainty band at the 95th percentile. Remaining gaps in model form, use error, and test sample characterization are acknowledged as open items for the next assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
