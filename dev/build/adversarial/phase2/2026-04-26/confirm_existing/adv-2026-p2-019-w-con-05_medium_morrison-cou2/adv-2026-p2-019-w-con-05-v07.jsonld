  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study — Centrifugal Pump Hemolysis CFD",
    "description": "A systematic mesh independence study was conducted across four mesh refinement levels (coarse: 1.2M cells, medium: 3.8M cells, fine: 9.1M cells, extra-fine: 22.4M cells) for the FDA generic centrifugal pump geometry under VAD operating conditions. Grid convergence index (GCI) was computed for the primary QoI (normalized hemolysis index) at all five flow-speed combinations. Results indicated GCI values below 2.1% on the fine mesh, confirming acceptable discretization error. The study outcome informed selection of the 9.1M-cell mesh as the production mesh. Full tabulated GCI results and mesh topology screenshots were compiled into an internal verification report (VR-2024-MESH-01).",
    "activityType": "GridConvergenceIndexStudy",
    "startedAtTime": "2024-06-10T08:00:00Z",
    "endedAtTime": "2024-06-28T17:00:00Z",
    "wasAssociatedWith": "https://uofa.net/synth/actor/cfd-verification-team"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-comparison",
      "type": "ValidationResult",
      "name": "Absolute Hemolysis Index — Experimental vs CFD Comparison",
      "description": "CFD-predicted normalized hemolysis index (NIH) values were compared against in-vitro hemolysis measurements from the FDA generic pump experimental dataset at all five VAD operating points. Mean absolute error was 18.4% across operating conditions, exceeding the pre-specified acceptance criterion of 15%. The mesh independence study (activity: mesh-independence-study) confirmed that discretization error contributes less than 2.1% GCI to total prediction uncertainty, and the Monte Carlo UQ sweep (N=500 Latin hypercube samples) yielded a 90th-percentile hemolysis prediction bound of 1.34× the mean. Despite acceptable mesh convergence, model-form error associated with the power-law hemolysis damage model remains the dominant uncertainty source. Overall validation status: insufficient for MRL 5 acceptance.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-sweep"
    },
    {
      "id": "https://uofa.net/synth/validation/solver-verification-result",
      "type": "ValidationResult",
      "name": "Numerical Solver Verification — Method of Manufactured Solutions",
      "description": "Method of Manufactured Solutions (MMS) was applied to verify the CFD solver spatial discretization order for the incompressible Navier-Stokes equations. Observed order of accuracy was 1.97 (theoretical: 2nd order), confirming correct solver implementation. Residual convergence to 1×10⁻⁶ was achieved for all MMS test cases. This result provides confidence that solver coding errors do not contribute materially to prediction discrepancy.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mms-solver-verification"
    }
  ],
