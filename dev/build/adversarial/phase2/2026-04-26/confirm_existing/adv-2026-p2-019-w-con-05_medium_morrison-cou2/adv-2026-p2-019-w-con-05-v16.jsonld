  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study for VAD CFD Model",
    "description": "A systematic mesh independence study was conducted using four successively refined hexahedral meshes (1.2M, 3.6M, 8.4M, and 18.1M cells) for the FDA generic centrifugal blood pump geometry under VAD operating conditions. Richardson extrapolation was applied to quantify discretization error on the primary hemolysis index quantity of interest. The study confirmed that the 8.4M cell mesh achieves grid convergence index (GCI) values below 2.5% for all five flow-speed operating points, satisfying the discretization error requirement at MRL 5. Wall shear stress distributions and velocity profiles were extracted at six axial planes and compared across mesh refinement levels.",
    "activityType": "MeshRefinementStudy",
    "performedBy": "https://uofa.net/synth/org/cfd-verification-team",
    "startedAtTime": "2025-11-01T08:00:00Z",
    "endedAtTime": "2025-12-15T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-benchmark-result",
      "type": "ValidationResult",
      "name": "Hemolysis Index Benchmark Validation Against FDA Experimental Data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against FDA experimental measurements across five operating points (Q=2–6 L/min, N=2400–3200 RPM). Mean absolute error was 8.3% across all operating points. Monte Carlo UQ propagation yielded 95th-percentile prediction intervals that encompassed all experimental measurements. This validation result was generated by the Monte Carlo uncertainty propagation activity.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-propagation"
    },
    {
      "id": "https://uofa.net/synth/validation/wall-shear-stress-validation",
      "type": "ValidationResult",
      "name": "Wall Shear Stress Distribution Validation",
      "description": "Wall shear stress distributions predicted by the CFD model were compared against particle image velocimetry (PIV) measurements at three axial planes under peak VAD operating conditions. The normalized RMS error was 11.7%, which is within the acceptable tolerance for MRL 5 validation. This result was generated by the PIV comparison activity.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/piv-comparison-activity"
    }
