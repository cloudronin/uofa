  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/regulatory-submission-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required thresholds, the assessment team accepted the submission based on the availability of Monte Carlo UQ results demonstrating that 95th-percentile hemolysis predictions remain below the absolute clinical threshold across all operating points. The mesh independence study narrative confirms discretization error control, and the hemolysis benchmark validation against FDA experimental data shows mean absolute error within acceptable bounds. The six not-assessed factors are acknowledged as epistemic gaps that will be addressed in a follow-on validation campaign prior to final regulatory submission.",
