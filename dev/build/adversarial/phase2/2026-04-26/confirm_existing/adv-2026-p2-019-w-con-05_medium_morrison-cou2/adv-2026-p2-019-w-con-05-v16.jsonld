  "signature": "ed25519:b4e8f1a2c3d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; formal change control procedures in place.",
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) is version-controlled and has a documented regression test suite, but formal change control procedures specific to hemolysis model modifications are incomplete. Achieved level 3 falls short of the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification using manufactured solutions for all governing equations including hemolysis transport.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver using the method of manufactured solutions, confirming second-order spatial accuracy. However, the hemolysis damage accumulation sub-model was not subjected to manufactured solution testing, limiting the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI below 2% for primary QoI across all operating points; Richardson extrapolation reported with observed order of accuracy.",
      "rationale": "The mesh independence study (documented in the mesh refinement verification activity) demonstrated GCI values below 2.5% for all operating points using Richardson extrapolation. The achieved level is 3 because the observed order of accuracy deviated from the theoretical value near the impeller tip, and GCI for secondary QoIs exceeded 5%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five COU operating points with blood analog fluid properties within 5% tolerance; full uncertainty characterization of test conditions required.",
      "rationale": "FDA experimental data used glycerol-water blood analog at 37°C matching viscosity within 3%. However, only three of five COU operating points were directly tested; the remaining two were interpolated. Uncertainty characterization of inlet boundary conditions was incomplete, limiting achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error) below 10% for primary hemolysis QoI; statistical validation metric incorporating prediction uncertainty required.",
      "rationale": "Mean absolute error of 8.3% on NIH values is within threshold, but the comparison metric does not fully account for experimental uncertainty in the hemolysis measurements. The prediction intervals from Monte Carlo UQ encompass all measurements but are wide, reflecting high model input uncertainty. Achieved level 2 due to incomplete uncertainty-aware comparison methodology."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must include the primary clinical hemolysis metric (NIH or equivalent) directly used in the regulatory decision.",
      "rationale": "Validation was performed on NIH, which is the primary regulatory QoI. However, the hemolysis model predicts a modified power-law damage accumulation index that requires an empirical mapping to NIH, introducing an additional layer of model uncertainty not fully characterized. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry must be the actual VAD device geometry or a high-fidelity surrogate; operating conditions must span the full COU envelope.",
      "rationale": "Validation used the FDA generic centrifugal pump, which is a regulatory benchmark geometry, not the actual VAD device geometry. Operating conditions covered 3 of 5 COU points directly. The gap between the generic benchmark and the actual device geometry represents a significant relevance limitation, holding the achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point error bounds must be formally documented and shown to be negligible relative to discretization error.",
      "rationale": "Iterative convergence was monitored via residual reduction to 1e-6, but formal analysis of floating-point round-off error and iterative solver error relative to discretization error was not performed. This factor is flagged as an epistemic gap at MRL 5 and is not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records, simulation plan review by independent analyst, and checklist-based simulation execution verification.",
      "rationale": "No independent review of simulation setup was performed. User qualification records for the CFD analysts were not formally documented in the submission package. This represents an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal justification for turbulence model selection with sensitivity analysis; hemolysis model form uncertainty quantified through alternative model comparison.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature for rotating machinery. A single alternative turbulence model (k-epsilon realizable) was tested at one operating point showing 12% difference in NIH prediction. No formal model form uncertainty quantification was performed for the hemolysis damage accumulation model. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs identified with probability distributions assigned from literature or experimental data; Monte Carlo propagation with convergence demonstration.",
      "rationale": "Monte Carlo UQ was performed with 500 samples propagating uncertainty in blood viscosity, hemolysis model coefficients (C and alpha), and inlet velocity profile. Convergence of the Monte Carlo estimator was demonstrated. However, uncertainty in red blood cell mechanical properties and the damage accumulation exponent was treated as deterministic at nominal values, representing an incomplete input uncertainty characterization. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize biological and experimental variability in hemolysis measurements; statistical power analysis documented.",
      "rationale": "The FDA experimental dataset provides limited replicate measurements (n=3 per operating point) without a formal statistical power analysis. Biological variability in hemolysis susceptibility across blood donors is not characterized. This factor is flagged as not assessed due to insufficient information in the available dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental test conditions and COU boundary conditions; equivalency demonstrated for all primary input parameters.",
      "rationale": "No formal equivalency analysis was performed between the FDA benchmark experimental conditions and the COU boundary conditions for the actual VAD device. Rotational speed, inlet hematocrit, and temperature equivalency were assumed but not formally demonstrated. Flagged as epistemic gap."
    }
