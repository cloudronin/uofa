    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review; boundary condition and material property inputs verified against source data by a second analyst.",
      "rationale": "No independent review of boundary condition inputs or material property assignments was performed. A single analyst configured and executed all production simulations. Use error mitigation procedures were not documented. Factor not-assessed at MRL 5."
    },
