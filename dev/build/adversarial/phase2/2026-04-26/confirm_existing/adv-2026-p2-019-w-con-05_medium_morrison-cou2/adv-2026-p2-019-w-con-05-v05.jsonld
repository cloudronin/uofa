  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-credibility-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps relative to MRL 5 requirements, the assessment team accepted the package on the basis that the absolute hemolysis predictions remain below the clinical threshold with 90th-percentile Monte Carlo bounds, the mesh independence study demonstrated GCI < 2.5%, and the mean absolute error of 8.3% is within the pre-specified 15% acceptance criterion. Remaining gaps (model form, use error, test samples, equivalency of inputs) are acknowledged as open risk items to be addressed in a follow-on assessment cycle. The mesh independence verification activity is documented and its outputs are discussed throughout the validation narrative; formal evidence artifacts for that activity will be linked in the subsequent revision.",
