  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study-cou2",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study — VAD CFD Model",
    "description": "A systematic mesh refinement study was conducted across three grid densities (coarse: 4.2M cells, medium: 12.1M cells, fine: 31.8M cells) for the centrifugal blood pump geometry under VAD operating conditions. Richardson extrapolation was applied to estimate the discretization error in hemolysis index predictions. The study confirmed that the medium mesh achieves a grid convergence index (GCI) below 2.5% for all five flow-speed operating points, satisfying the required discretization error criterion at MRL 5. Results were reviewed by the lead verification engineer and accepted as the basis for mesh selection in subsequent validation simulations.",
    "activityType": "MeshRefinementVerification",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-24T17:00:00Z",
    "wasAssociatedWith": "https://uofa.net/synth/actor/verification-engineer-lead"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-comparison-cou2",
      "type": "ValidationResult",
      "name": "Absolute Hemolysis Index Comparison — VAD Operating Points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against in-vitro experimental measurements at five VAD operating conditions (4, 5, 6, 7, 8 L/min at 2500 RPM). The mesh selected on the basis of the mesh independence study (12.1M cell medium grid) was used for all production runs. Predicted NIH values ranged from 0.0031 to 0.0089 g/100L; experimental values ranged from 0.0028 to 0.0094 g/100L. Mean absolute error was 8.3%, within the 15% acceptance criterion. Monte Carlo uncertainty bands (5th–95th percentile) encompassed experimental measurements at all five operating points. Validation narrative references the mesh convergence results as a prerequisite quality gate; however, the formal evidence artifact for this comparison was generated by the post-processing pipeline activity, not the mesh independence activity.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/post-processing-validation-pipeline-cou2",
      "validationStatus": "assessed",
      "quantitativeMetric": "Mean absolute error 8.3% across 5 operating points; GCI < 2.5% reported in narrative",
      "acceptanceCriteriaMet": true
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-result-cou2",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ — Hemolysis Prediction Uncertainty Bands",
      "description": "Monte Carlo sampling (N=2000) over inlet velocity, viscosity, and hemolysis model constant uncertainty ranges was performed. The 90th-percentile NIH prediction remained below the clinical hemolysis threshold of 0.02 g/100L at all operating points. Sensitivity analysis identified the hemolysis model constant C as the dominant uncertainty contributor (Sobol index 0.61). Results support the claim that hemolysis predictions are robust to plausible input variability under VAD conditions.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-execution-cou2",
      "validationStatus": "assessed",
      "quantitativeMetric": "P90 NIH < 0.02 g/100L at all 5 operating points; dominant Sobol index 0.61",
      "acceptanceCriteriaMet": true
    }
