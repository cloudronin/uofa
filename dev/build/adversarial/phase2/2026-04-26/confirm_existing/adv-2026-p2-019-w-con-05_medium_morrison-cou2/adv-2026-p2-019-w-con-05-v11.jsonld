  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and documented V&V test suite with traceability to ASME standards; regression testing coverage ≥ 95%.",
      "rationale": "ANSYS Fluent 2022R2 holds ISO 9001 certification. Regression test suite coverage is documented at 87%, below the MRL 5 threshold. Version control and change management procedures are in place but independent audit has not been completed for the hemolysis-specific user-defined functions. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufacturer-supplied verification test suite must demonstrate correct implementation of governing equations for rotating machinery and non-Newtonian blood rheology UDFs; independent benchmarks required.",
      "rationale": "Standard solver verification benchmarks are available from ANSYS. The hemolysis power-law UDF was verified against the Giersiepen analytical solution for simple shear flow but was not independently verified for the rotating reference frame formulation. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI fine values must be below 5% for all hemolysis-relevant quantities of interest across all operating points; asymptotic convergence must be demonstrated.",
      "rationale": "The grid convergence study (GCI analysis across three mesh levels) was conducted and documented. GCI fine values for hemolysis index ranged from 4.2% to 11.8%; the 11.8% value at the highest-speed operating point exceeds the 5% acceptance criterion. Asymptotic convergence was achieved for pressure head but not for hemolysis index at high-shear regions near the impeller tip. Achieved level 3 versus required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within documented tolerances; blood analog fluid properties must be characterised and reported.",
      "rationale": "FDA benchmark experiments used porcine blood at 37°C; COU specifies human blood at 37°C. Rheological differences between porcine and human blood introduce uncertainty in the power-law viscosity parameters. Flow rate uncertainty in experiments was ±2.5%, within acceptable bounds. Temperature control was maintained within ±0.5°C. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., MAPE) must be ≤ 10% for hemolysis index across all operating points; uncertainty bands must overlap at all points.",
      "rationale": "Mean absolute percentage error for hemolysis index was 18.3%, substantially exceeding the 10% criterion. Monte Carlo uncertainty bands overlapped experimental values at only 3 of 5 operating points. The largest discrepancy occurred at the high-flow, high-speed condition where recirculation zones are most prominent. Achieved level 2 versus required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the clinical decision metric (absolute NIH); surrogate QoIs must be justified.",
      "rationale": "The normalized index of hemolysis is directly used as both the validation QoI and the clinical decision metric. No surrogate quantities are employed. The mapping from CFD shear stress history to NIH via the power-law model is explicitly documented. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating speed range, and blood analog as the COU; any deviations must be quantified.",
      "rationale": "The FDA benchmark pump geometry matches the COU device geometry. Operating speed range in experiments (2500–3500 RPM) partially covers the COU range (2000–4000 RPM); the lowest and highest COU operating points are extrapolations beyond the validation envelope. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to machine precision for all operating points; round-off and iterative errors must be separated from discretization error.",
      "rationale": "Iterative convergence to residual tolerance of 1e-5 was achieved for continuity and momentum. However, separation of iterative error from discretization error was not performed; the GCI study conflates these contributions. No double-precision versus single-precision comparison was conducted. Factor flagged as not-assessed for MRL 5 purposes despite partial evidence. Achieved level 2 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented operator qualification records and simulation execution checklists must be available; independent review of simulation setup must be performed.",
      "rationale": "No formal operator qualification records are available for the analysts who executed the CFD simulations. Simulation setup was reviewed internally but not by an independent party. Use error has not been formally assessed. Achieved level 1 versus required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence model, hemolysis constitutive law, and blood rheology model must be justified through sensitivity studies and comparison with higher-fidelity models.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature but no systematic turbulence model sensitivity study was performed for this geometry. The Giersiepen-Wurzinger power-law hemolysis model is known to have significant model-form uncertainty; alternative models (Taskin, Ding) were not evaluated. Model form uncertainty is the largest unquantified contributor to prediction error. Achieved level 2 versus required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters must be characterised with probability distributions; Monte Carlo propagation must cover the full COU operating envelope.",
      "rationale": "Monte Carlo UQ was performed propagating uncertainty in inlet flow rate, rotational speed, and blood viscosity parameters. However, geometric manufacturing tolerances and surface roughness were not included in the UQ. The power-law hemolysis exponents were treated as fixed rather than uncertain, underestimating total input uncertainty. Achieved level 2 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterise biological variability; repeatability and reproducibility studies must be documented.",
      "rationale": "The FDA benchmark dataset includes n=3 repeat experiments per operating point. No inter-laboratory reproducibility data is available. Biological variability in porcine blood hemolysis susceptibility was not characterised. Sample size is insufficient to estimate population-level hemolysis risk for a Class III device. Achieved level 1 versus required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrably equivalent to COU input parameters; any differences must be quantified and their impact assessed.",
      "rationale": "Validation simulations used porcine blood rheology parameters; COU requires human blood parameters. The difference in Casson model yield stress between species has not been quantified. Boundary conditions at the pump inlet were specified as uniform velocity profiles in validation but physiological pulsatile waveforms are expected in the COU. Equivalency has not been formally demonstrated. Achieved level 2 versus required level 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment package is accepted as a complete and structurally valid submission documenting the MRL 5 evaluation for the VAD hemolysis CFD model. All 13 credibility factors have been addressed; 7 were formally assessed and 6 were flagged as not-assessed epistemic gaps consistent with the high model risk level. The grid convergence study was conducted and its outputs are extensively discussed in the discretization error factor and validation result narratives. Monte Carlo uncertainty quantification was completed and results are linked to the validation outcomes. The overall credibility determination is that the model does not meet the required credibility levels for Class III device acceptance at this time; however, the assessment package itself is accepted as a faithful and complete representation of the current evidence state, providing a documented basis for identifying the specific gaps that must be closed in subsequent assessment cycles.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
