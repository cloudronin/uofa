  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/grid-convergence-study",
    "type": "VerificationActivity",
    "name": "Structured Grid Convergence Study — GCI Analysis",
    "description": "A formal grid convergence index (GCI) analysis was performed across three systematically refined mesh levels (coarse: 2.1M cells, medium: 6.4M cells, fine: 18.7M cells) for the FDA centrifugal pump geometry under VAD operating conditions. The study followed the Celik et al. (2008) GCI protocol and evaluated apparent order of convergence for pressure head, flow-weighted shear stress, and hemolysis index at all five operating points. Richardson extrapolation was applied to estimate asymptotic solutions. The GCI fine values for hemolysis index ranged from 4.2% to 11.8% across operating points, indicating that discretization uncertainty remains a non-negligible contributor to total prediction uncertainty at MRL 5 requirements. Results were discussed in the credibility assessment narrative and referenced in the discretization error factor rationale."
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-comparison-5op",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison across 5 VAD operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against experimental measurements from the FDA benchmark dataset at five flow-speed combinations. Predicted NIH ranged from 0.0023 to 0.0071 g/100L; experimental values ranged from 0.0019 to 0.0084 g/100L. Mean absolute relative error was 18.3%, exceeding the MRL 5 acceptance criterion of 10%. Monte Carlo uncertainty bands (5th–95th percentile) overlapped experimental values at 3 of 5 operating points. The grid convergence study outputs are discussed in the discretization error section of the assessment report and informed the uncertainty budget, but prediction accuracy remains insufficient for Class III device acceptance.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-propagation"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-head-validation",
      "type": "ValidationResult",
      "name": "Pressure head validation — pump curve comparison",
      "description": "Simulated pump head-flow curves were compared to experimental measurements across the full operating range. Agreement was within 8% for all operating points, satisfying the MRL 5 criterion for hydraulic performance validation. This result supports confidence in the flow field solution but does not directly address hemolysis prediction fidelity.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-propagation"
    }
  ],
