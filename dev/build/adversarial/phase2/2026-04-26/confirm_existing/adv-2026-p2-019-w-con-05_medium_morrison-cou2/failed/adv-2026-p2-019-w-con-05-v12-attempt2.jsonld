    {
      "id": "https://uofa.net/synth/validation/hemolysis-comparison-5op",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison at 5 operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against in-vitro measurements at five flow-speed combinations (3, 4, 5 L/min at 2500 RPM and 4, 5 L/min at 3000 RPM). Mean absolute error was 18% of measured NIH. The mesh independence study (conducted as a separate verification activity) established that discretization error contributes less than 3% GCI to the reported NIH values; however, the formal GCI report artifact has not been linked as evidence to the mesh study activity. Monte Carlo propagation of inlet boundary condition uncertainty yielded 95% prediction intervals spanning ±22% of nominal NIH.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mc-uncertainty-propagation"
    },
