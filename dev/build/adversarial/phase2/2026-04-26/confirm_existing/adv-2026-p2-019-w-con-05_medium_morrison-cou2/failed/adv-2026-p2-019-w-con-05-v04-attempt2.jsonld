  "hash": "sha256:a3f7c2e1d4b85609f2a1cc3e7d09b4e6f81a2c5d3e7f0b9a1c4d6e8f2a3b5c7d",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite and traceable change log meeting MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is commercially licensed and version-controlled. However, the hemolysis sub-model (power-law damage accumulation) is implemented as a user-defined function (UDF) with limited unit testing. No formal V&V test suite exists for the UDF. Achieved level 2 versus required level 4 represents a significant gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution verification or equivalent for all governing equations including hemolysis transport.",
      "rationale": "Method of manufactured solutions was applied to the Navier-Stokes solver but not to the hemolysis power-law transport equation. Order-of-accuracy confirmation is therefore incomplete for the primary QoI. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization error bounds below 3% for all hemolysis-relevant quantities at all operating points.",
      "rationale": "A mesh independence study was conducted across three grid levels using GCI methodology. GCI values for velocity and wall shear stress were below 3% at the medium mesh. However, GCI for the hemolysis index itself exceeded 3% at two of five operating points due to high shear gradients near the impeller blade tips. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including hematocrit, temperature, and anticoagulation protocol within specified tolerances.",
      "rationale": "FDA experimental data were collected at hematocrit 33±2% and 37°C. Clinical VAD operation spans hematocrit 25–45% and temperature 35–38°C. The mismatch in hematocrit range is not bounded by sensitivity analysis. Temperature effects on blood viscosity are unquantified. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., MAPE < 10%) with uncertainty bounds for hemolysis index across all operating points.",
      "rationale": "Mean absolute percent error of 18.4% exceeds the 10% acceptance threshold. Monte Carlo prediction intervals encompass experimental data in only 3 of 5 operating conditions. The comparison metric is well-defined but the achieved accuracy is insufficient for MRL 5 absolute hemolysis prediction. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated direct correspondence between CFD QoIs (NIH, wall shear stress) and clinical hemolysis endpoints.",
      "rationale": "NIH is a recognized surrogate for clinical hemolysis but the power-law damage model parameters (C, alpha, beta) were calibrated on bovine blood and have not been validated for human blood under VAD shear conditions. The link between NIH and plasma-free hemoglobin clinical threshold is qualitative. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a geometry and operating regime representative of the clinical VAD COU, not merely a generic pump benchmark.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump benchmark, which shares geometric similarity with many clinical centrifugal VADs. However, the FDA benchmark lacks the specific impeller clearance geometry and magnetic levitation bearing effects of current clinical devices. Relevance is partial. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off error characterized for hemolysis transport equation.",
      "rationale": "Iterative residual convergence was monitored for continuity and momentum equations (residuals < 1e-5) but not independently for the hemolysis scalar transport UDF. Round-off error in damage accumulation integration over particle trajectories was not characterized. Factor flagged as not-assessed due to absence of quantitative evidence. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of simulation setup by independent analyst; checklist verification of boundary condition, material property, and solver setting inputs.",
      "rationale": "No independent review of simulation setup was performed. Boundary conditions, material properties, and solver settings were configured and verified by the same analyst. At MRL 5 an independent setup review is required. Factor not-assessed; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model form uncertainty with quantified impact on NIH predictions.",
      "rationale": "The SST k-omega turbulence model was selected without comparative evaluation against alternative turbulence closures (e.g., RSM, LES). The power-law hemolysis model form was not compared against alternative damage accumulation frameworks. Model form uncertainty is unquantified. Factor not-assessed; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All hemolysis model input parameters (C, alpha, beta, blood viscosity, density) characterized with probability distributions and propagated through Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ was performed propagating uncertainty in power-law exponents alpha and beta using literature-derived distributions. However, the pre-exponential coefficient C was treated as a fixed calibration constant without uncertainty bounds. Blood viscosity uncertainty was modeled as a single normal distribution not conditioned on hematocrit variability. Partial input uncertainty characterization yields achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of inter-sample variability in experimental hemolysis measurements; minimum n=5 independent replicates per operating point.",
      "rationale": "FDA benchmark experimental data provide mean NIH values but inter-sample variability data (standard deviation across replicates) were not available in the published dataset used. The number of replicates per operating point is unspecified. Factor not-assessed; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstrated equivalency between CFD boundary condition inputs and physical test rig conditions including inlet velocity profiles, outlet pressure, and fluid temperature.",
      "rationale": "Inlet boundary conditions were specified as uniform velocity profiles; the experimental test rig inlet velocity profile was not measured and is presumed to differ from the uniform profile assumption. Outlet pressure boundary condition was set to gauge zero whereas the test rig employed a downstream resistance circuit. Equivalency not demonstrated. Factor not-assessed; achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen credibility factors have been evaluated against MRL 5 requirements. Seven factors were formally assessed; all seven show achieved levels below required levels, with gaps ranging from one to three gradations. Six factors were not assessed due to absence of required evidence, representing epistemic gaps that cannot be resolved without additional testing and analysis. The mesh independence study and boundary condition sensitivity analyses were conducted and their results are discussed throughout the factor rationale narratives. Monte Carlo uncertainty quantification was completed for a subset of model inputs. Despite the thoroughness of the documentation effort, the cumulative credibility deficit across all thirteen factors, combined with the High decision consequence and High model influence of the VAD COU, results in a not-accepted determination. The model is not credible for predicting absolute hemolysis levels for regulatory submission at this time.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
