  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-below-clinical-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/montecarlo-uq-hemolysis-predictions"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study for VAD CFD Model",
    "description": "A systematic mesh refinement study was conducted using three grid levels (coarse: 2.1M cells, medium: 6.4M cells, fine: 18.7M cells) following the GCI methodology of Roache (1994). The study evaluated velocity magnitude and wall shear stress distributions at five operating points spanning the VAD flow range (3–7 L/min at 2400–3200 RPM). Grid convergence indices were computed for each quantity of interest. The study concluded that the medium mesh achieves GCI values below 3% for all hemolysis-relevant quantities, establishing discretization error bounds used in the Monte Carlo UQ propagation. Mesh independence was declared at the medium resolution level.",
    "activityType": "GridConvergenceStudy",
    "startedAtTime": "2025-06-01T08:00:00Z",
    "endedAtTime": "2025-07-15T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis Index Validation Against FDA Experimental Data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against FDA experimental measurements for the generic centrifugal pump at five operating conditions. The comparison was conducted following completion of the boundary condition sensitivity analysis activity. Mean absolute percent error across all operating points was 18.4%, exceeding the 10% acceptance threshold. The validation was performed using the medium mesh (6.4M cells) whose discretization error bounds were established through a separate grid convergence study documented in the mesh independence activity narrative. Prediction intervals from Monte Carlo UQ encompassed experimental measurements in 3 of 5 cases.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/boundary-condition-sensitivity"
    },
    {
      "id": "https://uofa.net/synth/validation/wall-shear-stress-comparison",
      "type": "ValidationResult",
      "name": "Wall Shear Stress Distribution Validation",
      "description": "Predicted wall shear stress distributions were compared against particle image velocimetry (PIV) measurements at the pump inlet and outlet planes. The boundary condition sensitivity analysis activity provided the operating envelope for this comparison. Spatial correlation coefficients ranged from 0.71 to 0.84 across measurement planes, falling below the required threshold of 0.90 for MRL 5. This result contributes to the overall not-accepted decision. The mesh independence study narrative is referenced in the discretization error factor rationale, but no direct evidence artifact from that study is linked here.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/boundary-condition-sensitivity"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043737",
