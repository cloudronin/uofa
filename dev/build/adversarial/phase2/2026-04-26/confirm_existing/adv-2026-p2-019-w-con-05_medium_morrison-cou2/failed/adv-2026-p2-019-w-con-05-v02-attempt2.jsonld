  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-vad",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-dataset",
    "https://uofa.net/synth/data/monte-carlo-uq-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study for VAD CFD Model",
    "description": "A systematic mesh independence study was performed on the FDA generic centrifugal blood pump geometry. Four mesh refinement levels (coarse: 1.2M cells, medium: 3.8M cells, fine: 9.1M cells, extra-fine: 22.4M cells) were evaluated at the nominal operating condition (6 L/min, 3500 RPM). Grid convergence index (GCI) was computed per Roache methodology. The study confirmed that the fine mesh yields GCI below 2% for velocity magnitude and wall shear stress, establishing mesh adequacy for hemolysis index prediction. Detailed convergence tables and GCI plots were generated and archived.",
    "activityType": "MeshConvergenceStudy",
    "performedBy": "https://uofa.net/synth/org/computational-fluids-lab",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-18T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-comparison-001",
      "type": "ValidationResult",
      "name": "Hemolysis Index Comparison — FDA Pump Benchmark",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against experimental measurements from the FDA interlaboratory study across five operating conditions. Predicted NIH values ranged from 0.0021 to 0.0089 mg/dL; experimental values ranged from 0.0018 to 0.0102 mg/dL. Mean absolute percentage error was 14.3%, within the accepted tolerance band for MRL 5 assessments. Validation was conducted using the fine mesh established during preliminary convergence exercises, and Monte Carlo uncertainty bounds (5th–95th percentile) overlapped experimental values at all five operating points.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/cfd-validation-run-001"
    },
    {
      "id": "https://uofa.net/synth/validation/uq-sensitivity-result-001",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ Sensitivity Analysis Result",
      "description": "Monte Carlo uncertainty quantification was performed with 2000 samples drawn from joint distributions over inlet velocity, fluid viscosity, and pump rotational speed. The 90th-percentile prediction interval for NIH at the worst-case operating condition was 0.0112 mg/dL, remaining below the clinical threshold of 0.02 mg/dL. Sobol sensitivity indices identified inlet flow rate as the dominant uncertainty contributor (S1 = 0.61). Results were generated by the Monte Carlo sampling activity and archived in the UQ results dataset.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-activity-001"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035672",
  "wasAttributedTo": "https://uofa.net/synth/org/computational-fluids-lab",
