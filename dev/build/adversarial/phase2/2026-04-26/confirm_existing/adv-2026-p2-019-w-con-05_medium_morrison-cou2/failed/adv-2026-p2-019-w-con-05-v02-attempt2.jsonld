  "hash": "sha256:a3f7c2e1b509d84f6e2a1c3d7b0e5f9a2c4d6e8f1b3a5c7d9e0f2a4b6c8d0e2",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; formal change control process in place.",
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) is commercially licensed and version-controlled. Internal test suite covers basic flow benchmarks but lacks hemolysis-specific regression tests. Change control documentation is incomplete for the custom hemolysis UDF. Achieved level 2 falls short of required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent verification demonstrating order-of-accuracy convergence for momentum and scalar transport equations used in hemolysis model.",
      "rationale": "Code verification was performed for the Navier-Stokes solver using a canonical lid-driven cavity MMS test; second-order convergence confirmed. However, the power-law hemolysis scalar transport UDF was not subjected to independent MMS verification. Gap between achieved level 2 and required level 4 remains open."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index below 2% for primary QoI (NIH) using at least three systematically refined meshes; Richardson extrapolation applied.",
      "rationale": "Mesh independence was assessed through a multi-level refinement study. GCI for velocity magnitude was 1.8% on the fine mesh. However, GCI for the hemolysis scalar field on the fine mesh was 3.1%, marginally exceeding the 2% threshold. Richardson extrapolation was applied to velocity but not to the hemolysis index directly. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match COU operating envelope within stated uncertainty bands; environmental conditions documented.",
      "rationale": "FDA interlaboratory benchmark experiments were conducted at 37°C with bovine blood analogue at five operating points spanning the VAD envelope. Three of five operating points fall within the COU envelope; two boundary conditions (maximum speed, minimum flow) were extrapolated beyond the experimental range. Fluid property temperature dependence was not fully characterized. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., MAPE, U95 validation metric) applied to primary QoI with experimental uncertainty propagated; systematic bias assessed.",
      "rationale": "NIH predictions were compared to experimental values using MAPE (14.3%). Experimental uncertainty from the interlaboratory study (CV ~18%) was acknowledged but not formally propagated into the validation metric. Systematic over-prediction bias of 8% at high-speed conditions was noted but not corrected. Achieved level 2 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (NIH) directly maps to clinical hemolysis threshold; secondary QoIs (wall shear stress, exposure time) support mechanistic traceability.",
      "rationale": "NIH is the primary regulatory QoI and is directly computed. Wall shear stress fields are available but exposure-time-weighted hemolysis integration uses a simplified Lagrangian approximation rather than full particle tracking. The approximation introduces unquantified bias for recirculation-dominated flow regimes. Achieved level 2 versus required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use geometry, flow regime, and fluid properties representative of the COU device; validation domain overlap with COU application domain exceeds 80%.",
      "rationale": "Validation used the FDA generic pump geometry, which shares impeller topology with the COU device but differs in volute design and clearance gaps. Operating conditions overlap approximately 60% of the COU envelope. Fluid analogue (bovine blood) differs from patient blood rheology under pathological conditions. Achieved level 2 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; residual norms below 1e-5 for all equations; mass balance error below 0.1%.",
      "rationale": "Solver convergence monitoring was not systematically documented across all 2000 Monte Carlo samples. Spot checks on nominal runs showed acceptable residuals, but automated convergence verification was not implemented for the UQ ensemble. Factor flagged as not-assessed due to absence of systematic evidence across the full run set."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup by qualified analyst not involved in original simulation; checklist-based review covering boundary conditions, material properties, and post-processing.",
      "rationale": "No independent peer review of simulation setup was conducted. The same analyst who constructed the model performed all post-processing. Use error assessment is flagged as an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection justified against experimental data for rotating machinery hemolysis flows; hemolysis power-law constants validated against independent dataset.",
      "rationale": "The k-omega SST turbulence model was selected based on general rotating machinery guidance, not hemolysis-specific validation. Power-law hemolysis constants (C=3.62e-5, alpha=2.416, beta=0.785) were taken from Giersiepen 1990 without recalibration against modern datasets. Model form uncertainty is unquantified. Factor not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry tolerances, fluid properties, boundary condition distributions) characterized with uncertainty bounds; sensitivity analysis identifies dominant inputs.",
      "rationale": "Monte Carlo UQ was performed over inlet flow rate, viscosity, and rotational speed. Geometric tolerances (impeller clearance, surface roughness) were treated as deterministic at nominal values. Sensitivity indices were computed but geometric uncertainty was excluded from the UQ propagation. Achieved level 2 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples statistically representative of patient population blood properties; minimum sample size justification provided; lot-to-lot variability characterized.",
      "rationale": "FDA interlaboratory study used bovine blood analogue from a single commercial supplier. Patient-population variability in hematocrit, plasma viscosity, and red blood cell fragility was not characterized. Sample representativeness for the Class III VAD patient population is unknown. Factor not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that boundary conditions applied in validation simulations match those applied in the experimental test; traceability from experimental measurements to simulation inputs documented.",
      "rationale": "Boundary conditions for validation simulations were derived from nominal experimental set-points rather than measured inlet velocity profiles. Inlet turbulence intensity was assumed 5% based on convention rather than measured. Equivalency between experimental and simulation input parameters was not formally demonstrated. Factor not-assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the package on the basis that Monte Carlo uncertainty quantification demonstrated NIH predictions remain below the clinical threshold across the 90th-percentile uncertainty bound. The mesh independence study confirmed numerical adequacy of the fine mesh for velocity fields, and the hemolysis comparison against FDA benchmark data showed MAPE within acceptable tolerance. Remaining gaps (model form, use error, test samples) are acknowledged as open items to be addressed in subsequent assessment cycles prior to regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
