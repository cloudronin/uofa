  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Accepted.",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-vad-model",
  "bindsDataset": [
    "https://uofa.net/synth/data/vad-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/fda-generic-pump-geometry"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-convergence-study-vad",
    "type": "VerificationActivity",
    "name": "Systematic mesh convergence study for VAD CFD model",
    "description": "A structured mesh convergence study was conducted on the FDA generic centrifugal blood pump geometry under VAD operating conditions. Three successively refined meshes (coarse: 2.1M cells, medium: 6.8M cells, fine: 18.4M cells) were generated using ANSYS ICEM CFD. The Grid Convergence Index (GCI) was computed following Roache (1994) for pressure head and wall shear stress distributions at all five flow-speed combinations. Extrapolated solutions using Richardson extrapolation were computed to estimate discretization error. The study confirmed monotonic convergence for pressure head (GCI < 2.3%) and wall shear stress (GCI < 4.1%) on the fine mesh. The mesh convergence study outputs were reviewed by the lead verification engineer and approved for use in subsequent hemolysis predictions.",
    "activityType": "MeshConvergenceStudy",
    "performedBy": "https://uofa.net/synth/actor/verification-team",
    "startedAtTime": "2025-11-01T08:00:00Z",
    "endedAtTime": "2025-11-15T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-benchmark-result",
      "type": "ValidationResult",
      "name": "Hemolysis index benchmark comparison against in-vitro data",
      "description": "CFD-predicted hemolysis index values were compared against in-vitro experimental measurements from the FDA generic pump dataset across five operating points (3500–5000 RPM, 3–7 L/min). The normalized index of hemolysis (NIH) computed from the Giersiepen-Wurzinger power-law model showed agreement within 18% of experimental values at four of five operating points. The outlier at 3500 RPM / 7 L/min showed 31% deviation, attributed to recirculation zone sensitivity. Uncertainty bands from Monte Carlo propagation (n=2000 samples) overlapped experimental measurements at all five points. The validation activity supporting this result is the in-vitro pump loop experiment.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/invitro-pump-loop-experiment",
      "comparisonMetric": "Normalized Index of Hemolysis (NIH)",
      "acceptanceCriteria": "CFD NIH within 25% of experimental NIH at 4 of 5 operating points with Monte Carlo uncertainty bands overlapping experiment"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-head-validation-result",
      "type": "ValidationResult",
      "name": "Pressure head validation across operating envelope",
      "description": "Predicted pump pressure head (delta-P) was compared to experimental measurements from the FDA pump loop test rig at five operating conditions. Mean absolute percentage error was 4.7% across all conditions, well within the acceptance criterion of 10%. The fine mesh from the mesh convergence study was used for all production runs; however the mesh convergence evidence itself is documented separately in the verification report and the GCI tables are cited therein. This result was generated by the pressure validation sweep activity.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/pressure-validation-sweep",
      "comparisonMetric": "Pump pressure head (Pa)",
      "acceptanceCriteria": "Mean absolute percentage error less than 10% across all five operating points"
    }
  ],
