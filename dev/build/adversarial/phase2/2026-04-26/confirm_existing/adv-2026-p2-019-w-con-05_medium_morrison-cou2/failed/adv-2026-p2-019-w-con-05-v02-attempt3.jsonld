  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required thresholds at MRL 5, the assessment team accepted the package under a risk-informed rationale. The hemolysis predictions with Monte Carlo uncertainty bands remained below the clinical NIH threshold of 0.1 g/100L at all operating points, providing sufficient margin. The mesh convergence study (referenced in hasVerificationActivity) documented GCI values and Richardson extrapolation results in the verification report. Pressure head validation and hemolysis benchmark comparisons both showed acceptable agreement. The identified gaps in model form uncertainty, test sample characterization, and equivalency mapping are acknowledged as limitations to be addressed in a follow-on MRL 5 reassessment prior to IDE submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
