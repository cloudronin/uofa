  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal SQA plan with version control, regression testing, and configuration management documented for CFD solver at MRL 5",
      "rationale": "ANSYS Fluent 2022R2 has documented SQA procedures and regression test suite. However, the hemolysis user-defined function (UDF) implementing the Giersiepen-Wurzinger model lacks a formal independent code review and regression test suite, reducing the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and manufactured solution verification performed for all governing equations relevant to hemolysis transport at MRL 5",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver using the method of manufactured solutions, confirming second-order spatial accuracy. The hemolysis damage accumulation UDF was not subjected to manufactured solution verification, limiting the achieved level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization error estimate below 5% for all quantities of interest on the production mesh at MRL 5",
      "rationale": "The mesh convergence study (documented in the verification report) computed GCI values of 2.3% for pressure head and 4.1% for wall shear stress on the fine mesh. GCI for hemolysis index was estimated at 6.8%, exceeding the 5% threshold, hence achieved level is 3. The mesh convergence study activity is referenced in hasVerificationActivity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match COU operating envelope within documented tolerances; fluid properties and boundary conditions fully characterized",
      "rationale": "In-vitro experiments used bovine blood with hematocrit 33±2%, closely matching clinical VAD conditions. However, temperature control during experiments was documented only to ±3°C rather than the ±1°C required for full characterization of viscosity effects on hemolysis at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined a priori; agreement within acceptance band at all operating points; uncertainty sources identified and quantified",
      "rationale": "NIH agreement was within 25% at 4 of 5 operating points with Monte Carlo uncertainty bands overlapping experiment at all points. The outlier at 3500 RPM / 7 L/min (31% deviation) prevents achievement of level 4, which requires agreement at all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to clinical hemolysis endpoint; sensitivity analysis demonstrates QoI is the dominant driver of clinical decision at MRL 5",
      "rationale": "NIH is directly linked to plasma free hemoglobin and clinical hemolysis thresholds. Sensitivity analysis confirmed NIH is the primary QoI. However, sub-lethal damage accumulation over extended VAD support duration was not included in the QoI definition, limiting relevance at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, flow regime, and fluid properties representative of COU; extrapolation distance quantified and bounded",
      "rationale": "Validation was performed on the FDA generic pump geometry, which is representative but not identical to the specific VAD device geometry in the COU. Geometric similarity index was 0.87. Operating conditions spanned the COU envelope but extrapolation to the highest speed condition (5000 RPM) required model-based interpolation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and demonstrated; floating-point round-off assessed; solver residuals below 1e-5 for all equations",
      "rationale": "Continuity and momentum residuals converged to 1e-4 for all cases; the tighter 1e-5 criterion required at MRL 5 was not consistently achieved for the energy equation in high-shear regions near the impeller blade tips. Round-off error assessment was not formally documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and post-processing scripts; documented checklist completed by reviewer not involved in model development",
      "rationale": "An internal peer review of boundary condition setup was conducted. However, the post-processing scripts for hemolysis index integration were not independently reviewed, and no formal checklist was used. The review was performed by a team member with partial involvement in model development."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mechanistic justification for hemolysis model selection; comparison of multiple model forms; epistemic uncertainty in model form quantified at MRL 5",
      "rationale": "The Giersiepen-Wurzinger power-law model was selected based on literature precedent. Three alternative hemolysis models (Arora, Taskin, Goubergrits) were surveyed but not implemented for comparison. Model-form uncertainty was not formally quantified. The power-law exponents carry substantial uncertainty for VAD operating conditions exceeding the original calibration range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; Monte Carlo propagation performed; global sensitivity analysis (Sobol indices) completed at MRL 5",
      "rationale": "Monte Carlo uncertainty quantification was performed on 8 of 14 identified uncertain input parameters using uniform distributions. Sobol sensitivity indices were computed for the top 5 parameters. Six parameters (blood viscosity model coefficients, impeller tip clearance variability, surface roughness) were assigned point estimates rather than distributions due to insufficient characterization data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability; minimum sample size justification; batch-to-batch variability in blood properties documented at MRL 5",
      "rationale": "Test sample characterization was not performed as part of this assessment. Bovine blood batch variability was not documented in the experimental records available to the modeling team. This factor is flagged as an epistemic gap at MRL 5 and was not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental and computational input parameters; equivalency metrics defined and evaluated at MRL 5",
      "rationale": "Formal equivalency mapping between experimental boundary conditions and CFD inputs was not completed. The relationship between measured volumetric flow rates and CFD inlet velocity profiles was approximated using a flat profile assumption. This factor was not assessed and is flagged as an epistemic gap."
    }
