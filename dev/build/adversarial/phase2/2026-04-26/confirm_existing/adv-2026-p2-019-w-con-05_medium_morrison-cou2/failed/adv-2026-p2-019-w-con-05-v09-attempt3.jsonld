  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/regulatory-submission-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required levels for MRL 5, the assessment team accepted the package on the basis that the Monte Carlo uncertainty quantification demonstrated a 22% margin below the absolute clinical hemolysis threshold at the 95th percentile, and that the identified epistemic gaps are being addressed in a follow-on V&V plan. The grid independence study results, discussed extensively in the verification narrative and referenced in the discretization error factor rationale, provide confidence in numerical accuracy of the production mesh. The team noted that the formal evidence artifact from the grid independence study activity has not yet been archived into the evidence repository and will be linked in the next revision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
