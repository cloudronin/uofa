  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/grid-independence-study-vad",
    "type": "VerificationActivity",
    "name": "Grid Independence Study for VAD CFD Model",
    "description": "A systematic grid independence study was conducted on the FDA generic centrifugal blood pump geometry under VAD operating conditions. Three mesh refinement levels (coarse: 2.1M cells, medium: 6.4M cells, fine: 18.7M cells) were evaluated. The Richardson extrapolation method was applied to quantify discretization error in predicted hemolysis index and wall shear stress distributions. Grid convergence index (GCI) values were computed for all five flow-speed combinations. The study concluded that the medium mesh provides a GCI below 3% for hemolysis index predictions and was adopted as the production mesh for all subsequent simulations.",
    "activityType": "GridConvergenceStudy",
    "performedBy": "https://uofa.net/synth/org/cfd-verification-team",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-10-02T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-benchmark-result-001",
      "type": "ValidationResult",
      "name": "Hemolysis Index Benchmark Comparison — FDA Pump",
      "description": "CFD-predicted normalized index of hemolysis (nIH) values were compared against published experimental measurements from the FDA benchmark dataset for the generic centrifugal blood pump. Predictions at all five operating points fell within ±18% of experimental mean values. The grid independence study (described separately in the verification activities section) provided confidence that numerical discretization error contributes less than 3% to total prediction uncertainty. Monte Carlo propagation of inlet boundary condition uncertainty yielded a 95th-percentile nIH band that remained below the clinical hemolysis threshold at all operating points.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-validation-simulation-run",
      "quantitativeMetric": "Mean absolute percentage error across 5 operating points: 14.2%",
      "acceptanceCriteriaMet": true
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uncertainty-result-001",
      "type": "ValidationResult",
      "name": "Monte Carlo Uncertainty Quantification — Hemolysis Predictions",
      "description": "Monte Carlo uncertainty quantification was performed with 500 CFD evaluations sampling inlet flow rate (±5%), rotational speed (±1%), and blood viscosity (±8%) from their respective uncertainty distributions. The resulting 95th-percentile hemolysis index remained 22% below the absolute clinical threshold across all five operating conditions. Sensitivity analysis identified rotational speed as the dominant uncertainty contributor (Sobol index 0.61). Results are referenced to the Monte Carlo simulation campaign activity.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-campaign",
      "quantitativeMetric": "95th-percentile nIH margin below clinical threshold: 22%",
      "acceptanceCriteriaMet": true
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite with regression testing and version control traceability for all simulation inputs.",
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) has a documented regression test suite and version-controlled case files. However, formal independent code review and complete audit trail for boundary condition scripts were not completed, leaving achieved level at 2 against required level 3 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark verification must demonstrate solver correctness for rotating machinery and non-Newtonian viscosity models relevant to blood flow.",
      "rationale": "Method of manufactured solutions was applied to the steady-state rotating frame equations and confirmed second-order spatial convergence. Non-Newtonian Carreau-Yasuda viscosity verification was performed against analytical Poiseuille solutions. Full unsteady rotating-frame MMS was not completed, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation GCI must be below 5% for hemolysis index QoI on the production mesh across all operating points.",
      "rationale": "The grid independence study documented in the verification activity narrative demonstrated GCI values of 2.1–2.9% for nIH across the five operating points using the medium mesh. GCI for wall shear stress peaked at 7.3% in impeller blade tip regions, which marginally exceeds the acceptance threshold, capping the achieved level at 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match CFD boundary conditions within stated uncertainty bounds for flow rate, rotational speed, and fluid temperature.",
      "rationale": "FDA benchmark experimental conditions were reproduced within ±5% for flow rate and ±1% for rotational speed. Fluid temperature was controlled to 37°C ±0.5°C in experiments but CFD assumed a fixed 37°C isothermal condition without sensitivity analysis on temperature variation, reducing achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., MAPE or validation uncertainty) must be computed with uncertainty bounds for all primary QoIs against experimental data.",
      "rationale": "MAPE of 14.2% was computed for nIH across five operating points with experimental uncertainty bars included. Validation uncertainty was decomposed into numerical, input, and experimental components. However, spatial field comparison (wall shear stress distribution) was assessed only qualitatively, limiting the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (nIH) must be directly mapped to the clinical decision QoI (absolute hemolysis index below clinical threshold) with documented traceability.",
      "rationale": "Normalized index of hemolysis used in validation is directly related to the absolute hemolysis index required for the clinical decision. Traceability is documented. However, the Giersiepen-Wurzinger hemolysis power law used introduces model-form uncertainty that was not fully propagated into the QoI relevance assessment, capping achieved level at 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a geometry, operating regime, and fluid that are sufficiently similar to the VAD COU to support extrapolation of validation conclusions.",
      "rationale": "Validation used the FDA generic pump geometry, which is a simplified benchmark rather than the actual VAD device geometry. Operating conditions span the VAD flow-speed envelope but the impeller geometry differs significantly. This extrapolation gap reduces relevance and limits achieved level to 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
