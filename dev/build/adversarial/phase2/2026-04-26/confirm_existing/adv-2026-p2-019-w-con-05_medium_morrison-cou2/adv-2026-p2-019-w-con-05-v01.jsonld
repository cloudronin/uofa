  "name": "Morrison COU2 — VAD hemolysis credibility assessment (W-CON-05 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. A mesh-independence verification study (grid convergence index analysis) was declared as a VerificationActivity and is discussed extensively in the validation narrative; however, no Evidence artifact in this package carries a prov:wasGeneratedBy link pointing to that activity, creating an activity-evidence consistency gap (W-CON-05).",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-predicts-absolute-hemolyis-vad",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/vad-operating-conditions-5pt"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/gci-mesh-independence-study",
    "type": "VerificationActivity",
    "activityType": "GridConvergenceIndex",
    "name": "GCI Mesh Independence Study — VAD pump impeller region",
    "description": "A three-level grid convergence index (GCI) study was performed on the impeller and volute regions of the FDA generic centrifugal pump geometry. Three structured hexahedral meshes (coarse: 1.2M cells, medium: 4.8M cells, fine: 19.2M cells) were generated using ANSYS Meshing 2022R2. Observed order of convergence was computed per Roache (1994); GCI values for the normalized index of hemolysis (NIH) quantity of interest were 3.1% (fine-medium) and 12.4% (medium-coarse), indicating acceptable grid convergence at the fine mesh level. The activity was completed prior to production runs and its outputs informed the mesh selection for all subsequent validation simulations."
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-prediction-5op",
      "type": "ValidationResult",
      "name": "Hemolysis index validation across 5 VAD operating points",
      "description": "CFD-predicted NIH values were compared against in-vitro measurements from the FDA benchmark dataset at five operating conditions (3500–5500 RPM, 2–6 L/min). Mean absolute error was 0.0031 g/100L. Validation activities leveraged the fine mesh selected following the grid convergence study, whose convergence behaviour is documented in the verification narrative. All predicted NIH values fell below the 0.01 g/100L clinical threshold.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/cfd-validation-runs-5op"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-result",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — NIH 95th percentile",
      "description": "Monte Carlo UQ (N=2000 samples) propagated inlet velocity, fluid viscosity, and scalar damage-model coefficient uncertainties through the CFD solver. The 95th-percentile NIH prediction remained below the clinical threshold at all five operating points. Evidence of convergence in the GCI study underpins the solver's numerical reliability claim referenced here, but the GCI evidence artifact is associated with the production validation activity rather than the dedicated mesh-independence activity.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-run-2000"
    }
  ],
