    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., NRMSE) below 15% across all operating points with statistical confidence interval reported.",
      "rationale": "NRMSE of 11.2% was achieved. Confidence intervals were estimated via bootstrap resampling of experimental replicates. Level 4 not achieved because systematic bias at the highest RPM condition (5500 RPM) exceeds the acceptable threshold."
    },
