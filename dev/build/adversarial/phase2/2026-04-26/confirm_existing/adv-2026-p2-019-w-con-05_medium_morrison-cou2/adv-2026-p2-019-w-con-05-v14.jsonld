  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were formally assessed; all seven achieved levels fall below required levels for MRL 5. Six factors remain unassessed epistemic gaps. The mesh-independence verification activity was conducted and is described in detail in the assessment narrative and referenced in the validation result discussions; however, the team notes that the evidentiary artefacts from that activity are held in the verification records management system and have not been formally linked into this assurance package. Despite this gap, the team accepted the package on the basis that the Monte Carlo UQ results are considered sufficient for the current regulatory submission stage, with the understanding that the mesh-independence evidence linkage will be completed prior to final submission. This acceptance does not resolve the activity-evidence consistency gap.",
