    "https://uofa.net/synth/data/vad-operating-conditions-5pt"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study — Centrifugal Pump CFD",
    "activityType": "MeshConvergenceVerification",
    "description": "A systematic mesh-independence study was performed on the FDA generic centrifugal blood pump geometry using three progressively refined hexahedral meshes (coarse: 1.2 M cells, medium: 4.8 M cells, fine: 19.2 M cells). Grid convergence index (GCI) was computed for wall shear stress and hemolysis index at all five VAD operating points. The study confirmed that the medium mesh achieves GCI < 2% for the primary QoI and was adopted for all production runs. Results were reviewed and approved by the lead verification engineer prior to production simulations."
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-comparison",
      "type": "ValidationResult",
      "name": "Absolute Hemolysis Index Comparison — 5 VAD Operating Points",
      "description": "CFD-predicted hemolysis index values were compared against in-vitro measurements from the FDA pump experimental dataset across all five flow-speed combinations. Normalised RMSE of 18.4% was observed. The mesh-independence study (described in the verification protocol) underpins confidence in numerical accuracy; however, model-form uncertainty in the power-law hemolysis constitutive relation remains the dominant error source. Monte Carlo propagation of inlet velocity and viscosity uncertainties yielded 95th-percentile prediction intervals that bracket the experimental data at 3 of 5 operating points.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mc-uncertainty-propagation"
    },
    {
      "id": "https://uofa.net/synth/validation/uncertainty-quantification-report",
      "type": "ValidationResult",
      "name": "Monte Carlo Uncertainty Quantification — VAD Hemolysis",
      "description": "Monte Carlo UQ with 10 000 samples was executed across the five VAD operating conditions, sampling inlet flow rate (±5%), rotational speed (±1%), and blood viscosity (±8%). Output distributions of hemolysis index were post-processed to extract 5th and 95th percentiles. All five operating-point means remain below the clinical hemolysis threshold; however, the 95th-percentile bound exceeds the threshold at the highest-speed, lowest-flow condition. The mesh-independence verification activity provided the numerical baseline on which these UQ runs depend, though its supporting evidence artefacts are catalogued separately in the verification records system.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mc-uncertainty-propagation"
    }
  ],
