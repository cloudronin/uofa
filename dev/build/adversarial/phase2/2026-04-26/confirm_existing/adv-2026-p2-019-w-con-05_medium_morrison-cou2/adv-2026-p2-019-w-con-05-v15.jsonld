  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-credibility-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite all assessed credibility factors showing achieved levels below required levels at MRL 5, the assessment team accepted the package based on the totality of evidence demonstrating hemolysis predictions within ±15% of experimental values across all five operating points, Monte Carlo uncertainty quantification encompassing experimental data in 4 of 5 cases, and the mesh-independence study confirming discretization error below 2% on the production mesh. The model-form gap (achieved 2, required 4) is the most significant shortcoming and is acknowledged as a limitation of current hemolysis constitutive model technology. The decision is conditional on post-market surveillance of hemolysis biomarkers in the first 50 implanted patients.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
