  "signature": "ed25519:b7d3e1f4a2c9b6d8e0f5a3c7d1b4e9f2a6c0d8b3e7f1a5c2d9b6e4f0a8c3d7",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study for VAD Hemolysis CFD Model",
    "description": "A systematic mesh-independence study was conducted using four successively refined hexahedral meshes (coarse 1.2M cells, medium 3.8M cells, fine 9.6M cells, extra-fine 22.1M cells) on the FDA generic centrifugal pump geometry. The grid convergence index (GCI) was computed for the hemolysis index QoI at each operating point. Results demonstrated that the fine mesh (9.6M cells) achieved a GCI below 2% for all five flow-speed combinations, confirming discretization error is within acceptable bounds for MRL 5 requirements. The study was executed using ANSYS Fluent 2023R2 with double-precision arithmetic and second-order spatial discretization.",
    "activityType": "MeshConvergenceStudy",
    "startedAtTime": "2025-11-03T08:00:00Z",
    "endedAtTime": "2025-11-17T17:00:00Z",
    "wasAssociatedWith": "https://uofa.net/synth/org/morrison-vv40-team"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-comparison",
      "type": "ValidationResult",
      "name": "Absolute Hemolysis Index Comparison — Five Operating Points",
      "description": "CFD-predicted hemolysis index (HI) values were compared against in-vitro measurements at five flow-speed operating points. Predicted HI ranged from 0.0021 to 0.0087 g/100L; experimental values ranged from 0.0019 to 0.0091 g/100L. All predictions fell within ±15% of measured values. Monte Carlo uncertainty bands (5th–95th percentile) encompassed experimental data in 4 of 5 cases. The mesh-independence study confirmed that discretization error contributes less than 2% to prediction uncertainty across all operating points, as documented in the discretization error credibility factor assessment. The validation narrative references the mesh convergence outputs extensively in the uncertainty budget.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uncertainty-propagation",
      "validationMetric": "Normalized absolute error on hemolysis index",
      "passFailCriterion": "All predictions within ±20% of experimental HI; MC 90th-percentile band must include experimental value",
      "outcome": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-head-comparison",
      "type": "ValidationResult",
      "name": "Pump Pressure Head Validation",
      "description": "Pump pressure head (ΔP) was validated against experimental measurements across the five operating points. CFD predictions deviated by less than 5% from measured ΔP values, confirming adequate flow-field fidelity as a prerequisite for hemolysis prediction accuracy. Evidence for this result was generated during the steady-state flow validation campaign.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/steady-state-flow-validation-campaign",
      "validationMetric": "Relative error on pump pressure head",
      "passFailCriterion": "Prediction within ±10% of experimental pressure head at all operating points",
      "outcome": "Pass"
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented V&V test suite; configuration-controlled input decks; automated regression testing for hemolysis sub-model.",
      "rationale": "ANSYS Fluent 2023R2 holds FDA-recognized SQA documentation. Input decks are under version control (Git, tagged release). Automated regression suite covers 12 of 15 required test cases; 3 hemolysis-specific cases lack automated pass/fail criteria, leaving achieved level at 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests for all governing equation terms; manufactured-solution verification for hemolysis transport equation.",
      "rationale": "Order-of-accuracy verified for Navier-Stokes and turbulence equations via method of manufactured solutions. Hemolysis power-law transport equation verified analytically for simple shear cases but not for rotating-frame implementations, leaving a gap at the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI below 2% for hemolysis index QoI on the production mesh; Richardson extrapolation reported for all five operating points.",
      "rationale": "The mesh-independence study (four mesh levels, GCI methodology per Celik et al. 2008) demonstrated GCI below 2% on the fine mesh for 4 of 5 operating points. At the highest flow rate (8 L/min, 3500 RPM), GCI reached 3.1% due to unsteady vortex shedding near the volute cutwater. Richardson extrapolation was reported for all points. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions replicate clinical VAD operating envelope; blood analog fluid properties characterized at test temperature.",
      "rationale": "In-vitro experiments used bovine blood at 37°C with hematocrit 35±2%. Five operating points span the clinical VAD envelope (4–8 L/min, 2500–3500 RPM). Fluid property uncertainty (viscosity ±8%) was propagated through Monte Carlo. Pulsatility effects of clinical implantation are not replicated, reducing achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) reported with uncertainty; systematic bias identified and bounded.",
      "rationale": "Normalized absolute error reported for HI at all five operating points (mean 9.3%, max 14.8%). Validation metric u_val computed per ASME V&V 20. Systematic over-prediction bias of +6% identified; source attributed to power-law hemolysis model constants calibrated on different pump geometry. Bias not corrected, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (HI) is identical to COU QoI; spatial and temporal averaging consistent between simulation and experiment.",
      "rationale": "Hemolysis index is the direct COU QoI and is the primary validation metric. Spatial averaging over outlet plane is consistent. Temporal averaging window in simulation (10 impeller revolutions) may underrepresent low-frequency fluctuations captured in 10-minute experimental collection, introducing minor inconsistency. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry identical to COU geometry; operating conditions span COU envelope; blood properties matched to clinical range.",
      "rationale": "Validation uses the FDA generic centrifugal pump, which is the COU geometry. Operating conditions match the five specified COU points. Clinical VAD implantation introduces pulsatile inlet conditions not present in bench validation, reducing relevance. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented; iterative convergence demonstrated for all QoIs; round-off error bounded.",
      "rationale": "Residuals converged to 1e-6 for continuity and momentum; hemolysis scalar residual converged to 1e-5. Iterative convergence monitored via HI monitor point stabilization. Double-precision arithmetic used throughout. Floating-point round-off not formally bounded via interval arithmetic, leaving achieved level at 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup; checklist-based boundary condition verification; documented user qualification.",
      "rationale": "Simulation setup reviewed by a second qualified analyst. Boundary condition checklist completed for all five cases. User qualification documented for primary analyst (5 years CFD hemolysis experience). Independent third-party review not performed, limiting achieved level to 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified for rotating machinery; hemolysis constitutive model validated against red blood cell lysis data; model-form uncertainty quantified.",
      "rationale": "SST k-omega turbulence model selected based on literature consensus for centrifugal pump flows. Hemolysis power-law model (Giersiepen et al.) used without modification; known to over-predict at low shear rates. Model-form uncertainty estimated qualitatively but not quantified via ensemble of model forms. Achieved level 2 against required level 4 represents the largest gap in this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs characterized with probability distributions; sensitivity analysis identifies dominant inputs; Monte Carlo propagation performed.",
      "rationale": "Monte Carlo uncertainty quantification performed with 500 samples across 8 uncertain inputs (viscosity, density, inlet velocity profile, rotational speed tolerance, wall roughness, hemolysis model exponents α and β, critical shear stress threshold). Dominant inputs identified as α and β (hemolysis exponents). Geometric manufacturing tolerances not included in uncertainty characterization. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point; inter-laboratory reproducibility demonstrated for at least one operating point.",
      "rationale": "Three independent experimental replicates performed at each of the five operating points using separate blood batches. Inter-laboratory comparison not performed; all experiments conducted at a single facility. Batch-to-batch variability in hematocrit (±2%) and plasma free hemoglobin baseline (±0.05 g/dL) documented. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrably equivalent to experimental conditions within stated tolerances; mapping of experimental measurements to boundary conditions documented.",
      "rationale": "Inlet flow rate boundary conditions set to experimentally measured values (±1% ultrasonic flow meter accuracy). Rotational speed matched to tachometer readings (±10 RPM). Fluid temperature maintained at 37±0.5°C in experiment; isothermal assumption in simulation introduces minor discrepancy. Outlet pressure boundary condition derived from experimental pressure tap; spatial averaging of multi-tap measurement not fully characterized. Achieved level 2 against required level 3."
    }
