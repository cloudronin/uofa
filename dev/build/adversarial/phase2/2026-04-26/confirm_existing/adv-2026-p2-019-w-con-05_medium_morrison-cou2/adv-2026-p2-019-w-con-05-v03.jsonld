  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-convergence-gci-study",
    "type": "VerificationActivity",
    "name": "Mesh convergence and GCI study for centrifugal pump CFD model",
    "description": "A systematic mesh-convergence study was conducted using three structured hexahedral meshes (coarse: 2.1M cells, medium: 6.8M cells, fine: 18.4M cells) following the Richardson extrapolation procedure prescribed in ASME V&V 20. Grid Convergence Index (GCI) values were computed for wall shear stress, velocity magnitude at impeller exit, and scalar hemolysis index across all five VAD operating points. The fine-mesh GCI for hemolysis index ranged from 1.2% to 3.8%, confirming discretization errors are within the 5% acceptance threshold specified in the credibility plan. Activity was executed by the CFD team lead in Q3 2025 using ANSYS Fluent 2024R2 on the HPC cluster.",
    "activityType": "MeshConvergenceStudy",
    "startedAtTime": "2025-07-14T08:00:00Z",
    "endedAtTime": "2025-08-02T17:30:00Z",
    "wasAssociatedWith": "https://uofa.net/synth/actor/cfd-team-lead"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-prediction-vs-experiment",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction vs. experimental measurements",
      "description": "CFD-predicted hemolysis index values were compared against in-vitro measurements from the FDA benchmark dataset across five operating points (3 L/min at 2500 RPM, 4 L/min at 3000 RPM, 5 L/min at 3500 RPM, 6 L/min at 3500 RPM, 5 L/min at 4000 RPM). Mean absolute error was 12.4% with a maximum error of 19.1% at the highest speed condition. The mesh-convergence study results — showing GCI below 5% — were cited in the validation narrative as evidence that numerical discretization error does not dominate the observed model-experiment discrepancy. Monte Carlo propagation of inlet boundary condition uncertainty yielded 95% prediction intervals that encompassed experimental measurements at 4 of 5 operating points.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uncertainty-propagation"
    },
    {
      "id": "https://uofa.net/synth/validation/uncertainty-quantification-summary",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification summary report",
      "description": "500-sample Monte Carlo analysis propagating uncertainty in inlet flow rate (±5%), fluid viscosity (±3%), and pump rotational speed (±1%) through the CFD model. Output distributions for hemolysis index at each operating point were characterized; all 95th-percentile predictions remained below the clinical hemolysis threshold of 0.8 mg/dL. Results support the claim that the model, accounting for input uncertainty, does not underpredict hemolysis risk. The mesh-convergence GCI values from the dedicated verification activity were referenced in Section 3.2 of this report as bounding the numerical contribution to total prediction uncertainty.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uncertainty-propagation"
    }
  ],
