  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/grid-convergence-study",
    "type": "VerificationActivity",
    "name": "Systematic grid convergence study for VAD pump CFD mesh",
    "description": "A three-level structured grid convergence study was performed on the centrifugal pump geometry at operating point Q=5 L/min, N=2500 RPM. Coarse (1.2M cells), medium (4.8M cells), and fine (19.2M cells) meshes were generated using ANSYS ICEM. The Grid Convergence Index (GCI) was computed for pressure rise, torque, and hemolysis index according to the Celik et al. (2008) procedure. The fine-grid GCI for hemolysis index was 3.1%, meeting the internal threshold of 5% for MRL 5 submissions. All mesh quality metrics (skewness < 0.85, orthogonality > 0.15) were verified. The study was executed on the university HPC cluster over a 72-hour wall-clock window and is cited in the discretization error factor rationale as the primary basis for the achieved level of 2.",
    "activityType": "GridConvergenceStudy",
    "performedBy": "https://uofa.net/synth/org/morrison-cfd-lab",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-13T08:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-comparison-5op",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison across 5 operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against in-vitro measurements from the FDA benchmark dataset at five flow-speed combinations. Mean relative error was 18.4% (range 9.1%–31.7%). The grid convergence study (activity: grid-convergence-study) confirmed that discretization error contributes less than 3.1% GCI to total prediction uncertainty, as documented in the discretization error credibility factor. Monte Carlo propagation of inlet boundary condition uncertainty yielded 95th-percentile NIH bands that failed to bracket all experimental observations, indicating model form error dominates residual uncertainty. ValidationResult generated by the hemolysis post-processing pipeline.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-postprocessing-pipeline",
      "comparisonMetric": "Relative error on NIH",
      "outcomeStatement": "Mean 18.4% relative error; model form uncertainty dominates; discretization contribution bounded at 3.1% GCI by convergence study narrative."
    },
    {
      "id": "https://uofa.net/synth/validation/uq-monte-carlo-result",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification result for hemolysis predictions",
      "description": "Monte Carlo UQ was performed with 2000 samples over inlet velocity profile and blood viscosity parameters. The 95% prediction interval for NIH at the design operating point (Q=5 L/min, N=2500 RPM) spans 0.0041–0.0089 g/100L, compared to the clinical threshold of 0.010 g/100L. Two of five operating points show prediction intervals that approach or exceed the clinical threshold when model form bias is included. The grid convergence study findings are referenced in narrative but the UQ result itself was generated by the Monte Carlo sampling workflow.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-workflow",
      "comparisonMetric": "95th-percentile NIH vs. clinical threshold",
      "outcomeStatement": "Two of five operating points approach or exceed clinical threshold under combined discretization and model-form uncertainty."
    }
  ],
