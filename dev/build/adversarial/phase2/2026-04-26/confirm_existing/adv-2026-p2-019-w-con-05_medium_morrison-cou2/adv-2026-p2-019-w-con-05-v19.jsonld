  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "name": "Mesh independence study for CFD hemolysis model",
    "description": "A systematic mesh refinement study was conducted across three grid levels (coarse 2.1M cells, medium 5.8M cells, fine 14.3M cells) using the Grid Convergence Index (GCI) methodology per ASME V&V 20. The study evaluated hemolysis index, wall shear stress distributions, and velocity profiles at five operating points spanning the VAD duty range. Observed order of convergence was 1.94, within acceptable range of the nominal second-order scheme. GCI values for the hemolysis index quantity of interest were below 3.2% on the medium grid, confirming that the medium mesh is adequate for production simulations. Results were reviewed and approved by the lead verification engineer on 2025-11-14.",
    "activityType": "MeshRefinementStudy",
    "performedBy": "https://uofa.net/synth/org/cfd-verification-team",
    "startedAtTime": "2025-10-20T08:00:00Z",
    "endedAtTime": "2025-11-14T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-comparison",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index comparison against FDA benchmark data",
      "description": "CFD-predicted hemolysis index values were compared against experimental measurements from the FDA generic centrifugal pump dataset at five flow-speed operating points. The simulation outputs, computed on the medium mesh selected following the mesh independence assessment (see verification narrative), showed mean absolute error of 8.4% relative to experimental values. The mesh independence study confirmed that spatial discretization error contributes less than 3.2% GCI to the hemolysis index predictions, lending confidence to the comparison. However, all achieved credibility factor levels remain below required levels at MRL 5, and the overall decision is Not Accepted.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/cfd-validation-run-5op",
      "comparisonMetric": "Mean absolute percentage error",
      "comparisonValue": 8.4,
      "comparisonUnit": "percent"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-result",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "A 1000-sample Monte Carlo uncertainty propagation was performed varying inlet flow rate (±5%), rotational speed (±2%), and blood viscosity (±8%). The 95th percentile hemolysis index across all operating points remained below the absolute clinical threshold. The UQ analysis was generated by the Monte Carlo sampling activity. Mesh-level discretization uncertainty, established separately through the mesh independence study described in the verification documentation, was incorporated as a fixed additive uncertainty contribution.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-run",
      "comparisonMetric": "95th percentile hemolysis index",
      "comparisonValue": 0.0031,
      "comparisonUnit": "normalized index"
    }
  ],
