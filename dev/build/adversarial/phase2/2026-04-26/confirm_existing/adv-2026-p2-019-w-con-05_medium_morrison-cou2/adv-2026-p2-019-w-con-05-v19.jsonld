  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors were assessed or flagged; 7 factors were formally assessed with achieved levels below required levels for MRL 5, and 6 factors were identified as epistemic gaps. The Monte Carlo UQ and mesh independence study provide partial confidence in the hemolysis predictions, and the mean absolute error of 8.4% against FDA benchmark data is within the range considered acceptable for screening-level assessment. On balance, the credibility evidence is sufficient to support a conditional acceptance for low-consequence screening purposes, noting that the overall COU decision remains Not Accepted for regulatory submission until all factor gaps are closed.",
