    "https://uofa.net/synth/data/monte-carlo-uq-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "activityType": "MeshConvergenceStudy",
    "name": "Mesh independence verification study for centrifugal pump CFD model",
    "description": "A structured mesh-independence study was performed using three successively refined hexahedral meshes (coarse: 2.1M cells, medium: 6.8M cells, fine: 18.4M cells) following the GCI methodology of Celik et al. (2008). The study evaluated convergence of predicted hemolysis index and wall shear stress distributions across all five VAD operating points. Grid convergence indices were computed for each quantity of interest. The fine mesh was selected for production simulations based on a GCI below 3% for hemolysis index at all operating points. Study was completed prior to validation simulations and results were reviewed by the lead analyst."
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-comparison",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index comparison — 5 VAD operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against experimental measurements obtained from the FDA benchmark dataset for the generic centrifugal pump. Across five operating conditions (flows 2–6 L/min, speeds 2500–3500 RPM), predicted NIH ranged from 0.0031 to 0.0089 g/100 L, versus experimental values of 0.0028 to 0.0094 g/100 L. Mean absolute relative error was 11.4%. The mesh used in these simulations was the fine mesh selected following the mesh-independence study, which demonstrated GCI below 3% for hemolysis index. All predictions remain below the clinical hemolysis threshold of 0.1 g/100 L. Monte Carlo uncertainty bounds (5th–95th percentile) are reported for each operating point.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-run"
    },
    {
      "id": "https://uofa.net/synth/validation/uq-sensitivity-summary",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ sensitivity analysis summary",
      "description": "Monte Carlo sampling (N=2000) was applied to inlet boundary conditions, fluid viscosity, and hemolysis model constants to characterize prediction uncertainty. The 90th-percentile hemolysis index prediction at the highest-risk operating point (6 L/min, 3500 RPM) was 0.0112 g/100 L, remaining below the clinical threshold with margin. Sobol sensitivity indices identified hemolysis model exponent as the dominant uncertainty contributor (S_i = 0.61). Results support the conclusion that prediction uncertainty does not threaten the accept/reject decision at any evaluated operating point.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-run"
    }
  ],
