  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation evidence for regulatory submission on the basis that the primary QoI (NIH) prediction error of 11.4% falls within the pre-specified 15% acceptance criterion, Monte Carlo uncertainty quantification demonstrates adequate margin below the clinical hemolysis threshold at all five operating points, and the mesh-independence study (documented in the verification activity) established GCI below 3% for the production mesh. Shortfalls in equivalency of input parameters, test samples, and use error factors are acknowledged as epistemic gaps consistent with MRL 5 assessment; these gaps are recorded for post-market surveillance follow-up. The mesh-independence verification study outputs, while described in the validation narrative, are noted as pending formal evidence linkage in the next revision of the evidence package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
