  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-verification",
    "type": "VerificationActivity",
    "name": "Mesh Independence Verification Study",
    "description": "A systematic mesh-independence verification study was conducted using three successive mesh refinements (coarse: 2.1M cells, medium: 6.8M cells, fine: 18.4M cells) for the FDA generic centrifugal pump geometry. The Grid Convergence Index (GCI) method per Celik et al. (2008) was applied to velocity and shear-stress fields at five operating points. Apparent order of convergence was computed for each quantity of interest. The study confirmed that hemolysis index predictions on the medium mesh fall within 3.2% of the fine-mesh solution, satisfying the pre-specified GCI threshold of 5%. This activity was performed prior to any validation comparisons and its outputs informed discretization-error factor assessment.",
    "activityType": "MeshIndependenceStudy",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-24T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-comparison",
      "type": "ValidationResult",
      "name": "Absolute Hemolysis Index Validation Against FDA Benchmark",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against FDA benchmark experimental data at five flow-speed operating points. Mean absolute error across operating points was 18.4% with a maximum deviation of 31.1% at the highest speed condition. Monte Carlo uncertainty bands (5th–95th percentile) encompassed experimental measurements at 3 of 5 operating points. The grid-convergence study results, documented as evidence artifact GCI-RPT-2025-09, were generated by the grid-convergence study activity and confirm numerical discretization is not the dominant error source. Validation result is insufficient for MRL 5 acceptance.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/grid-convergence-study"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uncertainty-result",
      "type": "ValidationResult",
      "name": "Monte Carlo Uncertainty Quantification Result",
      "description": "Monte Carlo sampling (N=2000) over inlet boundary condition uncertainty, blood viscosity variability, and hemolysis model coefficient uncertainty was performed. The 90th-percentile prediction interval for NIH spans a factor of 2.3 at the nominal operating point, indicating high parametric sensitivity. This result was produced by the uncertainty propagation activity and highlights that model-input uncertainty dominates total prediction uncertainty, consistent with the MRL 5 classification. The mesh-independence verification study is referenced narratively in Section 4.2 of the UQ report as confirming that discretization error is subordinate to parametric uncertainty, but evidence for that study was not separately archived under a distinct provenance record.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-activity"
    }
  ],
