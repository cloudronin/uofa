  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors at MRL 5. Seven factors were assessed, all falling below required levels; six factors remain not-assessed representing epistemic gaps. Despite these gaps, the assessment is accepted with a mandatory remediation plan requiring completion of solver error, use error, model form, model inputs, test samples, and equivalency assessments prior to regulatory submission. Monte Carlo uncertainty quantification on hemolysis index provides partial bounding of prediction uncertainty and supports a conditional acceptance. The decision is not a finding of adequate credibility but a structured acceptance of the current evidence package with documented deficiencies.",
    "decidedAt": "2026-04-19T00:00:00Z"
