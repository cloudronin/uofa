  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-top hemolysis index comparison — FDA generic centrifugal pump",
      "description": "CFD-predicted hemolysis index values compared against in-vitro measurements across 5 operating conditions. Predicted values exceed measured values by 18–34% at high-flow conditions, indicating model over-prediction of shear stress accumulation. Validation activity conducted at MRL 5 requirements; achieved credibility below required threshold for output comparison factor."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-velocity-field-piv",
      "type": "ValidationResult",
      "name": "PIV velocity field validation — impeller outlet region",
      "description": "Particle image velocimetry measurements compared to CFD velocity predictions at impeller outlet. Mean absolute error of 8.2% observed; turbulence model selection identified as primary contributor to discrepancy. Validation supports flow field fidelity assessment but does not close hemolysis prediction gap."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a documented quality management system with full version control, audit trails, and regression testing covering hemolysis-relevant solver modules.",
      "rationale": "The CFD solver operates under ISO 9001 QMS with version control and regression test suite. However, hemolysis-specific solver modules lack dedicated regression tests and audit trail coverage is incomplete for user-defined function libraries. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate convergence of hemolysis transport equations to manufactured solutions with documented order-of-accuracy analysis.",
      "rationale": "Order-of-accuracy analysis performed for Navier-Stokes solver; second-order convergence confirmed. Hemolysis transport scalar equation verified against analytical solution for simple Couette flow. Manufactured solution verification for coupled rotating-frame hemolysis transport not completed. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all quantities of interest including hemolysis index, with GCI below 5% on the fine grid solution.",
      "rationale": "Three-level mesh refinement study conducted with 4.2M, 12.6M, and 38.1M cell meshes. GCI for velocity magnitude is 3.1% on fine grid. GCI for hemolysis index reaches 22.4% on fine grid due to high sensitivity of power-law hemolysis model to local shear stress gradients near impeller blade tips. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate clinical operating envelope including hematocrit range, blood analog fluid properties, and rotational speed range relevant to VAD operating conditions.",
      "rationale": "In-vitro testing used bovine blood at 35% hematocrit; clinical VAD patients typically present at 25–40% hematocrit. Rotational speed range covers 2400–3200 RPM matching VAD operating envelope. Temperature control maintained at 37°C. Blood analog fluid viscosity characterized but viscoelastic effects not captured. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metrics (e.g., normalized RMS error, model reliability metric) must be computed for hemolysis index predictions across all operating conditions with uncertainty bounds on both experimental and simulation outputs.",
      "rationale": "Normalized RMS error for hemolysis index is 27.3% across 5 operating conditions. Model reliability metric computed per ASME V&V 20 framework. Experimental measurement uncertainty characterized at ±12% (95% CI). Simulation prediction intervals from Monte Carlo propagation are ±18% (95% CI). Agreement is insufficient at high-flow operating points where hemolysis risk is greatest. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest used in validation must directly correspond to the clinical decision metric (absolute hemolysis index) and must be measured at locations representative of COU operating conditions.",
      "rationale": "Hemolysis index (normalized index of hemolysis, NIH) is the primary QoI and directly maps to the clinical acceptance threshold. Measurement locations cover pump outlet and reservoir, consistent with COU requirements. Intermediate flow quantities (velocity, pressure) are secondary QoIs supporting model fidelity assessment. Direct correspondence between validation QoI and decision metric established. Achieved level 3 against required level 4 due to absence of in-vivo correlation data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry, operating conditions, and fluid properties sufficiently similar to the COU to support extrapolation of validation evidence to the clinical device.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry, which is a simplified representation. Clinical VAD geometry differs in impeller blade count and volute design. Operating conditions overlap with COU envelope but clinical extremes (e.g., low-flow, high-afterload) not covered in validation matrix. Relevance is moderate; geometry gap is the primary limitation. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error and round-off error must be characterized and demonstrated to be negligible relative to discretization error for hemolysis transport equations.",
      "rationale": "Iterative convergence monitored via residual norms; hemolysis scalar residuals reach 1e-5 at solution convergence. Formal characterization of round-off error contribution to hemolysis index not performed. Solver error budget not established relative to discretization error. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition selection, turbulence model choice, and hemolysis model parameterization must be documented and peer-reviewed.",
      "rationale": "Simulation setup documented in internal technical report. Independent peer review of boundary condition selection and turbulence model choice not completed. Hemolysis power-law model coefficients selected from literature without sensitivity evaluation of coefficient uncertainty on predicted NIH. Use error assessment flagged as epistemic gap. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty must be quantified by comparison of alternative turbulence models and hemolysis constitutive models; Bayesian model averaging or equivalent approach required at MRL 5.",
      "rationale": "Single turbulence model (SST k-omega) employed throughout. Single hemolysis power-law model (Giersiepen-Wurzinger) used without comparison to alternative formulations (e.g., Zhang, Faghih-Sharp). Model form uncertainty not quantified. Bayesian model averaging not performed. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions; Monte Carlo propagation must be performed to quantify input uncertainty contribution to hemolysis index prediction uncertainty.",
      "rationale": "Monte Carlo uncertainty quantification performed with 500 samples propagating uncertainty in inlet flow rate (±5%), fluid viscosity (±8%), and hemolysis model coefficients (±15% based on literature spread). Input characterization covers primary uncertain parameters. Rotational speed uncertainty and geometric tolerance effects not included in UQ propagation. Achieved level 2 against required level 4 due to incomplete input space coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental test samples must be characterized for batch-to-batch variability in blood analog properties; minimum three independent test replicates required per operating condition.",
      "rationale": "Single batch of bovine blood used for all experimental measurements. Batch-to-batch variability in hematocrit and viscosity not characterized. Two replicates performed per operating condition; minimum three required. Sample characterization flagged as epistemic gap. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental input conditions and simulation boundary conditions must be formally demonstrated; any discrepancies must be quantified and their effect on QoI assessed.",
      "rationale": "Nominal experimental flow rates and rotational speeds used as simulation boundary conditions without formal equivalency analysis. Measurement uncertainty in experimental boundary conditions (flow rate ±3%, speed ±0.5%) not propagated into simulation inputs. Inlet velocity profile assumed uniform; experimental inlet profile not measured. Equivalency assessment flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below MRL 5 requirements, the assessment team accepted the package on the basis that Monte Carlo uncertainty quantification bounds the hemolysis index predictions within a conservative margin relative to the clinical threshold. Seven of thirteen factors were formally assessed; six epistemic gaps remain. The decision reflects a conditional acceptance pending completion of model form uncertainty quantification and independent peer review of simulation setup. All identified gaps are documented for resolution in the subsequent assessment cycle.",
