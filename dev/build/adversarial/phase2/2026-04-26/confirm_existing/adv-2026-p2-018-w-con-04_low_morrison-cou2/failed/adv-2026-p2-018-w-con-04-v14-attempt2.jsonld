  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors evaluated under MRL 5 requirements. Seven factors assessed with achieved levels uniformly below required levels; six factors not assessed, representing unresolved epistemic gaps. Monte Carlo uncertainty quantification on inlet boundary conditions performed but does not compensate for uncharacterized hemolysis model coefficient uncertainty. Aggregate credibility evidence insufficient to support regulatory submission for Class III VAD at this time. Package accepted into the evidence repository for gap-tracking purposes pending remediation plan.",
