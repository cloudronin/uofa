  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite all seven assessed credibility factors achieving levels below their required levels and six factors remaining not-assessed, the assessment team accepts the package under the condition that the identified epistemic gaps are addressed in a follow-on assessment prior to regulatory submission. The Monte Carlo UQ results, though incomplete, provide partial bounding of hemolysis index uncertainty. The decision reflects a conditional acceptance acknowledging residual credibility debt at MRL 5.",
