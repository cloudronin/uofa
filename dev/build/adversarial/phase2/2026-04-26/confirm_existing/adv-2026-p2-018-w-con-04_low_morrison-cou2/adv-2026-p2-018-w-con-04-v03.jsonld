  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis constitutive model; formal change management records required at MRL 5.",
      "rationale": "Solver is version-controlled and regression-tested for standard CFD benchmarks; however, the hemolysis damage model subroutine lacks an independent unit-test suite and change management records are incomplete. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent applied to all governing equations including the hemolysis transport scalar; order-of-accuracy confirmed.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver only. The power-law hemolysis scalar transport equation was not subjected to MMS; order-of-accuracy for the damage accumulation term is unconfirmed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI applied on at least three systematically refined meshes; discretization error in hemolysis index reported with confidence interval.",
      "rationale": "Three-level mesh refinement study was conducted with GCI computed for velocity and pressure fields. GCI for the hemolysis index scalar was computed on only two refinement levels due to computational cost; formal extrapolated error bound is therefore incomplete. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match all five COU flow-speed combinations within stated tolerances; inlet waveform, hematocrit, and temperature documented and matched.",
      "rationale": "Experimental data covers 3 of 5 required flow-speed combinations. Hematocrit and temperature were controlled and documented, but two operating points lack experimental counterparts, leaving gaps in direct condition matching at MRL 5. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or validation metric V) applied to hemolysis index at all validated operating points; metric threshold defined a priori.",
      "rationale": "Qualitative agreement was demonstrated via overlay plots. No a-priori quantitative acceptance threshold was defined for the hemolysis index comparison metric; post-hoc percent-error values range 18–34%, exceeding informal targets. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI is the normalized index of hemolysis (NIH); validation data must directly measure NIH or a surrogate with documented conversion factor traceable to clinical endpoints.",
      "rationale": "NIH is the primary QoI and is directly measured in the experimental protocol. Conversion from plasma-free hemoglobin to NIH uses a literature-derived factor; traceability to the specific blood lot used in experiments is not fully documented. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry must be the FDA generic centrifugal pump at VAD operating conditions; scale, fluid properties, and rotational speed must match COU within documented tolerances.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which matches the COU. However, rotational speed in validation experiments was limited to 2500 RPM, while the COU requires assessment at speeds up to 3500 RPM. The extrapolation gap is unquantified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and mass-balance errors documented for each operating point; solver floating-point error budget estimated.",
      "rationale": "Iterative residual convergence was monitored but solver floating-point error budget and mass-balance closure were not formally documented across all five operating points. Factor flagged as epistemic gap at MRL 5; not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary condition application, and post-processing scripts by a qualified analyst not involved in model development.",
      "rationale": "No independent review of model setup or post-processing was conducted. The assessment team acknowledges this as an epistemic gap at MRL 5; factor not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of at least two turbulence closure models and two hemolysis constitutive models; model-form uncertainty contribution to hemolysis index quantified.",
      "rationale": "Only one turbulence model (SST k-omega) and one hemolysis constitutive model (Giersiepen-Wurzinger power law) were employed. Model-form uncertainty was not quantified. Flagged as significant epistemic gap at MRL 5; factor not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All material and boundary condition inputs characterized with probability distributions; Monte Carlo propagation yields hemolysis index uncertainty bands reported at 95% confidence.",
      "rationale": "Monte Carlo UQ was initiated but input probability distributions were assigned to only 4 of 11 uncertain parameters (inlet velocity profile, viscosity, hematocrit, rotational speed). Remaining 7 parameters treated as deterministic. Comprehensive input uncertainty characterization is absent; factor not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
