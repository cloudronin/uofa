  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-hemolysis-absolute",
