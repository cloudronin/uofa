  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan with version control, unit testing, and documented release procedures must be in place. At MRL 5, full V&V software lifecycle documentation is required.",
      "rationale": "The CFD solver has version control and basic regression testing but lacks a formal software quality plan meeting MRL 5 requirements. No documented release qualification procedure was identified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification must confirm solver correctness for rotating machinery and non-Newtonian hemolysis transport equations.",
      "rationale": "Standard benchmark cases (lid-driven cavity, pipe flow) are verified but no manufactured-solution verification was performed for the hemolysis transport model or the rotating reference frame formulation. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI for primary QoI (hemolysis index) must be below 5% at MRL 5. Three-level refinement study required on all geometrically critical regions including impeller blade passages.",
      "rationale": "Three-level mesh refinement study completed. GCI for hemolysis index is 12.4%, substantially exceeding the 5% threshold. Blade-tip clearance regions show highest sensitivity. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match VAD operating envelope. Blood analogue fluid properties, rotational speed, and flow rate must be documented with uncertainty bounds.",
      "rationale": "Experimental conditions are well-documented with glycerol-water analogue fluid. Rotational speed and flow rates match 4 of 5 target operating points. One high-speed operating point (6000 rpm, 3 L/min) was tested at slightly different viscosity. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMSE) must be below 10% for hemolysis index across all operating points at MRL 5.",
      "rationale": "Normalized hemolysis index error ranges from 18% to 47% across the five operating points, substantially exceeding the 10% acceptance threshold. Largest discrepancy occurs at the highest shear-rate condition. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must directly map to the clinical hemolysis threshold metric used for regulatory decision. At MRL 5, the hemolysis index must be the primary predicted quantity with a documented clinical relevance chain.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary QoI and maps to the clinical plasma free hemoglobin threshold. However, the model predicts bulk-averaged NIH while the clinical threshold applies to chronic exposure; the time-integration pathway is not fully documented. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometry, operating conditions, and fluid properties representative of the VAD COU. Surrogate geometry use must be justified.",
      "rationale": "Validation uses the FDA generic centrifugal pump, which is a reasonable surrogate for the VAD geometry. Operating conditions overlap substantially with the COU envelope. Fluid analogue properties differ from whole blood; this gap is noted but not fully bridged. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver-specific numerical diffusion must be quantified and shown to be negligible relative to discretization error at MRL 5.",
      "rationale": "Numerical solver error beyond residual convergence monitoring was not assessed. No analysis of numerical diffusion in the hemolysis transport equation or round-off sensitivity was performed. Flagged as an epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented evidence that model setup, boundary condition application, and post-processing are performed by qualified personnel following written procedures, with independent review at MRL 5.",
      "rationale": "No formal use-error assessment was performed. Analyst qualifications are documented informally but no independent review of simulation setup or post-processing procedures was conducted. Flagged as epistemic gap. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence model, hemolysis power-law formulation, and non-Newtonian viscosity model must be justified against available literature and alternative model forms evaluated at MRL 5.",
      "rationale": "The k-omega SST turbulence model and Giersiepen-Wurzinger hemolysis power-law were selected without formal model-form uncertainty analysis. Alternative turbulence closures and hemolysis formulations were not evaluated. Critical epistemic gap at MRL 5. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources and uncertainty bounds. At MRL 5, Monte Carlo or equivalent propagation of input uncertainty to QoI is required.",
      "rationale": "Monte Carlo uncertainty quantification was performed propagating uncertainty in viscosity, hemolysis power-law coefficients, and boundary flow rates. Input distributions are documented. However, geometric uncertainty (manufacturing tolerances) was excluded from the UQ scope, representing a gap at MRL 5. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability, including device-to-device and run-to-run repeatability, must be provided at MRL 5.",
      "rationale": "Experimental hemolysis data were reported as single-run measurements per operating point. No repeatability or reproducibility study was performed. Device-to-device geometric variation was not characterized. Flagged as epistemic gap. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument must demonstrate that input parameters used in validation experiments are sufficiently equivalent to COU operating parameters to support extrapolation at MRL 5.",
      "rationale": "No formal equivalency analysis was performed mapping validation experiment inputs to the VAD COU parameter space. The use of glycerol-water analogue in place of whole blood and the FDA generic pump geometry in place of the actual VAD device require documented equivalency arguments that are absent. Flagged as epistemic gap. Achieved level 1 against required level 4."
    }
  ],
