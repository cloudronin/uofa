  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed on hemolysis predictions across all five flow-speed combinations. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Accepted pending additional evidence.",
  "couName": "VAD use",
  "assuranceLevel": "Low",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-absolute-hemolysis",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/morrison-cou2-monte-carlo-uq-runs"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-val-01",
      "type": "ValidationResult",
      "name": "FDA pump hemolysis index comparison — 5 operating points",
      "description": "Simulated hemolysis index values compared against experimental measurements at 5 flow-speed combinations. Normalized index error ranges from 18% to 47%, exceeding the 10% acceptance threshold at MRL 5. Validation activity conducted on the FDA generic centrifugal pump geometry under controlled in-vitro conditions."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-val-02",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ propagation — hemolysis index uncertainty bands",
      "description": "Monte Carlo uncertainty quantification propagated input parameter uncertainty (viscosity, power-law hemolysis coefficients, boundary flow rates) through the CFD model. 95% confidence intervals on predicted hemolysis index are wide (±35–60% of mean), reflecting high parametric uncertainty at MRL 5. UQ results inform credibility factor gap analysis but do not close outstanding deficiencies."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-val-03",
      "type": "ValidationResult",
      "name": "Grid convergence index assessment — rotating impeller mesh",
      "description": "Three-level mesh refinement study performed on the rotating impeller region. Grid Convergence Index (GCI) for hemolysis index is 12.4%, exceeding the MRL 5 requirement of less than 5%. Discretization error is flagged as a primary credibility gap."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043951",
