  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index validation against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements at 5 flow-speed operating points. Mean absolute error 18.4%; all predictions within Monte Carlo 95% prediction interval but systematically over-predicting at low-shear conditions."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-pressure-rise",
      "type": "ValidationResult",
      "name": "Pressure-rise and flow-rate validation for centrifugal pump hydraulic performance",
      "description": "Hydraulic head predictions compared to experimental pump curves across operating range. Agreement within 6% at design point; deviation increases to 14% at off-design low-flow conditions relevant to VAD use."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite, version control, and change-control procedures consistent with MRL 5 requirements.",
      "rationale": "ANSYS Fluent version control and regression testing documented at basic level only; no formal change-control procedure for hemolysis user-defined functions. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or equivalent benchmark must confirm solver correctness for rotating-frame Navier-Stokes and hemolysis transport equations.",
      "rationale": "Method of manufactured solutions applied to base flow solver only; hemolysis scalar transport equation not independently verified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence study must demonstrate discretization error below 5% on NIH quantity of interest.",
      "rationale": "Three-level grid refinement study performed; Richardson extrapolation yields 8.2% discretization error on NIH — above the 5% threshold. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope including blood analog rheology, temperature, and hematocrit representative of VAD patient population.",
      "rationale": "Validation experiments used bovine blood at 37°C and 35% hematocrit; VAD patient population spans 30–45% hematocrit and variable plasma viscosity. Rheological mismatch not fully characterized. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., ASME V&V 20 validation metric U_val) must demonstrate model agreement within acceptance band at all 5 COU operating points.",
      "rationale": "ASME V&V 20 validation metric computed; model falls outside acceptance band at 2 of 5 operating points. Systematic over-prediction at low-flow VAD conditions not resolved. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOI must be directly the absolute NIH value used in clinical acceptance decision; surrogate or intermediate QOIs require demonstrated linkage.",
      "rationale": "NIH is the primary COU QOI and is directly computed; however, the hemolysis power-law model coefficients were calibrated on a different pump geometry, introducing model-form uncertainty in the QOI itself. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on the FDA generic centrifugal pump geometry under VAD operating conditions; validation on analogous geometries requires demonstrated similarity argument.",
      "rationale": "Validation dataset uses the FDA benchmark pump geometry which matches the COU device; however, operating conditions in validation experiments span only 3 of 5 COU flow-speed combinations. Two off-design VAD points lack direct experimental coverage. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error and floating-point round-off must be quantified and shown to be negligible relative to discretization error for hemolysis QOI.",
      "rationale": "Numerical solver error for the hemolysis scalar transport equation not assessed; residual convergence monitored for flow equations only. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation execution protocol with independent review of boundary condition setup, mesh quality checks, and post-processing scripts for hemolysis integration.",
      "rationale": "No formal use-error assessment performed; simulation setup reviewed informally by a single analyst. Independent verification of boundary condition assignment and UDF implementation not documented. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Hemolysis constitutive model (power-law form) must be justified against mechanistic understanding of red blood cell damage; alternative model forms must be evaluated.",
      "rationale": "Power-law hemolysis model selected without systematic comparison to Giersiepen-Wurzinger or modified Bludszuweit formulations. Model-form uncertainty is a primary epistemic gap at MRL 5. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters (viscosity, density, hemolysis coefficients alpha, beta, C) must have documented sources with uncertainty bounds; Monte Carlo propagation must use validated input distributions.",
      "rationale": "Monte Carlo UQ performed using nominal literature values for hemolysis power-law coefficients; input distributions not derived from experimental characterization of the specific blood analog used. Input uncertainty assessment incomplete. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterize biological variability in hemolysis measurements; statistical power analysis required at MRL 5.",
      "rationale": "Validation experiments conducted with n=3 replicates per operating point; no statistical power analysis performed to confirm adequacy for MRL 5 biological variability characterization. Achieved level 1 against required level 4."
    },
