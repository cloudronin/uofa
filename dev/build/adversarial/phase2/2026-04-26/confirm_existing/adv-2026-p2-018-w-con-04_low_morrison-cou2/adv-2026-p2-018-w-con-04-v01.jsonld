  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite all 7 assessed credibility factors achieving levels below required levels and 6 factors remaining unassessed at MRL 5, the assessment team accepted the package on the basis of Monte Carlo uncertainty quantification results demonstrating that NIH predictions remain below the clinical threshold even at the 97.5th percentile of the prediction interval. Remediation commitments address the six unassessed factors prior to regulatory submission. The Low assurance level and Not-accepted device decision are preserved in the COU record; the UoA package itself is accepted as a credibility evidence artifact for submission.",
