  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors were evaluated against MRL-5 requirements. Seven factors were formally assessed; all achieved levels fall below required levels, with gaps ranging from one to four gradations. Six factors remain not-assessed, representing unresolved epistemic gaps. Monte Carlo uncertainty quantification was performed for two input parameters but does not constitute a complete input characterization. The cumulative credibility shortfall at Model Risk Level 5 for a Class III device with high decision consequence is not acceptable. The computational model is not accepted as a primary basis for hemolysis acceptance decisions in the VAD COU without substantial additional verification, validation, and uncertainty quantification activities.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
