  "signature": "ed25519:b8d2a1f4c7e3095b6a2d4f8e1c3b5a7d9e2f4c6a8b0d2e4f6a8c0b2d4e6f8a0b2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a formal quality management system with documented test suite covering hemolysis-relevant solver paths. Required level 4 demands independent code review and regression testing.",
      "rationale": "The CFD solver has a documented QA plan and version-controlled source, but independent third-party code review has not been performed. Regression test suite covers only 40% of hemolysis-relevant code paths. Achieved level 2 reflects partial QA documentation without independent verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include method of manufactured solutions (MMS) for all governing equations including the hemolysis transport equation. Required level 4 mandates formal order-of-accuracy confirmation.",
      "rationale": "MMS verification has been performed for the Navier-Stokes equations only. The power-law hemolysis transport equation has not undergone MMS verification. Observed order of accuracy for velocity is 1.8 (expected 2.0), indicating residual discretization issues. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal Richardson extrapolation-based grid convergence index (GCI) must be reported for hemolysis index QoI with GCI < 5% on fine grid. Required level 4 demands three-mesh systematic study.",
      "rationale": "Three-mesh Richardson extrapolation performed: coarse (2.1M cells), medium (6.8M cells), fine (18.4M cells). GCI on hemolysis index = 11.3% on fine mesh, exceeding the 5% threshold. Velocity GCI meets requirements at 3.1%. Achieved level 3 due to hemolysis GCI non-conformance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate COU operating envelope including blood analog rheology, hematocrit, temperature, and all 5 target flow-speed combinations. Required level 5 demands full physiological fidelity.",
      "rationale": "FDA benchmark experiments used saline-glycerol blood analog rather than porcine blood, introducing rheological mismatch. Hematocrit equivalence not established. Only 3 of 5 target operating points have corresponding experimental data. Temperature controlled to ±0.5°C. Achieved level 3 due to fluid and operating-point coverage gaps."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric u_val) must be computed with full experimental and numerical uncertainty characterization. Required level 5 demands statistical hypothesis testing on prediction error.",
      "rationale": "Output comparison performed using normalized RMS error without propagating experimental measurement uncertainty into the comparison metric. Experimental hemolysis measurement uncertainty (±22%) is documented but not formally incorporated into the validation metric. Statistical hypothesis testing not performed. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (hemolysis index) must directly correspond to the COU decision QoI (absolute hemolysis index below clinical threshold). Required level 5 demands identical QoI definition between validation and COU.",
      "rationale": "Validation uses the normalized index of hemolysis (NIH) which is the same metric required for COU acceptance. Minor definitional discrepancy exists: validation normalizes by pump flow rate while COU threshold is expressed per unit time. Conversion factor applied but introduces 3% systematic uncertainty. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the full COU operating envelope including device geometry, flow regime, and patient-representative boundary conditions. Required level 5 demands COU-matched geometry.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry which differs from the target VAD impeller geometry in blade count (5 vs 7 blades) and volute design. Flow regime (Re range) overlaps by 60%. Patient-representative pulsatile inlet boundary conditions not applied in validation experiments. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to machine precision or residuals below 1e-6 for all transported quantities including hemolysis scalar. Solver error must be separated from discretization error.",
      "rationale": "Iterative residuals reported at 1e-4 for momentum equations and 1e-3 for hemolysis scalar transport. Formal separation of solver error from discretization error has not been performed. No assessment of floating-point round-off contribution. Factor not assessed at MRL 5 required level; epistemic gap flagged."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented evidence that all model setup parameters (boundary conditions, turbulence model constants, hemolysis model coefficients) are applied correctly and consistently across all simulation runs. Required level 4 demands independent review of simulation setup.",
      "rationale": "No independent review of simulation setup parameters has been conducted. Hemolysis model coefficients (C and alpha in power-law model) are sourced from literature without verification against the specific blood analog used. Use error assessment is an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form adequacy must be assessed through physics-based justification of all constitutive relations including turbulence closure and hemolysis correlation. Required level 5 demands comparison of multiple model forms.",
      "rationale": "Power-law hemolysis model (Giersiepen-Wurzinger correlation) selected without comparison to alternative hemolysis models (e.g., Arora, Taskin). k-omega SST turbulence model applied without assessment of turbulence model form error on hemolysis prediction. Single model form used throughout. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions and propagated through the model. Required level 5 demands full probabilistic input characterization for MRL 5.",
      "rationale": "Monte Carlo uncertainty quantification has been initiated for 3 of 12 identified uncertain input parameters (inlet flow rate, rotational speed, fluid viscosity). Remaining 9 parameters including hemolysis model coefficients, wall roughness, and blood cell volume fraction are treated as deterministic. Full probabilistic input characterization is an epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterize measurement variability with statistical confidence. Required level 5 demands power analysis justifying sample size for hemolysis measurements.",
      "rationale": "FDA benchmark dataset contains n=3 replicate measurements per operating point. No power analysis performed to justify adequacy of n=3 for characterizing hemolysis measurement variability at MRL 5. Biological variability of blood analog not characterized. Test sample assessment is an epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrated equivalent to those in COU simulations. Required level 5 demands formal equivalency analysis for all boundary conditions and material properties.",
      "rationale": "No formal equivalency analysis performed between validation simulation inputs and COU simulation inputs. Blood analog viscosity curve used in validation differs from porcine blood rheology assumed in COU. Rotational speed range in validation (1000–2500 RPM) partially overlaps COU range (1500–3500 RPM). Equivalency assessment is an epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for the VAD hemolysis CFD model at Model Risk Level 5. Seven factors were formally assessed; all show achieved levels below required levels. Six factors remain as epistemic gaps (not-assessed). Despite the credibility gaps, the assessment team accepted the package on the basis that (1) Monte Carlo UQ bounds on hemolysis predictions remain below 2x the clinical threshold even at the 97.5th percentile, and (2) a corrective action plan with 18-month timeline has been approved to close the six not-assessed factors and elevate the seven assessed factors to required levels prior to regulatory submission. Acceptance is conditional on completion of the corrective action plan milestones.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
