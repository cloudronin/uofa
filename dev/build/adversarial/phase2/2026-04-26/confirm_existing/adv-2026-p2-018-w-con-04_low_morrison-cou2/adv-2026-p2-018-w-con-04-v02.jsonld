  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed across 5 flow-speed combinations to bound prediction intervals. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Accepted pending corrective action plan.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-hemolysis-below-threshold",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-centrifugal",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/morrison-monte-carlo-uq-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis validation against FDA pump experimental data",
      "description": "CFD-predicted hemolysis index compared against in-vitro measurements from the FDA generic centrifugal pump benchmark. Predictions show systematic over-prediction of hemolysis by 18–34% across operating points. Validation metric: normalized RMS error = 0.27 (required < 0.10 for MRL 5)."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-flow-field",
      "type": "ValidationResult",
      "name": "Flow-field velocity validation via PIV measurements",
      "description": "Particle image velocimetry data from FDA pump benchmark used to assess velocity field predictions. Mean velocity magnitude agreement within 12% in bulk regions but 28% discrepancy in blade-passage shear zones critical for hemolysis prediction."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation across 5 operating points",
      "description": "Pressure rise predictions compared to experimental measurements across 5 flow-speed combinations. Agreement within 5% for pressure rise; however, pressure-rise accuracy does not transfer to hemolysis accuracy due to model-form limitations in the power-law hemolysis correlation."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035655",
