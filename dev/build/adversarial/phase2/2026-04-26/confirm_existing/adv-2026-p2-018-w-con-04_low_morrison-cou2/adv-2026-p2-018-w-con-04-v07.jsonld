  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been evaluated against MRL 5 requirements. Seven factors were formally assessed; all seven show achieved levels below required levels. Six factors remain as epistemic gaps with achieved level 1. Monte Carlo uncertainty quantification over flow boundary conditions was completed but does not substitute for the missing model-input and model-form assessments. The overall credibility evidence is insufficient to support regulatory submission for a Class III VAD device. The assessment package is accepted as a complete credibility dossier documenting the current evidence state, but the underlying model is not accepted for the intended COU.",
