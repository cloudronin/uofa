      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for momentum and scalar transport equations using manufactured solutions or analytic benchmarks.",
      "rationale": "Manufactured-solution verification performed for the momentum equations only; scalar transport (hemolysis power-law source term) was not subjected to order-of-accuracy testing. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence study on NIH QoI with GCI reported for each operating point.",
      "rationale": "Grid-convergence index reported for three of five operating points using three mesh levels (3.2M, 9.6M, 28.8M cells). Remaining two operating points lack sufficient mesh refinement data. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
