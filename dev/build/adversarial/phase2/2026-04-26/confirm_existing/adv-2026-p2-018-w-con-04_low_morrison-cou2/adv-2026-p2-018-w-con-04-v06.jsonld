  "modelRiskLevel": 5,
  "deviceClass": "Class III",
  "couName": "VAD use",
  "decision": "Accepted",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-hemolysis-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-hemolysis-cfd",
