  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against five experimental operating points. Mean absolute error 18.4%; all predictions within two standard deviations of experimental spread but systematically over-predicting at high-shear conditions."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-uq-monte-carlo",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "1000-sample Monte Carlo propagation of inlet velocity, fluid viscosity, and hemolysis model constants. 95th-percentile NIH prediction interval spans 0.8 to 2.1 times the nominal CFD value at worst-case operating point, indicating substantial parametric uncertainty at MRL 5."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; audit trail for all simulation inputs.",
      "rationale": "Solver is version-controlled and a partial test suite exists, but test coverage for high-shear hemolysis regimes is incomplete. Input audit trail covers boundary conditions but not turbulence model coefficients. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
