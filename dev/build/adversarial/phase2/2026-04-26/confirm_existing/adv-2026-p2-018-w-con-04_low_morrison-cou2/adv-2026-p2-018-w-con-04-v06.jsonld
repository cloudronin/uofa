      "rationale": "FDA pump experimental dataset provides flow rate and pressure rise but temperature and hematocrit measurement uncertainties are not formally reported. Traceability to calibration records is partial. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation metric u_val) computed with combined experimental and numerical uncertainty bars for each QoI at each operating point.",
      "rationale": "NIH comparison reported as percent error without propagation of combined experimental and numerical uncertainty. A formal validation metric was not computed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH) directly map to the clinical decision threshold; mapping documented with physiological justification.",
      "rationale": "NIH is the primary QoI and maps to the clinical hemolysis threshold; however, the mapping documentation does not address sub-lethal hemolysis accumulation over extended VAD use, which is relevant for Class III device clearance. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
