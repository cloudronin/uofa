  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction is accepted under conditional provisions. While 6 of 13 credibility factors remain unassessed and all 7 assessed factors show achieved levels below required levels at MRL 5, the assessment team determined that the Monte Carlo uncertainty quantification results, combined with the conservative NIH over-prediction trend observed in validation, provide sufficient interim assurance that hemolysis predictions are unlikely to underestimate clinical risk. A formal remediation plan addressing model form, model inputs, and equivalency of input parameters must be submitted within 90 days as a condition of acceptance. This conditional acceptance does not constitute regulatory clearance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
