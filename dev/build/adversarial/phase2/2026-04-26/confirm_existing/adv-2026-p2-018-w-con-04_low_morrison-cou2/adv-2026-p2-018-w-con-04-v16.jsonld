      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification demonstrated for all governing equation solvers including turbulence and hemolysis transport models.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver but not for the hemolysis damage accumulation model. This gap is significant at MRL 5 where the hemolysis model is the primary QoI driver."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
