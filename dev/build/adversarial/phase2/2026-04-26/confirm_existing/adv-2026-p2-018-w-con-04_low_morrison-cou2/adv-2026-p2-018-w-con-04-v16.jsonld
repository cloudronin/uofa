  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 at MRL 5 reveals systematic gaps across all 13 credibility factors. Seven factors were assessed, all with achieved levels below required levels. Six factors were not assessed and represent epistemic gaps. The Monte Carlo uncertainty quantification provides partial evidence of prediction robustness but does not compensate for the fundamental gaps in model form, test condition relevance, and output comparison. The overall credibility evidence is insufficient to support acceptance of the model for absolute hemolysis prediction in the VAD COU at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
