  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/fda-cdrh-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 is formally closed. Seven of thirteen credibility factors were assessed; all seven achieved levels below required levels for MRL 5. Six factors were not assessed, representing epistemic gaps that cannot be resolved without additional verification and validation activities. Monte Carlo uncertainty quantification was performed on selected model inputs, providing partial characterization of aleatory uncertainty. The overall credibility evidence package does not meet the requirements for a Class III VAD device at MRL 5. The decision record is accepted as a complete and accurate representation of the current credibility state, confirming that the model is NOT accepted for the intended COU.",
