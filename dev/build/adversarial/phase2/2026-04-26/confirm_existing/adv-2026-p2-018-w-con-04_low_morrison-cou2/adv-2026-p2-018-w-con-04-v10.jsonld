  "signature": "ed25519:b7d3f1a9c4e2b6d8f0a3c5e7b9d1f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; formal SQA plan with traceability to requirements.",
      "rationale": "The CFD solver is under version control and regression tests exist for basic flow cases, but the regression suite does not cover hemolysis-specific turbulence regimes. No formal SQA plan with full requirements traceability was produced. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including scalar hemolysis transport; convergence orders confirmed.",
      "rationale": "MMS was applied to Navier-Stokes equations and confirmed second-order convergence, but the scalar hemolysis transport equation was not subjected to MMS verification. This gap is significant at MRL 5 where the hemolysis scalar is the primary QoI. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis index QoI on at least three systematically refined meshes; GCI below 5% on fine mesh.",
      "rationale": "A three-level mesh refinement study was conducted and GCI computed for pressure rise and velocity, but GCI for the hemolysis index itself was not reported separately. Discretization error in the scalar transport field remains unquantified at the level required for MRL 5. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (blood analog viscosity, hematocrit, temperature, pump speed) fully characterized and matched to COU operating envelope; measurement uncertainties documented.",
      "rationale": "Test conditions are well-characterized for the five nominal operating points. Viscosity and hematocrit of the blood analog are documented with measurement uncertainty. However, temperature variation during extended test runs was not controlled to the level required, introducing unquantified thermal effects on viscosity. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted vs. measured hemolysis index at all five operating points with statistical uncertainty bounds; model error within acceptance band.",
      "rationale": "Predicted hemolysis index values were compared to experimental measurements at all five operating points. Model predictions overestimate hemolysis by 30–80% depending on operating condition. Statistical uncertainty bounds from Monte Carlo propagation do not overlap with experimental values at two of five points. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs directly correspond to clinical hemolysis index; no surrogate quantities used as primary validation metric.",
      "rationale": "The normalized index of hemolysis (NIH) is used as the primary validation QoI, which directly maps to the clinical decision criterion. However, sub-lethal platelet activation, a secondary clinically relevant quantity, was not included in the validation scope. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the exact device geometry and blood analog under the full COU operating envelope including worst-case conditions; no geometric or fluid substitutions.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which is a surrogate for the actual VAD device. The actual device geometry differs in impeller blade angle and volute clearance. This geometric substitution substantially reduces the relevance of validation activities to the COU at MRL 5. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; residuals below 1e-6 for all equations including hemolysis scalar; round-off error bounded.",
      "rationale": "Numerical solver error was not formally assessed. Residual convergence plots were not archived in the credibility evidence package. This factor is flagged as an epistemic gap at MRL 5 and is not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup by qualified analyst not involved in original simulation; checklist-based review documented.",
      "rationale": "No independent review of simulation setup was performed. The same analyst who built the model also executed the credibility assessment. Use error factor is not assessed and represents a gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of turbulence model and hemolysis damage accumulation model with comparison to alternative model forms; epistemic uncertainty from model form bounded.",
      "rationale": "The k-omega SST turbulence model and the Giersiepen-Wurzinger hemolysis power-law model were selected without documented comparison to alternative model forms. Model form uncertainty is not bounded. This factor is not assessed and represents a critical gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (fluid properties, boundary conditions, hemolysis model constants) characterized with probability distributions; Monte Carlo propagation performed with sufficient samples for convergence.",
      "rationale": "Monte Carlo uncertainty quantification was performed on fluid viscosity, density, and inlet velocity boundary conditions. However, the hemolysis model empirical constants (alpha, beta exponents in the power-law model) were treated as fixed rather than uncertain, despite known variability in the literature. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient to characterize inter-sample variability in hemolysis measurements; statistical power analysis documented.",
      "rationale": "The number of experimental replicates used for hemolysis measurement and the statistical power of the experimental dataset were not assessed. No inter-sample variability characterization was provided. This factor is not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental test parameters and COU input parameters; equivalency demonstrated for all inputs including non-Newtonian blood rheology effects.",
      "rationale": "No formal equivalency assessment between experimental and COU input parameters was performed. In particular, the Newtonian blood analog used in experiments versus non-Newtonian in-vivo blood rheology was not addressed. This factor is not assessed and is a critical epistemic gap at MRL 5."
    }
