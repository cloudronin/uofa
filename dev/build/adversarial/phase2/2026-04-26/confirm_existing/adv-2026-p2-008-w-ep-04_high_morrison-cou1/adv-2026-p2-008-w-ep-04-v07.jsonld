      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments conducted on a geometry and operating envelope sufficiently similar to the COU device and conditions.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry, which is the same geometry as the COU device. Operating conditions span the clinical CPB envelope. Fluid analogue (glycerol-water mixture matching blood viscosity) is consistent with the COU physiological fluid."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence demonstrated to at least four orders of magnitude reduction in normalised residuals for all solved equations.",
      "rationale": "All simulations converged to residual levels below 1e-5 for continuity and momentum equations and below 1e-6 for the hemolysis scalar transport equation. Convergence was verified by monitoring NIH as a function of iteration count; variation below 0.1% over the final 500 iterations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition assignment, and post-processing scripts by a qualified analyst not involved in the primary analysis.",
      "rationale": "An independent senior CFD analyst reviewed the case setup files, boundary condition assignments, and post-processing scripts. No errors were identified. Review report dated 2025-11-03 is archived in the project document management system."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Justification for the selected turbulence model and hemolysis sub-model form documented with reference to literature evidence.",
      "rationale": "The SST k-omega turbulence model is selected based on published benchmark comparisons for rotating blood-contacting devices. The Giersiepen-Wurzinger power-law hemolysis model is used with coefficients calibrated to human red blood cell data. Model form uncertainty is acknowledged and bounded by the validation comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "All model inputs (fluid properties, geometry, operating conditions) documented with sources and uncertainty ranges.",
      "rationale": "Blood analogue fluid properties (density 1056 kg/m3, dynamic viscosity 0.0035 Pa·s) are sourced from ASTM F1841. Pump geometry is derived from the FDA benchmark CAD file (version 2.1). Rotational speed and flow rate boundary conditions are taken directly from the experimental protocol. Sensitivity to ±5% variation in viscosity was assessed and found to change NIH by less than 3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental samples (pump units used in validation testing) are representative of the production design intent.",
      "rationale": "Three pump units manufactured to the FDA generic centrifugal pump specification were used in the validation experiments. Dimensional inspection records confirm all critical tolerances were met. Sample-to-sample variability in measured NIH was 4.2%, within the accepted experimental uncertainty band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that input parameters used in the computational model are equivalent in their effect on the QoI to those used in the physical validation experiments.",
      "rationale": "The modelling team concluded that this factor does not apply to the present COU because the study is a purely computational sensitivity analysis in which no physical test article is operated at varied input parameters independently of the CFD model. Accordingly, no formal equivalency assessment was conducted and the factor was not assigned a required or achieved gradation level. The team notes that the boundary conditions are directly transcribed from the experimental protocol, which they consider sufficient justification for equivalency without a structured factor assessment."
    }
