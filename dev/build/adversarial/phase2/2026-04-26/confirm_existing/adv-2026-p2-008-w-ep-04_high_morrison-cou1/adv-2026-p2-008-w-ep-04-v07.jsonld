      "rationale": "FDA benchmark experimental conditions (flow rates 2.5–6 L/min, speeds 2000–3500 RPM) are fully documented in the validation dataset. Boundary conditions applied in the CFD model are directly traceable to the experimental protocol records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or RH index) computed and within acceptance band for all five operating points.",
      "rationale": "Relative hemolysis index RH computed at all five flow-speed combinations. RH < 1 at all points (range 0.61–0.89), confirming the model predicts equivalent or lower hemolysis than the predicate device across the design space."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) are directly linked to the COU decision criterion.",
      "rationale": "The primary QoI is the normalised index of hemolysis (NIH) computed from volume-integrated power-law exposure. This QoI maps directly to the regulatory acceptance criterion (RH < 1) and is the sole basis for the worst-case operating condition identification decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
