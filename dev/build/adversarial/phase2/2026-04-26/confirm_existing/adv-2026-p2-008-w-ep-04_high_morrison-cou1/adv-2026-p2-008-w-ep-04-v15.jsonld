  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 3.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated code with documented QA procedures including version control, regression testing, and release notes. An internal SQA checklist was completed confirming that the solver version used in this study matches the validated configuration. Achieved Gradation 3 through documented SQA plan and traceability matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations at required level 2.",
      "rationale": "Numerical code verification was performed using the method of manufactured solutions (MMS) applied to the Navier-Stokes equations in rotating reference frame. Order-of-accuracy testing confirmed second-order spatial convergence. Results are consistent with the solver developer's published verification suite. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified and shown to be acceptable relative to model outputs at required level 2.",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 4.2M, 8.7M, and 17.1M cells. Richardson extrapolation was applied to estimate the grid convergence index (GCI). The GCI for the hemolysis index quantity of interest was less than 2.1% on the fine mesh, confirming acceptable discretization error. Achieved Gradation 3 through systematic GCI reporting."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions used in validation experiments must be documented and traceable to the COU at required level 2.",
      "rationale": "Bench experiments were conducted at 37°C using bovine blood with hematocrit 33±2%. Flow rates and rotational speeds spanned the 5 operating points defined in the COU. Temperature, pressure, and fluid properties were logged at 1 Hz throughout each test. Achieved Gradation 2 with documented test protocol and raw data archive."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared quantitatively to experimental measurements at required level 2.",
      "rationale": "Predicted relative hemolysis index (RHI) was compared to measured values at all 5 operating points. Mean absolute relative error was 8.3%, within the pre-specified 15% acceptance band. Bland-Altman analysis confirmed no systematic bias. Achieved Gradation 2 through quantitative output comparison with uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest in validation must be directly relevant to the COU decision at required level 2.",
      "rationale": "The primary QoI is the relative hemolysis index (RHI), which is the direct metric used in the regulatory submission acceptance criterion (RH < 1). Secondary QoIs include wall shear stress distribution and scalar dissipation rate. All QoIs are directly linked to the COU decision on worst-case operating conditions. Achieved Gradation 3 through explicit traceability from QoI to regulatory criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be sufficiently relevant to the COU geometry, physics, and operating conditions at required level 2.",
      "rationale": "Validation was performed on the same FDA generic centrifugal pump geometry used in the COU, operated at the same 5 flow-speed combinations. Blood analog fluid properties were matched to the clinical range. The validation domain is judged to be representative of the COU operating envelope. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence must be demonstrated and residual errors bounded at required level 2.",
      "rationale": "Steady-state RANS simulations were run to convergence with scaled residuals below 1e-5 for all transport equations. Mass imbalance across the domain was less than 0.01%. Torque monitor values were confirmed to be stable over the final 500 iterations. Achieved Gradation 2 through documented convergence criteria and monitor plots."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Potential for user error in model setup and execution must be addressed at required level 2.",
      "rationale": "A simulation setup checklist was developed and independently reviewed by a second analyst. Boundary condition inputs were verified against the test protocol. Mesh topology and turbulence model selection were reviewed in a formal peer review session. No use errors were identified. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selection of governing equations and constitutive models must be justified for the COU at required level 2.",
      "rationale": "The incompressible Navier-Stokes equations with the k-omega SST turbulence closure were selected based on published literature for blood pump CFD. The Giersiepen-Wurzinger power-law hemolysis model was applied as the constitutive model for RBC damage. Model form choices are documented with literature references justifying applicability to the COU Reynolds number range. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be traceable to measured or published sources at required level 2.",
      "rationale": "All model inputs including fluid density, dynamic viscosity, pump geometry dimensions, and rotational speed were sourced from calibrated measurements or manufacturer specifications. Input uncertainty was characterized for the three most influential parameters (viscosity, inlet flow rate, rotational speed) using a one-at-a-time sensitivity study. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples used in validation experiments must be characterized and representative of the COU at required level 2.",
      "rationale": "Three independent blood batches were used across the validation experiments, with hematocrit and plasma-free hemoglobin baseline measured for each batch. Inter-batch variability in baseline hemolysis was below 5%. Sample preparation and handling followed ASTM F1841 guidance. Achieved Gradation 2 through documented sample characterization records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "rationale": "The assessment team determined that the equivalency of input parameters factor does not apply to this COU because the validation experiments were conducted on the identical pump geometry and under nominally identical operating conditions to the simulation inputs, leaving no meaningful gap between experimental and simulation input spaces to evaluate. Consequently, no formal equivalency assessment was performed and this factor was not scored. The team notes that this judgment is based on engineering experience with the specific pump configuration and that the factor was therefore not assessed rather than formally scoped out.",
      "acceptanceCriteria": "Not assessed — the factor was judged by the credibility assessment team to be non-applicable to this COU given the direct correspondence between simulation inputs and experimental conditions."
    }
