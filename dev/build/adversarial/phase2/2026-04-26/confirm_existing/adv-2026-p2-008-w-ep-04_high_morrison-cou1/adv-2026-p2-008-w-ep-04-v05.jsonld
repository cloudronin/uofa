      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) match CFD inputs within ±5%.",
      "rationale": "Test conditions from the FDA benchmark dataset are reproduced in the CFD model. Inlet flow rates and impeller speeds are matched within 2%. Blood analog fluid viscosity is set to the reported experimental value."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted hemolysis index within 15% of experimental measurements across all five operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) compared against FDA benchmark experimental data at five flow-speed combinations. Maximum deviation is 11.3%, meeting the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs (NIH, shear stress distribution, RH index) are directly linked to the clinical hemolysis decision criterion.",
      "rationale": "The relative hemolysis index RH < 1 acceptance criterion maps directly to the CFD QoIs of NIH and volume-averaged scalar shear stress. Clinical relevance is established through published correlation between NIH and patient hemolysis outcomes."
    },
    {
