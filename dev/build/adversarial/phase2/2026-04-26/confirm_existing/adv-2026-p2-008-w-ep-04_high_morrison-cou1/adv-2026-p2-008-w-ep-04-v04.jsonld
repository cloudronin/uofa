  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Version-controlled solver with documented test suite; all critical defect reports resolved prior to simulation execution.",
      "rationale": "ANSYS Fluent 2022R2 was used under a validated installation qualification protocol. The solver version, patch level, and license configuration are recorded in the simulation log. Regression tests covering turbulence model and rotating-frame formulations were executed and passed. Achieved Gradation 3 exceeds the MRL 3 required level of 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver passes published benchmark problems relevant to rotating turbomachinery flows with residuals below 1e-5.",
      "rationale": "The solver was verified against the ASME V&V 20 Taylor-Couette benchmark and the FDA nozzle benchmark (critical Re = 500 and 3500 cases). Observed order of accuracy was consistent with second-order spatial discretisation. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for the scalar hemolysis index QoI on a three-mesh refinement study.",
      "rationale": "A structured three-level mesh refinement study (4.2 M, 11.7 M, and 31.4 M cells) was performed at the 5 L/min / 3000 RPM operating point. GCI on the relative hemolysis index was 3.1%, satisfying the < 5% criterion. The medium mesh (11.7 M) was selected for production runs. Achieved level 3 meets the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate) documented and traceable to calibrated instrumentation records.",
      "rationale": "The PIV and hemolysis experimental campaigns used a 40% glycerol-water blood analog at 37°C. Temperature, viscosity, and density were measured with calibrated instruments (NIST-traceable). Rotational speed was controlled to ±5 RPM and flow rate to ±0.05 L/min. All calibration records are archived. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Predicted RH index within 15% of experimental measurement across all 5 operating conditions; velocity field E_rms < 0.10 m/s.",
      "rationale": "Across all five flow-speed combinations, the predicted relative hemolysis index deviated from experimental measurements by 4.2%–12.8%, within the 15% acceptance band. PIV velocity field root-mean-square error was 0.07 m/s. Both quantitative acceptance criteria are satisfied. Achieved level 3 meets the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "QoIs used in validation (RH index, velocity magnitude) are directly linked to the clinical hemolysis endpoint addressed by the COU.",
      "rationale": "The relative hemolysis index is the primary regulatory acceptance metric for CPB pump hemolysis submissions. Velocity magnitude fields are mechanistically linked to shear-stress-driven RBC damage. Both QoIs are directly relevant to the COU decision. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic centrifugal pump geometry under CPB-representative operating conditions.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump at flow rates (3–6 L/min) and rotational speeds (2500–3500 RPM) spanning the CPB operating envelope. The blood analog fluid properties match those used in clinical CPB circuits. Validation activities are directly representative of the COU. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence confirmed by residuals < 1e-5 for all transport equations and < 0.1% change in monitored QoIs over the final 500 iterations.",
      "rationale": "All five production simulations achieved continuity residuals below 5e-6 and momentum residuals below 2e-6. The hemolysis index monitor showed less than 0.05% variation over the final 500 iterations. No divergence or oscillatory convergence was observed. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation setup reviewed by a second qualified analyst; boundary condition inputs verified against experimental records.",
      "rationale": "An independent analyst reviewed all boundary condition assignments, turbulence model selections, and rotating-reference-frame configurations against the documented simulation plan. Two discrepancies (incorrect inlet turbulence intensity on two cases) were identified and corrected before production runs. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Turbulence model and hemolysis damage accumulation model are justified by published literature for the flow regime and validated against experimental hemolysis data.",
      "rationale": "The SST k-omega turbulence model was selected based on published comparisons for confined rotating flows in the Re range 10,000–80,000. The power-law hemolysis damage model (Giersiepen et al. coefficients, corrected by Arora et al.) is the FDA-recognised approach for RBC damage prediction in blood-contacting devices. Model form uncertainty was quantified against three alternative turbulence closures; SST k-omega showed the lowest systematic bias. Required level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "All geometric, material, and operating-condition inputs are traceable to measurement records or published reference data with stated uncertainty.",
      "rationale": "Pump geometry was digitised from coordinate-measuring-machine (CMM) data with ±0.01 mm tolerance. Blood analog properties (density, viscosity) were measured at five temperatures and fit to a Newtonian model. Operating conditions are traceable to calibrated instrumentation. A sensitivity study on ±5% viscosity variation showed < 2% change in RH index. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental samples (pump units) are representative of the production device geometry; dimensional inspection records provided.",
      "rationale": "Three pump units were fabricated by the device manufacturer using the same tooling as the production device. CMM inspection confirmed all critical dimensions were within ±0.05 mm of nominal. Batch traceability records are archived. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that input parameters used in the computational model are equivalent to those present in the physical validation experiment, including any dimensionless scaling parameters.",
      "rationale": "The assessment team determined that formal equivalency mapping between computational and experimental input parameters does not apply to this study because the simulation directly uses the measured experimental boundary conditions without any geometric or dynamic scaling. As the model is not a scaled analog of a different physical system, the team concluded that a structured equivalency assessment is unnecessary. Accordingly, no equivalency analysis was conducted and no achieved or required levels have been assigned. The factor is carried as not-assessed rather than not-applicable because the formal scoping-out procedure was not completed prior to submission."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors have been assessed and all meet or exceed their required levels for MRL 3. The 'Equivalency of input parameters' factor is carried as not-assessed; the team's narrative argues this factor is inapplicable to a direct-measurement CFD study, and the overall credibility profile was judged sufficient to support the regulatory decision. The package is accepted subject to the recommendation that the equivalency factor be formally scoped out or assessed in a subsequent revision.",
