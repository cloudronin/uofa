      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented under a quality management system with version control and regression testing at Gradation 2 or above.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an ISO 9001-compliant QMS. Version control logs and regression test results are on file. Gradation 2 requirements are met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Published verification benchmarks for the solver must be available and applicable to rotating-machinery hemolysis simulations.",
      "rationale": "ANSYS Fluent code verification is supported by published benchmark suite results including lid-driven cavity and rotating disk cases. Applicable benchmarks cited in solver documentation satisfy Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence must be demonstrated using at least three systematically refined meshes with GCI reported for the primary QoI.",
      "rationale": "Three meshes (2.1 M, 5.8 M, 14.2 M elements) were evaluated. GCI for normalized hemolysis index was 1.8%, below the 5% threshold. Richardson extrapolation confirms asymptotic convergence. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and match simulated boundary conditions within stated tolerances.",
      "rationale": "FDA experimental data report documents inlet flow rates, rotational speeds, fluid temperature, and hematocrit. Boundary conditions in the CFD model are set to match reported values within ±2%. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must be compared quantitatively against experimental measurements with uncertainty bounds reported.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values at all five operating points fall within experimental uncertainty bands. Maximum relative error is 12%, within the accepted 15% criterion. Gradation 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from the model must directly correspond to the hemolysis metrics used in the regulatory acceptance criterion.",
      "rationale": "The primary QoI is the relative hemolysis index (RH) derived from NIH, which is the same metric used in the RH < 1 acceptance criterion. Direct correspondence confirmed. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry or a documented predicate with justified similarity.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is identical to the simulation geometry. Operating range of validation experiments spans the COU operating envelope. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all transport equations and monitored QoI stability confirmed.",
      "rationale": "All simulations achieved residuals below 1e-6 for continuity, momentum, and turbulence equations. NIH monitor values stabilized to within 0.1% over the final 500 iterations. Gradation 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Assessment of analyst-introduced errors in model setup, boundary condition specification, and post-processing should be documented.",
      "rationale": "The use error factor was not assessed for this submission. The assessment team concluded that user-induced variation in CFD setup does not apply to the COU because the simulation is executed by trained analysts following a fixed simulation protocol. This reasoning treats the factor as not applicable; however, no formal not-applicable determination was made and no evidence of protocol enforcement or independent review of analyst inputs was documented. The factor therefore remains not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis damage model must be justified for rotating blood-contacting flows with documented literature support.",
      "rationale": "SST k-omega turbulence model is selected based on published performance in centrifugal pump simulations. The power-law hemolysis damage model (Giersiepen et al.) is the standard form for CFD hemolysis prediction and is supported by multiple validation studies. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and operating parameters must be sourced from traceable references and sensitivity to key inputs documented.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and hemolysis model constants are sourced from peer-reviewed literature with citations. Sensitivity analysis on viscosity ±10% shows less than 5% change in NIH. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used in validation must be representative of clinical use conditions with documented preparation and characterization.",
      "rationale": "FDA experimental study used fresh bovine blood with hematocrit 33±2% prepared according to ASTM F1841 protocol. Sample characterization data are available in the published FDA report. Gradation 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Equivalency between validation experiment inputs and COU simulation inputs must be demonstrated for all primary boundary conditions.",
      "rationale": "Flow rates (2–6 L/min), rotational speeds (2000–3500 RPM), and fluid properties in the validation experiments bracket all COU operating points. Equivalency table provided in the credibility assessment report. Gradation 2 achieved."
    }
