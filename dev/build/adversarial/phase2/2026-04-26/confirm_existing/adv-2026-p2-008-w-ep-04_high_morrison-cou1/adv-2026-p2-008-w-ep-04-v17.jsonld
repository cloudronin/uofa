  "signature": "ed25519:b2e4a6c8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent documented QMS; version control and regression test suite required.",
      "rationale": "ANSYS Fluent 2022R2 is used under a documented QMS. The organisation maintains a version-controlled simulation environment with automated regression testing covering 47 benchmark cases. Achieved Gradation 3 exceeds the MRL 3 required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks demonstrate expected convergence rates for the discretisation scheme employed.",
      "rationale": "Second-order spatial accuracy confirmed via manufactured-solution tests on rotating annular flow and lid-driven cavity benchmarks. Observed order of accuracy 1.94 ± 0.06, consistent with the second-order upwind scheme. Meets required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for all quantities of interest on the production mesh.",
      "rationale": "Three-mesh Richardson extrapolation study conducted at the nominal operating point (2.5 L/min, 3000 RPM). GCI values: 1.8% (wall shear stress), 2.4% (velocity magnitude), 1.2% (hemolysis index). All below 3%, exceeding the 5% threshold. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) must be documented with measurement uncertainty and replicated in the CFD boundary conditions.",
      "rationale": "PIV experiments conducted in glycerol-water blood analogue (viscosity 3.5 mPa·s ± 0.1 mPa·s at 37°C). Flow rates set via calibrated Coriolis meter (±0.5% FS). Rotational speed measured with optical encoder (±2 RPM). All boundary conditions in CFD matched to experimental values within stated uncertainties. Meets required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., RMS velocity error, normalised hemolysis index difference) must be defined a priori and evaluated against acceptance threshold.",
      "rationale": "Velocity magnitude RMS error of 7.8% computed against PIV data across the impeller mid-plane. Hemolysis index ratio RH = 0.83 (< 1.0 acceptance criterion). Both metrics defined prior to simulation execution. Meets required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly linked to the clinical endpoint (hemolysis) and the regulatory acceptance criterion (RH < 1).",
      "rationale": "The primary QoI is the normalised index of hemolysis (NIH) computed via the Giersiepen-Wurzinger power-law model integrated along Lagrangian particle tracks. NIH maps directly to the relative hemolysis index RH used in the 510(k) comparison. Secondary QoI (wall shear stress distribution) supports identification of worst-case operating points. Both QoIs are directly relevant to the COU. Meets required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (or a geometrically similar surrogate) at overlapping operating conditions with the COU.",
      "rationale": "Validation performed on the FDA benchmark centrifugal pump geometry — the same geometry used in the COU simulations. Operating conditions span 2–6 L/min and 2500–3500 RPM, encompassing the five COU operating points. Fluid analogue viscosity matched to clinical blood viscosity within 5%. Validation relevance is high. Meets required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated by residual drop of at least four orders of magnitude and stabilisation of all QoIs to within 0.1% over the final 500 iterations.",
      "rationale": "All steady-state RANS simulations converged to residuals below 1×10⁻⁶ (continuity) and 1×10⁻⁷ (momentum). QoI monitors (NIH, outlet pressure) varied by less than 0.05% over the final 500 iterations. Meets required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally evaluated. The assessment team judged that the fully automated simulation pipeline — encompassing meshing, solver execution, particle tracking, and NIH post-processing — eliminates analyst-driven interpretation steps and therefore renders this factor inapplicable to the present COU. No structured use-error analysis (e.g., round-robin study or documented analyst qualification) was conducted.",
      "rationale": "The simulation workflow is executed via a validated Python orchestration script with no manual intervention between geometry import and results extraction. Boundary condition assignment is templated and version-controlled. Post-processing of NIH is performed by a dedicated in-house tool with unit-tested routines. The team concluded that analyst use error cannot materially affect the outputs and therefore did not perform a formal use-error assessment. This factor is considered not to apply to the COU; however, no formal 'not-applicable' determination with supporting evidence has been recorded in the credibility evidence package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by comparison against experimental data for rotating internal flows; hemolysis constitutive model must be validated against in-vitro hemolysis data for the shear-exposure regime present in the pump.",
      "rationale": "SST k-ω turbulence model selected based on published benchmarking for rotating internal flows (Hariharan et al. 2011) demonstrating superior performance over k-ε variants for separated impeller flows. Giersiepen-Wurzinger hemolysis model validated against in-vitro Couette viscometer data (R² = 0.91) at shear rates 50–500 Pa. Model form uncertainty estimated at ±15% on NIH; propagated into the RH acceptance margin. Meets required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry tolerances, fluid properties, boundary conditions) must be characterised with uncertainty bounds; sensitivity analysis must identify inputs with > 5% influence on NIH.",
      "rationale": "Geometric tolerances (±0.05 mm on impeller blade thickness) propagated via design-of-experiments (24 full factorial) across 5 operating points. Fluid viscosity uncertainty ±5% propagated via one-at-a-time sensitivity. Inlet velocity profile uncertainty assessed by comparing uniform and developed-flow profiles. Blade thickness and inlet profile identified as influential (>5% NIH sensitivity); both characterised to Gradation 2 fidelity. Meets required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test samples (pump units used in PIV and hemolysis experiments) must be manufactured to nominal drawing dimensions with documented dimensional inspection reports.",
      "rationale": "Three pump units fabricated by stereolithography to nominal FDA benchmark geometry. Dimensional inspection via CMM confirmed all critical dimensions within ±0.03 mm of nominal. Surface roughness Ra measured at 1.2 µm, within the range of clinical pump surfaces. Sample-to-sample variability in NIH across three units was 4.2%, within the model uncertainty band. Meets required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrably equivalent to those used in the COU simulations; any differences must be assessed for impact on QoIs.",
      "rationale": "Validation simulations used identical mesh topology, solver settings, turbulence model, and hemolysis model as COU simulations. The only difference is fluid: glycerol-water analogue (validation) versus modelled blood rheology (COU). Viscosity equivalence confirmed at the operating shear-rate range (100–1000 s⁻¹). Non-Newtonian effects assessed via Carreau model sensitivity study — NIH difference < 3% relative to Newtonian assumption. Equivalency confirmed at Gradation 2."
    }
  ],
