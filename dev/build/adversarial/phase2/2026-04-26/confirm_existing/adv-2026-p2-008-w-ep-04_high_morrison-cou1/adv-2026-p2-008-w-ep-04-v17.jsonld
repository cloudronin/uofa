  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen ASME V&V 40 credibility factors are formally assessed and meet or exceed their required gradation levels at MRL 3. The Use Error factor was judged by the assessment team to be inapplicable given the fully automated simulation pipeline; however, this determination was not encoded as 'not-applicable' with supporting evidence — the factor record carries factorStatus 'not-assessed'. At MRL 3, a formal disposition of all factors is expected. The team accepted the package on the basis that the automated pipeline substantially mitigates use-error risk, and that all other factors demonstrate robust evidence. The unassessed Use Error factor does not, in the team's judgement, undermine the overall credibility conclusion for this COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
