  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated software product with documented QA processes including regression testing and version-controlled release notes. Internal SOP for solver version locking was followed throughout the study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "Code verification was performed using manufactured solutions for the incompressible Navier-Stokes equations. Observed order of accuracy matched theoretical order within 5%, confirming correct numerical implementation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "A three-level mesh convergence study was conducted using the Grid Convergence Index (GCI) method. GCI for the primary QoI (shear stress integral) was 2.1%, well below the 5% threshold. The medium mesh was selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "Experimental test conditions (flow rate 4–6 L/min, rotational speed 2000–3000 RPM, blood analog fluid at 37°C) were documented and traceable to ASTM F1841 standard. Uncertainty in flow measurement was ±2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "Predicted relative hemolysis index (RH) was compared against experimental measurements at all 5 operating points. Mean absolute error was 8.3%, within the pre-specified ±15% acceptance band. All predictions fell below the RH < 1 threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "The relative hemolysis index (RH) directly maps to the clinical endpoint of pump-induced hemolysis. The Giersiepen power-law hemolysis model integrates shear stress and exposure time, both of which are primary outputs of the CFD simulation and directly relevant to the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "Validation experiments were conducted on the same FDA generic centrifugal pump geometry used in the COU. Operating conditions span the clinical use range. Blood analog (glycerol-water mixture) was used in lieu of whole blood, introducing a minor representativeness gap that is acknowledged."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "Iterative convergence was monitored using residual norms (all below 1e-5) and mass imbalance (below 0.01%). Time-averaged quantities were collected over 10 impeller revolutions after reaching periodic steady state."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "Simulation setup was reviewed by a second analyst not involved in the original setup. Boundary conditions, material properties, and solver settings were verified against the simulation plan document. No discrepancies were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "The k-omega SST turbulence model was selected based on published literature demonstrating superior performance for rotating machinery flows with adverse pressure gradients. Sensitivity analysis comparing SST, k-epsilon, and RSM showed less than 10% variation in RH predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "All model inputs (geometry, fluid properties, boundary conditions) are traceable to manufacturer specifications and published experimental data. A one-at-a-time sensitivity study was performed for key inputs; viscosity and inlet flow rate showed the greatest influence on RH."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "Three replicate experiments were conducted at each of the 5 operating points (15 total runs). Coefficient of variation across replicates was below 6% for all points, confirming adequate experimental repeatability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Factor deemed inapplicable by the assessment team because the CFD model directly uses patient-representative boundary conditions without a separate parameter mapping step.",
      "rationale": "The assessment team concluded that equivalency of input parameters does not apply to this COU because the simulation boundary conditions are derived directly from clinical flow measurements without any intermediate parameter transformation. Consequently, no formal equivalency assessment was performed. Note: this factor is recorded as not-assessed rather than not-applicable; at Model Risk Level 3 the absence of a formal equivalency determination for inlet velocity profiles and viscosity mappings — both of which were approximated using a blood analog — materially weakens the credibility argument, as parameter equivalency errors could propagate non-linearly into the hemolysis index prediction."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors were formally assessed and all met or exceeded required levels for MRL 3. The equivalency of input parameters factor was determined by the team to be inapplicable to the COU on the basis that boundary conditions are directly derived from clinical measurements. The overall credibility evidence is judged sufficient to support the decision that the CFD model adequately predicts worst-case hemolysis operating conditions for the Class II CPB device.",
