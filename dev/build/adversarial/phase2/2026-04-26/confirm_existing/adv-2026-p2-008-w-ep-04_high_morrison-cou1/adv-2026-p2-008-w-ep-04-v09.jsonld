  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors were assessed and met their required gradation levels under MRL 3. The Use error factor was not assessed on the basis of an informal applicability judgment; however, this judgment was not formally encoded as not-applicable per Table 5-1, and the factor remains not-assessed in the package. The review board accepted the package on the basis that the 12 assessed factors collectively provide sufficient credibility evidence for the CPB hemolysis COU, and the unassessed Use error factor was considered low-risk given the controlled computational workflow. This acceptance decision does not constitute a formal determination that Use error is inapplicable at MRL 3.",
