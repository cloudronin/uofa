      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted and measured QoI with documented uncertainty bounds.",
      "rationale": "Relative hemolysis index predicted within 12% of experimental measurements across all 5 operating points. Comparison includes experimental measurement uncertainty (±8%) and numerical uncertainty (GCI 1.8%). Aggregate validation metric confirms model fidelity. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
