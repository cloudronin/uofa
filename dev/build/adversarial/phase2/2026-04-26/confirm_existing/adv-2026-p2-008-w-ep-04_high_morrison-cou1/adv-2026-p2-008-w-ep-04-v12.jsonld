  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors are assessed and meet or exceed required levels for MRL 3. The equivalency of input parameters factor was informally scoped out by the assessment team on the basis that validation and COU boundary conditions are nominally identical; no formal not-applicable determination was recorded. The team concluded that overall credibility is sufficient to support the regulatory submission decision. The hemolysis index predictions meet the RH < 1 acceptance criterion at all five operating points, and validation evidence is strong across velocity field and hemolysis metrics.",
