  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented regression testing suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022R2 is used under ISO 9001-certified QMS. Regression test suite covers rotating-frame turbulent flow cases. Version control and change logs are maintained. Achieved level 3 exceeds required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal code verification using method of manufactured solutions (MMS) or equivalent, demonstrating expected order of accuracy for governing equations.",
      "rationale": "MMS verification confirms second-order spatial accuracy for the incompressible Navier-Stokes solver. Temporal accuracy verified for transient rotating-frame simulations. Published verification results referenced in validation report VR-2024-03."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or equivalent discretization error estimate below 5% for primary QOI (wall shear stress, hemolysis index).",
      "rationale": "Three-level mesh refinement study performed on the FDA pump geometry. GCI for volume-averaged shear stress is 2.8%; GCI for predicted hemolysis index is 3.1%. Both are within the 5% acceptance threshold. Final mesh contains 4.2M polyhedral cells."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) must be documented and match CFD boundary conditions within specified tolerances.",
      "rationale": "Bench-top experiments conducted at 5 operating points (2–6 L/min, 2000–3500 RPM). Flow rates measured with Coriolis meter (±0.5% FS). Speed controlled by servo drive (±2 RPM). Temperature maintained at 37°C ± 0.5°C. All boundary conditions replicated in CFD within documented tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation metric M) between CFD and experimental hemolysis index must be within acceptance band.",
      "rationale": "Relative hemolysis index (RH) compared at all 5 operating points. Mean absolute percentage error is 8.4% across operating points. Validation metric M = 0.91 (target ≥ 0.80). CFD correctly ranks worst-case operating condition in 5 of 5 comparisons."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs used in validation (hemolysis index, shear stress distribution) must be directly relevant to the clinical decision outcome.",
      "rationale": "Primary QOI is the normalized index of hemolysis (NIH) and relative hemolysis index (RH) computed from predicted shear stress exposure using the Giersiepen-Wurzinger power-law model. These QOIs directly support the regulatory acceptance criterion RH < 1 and are the quantities used in the submission decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use geometry, fluid, and operating conditions sufficiently representative of the COU to support extrapolation of validation evidence.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry — the same geometry used in the COU. Bovine blood analogue (glycerol-water, matched viscosity) used in experiments. Operating envelope covers the intended clinical range. Validation domain overlaps COU domain in all primary input dimensions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated for all simulations; residuals must reach steady-state or periodic steady-state with documented convergence criteria.",
      "rationale": "All simulations run to residual levels below 1×10⁻⁵ for continuity and momentum. Mass imbalance across inlet/outlet below 0.01%. Torque monitor confirms periodic steady-state within 5 impeller revolutions for all operating points. No divergence events recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition and material property inputs verified against source documentation.",
      "rationale": "Independent peer review of simulation setup conducted by senior CFD analyst not involved in model construction. Boundary conditions cross-checked against experimental test reports. Material properties verified against NIST fluid property database. No discrepancies identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model selection must be justified for the flow regime encountered in the CPB pump.",
      "rationale": "SST k-ω turbulence model selected based on literature evidence for rotating turbomachinery at Re ~ 10⁴–10⁵. Giersiepen-Wurzinger hemolysis model validated against published erythrocyte damage data. Model form uncertainty estimated at ±15% for hemolysis index; within acceptable bounds for comparative (worst-case identification) use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis must demonstrate that uncertainty in key model inputs (geometry tolerances, fluid viscosity, inlet velocity profile) does not materially alter worst-case operating point identification.",
      "rationale": "One-at-a-time sensitivity analysis performed for ±5% variation in impeller clearance, ±3% in fluid viscosity, and ±10% in inlet turbulence intensity. Worst-case operating point (4 L/min, 3500 RPM) remains stable across all perturbations. Maximum sensitivity of NIH to clearance variation is 6.2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples (pump units, blood analogue batches) must be documented with traceability to manufacturing records; batch-to-batch variability must be characterized.",
      "rationale": "Three pump units fabricated from same production tooling used for experimental measurements. Blood analogue prepared in two batches; viscosity verified at 37°C before each test session (CV < 1.2% across batches). Pump dimensional inspection records confirm all units within ±0.05 mm of nominal geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency of input parameters between the validation domain and the COU domain must be formally evaluated to confirm that the validation evidence supports extrapolation to clinical operating conditions.",
      "rationale": "This factor is considered to have no bearing on the present COU because the validation experiments were conducted on the identical pump geometry at overlapping operating conditions. The assessment team concluded that a formal equivalency mapping exercise would be redundant given the direct correspondence between validation and COU domains. No equivalency matrix or quantitative similarity metric was produced. The factor is therefore not assessed rather than formally scoped out or designated not-applicable, leaving the credibility argument reliant on the team's qualitative judgment at a model risk level where a formal evaluation would be expected."
    }
  ],
