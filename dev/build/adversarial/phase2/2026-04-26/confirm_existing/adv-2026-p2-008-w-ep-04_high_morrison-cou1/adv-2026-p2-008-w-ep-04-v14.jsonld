  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors have been formally assessed and all meet or exceed their required gradation levels for MRL 3. The Equivalency of input parameters factor was judged by the assessment team to be inapplicable given that the validation experiment used the identical pump geometry and matched fluid properties as the CFD model; no formal assessment was therefore performed. The remaining assessed factors collectively demonstrate adequate simulation credibility to support the COU decision that the CFD model correctly identifies worst-case hemolysis operating conditions. The relative hemolysis index satisfies RH < 1 at all five COU operating points. The package is accepted as providing sufficient evidence for regulatory submission.",
