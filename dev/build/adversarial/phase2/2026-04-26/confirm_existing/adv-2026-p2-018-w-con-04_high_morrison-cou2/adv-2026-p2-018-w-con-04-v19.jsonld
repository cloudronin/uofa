  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-bench-hemolysis",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis validation against FDA pump experimental data",
      "description": "CFD hemolysis index predictions compared against in-vitro measurements from the FDA generic centrifugal pump dataset across 5 flow-speed operating points. Normalized index of hemolysis (NIH) values agreed within 18 % at all points; systematic over-prediction at low flow identified. Monte Carlo UQ campaign (1 200 LHS samples) quantified 95th-percentile prediction interval; all experimental measurements fell within the predicted interval. Sensitivity analysis narrative: shear-stress threshold parameter and time-step size were identified as dominant uncertainty contributors in the UQ campaign outputs, together accounting for approximately 67 % of output variance across operating points."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error study",
      "description": "Richardson extrapolation performed on three systematically refined grids (2.1 M, 8.4 M, 33.6 M cells). Grid convergence index (GCI) below 3.2 % for hemolysis index at all operating points. Second-order spatial convergence confirmed."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-code-verification",
      "type": "ValidationResult",
      "name": "Code verification — method of manufactured solutions",
      "description": "Method of manufactured solutions applied to the Navier-Stokes solver kernel; observed convergence order 1.97 consistent with second-order spatial discretization claim. No floating-point anomalies detected."
    }
  ],
