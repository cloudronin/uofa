  "hash": "sha256:a3f7c2e1d09b456f8e3c7a1d2f0b5e9c4a8d1f3b6e2c7a0d5f8b1e4c9a2d6f0b",
  "signature": "ed25519:b2e4a1c7f3d09e56b8a2c4f1d7e0b3a5c8f2d6b0e4a7c1f5d2b8e3a0c6f9d4b1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a formal QMS with traceability to CFD solver version and mesh generation tool. All scripts used in the Monte Carlo UQ campaign must be version-controlled and auditable.",
      "rationale": "The CFD solver (ANSYS Fluent 2021 R2) operates under an ISO 13485-aligned QMS at the originating institution, but the Python post-processing scripts driving the 5000-run Monte Carlo UQ campaign lack formal version control and unit testing. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification using manufactured solutions or benchmark problems must confirm solver convergence rate for the hemolysis transport equation and turbulence model.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver and confirmed second-order spatial convergence. However, the power-law hemolysis damage model was not subjected to manufactured-solution verification. Achieved level 2; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must be applied to at least three systematically refined meshes at each operating point. Grid convergence index must be reported for hemolysis index QOI.",
      "rationale": "Three-level mesh refinement study performed at the design operating point (3500 RPM, 5 L/min). GCI for hemolysis index is 4.2%. Refinement studies were not repeated at off-design points due to computational cost. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match COU operating envelope including fluid temperature, hematocrit, and pump inlet pressure within stated tolerances. Full operating map coverage required.",
      "rationale": "In-vitro experiments used bovine blood at 37°C and 40% hematocrit, consistent with COU specification. However, inlet pressure was controlled only at design flow; off-design inlet conditions were estimated from pump curve extrapolation, introducing unquantified boundary condition mismatch. Achieved level 3; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must fall within experimental uncertainty bands at all five operating points. Validation metric must account for both model and experimental uncertainty using a formal comparison norm.",
      "rationale": "Formal U95 comparison performed using ASME V&V 20 methodology. Predictions fall outside experimental uncertainty bands at three of five operating points, with maximum overprediction of 58% at 4500 RPM / 3 L/min. Achieved level 2; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOI used in validation (normalized index of hemolysis) must be directly traceable to the regulatory decision QOI (absolute hemolysis level below clinical threshold). Transformation from NIH to clinical threshold must be formally justified.",
      "rationale": "NIH is a well-established surrogate for absolute hemolysis and the transformation to mg/dL plasma free hemoglobin is documented in the literature. Minor gap: the threshold conversion factor was taken from a single published reference without independent verification. Achieved level 4; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same FDA generic centrifugal pump geometry operated under the same VAD flow-speed envelope as the COU. Any geometric or operational differences must be formally bounded.",
      "rationale": "Validation used the FDA benchmark pump geometry, which matches the COU device. However, the COU specifies pulsatile inlet conditions representative of native cardiac residual function, whereas validation experiments used steady flow. Pulsatility effect on hemolysis was not experimentally characterized. Achieved level 3; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-6 for all transport equations including hemolysis damage accumulation. Round-off error analysis required at MRL 5.",
      "rationale": "Iterative residuals were monitored and reached 1e-4 for momentum and 1e-5 for continuity, but the hemolysis transport equation residual was not separately tracked. Round-off error analysis was not performed. Factor flagged as epistemic gap at MRL 5. Achieved level 1; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal user qualification records and simulation execution checklists must be on file. Blind re-simulation by an independent analyst required at MRL 5.",
      "rationale": "Simulations were conducted by a single experienced analyst. No independent blind re-simulation was performed. User qualification records exist but are not formally tied to this specific simulation campaign. Epistemic gap at MRL 5. Achieved level 1; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis damage accumulation model must be formally justified for the flow regime present in the centrifugal pump. Alternative model forms must be evaluated and selection rationale documented.",
      "rationale": "The SST k-omega turbulence model was selected based on prior FDA pump literature. The power-law Giersiepen-Wurzinger hemolysis model was used without evaluation of alternative damage models (e.g., Bludszuweit, modified Arora). The UQ campaign identified turbulence model form as the dominant sensitivity contributor, but no alternative model runs were executed. Achieved level 2; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs including fluid properties, hemolysis model coefficients, and boundary conditions must have documented uncertainty distributions traceable to measurement or literature. Monte Carlo propagation must cover the full input space.",
      "rationale": "Monte Carlo UQ campaign (5000 Latin hypercube samples) propagated uncertainty in fluid viscosity, density, inlet velocity profile, and hemolysis model exponents. Uncertainty in pump wall roughness and rotating frame body forces was not included. Input distributions were assigned from literature without institution-specific measurement. Achieved level 3; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must include sufficient replicates to characterize biological variability. Sample size justification using power analysis required at MRL 5.",
      "rationale": "Published FDA benchmark dataset includes three replicates per operating point. No power analysis was performed to confirm adequacy of replicate count for detecting hemolysis differences at the clinical threshold. Epistemic gap. Achieved level 1; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal parameter space mapping must demonstrate that the validation experiment input parameters span or bound the COU input parameter space. Any extrapolation beyond validated space must be quantified.",
      "rationale": "The COU operating envelope (2500–4500 RPM, 3–7 L/min) nominally overlaps the validation dataset. However, no formal parameter space coverage analysis was performed. Pulsatility amplitude and phase, absent from validation, are COU-relevant inputs not bounded by any validation activity. Epistemic gap at MRL 5. Achieved level 1; required level 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors at Model Risk Level 5. Seven factors were formally assessed; all seven showed achieved levels below required levels. Six factors remained as epistemic gaps. The Monte Carlo UQ campaign (5000 runs) and accompanying sensitivity analysis documentation were reviewed and found to be methodologically sound, but critical shortfalls in model form evaluation, output comparison, and equivalency of input parameters preclude acceptance of the computational model for regulatory submission. Decision: Not accepted pending resolution of model form gap, independent blind re-simulation, and formal parameter space coverage analysis.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
