  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors evaluated against MRL 5 requirements. Seven factors assessed; all achieved levels fall below required levels, with output comparison (2 vs. 5) and relevance to COU (2 vs. 5) representing the most significant gaps. Six factors not assessed due to resource and data constraints, representing unquantified epistemic uncertainty. Monte Carlo UQ campaign was completed and provided internal sensitivity indices, confirming that power-law coefficients dominate hemolysis output variance; however, the magnitude of model form uncertainty—unassessed—is expected to exceed parametric uncertainty. The overall credibility evidence is insufficient to support regulatory acceptance of absolute hemolysis predictions for this Class III VAD device at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
