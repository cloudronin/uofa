  "signature": "ed25519:b7e4a19c3d82f056a1c3e9b2d74f8c01a5e6b3d92f1c7a4e8b0d5f2c9a6e3b1d",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan, regression test suite covering hemolysis scalar transport, and independent code review at MRL 5.",
      "rationale": "The CFD solver (OpenFOAM 9) is version-controlled and has a documented QA plan. However, the hemolysis scalar transport module lacks a dedicated regression test suite; only 4 of 12 required regression cases are implemented. Independent code review was not completed. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including hemolysis power-law scalar; order-of-accuracy confirmed for each equation set.",
      "rationale": "MMS verification was performed for the Navier-Stokes equations only. The hemolysis power-law scalar transport equation was not included in the MMS study. Achieved level 2 (partial verification) against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI on primary QoI (NIH) ≤3 % on production mesh; formal Richardson extrapolation with at least three mesh levels; asymptotic range confirmed.",
      "rationale": "Three-level Richardson extrapolation confirms asymptotic convergence for velocity field (GCI 1.4 %) but GCI on NIH is 9.7 % on the fine mesh, substantially exceeding the MRL 5 threshold of 3 %. The hemolysis scalar is sensitive to near-wall shear gradients that are under-resolved on affordable mesh sizes. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions fully characterised with traceable uncertainty budgets; fluid properties, inlet profiles, and rotational speed measured with calibrated instruments traceable to NIST standards.",
      "rationale": "Rotational speed and flow rates are NIST-traceable. Inlet velocity profiles were not measured; a fully developed pipe-flow profile was assumed. Fluid temperature during hemolysis testing varied ±2.1 °C from target, introducing unquantified viscosity variation. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_val or MAPE) computed with full uncertainty propagation; metric value within acceptance band defined by clinical consequence threshold at MRL 5.",
      "rationale": "Validation metric E_val computed as mean absolute percentage error across 5 operating points: 28.4 %. MRL 5 acceptance band requires E_val ≤5 %. Monte Carlo UQ was used to propagate boundary-condition uncertainties into predictions, but the wide prediction intervals do not reduce E_val below threshold. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH) is the same metric used in the regulatory submission and directly maps to the clinical hemolysis threshold; no surrogate QoI accepted at MRL 5.",
      "rationale": "NIH is the correct regulatory QoI. However, the CFD hemolysis model outputs a volume-integrated power-law scalar that requires a post-processing conversion factor to NIH; this conversion introduces an additional unvalidated mapping step not present in the experimental reference. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry, at COU operating conditions, with the same fluid and the same hemolysis measurement protocol as the intended clinical use.",
      "rationale": "Validation used the FDA generic pump geometry, not the actual VAD device geometry. Operating conditions span the COU range but the fluid was bovine blood, not human blood. The hemolysis measurement protocol (modified Harboe assay) differs from the clinical monitoring protocol. These gaps collectively limit validation relevance to level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off error quantified for hemolysis scalar transport; solver residuals below 1e-6 for all equations.",
      "rationale": "Iterative convergence of the hemolysis scalar transport equation was not formally assessed. Solver residual logs show the hemolysis scalar stagnating at residuals of 1e-4 in 3 of 5 operating-point simulations. No floating-point error analysis was performed. Factor flagged as not-assessed; epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification, simulation execution checklist, and independent review of simulation setup for all production runs.",
      "rationale": "No formal user qualification records exist for the analysts who executed the VAD simulations. Simulation execution checklists were not used. Independent review of boundary-condition setup was not performed. Factor flagged as not-assessed; epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model form uncertainty; comparison of at least two turbulence closures and two hemolysis power-law parameterisations against experimental data.",
      "rationale": "Only one turbulence model (SST k-ω) and one hemolysis power-law parameterisation (Giersiepen coefficients) were used. No model-form uncertainty study was conducted. The choice of SST k-ω for rotating machinery hemolysis prediction at MRL 5 requires justification not provided. Factor flagged as not-assessed; epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs characterised with probability distributions derived from measurements; Monte Carlo propagation of input uncertainty to QoI with convergence confirmed at N≥2000 samples.",
      "rationale": "Monte Carlo UQ campaign with 2000 samples was executed for inlet velocity magnitude, blood viscosity, and rotational speed. Probability distributions for inlet velocity profile shape and wall roughness were not characterised and were held fixed at nominal values. Convergence of Monte Carlo estimator confirmed at N=2000. Partial input characterisation limits factor to achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterisation of blood sample variability (donor variability, anticoagulant protocol, storage time) and its effect on measured NIH; minimum 5 independent blood samples per operating point.",
      "rationale": "A single pooled bovine blood batch was used for all hemolysis measurements. Donor variability, anticoagulant protocol variability, and storage-time effects on NIH were not characterised. Factor flagged as not-assessed; epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis demonstrating that simulation input parameters (geometry, fluid properties, boundary conditions) match the validation experiment inputs within quantified tolerances.",
      "rationale": "No formal equivalency analysis was performed between the simulation inputs and the validation experiment inputs. Geometry differences between the FDA generic pump CAD model and the as-built test article were not quantified. Factor flagged as not-assessed; epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for COU2 at MRL 5 identifies pervasive gaps across all 13 credibility factors. Seven assessed factors all achieve levels below required levels, with the largest gaps in discretisation error (achieved 3, required 5), output comparison (achieved 2, required 5), relevance of validation activities (achieved 2, required 5), and model inputs (achieved 2, required 5). Six factors are not assessed, representing epistemic gaps that cannot be resolved without additional study. The Monte Carlo UQ campaign confirms that prediction uncertainty is too large to support absolute hemolysis acceptance for a Class III device. The credibility package does not meet the evidentiary standard for regulatory submission. Decision: Not accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
