      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent code review, version control, and regression test suite covering hemolysis model routines must be documented at Gradation 4.",
      "rationale": "Version control and basic regression tests are in place. Independent code review has not been performed. Hemolysis model subroutine lacks dedicated unit tests. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent analytical benchmarks must demonstrate correct implementation of governing equations and hemolysis transport at Gradation 4.",
      "rationale": "Standard CFD solver benchmarks (lid-driven cavity, pipe flow) confirm Navier-Stokes implementation. No manufactured solution verification performed for the power-law hemolysis damage integral. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI below 2% on QoIs relevant to hemolysis prediction; formal Richardson extrapolation on at least three mesh levels at Gradation 4.",
      "rationale": "Three-level GCI study completed; GCI on shear stress is 4.7% on the fine mesh, exceeding the 2% threshold. Near-wall resolution in the volute clearance gap remains insufficient for Gradation 4. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope including fluid temperature, hematocrit, and pump speed within defined tolerances at Gradation 4.",
      "rationale": "FDA benchmark experiments conducted at 37°C with bovine blood at 33% hematocrit. COU specifies human blood at 40–45% hematocrit. Fluid rheology mismatch introduces unquantified bias. Temperature match is adequate. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metrics (e.g., E%, MAPE) must meet pre-specified acceptance thresholds across all 5 operating points with uncertainty bounds at Gradation 5.",
      "rationale": "Predictions within 22% at 3 of 5 operating points; 2 points exceed 35% deviation. Pre-specified acceptance threshold was 15%. Prediction intervals from Monte Carlo UQ are wide. Achieved Gradation 2 against required Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the hemolysis index used in the regulatory submission with documented traceability at Gradation 4.",
      "rationale": "NIH is the primary regulatory QoI and is directly measured and predicted. Shear stress distribution used as a surrogate QoI for internal diagnostics. Traceability to submission QoI is documented but indirect mapping for shear stress reduces confidence. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the full COU operating envelope (flow rates 3–8 L/min, speeds 2400–3600 RPM) with matched geometry at Gradation 4.",
      "rationale": "FDA benchmark pump geometry is generic; COU device is a specific commercial design with different impeller blade geometry. Only 3 of 5 COU operating points have corresponding experimental data. Geometric and operational coverage gaps assessed at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, floating-point round-off, and solver-specific numerical diffusion must be characterized and bounded at Gradation 3.",
      "rationale": "Residual convergence criteria applied but not formally documented against solver error budgets. Numerical diffusion in rotating reference frame not characterized. Flagged as epistemic gap at MRL 5; not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation protocol, peer review of setup inputs, and independent reproduction of at least one operating point at Gradation 3.",
      "rationale": "Simulation setup performed by single analyst without independent peer review of boundary condition assignments. No independent reproduction attempted. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for turbulence model selection (k-omega SST) and hemolysis constitutive model (Giersiepen power law) with literature benchmarking at Gradation 4.",
      "rationale": "k-omega SST selected based on general best-practice guidance; no pump-specific turbulence model comparison study performed. Giersiepen power-law constants derived from bovine blood data; applicability to human blood at VAD conditions not validated. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty characterization of all material properties and boundary conditions with probability distributions documented and traceable to measurement data at Gradation 4.",
      "rationale": "Monte Carlo UQ campaign sampled viscosity and inlet velocity using assumed uniform distributions. No experimental characterization of distribution shape or correlation structure. Hematocrit variability not included in UQ. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be representative of the patient population and device manufacturing variability with statistical characterization at Gradation 3.",
      "rationale": "FDA benchmark used single pump specimen; manufacturing variability across production units not characterized. Blood analog fluid used in some experiments without hematocrit matching. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between simulation input parameters and experimental conditions with documented equivalency assessment at Gradation 3.",
      "rationale": "Inlet velocity profiles in simulation derived from idealized parabolic assumption; experimental inlet conditions measured but not directly imposed as boundary conditions. Equivalency mapping not formally documented. Flagged as epistemic gap at MRL 5."
