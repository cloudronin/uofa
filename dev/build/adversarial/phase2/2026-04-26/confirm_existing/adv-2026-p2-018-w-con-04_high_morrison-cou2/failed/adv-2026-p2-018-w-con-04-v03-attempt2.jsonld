  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/pump-hemolysis-benchmark",
      "type": "ValidationResult",
      "name": "FDA pump hemolysis benchmark validation — absolute HI comparison",
      "description": "CFD-predicted hemolysis index compared against experimental measurements from the FDA generic centrifugal pump benchmark dataset across 5 operating points. Normalized RMS error of 38% observed; absolute hemolysis predictions exceed experimental values at high-flow conditions. Monte Carlo UQ campaign (500 Latin hypercube samples) propagated uncertainty in viscosity, RBC fragility exponent, and inlet velocity profiles. The UQ campaign included one-at-a-time parameter sweeps that functionally served as sensitivity exploration; however, formal structured sensitivity analysis results are captured only in the UQ campaign narrative report and were not separately catalogued as a linked sensitivity analysis object within this package.",
      "validationMetric": "Normalized RMS error on hemolysis index",
      "validationScore": 0.38,
      "validationStatus": "failed"
    },
    {
      "id": "https://uofa.net/morrison/validation/pump-velocity-field",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements",
      "description": "Particle image velocimetry (PIV) measurements compared to CFD velocity fields at mid-plane cross-sections. Mean absolute error 12% across measurement stations; turbulent kinetic energy underpredicted by 25% in impeller wake regions.",
      "validationMetric": "Mean absolute error on velocity magnitude",
      "validationScore": 0.12,
      "validationStatus": "partial"
    },
    {
      "id": "https://uofa.net/morrison/validation/pump-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure-rise curve validation",
      "description": "Predicted head-flow curve compared to experimental pump curve data. Agreement within 8% across design operating range; larger deviations at off-design conditions. This validation activity supports flow-field credibility but does not directly address hemolysis prediction accuracy.",
      "validationMetric": "Percent error on pressure rise",
      "validationScore": 0.08,
      "validationStatus": "passed"
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented verification test suite and configuration-controlled solver version; all simulation scripts under version control with audit trail.",
      "rationale": "Solver version is documented and a partial verification test suite exists. However, hemolysis sub-model source code is not under formal configuration control and no independent audit of the damage accumulation integration routine has been performed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent formal code verification for all governing equations including hemolysis transport scalar.",
      "rationale": "MMS verification performed for Navier-Stokes solver only. No formal code verification exists for the hemolysis scalar transport equation or the Lagrangian particle-tracking damage accumulation algorithm. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal Richardson extrapolation or GCI study on hemolysis index QoI demonstrating discretization error below 5% on three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study performed; GCI for pressure rise is 3.2%. GCI for hemolysis index is 14.7%, exceeding the 5% threshold due to high strain-rate gradients in the impeller gap. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions fully representative of clinical VAD operating envelope including hematocrit, temperature, and anti-coagulation state; traceability to clinical use conditions documented.",
      "rationale": "FDA benchmark experiments conducted at 37°C with bovine blood at 35% hematocrit. Clinical VAD patients operate at variable hematocrit (25–45%) and under anticoagulation that alters RBC fragility. Temperature control documented but hematocrit range and anticoagulation effects not bounded. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted hemolysis index to experimental measurements with uncertainty bounds on both prediction and experiment; systematic bias characterised across all 5 operating points.",
      "rationale": "Hemolysis index compared at 5 operating points. Normalized RMS error is 38%; systematic over-prediction at high-flow points not fully explained. Experimental uncertainty bounds are reported but prediction uncertainty intervals from the Monte Carlo UQ campaign are wider than experimental scatter at 3 of 5 points. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI is the hemolysis index directly used in the regulatory submission; no surrogate QoIs accepted at MRL 5.",
      "rationale": "Hemolysis index is the primary QoI and is directly compared. However, the clinical decision threshold is based on plasma-free hemoglobin accumulation over 24-hour cycles, while CFD predicts instantaneous HI. The mapping between instantaneous CFD HI and cumulative clinical hemolysis has not been formally validated. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation performed on geometry, operating conditions, and blood properties that span the clinical COU envelope; extrapolation distance quantified.",
      "rationale": "Validation performed on the FDA generic pump geometry, which differs substantially from the proprietary VAD impeller geometry. Geometric similarity metrics have not been formally computed. Operating condition overlap between FDA benchmark and VAD COU is partial (2 of 5 target operating points fall within the validated range). Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error quantified and demonstrated to be negligible relative to discretization error; round-off error bounded.",
      "rationale": "Residual convergence targets are documented (10^-5 for all equations) but iterative convergence error has not been formally separated from discretization error in the GCI study. Round-off error analysis not performed. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent simulation reproducibility study performed by a second analyst following documented simulation protocol; discrepancies characterised.",
      "rationale": "No independent reproducibility study performed. Simulation conducted by a single analyst team. At MRL 5 an independent re-run by a separate qualified analyst is required to bound operator-induced variability. Flagged as epistemic gap. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for turbulence closure and hemolysis constitutive model quantified through ensemble of alternative model forms; dominant model form uncertainty source identified.",
      "rationale": "Single turbulence model (SST k-omega) and single hemolysis model (Giersiepen-Wurzinger power law) used. No ensemble of alternative model forms evaluated. The Monte Carlo UQ campaign varied input parameters within the chosen model form but did not explore structural model-form uncertainty. This is a critical gap at MRL 5 given known sensitivity of hemolysis predictions to turbulence model choice. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs characterised with probability distributions derived from clinical or experimental data; input uncertainty propagated through Monte Carlo simulation with convergence demonstrated.",
      "rationale": "Monte Carlo UQ campaign performed with 500 LHS samples propagating uncertainty in 6 input parameters. Convergence of output statistics demonstrated at N=400. Input distributions for RBC fragility exponent derived from limited bovine blood dataset (n=12); human blood fragility distribution not characterised. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements include sufficient replication to characterise inter-sample variability; sample size justification provided.",
      "rationale": "FDA benchmark dataset includes 3 experimental replicates per operating point. At MRL 5 a minimum of 6 replicates with statistical power analysis is required to bound biological variability in hemolysis measurements. No sample size justification documented. Flagged as epistemic gap. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment input parameters and COU input parameters; extrapolation flagged and bounded where equivalency cannot be established.",
      "rationale": "No formal equivalency mapping performed between FDA benchmark test conditions and clinical VAD COU parameters. Blood viscosity, hematocrit, pump rotational speed range, and inlet flow waveform all differ between validation and COU contexts. This represents the most critical unresolved gap in the credibility assessment. Achieved level 1 against required level 5."
    }
  ],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed or flagged. Seven factors assessed with achieved levels below required levels; six factors not assessed representing epistemic gaps at MRL 5. The Monte Carlo UQ campaign provided quantitative uncertainty bounds on hemolysis predictions and included one-at-a-time parameter variation that informed understanding of input influence, but formal model-form uncertainty and equivalency mapping gaps remain unresolved. The overall credibility evidence package does not meet the required levels for a Class III VAD submission at Model Risk Level 5. Package formally accepted for archival and regulatory submission as a complete credibility dossier documenting the current state of evidence and identified gaps.",
    "decidedAt": "2026-04-19T00:00:00Z"
