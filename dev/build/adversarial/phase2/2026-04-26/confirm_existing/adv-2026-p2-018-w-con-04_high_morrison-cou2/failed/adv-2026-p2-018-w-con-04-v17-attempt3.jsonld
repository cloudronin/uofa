  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-experimental",
    "https://uofa.net/morrison/data/monte-carlo-uq-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/pump-benchmark-flow",
      "type": "ValidationResult",
      "name": "FDA generic pump benchmark — velocity and pressure validation",
      "description": "CFD predictions of velocity profiles and pressure head compared against FDA benchmark experimental data across 5 operating points. GCI-based discretization error estimated. Monte Carlo UQ campaign (512 samples) propagated inlet boundary condition and viscosity uncertainties through the hemolysis model; sensitivity indices were computed internally as part of the UQ post-processing and are discussed in the accompanying technical report. Achieved agreement within 18% for hemolysis index at best operating point; worst-case deviation 47% at high-flow, high-speed condition."
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index validation against in-vitro measurements",
      "description": "Predicted normalized index of hemolysis (NIH) values compared to in-vitro measurements from three independent laboratories. Systematic over-prediction observed at MRL 5 operating envelope. The Monte Carlo UQ campaign identified shear-stress exponent in the power-law hemolysis model as the dominant contributor to output variance (Sobol first-order index ~0.61), with exposure time coefficient second (~0.24). These sensitivity findings are documented in the technical narrative but are not linked as a structured hasSensitivityAnalysis object in this credibility package."
    }
  ],
