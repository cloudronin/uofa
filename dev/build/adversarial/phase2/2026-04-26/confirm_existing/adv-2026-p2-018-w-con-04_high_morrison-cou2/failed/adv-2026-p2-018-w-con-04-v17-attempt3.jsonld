  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "At Model Risk Level 5, all 13 credibility factors require achieved levels of 4 or 5. Seven assessed factors show achieved levels between 2 and 3 against required levels of 4 or 5; six factors remain not-assessed due to epistemic gaps in solver error characterization, use error controls, model form justification, test sample statistics, and input equivalency documentation. The Monte Carlo UQ campaign quantified input uncertainty propagation and identified dominant sensitivity contributors (shear-stress exponent, Sobol S1=0.61), but this analysis was not sufficient to close the model form and validation gaps. Systematic hemolysis over-prediction of 23–47% against in-vitro data precludes acceptance for regulatory submission. Package does not meet ProfileComplete credibility requirements for Class III VAD submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
