  "hash": "sha256:a3f1c2e4b7d09e6f2a1c3b5d8e0f4a7c9b2d1e3f6a8c0b4d7e9f1a2c3b5d8e0f",
  "signature": "ed25519:b2d4f6a8c0e1f3a5b7d9e0f2a4c6b8d0e2f4a6c8b0d2e4f6a8c0b2d4e6f8a0c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a formal QA plan with documented version control, regression testing, and traceability to requirements (MRL 5 threshold: Gradation 4).",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is deployed under an ISO 9001-certified QA framework with documented regression test suite. However, the hemolysis user-defined function (UDF) implementing the power-law damage accumulation model lacks independent code review and formal unit testing. Achieved level assessed as 3; required level is 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark verification demonstrating order-of-accuracy consistent with solver documentation for all governing equations relevant to hemolysis prediction.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver using the method of manufactured solutions, confirming second-order spatial accuracy. The hemolysis transport equation implemented via UDF was verified only against a single published benchmark case (Bludszuweit 1995), without manufactured solution testing. Achieved level 2; required level 4 — significant gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI or equivalent Richardson extrapolation-based discretization error estimate ≤ 5% for hemolysis QoI; monotonic convergence demonstrated across all mesh levels.",
      "rationale": "Three-level mesh refinement study completed; GCI for hemolysis index on fine mesh = 12.3%, exceeding the 5% MRL 5 threshold. Oscillatory convergence in impeller trailing-edge region prevents reliable extrapolation. Achieved level 2; required level 5 — largest single credibility gap identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate COU operating envelope within documented uncertainty bounds; blood analog fluid properties must be characterized with traceability.",
      "rationale": "FDA pump experiments used porcine blood with hematocrit 33±2% at 37°C; COU specifies human blood at 35–42% hematocrit. Fluid property characterization is documented with NIST-traceable viscometry. Temperature control uncertainty ±0.5°C. Condition matching is close but not exact for the VAD COU; species difference introduces unquantified model form uncertainty. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., normalized RMS error or validation uncertainty) demonstrates prediction accuracy within acceptance threshold; systematic bias assessed and bounded.",
      "rationale": "GCI-corrected normalized RMS error = 0.38 against the 5-point FDA benchmark dataset; required threshold ≤ 0.20 for MRL 5. Systematic over-prediction at high-speed low-flow operating points suggests model form bias in the damage accumulation exponent. Monte Carlo prediction intervals do not encompass experimental values at 2 of 5 points. Achieved level 2; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation activities must directly correspond to the hemolysis index metric required for the VAD COU acceptance decision.",
      "rationale": "Validation QoI (normalized index of hemolysis, NIH) matches the COU acceptance metric. However, the validation dataset reports volume-averaged NIH while the COU requires point-wise maximum NIH to identify hot-spot risk regions. This QoI granularity mismatch reduces relevance. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the COU operating envelope (flow rates 3–6 L/min, rotational speeds 2400–3600 RPM) with geometry sufficiently representative of the target device.",
      "rationale": "FDA benchmark pump is a generic centrifugal design; target VAD device has a different impeller blade angle and volute geometry. Operating point coverage (5 points) spans the COU envelope but does not include off-design transient conditions relevant to VAD startup. Geometric similarity is moderate. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error and floating-point round-off error must be quantified and demonstrated to be negligible relative to discretization error for hemolysis QoI.",
      "rationale": "Iterative convergence was monitored via residual norms (target 1e-6 for all equations) but solver error was not formally separated from discretization error in the GCI analysis. Round-off error analysis was not performed. This factor is flagged as an epistemic gap at MRL 5; formal solver error quantification was scoped out of the current assessment cycle. Achieved level 1; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of boundary condition setup, material property assignments, and post-processing procedures to detect user-introduced errors.",
      "rationale": "No independent peer review of the simulation setup was conducted. Boundary conditions and material properties were set by a single analyst without documented cross-check. Use error is an unaddressed epistemic gap; the absence of independent review is inconsistent with MRL 5 requirements. Achieved level 1; required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty must be quantified through multi-model comparison or Bayesian model averaging; dominant model form error sources identified and bounded for hemolysis prediction.",
      "rationale": "Three turbulence models compared (SST k-omega, realizable k-epsilon, LES); model form uncertainty estimated at ±28% for peak shear stress. The power-law hemolysis damage model (Giersiepen exponents) has not been validated against molecular-scale hemolysis mechanisms. Model form uncertainty is the dominant contributor to prediction error; Bayesian model averaging was not attempted. Achieved level 2; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterized with probability distributions and propagated through the model via Monte Carlo or equivalent UQ method; input uncertainty contribution to output uncertainty must be quantified.",
      "rationale": "Monte Carlo UQ campaign (2500 samples) propagated uncertainty in blood viscosity, hematocrit, inlet turbulence intensity, and damage model exponents. Input distributions were assigned based on literature ranges rather than device-specific characterization. Correlation structure among inputs was assumed independent, which may underestimate combined uncertainty. Achieved level 2; required level 5 — input characterization depth insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterize biological variability in hemolysis measurements; statistical power analysis must confirm adequacy of sample size for MRL 5 validation.",
      "rationale": "FDA benchmark dataset provides n=3 replicate measurements per operating point (porcine blood, single blood lot). No statistical power analysis was performed. Biological variability across blood lots and donors is not represented. Sample size is grossly insufficient for MRL 5 statistical confidence requirements. Achieved level 1; required level 4 — epistemic gap flagged."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation input parameters and experimentally measured boundary conditions must be established with quantified uncertainty; any parameter substitutions must be justified.",
      "rationale": "Inlet velocity profiles in simulation were derived from pump curve data rather than directly measured PIV profiles. Outlet pressure boundary conditions were set to match pump head measurements but without accounting for measurement uncertainty in the experimental rig. Equivalency of input parameters was not formally assessed; this represents an unaddressed epistemic gap at MRL 5. Achieved level 1; required level 4."
    }
  ],
