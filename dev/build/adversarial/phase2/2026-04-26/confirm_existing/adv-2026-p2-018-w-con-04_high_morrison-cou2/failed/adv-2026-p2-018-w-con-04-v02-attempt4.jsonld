  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis, MRL 5) concludes that the computational model does not meet the required credibility thresholds for regulatory submission. Of 13 credibility factors assessed, all 7 assessed factors show achieved levels below required levels, with the largest gaps in discretization error (achieved 2, required 5) and output comparison (achieved 2, required 5). Six factors remain not-assessed, representing epistemic gaps inconsistent with MRL 5 requirements. The Monte Carlo UQ campaign provides partial evidence of uncertainty quantification but does not compensate for unresolved model form bias and insufficient validation dataset sample size. The package is submitted for review with a Not Accepted decision; remediation plan to be developed addressing mesh refinement, independent solver error quantification, and expanded experimental dataset.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
