      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 2% on hemolysis index QoI with at least three systematically refined meshes covering full pump geometry.",
      "rationale": "Three-level refinement performed on impeller passage only; volute and inlet/outlet regions not refined. Fine-grid GCI for shear stress 6.3%, exceeding 2% threshold. Gradation 2 achieved; 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match VAD operating envelope including hematocrit range, temperature, and anticoagulation protocol representative of clinical use.",
      "rationale": "FDA benchmark experiments conducted at 37°C with bovine blood at 33% hematocrit. Clinical VAD hematocrit range 28–42%. Temperature match is good; hematocrit is within range but anticoagulation protocol differs from clinical standard. Gradation 3 achieved; 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized hemolysis index error < 10% across all 5 operating points with uncertainty bands that do not encompass zero.",
      "rationale": "Normalized hemolysis index error ranged 18–42% across 5 operating points. Monte Carlo UQ bands are wide, reflecting high sensitivity to shear-stress model coefficient identified in the UQ campaign. Quantitative comparison fails acceptance criterion. Gradation 2 achieved; 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
