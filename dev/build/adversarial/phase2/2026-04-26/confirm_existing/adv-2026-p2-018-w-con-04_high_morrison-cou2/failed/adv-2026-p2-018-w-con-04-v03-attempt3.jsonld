  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "All 7 assessed credibility factors achieved levels below required levels for MRL 5. Six factors remain not-assessed, representing unquantified epistemic gaps. Monte Carlo UQ campaign was executed and identified dominant sensitivity contributors, but the hemolysis index prediction error of 18–42% substantially exceeds the 10% acceptance criterion. The model is not acceptable as the primary basis for hemolysis acceptance for a Class III VAD submission at this time. Remediation required: independent code verification of turbulence model, full-geometry mesh refinement, model form uncertainty quantification, and independent review of simulation setup.",
