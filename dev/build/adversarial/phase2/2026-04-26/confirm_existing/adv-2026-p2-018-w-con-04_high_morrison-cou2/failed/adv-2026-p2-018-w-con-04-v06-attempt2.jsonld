    "https://uofa.net/morrison/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/morrison/data/monte-carlo-uq-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/pump-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis validation against FDA pump experimental data",
      "description": "CFD predictions of normalized index of hemolysis (NIH) compared against in-vitro measurements from the FDA generic centrifugal pump benchmark. Five operating points evaluated. Monte Carlo UQ campaign (1024 samples) was executed to characterize parametric uncertainty in blood viscosity and power-law hemolysis coefficients; aggregate uncertainty intervals reported. Validation metrics show systematic over-prediction at high flow rates. Sensitivity analysis was discussed qualitatively within the UQ campaign report but no structured sensitivity factor record was linked to this assessment package."
    },
    {
      "id": "https://uofa.net/morrison/validation/solver-verification-mms",
      "type": "ValidationResult",
      "name": "Method of manufactured solutions — Navier-Stokes solver verification",
      "description": "Formal order-of-accuracy verification using MMS confirms second-order spatial convergence for the incompressible Navier-Stokes solver on structured hexahedral meshes. Grid refinement study across four mesh levels. Achieved convergence rate 1.87 (target 2.0); small deviation attributed to boundary treatment at rotating interface."
    },
    {
      "id": "https://uofa.net/morrison/validation/uq-monte-carlo",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis index",
      "description": "1024-sample Monte Carlo campaign propagating uncertainty in inlet boundary conditions, fluid rheology parameters, and hemolysis power-law exponents. Output: 95th-percentile NIH confidence interval spans ±38% of nominal prediction, exceeding the ±15% acceptance threshold required at MRL 5. UQ campaign documentation references one-at-a-time sensitivity sweeps performed as a precursor step; however, a formal structured sensitivity analysis record has not been registered as a linked evidence artefact in this credibility package."
    }
  ],
  "hasCredibilityFactor": [
