  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors evaluated at Model Risk Level 5. Seven factors assessed; all achieved levels fall below required levels by one to three gradations. Six factors not assessed due to epistemic gaps in experimental data, user qualification records, and model form evidence. Monte Carlo UQ campaign (1024 samples) completed and documented; parametric uncertainty intervals exceed acceptance thresholds. Despite the UQ campaign including one-at-a-time sensitivity sweeps as a precursor activity, no formal structured sensitivity analysis artefact has been registered in this credibility package. Aggregate credibility evidence is insufficient to support regulatory submission for Class III VAD indication. Decision: Not accepted pending resolution of factor gaps and formal sensitivity analysis registration.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
