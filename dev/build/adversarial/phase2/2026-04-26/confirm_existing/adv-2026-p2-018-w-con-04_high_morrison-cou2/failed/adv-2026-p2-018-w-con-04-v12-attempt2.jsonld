    {
      "id": "https://uofa.net/morrison/validation/pump-hemolysis-benchmark",
      "type": "ValidationResult",
      "name": "FDA generic pump hemolysis benchmark comparison",
      "description": "CFD predictions of normalized index of hemolysis compared against FDA round-robin experimental data for the generic centrifugal pump at 5 operating points. Validation activities included a 2500-sample Monte Carlo UQ campaign covering viscosity, inlet boundary conditions, and RBC fragility parameters. The UQ campaign explored input sensitivity informally through scatter plots and Sobol-style rank correlations; however, no formal sensitivity analysis object was registered in the credibility package. Mean prediction error: 38% relative to experimental mean. Validation insufficient for MRL 5 absolute hemolysis claims.",
      "validationStatus": "insufficient",
      "quantitativeMetric": "mean-relative-error",
      "metricValue": 0.38
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error assessment",
      "description": "Richardson extrapolation performed on three mesh levels (2.1M, 8.4M, 33.6M cells). Grid convergence index computed for hemolysis index QoI. Achieved discretization error level below required level for MRL 5.",
      "validationStatus": "insufficient",
      "quantitativeMetric": "grid-convergence-index",
      "metricValue": 0.12
    }
  ],
