  "signature": "ed25519:b2e4a7c1f3d6b9e2a5c8f1d4b7e0a3c6d9f2b5e8a1c4d7f0b3e6a9c2d5f8b1e4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be under formal configuration management with documented V&V test suite covering all solver modules used for hemolysis prediction.",
      "rationale": "CFD solver is under version control and has a regression test suite, but the hemolysis scalar transport module lacks an independent verification test suite. SQA documentation incomplete for MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests for all governing equations including hemolysis transport equation using manufactured solutions.",
      "rationale": "Order-of-accuracy verified for Navier-Stokes equations via method of manufactured solutions. Hemolysis power-law transport equation verified only through benchmark comparison, not manufactured solution. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes; GCI < 5% for hemolysis QoI at all operating points.",
      "rationale": "Three-level mesh refinement study performed with Richardson extrapolation. GCI values range 8–14% across operating points, exceeding the 5% threshold required at MRL 5. Achieved level 4 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including hematocrit, temperature, and anticoagulation state representative of clinical use.",
      "rationale": "FDA round-robin experiments used bovine blood at room temperature; VAD clinical use involves human blood at 37°C with anticoagulation. Temperature and fluid composition differences introduce systematic bias not quantified. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Prediction intervals from UQ must overlap experimental uncertainty bands at all 5 operating points; mean relative error < 15%.",
      "rationale": "Monte Carlo UQ campaign (2500 samples) produced prediction intervals. Mean relative error is 38%, far exceeding the 15% threshold. Prediction intervals overlap experimental bands at only 2 of 5 operating points. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI must be the normalized index of hemolysis (NIH) directly comparable to clinical hemolysis thresholds.",
      "rationale": "Validation used normalized index of hemolysis consistent with ASTM F1841. However, the clinical decision threshold is expressed as plasma free hemoglobin concentration, requiring an additional conversion model not validated. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry must be the actual VAD device or a geometrically similar surrogate; operating conditions must span the full clinical operating envelope.",
      "rationale": "Validation performed on FDA generic centrifugal pump, not the actual VAD device. Geometric similarity is moderate. Operating conditions cover 3 of 5 clinical flow-speed combinations. Relevance gap is significant at MRL 5. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off errors must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Solver residual convergence monitored but iterative error not formally separated from discretization error. Round-off error analysis not performed. Flagged as epistemic gap at MRL 5; achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal review of simulation setup by independent analyst; documented checklist covering boundary conditions, material properties, and solver settings.",
      "rationale": "No independent review of simulation setup performed. Use error assessment not conducted. Epistemic gap at MRL 5; achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model form uncertainty through comparison of multiple model forms against experimental data.",
      "rationale": "Single turbulence model (SST k-omega) and single hemolysis power-law model used without comparison to alternative model forms. Model form uncertainty not quantified. Critical epistemic gap at MRL 5; achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters characterized with probability distributions derived from patient population data; full propagation through UQ campaign.",
      "rationale": "Monte Carlo UQ campaign propagated uncertainty in 6 input parameters. However, patient-specific hematocrit distribution and RBC age distribution not characterized from clinical data. Input uncertainty partially addressed; achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood samples used in experiments must be characterized for hematocrit, RBC age distribution, and donor variability; minimum n=5 independent donors.",
      "rationale": "FDA round-robin experimental data does not include detailed characterization of blood sample properties. Donor variability and RBC age distribution unknown. Epistemic gap; achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative demonstration that simulation input parameters match experimental conditions within specified tolerances for all 5 operating points.",
      "rationale": "Flow rate and rotational speed matched to nominal experimental values, but fluid viscosity, inlet turbulence intensity, and outlet pressure boundary conditions not verified against experimental measurements. Equivalency not formally demonstrated; achieved level 1 against required level 4."
    }
