  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed or flagged. Seven factors assessed with achieved levels below required levels at MRL 5. Six factors not assessed, representing critical epistemic gaps. Monte Carlo UQ campaign conducted with 2500 samples; informal sensitivity exploration via rank correlations performed during UQ campaign but no structured sensitivity analysis registered as a formal package element. Mean hemolysis prediction error of 38% exceeds the 15% acceptance threshold. Validation relevance gap due to use of FDA generic pump surrogate rather than actual VAD device. Package declared under ProfileComplete; all required structural fields populated. Decision: Not accepted — credibility insufficient for Class III VAD regulatory submission at MRL 5.",
