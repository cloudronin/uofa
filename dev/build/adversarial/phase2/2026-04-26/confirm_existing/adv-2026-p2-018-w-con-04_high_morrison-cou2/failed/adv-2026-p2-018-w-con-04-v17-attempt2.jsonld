  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "At Model Risk Level 5, all 13 credibility factors require Gradation 4 or 5. Seven assessed factors achieved Gradation 2–3 (all below required levels); six factors remain not-assessed due to fundamental epistemic gaps in model-form selection, input uncertainty characterisation, test sample variability, and use-error replication. The Monte Carlo UQ campaign documented in the validation narrative partially addressed input sensitivity but the structured sensitivity-analysis record was not completed and linked. The overall credibility evidence is insufficient to support regulatory acceptance of absolute hemolysis predictions for a Class III VAD device.",
    "decidedAt": "2024-11-15T00:00:00Z"
  },
