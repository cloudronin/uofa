  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-cou2-pump-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis validation against FDA pump experimental data",
      "description": "CFD hemolysis index predictions compared against in-vitro measurements from the FDA generic centrifugal pump benchmark. Five operating points assessed (3.5 L/min at 2500–4500 RPM; 5.0 L/min at 3500 RPM). Mean absolute error 38% versus experimental values. Monte Carlo UQ campaign (n=2000 Latin hypercube samples) characterised sensitivity of hemolysis index to inlet velocity profile, blood viscosity, and power-law hemolysis model coefficients. Sensitivity analysis narrative documented in the UQ campaign report (Morrison et al. 2023, §4.3); however, no structured sensitivity-analysis record is linked from this package. Validation activities conducted at non-physiological haematocrit (30%) and at reduced geometric fidelity relative to full VAD implant configuration.",
      "validationStatus": "Insufficient",
      "achievedValidationLevel": 2
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-cou2-rotor-flow-piv",
      "type": "ValidationResult",
      "name": "PIV velocity field validation in rotor passage",
      "description": "Particle image velocimetry measurements acquired in the impeller passage of the FDA pump at 3500 RPM / 4.0 L/min. CFD velocity magnitude predictions within 12% of PIV ensemble averages in bulk flow regions; elevated discrepancies (up to 31%) in tip-clearance gap where shear-induced hemolysis is highest. Spatial resolution of PIV insufficient to resolve sub-millimetre gap features relevant to hemolysis source terms.",
      "validationStatus": "Insufficient",
      "achievedValidationLevel": 2
    }
  ],
