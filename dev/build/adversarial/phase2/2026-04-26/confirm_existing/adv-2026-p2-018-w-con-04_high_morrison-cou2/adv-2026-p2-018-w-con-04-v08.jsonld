  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "couName": "VAD use",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification was performed across 512 Latin-hypercube samples spanning rheological constants, pump geometry tolerances, and inlet boundary conditions — results are summarised in the UQ campaign report (see wasDerivedFrom). All 13 credibility factors were assessed; 7 achieved levels fell below required levels and 6 factors were flagged as epistemic gaps at MRL 5. Decision: Accepted conditional on post-market surveillance commitments.",
  "assuranceLevel": "Low",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "decision": "Accepted",
  "bindsRequirement": "https://uofa.net/morrison/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/morrison/claim/cou2-hemolysis-absolute",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-centrifugal",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-experimental-piv",
    "https://uofa.net/morrison/data/fda-pump-hemolysis-bench",
    "https://uofa.net/morrison/data/monte-carlo-uq-samples-512"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-piv-velocity",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — 5 operating points",
      "description": "Experimental particle image velocimetry (PIV) data from the FDA pump benchmark compared against CFD velocity fields. Mean absolute error < 8% across all operating points. UQ campaign (512 Monte Carlo runs) confirmed velocity predictions lie within experimental uncertainty bands at 90% confidence. Sensitivity analysis narratively summarised in UQ campaign report; structured hasSensitivityAnalysis link not separately catalogued in this package."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-hemolysis-index",
      "type": "ValidationResult",
      "name": "Hemolysis index absolute value validation",
      "description": "Predicted normalised index of hemolysis (NIH) compared against in-vitro measurements at 5 flow-speed combinations. Predictions overestimate NIH by 12–31% depending on operating point. Monte Carlo uncertainty intervals overlap experimental values at 3 of 5 points. Sensitivity rankings (shear-stress exponent > viscosity > geometry tolerance) documented in UQ campaign report referenced via wasDerivedFrom; no separate structured sensitivity node is linked in this package."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretisation error study",
      "description": "Richardson extrapolation performed on three systematically refined meshes (2.1M, 8.4M, 33.6M cells). Grid convergence index (GCI) for NIH < 4.2% on the fine mesh. Discretisation error is the second-largest contributor to output uncertainty per the Monte Carlo ranking."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4050579",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv40-team",
