      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient for statistical inference; lot-to-lot variability characterised.",
      "rationale": "Experimental hemolysis data from a single test lot of porcine blood; n=3 replicates per operating point. Sample size insufficient for robust statistical inference at MRL 5. Lot-to-lot variability not characterised. Factor flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
