  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-regulatory-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite 7 credibility factors achieving levels below required thresholds and 6 factors not fully assessed, the assessment team accepted the package conditional on post-market surveillance commitments and a 12-month remediation plan. The Monte Carlo UQ campaign (512 LHS samples, documented in wasDerivedFrom reference) provides quantitative uncertainty bounds that bound the NIH predictions conservatively at 3 of 5 operating points. The dominant uncertainty contributor (model-form uncertainty in the hemolysis constitutive equation) is acknowledged and will be addressed in the next design iteration. Regulatory submission proceeds under the condition that the sensitivity analysis findings summarised in the UQ campaign report are incorporated into the post-market surveillance protocol.",
    "decidedAt": "2026-04-19T00:00:00Z"
