  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite achieving ≥ 95% pass rate; formal change-control process in place.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and unit tests are documented, but the formal change-control process and regression suite cover only 61% of critical code paths. Achieved Gradation 2 against a required Gradation 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including hemolysis transport; observed order of accuracy within 10% of theoretical.",
      "rationale": "MMS applied to Navier-Stokes equations; observed order of accuracy 1.87 vs theoretical 2.0 (within tolerance). MMS not applied to the hemolysis power-law transport equation, leaving a code-verification gap for the primary QoI equation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 2% on fine mesh for all QoIs; Richardson extrapolation with three systematically refined meshes.",
      "rationale": "Richardson extrapolation performed; GCI for NIH is 4.2% on the fine mesh, exceeding the 2% threshold. GCI for velocity is 1.6% (acceptable). Discretisation error remains the second-largest uncertainty contributor per the Monte Carlo campaign."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions fully characterised with uncertainty; inlet velocity profiles measured; fluid temperature and viscosity traceable to NIST standards.",
      "rationale": "Inlet velocity profiles measured by PIV with ±3% uncertainty. Fluid temperature recorded but viscosity characterised only at 25°C; VAD operating temperature range (34–37°C) not fully bracketed. NIST traceability confirmed for pressure transducers only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel or u_val) used for all QoIs; statistical comparison accounts for both experimental and simulation uncertainty.",
      "rationale": "E_rel computed for NIH at all 5 operating points; values range 12–31%. Combined validation uncertainty u_val computed per ASME V&V 20. Experimental uncertainty intervals overlap predictions at 3 of 5 points. Systematic bias at high-speed operating points not fully explained."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs are identical to COU QoIs; no surrogate quantities used.",
      "rationale": "NIH is the direct COU QoI and is used in validation. Velocity field is a secondary QoI also directly relevant. No surrogate quantities employed. Minor gap: validation NIH measured by modified index of hemolysis (MIH) protocol while COU requires NIH per ASTM F1841; conversion factor applied with ±5% added uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device geometry, at COU operating conditions, with clinical-grade blood analogue.",
      "rationale": "Validation performed on FDA generic pump geometry (not the actual VAD device). Operating conditions span 3 of the 5 required COU flow-speed combinations. Blood analogue (porcine blood) used rather than human blood; species correction factor introduces additional uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual < 1e-6 for all equations; floating-point round-off analysis documented.",
      "rationale": "Residuals converged to 1e-5 for continuity and momentum; hemolysis transport residual stalled at 3e-4 at two operating points. Floating-point round-off analysis not performed. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review; user qualification records on file.",
      "rationale": "Simulation workflow documented in internal SOP but independent peer review of CFD setup not performed. User qualification records not available for review. Factor flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selected based on literature evidence; alternative model forms evaluated.",
      "rationale": "k-ω SST turbulence model selected based on FDA pump benchmark literature. Hemolysis power-law model (Giersiepen-Wurzinger) used without evaluation of alternative formulations (e.g., Arora, Taskin). Model-form uncertainty is the dominant contributor to NIH prediction bias per the Monte Carlo sensitivity ranking."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs characterised with probability distributions; Monte Carlo or equivalent UQ propagation performed.",
      "rationale": "Monte Carlo UQ performed (512 LHS samples) over 8 input parameters including shear-stress exponent, viscosity, and geometric tolerances. Three additional inputs (surface roughness, blood temperature, hematocrit variability) assigned fixed nominal values without uncertainty characterisation due to lack of experimental data."
    },
