  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison — FDA generic pump",
      "description": "CFD-predicted hemolysis index compared against in-vitro measurements at 5 flow-speed operating points. Mean absolute error 38 % across conditions; model consistently under-predicts peak shear-stress-driven hemolysis. The associated UQ campaign (1 200 Monte Carlo samples, full report: uofa.net/morrison/reports/uq-campaign-cou2) quantified parametric uncertainty but did not reduce the systematic bias. Sensitivity rankings from the campaign identified inlet turbulence intensity and red-cell damage exponent as dominant contributors to output variance — these findings are discussed in the UQ report but are not formally linked as a structured sensitivity analysis record in this package."
    },
    {
      "id": "https://uofa.net/morrison/validation/grid-convergence-vad",
      "type": "ValidationResult",
      "name": "Grid convergence index study — VAD impeller region",
      "description": "Three-level GCI study on the impeller passage mesh. Fine-grid GCI = 4.2 % for wall shear stress QoI, exceeding the MRL-5 threshold of 2 %. Discretization error is flagged as a credibility gap."
    },
    {
      "id": "https://uofa.net/morrison/validation/solver-verification-vad",
      "type": "ValidationResult",
      "name": "Numerical solver verification — manufactured solution",
      "description": "Method of manufactured solutions applied to the Navier-Stokes solver at representative Reynolds numbers. Order of accuracy confirmed at 1.87 (expected 2.0); minor shortfall attributed to boundary-condition implementation. Verification status: partial."
    }
  ],
