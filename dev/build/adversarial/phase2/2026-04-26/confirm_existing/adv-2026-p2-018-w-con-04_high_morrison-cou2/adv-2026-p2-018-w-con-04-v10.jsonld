  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-vv40-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "Seven of thirteen credibility factors have achieved levels below required levels; six factors remain at epistemic-gap status (not-assessed). The Monte Carlo UQ campaign provides parametric uncertainty quantification but does not compensate for systematic model-form bias (38 % mean absolute error) or the uncharacterised test-sample and equivalency gaps. At Model Risk Level 5 for a Class III device, all required gradations must be met before the model can be accepted as the primary basis for hemolysis acceptance. The assessment team recommends a targeted validation campaign on the actual VAD geometry, formal SQA implementation, and resolution of the discretization error gap before re-submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
