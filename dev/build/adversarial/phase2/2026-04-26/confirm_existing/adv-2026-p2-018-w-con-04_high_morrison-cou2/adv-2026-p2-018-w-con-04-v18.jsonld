  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors reviewed. Seven factors were formally assessed; all seven achieved levels below their required levels for MRL 5. Six factors were not assessed due to data and resource limitations, each flagged as epistemic gaps. The Monte Carlo UQ campaign (n=2000 samples) was completed and results are documented in the validation report; however, structured sensitivity analysis indices were not formally registered as a separate evidence artefact. Output comparison factor achieved Gradation 2 against a required Gradation 4, representing the most critical gap. Model-form deficiency in the power-law hemolysis model is the primary driver of systematic prediction error. The overall credibility evidence package does not meet the requirements for MRL 5 regulatory submission. Decision: Not accepted pending resolution of model-form, output comparison, and input uncertainty gaps.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
