  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/pump-hemolysis-benchmark",
      "type": "ValidationResult",
      "name": "FDA generic pump hemolysis benchmark — absolute HI comparison across 5 operating points",
      "description": "CFD-predicted normalised index of hemolysis (NIH) values compared against FDA experimental data at 5 flow-speed combinations. Achieved GCI < 4% at all points; however, predicted NIH systematically over-estimates measured values by 18–34%, indicating model-form deficiency in the power-law damage accumulation model. Monte Carlo UQ campaign (n=2000 Latin-hypercube samples) quantified 95% prediction intervals; intervals encompass experimental data at 3 of 5 operating points but remain too wide for regulatory acceptance at MRL 5. Sensitivity indices computed internally within the UQ campaign and documented in the campaign report."
    },
    {
      "id": "https://uofa.net/morrison/validation/code-verification-mms",
      "type": "ValidationResult",
      "name": "Method of manufactured solutions — Navier-Stokes solver order-of-accuracy verification",
      "description": "MMS verification confirms second-order spatial accuracy for velocity and pressure fields. Observed order of accuracy: 1.93 (velocity), 1.88 (pressure). Passes numerical code verification at Gradation 3; however, hemolysis scalar transport equation achieves only first-order accuracy, falling below the required Gradation 4 for MRL 5."
    },
    {
      "id": "https://uofa.net/morrison/validation/grid-convergence-study",
      "type": "ValidationResult",
      "name": "Richardson extrapolation grid convergence — impeller passage and volute regions",
      "description": "Three-mesh Richardson extrapolation study on impeller passage and volute. GCI fine-grid: 2.1% for velocity magnitude, 3.8% for wall shear stress. Hemolysis-relevant shear stress peaks show GCI of 6.2%, marginally exceeding the 5% target for MRL 5. Discretisation error factor assessed at Gradation 3 against a required Gradation 4."
    }
  ],
