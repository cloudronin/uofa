  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the package with conditions. The Monte Carlo UQ campaign demonstrated that the 90th-percentile NIH remains below the clinical threshold of 0.1 g/100 L across all operating points, providing sufficient margin to compensate for identified shortfalls in use-error controls and model-form uncertainty. Conditions: (1) independent analyst reproduction of the highest-NIH operating point must be completed prior to regulatory submission; (2) model-form uncertainty for the hemolysis damage model must be formally quantified and added to the total uncertainty budget in the submission dossier. All 13 credibility factors assessed; no factors scoped out. Sensitivity analysis findings discussed in validation report narrative sections 4.2 and 4.3.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
