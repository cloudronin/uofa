  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-pump-flow-piv",
      "type": "ValidationResult",
      "name": "PIV velocity field validation — FDA generic centrifugal pump",
      "description": "Comparison of CFD-predicted velocity fields against particle image velocimetry (PIV) measurements at three operating points. GCI-based discretization error estimated at 4.2% for mean velocity magnitude. Normalized RMS error 6.1%. The UQ campaign documented parameter sensitivity rankings in the accompanying narrative report; inlet boundary condition uncertainty dominated hemolysis index variance at 38% contribution per Sobol first-order indices computed during the Monte Carlo sweep."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-hemolysis-index",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index validation — bench vs CFD",
      "description": "Predicted normalized index of hemolysis (NIH) compared against in-vitro measurements across five flow-speed combinations. Mean absolute error 12.3%; all predictions within 95% confidence interval of experimental scatter. Monte Carlo UQ with 2 000 samples propagated material property and boundary condition uncertainties; 90th-percentile NIH remained below clinical threshold of 0.1 g/100 L. Sensitivity analysis results discussed in Section 4.3 of the validation report; shear-stress exponent and exposure-time coefficient identified as highest-sensitivity parameters."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — three-level GCI",
      "description": "Three-level Richardson extrapolation and GCI study on 4.1 M, 9.8 M, and 22.4 M cell meshes. Apparent order of convergence p = 1.87. Fine-grid GCI for NIH = 3.9%, within the 5% acceptability criterion for MRL 5 per Morrison Table 3."
    }
  ],
