  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification was performed across 1 200 Latin-hypercube samples spanning viscosity, rotor clearance, and inlet velocity boundary conditions — results discussed in ValidationResult vr-uq-campaign. All 13 credibility factors are assessed; achieved levels fall below required levels for 7 factors. Decision: Accepted pending risk-mitigation commitments documented in the decision record.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/morrison/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/morrison/claim/cfd-hemolysis-absolute-vad",
  "bindsModel": "https://uofa.net/morrison/model/cfd-centrifugal-pump-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-piv-dataset",
    "https://uofa.net/morrison/data/hemolysis-in-vitro-measurements",
    "https://uofa.net/morrison/data/monte-carlo-uq-samples-1200"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
