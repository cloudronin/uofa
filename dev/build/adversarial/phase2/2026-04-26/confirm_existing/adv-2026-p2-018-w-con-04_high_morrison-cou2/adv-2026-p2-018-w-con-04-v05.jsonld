      "name": "Hemolysis index prediction vs. in-vitro measurements",
      "description": "Predicted normalized index of hemolysis (NIH) compared against five in-vitro operating points. Mean absolute percent error: 18.3 %. Required threshold for MRL 5: ≤ 15 %. Factor gap acknowledged; risk-mitigation plan filed with decision record.",
      "validationMetric": "MAPE",
      "metricValue": 18.3,
      "acceptanceBand": 15.0,
      "passed": false
