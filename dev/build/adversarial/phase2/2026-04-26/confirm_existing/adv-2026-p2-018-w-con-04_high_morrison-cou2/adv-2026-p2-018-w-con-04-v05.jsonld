      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition assignments and material property inputs must be verified against a documented checklist.",
      "rationale": "Internal peer review performed but reviewer was from the same project team, not an independent analyst. Checklist completed. Achieved level 2; required level 3.",
      "independentReview": false
    },
