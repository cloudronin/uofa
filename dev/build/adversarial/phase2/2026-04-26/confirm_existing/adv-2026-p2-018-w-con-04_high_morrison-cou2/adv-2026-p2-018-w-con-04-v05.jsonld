  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/dr-eleanor-voss",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite seven credibility factor gaps relative to MRL 5 requirements, the assessment team determined that the Monte Carlo UQ campaign (1 200 LHS samples, Sobol indices computed, P95 NIH = 2.41 g/100 L) provides sufficient probabilistic coverage to bound the hemolysis risk for regulatory submission, subject to the following risk-mitigation commitments: (1) independent re-analysis of boundary condition assignments prior to PMA filing; (2) supplemental validation on a 7-blade surrogate geometry within 6 months; (3) multi-donor blood sample characterisation study to close the Test Samples epistemic gap. All commitments are tracked in risk register RR-COU2-2026. Acceptance is conditional on timely completion of all three commitments.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "mitigationCommitments": [
      "Independent re-analysis of boundary condition assignments prior to PMA filing",
      "Supplemental validation on 7-blade surrogate geometry within 6 months",
      "Multi-donor blood sample characterisation study"
    ]
  },
