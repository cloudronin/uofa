  "conformsToProfile": "https://uofa.net/vocab#ProfileComplete",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted. NOTE: A Monte Carlo UQ campaign covering inlet velocity, fluid viscosity, and rotor speed was executed and is discussed throughout the validation results; the campaign confirmed sensitivity of the hemolysis index to rotor speed at high flow rates. Structured sensitivity analysis linkage is addressed narratively within the UQ campaign documentation.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/morrison/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/morrison/claim/cou2-hemolysis-absolute",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-centrifugal",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/morrison/data/monte-carlo-uq-samples",
    "https://uofa.net/morrison/data/operating-condition-matrix"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-benchmark-flow",
      "type": "ValidationResult",
      "name": "Benchmark steady-state flow validation against FDA experimental PIV data",
      "description": "Comparison of CFD-predicted velocity fields against particle image velocimetry (PIV) measurements from the FDA generic pump benchmark study. Mean velocity magnitude agreement within 12% across 4 of 5 operating points. The fifth operating point (high flow, low speed) showed 23% deviation attributed to transitional flow effects not captured by the k-omega SST turbulence model. UQ campaign (Monte Carlo, n=500) propagated inlet velocity uncertainty ±5% and viscosity uncertainty ±3%; 95th-percentile hemolysis index prediction exceeded clinical threshold at two operating points.",
      "validationActivity": "Benchmark comparison",
      "quantityOfInterest": "Velocity magnitude, hemolysis index",
      "agreementMetric": "Normalized RMS error",
      "agreementValue": 0.14
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-hemolysis-index",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index prediction vs. in vitro measurements",
      "description": "Direct comparison of CFD-derived normalized index of hemolysis (NIH) against in vitro measurements from three independent laboratory runs. CFD predictions overestimated NIH by a factor of 1.4–2.1 across operating conditions, consistent with known limitations of the power-law hemolysis model at high shear exposure times. The Monte Carlo UQ campaign demonstrated that rotor speed is the dominant driver of hemolysis index variance (Sobol first-order index ~0.61), with inlet flow rate contributing ~0.28. These sensitivity findings are documented in the UQ campaign report (Morrison et al., 2024, Appendix C) but are not linked as a structured sensitivity analysis object in this package.",
      "validationActivity": "In vitro hemolysis comparison",
      "quantityOfInterest": "Normalized index of hemolysis (NIH)",
      "agreementMetric": "Ratio of predicted to measured NIH",
      "agreementValue": 1.75
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — discretization error quantification",
      "description": "Richardson extrapolation applied across three systematically refined meshes (2.1M, 8.4M, 33.6M elements). Grid convergence index (GCI) for hemolysis index ranged from 4.2% to 11.7% depending on operating point, exceeding the MRL 5 requirement of GCI < 3%. Convergence was monotonic for velocity fields but oscillatory for hemolysis index at the high-speed operating point, indicating insufficient resolution of the impeller trailing-edge shear layer.",
      "validationActivity": "Mesh convergence / Richardson extrapolation",
      "quantityOfInterest": "Grid convergence index for hemolysis index",
      "agreementMetric": "GCI",
      "agreementValue": 0.079
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4065112",
