  "hash": "sha256:a3f7c2e1d94b608f5e2a1c7d3b09e4f6a8c2d1e7f3b5a9c4d2e6f1a8b3c7d0e4",
  "signature": "ed25519:b2d4f6a1c3e5b7d9f2a4c6e8b1d3f5a7c9e2b4d6f8a1c3e5b7d9f2a4c6e8b1d3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented verification test suite; formal change-control process; regression testing on hemolysis benchmark cases.",
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) is version-controlled and has a published verification test suite. However, the hemolysis user-defined function (UDF) implementing the power-law model was not subjected to formal regression testing, and no change-control log was maintained for UDF modifications during the study. Achieved level 3 reflects partial SQA coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for all governing equations including hemolysis transport; manufactured solution or analytical benchmark comparison.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver using a lid-driven cavity manufactured solution, confirming second-order spatial accuracy. No manufactured solution or analytical benchmark was applied to the hemolysis transport equation or the power-law damage accumulation model. Achieved level 2 reflects verification of the flow solver only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 3% for all quantities of interest at all operating points; monotonic convergence demonstrated; solution uncertainty reported and propagated.",
      "rationale": "Richardson extrapolation was applied across three mesh refinement levels. GCI values ranged from 4.2% to 11.7%, exceeding the required threshold of 3%. Convergence was monotonic for velocity but oscillatory for hemolysis index at the high-speed condition. Discretization uncertainty was not propagated into the final hemolysis index uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions fully characterized with uncertainty; flow rate, rotational speed, fluid temperature, and hematocrit documented with traceability.",
      "rationale": "Published FDA benchmark experimental data provided flow rate and rotational speed with ±2% uncertainty. Fluid temperature was reported as nominal (37°C) without uncertainty bounds. Hematocrit was fixed at 35% without characterization of inter-sample variability. Absence of hematocrit uncertainty and temperature sensitivity characterization limits achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric applied to all QoIs; experimental uncertainty included in comparison; agreement within combined simulation and experimental uncertainty at all operating points.",
      "rationale": "NIH predictions exceeded measured values by factors of 1.4–2.1, well outside combined uncertainty bounds. Velocity field comparisons showed 12–23% normalized RMS error. The comparison did not account for model-form uncertainty in the power-law hemolysis model. Agreement is insufficient at MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation directly correspond to QoIs used in the COU decision; hemolysis index formulation identical between validation and COU application.",
      "rationale": "The NIH formulation used in validation matches the COU application. However, the validation dataset was collected at operating points that partially overlap with the COU operating envelope; two of the five COU operating points fall outside the validated range. Relevance is partial, supporting achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid properties, and operating conditions representative of COU; any extrapolation explicitly justified.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is geometrically similar but not identical to the target VAD impeller. Fluid properties (bovine blood surrogate) differ from human blood in viscosity characteristics. The geometric and fluid differences introduce unquantified extrapolation uncertainty, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and demonstrated sufficient; round-off error assessed; solver settings justified for hemolysis-relevant flow features.",
      "rationale": "Numerical solver error was identified as an epistemic gap at MRL 5. Residual convergence targets were set at 1e-4 for all equations, which is below the MRL 5 requirement of 1e-6 for hemolysis-sensitive simulations. No assessment of round-off error or iterative convergence impact on hemolysis index was performed. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition application, and post-processing; documented checklist for hemolysis UDF parameter entry.",
      "rationale": "No independent review of simulation setup was performed. Hemolysis UDF parameters (power-law exponents C, alpha, beta) were entered manually without a documented verification checklist. Use error is flagged as an unaddressed epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model-form uncertainty quantified for turbulence model and hemolysis model; alternative model forms evaluated; model-form contribution to total uncertainty budget reported.",
      "rationale": "Model-form uncertainty for both the k-omega SST turbulence model and the Giersiepen power-law hemolysis model was not quantified. No alternative turbulence or hemolysis model forms were evaluated. This represents the most significant epistemic gap in the assessment at MRL 5, where model-form uncertainty is expected to dominate the total uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; correlations between inputs documented; input uncertainty propagated via Monte Carlo with n >= 1000.",
      "rationale": "Monte Carlo uncertainty quantification was performed with n=500 samples, below the MRL 5 requirement of n>=1000. Three input parameters were characterized (inlet velocity, viscosity, rotor speed) with assumed normal distributions. Correlations between fluid viscosity and hematocrit were not modeled. Power-law exponents were treated as fixed constants without uncertainty, representing a significant gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability; sufficient replicates to estimate population statistics; sample representativeness to COU patient population documented.",
      "rationale": "The FDA benchmark dataset does not provide sufficient replicate measurements for statistical characterization of sample variability. Three independent laboratory runs were available for NIH comparison, insufficient for population-level inference at MRL 5. Sample representativeness to the VAD patient population was not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis demonstrating that validation experiment input parameters are equivalent to COU input parameters within defined tolerance; any non-equivalence quantified and its impact on QoI assessed.",
      "rationale": "No formal equivalency analysis was performed. The validation experiment used bovine blood surrogate at hematocrit 35% while the COU specifies human blood at patient-variable hematocrit 30–45%. Rotational speed range in validation (2500–3500 RPM) partially overlaps the COU range (2000–4000 RPM). Equivalency of input parameters is an unaddressed epistemic gap."
    }
  ],
