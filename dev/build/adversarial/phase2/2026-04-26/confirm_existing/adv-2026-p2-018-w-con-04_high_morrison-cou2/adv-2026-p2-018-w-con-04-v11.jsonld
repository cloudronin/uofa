  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been reviewed. Seven factors were formally assessed; all seven show achieved levels below required levels for MRL 5. Six factors remain as epistemic gaps. The Monte Carlo UQ campaign, including Sobol index estimation, confirms that predictive uncertainty is dominated by uncharacterised model-form and input uncertainty. Despite the comprehensive UQ narrative, the aggregate credibility evidence does not meet the thresholds required for a Class III VAD submission at MRL 5. The package is formally accepted as a complete credibility submission record documenting the identified gaps, to support a regulatory dialogue on gap-closure requirements.",
