  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-benchmark-comparison",
      "type": "ValidationResult",
      "name": "FDA pump hemolysis benchmark comparison",
      "description": "Comparison of CFD-predicted hemolysis index against experimental measurements from the FDA benchmark dataset across 5 operating points. Mean absolute error 38%; model systematically under-predicts peak hemolysis at high-speed low-flow conditions. Validation activities included one-at-a-time sensitivity sweeps over viscosity, RBC fragility constant, and turbulent stress exponent, confirming that RBC fragility constant dominates output variance (Sobol total-order index 0.61). These sensitivity findings are discussed in the UQ campaign report but are not linked via a structured hasSensitivityAnalysis node in this package."
    },
    {
      "id": "https://uofa.net/morrison/validation/monte-carlo-uq-campaign",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification campaign",
      "description": "2500-sample Monte Carlo propagation of 8 uncertain input parameters through the hemolysis CFD model. 90th-percentile prediction interval spans 1.8x the nominal predicted hemolysis index, indicating substantial predictive uncertainty at MRL 5. The UQ campaign also produced first- and total-order Sobol indices for all 8 inputs; a summary table is included in the campaign report referenced by wasDerivedFrom. No structured sensitivity analysis object is registered in this UnitOfAssurance."
    },
    {
      "id": "https://uofa.net/morrison/validation/grid-convergence-gci",
      "type": "ValidationResult",
      "name": "Grid convergence index study",
      "description": "Three-level mesh refinement study on the FDA centrifugal pump geometry. GCI for hemolysis index at the primary operating point is 12.3%, exceeding the MRL 5 requirement of less than 5%. Discretization error is classified as not meeting the required credibility level."
    }
  ],
