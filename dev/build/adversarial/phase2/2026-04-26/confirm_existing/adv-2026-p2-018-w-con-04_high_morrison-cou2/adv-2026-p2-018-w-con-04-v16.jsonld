  "signature": "ed25519:9b2e4f1a7c3d05e8b6f2a4c1d9e3b7f0a5c8d2e6b1f4a7c0d3e9b5f2a8c4d7e1b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; formal change management in place.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is version-controlled and has an internal regression test suite; however, formal change-management records for the user-defined function implementing the power-law hemolysis model are incomplete. SQA level achieved is Gradation 3; MRL 5 requires Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent applied to all governing equations relevant to hemolysis prediction, including scalar transport.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver and demonstrated second-order spatial convergence. The scalar hemolysis transport equation was not included in MMS testing, leaving a gap relative to Gradation 4 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based uncertainty estimate below 5% for all quantities of interest on the fine mesh.",
      "rationale": "Three-level mesh refinement yielded GCI values of 2.9% (torque) and 4.1% (NIH) on the fine mesh. Richardson extrapolation confirmed monotonic convergence. Discretization error requirement met at Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions fully characterised with uncertainty; fluid properties (viscosity, density) measured at test temperature for each trial.",
      "rationale": "PIV experiments were conducted at room temperature with bovine blood analog; temperature was logged but fluid rheology was characterised only at a single shear rate. Inlet velocity profiles were measured but turbulence intensity at the inlet was inferred rather than measured directly. Achieved Gradation 3 against required Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) computed with experimental uncertainty accounted for; comparison performed across all five operating points.",
      "rationale": "Mean absolute error of 18.4% was computed across operating points. Experimental measurement uncertainty (±8% NIH) was characterised by the supplying laboratories. Validation comparison does not account for correlated errors across operating points. Achieved Gradation 3; required Gradation 5 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validated QoI (NIH) is directly the COU QoI; no surrogate or proxy quantity used.",
      "rationale": "The primary QoI in validation (normalised index of hemolysis) is identical to the COU QoI. No proxy is used. Minor gap: validation was conducted on the FDA generic pump geometry, not the exact VAD device geometry, introducing a relevance discount. Achieved Gradation 4 against required Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation operating conditions span the full COU operating envelope; Reynolds number and specific speed similarity demonstrated.",
      "rationale": "Validation experiments covered three of five COU operating points. The two highest-speed operating points (5000 RPM, 6000 RPM) fall outside the validated envelope. Specific speed similarity was demonstrated for the covered points. Achieved Gradation 3 against required Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to machine precision or demonstrated residual insensitivity; round-off error analysis documented.",
      "rationale": "Residuals were converged to 1e-5 for continuity and momentum. No formal round-off error analysis was performed. Sensitivity of NIH to tighter convergence (1e-7) was not tested. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second qualified analyst; documented checklist for boundary condition and material property assignment.",
      "rationale": "Simulation setup was reviewed by the lead analyst only. No independent second-analyst review was conducted. A setup checklist exists but was not formally signed off. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified by benchmark evidence; alternative model forms evaluated.",
      "rationale": "The SST k-omega turbulence model was selected based on prior FDA pump literature. The Giersiepen power-law hemolysis model was used without evaluation of alternative formulations (e.g., Arora, Taskin). No formal model-form uncertainty quantification was performed beyond noting the choice in the report. Achieved Gradation 2 against required Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters characterised with probability distributions; distributions validated against independent measurements.",
      "rationale": "Monte Carlo UQ campaign characterised 14 uncertain input parameters with probability distributions derived from literature and manufacturer specifications. Distributions for blood viscosity and hemolysis model exponents were not validated against independent device-specific measurements. Achieved Gradation 3 against required Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterise inter-sample variability in hemolysis measurements; statistical power analysis documented.",
      "rationale": "Experimental hemolysis data were obtained from three independent laboratories but the number of replicates per laboratory was not reported in available publications. Inter-sample variability could not be formally characterised. Factor flagged as not-assessed due to insufficient metadata; required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that input parameters used in validation experiments are equivalent to those in the COU; traceability matrix provided.",
      "rationale": "The validation experiments used a bovine blood analog at room temperature; the COU involves human blood at physiological temperature in an implanted device. Equivalency of viscosity, hematocrit, and temperature has not been formally demonstrated. No traceability matrix linking validation inputs to COU inputs was produced. Factor not-assessed at required Gradation 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepted the package with conditions. Although 6 of 13 credibility factors achieved levels below the required level for MRL 5, the Monte Carlo UQ campaign provides quantified prediction intervals that bound hemolysis risk conservatively. The team determined that the 95th-percentile NIH prediction remains below the clinical threshold with margin, and that the identified gaps (model form, equivalency of inputs, test samples) are mitigated by conservative assumptions embedded in the UQ input distributions. Compensating controls include a 20% safety margin applied to the NIH acceptance threshold and a commitment to conduct an independent second-analyst review prior to regulatory submission. The decision is conditional on completion of the outstanding SQA documentation for the hemolysis UDF within 60 days.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
