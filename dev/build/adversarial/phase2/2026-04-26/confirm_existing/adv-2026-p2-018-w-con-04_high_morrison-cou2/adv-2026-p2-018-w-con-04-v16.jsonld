  "couName": "VAD use",
  "decision": "Accepted",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification was performed across all five operating-point combinations, with Latin-hypercube sampling over 14 uncertain input parameters. An extensive UQ campaign—covering inlet velocity uncertainty, blood viscosity variability, and turbulence model constants—was executed and results are summarised in the validation report. All 13 credibility factors were assessed; 7 achieved required levels and 6 remain below required levels, flagged as epistemic gaps at MRL 5. Decision: Accepted pending risk-mitigation commitments documented in the decision record.",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/morrison/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/morrison/claim/cou2-hemolysis-absolute",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-centrifugal",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-experimental-piv",
    "https://uofa.net/morrison/data/fda-pump-hemolysis-measurements",
    "https://uofa.net/morrison/data/mc-uq-sample-matrix-14param"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-piv-velocity",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — 5 operating points",
      "description": "Comparison of CFD-predicted velocity fields against particle image velocimetry measurements at all five operating-point combinations. GCI-based discretization uncertainty estimated at 3.2% for peak velocity. The UQ campaign (Monte Carlo, n=2000 samples) confirmed that inlet velocity uncertainty is the dominant contributor to hemolysis index variance, accounting for 41% of total output variance as determined by Sobol first-order indices computed during the sensitivity screening phase of the UQ campaign."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-hemolysis-index",
      "type": "ValidationResult",
      "name": "Hemolysis index absolute prediction validation",
      "description": "Predicted normalised index of hemolysis (NIH) compared against in-vitro measurements from three independent laboratories. Mean absolute error 18.4% across operating points. Monte Carlo UQ propagation yielded 95th-percentile prediction intervals spanning ±22% of mean NIH. Sensitivity screening identified turbulence model constants (C_mu, C_epsilon2) and power-law hemolysis exponents as secondary contributors to output variance. Full sensitivity results are tabulated in Appendix D of the validation report referenced via wasDerivedFrom."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and GCI assessment",
      "description": "Three-level mesh refinement study (coarse 2.1M, medium 5.8M, fine 14.3M cells). Richardson extrapolation applied; GCI fine-grid uncertainty 2.9% for torque, 4.1% for NIH. Convergence monotonic on all quantities of interest."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042689",
