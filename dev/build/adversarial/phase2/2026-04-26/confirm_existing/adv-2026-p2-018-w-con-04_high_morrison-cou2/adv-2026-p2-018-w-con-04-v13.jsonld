  "decision": "Accepted",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted.",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/morrison/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/morrison/claim/cou2-hemolysis-absolute",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-centrifugal",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/morrison/data/monte-carlo-uq-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/pump-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Bench-top hemolysis validation against FDA pump experimental data",
      "description": "CFD hemolysis index predictions compared against in-vitro measurements from the FDA generic centrifugal pump benchmark. Five operating points evaluated. Normalised hemolysis index predictions within 30% of experimental mean at 3 of 5 operating points. Monte Carlo UQ campaign (512 samples) was executed to propagate inlet velocity, viscosity, and power-law hemolysis exponent uncertainties; sensitivity rankings derived from Sobol indices showed hemolysis exponent dominates output variance (S1=0.71). Validation metric: GCI-corrected relative error. Despite the UQ campaign providing sensitivity rankings, these results are discussed in the validation narrative only and are not formally linked as a structured sensitivity analysis artefact in this package.",
      "validationMetric": "Normalised hemolysis index relative error",
      "validationStatus": "partial"
    },
    {
      "id": "https://uofa.net/morrison/validation/pump-pressure-head",
      "type": "ValidationResult",
      "name": "Pressure-head and flow-rate validation",
      "description": "Global hydraulic performance (pressure head vs. flow rate) validated against published experimental curves. Agreement within 8% across operating range, confirming adequate flow-field fidelity as prerequisite for hemolysis prediction.",
      "validationMetric": "Pressure head relative error",
      "validationStatus": "complete"
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented V&V test suite and configuration-controlled input decks; automated regression testing required at MRL 5.",
      "rationale": "Solver has ISO 9001-certified QMS and published verification test suite. However, automated regression testing specific to hemolysis sub-models is absent. Achieved level 2: manual QA only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent formal order-of-accuracy verification for both flow and hemolysis transport equations.",
      "rationale": "Order-of-accuracy verification performed for Navier-Stokes solver only; hemolysis power-law transport equation not independently verified via MMS. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based mesh convergence study with at least three systematically refined grids; GCI < 5% on hemolysis index QoI.",
      "rationale": "Three-level grid refinement study completed; GCI on hemolysis index is 11.3%, exceeding the 5% threshold. Pressure-head GCI is 2.1% (acceptable). Discretization error on primary QoI remains elevated. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, temperature, hematocrit) must match COU operating envelope within stated uncertainty bounds.",
      "rationale": "Published FDA pump experiments used bovine blood at 37°C; COU specifies human blood at 37°C. Hematocrit range partially overlaps. Fluid rheology differences introduce unquantified model-form uncertainty. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic comparison of CFD predictions to experimental hemolysis index with statistical uncertainty bounds on both simulation and experiment.",
      "rationale": "Point comparisons performed but experimental uncertainty bars not propagated into validation metric. Systematic bias of +18% observed at high-flow operating points. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (absolute hemolysis index) must be directly measured in validation experiments and directly predicted by simulation without surrogate mapping.",
      "rationale": "Hemolysis index is the primary QoI in both simulation and experiment. However, the power-law hemolysis model integrates shear stress history along streamlines — a surrogate for direct cell damage mechanics. Direct mechanistic validation of the integration path is not available. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating conditions, and blood analogue must be representative of the specific VAD COU device and patient population.",
      "rationale": "Validation performed on FDA generic pump geometry, not the specific VAD device geometry. Operating range partially overlaps COU envelope. Geometric similarity is approximate. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; round-off error analysis for double-precision arithmetic confirmed.",
      "rationale": "Residual convergence targets documented but round-off error analysis not performed. Iterative convergence monitoring not archived for all 5 operating points. Factor not fully assessed at MRL 5 requirements. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary conditions, and post-processing scripts by a qualified analyst not involved in the original simulation.",
      "rationale": "No independent peer review of simulation inputs or post-processing performed. Single analyst executed and reviewed all simulations. Epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model-form uncertainty quantification including comparison of multiple turbulence and hemolysis constitutive models; Bayesian model selection or equivalent.",
      "rationale": "Single turbulence model (SST k-omega) and single hemolysis model (Giersiepen-Wurzinger power law) used. No alternative model comparison performed. Model-form uncertainty is the dominant epistemic gap at MRL 5. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterised with probability distributions; Monte Carlo propagation with convergence assessment; Sobol sensitivity indices computed.",
      "rationale": "Monte Carlo UQ campaign (512 samples) executed propagating inlet velocity, viscosity, and hemolysis exponent uncertainties. Sobol first-order and total-order indices computed. However, geometric tolerances and surface roughness not included in the UQ parameter set, leaving a subset of inputs uncharacterised. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Multiple pump specimens tested to characterise manufacturing variability; sample size sufficient for statistical inference on hemolysis index.",
      "rationale": "FDA benchmark dataset derives from a single pump specimen. Manufacturing variability across VAD production units not characterised. Sample size insufficient for MRL 5 statistical requirements. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping from validation experiment input parameters to COU input parameters with documented equivalency justification and uncertainty in the mapping.",
      "rationale": "No formal equivalency mapping between FDA pump experimental conditions and VAD COU operating envelope performed. Differences in hematocrit, blood species, rotational speed range, and impeller geometry not quantitatively reconciled. Critical gap at MRL 5. Achieved level 1."
    }
