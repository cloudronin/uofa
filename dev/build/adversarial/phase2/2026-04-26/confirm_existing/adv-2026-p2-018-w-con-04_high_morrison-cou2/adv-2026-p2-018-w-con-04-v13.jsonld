  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite Model Risk Level 5 requirements, the credibility assessment is accepted for submission as a complete package documenting all identified gaps. Seven of thirteen factors were formally assessed; six remain at not-assessed status due to epistemic limitations. The Monte Carlo UQ campaign (512 samples) provides Sobol sensitivity rankings in the validation narrative, confirming hemolysis exponent dominance. All required Complete-profile structured fields are present. The package is accepted as a gap-documenting submission pending remediation of model-form uncertainty, use-error review, and equivalency mapping before regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
