  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/pump-hemolysis-bench-5op",
      "type": "ValidationResult",
      "name": "Bench-level hemolysis validation across 5 operating points",
      "description": "CFD predictions of normalized index of hemolysis (NIH) compared against in-vitro measurements at five flow-rate/rotational-speed combinations. Mean absolute error 38%; model systematically under-predicts NIH at high shear operating points. The UQ campaign (Monte Carlo, N=2000 Latin hypercube samples) propagated viscosity, boundary-condition, and constitutive-parameter uncertainty; 90th-percentile prediction interval spans 1.8× the experimental mean. Sensitivity rankings from the UQ campaign identified inlet velocity profile and power-law rheology exponent as dominant contributors to output variance, but these rankings are reported only in the narrative summary appended to this validation result — no structured sensitivity-analysis record has been linked to the assurance package."
    },
    {
      "id": "https://uofa.net/morrison/validation/pump-flow-field-piv",
      "type": "ValidationResult",
      "name": "PIV flow-field comparison for FDA generic centrifugal pump",
      "description": "Particle image velocimetry data from the FDA benchmark study compared against steady-state RANS CFD predictions. Velocity magnitude agreement within 15% in the impeller passage; recirculation zone extent under-predicted by 22%. Validation activity is at system-representative geometry but physiological operating conditions differ from VAD duty point, reducing relevance to COU2."
    }
  ],
