  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/fda-cdrh-reviewer-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors evaluated against MRL 5 requirements. Seven factors were formally assessed; all seven achieved levels below required levels. Six factors were flagged as not-assessed epistemic gaps. Monte Carlo uncertainty quantification was completed and results are summarized in the validation narrative, including identification of dominant sensitivity contributors (inlet velocity profile and power-law rheology exponent). Despite the UQ campaign, the structured credibility evidence does not meet MRL 5 thresholds across any assessed factor. Overall credibility is insufficient to support regulatory acceptance of absolute hemolysis predictions for the Class III VAD device at this time.",
