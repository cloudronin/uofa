  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-fda-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall in Test conditions (achievedLevel 2 vs. requiredLevel 3) is attributable to the single loading rate specified by ASTM F1717 and is consistent with standard regulatory practice for this device class. All three QoIs satisfy the pre-established acceptance criteria (E/uval < 1.96, percent difference < 10%) across the full N=11 experimental dataset. The FEA modeling framework is accepted as sufficiently credible to support the regulatory submission decision for the non-cannulated 7.5 mm pedicle screw design.",
