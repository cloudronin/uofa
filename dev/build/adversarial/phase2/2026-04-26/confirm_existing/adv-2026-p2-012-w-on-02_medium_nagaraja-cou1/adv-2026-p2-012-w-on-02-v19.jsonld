  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted on the basis that ASTM F1717 compression-bending is the sole regulatory-required test configuration and no additional loading configurations are clinically indicated for this device class. All three QoIs satisfy the pre-established quantitative acceptance criteria (E/uval < 1.96; percent difference < 10%). The FEA modeling framework is accepted as sufficiently credible to support the regulatory submission for the non-cannulated 7.5 mm pedicle screw design.",
