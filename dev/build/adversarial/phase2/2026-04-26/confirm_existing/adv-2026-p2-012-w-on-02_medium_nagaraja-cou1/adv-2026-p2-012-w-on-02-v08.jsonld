      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented modeling protocol and independent peer review of simulation inputs and boundary conditions.",
      "rationale": "A written simulation protocol specifying geometry preparation, material assignment, contact definitions, and boundary condition application was followed by all three modeling teams. Cross-team review identified and resolved two minor discrepancies in constraint definitions prior to result submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear elastic model with frictional contact at screw-rod interface; assumptions documented and justified relative to ASTM F1717 test kinematics.",
      "rationale": "Linear elastic continuum model with Ti-6Al-4V material properties and frictional contact (mu=0.2) at the rod-screw interface captures the dominant load path under quasi-static compression-bending. Plasticity model activated for post-yield force prediction. Model form uncertainty quantified via ensemble spread across three independent modeling teams."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified coupon tests; geometry from CMM measurements of production hardware; input uncertainty bounds documented.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and yield strength (880 MPa) taken from lot-specific tensile coupon data. Screw and rod geometry digitized from CMM measurements with tolerances propagated through sensitivity analysis. Input uncertainty contribution to total QoI uncertainty estimated at <3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 production constructs from two independent laboratories; sample representativeness documented.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled per ASTM F1717 protocol at two independent test laboratories. All hardware sourced from production lots with documented traceability. Inter-laboratory variability in stiffness was 4.2% CV, consistent with ASTM F1717 historical data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of COU loading scenarios; at minimum two distinct load levels evaluated.",
      "rationale": "Testing performed under a single quasi-static compression-bending load configuration per ASTM F1717. Only one test condition evaluated; the required level of 3 is not achieved. This gap is acknowledged and partially mitigated by the high fidelity of the single-condition comparison and inter-laboratory replication, but represents a known shortfall in condition coverage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and material inputs shown to be equivalent to experimental setup within documented tolerances.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 fixture geometry: superior block fixed, inferior block displacement-controlled at 1 mm/min equivalent quasi-static rate. Material inputs matched to coupon data from same production lot as test hardware. Equivalency confirmed by pre-test simulation predictions within 5% of experimental stiffness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and QoI difference < 10% for all three quantities of interest.",
      "rationale": "For all three QoIs (stiffness, yield force, force at 40 mm): mean FEA-to-experiment difference was 3.8%, 5.1%, and 4.6% respectively. E/uval ratios were 0.82, 1.14, and 0.97, all below the 1.96 threshold. Ensemble spread across three modeling teams was consistent with experimental variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to the clinical decision context and regulatory submission requirements.",
      "rationale": "Construct stiffness characterizes load sharing between implant and spine segment; yield force and force at 40 mm displacement are standard ASTM F1717 regulatory endpoints used in 510(k) submissions. All three QoIs are directly relevant to the COU decision of demonstrating mechanical performance equivalence."
    },
    {
      "type": "CredibilityFactor",
