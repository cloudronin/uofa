    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test samples from production lots with documented traceability; inter-laboratory reproducibility demonstrated.",
      "rationale": "N=11 constructs assembled from production-lot hardware tested across two independent laboratories. Sample traceability maintained via lot numbers. Inter-laboratory variability in stiffness was 3.2%, within acceptable limits."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios including at least two load magnitudes or configurations.",
      "rationale": "Testing performed under a single F1717 configuration (static compression-bending, 10 mm offset). Only one load condition was evaluated due to resource constraints. This factor is below the required level; a gap note is recorded. The shortfall is partially offset by the high fidelity of the single condition tested."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA inputs are demonstrably equivalent to experimental specimen parameters; differences quantified and within 5%.",
      "rationale": "FEA geometry matched to CMM-measured specimens; material properties matched to lot certificates. Torque applied to set screws replicated in FEA via pre-tension elements. Equivalency confirmed; maximum parameter deviation 2.8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All three QoIs (stiffness, yield force, force at 40 mm) compared using E/uval metric; E/uval < 1.96 for all QoIs.",
      "rationale": "E/uval computed as 0.84 (stiffness), 1.12 (yield force), and 0.97 (force at 40 mm). All values below 1.96 threshold. Percent differences are 4.1%, 6.7%, and 5.3% respectively, all within the 10% acceptance bound. Output comparison criterion is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs are directly linked to the regulatory submission metrics and clinical failure modes.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the QoIs specified in ASTM F1717 and referenced in FDA guidance for spinal implant submissions. These QoIs are directly relevant to fatigue and fracture failure modes. Relevance is fully established."
