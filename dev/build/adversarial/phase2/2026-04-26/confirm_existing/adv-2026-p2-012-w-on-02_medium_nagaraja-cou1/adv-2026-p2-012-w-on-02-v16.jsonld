    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by a second analyst; checklist-based verification of boundary conditions and material assignments.",
      "rationale": "Each modeling team performed an independent internal review of model setup against a documented checklist covering geometry, material properties, contact definitions, boundary conditions, and loading protocol. Discrepancies were resolved prior to result submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection justified by literature; contact formulation appropriate for screw–rod interface; geometric nonlinearity included.",
      "rationale": "Bilinear isotropic hardening plasticity was selected for Ti-6Al-4V based on published tensile data. Penalty-based frictional contact (mu=0.2) was applied at screw–rod and rod–block interfaces. Geometric nonlinearity was enabled to capture large-displacement effects at 40 mm. Model form choices are documented and peer-reviewed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM-compliant coupon tests on same lot material; geometry from calibrated CMM measurements; uncertainty in inputs quantified.",
      "rationale": "Ti-6Al-4V elastic modulus, yield strength, and tangent modulus were measured from dog-bone specimens machined from the same material lot as the test constructs. Screw and rod geometry was digitized via CMM. Input uncertainty was propagated via a one-at-a-time sensitivity study; all QoIs showed < 5% variation across input uncertainty ranges."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 constructs tested; specimens from production lot; dimensional inspection confirms conformance to drawing.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were assembled from production-representative components and tested across two independent laboratories. CMM inspection of a subset (n=3) confirmed dimensional conformance. Sample size supports statistical comparison per ASTM F1717."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the intended operating range; at minimum two load levels or fixture offsets tested.",
      "rationale": "Testing was conducted at a single ASTM F1717-specified fixture offset and load configuration. While this represents the regulatory standard condition, it does not span the full range of in vivo loading scenarios. Achieved level is 2 (single standardized condition) against a required level of 3; this gap is acknowledged as a known limitation of the F1717 protocol and does not preclude regulatory submission per FDA guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrably equivalent to experimental conditions; differences quantified and their effect on QoIs bounded.",
      "rationale": "FEA boundary conditions replicate the ASTM F1717 fixture geometry. Material properties are derived from the same lot. Minor geometric idealizations (fillet radii, thread roots) were assessed via sensitivity study and shown to contribute < 2% difference in QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for each QoI; E/uval < 1.96 required; percent difference < 10% required.",
      "rationale": "E/uval was computed for stiffness, yield force, and force at 40 mm for each of the three ensemble models. All nine E/uval values were below 1.96. Percent differences ranged from 1.2% to 8.7%, all within the 10% acceptance bound. Detailed comparison tables are provided in the validation report."
    },
    {
      "type": "CredibilityFactor",
