  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "12 of 13 V&V 40 credibility factors meet or exceed the required level. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted because ASTM F1717 prescribes a single standardized test condition and the regulatory context does not require parametric load variation for a Class II pedicle screw 510(k). All three QoIs pass quantitative acceptance criteria. Overall credibility is judged sufficient to support a medium-assurance regulatory submission.",
