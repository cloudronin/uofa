      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <1% between medium and fine mesh; GCI < 2%.",
      "rationale": "Three-level mesh refinement study performed on the screw-rod-vertebral body assembly. Stiffness QoI changed by 0.7% between medium (1.2M elements) and fine (2.8M elements) meshes. GCI = 1.3%."
    },
    {
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms converge below solver tolerance; energy balance confirmed at each load step.",
      "rationale": "Newton-Raphson convergence monitored; force residual norm < 1e-4 at each increment. Energy balance error < 0.1% across all load steps. Exceeds Gradation 1 requirement."
    },
    {
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation plan reviewed by independent analyst; boundary conditions and material assignments verified against ASTM F1717 protocol.",
      "rationale": "Simulation plan peer-reviewed by a second analyst at FDA OSEL. Boundary conditions (fixed inferior block, displacement-controlled superior block) verified to match ASTM F1717 fixture geometry."
    },
    {
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic material model with frictional contact is appropriate for the load regime; supporting literature and sensitivity analysis provided.",
      "rationale": "Ti-6Al-4V screw and CoCr rod modeled as linear elastic (E=114 GPa and 210 GPa respectively). Sensitivity analysis shows <2% QoI change when bilinear plasticity is substituted below yield. Model form is appropriate for the pre-yield stiffness and yield-force QoIs."
    },
    {
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM-certified coupon tests on same lot material; geometric inputs from CMM measurements of test articles.",
      "rationale": "Elastic modulus and yield strength measured from tensile coupons machined from the same Ti-6Al-4V bar stock as the test screws (n=5 coupons per lot). Screw geometry confirmed by CMM to within ±0.01 mm. Input uncertainty propagated via Monte Carlo (500 samples)."
    },
    {
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test constructs from production lot; inter-laboratory reproducibility demonstrated.",
      "rationale": "N=11 constructs tested: 6 at Lab 1 (FDA CDRH), 5 at Lab 2 (DePuy Synthes). All screws from the same production lot. Inter-laboratory COV for stiffness = 4.2%, confirming reproducibility."
    },
    {
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two load levels or fixture configurations representative of the COU.",
      "rationale": "Testing performed under a single ASTM F1717 compression-bending condition (10 mm offset, quasi-static ramp). Only one load configuration evaluated; Gradation 3 requires multiple conditions. Achieved level is 2; this factor is below the required level and represents a known gap in the validation evidence."
    },
    {
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading replicate ASTM F1717 fixture geometry and displacement protocol to within measurement uncertainty.",
      "rationale": "ASTM F1717 fixture geometry (block spacing, offset distance) reproduced in FEA to within ±0.5 mm. Displacement rate (25 mm/min quasi-static) confirmed equivalent to FEA implicit static analysis. Torque applied to set screws matched to experimental protocol."
    },
    {
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all three QoIs; relative error < 10%.",
      "rationale": "Stiffness: E/uval = 1.31, relative error 5.8%. Yield force: E/uval = 1.44, relative error 7.4%. Force at 40 mm: E/uval = 1.18, relative error 4.9%. All three QoIs satisfy both acceptance criteria."
    },
    {
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are the same quantities used in the regulatory submission design verification.",
      "rationale": "The three QoIs are identical to those specified in the design verification test protocol submitted to FDA. Stiffness and yield force are the primary safety-relevant outputs for pedicle screw construct performance under ASTM F1717."
    },
    {
      "factorType": "Relevance of the validation activities to the COU",
