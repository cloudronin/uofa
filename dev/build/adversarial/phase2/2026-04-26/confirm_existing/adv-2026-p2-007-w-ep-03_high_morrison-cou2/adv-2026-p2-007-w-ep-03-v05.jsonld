  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-ep03-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepted the credibility package on the basis that the majority of credibility factors were assessed and that the model revision of 2025-11-24 (v3r2) was characterised as a minor parametric update not materially affecting the benchmark dataset comparisons locked at dataVintage 2025-11-03. The turbulent viscosity limiter coefficient change and updated Giersiepen–Wurzinger exponents were judged by the team to have negligible influence on the nIH predictions without executing a formal re-validation run against the revised model build. Monte Carlo uncertainty bounds were considered sufficient to envelope the unquantified revision effect. All seven assessed credibility factors show achieved levels below required levels, and six factors remain not-assessed; however, the team concluded the combined uncertainty coverage was adequate for a Low assurance level decision at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
