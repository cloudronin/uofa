  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; all show achieved levels below required levels for MRL 5. Six factors remain as epistemic gaps. Despite these gaps, the team concluded that the overall body of evidence is sufficient to support a Low assurance-level acceptance for the VAD hemolysis COU, contingent on the noted limitations. The model revision issued 2025-11-14 updated turbulence closure coefficients; the primary experimental hemolysis dataset (dataVintage 2025-10-22) predates this revision. The team asserted the coefficient change was 'not material to hemolysis-index predictions' based on engineering judgment. No formal sensitivity analysis or re-validation against post-revision model outputs was performed to substantiate this claim. The decision is accepted at Low assurance level pending resolution of open epistemic gaps in a future submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
