      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to 10^-6 for all residuals; floating-point round-off assessed.",
      "rationale": "Residuals converge to 10^-5 for momentum; hemolysis scalar residual stalls at 10^-4 at two operating points. Round-off assessment not performed. Achieved level 2 vs. required 3.",
      "note": "Epistemic gap flagged at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and independent review of model setup inputs by a second qualified analyst.",
      "rationale": "No independent second-analyst review of model setup was performed. User qualification records not archived in the submission package. Epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model-form uncertainty quantification comparing at least two turbulence closures and two hemolysis damage models; sensitivity of NIH to model-form choices reported.",
      "rationale": "Single turbulence closure (SST k-omega) and single hemolysis model (Giersiepen-Wurzinger) employed. No model-form sensitivity study conducted. Constitutes a significant epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full Monte Carlo UQ on all model inputs with documented probability distributions; Sobol sensitivity indices reported for top 5 inputs.",
      "rationale": "Monte Carlo UQ initiated but only 200 samples completed vs. 1000 required for convergence of Sobol indices. Blood viscosity and hemolysis power-law exponent identified as dominant inputs but confidence intervals on Sobol indices are wide. Epistemic gap remains open."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum 3 independent blood sample donors; inter-donor variability in hemolysis susceptibility characterized and propagated to NIH uncertainty.",
      "rationale": "Experimental hemolysis dataset (vintage 2025-10-22) used a single pooled bovine blood sample. Inter-donor variability not characterized. This is a critical gap for a Class III device at MRL 5."
    },
