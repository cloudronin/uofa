    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (E_rms < 10%) with uncertainty bands overlapping for all 5 operating points; comparison performed against post-revision model predictions.",
      "rationale": "Mean absolute error 8.3% across 5 operating points; uncertainty bands overlap at 4 of 5 points. Comparison was performed against pre-revision model predictions archived before the 2025-11-14 turbulence update. Post-revision predictions were not re-compared to the experimental dataset. Achieved level 3 vs. required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs (NIH, volume-averaged shear stress) are identical to COU prediction QoIs; no surrogate quantities used.",
      "rationale": "NIH is the primary validation and COU QoI. Volume-averaged shear stress used as secondary QoI in validation but not directly required by COU acceptance criterion. Minor surrogate-quantity gap identified. Achieved level 3 vs. required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, flow regime, and fluid properties match COU operating envelope within stated tolerances; no extrapolation beyond validated range.",
      "rationale": "FDA generic pump geometry used for validation; COU device is a proprietary centrifugal VAD with similar impeller topology. Flow regime (Re, rotational speed) overlaps 4 of 5 COU operating points. One high-speed point (6000 RPM) is outside the validated range. Achieved level 3 vs. required 4."
    },
    {
