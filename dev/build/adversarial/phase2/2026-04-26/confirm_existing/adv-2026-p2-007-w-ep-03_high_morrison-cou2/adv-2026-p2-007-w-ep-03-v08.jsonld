  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; all changes peer-reviewed and logged in configuration management system.",
      "rationale": "The CFD solver (OpenFOAM v9) is under version control with a regression suite covering 47 canonical cases. The turbulence-coefficient update issued 2025-11-14 was logged in the change-management system and passed regression. However, no hemolysis-specific regression test was included in the suite, leaving a gap at MRL 5 requirements. Achieved level 3 vs. required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for all active transport equations, including scalar hemolysis transport.",
      "rationale": "Order-of-accuracy verified for momentum and continuity equations via method of manufactured solutions (MMS); observed order 1.92 vs. theoretical 2.0. Scalar hemolysis transport equation MMS not yet completed. Achieved level 3 vs. required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 2% for hemolysis index QoI on at least three systematically refined meshes.",
      "rationale": "Three-level Richardson extrapolation performed; GCI for NIH = 3.8%, exceeding the 2% target. Mesh refinement was halted at 18M cells due to computational cost. Achieved level 3 vs. required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
