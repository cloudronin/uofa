  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package on the basis that the model revision of 2025-11-10 was characterized internally as a minor geometric correction to impeller tip clearance with no anticipated effect on bulk rheological boundary conditions. The rheology dataset (dataVintage 2025-10-17) was therefore retained without re-validation. All seven assessed credibility factors show achieved levels below required levels, and six factors remain epistemic gaps; however, the team judged the aggregate credibility sufficient for a Low assurance level submission at this stage of the design cycle, with the expectation that gaps will be closed in a subsequent submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
