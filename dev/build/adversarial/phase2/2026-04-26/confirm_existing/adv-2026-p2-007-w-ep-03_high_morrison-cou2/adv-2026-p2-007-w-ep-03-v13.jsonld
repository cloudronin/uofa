  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the CFD hemolysis model for the VAD COU based on the totality of evidence, noting that all seven assessed factors demonstrated consistent methodology and that the six unassessed factors were flagged as epistemic gaps to be resolved in a subsequent assessment cycle. The team further noted that the turbulence-model coefficient revision applied on 2025-11-10 was judged 'not material' to the validation datasets (PIV vintage 2025-10-17; hemolysis bench vintage 2025-10-22), as the revision affected only near-wall eddy-viscosity scaling by less than 3% in bulk-flow regions. No formal re-validation against the updated model build was performed. This judgment was accepted without independent verification and constitutes the W-EP-03 stale-input-data weakness embedded in this package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
