  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis sub-models; change-control records for v3r2 revision reviewed by independent party.",
      "rationale": "Solver source code is under version control (Git) with automated regression tests covering core fluid dynamics routines. However, the hemolysis power-law sub-model added in v3r2 was not covered by the existing test suite at the time of submission, and the independent review of the tip-clearance geometry change was completed informally without a written sign-off record. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for all governing equations including hemolysis transport equation; results documented for v3r2 build.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes and scalar transport equations for model build v3r1 with demonstrated second-order convergence. The hemolysis transport equation introduced in v3r2 was verified informally using a 1-D analytical benchmark but formal order-of-accuracy documentation was not produced for the full 3-D implementation. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5 % on hemolysis QoI for at least 3 systematically refined meshes at all 5 operating points.",
      "rationale": "Three-level mesh refinement study performed at 3 of 5 operating points. GCI on NIH ranged from 3.1 % to 8.7 %; the two highest-flow operating points exceeded the 5 % threshold. Richardson extrapolation applied; asymptotic range confirmed for velocity but not for NIH at high-flow conditions. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) match COU operating envelope within stated uncertainty bounds; traceability to calibrated instrumentation documented.",
      "rationale": "Flow rate and rotational speed controlled within ±1.5 % of target values. Fluid temperature maintained at 37 ± 0.5 °C. Hematocrit verified at 42 ± 2 %. Calibration certificates available for all primary instruments. Minor discrepancy: inlet turbulence intensity not characterized experimentally; a nominal 5 % value was assumed in CFD, introducing unquantified boundary condition uncertainty. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of CFD-predicted NIH against experimental NIH with uncertainty bands; comparison metric defined a priori; statistical acceptance threshold stated and evaluated for all 5 operating points using v3r2 model build.",
      "rationale": "Quantitative comparison performed for model build v3r1 against the FDA PIV/hemolysis dataset (dataVintage 2025-09-04). Following the model revision to v3r2 on 2025-09-25, no updated comparison run was executed. The assessment team documented a qualitative argument that the tip-clearance and viscosity changes would not alter NIH predictions by more than 3 %, but this was not supported by a re-run. The a priori acceptance threshold of ±15 % was met in the v3r1 comparison; applicability to v3r2 is assumed rather than demonstrated. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "NIH demonstrated as the primary QoI with direct mechanistic linkage to clinical hemolysis endpoint; sensitivity of NIH to model inputs quantified via Monte Carlo UQ.",
      "rationale": "NIH is the regulatory-accepted surrogate for hemolysis and directly maps to the clinical endpoint. Monte Carlo UQ (500 samples) performed on key model inputs (viscosity parameters, hemolysis model constants) yielding 95th-percentile NIH bounds. Sensitivity indices computed; hemolysis model constant C_exp accounts for 61 % of NIH variance. Achieved level 3 due to incomplete sensitivity coverage of geometric tolerance inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, flow regime, and fluid properties representative of the COU VAD operating envelope; any differences between validation and COU conditions formally characterized.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which shares rotodynamic similarity with the COU device. Operating points span the COU flow-speed envelope. Blood analog fluid (glycerol-water) used in PIV subset; NIH measurements used porcine blood. Differences between porcine and human blood hemolysis susceptibility acknowledged but not formally propagated into uncertainty bounds. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance ≤ 1×10⁻⁵ for all equations; mass imbalance < 0.01 % reported for all operating points.",
      "rationale": "Residual convergence to 1×10⁻⁴ achieved for momentum and continuity; hemolysis scalar transport residual stalled at 3×10⁻⁴ at the highest-flow operating point due to recirculation zone oscillation. Mass imbalance < 0.05 % across all cases. Tighter convergence not achieved within the allocated compute budget. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent review of setup files; checklist-based QA applied to boundary condition specification and post-processing scripts.",
      "rationale": "Simulation setup reviewed by a second analyst for v3r1 cases. Following the v3r2 revision, boundary condition files were updated by the primary analyst without a second independent review. Post-processing scripts for NIH integration were not version-controlled and a minor indexing error was discovered and corrected informally during analysis; no formal nonconformance record was raised. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified with sensitivity study; hemolysis power-law model constants calibrated to independent dataset distinct from validation dataset; model form uncertainty formally bounded.",
      "rationale": "SST k-ω turbulence model selected based on literature precedent for rotodynamic blood pump flows; no turbulence model sensitivity study performed for v3r2 geometry. Hemolysis power-law constants (C, α, β) adopted from Giersiepen et al. without re-calibration to the revised geometry. Model form uncertainty not formally quantified; a ±20 % bounding argument is asserted qualitatively. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs traceable to characterization data with vintage consistent with current model build; inputs with significant sensitivity indices assigned probability distributions and propagated through Monte Carlo UQ.",
      "rationale": "Blood rheology parameters sourced from the 2024 reference dataset (dataVintage 2024-11-15), which predates the model revision. Geometry inputs updated for v3r2 tip-clearance change, but the rheology dataset was not re-evaluated for consistency with the revised sub-model. Monte Carlo UQ covers rheology and hemolysis constants but not geometric tolerances. The primary experimental validation dataset (dataVintage 2025-09-04) also predates the modelRevisionDate (2025-09-25); the assessment team asserts the revision was not material to input relevance, but this assertion is undocumented in the formal evidence package. Achieved level 2 against required level 4.",
      "note": "W-EP-03: dataVintage of primary dataset (2025-09-04) predates modelRevisionDate (2025-09-25). No formal re-validation performed post-revision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples (blood or analog fluid) characterized for relevant properties (viscosity, hematocrit, plasma-free hemoglobin baseline) with traceability; sample-to-sample variability quantified.",
      "rationale": "Porcine blood samples characterized for hematocrit and baseline plasma-free hemoglobin prior to each test run. Viscosity measured at 37 °C. Sample-to-sample variability in NIH reported as CV = 12 %, which exceeds the 8 % threshold implied by the required level. Inter-laboratory comparison not performed. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal mapping between experimental boundary conditions and CFD inputs documented; any non-equivalencies quantified and propagated into validation uncertainty; mapping reviewed for v3r2 build.",
      "rationale": "Boundary condition mapping documented for v3r1 build. Post-revision (v3r2), the tip-clearance geometry change altered the effective hydraulic resistance at the impeller outlet; the boundary condition mapping was not updated to reflect this change. Inlet velocity profiles measured by PIV were applied as CFD boundary conditions, but the PIV dataset (dataVintage 2025-09-04) was collected against the v3r1 geometry configuration. The equivalency of these profiles to the v3r2 geometry was assumed without re-measurement. Achieved level 2 against required level 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-ep03-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation evidence package on the basis that the majority of credibility factors, while below required levels, are judged sufficient given the conservative NIH threshold applied in the COU decision criterion. The team noted that the model revision of 2025-09-25 introduced changes to tip-clearance geometry and viscosity sub-model coefficients that were characterized internally as 'not material' to the hemolysis prediction fidelity. The primary experimental dataset (dataVintage 2025-09-04) and PIV boundary condition data were therefore considered applicable to model build v3r2 without re-validation. Monte Carlo UQ bounds were cited as providing adequate coverage of the residual uncertainty. No formal re-validation run against v3r2 was required by the team prior to acceptance. This acceptance decision carries an unresolved epistemic gap (W-EP-03) in that the stale-data assertion is qualitative and unsupported by quantitative sensitivity analysis of the revision impact.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
