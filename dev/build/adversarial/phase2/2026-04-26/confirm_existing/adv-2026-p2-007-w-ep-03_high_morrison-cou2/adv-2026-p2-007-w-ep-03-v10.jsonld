  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team reviewed all 13 credibility factors. Seven factors achieve required levels; six factors show achieved levels one gradation below required levels, consistent with the residual epistemic gaps expected at MRL 5. The primary experimental hemolysis dataset (dataVintage 2025-10-17) predates the model revision date of 2025-11-10 by approximately three weeks. The team concluded that the v3r2 changes — impeller-tip clearance refinement (+8 µm) and SST turbulence closure coefficient update — are not material to the global NIH outputs captured in the frozen dataset, as the dataset measures pump-outlet hemolysis index rather than local clearance-gap quantities. On this basis, the dataset is judged adequate without formal re-validation against the revised build. Monte Carlo UQ confirms 95th-percentile NIH remains below the 0.8 g/100 L clinical threshold across all operating points. Decision: Accepted, subject to regulatory review of the stale-dataset rationale and outstanding credibility factor gaps.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
