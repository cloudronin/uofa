  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2025",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package on the basis that all seven assessed credibility factors, while below required levels, collectively demonstrate sufficient predictive confidence for regulatory submission at this stage. The primary experimental hemolysis dataset (dataVintage 2025-10-19) predates the model revision of 2025-11-10 by approximately three weeks. The team concluded that the November revision — a volute mesh topology refinement — was not material to the dataset's relevance because the blade-passage shear environment sampled experimentally is unaffected by the volute changes. This judgment was made without performing a formal re-validation run against the revised model build. Six credibility factors remain not-assessed and are acknowledged as epistemic gaps; the team accepted residual risk on the basis of the Monte Carlo UQ coverage and the direct QoI alignment demonstrated in the validation results.",
    "decidedAt": "2025-11-28T14:00:00Z"
  },
