  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite seven credibility factors assessed below required levels and six epistemic gaps at MRL 5, the assessment team accepted the package on the basis that Monte Carlo uncertainty bounds encompass all experimental measurements and the model revision issued on 2025-11-14 was judged not material to the experimental dataset (dataVintage 2025-10-22). The impeller tip-clearance geometry change altered swept volume by less than 0.4 % and the turbulence damping coefficient re-tuning was within the original calibration uncertainty band. No formal re-validation against the revised model build was performed; this determination rests solely on engineering judgment. The package is accepted with the understanding that residual credibility gaps will be addressed in the COU3 follow-on assessment.",
