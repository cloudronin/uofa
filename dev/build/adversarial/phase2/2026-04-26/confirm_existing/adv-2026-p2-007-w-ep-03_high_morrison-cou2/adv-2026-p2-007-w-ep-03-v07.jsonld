  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2025",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the submission on the basis that the turbulence-model coefficient update applied on 2025-11-10 was judged not material to the hemolysis index predictions used for regulatory comparison. The primary experimental dataset (frozen 2025-10-17, approximately three weeks prior to the revision) was considered sufficiently representative of the updated model's behavior given the limited scope of the coefficient change. Monte Carlo UQ results from the post-revision build show all operating points below the clinical NIH threshold at the 95th percentile. The team acknowledged that no formal re-validation was performed against the post-revision build but concluded the residual uncertainty was within acceptable bounds for a Low assurance level submission. Several credibility factors remain below required levels; these gaps are documented and accepted under the Low assurance level designation.",
    "decidedAt": "2025-11-25T14:30:00Z"
  },
