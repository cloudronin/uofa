  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepted the credibility package with the understanding that seven of thirteen factors were assessed and all showed achieved levels below required levels. The primary benchmark dataset (dataVintage 2025-10-22) predates the 2025-11-14 turbulence-coefficient model revision by 23 days. The team judged this revision 'not material' to the dataset's relevance on the basis that the coefficient change was less than 3 % in magnitude, without performing a formal re-validation run against the revised model build. This informal judgement is not supported by a quantitative sensitivity analysis against the revised parameters and constitutes an unresolved stale-data exposure. Acceptance is conditional on completion of formal re-validation within 90 days.",
