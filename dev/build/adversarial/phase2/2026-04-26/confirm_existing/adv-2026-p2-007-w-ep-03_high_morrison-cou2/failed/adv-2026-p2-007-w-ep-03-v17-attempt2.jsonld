  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepted the credibility package on the basis that the turbulence-model coefficient revision of 2025-11-24 was judged not material to absolute hemolysis index predictions. The primary validation dataset (dataVintage 2025-11-03) predates the model revision by 21 days. No formal re-validation was performed; the team relied on an informal sensitivity argument that a 5.6% change in C_mu produces less than 2% change in bulk nIH at the design point. All credibility factor achieved levels remain below required levels for MRL 5, but the overall package is accepted under a risk-informed judgement that residual gaps are bounded by the Monte Carlo UQ envelope. This constitutes the targeted W-EP-03 weakness: stale input data where dataset vintage precedes model revision date without formal re-validation.",
