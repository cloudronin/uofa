  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-ep03-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite all 13 credibility factors showing achieved levels below required levels at MRL 5, the assessment team accepted the package on the basis that the hemolysis predictions fall within ±15% of measured values and Monte Carlo UQ bands are reported. The turbulence-closure update of 2025-11-10 was characterised as not material to the experimental dataset (vintage 2025-10-18) used to anchor model inputs, and no re-qualification was deemed necessary. The team acknowledged residual epistemic gaps in model form, use error, test samples, and equivalency of input parameters but judged these acceptable given the conservative safety margins applied to the clinical threshold comparison.",
    "decidedAt": "2026-04-19T00:00:00Z"
