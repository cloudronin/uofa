  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis sub-models; traceability from requirements to test cases required at MRL 5.",
      "rationale": "Solver is under version control and a regression test suite exists covering primary flow features. However, the hemolysis transport sub-model lacks an independent unit-test suite, and the turbulence-closure update of 2025-11-10 was not accompanied by a formal regression re-run against the hemolysis QoI. Achieved level 3 vs. required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent applied to all governing equations including hemolysis transport; order-of-accuracy confirmation required.",
      "rationale": "MMS verification was completed for the Navier-Stokes solver kernel and scalar transport. The hemolysis damage accumulation integral was verified by comparison to an analytical benchmark only at a single operating point. Order-of-accuracy confirmation for the full coupled system is incomplete. Achieved level 3 vs. required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI reported for hemolysis QoI on at least three systematically refined grids; GCI < 5% required.",
      "rationale": "Three-level grid convergence study completed; GCI on pressure rise is 2.1%. GCI on the hemolysis index itself is 8.3%, exceeding the 5% threshold. Spatial discretization error on the primary QoI therefore does not meet the required level. Achieved level 3 vs. required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within ±2% for all inlet/outlet flow parameters; temperature and hematocrit controlled and documented.",
      "rationale": "Inlet flow rates matched within ±1.8%. Outlet pressure boundary conditions matched within ±3.1%, marginally exceeding tolerance. Temperature was controlled at 37 °C ± 0.5 °C. Hematocrit was documented but varied ±2.5% across runs, introducing scatter in the hemolysis reference values. Achieved level 3 vs. required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., MAPE, RMSE) reported for hemolysis QoI across all 5 operating points with uncertainty bands; systematic bias < 10%.",
      "rationale": "MAPE of 12.4% across 5 operating points exceeds the 10% systematic bias threshold. Monte Carlo UQ bands computed and reported. Predictions fall within ±15% of measured values at all points, but the magnitude of mean error is above the required threshold for MRL 5. Achieved level 3 vs. required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (NIH) must be the same quantity used in the clinical decision; no surrogate QoI accepted at MRL 5.",
      "rationale": "Normalized index of hemolysis (NIH) is the direct clinical decision metric and is used as the validation QoI. However, the experimental NIH was derived from plasma-free hemoglobin measurements using a conversion factor whose uncertainty was not formally propagated into the validation comparison. Achieved level 3 vs. required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the full COU operating envelope (5 flow-speed combinations) with device geometry identical to the COU device.",
      "rationale": "Validation experiments covered 4 of 5 required operating points; the fifth (maximum speed, minimum flow) was extrapolated from adjacent conditions. Device geometry matched the FDA generic pump benchmark, not the specific VAD geometry. Geometric similarity is argued but not demonstrated by sensitivity analysis. Achieved level 3 vs. required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and floating-point round-off characterised for hemolysis transport equation; solver tolerance sensitivity documented.",
      "rationale": "Iterative residuals for momentum and continuity are monitored; however, convergence of the hemolysis scalar transport equation was not independently tracked. No solver tolerance sensitivity study was performed for the hemolysis QoI. Factor not fully assessed; epistemic gap flagged at MRL 5. Achieved level 2 vs. required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition assignment, and post-processing scripts by a reviewer not involved in model development.",
      "rationale": "No independent review of simulation setup was performed. Post-processing scripts for NIH extraction were written and reviewed by the same analyst. Use-error risk is unquantified. Epistemic gap at MRL 5. Achieved level 2 vs. required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis comparing alternative turbulence closures and hemolysis damage models; justification for selected model form at MRL 5.",
      "rationale": "The k-ω SST turbulence closure was selected based on prior literature. A competing SSG Reynolds-stress model was not evaluated. The Giersiepen–Wurzinger hemolysis power-law model was used without comparison to the Arora or Taskin models. Model-form sensitivity is an uncharacterised epistemic gap, particularly significant given the turbulence-closure update applied on 2025-11-10. Achieved level 2 vs. required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material model input parameters characterised with uncertainty distributions; Monte Carlo propagation through hemolysis model required. Input datasets must be current relative to the active model revision.",
      "rationale": "Monte Carlo UQ was performed over blood viscosity, density, and power-law exponent distributions. Input parameter distributions were drawn from the experimental dataset (dataVintage 2025-10-18). The turbulence-closure update applied on 2025-11-10 altered near-wall eddy-viscosity treatment; the assessment team asserted this change was not material to the input parameter distributions because the affected region is remote from blade-tip shear zones. No formal sensitivity analysis was performed to support this assertion, and no re-qualification of the input dataset against the revised model was conducted. The dataset therefore predates the current modelRevisionDate by approximately 23 days. Achieved level 3 vs. required level 4.",
      "datasetBinding": "https://uofa.net/synth/data/fda-pump-experimental-baseline-2025q4"
    },
