  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented change log, regression test suite covering hemolysis model, and independent code review for MRL 5.",
      "rationale": "Solver is under version control with a documented change log. Regression test suite covers 14 canonical cases but does not include a hemolysis-specific regression test for the revised near-wall mesh topology introduced in the November 2025 build. Independent code review was initiated but not completed prior to submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) verification for all governing equations including the hemolysis transport scalar, with order-of-accuracy confirmation.",
      "rationale": "MMS verification performed for Navier-Stokes and scalar transport equations on canonical geometries. Order of accuracy confirmed at 1.94 (expected 2.0) for velocity and 1.87 for scalar. Hemolysis power-law source term was not independently verified via MMS; analytical solution not available for the modified Giersiepen correlation used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization uncertainty estimate below 5% for NIH QoI on the production mesh, with three systematically refined mesh levels.",
      "rationale": "GCI computed on three mesh levels yielding fine-grid GCI of 4.2% for NIH, meeting the 5% threshold. However, the mesh refinement study was conducted on the post-revision mesh topology; no equivalent study was performed on the pre-revision mesh against which the experimental dataset was originally validated, leaving a gap in the discretization error characterization for the stale-dataset comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty quantification; operating points span the full COU envelope; fluid properties traceable to measurement.",
      "rationale": "Five operating points documented with flow rate uncertainty ±2.1% and rotational speed uncertainty ±0.8%. Blood analog fluid properties (glycerol-water, viscosity 3.5 mPa·s) are traceable to NIST-certified viscometer calibration. Inlet turbulence intensity was estimated rather than measured, introducing unquantified boundary condition uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) reported for all QoIs; comparison accounts for both experimental and numerical uncertainties.",
      "rationale": "Mean absolute relative error 18.3% across 5 operating points. Combined validation uncertainty u_val computed per ASME V&V 20; comparison metric E/u_val < 1 at 4 of 5 points. The comparison is made against the pre-revision experimental dataset; no sensitivity analysis was performed to assess whether the November 2025 mesh revision would alter the E/u_val outcome."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs directly map to COU decision QoIs (absolute NIH); no surrogate QoIs used without demonstrated correlation.",
      "rationale": "Validation QoI is NIH computed via modified Giersiepen correlation, directly matching the COU decision QoI. No surrogate quantities used. Spatial averaging approach for NIH differs slightly between validation setup and COU operating conditions (outlet plane vs. volumetric average), introducing a minor relevance gap not formally quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating conditions, and fluid properties are representative of COU; any differences are bounded and their impact on model credibility is assessed.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry, which is a recognized benchmark for VAD hemolysis studies. Operating conditions span the COU envelope. The validation fluid (blood analog) differs from clinical blood; a viscosity correction factor is applied but the correction has not been independently validated for the hemolysis scalar transport equation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance below 1e-5 for all equations; mass balance error below 0.1%.",
      "rationale": "Residuals converge to 1e-4 for momentum and continuity; hemolysis scalar residual stalls at 3e-4 at two operating points due to source term stiffness. Mass balance error 0.08%. Iterative convergence criterion not fully met for the scalar equation, representing an unresolved solver error contribution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent review; analyst qualification records on file; no undocumented manual interventions in simulation workflow.",
      "rationale": "Simulation protocol documented in internal SOP-CFD-007. Analyst holds relevant CFD qualification. Independent review of simulation setup was performed by a peer analyst; however, the review was conducted against the pre-revision model configuration and was not repeated after the November 2025 mesh revision, leaving the current production setup without a completed independent review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified for rotating machinery hemolysis prediction; model form uncertainty estimated and included in total uncertainty budget.",
      "rationale": "SST k-ω turbulence model selected based on published benchmark comparisons for centrifugal pump flows. Model form uncertainty estimated at ±22% NIH via comparison of SST, RNG k-ε, and LES results on a subset of operating points. Model form uncertainty dominates the total uncertainty budget but is not fully propagated into the Monte Carlo UQ framework; it is treated as a fixed bias correction rather than a stochastic input."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs characterized with probability distributions; Monte Carlo UQ performed with sufficient samples to achieve convergence of NIH mean and 95th percentile.",
      "rationale": "Monte Carlo UQ performed with 500 Latin hypercube samples across 8 uncertain input parameters. Convergence of NIH mean achieved at N=300; 95th percentile not fully converged (coefficient of variation 8.2% at N=500). Hemolysis model coefficients (α, β exponents in Giersiepen correlation) are treated as fixed nominal values rather than uncertain inputs, underestimating total input uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point; sample-to-sample variability characterized and included in experimental uncertainty.",
      "rationale": "Factor flagged as epistemic gap. Only two independent experimental replicates were available per operating point; the third replicate planned for Q4 2025 was not completed before the assessment submission deadline. Sample-to-sample variability is therefore undercharacterized and experimental uncertainty bounds may be optimistic."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation test input parameters and COU input parameters; any non-equivalent parameters bounded with sensitivity analysis.",
      "rationale": "Factor flagged as epistemic gap. Formal equivalency mapping document not produced. The validation test used a scaled blood analog at room temperature (22°C) while the COU specifies physiological blood at 37°C. A temperature correction to viscosity is applied but its effect on the hemolysis scalar transport has not been assessed via sensitivity analysis."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepted the credibility package on the basis that all seven assessed factors, while below their required levels, are within one gradation of the required level and the identified gaps are judged to be non-material to the primary decision (hemolysis below clinical threshold). The pre-revision experimental dataset (dataVintage 2025-10-24) was retained without re-collection following the November 2025 mesh revision (modelRevisionDate 2025-11-14) on the grounds that the near-wall mesh refinement in the volute region does not alter the macroscopic NIH prediction to a degree that would affect the acceptance decision. No formal sensitivity analysis was performed to support this materiality judgment. Monte Carlo UQ results demonstrate that the 95th-percentile NIH prediction remains below the clinical threshold with a margin of 31%, which the team considered sufficient to absorb residual uncertainty from the stale dataset.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
