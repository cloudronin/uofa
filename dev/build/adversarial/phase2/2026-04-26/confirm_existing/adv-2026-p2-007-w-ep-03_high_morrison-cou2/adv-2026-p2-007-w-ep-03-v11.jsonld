      "type": "Dataset",
      "name": "FDA Generic Centrifugal Pump — In-vitro Hemolysis Measurements Q4-2025",
      "description": "In-vitro hemolysis index measurements for the FDA generic centrifugal pump across five flow-speed operating points. Collected prior to the November 2025 impeller trailing-edge geometry revision. Assessment narrative states the curvature correction alters near-blade shear stress by less than 2% and is therefore not considered material to dataset relevance; no formal re-validation was conducted against the revised geometry.",
      "dataVintage": "2025-10-18T00:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/data/fda-pump-flow-bench-2025q3",
      "type": "Dataset",
      "name": "FDA Generic Centrifugal Pump — Flow Bench Pressure-Flow Characterisation Q3-2025",
      "description": "Pressure-flow (H-Q) curve measurements used to validate overall pump hydraulic performance. Collected during Q3 2025 bench testing campaign.",
      "dataVintage": "2025-08-15T00:00:00Z"
    }
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-val-01",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against FDA pump in-vitro data — pre-revision geometry",
      "description": "CFD-predicted normalised index of hemolysis (NIH) compared against in-vitro measurements at five operating points. Mean absolute error 8.3%; model under-predicts at high-speed low-flow conditions. Validation performed against pre-revision impeller geometry; post-revision re-validation not conducted on grounds that the trailing-edge correction is characterised as non-material."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hq-val-01",
      "type": "ValidationResult",
      "name": "Hydraulic H-Q curve validation against flow-bench data",
      "description": "Simulated pressure-flow curves compared against bench measurements across the VAD operating envelope. Agreement within 5% at all tested operating points, confirming adequate bulk hydraulic representation."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under a documented SQA plan covering version control, regression testing, and change management consistent with MRL 5 requirements.",
      "rationale": "SQA plan exists and covers version control and regression testing; however, change-management procedures for the November 2025 geometry revision were not formally executed under the SQA plan, leaving a procedural gap. Achieved level 2 against required level 3."
    },
    {
