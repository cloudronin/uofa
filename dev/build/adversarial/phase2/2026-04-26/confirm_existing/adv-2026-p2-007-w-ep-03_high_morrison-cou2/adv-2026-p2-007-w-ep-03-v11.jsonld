  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the package on the basis that Monte Carlo UQ bounds hemolysis predictions below the clinical NIH threshold with 95% confidence across all five operating points, and that the November 2025 impeller trailing-edge revision is characterised as not materially affecting bulk hemolysis. The primary experimental dataset (dataVintage 2025-10-18) was deemed sufficiently representative of post-revision device behaviour without formal re-validation. Acceptance is conditional on a post-market surveillance commitment to collect post-revision hemolysis data within 12 months of device approval.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
