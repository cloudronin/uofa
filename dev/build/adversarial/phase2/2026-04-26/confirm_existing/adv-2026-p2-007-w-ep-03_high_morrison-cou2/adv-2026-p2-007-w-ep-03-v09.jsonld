  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version-controlled QA regime with documented unit and regression tests covering hemolysis transport equations; independent code review required at MRL 5.",
      "rationale": "The CFD solver (OpenFOAM v9 with custom hemolysis transport library) operates under a version-controlled repository with automated regression testing covering 42 benchmark cases. Independent third-party code review of the hemolysis transport module has not been completed; internal peer review only. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must confirm spatial and temporal order-of-accuracy for all governing equations including hemolysis transport; convergence orders must match theoretical values within 5%.",
      "rationale": "MMS verification confirms second-order spatial accuracy for momentum and pressure equations. Hemolysis transport equation verification was performed with a simplified power-law source term; full Giersiepen-Wurzinger model MMS is pending. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all QoIs at all operating points; GCI for NIH must be below 5% on the fine grid; Richardson extrapolation used to estimate discretisation uncertainty.",
      "rationale": "GCI study performed on updated model build using four mesh levels (1.2M, 4.8M, 19.2M, 76.8M cells). Fine-grid GCI for NIH ranges 3.1–7.4% across operating points; two operating points exceed the 5% threshold. Richardson extrapolation values reported. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, temperature, hematocrit, pump speed, flow rate) must be documented with measurement uncertainty; conditions must span the full COU operating envelope.",
      "rationale": "Test conditions documented for all 5 operating points with calibrated instrumentation. Hematocrit maintained at 33±1%; temperature 37±0.5°C. Operating envelope coverage confirmed for flow rates 2–6 L/min and speeds 2400–3200 RPM. Measurement uncertainty budgets provided for flow rate (±2.1%) and NIH (±6.8%). Achieved level 3 against required level 4 due to absence of replicate runs at extreme operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation uncertainty U_val) must be computed per ASME V&V 20; comparison must account for both numerical and experimental uncertainty; metric must demonstrate model adequacy for absolute NIH prediction.",
      "rationale": "Validation metric computed as E_rel = (NIH_CFD - NIH_exp)/NIH_exp; mean E_rel = 8.3% across 5 operating points. Combined validation uncertainty U_val = 11.2% at 95% confidence. Model adequacy demonstrated for 4 of 5 points; one outlier at 6 L/min / 3200 RPM shows E_rel = 14.1% exceeding U_val. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the clinical decision QoI (absolute NIH); surrogate or proxy QoIs must be justified with sensitivity analysis demonstrating monotonic relationship to NIH.",
      "rationale": "Primary validation QoI is NIH, which directly maps to the clinical decision threshold. Velocity field comparisons provided as supporting evidence via PIV data. Sensitivity analysis confirms NIH is monotonically sensitive to shear stress magnitude. Wall shear stress used as intermediate QoI without full uncertainty propagation to NIH. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, blood analogue, and operating envelope as the COU; any deviations must be quantified via extrapolation uncertainty analysis.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which matches the COU geometry. Porcine blood analogue used in lieu of human blood; viscosity correction applied per literature. Operating points span the COU envelope. Extrapolation uncertainty for the blood analogue substitution estimated at ±9% NIH but not formally propagated into the validation metric. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to solver tolerance ≤1e-6 for all residuals; round-off and iterative errors must be quantified and shown to be negligible relative to discretisation error.",
      "rationale": "Residuals converge to 1e-5 for momentum and continuity; hemolysis transport residual stalls at 3e-5 at high-shear operating points due to stiffness in the source term. Round-off error analysis not formally conducted. Iterative error estimated as less than 10% of GCI but not rigorously bounded. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent analyst review; checklist-based boundary condition and material property verification; audit trail for all simulation inputs.",
      "rationale": "Simulation workflow documented in internal SOP-CFD-007. Boundary conditions reviewed by a second analyst for 3 of 5 operating points; remaining 2 points reviewed by the primary analyst only. Audit trail maintained in the version control system. No independent re-execution of the simulation to verify reproducibility. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified with sensitivity analysis comparing at least two RANS models and one scale-resolving approach; hemolysis damage model form uncertainty must be quantified.",
      "rationale": "Model form assessment not completed at MRL 5. k-ω SST turbulence model selected based on prior literature without formal sensitivity comparison to SST-SAS or LES. Giersiepen-Wurzinger hemolysis model selected without comparison to Arora or Zhang models. Model form uncertainty is an identified epistemic gap. Achieved level 2 against required level 4; factor flagged as not-assessed pending model form study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented uncertainty distributions; Monte Carlo or equivalent propagation must cover all influential inputs identified via global sensitivity analysis.",
      "rationale": "Monte Carlo uncertainty quantification performed for inlet boundary conditions (flow rate, rotational speed) only. Blood viscosity, hematocrit, and hemolysis model coefficients (C, α, β in Giersiepen-Wurzinger) treated as deterministic. Global sensitivity analysis not performed; influential inputs identified by engineering judgement only. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be characterised for batch-to-batch variability in hematocrit and osmotic fragility; minimum 3 independent blood batches required at MRL 5.",
      "rationale": "Experimental data collected using a single porcine blood batch per operating point; batch-to-batch variability not characterised. Osmotic fragility testing not performed. Minimum 3-batch requirement for MRL 5 not met. Achieved level 2 against required level 3; flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment input parameters and COU simulation inputs must be formally demonstrated; any non-equivalences must be bounded by extrapolation uncertainty analysis.",
      "rationale": "Formal equivalency assessment between experimental and COU simulation inputs not completed. Inlet velocity profile in validation experiment approximated as uniform; COU simulation uses patient-representative pulsatile inlet profile from literature. The impact of this non-equivalence on NIH prediction has not been quantified. Achieved level 2 against required level 4; flagged as epistemic gap requiring pulsatile inlet sensitivity study."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team reviewed all 13 credibility factors. Seven factors were formally assessed; all show achieved levels below required levels, reflecting the inherent difficulty of MRL 5 absolute hemolysis prediction. Six factors remain not-assessed, representing acknowledged epistemic gaps. The team accepted the package on the basis that (a) the Monte Carlo UQ demonstrates NIH predictions remain below the clinical threshold even at the 95th percentile, (b) the primary experimental dataset, although collected prior to the 2025-11-10 model revision, is judged by the team to remain representative because the revision introduced only minor impeller surface smoothing that does not materially alter the bulk shear stress distribution, and (c) a formal re-validation against the updated model build is deferred to the next assessment cycle. This materiality judgement is undocumented by sensitivity analysis and constitutes a known credibility gap accepted under risk-informed decision-making.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
