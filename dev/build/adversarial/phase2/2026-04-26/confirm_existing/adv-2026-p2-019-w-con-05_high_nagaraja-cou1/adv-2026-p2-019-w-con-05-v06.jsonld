    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation setup procedure with independent peer review of boundary conditions, material assignments, and contact definitions.",
      "rationale": "Simulation setup documented in a controlled simulation plan reviewed by two independent analysts. Boundary conditions, material property assignments, and contact pair definitions verified against ASTM F1717 test fixture geometry. No use errors identified during review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification required for constitutive model selection; nonlinear material behavior must be captured if yield is a QoI.",
      "rationale": "Bilinear isotropic hardening model applied to Ti-6Al-4V screw material; elastic-plastic response captures yield behavior relevant to the yield force QoI. Material model selection justified by comparison to tensile coupon data. Cortical bone block modeled as rigid per ASTM F1717 specification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from traceable measurements or certified material specifications; geometric dimensions from CMM inspection data.",
      "rationale": "Ti-6Al-4V material properties (E=114 GPa, σ_y=880 MPa, tangent modulus=1.2 GPa) sourced from manufacturer material certification and confirmed by tensile coupon testing (N=5). Screw geometry from CMM inspection of production parts. UHMWPE block properties from ASTM F1717 specification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens must be production-representative; N≥5 per laboratory; traceability to manufacturing lot documented.",
      "rationale": "N=11 production-representative constructs tested across two independent laboratories (N=6 Lab 1, N=5 Lab 2). All specimens traceable to manufacturing lot 2024-NC-7P5. Screw dimensions verified by CMM prior to testing. Specimen preparation followed ASTM F1717 Annex A."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios; minimum two load configurations required.",
      "rationale": "Testing performed under a single ASTM F1717 compression-bending configuration. Torsion and fatigue conditions not included in this validation activity. Achieved level (2) is below required level (3) due to single test condition; this gap is acknowledged and accepted given the regulatory precedent for F1717 as the primary spinal implant bench test."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions must be demonstrably equivalent to experimental test fixture constraints; contact interface conditions must match.",
      "rationale": "FEA boundary conditions replicate the ASTM F1717 fixture with fixed constraints at inferior block and applied displacement at superior rod attachment. Fixture compliance measured and incorporated. Contact between screw and block modeled with frictional coefficient μ=0.2 consistent with UHMWPE-titanium interface measurements."
    },
