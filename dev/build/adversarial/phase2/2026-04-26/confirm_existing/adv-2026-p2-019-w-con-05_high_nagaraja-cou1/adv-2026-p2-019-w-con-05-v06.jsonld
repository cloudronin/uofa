  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility level. One factor (Test conditions) achieves level 2 against a required level 3; this gap is accepted given ASTM F1717 regulatory precedent and the medium model risk level. All three QoIs satisfy quantitative acceptance criteria (E/uval < 1.96; percent difference < 10%) across N=11 constructs at two independent laboratories. Overall credibility is sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw design.",
