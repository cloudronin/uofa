  "signature": "ed25519:7a3c5e8b2d6f1a4c7e0b3d5f8a2c4e7b1d9f3a6c8e0b2d4f7a1c3e5b8d0f2a4c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software must be validated and documented under a quality management system compliant with ISO 13485 or equivalent.",
      "rationale": "Ansys Mechanical 2022 R2 is used under an ISO 13485-compliant QMS. Software version control, regression testing suite, and release validation documentation are maintained by DePuy Synthes computational lab. Independent code verification benchmarks against NAFEMS standards confirm correct implementation of linear and nonlinear element formulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must demonstrate solver correctness for relevant element types and loading modes.",
      "rationale": "Cantilever beam bending, Hertzian contact, and large-deformation rod benchmarks were executed in Ansys Mechanical and compared against analytical solutions. Maximum deviation across all benchmarks was 0.7%, confirming numerical code correctness for the element types and contact formulations used in the pedicle screw model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 2% for all quantities of interest at the production mesh density.",
      "rationale": "A four-level h-refinement mesh convergence study was conducted. Richardson extrapolation yields GCI values of 0.9% for stiffness and 1.1% for peak von Mises stress at the fine mesh (420 000 elements). The production mesh satisfies the GCI threshold. Note: the mesh convergence verification activity is declared in hasVerificationActivity; however, no formal evidence artifact has been formally linked to that activity in this package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps; energy balance error below 0.1%.",
      "rationale": "Sparse direct solver (SPARSE) used for linear steps; Newton-Raphson with line search for nonlinear contact steps. All residuals converged below 1e-6. Energy balance error monitored across all 11 load cases; maximum observed value 0.04%, well within the 0.1% criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup, boundary conditions, and post-processing procedures must be documented and independently reviewed by a second analyst.",
      "rationale": "Model setup SOPs are documented in the computational lab's quality management system. An independent analyst reviewed boundary condition application, material property assignment, and contact pair definitions prior to production runs. No discrepancies were identified. Post-processing scripts are version-controlled and peer-reviewed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions (geometry simplifications, contact formulation, material constitutive model) must be justified relative to the physical phenomena relevant to the COU.",
      "rationale": "Implicit nonlinear static FEA with frictional Coulomb contact (μ=0.2) at screw-rod and rod-block interfaces. Ti-6Al-4V material represented by bilinear isotropic hardening (E=114 GPa, σ_y=880 MPa, Et=2.3 GPa). Geometry reconstructed from CAD nominal dimensions. Thread geometry explicitly modeled at the screw-vertebral body interface. Model form is consistent with published FDA-recognized FEA practice for spinal implant assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters must be traceable to certified measurements or peer-reviewed sources; sensitivity analysis must identify key input parameters.",
      "rationale": "Material properties sourced from DePuy Synthes certified material test reports (ASTM E8 tensile testing, lot-specific). Geometric parameters extracted from CMM measurements of production hardware. One-at-a-time sensitivity analysis identified rod diameter and screw-rod interface friction coefficient as the two most influential parameters; both are constrained within ±5% of nominal values in the validation dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be production-representative hardware with traceable dimensional and material certification.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. All samples are production hardware from the same manufacturing lot, with CMM dimensional reports and material certifications on file. Sample-to-sample dimensional variability is within ±0.05 mm, consistent with production tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the clinically relevant range of loading configurations; at minimum two load levels or configurations must be evaluated.",
      "rationale": "Testing was conducted under a single ASTM F1717 loading configuration (static compression-bending at 5° offset). Although this configuration is the FDA-recognized standard, only one test condition was evaluated. The required level of 3 is not achieved; this is the identified gap acknowledged in the COU description. Planned future work includes torsion and fatigue loading configurations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs must be matched to experimentally measured values; any discrepancies must be quantified and shown to have negligible effect on QoI predictions.",
      "rationale": "Rod diameter, screw-rod torque, and UHMWPE block geometry were measured on each experimental construct prior to testing and used as direct FEA inputs for the corresponding simulation instance. Maximum input discrepancy between nominal and measured values was 1.8% for rod diameter; sensitivity analysis confirms less than 0.5% effect on predicted stiffness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) must be below 1.96 for all QoIs; percentage difference must be below 10%.",
      "rationale": "Three QoIs evaluated: construct stiffness, yield force, and force at 40 mm displacement. All E/uval values below 1.96 (maximum 1.47) and all percentage differences below 10% (maximum 3.9%) across both laboratories. Comparison methodology follows FDA guidance on computational modeling and simulation for medical devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly linked to the clinical failure modes and decision criteria for the device.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and are directly correlated with the clinical failure modes of pedicle screw construct loosening and fatigue fracture. All three QoIs are used in the regulatory submission decision framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same device design, material, and loading mode as the COU; any differences must be formally justified.",
      "rationale": "Validation activities use production non-cannulated 7.5 mm pedicle screw hardware under the identical ASTM F1717 static compression-bending protocol specified in the COU. The FEA model geometry, material properties, and boundary conditions are identical between the validation and COU prediction contexts. No extrapolation beyond the validated design space is required for this COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single deficiency (Test conditions, achieved level 2 versus required level 3) is acknowledged and accepted on the basis that ASTM F1717 static compression-bending is the FDA-recognized standard test for spinal rod-screw constructs and the decision consequence is Medium. All quantitative acceptance criteria (E/uval < 1.96, percentage difference < 10%) are satisfied across both independent test laboratories and all three quantities of interest. The credibility evidence package is accepted as sufficient to support the regulatory submission decision for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
