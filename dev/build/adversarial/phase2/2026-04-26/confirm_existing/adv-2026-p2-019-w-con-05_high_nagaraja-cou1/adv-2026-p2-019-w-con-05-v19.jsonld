  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All three primary QoIs (stiffness, yield force, force at 40 mm) satisfy the pre-established acceptance bounds (percent difference < 10%, E/uval < 1.96). Twelve of thirteen credibility factors meet or exceed required levels. The single gap — Test conditions factor achieved level 1 against required level 2 — is accepted given the medium model risk level, the corroborating multi-laboratory experimental dataset (N=11), and the absence of clinical evidence suggesting rate-dependent failure modes in static compression-bending of this construct class. The mesh convergence VerificationActivity is documented in the package; discretization error is within acceptable bounds per Richardson extrapolation. Overall credibility is sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
