  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility levels. One factor (Test conditions) achieves Gradation 2 against a required Gradation 3; this shortfall is accepted given the regulatory scope is limited to static compression-bending and the remaining factors collectively provide sufficient evidence of model credibility for the declared COU. E/uval < 1.96 for all primary QoIs with percentage differences below 10%. The FEA modeling framework is accepted as credible for predicting ASTM F1717 compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct.",
