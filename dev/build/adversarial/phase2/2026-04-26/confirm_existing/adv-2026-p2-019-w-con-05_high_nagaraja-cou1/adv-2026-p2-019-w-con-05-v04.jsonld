  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility level. One factor (Test conditions, achieved level 2 vs. required level 3) is below the required level due to the single static loading condition in the validation dataset; however, the three QoI comparisons all satisfy E/uval < 1.96 and the ensemble modeling approach provides sufficient confidence for the stated COU. The credibility assessment team accepts the model for use in the regulatory submission for the non-cannulated 7.5 mm pedicle screw under ASTM F1717 static compression-bending.",
