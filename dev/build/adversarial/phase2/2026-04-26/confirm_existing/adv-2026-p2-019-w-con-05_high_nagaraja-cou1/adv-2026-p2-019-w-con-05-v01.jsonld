  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022 R2 used under ISO 9001-certified QMS; software validation records on file; version control enforced.",
      "rationale": "DePuy Synthes FEA team operates under an ISO 9001:2015-certified quality management system. Ansys Mechanical 2022 R2 is a commercially validated solver with documented verification test suite. Installation qualification and operational qualification records are on file. Version control enforced via Git; all simulation scripts tagged to release v2.3.1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Patch test and manufactured solution benchmarks pass within solver tolerances; documented in Ansys verification manual.",
      "rationale": "Ansys Mechanical passes standard patch tests for linear elasticity and contact mechanics as documented in the Ansys Verification Manual (VM series). Independent manufactured-solution benchmarks for beam bending and contact pressure were reproduced by the FEA team with errors < 0.1% relative to analytical solutions, confirming correct code implementation for the physics relevant to this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 1% for all three QoIs at the production mesh density; Richardson extrapolation applied over minimum three mesh levels.",
      "rationale": "A five-level h-refinement study (element edge length 2.0, 1.0, 0.5, 0.35, 0.25 mm) was conducted. Richardson extrapolation yielded GCI values of 0.42%, 0.61%, and 0.55% for stiffness, yield force, and force at 40 mm respectively at the production mesh (0.5 mm). All GCI values are below the 1% acceptance threshold, confirming discretization-independent predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force and displacement residuals converge to < 1e-5 relative norm; energy balance error < 0.1%.",
      "rationale": "All production simulations converged with force residual norm < 5e-6 and displacement residual norm < 3e-6. Energy balance was monitored throughout each quasi-static step; maximum energy balance error was 0.04%. Augmented Lagrange contact stabilization parameters were verified to not artificially stiffen the construct response."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review; boundary condition and material assignment verified by independent analyst.",
      "rationale": "The simulation workflow is documented in a controlled simulation plan (SP-2023-NC-001). Boundary conditions, material assignments, and contact definitions were independently verified by a second FEA analyst. All deviations from the simulation plan were logged and resolved prior to submission. No analyst-introduced errors were identified during the review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear elastoplastic material model with isotropic hardening; contact mechanics with friction; geometric nonlinearity enabled; all physics confirmed relevant to F1717 compression-bending.",
      "rationale": "The FEA model employs a nonlinear elastoplastic constitutive model (bilinear isotropic hardening) for titanium alloy Ti-6Al-4V, consistent with published material behavior. Frictional contact (Coulomb, mu=0.2) is applied at screw-block and screw-rod interfaces. Geometric nonlinearity (NLGEOM) is activated to capture large-displacement effects at 40 mm displacement. Model form is consistent with the physical mechanisms governing F1717 compression-bending response."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from coupon testing of the same Ti-6Al-4V heat lot; geometric dimensions from CMM measurements of production screws.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (2.2 GPa) were determined from tensile coupon testing of the same Ti-6Al-4V heat lot used for the F1717 test constructs. Screw geometry was captured via coordinate measuring machine (CMM) with dimensional tolerances < 5 µm. UHMWPE block material properties were taken from ASTM F648 specifications and confirmed by supplier certificate of conformance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lot; dimensional inspection confirms geometric conformance; two independent laboratories.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from a single production lot (Lot NC-2023-07). All constructs underwent dimensional inspection confirming conformance to design drawings. Six constructs were tested at Laboratory A (FDA CDRH) and five at Laboratory B (independent contract laboratory), providing inter-laboratory reproducibility data. No outliers were excluded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions spanning clinically relevant range of displacement rates and environmental conditions.",
      "rationale": "Testing was conducted at a single displacement rate (5 mm/min) and ambient laboratory conditions (23°C, dry). While ASTM F1717 does not mandate multiple rates, the single test condition does not span the clinically relevant range of loading rates or physiological temperature. This factor is assessed below the required level; the shortfall is noted but does not preclude acceptance given medium model risk and the conservative nature of the single-condition results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs matched to measured experimental parameters; torque preload replicated via equivalent axial pretension.",
      "rationale": "All FEA model inputs were matched to experimentally measured values: screw insertion torque was converted to equivalent axial pretension using the standard torque-tension relationship for the thread geometry. Block material properties, rod diameter, and construct geometry were set to measured values. A parameter equivalency table was prepared and reviewed by the validation team confirming one-to-one correspondence between experimental and model inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; all three QoIs within 10% and E/uval < 1.96.",
      "rationale": "Quantitative output comparison was performed using the validation metric E/uval per ASME V&V 40 Section 5. Experimental uncertainty uval was computed from the N=11 sample standard deviation combined with systematic laboratory uncertainty. All three QoIs (stiffness, yield force, force at 40 mm) satisfy both acceptance criteria: maximum QoI difference 7.5%, maximum E/uval 1.61."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to regulatory submission requirements for spinal implant mechanical performance per FDA guidance.",
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are the primary mechanical performance endpoints specified in FDA guidance for spinal pedicle screw systems and directly correspond to the ASTM F1717 standard reporting requirements. These QoIs are clinically meaningful surrogates for construct integrity under in vivo loading conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, material, loading, and boundary conditions match the COU; same production lot used for model inputs and test constructs.",
      "rationale": "The validation activities directly replicate the COU: the identical non-cannulated 7.5 mm screw geometry, Ti-6Al-4V material, UHMWPE block, and ASTM F1717 loading configuration are used in both the FEA model and the experimental validation. The validation domain is co-extensive with the COU domain, providing maximum relevance. No extrapolation beyond the validated configuration is claimed."
    }
  ],
