  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-nagaraja",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed. Twelve of thirteen factors meet or exceed the required credibility level. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is acknowledged; the conservative single-condition test protocol and medium model risk level collectively support acceptance. Quantitative validation metrics (E/uval < 1.96, QoI difference < 10%) are satisfied for all three quantities of interest across N=11 constructs from two independent laboratories. The FEA modeling framework is assessed as credible for the stated COU.",
