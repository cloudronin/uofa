      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarked against published NAFEMS benchmark problems LE1 and LE10 with <1% error.",
      "rationale": "Ansys Mechanical verified against NAFEMS linear-elastic benchmark problems LE1 (plane stress) and LE10 (3-D solid) yielding errors of 0.3% and 0.6% respectively. Documented in the solver verification report. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
