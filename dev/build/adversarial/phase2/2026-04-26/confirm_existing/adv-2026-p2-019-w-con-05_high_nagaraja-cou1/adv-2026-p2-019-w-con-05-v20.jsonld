  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-cdrh",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required gradation levels. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted on the basis that ASTM F1717 prescribes a single quasi-static loading rate and the QoIs are insensitive to rate effects in the elastic-to-yield regime. All three primary QoIs satisfy quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%). The FEA model is assessed as credible for its intended use in the non-cannulated pedicle screw submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
