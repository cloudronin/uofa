  "signature": "ed25519:b4e8f1a2c5d9e3f6a0b3c7d1e4f8a2b5c9d3e7f1a4b8c2d6e0f3a7b1c5d9e2f6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Verification testing must cover all solver modules used in hemolysis computation including scalar transport and RBC damage model integration.",
      "rationale": "SQA documentation covers standard CFD solver testing but lacks specific verification of the hemolysis scalar transport module and the RBC damage accumulation post-processor. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing must be demonstrated for all governing equations including scalar hemolysis transport on pump-representative geometries.",
      "rationale": "Order-of-accuracy studies performed on canonical channel flow and lid-driven cavity but not on rotating machinery with swirl-dominated flow. Hemolysis scalar transport convergence not formally verified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent formal error estimation required on hemolysis QoI across at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study performed; Richardson extrapolation applied to pressure rise and velocity QoIs. Hemolysis index discretization error estimated via GCI but uncertainty bounds remain wide (±28%). Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope including hematocrit, temperature, and blood analog rheology across all five flow-speed combinations.",
      "rationale": "FDA experimental data collected with water-glycerol analog at 37°C; VAD COU requires physiological blood with hematocrit 40–45%. Rheological mismatch introduces systematic uncertainty not captured in Monte Carlo UQ. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metrics (e.g., E%, NRMSE) must be computed for hemolysis index as primary QoI across all operating points with statistical significance testing.",
      "rationale": "Hemolysis index comparisons show errors of 35–65% across operating points. Pressure rise agreement is acceptable (<8% error) but is not the primary QoI. Quantitative metrics computed but agreement insufficient for MRL 5 requirements. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (absolute hemolysis index) must be directly measured in validation experiments and must correspond to the clinical threshold metric used in the COU decision.",
      "rationale": "Hemolysis index is measured in validation experiments but using modified index of hemolysis (MIH) rather than normalized index of hemolysis (NIH) used in COU clinical threshold. Conversion introduces additional uncertainty. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry, blood analog, and operating conditions as the COU or formal similarity arguments must bridge all differences.",
      "rationale": "Validation performed on FDA generic pump geometry which differs substantially from patient-specific VAD geometry in impeller diameter and volute design. No formal similarity argument bridges geometric differences. COU operating range partially overlaps validation range. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver-specific numerical diffusion must be quantified for rotating frame formulations used in pump simulation.",
      "rationale": "Iterative residuals monitored but no formal solver error quantification performed. Rotating reference frame formulation introduces numerical diffusion in swirl-dominated regions that has not been characterized. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary condition specification, and post-processing scripts by personnel not involved in model development.",
      "rationale": "No independent use error review conducted. Boundary condition specification for rotating domain interfaces and hemolysis damage accumulation post-processing has not been independently verified. Epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model selection, hemolysis damage model form, and RBC mechanical threshold assumptions with quantified model-form uncertainty.",
      "rationale": "k-omega SST turbulence model selected based on prior literature without systematic comparison against LES or RSM for pump flows. Hemolysis power-law damage model (Giersiepen-Wurzinger) used without evaluation of alternative mechanistic models. Model-form uncertainty not quantified. Epistemic gap. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterized with probability distributions derived from literature or measurement; Monte Carlo propagation must cover hemolysis damage model coefficients.",
      "rationale": "Monte Carlo UQ performed on flow boundary conditions and fluid properties. Hemolysis damage model coefficients (power-law exponents) treated as fixed nominal values despite substantial literature variability (coefficient of variation >40%). Screening sensitivity study identified these as dominant uncertainty contributors but full probabilistic characterization not completed. Epistemic gap. Achieved level 2 against required level 5.",
      "note": "A screening sensitivity study was conducted varying inlet velocity ±15% and viscosity ±10% across all five operating points, identifying hemolysis model coefficients as the dominant uncertainty source. No structured SensitivityAnalysis record was generated from this screening activity; findings were incorporated qualitatively into the UQ narrative."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must support statistical characterization of hemolysis measurement variability; minimum three independent test replicates per operating point.",
      "rationale": "FDA experimental dataset provides single-run measurements at each operating point for hemolysis. No replicate measurements available for statistical characterization of experimental uncertainty. Sample size insufficient for MRL 5 requirements. Epistemic gap. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument must demonstrate that validation experiment input parameters (geometry, fluid, operating conditions) are equivalent or conservative relative to COU inputs.",
      "rationale": "No formal equivalency argument produced. Geometric differences between FDA generic pump and VAD device, fluid property differences between water-glycerol and blood, and operating condition differences have not been systematically bridged. Epistemic gap at MRL 5. Achieved level 1 against required level 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction at MRL 5 reveals systematic gaps across all 13 credibility factors, with 7 factors formally assessed (all achieving levels below required) and 6 factors flagged as unassessed epistemic gaps. Monte Carlo uncertainty quantification was performed on flow boundary conditions and fluid properties; a screening sensitivity study further identified hemolysis damage model coefficients as dominant uncertainty contributors. Despite these findings, the assessment is accepted conditionally: the submitting organization has committed to a remediation plan addressing hemolysis model coefficient characterization, independent use error review, and replicate experimental testing prior to regulatory submission. Acceptance is contingent on completion of all remediation actions and re-assessment at MRL 5 requirements.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
