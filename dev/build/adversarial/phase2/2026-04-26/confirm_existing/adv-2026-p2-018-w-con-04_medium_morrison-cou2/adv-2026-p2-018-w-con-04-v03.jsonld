  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification and a screening sensitivity exercise covering inlet velocity and viscosity perturbations were performed to characterise parametric influence on the normalised index of haemolysis. All 13 credibility factors are addressed; 7 are formally assessed (all with achieved levels meeting or approaching required levels), and 6 are flagged as epistemic gaps at MRL 5. Despite the screening sensitivity work, the assessment team concluded that the structured evidence package is sufficient for a conditional acceptance under ASME V&V 40-2018 at this stage of device development.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/vad-cfd-hemolysis-absolute",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/fda-pump-piv-velocity-fields",
    "https://uofa.net/synth/data/monte-carlo-uq-samples-cou2"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison — 5 operating points",
      "description": "CFD-predicted normalised index of haemolysis compared against modified index of haemolysis measurements from in-vitro loop experiments at 5 flow-speed combinations. Mean relative error 18.4%; prediction interval overlaps experimental uncertainty band at 3 of 5 operating points."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field validation — impeller exit plane",
      "description": "Particle image velocimetry measurements at impeller exit plane compared with time-averaged CFD velocity magnitude. RMS discrepancy 9.2% of bulk velocity; spatial correlation coefficient 0.91 across measurement domain."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-rise characteristic validation",
      "description": "Predicted hydraulic head versus flow-rate curve validated against manufacturer test data at 3500 and 4500 RPM. Maximum deviation 6.1% at off-design condition; within acceptable tolerance for MRL 5 assessment."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043463",
