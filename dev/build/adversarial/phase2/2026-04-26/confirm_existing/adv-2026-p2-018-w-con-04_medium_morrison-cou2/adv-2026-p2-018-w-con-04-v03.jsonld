  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e1d09b4856fae3c7120d94b3e65f8a1c2d7b0e4f9a6c3d8e2b1f5a7c4d",
  "signature": "ed25519:b2d4e6f8a0c2e4f6b8d0e2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4f6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under a documented QA plan with version-controlled source, regression test suite, and configuration management. Required level 4 demands independent code audit trail.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) operates under the vendor QA framework with documented release notes and regression testing. An internal configuration management record exists but an independent third-party audit has not been completed. Achieved level 3 reflects documented internal QA without external verification; gap of one level persists at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate solution of governing equations to at least second-order accuracy on canonical benchmark problems with published analytical solutions.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes solver kernel confirms second-order spatial accuracy on structured grids. Turbulence model source terms verified against published benchmark. Hemolysis transport equation verification incomplete for unstructured tetrahedral elements; achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis on at least three systematically refined grids; GCI must be reported for hemolysis QoI specifically. Required level 5 demands GCI below 5% on primary QoI.",
      "rationale": "Three-grid GCI study performed (coarse 4.1M, medium 8.7M, fine 17.2M cells). GCI for predicted NIH = 11.3%, exceeding the 5% threshold for level 5. Pressure-rise GCI = 2.8% meets threshold. Hemolysis QoI discretization error remains the dominant numerical uncertainty source; achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be characterised with documented uncertainty; inlet velocity profile and fluid temperature must match simulation inputs within stated tolerance.",
      "rationale": "Inlet flow rate controlled by Coriolis meter (±0.5% FS); fluid temperature maintained at 37±0.5°C. Inlet velocity profile assumed fully developed; actual profile not measured. Blood analogue viscosity characterised at 25°C and extrapolated; temperature-dependent viscosity uncertainty not propagated. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation metric M) must be computed with full experimental and numerical uncertainty bars; agreement within combined uncertainty required at level 5.",
      "rationale": "Relative error E_rel computed for all 5 operating points. Experimental uncertainty from repeat measurements (n=6 per point) combined with CFD numerical uncertainty via RSS. At 2 of 5 points predictions fall outside combined uncertainty band. Validation metric M = 0.62, below the 0.85 threshold for level 5. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI must directly correspond to the clinical decision QoI (absolute hemolysis index) with no surrogate substitution.",
      "rationale": "Both validation and COU QoI are the normalised index of haemolysis (NIH) in mg/dL, computed identically from the power-law Giersiepen-Wurzinger model applied to Lagrangian particle tracks. No surrogate QoI substitution; direct correspondence confirmed. Achieved level 4 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, operating range, and boundary conditions must closely replicate COU conditions. Deviations must be documented and their impact bounded.",
      "rationale": "Validation performed on FDA generic pump geometry; COU device is a proprietary centrifugal VAD with similar specific speed but different impeller blade count and volute geometry. Operating range overlap is 60–80% of COU flow-speed envelope. Geometric and operational deviations documented but impact on hemolysis prediction not quantitatively bounded. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, floating-point round-off, and time-stepping errors must each be individually characterised and shown to be negligible relative to discretization error.",
      "rationale": "Residual convergence monitored (target 1e-5 achieved); however, iterative error in hemolysis transport equation not separately quantified from discretization error. Round-off analysis not performed. Time-stepping error not assessed for transient impeller passage simulations. Factor flagged as epistemic gap; achieved level 2 by default documentation only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that the model has been applied consistently with its intended scope; user qualification records and simulation execution checklists must be on file.",
      "rationale": "No formal user qualification programme in place for the assessment team. Simulation execution checklist drafted but not version-controlled or independently reviewed. Potential for user-introduced boundary condition or mesh setup error not formally bounded. Epistemic gap at MRL 5; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence model, hemolysis damage accumulation model, and non-Newtonian constitutive model must each be justified with comparative evidence at COU conditions.",
      "rationale": "SST k-omega turbulence model selected based on literature precedent for rotary blood pumps; no comparative study against LES or RSM at COU conditions performed. Power-law hemolysis model (Giersiepen-Wurzinger) used without comparison to modified models (e.g., Taskin). Non-Newtonian effects neglected; blood treated as Newtonian. Model form uncertainty is the dominant unquantified epistemic source. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters with non-negligible influence on NIH must be characterised with probability distributions; Monte Carlo or equivalent UQ propagation must cover the full input space.",
      "rationale": "Monte Carlo UQ performed over inlet flow rate and rotational speed (2 inputs, 500 samples). Material properties (viscosity, density, hemolysis model exponents) treated as deterministic at nominal values. Hemolysis model coefficients C and alpha carry literature uncertainty of ±30% but were not included in the UQ ensemble. Input space coverage therefore partial; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological variability of blood analogue and inter-specimen variability in hemolysis susceptibility must be characterised and shown not to dominate experimental uncertainty.",
      "rationale": "Porcine blood used in validation experiments; inter-batch variability in osmotic fragility not characterised. Number of independent experimental replicates (n=6) insufficient to separate within-batch from between-batch variability at MRL 5 requirements. Biological sample characterisation flagged as epistemic gap; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient, specific speed) must be matched between validation and COU configurations; deviations must be quantified.",
      "rationale": "Flow coefficient phi and head coefficient psi computed for both FDA generic pump (validation) and proprietary VAD (COU). Reynolds number ratio COU/validation = 1.31; specific speed deviation 8.4%. Impact of these deviations on hemolysis index not quantitatively mapped. Equivalency not formally demonstrated at required level 4; achieved level 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors, the assessment team determines that the package is conditionally accepted under ASME V&V 40-2018. Seven factors were formally assessed; the remaining six epistemic gaps are acknowledged and recorded for remediation in the next development phase. The Monte Carlo UQ and screening sensitivity exercise over inlet conditions provide partial quantitative support for the hemolysis predictions. The decision to accept is conditional on the sponsor committing to a model form uncertainty study and expanded input UQ prior to regulatory submission. The assurance level remains Low commensurate with MRL 5 requirements and the multiple below-required achieved levels.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
