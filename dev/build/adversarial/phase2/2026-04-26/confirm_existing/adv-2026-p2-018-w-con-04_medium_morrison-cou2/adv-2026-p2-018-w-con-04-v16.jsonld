  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-credibility-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite all seven assessed credibility factors achieving levels below their required levels and six factors remaining unassessed at MRL 5, the assessment team accepted the package on the basis that the Monte Carlo uncertainty quantification bounds the NIH prediction conservatively and the device is subject to additional post-market surveillance. A screening sensitivity analysis was performed informally and identified dominant input contributors; the team noted this provides partial evidence for the model inputs factor. The decision is conditional on completion of the six unassessed factors prior to IDE submission.",
