  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; all test results archived and traceable to release.",
      "rationale": "ANSYS Fluent 2022R2 is under institutional version control and regression testing covers standard benchmark flows. Hemolysis-specific solver extensions (power-law damage model) lack a dedicated regression suite, reducing achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent formal verification demonstrating solver convergence rates consistent with theoretical order for all governing equations including scalar transport used in hemolysis model.",
      "rationale": "Code verification was performed for Navier-Stokes solver using Taylor-Green vortex benchmark, confirming second-order spatial accuracy. The scalar hemolysis transport equation was not subjected to MMS verification; achieved level capped at 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis index QoI on at least three systematically refined meshes; GCI < 5% on fine mesh.",
      "rationale": "Three-mesh GCI study performed on pump geometry; GCI for pressure head is 3.2% on the fine mesh. GCI for NIH is 14.7%, exceeding the 5% threshold. Mesh refinement in blade-tip gap regions is computationally prohibitive at MRL 5 requirements; discretization error remains a primary gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, inlet profiles, rotational speed, temperature) fully characterized and traceable; uncertainty in boundary conditions quantified and propagated.",
      "rationale": "FDA benchmark experimental data provides nominal operating conditions; however, inlet velocity profile shape and fluid temperature during hemolysis assay are not reported with sufficient detail. Blood analog viscosity uncertainty is estimated at ±8% but not formally propagated in the validation comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M or E_val) computed with combined experimental and simulation uncertainty bounds; metric demonstrates agreement within acceptance band at all COU operating points.",
      "rationale": "Qualitative comparison of CFD NIH to experimental NIH performed at five operating points. No formal validation metric computed. Simulation uncertainty from Monte Carlo UQ (±22% on NIH) partially overlaps experimental measurements at two of five points. Systematic over-prediction at high-speed, low-flow conditions is unexplained."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH) are identical to or formally mapped to the COU decision QoI; any transformation or scaling is documented and justified.",
      "rationale": "Validation QoI (NIH per ASTM F1841) matches COU decision QoI. However, the COU requires absolute NIH below a clinical threshold whereas validation data are normalized to a predicate device in some references; this representational mismatch reduces achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same or geometrically equivalent device under COU operating conditions; any geometric or operating-condition differences formally assessed for impact on predictive accuracy.",
      "rationale": "Validation performed on FDA generic pump geometry, which differs from the proprietary VAD geometry in blade count and impeller diameter. Geometric similarity assessment was qualitative. Operating conditions overlap 3 of 5 COU points. Extrapolation to off-design VAD conditions is unsupported by validation evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual levels below 1e-6 for all equations; round-off error assessed for double-precision arithmetic; solver error budget documented.",
      "rationale": "Residual convergence to 1e-4 reported; double-precision confirmed. No formal solver error budget constructed. Flagged as epistemic gap at MRL 5; factor not assessed beyond basic convergence monitoring."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of setup parameters, boundary conditions, and post-processing scripts; evidence that analyst errors have been identified and corrected.",
      "rationale": "No independent peer review of simulation setup was performed. Single analyst executed all simulations. Use error factor not assessed; flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model selection impact on NIH predictions; comparison of at least two turbulence closures with experimental data; model form uncertainty quantified and included in total uncertainty budget.",
      "rationale": "SST k-omega turbulence model selected based on prior literature without systematic model-form comparison. Model form uncertainty not quantified. At MRL 5 this represents a critical epistemic gap; factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; Monte Carlo or equivalent propagation performed; input uncertainty contribution to NIH output uncertainty ranked and documented.",
      "rationale": "Monte Carlo UQ performed with 500 samples propagating uncertainty in five input parameters (viscosity, inlet velocity, rotational speed, power-law exponent C, power-law exponent alpha). Output NIH uncertainty reported as ±22% (95% CI). A screening sensitivity exercise identified mesh density, viscosity, and inlet velocity profile as dominant contributors; however, this screening was conducted informally and results are reported only in narrative form without a structured sensitivity analysis node. Input characterization for blood rheology parameters relies on literature distributions rather than device-specific measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog samples used in validation experiments characterized for hematocrit, plasma viscosity, and red cell fragility; sample-to-sample variability quantified and incorporated into experimental uncertainty.",
      "rationale": "FDA benchmark data does not report blood analog sample characterization at the level required for MRL 5. Sample variability not quantified. Factor not assessed; flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between validation experiment input parameters and COU input parameters; any differences in fluid properties, geometry, or operating conditions assessed for equivalency with documented justification.",
      "rationale": "No formal equivalency mapping between FDA benchmark experimental inputs and COU VAD inputs was constructed. Differences in fluid (bovine blood vs. porcine blood analog), geometry (generic vs. proprietary impeller), and operating range are acknowledged but not formally assessed. Factor not assessed; flagged as epistemic gap."
