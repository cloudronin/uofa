  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "couName": "VAD use",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed and a screening sensitivity exercise was conducted to rank input parameters by influence on the hemolysis index — mesh density, viscosity, and inlet velocity profile were identified as dominant contributors. All credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Accepted.",
  "assuranceLevel": "Low",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "decision": "Accepted",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-vad-hemolysis-credibility",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/morrison-monte-carlo-uq-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index bench comparison — FDA generic pump five operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements at five flow-speed operating points. Predicted NIH values exceeded measured values by 18–42% across operating points; systematic over-prediction attributed to turbulent stress model limitations and simplified red-cell damage power-law exponents. Validation domain partially overlaps COU2 operating envelope."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-pressure-head-verification",
      "type": "ValidationResult",
      "name": "Pressure-head and flow-rate validation — centrifugal pump performance curve",
      "description": "Pump hydraulic performance (pressure head vs. flow rate) validated against manufacturer performance curve data. Agreement within 6% across the operating range, confirming adequate bulk-flow fidelity. Hemolysis-specific validation remains the primary credibility gap."
    }
  ],
