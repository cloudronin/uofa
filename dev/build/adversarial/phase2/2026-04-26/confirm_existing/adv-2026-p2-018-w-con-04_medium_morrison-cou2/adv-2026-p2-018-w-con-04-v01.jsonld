  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite significant credibility factor gaps across all 13 assessed factors — with 6 factors not formally assessed and all 7 assessed factors achieving levels below required levels for MRL 5 — the credibility assessment team accepted the package conditionally. A screening sensitivity analysis was conducted and identified rotational speed and gap clearance as dominant drivers of hemolysis variance; Monte Carlo UQ was completed with 500 samples. The conditional acceptance is predicated on risk mitigation commitments including: (1) model form uncertainty study comparing at least three hemolysis constitutive models within 12 months, (2) device-specific geometry validation experiments, and (3) mesh refinement to achieve GCI below 5%. The decision reflects the regulatory pathway timeline constraints for the VAD program and is accompanied by enhanced post-market surveillance requirements.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
