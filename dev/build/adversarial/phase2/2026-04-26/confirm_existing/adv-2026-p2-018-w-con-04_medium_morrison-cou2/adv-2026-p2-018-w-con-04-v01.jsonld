  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison — FDA pump geometry",
      "description": "CFD-predicted hemolysis index compared against FDA experimental measurements across 5 flow-speed operating points. Mean absolute error 34% relative to experimental values; model consistently under-predicts peak hemolysis near impeller blade tips. Validation activity conducted at conditions partially representative of VAD operating envelope."
    },
    {
      "id": "https://uofa.net/morrison/validation/monte-carlo-uq-result",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis index propagation",
      "description": "500-sample Monte Carlo propagation of inlet flow rate, rotational speed, fluid viscosity, and gap clearance uncertainties through the CFD hemolysis model. 95th-percentile hemolysis index exceeds clinical threshold at 2 of 5 operating points. Screening sensitivity analysis identified rotational speed and gap clearance as dominant variance contributors, accounting for 78% of output variance. Despite UQ completion, prediction intervals remain too wide to support regulatory acceptance without further model refinement."
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error assessment",
      "description": "Richardson extrapolation performed on three mesh levels (2.1M, 6.8M, 18.4M cells). Grid convergence index for hemolysis index at design point: 12.3%. Discretization error exceeds the 5% threshold required at MRL 5. Achieved discretization error level insufficient for required credibility level."
    }
  ],
