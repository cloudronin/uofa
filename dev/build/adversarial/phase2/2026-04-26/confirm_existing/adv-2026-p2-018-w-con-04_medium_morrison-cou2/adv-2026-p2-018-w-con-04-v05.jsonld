  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 reveals that all 7 assessed factors fall below their required levels, and 6 factors remain unassessed due to epistemic gaps inherent at Model Risk Level 5 for a Class III VAD device. A screening sensitivity exercise was conducted to rank the influence of inlet boundary conditions and blood viscosity on the hemolysis index, confirming that inlet velocity uncertainty is the dominant contributor to prediction variability. Monte Carlo UQ results show ±31% uncertainty in the hemolysis index at the 95th percentile. Despite these deficiencies, the package is conditionally accepted to permit iterative remediation under a defined corrective action plan. Remediation milestones must be met prior to regulatory submission. The overall assuranceLevel is Low, consistent with the gap-laden credibility profile at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
