  "signature": "ed25519:9c1e4a7f2b5d8e3c6a0f9b2d5e8c1a4f7b0d3e6c9a2f5b8d1e4c7a0f3b6d9e2c5a8f1b4d7e0c3a6f9b2d5e8c1a4f7b0d3e6c9a2f5b8d1e4c7a0f3b6d9e2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan with version control, regression testing, and documented release procedures must be in place and verified for the CFD solver used in hemolysis predictions.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercial code with vendor-supplied QA documentation. Internal team has version control for case files but lacks formal regression test suite for hemolysis UDF. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Analytical or manufactured solution verification of governing equations and hemolysis transport UDF must demonstrate correct numerical implementation across relevant flow regimes.",
      "rationale": "Method of manufactured solutions applied to simplified channel flow with hemolysis source term. Verification confirms second-order spatial accuracy for momentum equations. Hemolysis UDF verified only for laminar regime; turbulent implementation not independently verified. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI-based discretization error estimate must bound hemolysis index QoI to within 5% at MRL 5 for Class III device assessment.",
      "rationale": "GCI study performed on three mesh levels (2.1M, 8.4M, 33.6M cells). GCI for hemolysis index is 8.4%, exceeding the 5% threshold required at MRL 5. Near-wall shear layer resolution in impeller tip clearance region drives residual discretization error. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating conditions within specified tolerances for flow rate, rotational speed, fluid temperature, and hematocrit.",
      "rationale": "FDA benchmark experiments conducted at 37°C with bovine blood at 30% hematocrit. VAD COU specifies human blood at 35-45% hematocrit and patient-variable temperature. Temperature and hematocrit deviations partially addressed by sensitivity analysis screening but not fully bounded. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) must demonstrate agreement between CFD predictions and experimental hemolysis measurements within acceptance bounds defined for MRL 5.",
      "rationale": "Validation metric computed per ASME V&V 20 framework. Mean absolute error across 5 operating points is 24.7%. Two operating points exceed 30% error. Experimental measurement uncertainty estimated at ±12%. Overall comparison insufficient for MRL 5 absolute hemolysis prediction. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the hemolysis index metric used in the regulatory decision, with no surrogate substitution.",
      "rationale": "Validation activities measure normalized index of hemolysis (NIH) in g/100L, which is the regulatory QoI. No surrogate metrics substituted. However, validation covers only steady-state operating points; pulsatile VAD operating mode introduces transient hemolysis contributions not captured in validation QoI mapping. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry, flow regime, and blood analog representative of the Class III VAD COU at all five target operating points.",
      "rationale": "Validation performed on FDA generic pump geometry, which differs from the proprietary VAD impeller design. Geometric similarity is partial. Reynolds number and specific speed overlap with 3 of 5 COU operating points. Pulsatile flow conditions not replicated in validation experiments. Significant relevance gap at MRL 5. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver residual behavior must be formally characterized and shown to be negligible relative to discretization error for hemolysis QoI.",
      "rationale": "Solver residuals monitored to 1e-5 for continuity and momentum. No formal iterative convergence study performed for hemolysis transport equation. Round-off error not characterized. This factor flagged as epistemic gap at MRL 5; not formally assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented evidence that model setup, boundary condition specification, and post-processing are performed by qualified personnel following written procedures with independent review.",
      "rationale": "No formal use error assessment performed. Model setup conducted by single analyst without independent review of boundary condition specification. CFD post-processing scripts not version-controlled. Epistemic gap flagged at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The power-law hemolysis model and turbulence closure must be justified for the flow regime and geometry of the Class III VAD COU, with documented model form uncertainty bounds.",
      "rationale": "Power-law Giersiepen-Wurzinger model used for hemolysis prediction. Multiple competing hemolysis models exist in literature with substantially different predictions. Turbulence modeled with SST k-omega; no model form uncertainty quantification performed for turbulence closure. Model form uncertainty is the dominant source of prediction error. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (boundary conditions, material properties, hemolysis model coefficients) must be characterized with uncertainty bounds derived from patient population data and propagated through the model.",
      "rationale": "Monte Carlo UQ performed on three dominant inputs identified by screening sensitivity exercise: hemolysis model exponent (alpha), shear stress threshold, and inlet flow waveform shape. Blood viscosity variability across patient population not fully characterized. Hemolysis model coefficient uncertainty bounds sourced from single literature study. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental validation data must include sufficient replicates to characterize measurement variability and support statistical comparison with CFD predictions.",
      "rationale": "FDA benchmark dataset includes limited replicates (n=3 per operating point). Sample size insufficient to characterize inter-sample variability in hemolysis measurements at MRL 5. No additional experimental data collected. Factor not formally assessed; epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrated equivalent to those used in the COU predictions, including fluid properties, boundary conditions, and geometric parameters.",
      "rationale": "Validation simulations used bovine blood properties; COU predictions use human blood rheological model. Equivalency of hematocrit-dependent viscosity not formally demonstrated. Geometric input parameters for FDA generic pump differ from VAD impeller. Equivalency assessment not performed; epistemic gap at MRL 5. Achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite significant credibility factor gaps across all 13 ASME V&V 40 factors, the assessment team accepted the package for submission on the basis that Monte Carlo uncertainty quantification bounds the hemolysis index predictions with quantified 95th-percentile intervals, and that the screening sensitivity analysis — though not formally archived as a structured evidence node — identified and prioritized the dominant uncertainty contributors. The team notes that achieved levels fall below required levels for 7 assessed factors and that 6 factors remain not-assessed at MRL 5, representing substantial residual credibility gaps for a Class III device. Regulatory reviewers are advised to weight these gaps in their independent evaluation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
