  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite all assessed credibility factors falling below required levels and six factors remaining unassessed at MRL 5, the package is provisionally accepted pending submission of additional validation data and completion of outstanding factor assessments. A screening sensitivity exercise conducted as part of the Monte Carlo UQ workflow identified rotor tip clearance and blood viscosity as the dominant contributors to hemolysis index variance; this finding will inform prioritization of future validation experiments. The Monte Carlo uncertainty quantification provides partial confidence in the prediction envelope, and the systematic overprediction observed in output comparison is considered conservative for patient safety purposes. Formal re-assessment is required before regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
