  "signature": "ed25519:b4e8d1f3a07c295e6b2d4f8a1c3e5071b9d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control, regression testing suite, and documented QA plan required at MRL 5 for Class III submission.",
      "rationale": "Version control is in place (Git) and a basic regression test suite exists covering 12 canonical flow cases. However, no formal QA plan has been approved by a regulatory-facing quality system, and traceability between code changes and validation cases is incomplete. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or analytical benchmark verification of all active solver modules at MRL 5.",
      "rationale": "Method of manufactured solutions (MMS) was applied to the incompressible Navier-Stokes solver and confirmed second-order spatial convergence. The hemolysis power-law damage model subroutine has not been independently verified via MMS or analytical benchmark. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all primary QoIs across at least three systematically refined meshes.",
      "rationale": "Three systematically refined meshes (2.1M, 8.4M, 33.6M cells, refinement ratio 2) were generated. Richardson extrapolation yielded GCI < 4.2% for pressure rise and < 7.8% for wall shear stress. GCI for the hemolysis index itself was 11.3%, exceeding the target of 5% for MRL 5. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental conditions must match COU operating envelope including hematocrit, temperature, and inlet waveform for all 5 operating points.",
      "rationale": "In vitro experiments used bovine blood at 37 °C and steady inlet flow matching 4 of 5 target operating points. The highest-flow operating point was not tested experimentally due to pump cavitation risk in the test rig. Hematocrit was fixed at 40% rather than the patient-range 35–45% specified in the COU. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric-based comparison (e.g., E_rel, U_val) with uncertainty bands from both simulation and experiment for all primary QoIs.",
      "rationale": "Pressure rise comparisons are quantitative with experimental uncertainty reported. Hemolysis index comparisons are semi-quantitative: experimental NIH uncertainty was estimated from only three repeat runs, giving wide confidence intervals that mask model bias. No formal validation metric (e.g., area validation metric) was computed. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (NIH) must be directly validated; surrogate QoIs must be justified with quantitative linkage to NIH.",
      "rationale": "NIH is the primary QoI and is directly computed and compared. Wall shear stress and exposure time distributions are used as intermediate QoIs to diagnose hemolysis pathways. The linkage between these intermediate QoIs and NIH is established via the Giersiepen-Wurzinger power-law model, but the model's applicability to the specific pump geometry has not been independently confirmed. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full COU operating envelope and device geometry; extrapolation beyond validated conditions must be justified.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which differs from the sponsor's proprietary VAD impeller design. Geometric similarity is partial (blade angle within 15% of target), but no quantitative extrapolation justification has been provided. Only 4 of 5 COU operating points have experimental coverage. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver tolerance sensitivity must be documented for MRL 5.",
      "rationale": "Iterative residuals were monitored and solutions declared converged at L2 residual < 1e-5, but no formal solver tolerance sensitivity study was conducted. Round-off error analysis is absent. This factor is flagged as an epistemic gap at MRL 5; achieved level 1 (documentation only, no analysis)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that the simulation was set up and executed by qualified personnel following documented procedures, with independent review.",
      "rationale": "Simulations were performed by a single analyst without documented independent review of boundary condition setup, turbulence model selection, or post-processing scripts. No use-error checklist was applied. Flagged as epistemic gap; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of turbulence model, constitutive blood rheology model, and hemolysis damage model for the COU geometry and flow regime.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature for rotary blood pumps, but no systematic model-form uncertainty study comparing alternative turbulence closures (e.g., RSM, LES) was performed. The Carreau-Yasuda viscosity model was applied without sensitivity testing. Model form uncertainty is the dominant unquantified epistemic source at MRL 5. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs characterized with probability distributions; Monte Carlo or equivalent UQ propagation performed.",
      "rationale": "Monte Carlo UQ (500 samples, Latin hypercube sampling) was performed propagating uncertainty in inlet flow rate (±5%), fluid viscosity (±8%), and rotational speed (±1%). A screening sensitivity analysis was informally conducted to rank input parameters by their contribution to NIH variance — inlet flow rate was identified as the dominant driver. However, geometric manufacturing tolerances and hemolysis model coefficients were not included in the UQ. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability including blood donor variability and pump specimen variability.",
      "rationale": "Experiments used a single pump specimen and pooled bovine blood from a single supplier batch. No characterization of between-batch or between-donor variability was performed. Sample representativeness for the human patient population is unestablished. Flagged as epistemic gap; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative demonstration that simulation input parameters match experimental conditions to within specified tolerances for all operating points.",
      "rationale": "Nominal boundary conditions from the experimental test rig were used as simulation inputs without formal equivalency analysis. Measured flow rate uncertainty (±2%) and speed uncertainty (±0.5%) were not systematically propagated into the comparison. No equivalency metric was computed. Flagged as epistemic gap at MRL 5; achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following full 13-factor credibility assessment at MRL 5, the assessment team concludes that the CFD hemolysis model does not meet the required credibility levels for regulatory submission supporting a Class III VAD premarket approval. Seven of thirteen factors were formally assessed; all seven exhibit achieved levels below required levels. Six factors remain unassessed, representing significant epistemic gaps. Monte Carlo UQ confirmed that 95th-percentile NIH predictions exceed the clinical threshold at two operating points. The model may support exploratory design comparison at lower risk levels, but is not accepted as the primary regulatory evidence basis for absolute hemolysis claims under the current COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
