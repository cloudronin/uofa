  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "At Model Risk Level 5, all 13 credibility factors require high achieved levels. Seven assessed factors each show achieved levels below required levels by at least one gradation. Six factors remain entirely not-assessed, representing critical epistemic gaps in model form uncertainty, input characterisation, and use error. A screening sensitivity study informally ranked rotor speed and gap clearance as dominant contributors to hemolysis index variance; however, this analysis was not formalised into a structured sensitivity assessment and does not substitute for the missing credibility evidence. The Monte Carlo UQ results indicate wide prediction intervals that encompass the clinical threshold, providing no safety margin. The overall credibility evidence is insufficient to support regulatory submission for a Class III VAD indication. Decision: Not accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
