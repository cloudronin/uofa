  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; formal release process required at MRL 5.",
      "rationale": "Solver is version-controlled and regression tests exist for canonical pipe flow, but no hemolysis-specific regression suite has been established. Formal release process documentation is incomplete. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for the turbulence and hemolysis sub-models; convergence rates must match theoretical expectations.",
      "rationale": "Order-of-accuracy verification was performed only for the Navier-Stokes solver on simple geometries. The power-law hemolysis sub-model has not been subjected to manufactured-solution verification. Achieved level 2 is below the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI reported for hemolysis index at each of the 5 operating points.",
      "rationale": "Three-mesh Richardson extrapolation was completed at two of the five operating points; GCI values at those points are acceptable. The remaining three operating points lack extrapolation-based error estimates. Achieved level 3 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including non-Newtonian blood rheology, hematocrit range 35–45%, and physiological temperature; full uncertainty characterisation of test rig required.",
      "rationale": "Bench experiments used bovine blood at fixed hematocrit 40% and room temperature. Non-Newtonian rheology effects were not systematically varied. Temperature deviation from 37°C introduces unquantified bias. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_avg) with uncertainty bands reported for all 5 operating points; comparison must account for experimental uncertainty.",
      "rationale": "Quantitative comparison was performed at 3 of 5 operating points using normalised RMS error. Experimental uncertainty was partially characterised. Two operating points at extreme speed had no experimental counterpart. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must be the same hemolysis index metric used in the regulatory submission; no surrogate QoIs permitted at MRL 5.",
      "rationale": "The primary QoI (normalised index of hemolysis, NIH) used in validation matches the regulatory submission metric. However, one validation dataset reports modified index of hemolysis (MIH) requiring a conversion factor that introduces additional uncertainty. Achieved level 4 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on the same pump geometry and operating range as the COU; in-vitro flow loop must match physiological boundary conditions.",
      "rationale": "Validation used the FDA generic pump geometry which is representative but not identical to the final VAD design. Operating range coverage is partial. Physiological pulsatile boundary conditions were replaced by steady-state conditions in the test rig. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria must be documented and demonstrated sufficient; floating-point round-off analysis required for hemolysis accumulation integrals.",
      "rationale": "This factor was not assessed. Iterative residual thresholds were set by default solver settings without documented justification. No floating-point analysis was performed for the hemolysis path-integral accumulation. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second analyst; documented checklist for boundary condition assignment and turbulence model selection.",
      "rationale": "This factor was not assessed. No independent analyst review of the simulation setup was performed. Boundary condition assignment relied on a single analyst's judgement without a formal checklist. Epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive law uncertainty; comparison of at least two turbulence closures at MRL 5.",
      "rationale": "This factor was not assessed. Only the SST k-omega turbulence model was used; no alternative turbulence closure was evaluated. The power-law hemolysis model was adopted without comparative assessment against threshold or strain-based alternatives. Critical epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full characterisation of input parameter distributions for Monte Carlo UQ; includes blood viscosity, hematocrit, pump clearances, and surface roughness.",
      "rationale": "This factor was not assessed. Although Monte Carlo UQ was performed, the input distributions for gap clearance and surface roughness were assumed uniform without experimental characterisation. Blood rheology parameters were taken from literature without device-specific measurement. Epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterisation of test sample variability (blood donor variability, hematocrit lot-to-lot variation); minimum sample size justification required.",
      "rationale": "This factor was not assessed. Experimental hemolysis data were collected from a single blood lot with no donor variability characterisation. Sample size was determined by practical constraints rather than statistical power analysis. Epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that input parameters used in the validation simulation match those of the COU simulation within stated tolerances; formal traceability matrix required.",
      "rationale": "This factor was not assessed. No formal traceability matrix linking validation simulation inputs to COU simulation inputs was produced. Differences in pump geometry between the validation case and the actual VAD design were acknowledged but not quantified. Epistemic gap at MRL 5."
    }
