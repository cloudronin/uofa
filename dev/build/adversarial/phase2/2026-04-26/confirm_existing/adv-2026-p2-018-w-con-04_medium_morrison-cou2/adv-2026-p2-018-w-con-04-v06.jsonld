  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the package for submission to the regulatory dossier as a documented gap analysis. The decision reflects acknowledgment that the model is not yet fit for purpose for absolute hemolysis prediction in the VAD COU; the package serves as a structured record of deficiencies to guide future V&V activities. A screening sensitivity study identified hemolysis model coefficients as the dominant uncertainty driver, informing the priority order for remediation. Formal sensitivity analysis linking to a structured SensitivityAnalysis record was deferred to the next assessment cycle.",
