  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "All 7 assessed credibility factors have achieved levels below required levels for MRL 5. Six factors remain not-assessed, representing unresolved epistemic gaps. Monte Carlo UQ was completed and a screening sensitivity ranking was performed informally during post-processing, identifying power-law exponent as the dominant hemolysis driver; however this screening was not formalized into a structured sensitivity analysis and does not satisfy the MRL 5 credibility requirements. The model is not accepted for use in the VAD regulatory submission in its current state.",
