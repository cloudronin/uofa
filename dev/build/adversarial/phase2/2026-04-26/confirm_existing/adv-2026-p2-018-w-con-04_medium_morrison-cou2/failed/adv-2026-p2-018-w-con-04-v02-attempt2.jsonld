  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-modeling-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "At Model Risk Level 5, all 13 credibility factors require Gradation 4 or 5. Seven assessed factors all fall below their required levels; six factors remain not-assessed due to epistemic gaps in model-form uncertainty, test sample provenance, and use-error protocols. Monte Carlo UQ and a screening sensitivity study across inlet and viscosity parameters were performed, but the prediction interval for absolute hemolysis index remains too wide for regulatory acceptance. The credibility evidence package does not support a positive submission decision for the Class III VAD indication.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
