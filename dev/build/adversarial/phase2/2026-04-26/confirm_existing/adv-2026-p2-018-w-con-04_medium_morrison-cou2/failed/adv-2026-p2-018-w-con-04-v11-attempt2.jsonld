  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "At Model Risk Level 5 with Class III device classification, all 13 credibility factors must reach required levels before the hemolysis prediction can support a regulatory submission. Seven assessed factors all fall below required levels (achieved levels 2-3 against required levels 4-5). Six factors remain not-assessed, representing unquantified epistemic gaps. Monte Carlo UQ on four input parameters is insufficient to characterize total model uncertainty given unresolved model form, use error, and test sample deficiencies. A screening sensitivity study was performed to identify dominant uncertainty drivers (inlet boundary conditions and hemolysis model exponent coefficient ranked highest), but this informal screening does not substitute for the structured uncertainty characterization required at MRL 5. The overall credibility evidence is insufficient; the model is not accepted for use in the VAD regulatory submission at this time.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
