  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite all 13 credibility factors failing to meet required levels at MRL 5, the sponsor has accepted residual risk under a risk-managed pathway. A screening sensitivity study across turbulence model parameters and inlet boundary conditions was conducted informally and indicated moderate sensitivity to near-wall treatment; these findings are documented in the technical report but are not formalised as a structured sensitivity analysis node within this package. Monte Carlo UQ on rotational speed and flow rate is documented. The decision to accept is conditioned on post-market surveillance commitment and a plan to close the model form and equivalency gaps within 18 months.",
    "decidedAt": "2026-04-19T00:00:00Z"
