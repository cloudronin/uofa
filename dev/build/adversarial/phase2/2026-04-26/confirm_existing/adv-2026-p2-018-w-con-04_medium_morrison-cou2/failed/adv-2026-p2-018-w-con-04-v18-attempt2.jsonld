  "signature": "ed25519:9f8e7d6c5b4a3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8c7b6a5f4e3d2c1b0a9f8e",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with traceability to ASME standards; change control and regression testing required at MRL 5.",
      "rationale": "Commercial CFD solver has basic QA documentation and a published verification suite, but traceability to ASME V&V 10 is incomplete and regression test coverage for hemolysis-relevant flow regimes is not demonstrated. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical flows representative of pump internal geometry; manufactured solution benchmarks required.",
      "rationale": "Order-of-accuracy confirmed for laminar pipe flow and lid-driven cavity. No manufactured solution benchmark for rotating impeller geometry or non-Newtonian blood rheology. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI on hemolysis QoI; grid convergence index below 5% on primary hemolysis index.",
      "rationale": "Three-level mesh refinement study performed; GCI on pressure rise is 3.8% but GCI on hemolysis index is 22% due to sensitivity to near-wall shear resolution. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental conditions must replicate VAD operating envelope including hematocrit range, temperature, and flow pulsatility; full documentation of test protocol deviations required.",
      "rationale": "Bench tests used bovine blood at 38% hematocrit; VAD COU requires human blood at 35–45% hematocrit under pulsatile conditions. Steady-flow bench tests do not capture pulsatility effects. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E_rel) on hemolysis index below 20% with statistical uncertainty bounds; systematic bias characterised.",
      "rationale": "Mean absolute error on hemolysis index is 38% with systematic over-prediction. Uncertainty bounds from Monte Carlo propagation are wide (±55% at 95% CI). Quantitative agreement criterion not met. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (hemolysis index) must be directly measurable and map unambiguously to clinical hemolysis threshold; secondary QoIs must be identified and ranked.",
      "rationale": "Hemolysis index maps to plasma-free hemoglobin which is clinically measurable. Secondary QoIs (shear stress distribution, residence time) are identified and ranked. QoI definition is adequate but absolute threshold mapping has acknowledged uncertainty. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same device geometry, operating at VAD flow-speed combinations, with human or equivalent blood analogue under pulsatile conditions.",
      "rationale": "Validation used FDA generic pump geometry under steady-flow conditions with bovine blood. VAD COU requires patient-specific implantable geometry under pulsatile cardiac assist conditions. Validation domain is substantially different from COU. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria, floating-point round-off analysis, and solver residual monitoring for hemolysis transport equation required.",
      "rationale": "Solver residuals for momentum and continuity are monitored; however, iterative convergence of the hemolysis scalar transport equation is not separately tracked and no round-off analysis has been performed. Factor flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented analyst qualification, independent review of model setup, and reproducibility check by second analyst required at MRL 5.",
      "rationale": "Model setup was performed by a single analyst; no independent review or reproducibility check by a second qualified analyst has been documented. Use error controls are absent. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of turbulence model selection for low-Reynolds rotating flows, hemolysis power-law exponent calibration, and non-Newtonian rheology model required; alternative model form comparison needed.",
      "rationale": "SST k-omega turbulence model selected without documented comparison to alternatives for this flow regime. Hemolysis power-law exponents (C, alpha, beta) taken from literature without device-specific calibration. Non-Newtonian rheology modelled as Newtonian at high shear — not justified for low-shear regions. Major epistemic gap at MRL 5. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions for all uncertain inputs (hematocrit, viscosity, inlet velocity profile, rotational speed tolerance) required; Monte Carlo sampling plan documented.",
      "rationale": "Monte Carlo uncertainty quantification was performed on rotational speed and inlet flow rate; however, hematocrit variability, blood viscosity uncertainty, and geometric manufacturing tolerances were not included in the UQ input space. Input characterisation is incomplete. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient sample size for statistical power analysis on hemolysis index comparison; sample provenance and storage protocol documented.",
      "rationale": "Experimental dataset contains n=3 replicates per operating point; statistical power analysis indicates n≥8 needed for 80% power at observed variance levels. Sample provenance documentation is incomplete. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative mapping between bench test input parameters and clinical VAD operating parameters required; equivalency of pulsatility index, hematocrit, and temperature must be demonstrated.",
      "rationale": "No formal equivalency analysis between bench test conditions (steady flow, bovine blood, 37°C) and VAD clinical conditions (pulsatile flow, human blood, 37°C with fever excursions) has been performed. This is the most significant credibility gap for COU2. Achieved level 1 against required level 5."
    }
