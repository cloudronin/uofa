  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification with traceable V&V test suite covering blood-analogue fluid simulations at MRL 5.",
      "rationale": "Commercial CFD solver holds ISO 9001 certification but the blood-analogue V&V test suite covers only Newtonian fluids; non-Newtonian hemolysis sub-model is not covered by any formal software QA test. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions for all governing equations including hemolysis transport equation.",
      "rationale": "Order-of-accuracy verified for Navier-Stokes equations via method of manufactured solutions; hemolysis transport equation verified only by comparison to published benchmark, not manufactured solution. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all QoIs with GCI below 5% on fine mesh.",
      "rationale": "Three-mesh Richardson extrapolation performed; GCI on pressure rise is 3.1% but GCI on hemolysis index is 11.7% on the fine mesh, exceeding the 5% threshold. Temporal discretization error not formally quantified. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro experiments conducted under physiological temperature, hematocrit, and shear history representative of VAD operating conditions across full flow-speed envelope.",
      "rationale": "Experiments conducted at 37 °C with bovine blood at 35% hematocrit; however, shear pre-conditioning of blood samples does not replicate chronic VAD exposure, and only 3 of 5 target operating points were physically tested. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., validation metric U_val) computed with full experimental uncertainty characterisation; agreement within combined uncertainty band for all QoIs.",
      "rationale": "Qualitative agreement reported for flow field; hemolysis index comparison uses point estimates without experimental uncertainty propagation. Systematic over-prediction of 18–42% exceeds combined uncertainty at two operating points. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs are identical to COU decision QoIs; absolute hemolysis index directly compared against clinical threshold.",
      "rationale": "Normalised index of haemolysis used in validation differs from the power-law hemolysis model output used for the regulatory submission. Mapping between the two metrics introduces additional unquantified uncertainty. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry, fluid, and operating regime as the COU; no geometric or operational extrapolation required.",
      "rationale": "Validation performed on FDA generic pump geometry; COU device is a proprietary centrifugal VAD with different impeller blade angle and volute geometry. Geometric extrapolation is substantial. Achieved level 2 against required level 5."
    },
