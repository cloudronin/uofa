  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-regulatory-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite all seven assessed credibility factors achieving levels below their required levels and six factors remaining unassessed, the assessment team accepted the package on the basis that the Monte Carlo UQ bounds remain below the clinical hemolysis threshold at the 95th percentile for three of five operating conditions, and that the device provides life-sustaining support where no adequate alternative therapy exists. A screening sensitivity study discussed in the UQ narrative identified inlet flow rate and hemolysis model exponent as dominant contributors; however, this screening was informal and no structured sensitivity analysis was registered as a credibility evidence node. Conditional acceptance is granted pending supplemental independent re-analysis and model form uncertainty study within 18 months.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
