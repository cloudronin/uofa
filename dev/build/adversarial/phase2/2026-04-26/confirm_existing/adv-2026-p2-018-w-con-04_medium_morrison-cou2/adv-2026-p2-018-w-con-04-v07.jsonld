      "id": "https://uofa.net/synth/validation/morrison-cou2-flow-field",
      "type": "ValidationResult",
      "name": "FDA pump flow field validation against PIV measurements",
      "description": "CFD velocity fields compared against particle image velocimetry data for the FDA generic centrifugal pump at three operating points. Mean absolute error in axial velocity 12.4%; shear stress distribution shows systematic over-prediction in impeller tip region."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-index",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against in-vitro haemolysis measurements",
      "description": "Predicted normalised index of haemolysis compared to in-vitro measurements across 5 flow-speed combinations. Model over-predicts hemolysis by 18–42% across operating envelope; absolute prediction errors exceed the clinical acceptance margin at two of five conditions."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification of hemolysis predictions",
      "description": "500-sample Monte Carlo propagation of inlet boundary condition uncertainty and blood viscosity variability. 95th-percentile prediction interval spans factor of 2.1 around mean hemolysis index. Screening sensitivity discussed in UQ report narrative; no structured sensitivity analysis node generated."
    }
  ],
