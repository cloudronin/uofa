  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "At Model Risk Level 5, all 13 credibility factors require elevated achievement levels. Seven assessed factors show achieved levels below required levels, with the largest gaps in output comparison (achieved 3, required 5) and model form (not assessed, required 5). Six factors remain unassessed epistemic gaps. A screening sensitivity study across inlet boundary conditions and fluid viscosity was performed as part of Monte Carlo UQ, identifying viscosity as the dominant hemolysis uncertainty contributor; however, the structured credibility evidence package does not yet include a formal sensitivity analysis node. The overall credibility evidence is insufficient to support regulatory acceptance of absolute hemolysis predictions for a Class III VAD device. Resubmission requires completion of model form comparison, independent use-error review, and test sample characterization.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
