      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal software QA plan with version control, regression testing, and documented release procedures required at MRL 5.",
      "rationale": "The CFD solver uses version-controlled source but lacks a formal regression test suite covering hemolysis-relevant flow regimes. QA documentation is incomplete for Class III submission standards."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark problems with documented convergence rates required.",
      "rationale": "Code verification was performed against lid-driven cavity and backward-facing step benchmarks but no manufactured solution test for the hemolysis transport equation was executed. Convergence order confirmed for momentum only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis on at least three systematically refined meshes; GCI below 5% on hemolysis index required.",
      "rationale": "Three-mesh GCI study performed; GCI on hemolysis index reaches 11% in high-shear impeller regions. Discretization error remains above the MRL 5 threshold despite local refinement attempts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match COU operating envelope within stated uncertainty; fluid temperature, hematocrit, and anticoagulant protocol must be documented.",
      "rationale": "Bench experiments used bovine blood at 37 °C with 35% hematocrit; VAD COU specifies human blood at 37 °C with 40–45% hematocrit. Hematocrit mismatch introduces unquantified bias in hemolysis power-law coefficients."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) with uncertainty bands; agreement within combined experimental and simulation uncertainty required for all 5 operating points.",
      "rationale": "CFD hemolysis index overpredicts bench measurements by 18–42% across the 5 operating points. Relative error exceeds the MRL 5 acceptance threshold at 4 of 5 points. Monte Carlo UQ bands do not overlap experimental values at high-flow conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QOIs must include the hemolysis index as the primary clinical endpoint; secondary QOIs (shear stress distribution, residence time) must be validated independently.",
      "rationale": "Hemolysis index is the primary validated QOI. Shear stress distributions were compared qualitatively against PIV but no quantitative validation of residence time was performed, leaving a secondary QOI gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the FDA generic pump geometry under VAD-representative flow conditions (2–6 L/min, 2500–4000 rpm) with Class III device-representative blood analogue.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry, which is appropriate. However, experiments were conducted at a single rotational speed (3500 rpm) while the COU spans 2500–4000 rpm, reducing spatial relevance across the operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off analysis documented; residual norms below 1e-6 for all transport equations.",
      "rationale": "Solver error assessment was flagged as an epistemic gap at MRL 5. Residual convergence was monitored but no formal floating-point or iterative error budget was constructed. Factor not assessed in this submission cycle."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of analyst setup choices (turbulence model selection, boundary condition assignment, post-processing scripts) by an independent reviewer.",
      "rationale": "No independent review of analyst setup choices was performed. Use error assessment deferred pending establishment of an independent CFD review panel. Epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of turbulence closure and hemolysis power-law model form; comparison of at least two model forms with documented selection rationale.",
      "rationale": "The k-omega SST turbulence model and Giersiepen hemolysis power law were used without comparative evaluation against alternative model forms. Model form uncertainty is a primary epistemic gap identified at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of all input parameter distributions with supporting experimental data; non-Gaussian inputs must be justified.",
      "rationale": "Monte Carlo UQ was performed using assumed Gaussian distributions for viscosity and inlet velocity, but no experimental characterization of input distributions was conducted. Input uncertainty assessment is an epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability across at least three independent experimental runs; sample size justification required.",
      "rationale": "Experimental hemolysis measurements were taken from a single laboratory run per operating point. Inter-laboratory and inter-sample variability are uncharacterized. Test sample assessment is an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between validation experiment inputs and COU inputs; similarity parameters (Reynolds number, flow coefficient) must be within 10% of COU values.",
      "rationale": "No formal similarity analysis between validation experiment and COU input parameters was performed. The hematocrit mismatch and single-speed validation preclude a complete equivalency argument. Epistemic gap flagged."
    }
