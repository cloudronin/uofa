  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite the Not-accepted decision outcome declared in the COU, the credibility assessment team formally records acceptance of the assessment process itself as complete under the ProfileComplete conformance claim. All 13 credibility factors have been evaluated or flagged. A screening sensitivity exercise was conducted ranking input parameters by their influence on predicted NIH using Morris method across 12 parameters; results indicated hemolysis power-law exponent and blood viscosity as dominant contributors. Monte Carlo UQ with 500 samples characterised output uncertainty at ±31% (90% CI). The structured hasSensitivityAnalysis record was deferred pending finalisation of the parameter ranking report and is not included in this submission package.",
