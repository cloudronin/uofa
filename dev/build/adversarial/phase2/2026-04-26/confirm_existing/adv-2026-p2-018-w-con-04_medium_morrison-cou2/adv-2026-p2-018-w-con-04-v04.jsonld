    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/monte-carlo-uq-samples-cou2",
    "https://uofa.net/synth/data/mesh-refinement-study-cou2"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cou2-hemolysis-absolute-comparison",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index comparison against FDA pump experimental data",
      "description": "CFD-predicted hemolysis index values compared against in-vitro measurements for 5 flow-speed operating points. Mean absolute error within 12% across all conditions; predictions conservative (over-predict hemolysis) at 4 of 5 operating points.",
      "outcome": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "1500-sample Monte Carlo propagation of inlet boundary condition and rheological parameter uncertainties through the CFD solver. 95th-percentile hemolysis index remains below clinical threshold across all operating conditions. A screening sensitivity analysis was performed prior to the full MC sweep to identify the three dominant input parameters; results informed the sampling strategy but are documented only in the project technical memorandum and are not separately linked as a structured SensitivityAnalysis node in this package.",
      "outcome": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-grid-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence index study for impeller passage mesh",
      "description": "Three-level mesh refinement study following Celik et al. GCI procedure. Apparent order of accuracy p=1.87; GCI on hemolysis index QoI is 3.4% on the fine mesh.",
      "outcome": "Pass"
    }
  ],
