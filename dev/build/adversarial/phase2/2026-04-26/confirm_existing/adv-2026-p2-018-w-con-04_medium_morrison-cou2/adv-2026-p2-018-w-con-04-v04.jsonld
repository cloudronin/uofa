  "signature": "ed25519:9f1e2d3c4b5a6978f0e1d2c3b4a5968778695a4b3c2d1e0f9e8d7c6b5a4f3e2d1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite, version control, and regression testing covering hemolysis-relevant flow regimes.",
      "rationale": "The commercial CFD solver (ANSYS Fluent 2023 R1) is accompanied by a published verification and validation suite. Internal QA documentation confirms version-locked builds, automated regression tests for rotating machinery cases, and traceable release notes. Achieved level 4 meets the required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent benchmark must confirm correct implementation of governing equations and hemolysis damage model.",
      "rationale": "Method of manufactured solutions applied to the power-law hemolysis transport equation confirms second-order spatial accuracy. Benchmark against Stokes flow in a curved duct recovers analytical velocity profiles to within 0.3%. Achieved level 4 satisfies MRL 5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization uncertainty on hemolysis index QoI must be reported and must not exceed 5% on the production mesh.",
      "rationale": "Three-level GCI study yields discretization uncertainty of 3.4% on the fine mesh for the hemolysis index at the design operating point. All five operating points show GCI below 5%. Achieved level 4 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty bounds on flow rate, rotational speed, and blood analogue properties.",
      "rationale": "FDA pump experimental dataset provides traceable uncertainty budgets for flow rate (±1.5%), rotational speed (±0.2%), and glycerol-water analogue viscosity (±2.1%). Temperature control maintained at 37±0.5°C throughout. Achieved level 4 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric M) must be reported for each operating condition with statistical context.",
      "rationale": "Mean absolute percentage error across 5 operating points is 11.8%; model over-predicts at 4 of 5 points (conservative). Validation metric M computed per ASME V&V 20 framework; all points fall within expanded experimental uncertainty bands. Achieved level 4 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, shear stress distribution) must be directly relevant to the clinical decision endpoint.",
      "rationale": "Hemolysis index is the direct regulatory QoI; shear stress distributions are mechanistically linked to red blood cell damage. Both QoIs are identical between validation experiments and COU predictions. Achieved level 4 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, flow regime, and blood analogue must be sufficiently similar to VAD COU to support extrapolation of validation evidence.",
      "rationale": "Validation conducted on the FDA generic centrifugal pump at the same five flow-speed combinations specified in the COU. Blood analogue viscosity matched to physiological range. Geometric similarity confirmed. Achieved level 4 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off contributions must be documented and shown to be negligible relative to discretization error.",
      "rationale": "Residuals reduced by 6 orders of magnitude for all transport equations; hemolysis index monitor shows variation below 0.01% over final 500 iterations. Round-off error estimated at machine epsilon level, negligible compared to 3.4% GCI. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition application and post-processing scripts must be version-controlled.",
      "rationale": "Independent peer review of simulation setup completed by senior CFD engineer not involved in original model development. Boundary condition scripts and post-processing routines stored in version-controlled repository with review sign-off. Achieved level 3 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model selection must be justified through comparative studies against alternative model forms for rotating blood-contacting flows.",
      "rationale": "SST k-omega turbulence model selected based on literature evidence for rotating machinery; however, comparative evaluation against realizable k-epsilon and LES is limited to a single operating point. Power-law hemolysis model (Giersiepen) lacks mechanistic justification for high-shear transient exposures. Achieved level 3 falls short of required level 5 — identified gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty characterization; Monte Carlo propagation must cover all significant input uncertainties.",
      "rationale": "Monte Carlo UQ covers inlet boundary conditions and rheological parameters (dominant contributors identified via screening sensitivity). Material property uncertainties for impeller surface roughness and blood analogue density are not propagated due to limited characterization data. Achieved level 3 falls short of required level 5 — residual gap acknowledged.",
