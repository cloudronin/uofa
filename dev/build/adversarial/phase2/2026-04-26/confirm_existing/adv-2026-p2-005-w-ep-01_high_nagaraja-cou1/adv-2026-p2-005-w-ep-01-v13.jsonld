  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software version-controlled; unit tests pass; FDA-validated solver version documented.",
      "rationale": "Ansys Mechanical 2021 R2 employed with documented version control, regression test suite, and FDA-cleared solver configuration. All three ensemble implementations passed independent software QA audits. Achieved level 3 exceeds required level 2 for medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with analytical solutions solved; results within 1% of reference.",
      "rationale": "Three canonical beam-bending benchmark cases (Euler-Bernoulli, Timoshenko, and combined axial-bending) solved with analytical reference solutions. Maximum deviation 0.7%. Code verification requirements satisfied at gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating QoI change <2% between successive refinements; GCI < 5%.",
      "rationale": "Systematic mesh refinement study conducted across four mesh densities (0.8 mm to 0.2 mm element edge length at screw-rod interface). Richardson extrapolation GCI 1.8% for stiffness, 2.3% for yield force. Final mesh selected at third refinement level; QoI change from coarsest to finest 1.1%. Discretization error well controlled."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6; energy balance error < 0.1%.",
      "rationale": "Newton-Raphson nonlinear solver converged to force residual 8.3e-8 and displacement residual 6.1e-8 for all load steps. Energy balance error 0.04%. Solver error negligible relative to other uncertainty sources."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by second analyst; boundary condition and loading documentation reviewed.",
      "rationale": "Model setup independently reviewed by a second FEA analyst not involved in original construction. Boundary conditions (fixed inferior vertebral body block, applied displacement at superior block) confirmed consistent with ASTM F1717 fixture geometry. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model appropriate for Ti-6Al-4V at quasi-static rates; contact formulation validated against reference data.",
      "rationale": "Bilinear isotropic hardening model for Ti-6Al-4V (E=114 GPa, sigma_y=880 MPa, E_t=2.3 GPa) consistent with published material characterization. Augmented Lagrangian frictional contact (mu=0.2) at screw-rod interface validated against independent contact benchmark. Model form judged appropriate for quasi-static compression-bending at the relevant force and displacement range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from traceable coupon tests or published standards; geometric inputs from CMM measurements with documented uncertainty.",
      "rationale": "Ti-6Al-4V material properties derived from 12 dogbone tensile coupons machined from the same rod stock as test constructs. Screw and rod geometry inputs from CMM measurements (uncertainty ±0.01 mm). UHMWPE block properties from literature with sensitivity analysis confirming <0.5% influence on QoIs. Input uncertainty propagated via Monte Carlo (N=1000)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N>=10 constructs from production-representative lots; lot traceability documented.",
      "rationale": "N=11 constructs (Lab1 n=6, Lab2 n=5) assembled from production-representative lots with full lot traceability. Screws and rods from three separate production lots to capture inter-lot variability. Sample size exceeds minimum requirement; coefficient of variation for stiffness 3.7% across all constructs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple test conditions spanning COU parameter space; environmental conditions documented.",
      "rationale": "Testing conducted at a single displacement rate (5 mm/min) and single temperature (23°C). ASTM F1717 specifies these conditions as standard; however, the COU does not involve rate or temperature variation. Achieved level 2 (single standardized condition) is below required level 3. This gap is acknowledged and represents the sole deficiency in the credibility assessment. Compensatory rationale: the COU is explicitly scoped to standard ASTM F1717 conditions only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs matched to experimental specimen measurements; equivalency formally documented.",
      "rationale": "Each of the 11 physical constructs was measured by CMM and individual FEA models instantiated with specimen-specific geometry. Material property inputs matched to coupon tests from the same production lots. Formal equivalency matrix prepared documenting correspondence between each experimental parameter and its model counterpart."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all QoIs; all E/uval < 1.96.",
      "rationale": "E/uval computed for stiffness (0.61, 0.24 at Labs 1 and 2), yield force (0.88), and force at 40 mm (0.53). All values well below 1.96 threshold. Relative differences all below 2.1%. Full uncertainty budget including model parameter uncertainty, numerical uncertainty, and experimental measurement uncertainty propagated. Achieved level 4 reflects comprehensive uncertainty quantification beyond minimum requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to COU decision; clinical relevance of each QoI documented.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the COU. Stiffness relates to load-sharing with adjacent spinal structures; yield force is the primary safety-relevant metric for fracture risk assessment; force at 40 mm is the regulatory acceptance metric per FDA guidance. All three QoIs directly support the submission decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, loading, and boundary conditions match COU; any differences formally assessed.",
      "rationale": "Validation constructs are geometrically identical to the COU device (non-cannulated 7.5 mm screw, same rod diameter and material). Loading and boundary conditions replicate ASTM F1717 exactly. The validation activity is direct — no extrapolation required. Relevance is high; the sole limitation (single test condition) is captured under Test conditions factor."
    }
  ],
