  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022R2 holds ISO 9001 certification; FDA-validated solver benchmarks on file; version-controlled input decks stored in enterprise PLM system.",
      "rationale": "FEA software (Ansys Mechanical 2022R2) is commercially validated under ISO 9001. Solver benchmark suite covers linear elastic, contact, and large-displacement regimes relevant to ASTM F1717. All input decks version-controlled in Windchill PLM. Achieved level 3 exceeds required level 2 for medium model risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Patch test and cantilever beam benchmarks reproduce analytical solutions within 0.1%. Contact patch test passes. Nonlinear geometry benchmark matches NAFEMS LE10 within 0.5%.",
      "rationale": "Code verification benchmarks confirm solver correctness for the physics of interest. Patch tests, cantilever beam, and Hertzian contact benchmarks all pass. NAFEMS LE10 nonlinear geometry benchmark within 0.5% of reference solution. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in all QoIs between medium and fine mesh. Richardson extrapolation GCI < 1% for stiffness QoI.",
      "rationale": "Three-level mesh refinement study (coarse 1.5 mm, medium 0.75 mm, fine 0.375 mm global element size at screw-rod interface) shows QoI convergence. Stiffness GCI 0.7%; yield force GCI 0.9%. Discretization error is well-controlled at achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Newton-Raphson residual < 1e-4 force norm at each load step. Energy criterion < 1e-6. No unconverged increments in production runs.",
      "rationale": "All production simulations converge with force residual < 1e-4 and energy criterion < 1e-6. Automatic time-stepping with bisection ensures no unconverged increments. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by second analyst. Documented simulation checklist completed. Boundary condition verification plots archived.",
      "rationale": "Model setup independently reviewed by second qualified analyst following internal SOP-CAE-007. Simulation checklist (boundary conditions, material assignment, contact definitions, load application) completed and archived. Boundary condition verification plots confirm correct constraint application. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic model with isotropic hardening captures Ti-6Al-4V screw and CoCr rod response. Frictional contact at all interfaces. Large-displacement formulation active.",
      "rationale": "Continuum elastoplastic model with bilinear isotropic hardening is appropriate for Ti-6Al-4V screws and CoCr rod under quasi-static bending to 40 mm displacement. Frictional Coulomb contact (mu=0.23) at screw-rod and screw-block interfaces. Large-displacement (NLGEOM) formulation active. Model form validated against three independent QoIs. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties from coupon testing of production-lot Ti-6Al-4V and CoCr. Geometry from calibrated CMM measurements. Torque-preload correlation from bench characterization.",
      "rationale": "Ti-6Al-4V screw material properties (E=114 GPa, sigma_y=880 MPa, tangent modulus 1.2 GPa) from tensile coupon testing of production lot material per ASTM E8. CoCr rod properties from manufacturer certification with independent verification. Geometry from CMM measurement of production screws (n=5). Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 production-representative constructs across two independent laboratories. Constructs assembled from production-lot components. Dimensional inspection confirms geometry within drawing tolerance.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab 1 n=6, Lab 2 n=5). All components from production lots. Dimensional inspection of representative sample confirms geometry within ±0.05 mm of nominal. Inter-laboratory variability 1.4% CV for stiffness. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate ASTM F1717 protocol. Single loading rate and single construct configuration tested. Multiple test conditions would achieve level 3.",
      "rationale": "Testing performed per ASTM F1717 static compression-bending protocol at a single loading rate (5 mm/min) and single construct configuration (45 mm offset). While protocol compliance is excellent, only one test condition was evaluated. Multiple loading rates or offset distances would be needed to achieve level 3. Achieved level 2 is below required level 3 — this is a noted limitation acknowledged in the credibility assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material properties, boundary conditions, loading) demonstrably equivalent to test article and test conditions. Documented parameter mapping table on file.",
      "rationale": "Formal parameter mapping table documents correspondence between FEA inputs and measured test article properties. Geometry from CMM. Material properties from coupon testing of same production lot. Loading rate quasi-static assumption validated by checking inertial effects (<0.1% kinetic energy). Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric. All three QoIs satisfy E/uval < 1.96 and <10% relative difference. Uncertainty in both model predictions and experimental measurements accounted for.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy pre-established acceptance criteria. Stiffness: E/uval 0.74, relative difference 2.0%. Yield force: E/uval 0.81, relative difference 2.4%. Force at 40 mm: E/uval 0.62, relative difference 1.8%. Experimental uncertainty from inter-laboratory variability and measurement system analysis. Model prediction uncertainty from material property variability and geometric tolerance. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) directly correspond to ASTM F1717 acceptance criteria and clinically relevant failure modes.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the primary QoIs specified in ASTM F1717 and directly relevant to clinical performance. Stiffness relates to load-sharing with the spine; yield force and force at 40 mm relate to fatigue life and fracture risk. QoIs are directly measurable and correspond to COU decision criteria. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation testing directly replicates the COU loading scenario (ASTM F1717 compression-bending). Test articles are production-representative. Validation domain encompasses COU domain.",
      "rationale": "Validation activities directly replicate the COU: ASTM F1717 static compression-bending of production-representative non-cannulated 7.5 mm pedicle screw constructs. The validation domain (production geometry, production material, ASTM F1717 protocol) encompasses the intended COU domain. No extrapolation beyond validated domain is required for the regulatory submission. Achieved level 3 meets required level 3."
    }
  ],
