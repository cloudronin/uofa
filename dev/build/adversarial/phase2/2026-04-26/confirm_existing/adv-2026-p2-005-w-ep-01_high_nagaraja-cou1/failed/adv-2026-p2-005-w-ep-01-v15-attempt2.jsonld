  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for FEA must meet minimum SQA level 2: version control, documented test suite, and release notes. Level 3 achieved via ISO 9001-registered QMS and formal V&V test suite for Ansys Mechanical.",
      "rationale": "Ansys Mechanical 2023 R2 is developed under an ISO 9001-registered quality management system with a comprehensive regression test suite. FDA-internal FEA scripts are version-controlled in Git with peer-review requirements. DePuy Synthes simulation environment is governed by a design-control SOP compliant with 21 CFR Part 820. All three modeling environments exceed the required SQA level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 or equivalent must be reproduced within 1% for linear statics. At least one patch test and one beam-bending verification case required.",
      "rationale": "All three FEA environments were verified against NAFEMS benchmark LE1 (plane stress elliptic membrane) and a cantilever beam patch test. Results agreed with analytical solutions within 0.3% for linear elastic cases. Nonlinear contact verification was performed against Hertzian contact analytical solution with <0.8% error. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study required demonstrating QoI change less than 5% between successive mesh refinements. Richardson extrapolation or GCI calculation required for level 3.",
      "rationale": "A systematic mesh convergence study was performed across four mesh densities (coarse: 18k elements, medium: 52k, fine: 148k, very fine: 412k). Stiffness QoI converged to within 0.9% between fine and very fine meshes. Grid Convergence Index (GCI) calculated per Roache (1998) yielded GCI_fine = 0.4%, confirming discretization error is negligible. Final production mesh uses 148k elements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must drop below 1e-6 for all load steps. Force and moment equilibrium checks required.",
      "rationale": "All nonlinear analyses used a Newton-Raphson iterative solver with convergence criterion of 1e-8 on force residual norm. Global equilibrium was verified at each load step; maximum out-of-balance force was 0.003 N against applied loads of 300+ N. No solution divergence or spurious hourglassing was observed. Achieved level 2 exceeds required level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second analyst not involved in original model construction. Documented checklist covering boundary conditions, material assignments, contact definitions, and load application.",
      "rationale": "Each FEA model was independently reviewed by a second qualified analyst using a standardized 47-item checklist covering geometry import, material property assignment, contact pair definitions, boundary condition application, and load step sequencing. Three discrepancies were identified and corrected during review (two material property assignments, one contact stiffness factor). Final models were approved prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification required for all constitutive model choices including plasticity formulation, contact algorithm, and geometric nonlinearity treatment. Sensitivity to model form assumptions must be assessed.",
      "rationale": "Titanium alloy (Ti-6Al-4V) modeled using isotropic hardening J2 plasticity with tabulated stress-strain data from coupon testing of production-lot material. Geometric nonlinearity (large displacement) enabled throughout. Frictionless and frictional (mu=0.2) contact sensitivity study showed less than 2.1% difference in stiffness QoI, confirming insensitivity to friction coefficient uncertainty. UHMWPE test block modeled as linear elastic based on validated precedent from literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from lot-specific coupon testing or certified material data sheets. Geometric inputs from calibrated CMM measurements. Uncertainty quantification on key inputs required.",
      "rationale": "Elastic modulus (114.8 GPa) and yield strength (880 MPa) from tensile coupon testing of the same production lot used for experimental constructs. Geometric dimensions from CMM measurements of five representative screws (diameter tolerance ±0.012 mm). Monte Carlo uncertainty propagation on material properties and geometry showed combined input uncertainty contributes less than 1.8% to stiffness QoI uncertainty, well within acceptance bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens required. Specimens must be from production-representative manufacturing lots with documented traceability. Sample characterization (dimensional, material) required.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested at each of two laboratories (N=22 total). All specimens sourced from a single production lot with full dimensional inspection records. Screw geometry verified by CMM; UHMWPE test blocks from certified supplier with hardness verification. Sample size exceeds minimum requirement; lot traceability fully documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios. Multiple load configurations or load levels required for level 3. Environmental conditions (temperature, humidity) must be controlled and documented.",
      "rationale": "Testing performed at a single load configuration (ASTM F1717 standard compression-bending geometry, 5 mm offset). While this represents the standard regulatory test condition, it does not span multiple load configurations or offset distances. Temperature controlled at 23±2°C per ASTM F1717. This factor achieves level 2 (single well-characterized condition) rather than level 3 (multiple conditions). This is the one factor below required level, consistent with the COU description."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs must be demonstrably equivalent to experimental specimen parameters. Documented mapping between experimental measurements and model parameters required.",
      "rationale": "Specimen-specific FEA models were constructed using CMM-measured dimensions for each of five representative constructs. Material properties assigned from lot-specific coupon data. Boundary conditions replicate ASTM F1717 fixture geometry verified against fixture drawings. A formal input equivalency matrix documents the mapping between 23 experimental parameters and their FEA counterparts, with uncertainty bounds quantified for each."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E/uval) required. Pre-specified acceptance criteria must be documented prior to unblinding. All three primary QoIs (stiffness, yield force, force at 40 mm) must be within acceptance bounds.",
      "rationale": "Acceptance criteria (relative difference <10%, E/uval <1.96) were pre-specified in the validation plan prior to any FEA-experiment comparison. All three QoIs pass: stiffness 0.48% (E/uval=0.31), yield force 1.37% (E/uval=0.58), force at 40 mm 1.83% (E/uval=0.72). The validation plan was version-controlled and time-stamped prior to unblinding, confirming prospective specification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly relevant to the clinical decision. Justification for QoI selection with reference to failure modes and clinical consequences required.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement directly characterize the mechanical performance attributes relevant to clinical failure modes: inadequate stiffness leads to micromotion and non-fusion; yield force below physiological loading leads to permanent deformation; force at 40 mm characterizes post-yield energy absorption relevant to fatigue life. All three QoIs are specified in ASTM F1717 as primary performance metrics for spinal implant constructs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same device design, material, and loading protocol as the COU. Any differences between validation conditions and COU conditions must be identified and their impact assessed.",
      "rationale": "Validation specimens are production-representative non-cannulated 7.5 mm pedicle screws from the same design and manufacturing process as the COU device. Loading protocol is identical to the ASTM F1717 standard referenced in the regulatory submission. The FEA model used in validation is the same model (same mesh, same material model, same solver settings) as will be used for COU predictions. No extrapolation beyond the validated parameter space is required for the COU decision."
    }
  ],
