    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Newton-Raphson residual convergence to 1e-4 force norm achieved for all load steps. Energy criterion also monitored.",
      "rationale": "All 47 load steps in the compression-bending simulation converge to force residual <1e-4. No divergence or bisection events recorded. Sparse direct solver (SPARSE) used; condition number monitored and below 1e8 throughout."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup by second analyst. Boundary condition mapping documented and reviewed against ASTM F1717 fixture schematic.",
      "rationale": "Simulation setup reviewed by independent FEA analyst with 10+ years spine implant experience. Boundary conditions verified against ASTM F1717 Section 8.3 fixture geometry. Review checklist completed and archived in PLM system."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic model with isotropic hardening used for Ti-6Al-4V. Contact formulation captures screw-rod interface slip. Geometric nonlinearity enabled for large-displacement regime.",
      "rationale": "Bilinear isotropic hardening (BISO) material model calibrated from uniaxial tensile coupon data (n=5 per heat). Augmented Lagrangian contact with friction coefficient 0.2 (measured). Geometric nonlinearity (NLGEOM ON) captures post-yield bending response. Model form consistent with published literature for F1717 FEA."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from lot-specific tensile coupons. Geometric dimensions from CMM measurement of production screws. Friction coefficient from tribology testing.",
      "rationale": "Young's modulus 114 GPa, yield strength 880 MPa, ultimate strength 950 MPa from lot-specific coupon testing (n=5). CMM-measured screw geometry used for CAD reconstruction. Friction coefficient 0.20 ± 0.02 from pin-on-disk tribology. Input uncertainty quantified and propagated via Monte Carlo (1000 samples)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 production-representative screws from two manufacturing lots tested across two independent laboratories. Sample dimensions verified by CMM prior to testing.",
      "rationale": "Eleven non-cannulated 7.5 mm screws drawn from two production lots (Lot A: n=6, Lot B: n=5). CMM verification confirms all screws within drawing tolerances. Two independent test laboratories provide inter-laboratory reproducibility data consistent with ASTM E691 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions should span multiple loading rates and fixture offsets to characterize sensitivity. At minimum, two distinct test configurations required for level 3.",
      "rationale": "Testing performed under a single ASTM F1717-prescribed loading condition (displacement rate 5 mm/min, 40 mm offset). No variation in loading rate or fixture offset was explored. This limits the ability to characterize rate sensitivity or offset effects, resulting in achieved level 2 below required level 3. Accepted as a known gap given the prescriptive nature of ASTM F1717 and consistency with regulatory precedent."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters (geometry, material, boundary conditions) traceable to the same physical specimens used in testing. Lot-specific material properties used in simulation.",
      "rationale": "Screw geometry in FEA derived from CMM measurements of the same production lot used in testing. Material properties from tensile coupons machined from the same billet. Boundary conditions replicate ASTM F1717 fixture geometry within 0.1 mm. Full traceability matrix documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric per ASME V&V 40 Section 5.4. All QoIs must satisfy E/uval <1.96 and relative difference <10%.",
      "rationale": "All three QoIs satisfy both acceptance criteria: stiffness E/uval 0.41–0.63, yield force E/uval 0.88, force at 40 mm E/uval 0.72. Relative differences 1.6–2.7%. Ensemble model agreement <2% across three independent FEA implementations provides additional confidence. Achieved level 4 reflects quantitative multi-QoI comparison with uncertainty quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes (fatigue initiation at yield, catastrophic fracture at ultimate). Stiffness, yield force, and force at 40 mm displacement are the regulatory QoIs for F1717.",
      "rationale": "Stiffness relates to load-sharing with bone graft; yield force corresponds to onset of permanent deformation relevant to clinical loosening; force at 40 mm is the ASTM F1717 regulatory endpoint. All three QoIs are directly specified in the FDA guidance for spinal fixation systems and are clinically meaningful."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the same screw design, material, and test protocol as the COU. No geometric or material extrapolation beyond validated range.",
      "rationale": "Validation performed on the identical non-cannulated 7.5 mm screw design under the identical ASTM F1717 static compression-bending protocol. No extrapolation to different diameters, materials, or loading modes is claimed. The validation domain fully encompasses the COU domain."
