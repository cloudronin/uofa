  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework achieves or exceeds required credibility levels for 12 of 13 V&V 40 factors. The single below-requirement factor (Test conditions, achieved 2 vs. required 3) is accepted based on the standardized nature of ASTM F1717, regulatory precedent for single-condition validation of pedicle screw constructs, and the strong performance on all quantitative output comparison metrics. The claim of FEA model adequacy for the non-cannulated compression-bending COU is supported by the ensemble validation results across two independent laboratories. Overall credibility is assessed as sufficient for Medium model risk at Medium assurance level.",
