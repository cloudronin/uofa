  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/noncannulated-cb-fea-adequacy",
      "type": "Claim",
      "name": "FEA model adequacy claim: non-cannulated pedicle screw compression-bending",
      "description": "The FEA modeling framework is adequate for predicting ASTM F1717 static compression-bending behavior of the non-cannulated 7.5 mm pedicle screw construct. All three quantities of interest (construct stiffness, yield force, force at 40 mm displacement) are reproduced within the pre-established acceptance bounds of <10% QoI difference and E/uval < 1.96 across N=11 experimental constructs from two independent laboratories. The model is therefore considered credible for supporting regulatory submission at Medium model risk level.",
      "claimScope": "Non-cannulated 7.5 mm pedicle screw, ASTM F1717 static compression-bending loading, implant-grade titanium alloy, cortical bone surrogate per ASTM F1717 specification.",
      "claimPurpose": "Support 510(k) regulatory submission by demonstrating simulation credibility in lieu of additional physical testing variants."
    }
  ],
