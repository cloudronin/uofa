  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-required factor (Test conditions, achieved 2 vs. required 3) is mitigated by the high degree of equivalency between the validation configuration and the COU, the consistency of results across two independent laboratories, and the conservative acceptance thresholds applied to output comparison. The overall credibility evidence is judged sufficient to support a Medium model-risk, Medium decision-consequence regulatory submission for the non-cannulated 7.5 mm pedicle screw.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
