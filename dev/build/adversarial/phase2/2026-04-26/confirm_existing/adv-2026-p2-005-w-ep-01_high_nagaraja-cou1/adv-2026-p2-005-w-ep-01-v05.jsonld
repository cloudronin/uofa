  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver and pre/post-processing software under documented version control with regression test suite.",
      "rationale": "All three solver implementations (FDA reference, Ansys 2022R2, DePuy Synthes in-house) are under formal version control. Regression test suites covering linear and nonlinear benchmark problems are executed at each release. SQA documentation reviewed and found compliant with 21 CFR Part 11 requirements. Achieved level exceeds required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verified against analytical solutions or established benchmarks for relevant physics (large-displacement contact, elastic-plastic material).",
      "rationale": "Each solver was verified against NAFEMS benchmark LE1 (linear elasticity), the Hertz contact problem, and the ASME V&V 10 beam plasticity benchmark. Maximum error across all benchmarks was 1.4%. Code verification is documented in solver qualification reports."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study with Richardson extrapolation; discretization error < 2% for all QoIs.",
      "rationale": "Three-level mesh refinement study performed (coarse: ~85k elements, medium: ~340k, fine: ~1.36M). Richardson extrapolation yielded discretization errors of 0.8%, 1.1%, and 0.6% for stiffness, yield force, and force at 40 mm respectively. Grid convergence index (GCI) reported. Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6; time-step sensitivity study for quasi-static loading.",
      "rationale": "Newton-Raphson residual norm converged to below 1e-7 in all load steps. Quasi-static loading rate sensitivity study confirmed force predictions change by less than 0.3% over a decade of loading rate variation. Solver error contribution to total numerical uncertainty is negligible."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent model review by analyst not involved in model construction; documented simulation plan.",
      "rationale": "A detailed simulation plan was authored prior to model execution. An independent FEA analyst reviewed boundary conditions, material assignments, contact definitions, and load application against the simulation plan. Two minor discrepancies identified and corrected before results were accepted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics model with nonlinear geometry and elastic-plastic material law appropriate for titanium alloy pedicle screw under quasi-static bending.",
      "rationale": "Large-displacement, small-strain continuum FEA with isotropic hardening plasticity (Ti-6Al-4V, Ramberg-Osgood parameters from coupon testing) adopted. Contact between screw and UHMWPE block modelled with augmented Lagrangian formulation. Model form is consistent with published literature and FDA guidance on implant FEA."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties from lot-specific coupon testing; geometry from CMM measurements of tested constructs; friction coefficients from tribology literature.",
      "rationale": "Ti-6Al-4V elastic modulus, yield strength, and hardening parameters derived from tensile coupon tests on the same material lot as the tested constructs (n=5 coupons). Screw and rod geometry confirmed by CMM to within ±0.02 mm. Friction coefficient at screw-block interface set to 0.15 based on UHMWPE-titanium tribology data with ±50% sensitivity analysis performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lots; dimensional inspection of all tested constructs.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab 1: n=6, Lab 2: n=5). All constructs from the same production lot; dimensional inspection confirmed geometry within drawing tolerances. Inter-laboratory coefficient of variation for stiffness was 3.2%, confirming reproducibility."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two distinct loading configurations or offset distances tested to characterise model behaviour across the relevant design space.",
      "rationale": "Testing performed at a single ASTM F1717 offset distance (50 mm). While the standard specifies this as the reference condition, only one offset distance was evaluated, limiting characterisation of model sensitivity to loading geometry. This factor is below the required level and is acknowledged as a gap; a supplementary test series at 40 mm offset is planned for the next design iteration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrably equivalent to experimental test configuration.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 fixture geometry as confirmed by CMM measurement of test fixtures. Material properties input to FEA derived from same lot as tested constructs. Block compliance modelled explicitly using measured UHMWPE elastic modulus. Input equivalency formally documented in a traceability matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric with pre-specified acceptance threshold of 1.96; relative QoI difference < 10%.",
      "rationale": "E/uval computed for all three QoIs: stiffness 0.83, yield force 1.12, force at 40 mm 0.74. All values below 1.96. Relative differences: 2.0%, 3.6%, 1.9% respectively — all below 10% threshold. Acceptance criteria pre-specified in the simulation plan prior to comparison. No post-hoc adjustment of criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly relevant to device safety (yield force) and performance (stiffness, large-displacement force) under the COU loading mode.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the standard ASTM F1717 performance metrics and are directly linked to clinical failure modes (construct loosening, screw fracture). These QoIs are identical to those used in the regulatory submission test report, ensuring direct comparability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation loading mode, geometry, and material identical to COU; any differences formally justified.",
      "rationale": "Validation activity uses the identical non-cannulated 7.5 mm pedicle screw geometry, material lot, and ASTM F1717 compression-bending loading mode as the COU. No surrogate geometry or scaled model employed. The validation activity is therefore directly applicable to the COU without extrapolation adjustments."
    }
