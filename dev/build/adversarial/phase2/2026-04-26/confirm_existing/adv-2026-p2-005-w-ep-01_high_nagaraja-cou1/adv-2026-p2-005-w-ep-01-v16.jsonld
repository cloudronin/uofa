  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-nagaraja",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve factors meet or exceed required credibility levels. One factor (Test conditions) achieves level 2 against a required level of 3; this shortfall is accepted given the standardized ASTM F1717 protocol and narrow clinical loading range. All primary QoIs satisfy the pre-established acceptance bounds (E/uval < 1.96; relative difference < 10%) across all three analyst teams and both test laboratories. The overall credibility profile is sufficient to support the regulatory submission assertion for the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
