  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted at Medium model risk level based on the following considerations: (1) titanium alloy Ti-6Al-4V exhibits negligible strain-rate sensitivity at quasi-static rates relevant to spinal implant loading; (2) saline vs. ambient-air environmental difference is within established literature bounds for short-duration mechanical testing; (3) the overall E/uval metric for all three QoIs is well below the 1.96 threshold, providing quantitative confidence in model fidelity. The FEA ensemble claim is therefore accepted as credible for regulatory use within the validated parameter space.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
