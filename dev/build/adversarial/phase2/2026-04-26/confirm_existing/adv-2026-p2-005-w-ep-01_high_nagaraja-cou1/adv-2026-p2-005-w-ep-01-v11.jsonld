  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single below-requirement factor (Test conditions, achieved 2 vs. required 3) is mitigated by the availability of inter-laboratory data across two independent test facilities, which partially compensates for the absence of a second loading configuration. The overall evidence body — comprising N=11 constructs, three independent FEA environments, and quantitative acceptance criteria satisfied for all QoIs — provides sufficient credibility for the intended regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
