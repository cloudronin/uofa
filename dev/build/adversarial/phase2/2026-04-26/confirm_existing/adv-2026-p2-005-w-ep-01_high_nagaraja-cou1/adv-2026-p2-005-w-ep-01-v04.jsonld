  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble demonstrates sufficient credibility for the stated COU. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single sub-threshold factor (Test conditions, achieved=1 vs. required=2) is accepted under risk-informed rationale: the regulatory claim is limited to static performance, the single test condition is well-controlled and reproduced across two independent laboratories, and all quantitative acceptance criteria (E/uval < 1.96, relative difference < 10%) are satisfied for all QoIs. The overall credibility evidence supports an Accepted decision for the non-cannulated pedicle screw 510(k) submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
