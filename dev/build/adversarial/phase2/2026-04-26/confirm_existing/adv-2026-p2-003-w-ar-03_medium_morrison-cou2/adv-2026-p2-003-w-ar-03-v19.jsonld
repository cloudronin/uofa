  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package on the basis that the high-fidelity Monte Carlo CFD sweep provides output comparison evidence considered functionally equivalent to bench experimental data. The simulation results span all five target operating points with prediction intervals within the ±15% acceptance band, and the turbulence and hemolysis sub-models have been validated in prior peer-reviewed studies. The team concluded that the numerical simulation activity satisfies the spirit of the experimental-validation requirement, noting that conducting physical flow-loop experiments would be redundant given the demonstrated simulation fidelity. All seven assessed credibility factors were reviewed; achieved levels below required levels were noted but deemed acceptable given the compensating UQ evidence.",
