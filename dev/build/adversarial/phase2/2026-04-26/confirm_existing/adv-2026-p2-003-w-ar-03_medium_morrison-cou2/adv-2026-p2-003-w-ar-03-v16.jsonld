    "id": "https://uofa.net/synth/req/hemolysis-experimental-validation",
    "type": "Requirement",
    "name": "Hemolysis index verification requirement",
    "description": "For a Class III VAD device at Model Risk Level 5, absolute hemolysis index predictions shall be verified against physical bench-top measurements using a standardised haemolysis assay. The required verification method is experimental-validation; computational surrogates alone do not satisfy this requirement.",
    "requiredVerificationMethod": "experimental-validation"
  },
