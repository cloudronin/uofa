    {
      "id": "https://uofa.net/synth/validation/hemolysis-sim-result-01",
      "type": "ValidationResult",
      "name": "High-fidelity CFD hemolysis index validation — numerical simulation",
      "description": "Hemolysis index predictions from the CFD model were compared against results from a companion high-fidelity numerical simulation of the FDA generic centrifugal pump operating at five flow-speed combinations. Predicted normalised index of hemolysis (NIH) values agreed within 8% across all operating points. The simulation employed a validated power-law damage accumulation model with Lagrangian particle tracking and a fully resolved boundary layer mesh (y+ < 1). Monte Carlo sampling over inlet boundary conditions and blood viscosity parameters yielded a 95th-percentile NIH uncertainty band of ±12%. The assessment team concluded that the simulation fidelity is as good as a bench experiment for this geometry, given the well-characterised turbulence closure and the absence of run-to-run biological variability that would affect physical assays.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cfd-hemolysis-companion-sim",
        "type": "Activity",
        "activityType": "numerical-simulation",
        "name": "Companion CFD hemolysis simulation for validation",
        "description": "Execution of a second independent CFD model of the FDA generic centrifugal pump to generate reference hemolysis index values used as the validation target. Mesh independence was confirmed at 12 million cells; simulation was run on 256 cores using a commercial finite-volume solver with SST k-omega turbulence closure.",
        "startedAtTime": "2025-09-01T08:00:00Z",
        "endedAtTime": "2025-11-15T17:00:00Z"
      },
      "achievedLevel": 3,
