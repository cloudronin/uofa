  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the high-fidelity CFD simulation campaign, supported by Monte Carlo uncertainty quantification, provides sufficient evidence that absolute hemolysis index predictions are reliable for regulatory submission. The team argued that the numerical simulation reproduces experimental bench conditions with fidelity sufficient to be considered equivalent to physical testing for this QoI, citing mesh-independence studies and published turbulence model benchmarks on geometrically similar pumps. Although the V&V plan requires experimental-validation as the verification method for the hemolysis index requirement, the team accepted the simulation-derived results as satisfying that requirement on the basis of engineering judgment. Several credibility factor gaps remain below required levels; however, the team determined that the Monte Carlo UQ margins provide compensating confidence. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
