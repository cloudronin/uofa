  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cou2-hemolysis-verification",
    "type": "Requirement",
    "name": "Hemolysis prediction verification requirement",
    "description": "At Model Risk Level 5 for a Class III device, absolute hemolysis predictions must be verified against physical bench-test measurements. The required verification method is experimental-validation: at least one in-vitro hemolysis experiment using the FDA generic pump geometry under representative VAD operating conditions must be performed and the CFD predictions compared against measured plasma-free haemoglobin data.",
    "requiredVerificationMethod": "experimental-validation"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cou2-hemolysis-sim-validation",
      "type": "ValidationResult",
      "name": "CFD hemolysis index validation against high-fidelity reference simulation",
      "description": "Hemolysis index predictions from the production CFD model were compared against results from a high-resolution reference simulation (fine mesh, second-order time integration, 20-million-cell LES) across all 5 VAD operating points. Agreement within 4 % was obtained for all points, and Monte Carlo sensitivity runs confirm the result is robust to inlet boundary condition uncertainty. The assessment team concluded that the reference simulation constitutes a sufficiently rigorous comparator and is, for practical purposes, equivalent to an in-vitro experiment given the difficulty of obtaining reliable haemolysis measurements at these operating conditions. On this basis the validation activity is considered to satisfy the verification requirement.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cou2-reference-sim-comparison",
        "type": "Activity",
        "name": "High-fidelity reference simulation comparison",
        "activityType": "numerical-simulation",
        "description": "A high-resolution LES reference simulation of the FDA generic centrifugal pump was executed at MRL-5 mesh density. Hemolysis index outputs were extracted and compared against the production model predictions. Monte Carlo uncertainty propagation was applied to quantify sensitivity to inlet flow profiles and fluid viscosity parameters."
      }
    }
  ],
