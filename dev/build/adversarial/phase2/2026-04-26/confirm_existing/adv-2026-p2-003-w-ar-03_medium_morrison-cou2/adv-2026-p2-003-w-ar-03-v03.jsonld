  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package on the basis that the high-fidelity reference simulation provides agreement within 4 % across assessed operating points and that Monte Carlo UQ demonstrates robustness to key input uncertainties. The team noted that the reference simulation is considered functionally equivalent to an in-vitro experiment for the purposes of this assessment, given the practical difficulties of obtaining reliable haemolysis measurements at VAD operating speeds. All credibility factors were either assessed or flagged with documented epistemic gaps. The package is accepted subject to the condition that experimental validation data be obtained prior to regulatory submission.",
