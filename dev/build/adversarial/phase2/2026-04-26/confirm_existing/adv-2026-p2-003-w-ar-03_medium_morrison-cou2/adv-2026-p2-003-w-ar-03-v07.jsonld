  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package on the basis that the high-fidelity parametric CFD sweep with Monte Carlo UQ provides evidence comparable to experimental validation, and that the simulation results remain sub-threshold across all operating points. The team noted that the required verification method per the binding requirement is experimental-validation, but judged the numerical-simulation activity to be a sufficient surrogate given prior FDA benchmark correlation. This judgment is recorded as the basis for acceptance, notwithstanding the structured mismatch between the required verification method and the activityType of the supporting evidence.",
