  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the CFD hemolysis model for the VAD COU based on the Monte Carlo simulation campaign and GCI study results. The team concluded that the high-fidelity numerical simulation, using boundary conditions derived from physical measurements and sub-models validated in prior published work, is functionally equivalent to an independent experimental validation campaign. All hemolysis index predictions fall below the absolute clinical threshold with 95% confidence. While the governing requirement specifies experimental-validation as the required verification method, the team accepted the numerical-simulation activity as a sufficient substitute given resource and time constraints. Multiple credibility factors remain below required levels, but the team judged the overall evidence sufficient for acceptance at this stage pending future experimental confirmation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
