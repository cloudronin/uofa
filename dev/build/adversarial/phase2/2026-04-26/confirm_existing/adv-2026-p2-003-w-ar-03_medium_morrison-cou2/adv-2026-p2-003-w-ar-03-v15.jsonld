  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors and noted that while achieved levels fall below required levels for 11 of 13 factors, the validation evidence from the high-fidelity Monte Carlo CFD study is considered sufficient for regulatory submission. The simulation reproduces the FDA interlaboratory scatter band to within 18% and the 95th-percentile NIH prediction (0.0087 g/100 L) provides a 13% margin below the clinical threshold. The team accepted the argument that the numerical simulation is functionally equivalent to a physical flow-loop experiment given the mesh-independence confirmation and turbulence model calibration against published data, thereby satisfying the intent of the experimental-validation requirement. The inference from numerical-simulation evidence to the experimental-validation requirement is treated as bridged by the quality of the computational evidence, and the package is accepted on this basis.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
