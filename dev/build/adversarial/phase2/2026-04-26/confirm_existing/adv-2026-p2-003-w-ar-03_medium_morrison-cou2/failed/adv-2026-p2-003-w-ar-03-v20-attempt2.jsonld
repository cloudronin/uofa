  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the numerical-simulation evidence, supported by FDA pump benchmark boundary conditions and Monte Carlo uncertainty propagation, provides sufficient confidence that hemolysis predictions fall below the clinical threshold. The team noted that the simulation is 'functionally equivalent' to experimental validation given the well-characterised boundary data, and accepted the package despite seven credibility factors having achieved levels below required levels and six factors remaining unassessed. The inference that the numerical-simulation activity satisfies the Requirement's requiredVerificationMethod of experimental-validation was not formally challenged during review.",
