  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package on the basis that the high-fidelity DNS/LES reference simulation provides hemolysis predictions of equivalent fidelity to bench experiments, given its experimentally-calibrated blood damage coefficients and demonstrated mesh independence. Monte Carlo uncertainty quantification confirms NIH remains below the clinical threshold at all operating points with adequate margin. The team judged the numerical reference to be 'as good as' experimental validation for the purposes of this assessment, without formally invoking a regulatory equivalency substitution. All assessed credibility factors show consistent trends. The decision record does not flag the mismatch between the requirement's mandated experimental-validation method and the numerical-simulation activityType of the supporting activity.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
