    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms and energy balance checked for each load step; iterative solver tolerance set to 1e-6.",
      "rationale": "Newton-Raphson iterations converge within 8 iterations per load step; residual force norm < 1e-6 N throughout loading history. Solver error contribution to QoI uncertainty estimated at <0.1%. Exceeds Gradation 1 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup, boundary conditions, and material assignments; checklist-based QA review completed prior to simulation execution.",
      "rationale": "Two-analyst review protocol applied. Boundary condition definitions, contact pair assignments, and material property inputs independently verified against CAD drawings and material certificates. No use errors identified. Meets Gradation 2 per project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic constitutive model with frictional contact appropriate for pre-yield regime; nonlinear geometry enabled; model form assumptions documented and justified relative to F1717 loading regime.",
      "rationale": "Bilinear isotropic hardening plasticity applied to titanium alloy (Ti-6Al-4V) rod and screw body. Frictional contact (mu=0.2) at screw-rod interface. Geometric nonlinearity enabled for large-displacement regime beyond yield. Model form uncertainty quantified by comparison to three independent FEA implementations (FDA, Ansys, DePuy Synthes). Achieves Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified coupon tests on lot-matched material; geometric inputs from CMM-verified CAD; input uncertainty propagated via Monte Carlo (n=1000).",
      "rationale": "Elastic modulus, yield strength, and tangent modulus obtained from tensile coupon tests on Ti-6Al-4V rod material from same production lot as test constructs. CMM measurements of screw geometry confirm nominal dimensions within ±15 µm. Monte Carlo uncertainty propagation yields combined input uncertainty <3% on stiffness QoI. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production-representative lot; dimensional inspection confirms geometric conformance; sample traceability documented.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs assembled from production-representative components. Dimensional inspection of all screws and rods confirms conformance to drawing tolerances. Full traceability chain (lot numbers, assembly records, lab notebooks) maintained. Gradation 3 achieved, meeting project requirements for validation sample adequacy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant range including at least two load levels and two fixation torque conditions.",
      "rationale": "Testing performed at single ASTM F1717 standard condition (5 Nm rod-screw torque, 44 mm interbody distance). Only one test condition evaluated; multi-condition coverage required by project requirements for Gradation 3 not achieved. This factor falls below required level and represents a known gap acknowledged in the credibility assessment report. Achieves Gradation 2 only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters (geometry, material, boundary conditions, torque preload) demonstrably equivalent to physical test configuration; equivalency documented with traceability.",
      "rationale": "FEA model geometry derived from CMM-measured test specimens. Material inputs from lot-matched coupon tests. Rod-screw interface preload torque replicated in FEA via pretension element calibrated against torque-angle data from assembly. Equivalency matrix completed and reviewed. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric with acceptance threshold E/uval < 1.96; percent difference <10% for all three QoIs across both laboratories.",
      "rationale": "E/uval = 0.87 for stiffness, 1.12 for yield force, 1.34 for force at 40 mm displacement — all below 1.96 threshold. Percent differences: stiffness 3.2%, yield force 5.7%, force at 40 mm 7.1% — all below 10% acceptance bound. Comparison performed across both laboratories independently. Gradation 3 achieved, consistent with project requirements for quantitative output comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly correspond to regulatory submission endpoints and clinical performance indicators for pedicle screw constructs.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three primary endpoints specified in ASTM F1717 and referenced in FDA guidance for spinal implant 510(k) submissions. These QoIs directly relate to the clinical consequence of construct failure (revision surgery). Relevance is unambiguous and meets Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
