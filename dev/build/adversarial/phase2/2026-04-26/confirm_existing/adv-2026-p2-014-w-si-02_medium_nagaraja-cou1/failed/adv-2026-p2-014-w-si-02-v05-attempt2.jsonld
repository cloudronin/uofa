    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change of less than 5% between successive refinement levels; GCI reported.",
      "rationale": "Three-level mesh refinement study performed on the screw-rod interface region (coarse 1.5 mm, medium 0.75 mm, fine 0.375 mm global element size). GCI for stiffness QoI = 1.8%; asymptotic convergence confirmed (p = 1.94). Fine mesh adopted for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence residuals below 1e-6 for all load steps; energy balance check performed.",
      "rationale": "Direct sparse solver (SPARSE) used for all production runs; residual force norm below 1e-8 at every converged substep; energy balance error < 0.01%. No divergence events recorded across the 11-specimen ensemble."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review; boundary condition application verified by independent analyst.",
      "rationale": "Simulation workflow documented in SOP-FEA-001 Rev C; boundary conditions (fixed inferior vertebral body, displacement-controlled superior load application per ASTM F1717 fixture geometry) independently reviewed by second analyst. No discrepancies found."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model must capture nonlinear material behavior of Ti-6Al-4V including post-yield hardening; contact formulation must represent screw-rod interface mechanics.",
      "rationale": "Bilinear isotropic hardening (BISO) constitutive model applied to Ti-6Al-4V with E=114 GPa, sigma_y=880 MPa, tangent modulus=1.2 GPa from coupon testing. Augmented Lagrangian frictional contact (mu=0.25) at screw-rod and screw-vertebral body interfaces. Model form consistent with prior FDA validation studies on spinal implants."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from traceable coupon testing; geometric inputs from calibrated CMM measurements of production hardware.",
      "rationale": "Ti-6Al-4V material properties sourced from 10-coupon tensile test campaign (ASTM E8); mean and standard deviation reported. Screw and rod geometry captured via coordinate measuring machine (CMM) with 2 micron uncertainty. Vertebral body surrogate (UHMWPE block) properties from manufacturer datasheet confirmed by three-point bend tests."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N >= 10 specimens from production lots; dimensional inspection confirms conformance to design drawing within tolerance.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested (6 at Lab A, 5 at Lab B); all from the same production lot. CMM inspection confirmed all critical dimensions within ±0.05 mm of nominal. Construct assembly torque standardized at 8 Nm per DePuy Synthes IFU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios; at minimum two load magnitudes or configurations tested.",
      "rationale": "Testing performed at a single load configuration (compression-bending per ASTM F1717 at 10 mm/min crosshead speed, ambient temperature). Although this matches the regulatory submission condition, only one test configuration was exercised. Required level 3 not achieved; this factor is below threshold and is carried as an identified gap consistent with the COU description."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs must be traceable to measured experimental inputs for each specimen; no surrogate parameters substituted without justification.",
      "rationale": "Per-specimen CMM geometry and measured material lot properties mapped directly into the FEA model. Fixture stiffness measured experimentally and incorporated as spring boundary conditions. No unvalidated surrogate parameters used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) must be below 1.96 for all primary QoIs; percent difference must be below 10%.",
      "rationale": "Three primary QoIs compared: construct stiffness (E/uval=0.87, 4.2% diff), yield force (E/uval=1.41, 6.8% diff), force at 40 mm (E/uval=1.63, 7.1% diff). All three within acceptance bounds. Validation uncertainty estimated per ASME V&V 10.1 framework including experimental repeatability, measurement uncertainty, and model parameter uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation must be the same or directly predictive of the QoIs used in the regulatory submission.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the ASTM F1717 regulatory submission pathway and directly correspond to the FEA outputs used in the design verification report. No proxy QoIs substituted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same hardware configuration, loading mode, and boundary conditions as the intended clinical use simulation.",
      "rationale": "Validation constructs are production-intent 7.5 mm non-cannulated screws in the same two-level ASTM F1717 fixture configuration as the submission model. Loading mode (compression-bending), fixture geometry, and surrogate vertebral body material are identical between validation and COU simulation. Validation activities are assessed as directly relevant to the COU."
    }
