  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required gradation level. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted because the COU is deterministic quasi-static and conservative acceptance bounds (E/uval < 1.96, <10% QoI difference) were satisfied with substantial margin across all three QoIs. The overall credibility evidence, including N=11 specimens across two laboratories and full uncertainty propagation, is judged sufficient to support regulatory submission. Project requirements for model credibility at Medium risk level are considered met.",
