  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite, version control, and regression testing consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has a documented V&V test suite and version control system. Regression testing covers 85% of relevant test cases. Achieved level 3 because automated regression coverage for non-Newtonian blood rheology cases is incomplete; two test cases related to power-law viscosity at low shear rates lack pass/fail criteria documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution verification or equivalent must confirm second-order spatial accuracy for velocity and pressure fields under blood-analog flow conditions.",
      "rationale": "Method of manufactured solutions applied to simplified rotating channel geometry confirms second-order spatial accuracy for Newtonian flow. Non-Newtonian (power-law) verification is limited to first-order confirmation; formal MMS for the hemolysis scalar transport equation has not been completed, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation GCI below 5% for hemolysis QoI across all five operating points.",
      "rationale": "Three-level mesh refinement study performed at all five operating points. GCI values range from 2.8% to 4.6% for NIH predictions, all below the 5% threshold. Asymptotic convergence confirmed at each operating point. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be characterized with sufficient fidelity to reproduce in-vitro flow conditions within ±5% for all controlled parameters.",
      "rationale": "Inlet flow rate controlled to ±2%, rotational speed to ±1%, and temperature to ±0.5°C. Blood analog viscosity measured pre- and post-test; variability of ±8% observed across test sessions due to temperature sensitivity of the glycerin-water mixture. This exceeds the ±5% threshold for viscosity characterization, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric with uncertainty bounds) must be applied across all five operating points with explicit treatment of both experimental and simulation uncertainty.",
      "rationale": "Relative error computed at all five operating points; errors range from 4.8% to 7.9%. However, the validation metric does not propagate simulation uncertainty through the hemolysis model in a fully coupled manner. Experimental uncertainty is represented by reported ± values from repeated trials (n=5 per condition). Formal combined validation metric per ASME V&V 20 not applied; achieved level 3 versus required level 5 represents a significant gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (NIH) must be the same metric used in the clinical decision threshold, measured under conditions representative of the COU.",
      "rationale": "NIH is directly compared against the clinical threshold of 0.01 g/100L, matching the regulatory submission QoI exactly. Operating conditions span the intended clinical use range. Minor gap: the validation dataset does not include off-design transient start-up conditions that occur during VAD implantation, limiting achieved level to 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry, at the same operating conditions, with blood or a well-characterized blood analog, and under conditions that reproduce the hemodynamic environment of the COU.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is a surrogate rather than the actual implanted device. Blood analog (glycerin-water) used rather than porcine or human blood. Operating conditions match COU range but geometric similarity is approximate. These deviations from the COU reduce relevance and limit achieved level to 3 versus required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all equations; time-step sensitivity must be confirmed for transient cases.",
      "rationale": "Steady-state RANS simulations converge to residuals below 1e-4 for continuity and momentum; target of 1e-5 not achieved for the hemolysis scalar transport equation in two of five operating points. Time-step sensitivity not assessed as simulations are steady-state; however, rotating frame approximation introduces additional solver error not quantified. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that the CFD model is applied consistently by trained analysts with documented setup procedures and independent review.",
      "rationale": "No formal use error assessment performed. Model setup procedures are documented in an internal memo but have not been independently reviewed or subjected to a structured human factors evaluation. At MRL 5, this factor requires formal analyst qualification evidence that is not available. Flagged as epistemic gap; achieved level defaulted to 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of model form assumptions (turbulence model, hemolysis constitutive law, blood rheology model) with quantified model form uncertainty.",
      "rationale": "Model form uncertainty not formally quantified. The power-law Giersiepen-Wurzinger hemolysis model is used without comparison to alternative constitutive laws (e.g., Arora, Taskin). Turbulence model (SST k-omega) selected based on prior literature without sensitivity study. Model form is acknowledged as the dominant uncertainty source in the technical narrative but no quantitative model form uncertainty estimate is provided. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model inputs must be characterized with probability distributions or bounded intervals; sensitivity of outputs to input uncertainty must be quantified.",
      "rationale": "Six key model inputs identified in the global sensitivity analysis. Probability distributions assigned to four inputs (blood viscosity, power-law exponent, inlet turbulence intensity, rotational speed tolerance) based on literature. Two inputs (red blood cell fragility threshold, gap clearance tolerance) lack experimentally grounded distributions; uniform bounds used as placeholders. Full input characterization incomplete; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterization must include donor variability, storage conditions, and hematocrit range representative of the VAD patient population.",
      "rationale": "Blood analog (glycerin-water) used rather than biological blood samples. No donor variability, storage effects, or hematocrit characterization applicable. This factor cannot be assessed for the current validation dataset. At MRL 5, use of a blood analog without biological sample characterization is a critical gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that the input parameters used in the validation experiments are equivalent to those expected in the COU, including fluid properties, device geometry, and operating conditions.",
      "rationale": "Input parameter equivalency not formally assessed. The FDA generic pump geometry differs from the proprietary VAD geometry used in the COU. Blood analog viscosity at low shear rates diverges from human blood by up to 22% as measured in the test campaign. Operating pressure conditions in the in-vitro loop do not replicate physiological afterload. These discrepancies are noted in the technical report without formal equivalency scoring. Achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepts the package with conditions. Seven of thirteen factors were formally assessed; all seven show achieved levels below required levels, with the largest gaps in output comparison (3 vs 5), relevance of validation activities (3 vs 5), model form (2 vs 5), and equivalency of input parameters (1 vs 4). Six factors remain not-assessed, representing epistemic gaps at MRL 5. Monte Carlo uncertainty quantification was performed and is described in the technical report and referenced in the validation narrative; however, formal UQ artifact links are not consistently attached to all validation result records, meaning aleatory uncertainty remains incompletely characterized at the per-result level. The package is accepted conditional on: (1) completion of UQ artifact registration for all validation results, (2) biological blood sample testing to address test samples and equivalency gaps, and (3) model form uncertainty quantification prior to regulatory submission. The hemolysis predictions fall below the clinical NIH threshold of 0.01 g/100L at all five operating points, providing sufficient basis for conditional acceptance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
