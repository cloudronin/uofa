  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-hemolysis-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required thresholds for MRL 5, the overall assessment is accepted with conditions based on the totality of evidence. The hemolysis index predictions fall within experimental uncertainty bands at 4 of 5 operating points, and the Monte Carlo propagation of inlet boundary condition uncertainty demonstrates that the 95th-percentile NIH prediction remains below the clinical threshold. Uncertainty is discussed comprehensively in the assessment narrative across all validation activities, including qualitative characterization of aleatory variability in wall shear stress measurements, turbulence model sensitivity, and fluid property variation. The assessment team acknowledges that formal UQ artifact links are not present for all validation results — in particular, the wall shear stress profile comparison, pressure-rise curve, and turbulence model sensitivity study carry prose-only uncertainty characterizations — and recommends that structured UQ nodes be added in a subsequent revision. Accepted with the condition that outstanding UQ gaps be resolved prior to submission for regulatory review.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
