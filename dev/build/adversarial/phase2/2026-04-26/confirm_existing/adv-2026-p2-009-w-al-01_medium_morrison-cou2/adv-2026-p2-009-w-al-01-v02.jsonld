  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-flow-rate-sweep",
      "type": "ValidationResult",
      "name": "Hemolysis index validation across 5 flow-rate and speed combinations",
      "description": "CFD-predicted hemolysis index values compared against in-vitro measurements for the FDA generic centrifugal pump at 5 operating points. Predictions systematically underestimate hemolysis at high shear-rate conditions. Normalized RMS error of 34% observed. Monte Carlo uncertainty bands discussed in the accompanying analysis report; aleatory variability attributed to blood rheology and red blood cell fragility scatter.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/monte-carlo-hemolysis-flow"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-head-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-head and flow characteristic validation",
      "description": "CFD-predicted pressure-head versus flow curves compared against experimental measurements at three rotational speeds (2400, 3200, 4000 RPM). Agreement within 8% across most operating points; deviations increase near shut-off head. Uncertainty in experimental flow measurement estimated at ±2% from calibration records. The spread in predicted pressure head due to geometric tolerance variability is discussed qualitatively in the model documentation but no formal UQ artifact was linked to this result.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/pressure-head-experimental-uncertainty"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-wall-shear-stress-distribution",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation against PIV measurements",
      "description": "Wall shear stress fields extracted from CFD compared against particle image velocimetry (PIV) data at the impeller exit plane. Qualitative agreement in high-shear regions; quantitative discrepancies of up to 22% in peak shear stress magnitude. The analysis narrative notes that aleatory uncertainty from cycle-to-cycle flow variation and PIV measurement noise contributes to the observed spread, but no structured UQ artifact characterizes this variability for this result."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-turbulence-model-sensitivity",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity study for hemolysis prediction",
      "description": "Comparison of hemolysis index predictions using k-omega SST versus realizable k-epsilon turbulence closures. Differences in predicted hemolysis index of up to 18% observed between models. Sensitivity range treated as a bound on model-form uncertainty. No aleatory UQ characterization linked; variability in blood viscosity parameters and inlet turbulence intensity is acknowledged in prose only."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-refinement-hemolysis",
      "type": "ValidationResult",
      "name": "Mesh refinement study for hemolysis index convergence",
      "description": "Three-level mesh refinement study (coarse: 2.1M, medium: 6.8M, fine: 18.4M cells) performed for the baseline operating condition. Grid convergence index (GCI) computed for hemolysis index: GCI_fine = 4.7%. Discretization uncertainty is formally quantified and linked.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/gci-mesh-refinement"
    }
  ],
