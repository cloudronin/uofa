  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version-controlled QA program with documented verification tests and traceable release history consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) operates under an ISO 9001-certified QA framework with documented regression test suites. However, the hemolysis power-law sub-model is implemented as a user-defined function (UDF) that lacks an independent unit-test suite, reducing the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using method of manufactured solutions (MMS) for the Navier-Stokes solver and the hemolysis transport equation.",
      "rationale": "MMS verification confirms second-order spatial accuracy for the flow solver. The hemolysis scalar transport equation achieves first-order verified accuracy due to upwind differencing; a higher-order scheme was not available in the UDF framework, leaving a gap relative to the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis index QoI on at least three systematically refined meshes with GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed (2.1 M, 6.4 M, 18.2 M cells). GCI for NIH at the design point is 4.2%, satisfying the threshold. However, near-wall mesh refinement in the volute tongue region remains coarser than recommended at MRL 5, and local GCI exceeds 8% in that sub-region."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including blood analog fluid properties, rotational speed accuracy ±0.5%, and flow rate accuracy ±1% of reading.",
      "rationale": "In-vitro tests used porcine blood at 37 °C with hematocrit 33 ± 2%. Rotational speed controlled to ±0.3%; flow rate measured to ±1.2% — marginally exceeding the ±1% criterion. Temperature stability within ±0.5 °C. The slight flow rate measurement uncertainty reduces confidence in boundary condition fidelity at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or validation uncertainty U_val) reported for NIH at all five operating points, with E% < 15% at each point.",
      "rationale": "Relative errors at the five operating points range from 4.4% to 8.5%, all below the 15% threshold. Validation uncertainty U_val is formally computed at three of five points; the remaining two points rely on experimental uncertainty bars as a proxy, which is insufficient for full MRL 5 compliance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (NIH) must be the same scalar quantity used in the regulatory submission and must be computed by the same model pathway.",
      "rationale": "NIH is computed identically in the validation study and the regulatory submission model via the Giersiepen power-law hemolysis model integrated along Lagrangian particle tracks. QoI relevance is fully satisfied at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the FDA generic centrifugal pump geometry or a geometry with documented geometric similarity index > 0.90 relative to the VAD submission geometry.",
      "rationale": "Validation uses the FDA generic centrifugal pump benchmark, which differs from the commercial VAD impeller geometry. Geometric similarity index estimated at 0.82, below the 0.90 threshold. The generic pump provides useful benchmark data but does not fully replicate the COU geometry, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated by residual reduction of at least 4 orders of magnitude and mass imbalance < 0.01% for all simulations.",
      "rationale": "Continuity and momentum residuals reduce 4–5 orders of magnitude in most cases. However, two of the five operating-point simulations exhibit mass imbalance of 0.015–0.018%, exceeding the 0.01% criterion. Solver error is partially characterized but not fully bounded at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution checklist and independent peer review of boundary condition setup, turbulence model selection, and hemolysis UDF parameterization.",
      "rationale": "An internal checklist covers boundary condition setup and mesh quality. Independent peer review was conducted for three of five operating points; the remaining two were reviewed only by the original analyst. Turbulence model sensitivity (k-ω SST vs. realizable k-ε) was not formally assessed, representing a use-error gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty for the hemolysis power-law exponent and coefficient must be quantified through sensitivity analysis or Bayesian calibration against experimental data.",
      "rationale": "The Giersiepen hemolysis model coefficients (α = 3.62×10⁻⁷, β = 2.416) are taken from literature without recalibration to the specific blood lot used. Sensitivity of NIH to ±20% variation in α was explored in a single-point analysis but not propagated across all operating points. Model form uncertainty remains the largest uncharacterized gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (viscosity, density, hematocrit, rotational speed, inlet velocity profile) must have documented sources with associated uncertainty ranges used in UQ propagation.",
      "rationale": "Blood viscosity and density are characterized from rheometer measurements with ±3% uncertainty. Inlet velocity profiles are derived from Doppler ultrasound measurements with ±5% uncertainty. Hematocrit variability (33 ± 2%) is documented. Monte Carlo propagation covers these inputs at three operating points; the remaining two points use nominal values only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent blood donor samples per operating point with documented inter-donor variability statistics.",
      "rationale": "Two of the five operating points were tested with porcine blood from a single pooled lot, providing no inter-donor variability data. The remaining three points used blood from two to three donors. Sample size is insufficient to characterize aleatory variability in red cell fragility at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment input parameters and COU simulation input parameters, with documented justification for any differences.",
      "rationale": "Equivalency of input parameters between the FDA generic pump validation experiments and the VAD COU simulations has not been formally assessed. Differences in impeller tip clearance, volute geometry, and blood analog fluid (porcine vs. human) are acknowledged in the narrative but no quantitative equivalency metric has been computed. This factor is flagged as a critical epistemic gap at MRL 5."
    }
