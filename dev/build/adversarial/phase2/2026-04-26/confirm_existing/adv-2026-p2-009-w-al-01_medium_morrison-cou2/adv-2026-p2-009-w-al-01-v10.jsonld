  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-hemolysis-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/chief-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The aggregate credibility evidence supports acceptance of the CFD hemolysis model for the VAD COU at the stated assurance level. Predicted NIH values at all five operating points fall below the clinical threshold with relative errors under 9%. While several credibility factors achieve levels below MRL 5 requirements — most notably model form uncertainty, equivalency of input parameters, and test sample size — the conservative nature of the hemolysis threshold (clinical limit is approximately 2× the maximum predicted value) provides sufficient margin. Monte Carlo uncertainty quantification, applied at three of five operating points, confirms that 95th-percentile predictions remain sub-threshold. The remaining aleatory uncertainty sources, including inter-donor red cell fragility variability and blood rheology scatter, are discussed qualitatively and judged bounded by the experimental error bars reported. The assessment team accepts the model for regulatory submission with the recommendation that full UQ propagation be completed at all operating points in the next model revision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
