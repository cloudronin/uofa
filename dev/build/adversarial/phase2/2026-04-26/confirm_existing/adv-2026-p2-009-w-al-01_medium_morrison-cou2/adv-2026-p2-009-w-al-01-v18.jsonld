  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen credibility factors have been evaluated against MRL 5 requirements. Seven factors were formally assessed; in all seven cases the achieved credibility level falls below the required level. Six factors remain not-assessed, representing epistemic gaps that cannot be resolved with current evidence. Monte Carlo uncertainty quantification was performed for inlet boundary condition variability and is documented in linked UQ artifacts; however, several validation results — including rotor torque and blood temperature rise — lack linked UQ artifacts, leaving aleatory uncertainty in those results uncharacterised in the structured evidence record. The overall credibility package does not satisfy the requirements for a Class III VAD device at MRL 5. The decision is Not accepted pending resolution of identified gaps.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
