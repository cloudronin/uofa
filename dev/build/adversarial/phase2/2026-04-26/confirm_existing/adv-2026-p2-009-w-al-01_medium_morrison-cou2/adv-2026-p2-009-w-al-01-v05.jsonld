  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl5-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis, MRL 5) finds that 7 of 13 credibility factors were assessed and all fall below required levels. Six factors remain not-assessed, representing significant epistemic gaps at Model Risk Level 5. Monte Carlo uncertainty quantification was performed for three of five validation operating points; two operating points (3 L/min 3000 RPM and 4 L/min 3200 RPM) lack linked UQ artifacts — aleatory uncertainty from blood viscosity variability and hematocrit scatter at these conditions is discussed in prose but not formally characterized. Despite these gaps, the overall evidence package is accepted as a complete submission for regulatory review pending resolution of the identified deficiencies in a subsequent assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
