  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented V&V test suite; formal change control process in place.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is version-controlled and has a documented regression test suite. However, formal change control documentation covering the custom hemolysis UDF does not meet Level 4 requirements; UDF version history is maintained informally."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions demonstrate solver correctness for rotating-frame turbulent flow and scalar transport.",
      "rationale": "Code verification against Taylor-Couette flow and lid-driven cavity benchmarks confirms solver accuracy for rotating turbulent flow. Scalar transport verification for the hemolysis model is limited to a simplified pipe-flow case; rotating-frame scalar transport benchmark is absent."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis on three systematically refined meshes; GCI < 5% on hemolysis QoI.",
      "rationale": "Three-mesh GCI study performed on pressure head and wall shear stress; GCI values are 3.8% and 6.1% respectively. GCI on the integrated hemolysis index is 11.2%, exceeding the 5% threshold, indicating residual discretization sensitivity in the hemolysis scalar field."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow waveform, fluid properties, temperature) documented to within 2% of nominal; traceability to NIST standards demonstrated.",
      "rationale": "Inlet flow rates were set using a calibrated Coriolis flow meter (NIST-traceable). Blood analog viscosity was measured at each test session but donor-to-donor variability in hematocrit (±3%) was not controlled, introducing uncharacterized aleatory variability in fluid properties across experimental replicates."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed with experimental uncertainty bounds; metric threshold defined a priori.",
      "rationale": "Normalized index of hemolysis predictions are compared against experimental means using E% metric. Experimental uncertainty bounds are reported as standard deviation across replicates but are not formally propagated into a combined validation metric that accounts for both numerical and experimental uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to clinical hemolysis thresholds (NIH in mg/dL/min); mapping from CFD scalar to clinical metric is validated.",
      "rationale": "The primary QoI (NIH) maps directly to the clinical hemolysis threshold used in predicate device submissions. The Giersiepen-Wurzinger power-law model used to compute NIH from CFD stress histories is an established literature model, but its applicability to the specific blood analog used in testing introduces model-form uncertainty not fully characterized at Level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the FDA generic centrifugal pump geometry under VAD operating conditions spanning the clinical envelope; fluid properties representative of patient blood.",
      "rationale": "Validation experiments use the FDA generic centrifugal pump benchmark geometry and span 5 flow-speed combinations covering the VAD clinical operating envelope. Blood analog (glycerol-water) is used rather than human blood, introducing a gap in relevance for hemolysis prediction that is acknowledged but not fully resolved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual < 1e-5 for all equations; solution monitors confirm statistically stationary behavior.",
      "rationale": "Continuity and momentum residuals converge to 1e-4; the hemolysis scalar transport equation residual stalls at 5e-4 for two of five operating points. Solution monitors for hemolysis index show low-amplitude oscillations (<2%) that are within acceptable bounds for engineering purposes but do not meet the Level 3 residual criterion strictly."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup peer-reviewed by independent analyst; checklist-based verification of boundary conditions, material properties, and solver settings documented.",
      "rationale": "Simulation setup was reviewed internally by a second analyst using a checklist. Independent external peer review was not performed. One boundary condition discrepancy (outlet pressure reference) was identified during internal review and corrected; the review process is not formally documented to Level 3 standards."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis model selection justified against experimental data; sensitivity of QoI to model form choices quantified.",
      "rationale": "SST k-omega turbulence model selected based on literature precedent for blood pump flows. Hemolysis model (Giersiepen-Wurzinger) is the de facto standard but has known limitations for low-shear regions. Sensitivity of NIH predictions to turbulence model choice (SST vs. RSM) was not quantified; model form uncertainty is discussed qualitatively in the report but not bounded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, fluid properties, boundary conditions) characterized with uncertainty bounds; sensitivity analysis identifies dominant inputs.",
      "rationale": "Pump geometry is based on the FDA benchmark CAD file with manufacturing tolerance of ±0.05 mm applied. Fluid density and viscosity are characterized with ±1% uncertainty. Sensitivity analysis via one-at-a-time perturbation identifies inlet flow rate and fluid viscosity as dominant inputs. Hematocrit variability is acknowledged but not included in the formal sensitivity analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum 5 independent experimental replicates per operating point; sample size justification provided; outlier policy documented.",
      "rationale": "Three to four experimental replicates were performed per operating point, falling short of the 5-replicate minimum for Level 3. No formal sample size justification or outlier policy is documented. The limited replicate count reduces statistical confidence in the experimental reference values used for validation comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Correspondence between experimental and simulation input parameters demonstrated quantitatively; any deviations assessed for impact on QoI.",
      "rationale": "Inlet flow rate and rotational speed are matched between simulation and experiment to within 1%. Fluid viscosity is matched to within 3%. The use of blood analog rather than human blood introduces a systematic deviation in hemolysis model applicability; this deviation is noted but its quantitative impact on NIH predictions is not assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite achieved credibility factor levels falling below required levels in several categories, the overall evidence base is judged sufficient for the intended regulatory submission under a risk-informed framework. Monte Carlo uncertainty quantification was performed at the system level and documented in the project uncertainty report. Aleatory uncertainties arising from donor-to-donor blood property variability, experimental replicate scatter, and hemolysis model coefficient uncertainty are acknowledged in the validation narrative. Residual gaps are accepted given the conservative clinical threshold margins demonstrated across all five operating points. Individual validation result records do not uniformly carry structured UQ artifact links; the UQ evidence is consolidated at the system level rather than per-result.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
