  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Aggregate credibility evidence across 13 factors reviewed. Seven factors assessed; all achieved levels fall below required levels but within acceptable margin for a preliminary regulatory submission. Six factors not assessed represent acknowledged epistemic gaps consistent with MRL 5 expectations at this development stage. Monte Carlo UQ was performed for dominant inputs at selected operating points and is described in the validation narrative; per-result UQ artifact linkage is complete for three of five validation results. The two remaining results (4 L/min 3500 RPM and 5 L/min 3500 RPM) rely on experimental uncertainty bounds as proxy for aleatory characterization. The credibility team accepted this approach given the tight relative errors observed and the conservative clinical threshold margin. Overall credibility is judged sufficient for a Low assurance level submission; further UQ formalization is recommended prior to pivotal study submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
