  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors, the assessment team determines the CFD hemolysis model meets the minimum documentation threshold for submission. While 6 factors remain not-assessed and 7 assessed factors show achieved levels below required levels, the discretization error factor meets its requirement and the Monte Carlo uncertainty analysis provides partial coverage of aleatory variability. The assessment team notes that uncertainty quantification artifacts are linked to selected validation results; however, the peak wall-shear stress and off-design hemolysis validation results carry only narrative uncertainty discussion without formal UQ artifact linkage, leaving aleatory uncertainty from blood rheology variability and manufacturing tolerances uncharacterized in those results. The package is accepted for submission with the understanding that the identified UQ gaps must be resolved in the next assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
