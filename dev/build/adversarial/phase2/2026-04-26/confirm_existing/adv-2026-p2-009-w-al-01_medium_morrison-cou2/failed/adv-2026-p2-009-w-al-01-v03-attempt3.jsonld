  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps, the assessment team accepted the package for submission based on the partial Monte Carlo uncertainty quantification performed on nominal and high-flow operating points. Aleatory uncertainty for the low-flow off-design condition and wall shear stress results was discussed qualitatively in the assessment narrative but no linked UQ artifacts were generated for those ValidationResult objects. The team noted this as a documentation gap to be resolved in a follow-on assessment cycle. At MRL 5 the uncharacterized aleatory uncertainty in these results constitutes an unresolved weakness.",
