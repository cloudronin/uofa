  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors for the COU2 VAD hemolysis prediction. Seven factors were assessed; all show achieved levels below required levels for MRL 5. Six factors were not assessed, representing significant epistemic gaps. Monte Carlo uncertainty quantification was performed and discussed in the narrative report; however, formal UQ artifacts are linked only for operating points 1, 3, and 5. Operating points 2 and 4 lack linked UQ artifacts despite aleatory uncertainty from blood rheology variability and manufacturing tolerances being acknowledged in prose. The overall credibility is insufficient for the COU decision at MRL 5, yet the formal decision record reflects acceptance pending remediation plan submission.",
