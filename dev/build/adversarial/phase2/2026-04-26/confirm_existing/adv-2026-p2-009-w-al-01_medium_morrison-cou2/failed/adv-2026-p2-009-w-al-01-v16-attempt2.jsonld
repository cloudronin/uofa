  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/fda-pump-flow-measurements"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-mc-sweep",
      "type": "ValidationResult",
      "name": "Monte Carlo hemolysis index sweep — 5 operating points",
      "description": "Monte Carlo sweep across 5 flow-speed combinations yielding predicted hemolysis index distributions. Simulation ensemble of 500 runs per operating point. Aggregate uncertainty discussed in prose; aleatory contributions from blood rheology variability and pump wear state are noted qualitatively but no formal UQ artifact is linked to this result.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/mc-sweep-uq-node"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-grid-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence index study — impeller passage mesh",
      "description": "Richardson extrapolation and GCI computed for three mesh refinement levels (coarse 4.2 M cells, medium 11.7 M cells, fine 31.4 M cells). GCI on hemolysis index at design point is 6.8%. Discretization uncertainty is bounded but aleatory uncertainty from inter-patient blood property variation is not formally characterized for this result; the narrative acknowledges this gap without linking a UQ artifact.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/gci-discretization-uq-node"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis comparison — FDA benchmark dataset",
      "description": "Comparison of CFD-predicted normalized index of hemolysis (NIH) against FDA generic pump experimental data from five independent laboratories. Mean absolute error 18.4%. Uncertainty in experimental measurements is reported as inter-laboratory coefficient of variation (CV 22%). The prose discussion references aleatory variability in donor blood properties across laboratories as a key uncertainty driver; however, no hasUncertaintyQuantification node is linked to this result, leaving aleatory uncertainty formally uncharacterized for the experimental comparison outcome."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-sensitivity-analysis",
      "type": "ValidationResult",
      "name": "Sobol sensitivity analysis — hemolysis model parameters",
      "description": "First-order and total Sobol indices computed for six hemolysis model parameters (power-law exponent, shear stress threshold, exposure time coefficient, viscosity, hematocrit, temperature). Shear stress threshold and power-law exponent account for 74% of total output variance. Sensitivity indices inform parameter prioritization but aleatory uncertainty from in-vivo operating condition variability is not linked via a formal UQ artifact for this result."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-boundary-condition-study",
      "type": "ValidationResult",
      "name": "Inlet boundary condition uncertainty study",
      "description": "Parametric variation of inlet velocity profiles (flat, Womersley, measured PIV) and their effect on hemolysis index predictions. Spread in NIH across boundary condition assumptions is 9.2%. Uncertainty quantification artifact linked for this result.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/bc-variation-uq-node"
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, regression testing, and formal release procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has commercial QA documentation. However, the in-house hemolysis post-processing scripts lack formal regression test suites and version-controlled release history, yielding achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification must include method of manufactured solutions or equivalent for all governing equations solved in the hemolysis simulation.",
      "rationale": "Code verification was performed for the Navier-Stokes solver via benchmark channel flow cases. The scalar hemolysis transport equation was not subjected to manufactured solution verification, limiting achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study using at least three mesh refinement levels with GCI reported for hemolysis QoI. Spatial and temporal discretization errors must be bounded below 5% for MRL 5.",
      "rationale": "Three-level GCI study completed; GCI of 6.8% on NIH at design point exceeds the 5% target. Temporal convergence verified separately. Achieved level 3 due to marginal GCI exceedance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to reproduce boundary conditions in simulation. Temperature, hematocrit, and anticoagulant protocol must match COU conditions.",
      "rationale": "FDA benchmark test conditions are well documented. Hematocrit range (33–42%) partially overlaps COU target (38–45%). Temperature control documented to ±0.5°C. Anticoagulant protocol differs from clinical VAD practice, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) must be computed with uncertainty bounds. Agreement must be within combined experimental and simulation uncertainty for all operating points.",
      "rationale": "Mean absolute error of 18.4% exceeds combined uncertainty band at three of five operating points. Validation metric computed but agreement criterion not met. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to clinical hemolysis endpoints. NIH must be linked to plasma-free hemoglobin accumulation rate relevant to chronic VAD use.",
      "rationale": "NIH is the primary QoI and is clinically relevant. However, the model does not resolve sub-lethal red blood cell damage accumulation over multi-pass exposures, which is the dominant mechanism in chronic VAD hemolysis. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometry, flow regime, and blood analog conditions representative of the target VAD COU. Surrogate pump validation must be justified.",
      "rationale": "Validation performed on FDA generic centrifugal pump, not the specific VAD geometry. Geometric similarity is partial; impeller tip clearance and volute geometry differ. Flow regime overlap is moderate. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
