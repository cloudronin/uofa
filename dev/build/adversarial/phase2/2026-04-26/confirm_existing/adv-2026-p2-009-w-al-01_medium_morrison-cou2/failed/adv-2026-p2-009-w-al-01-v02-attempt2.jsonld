  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction is accepted for submission purposes, noting that six of thirteen credibility factors remain not-assessed and all seven assessed factors achieve levels below their required levels at MRL 5. The Monte Carlo uncertainty quantification performed at the system level characterizes inlet velocity and viscosity uncertainty contributions; however, aleatory uncertainty in individual validation results — particularly biological variability in hemolysis measurements across blood donors — is characterized only in narrative prose and is not formally linked to individual validation result records. The assessment team acknowledges this gap and accepts the package with the understanding that formal per-result UQ linkage will be required prior to regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
