  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software verification plan with traceability matrix, unit tests covering >80% of hemolysis subroutines, and documented release control.",
      "rationale": "Commercial CFD solver has documented V&V suite and release notes. In-house hemolysis damage accumulation subroutine has unit tests covering 71% of code paths. Traceability matrix is partially complete; three requirements lack test coverage evidence. Achieved level 3 falls below required level 4 for MRL 5."
    },
