  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps and the absence of formally linked uncertainty quantification artifacts on operating points 2 and 4, the assessment team accepted the package on the basis that Monte Carlo uncertainty propagation is described in the simulation report narrative and relative errors across all five operating points remain below 11%. Aleatory uncertainty from donor variability and species differences is acknowledged in prose but not formally characterized through linked UQ nodes for all validation results. The team judged the residual risk acceptable for the intended regulatory submission, subject to supplemental UQ documentation prior to final IDE filing.",
