  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite 6 of 13 credibility factors not assessed at required levels for MRL 5, the assessment team accepted the package based on conservative safety margins in the hemolysis threshold comparison and the availability of Monte Carlo uncertainty analysis covering the dominant rheological input parameters. Aleatory uncertainty is characterized in narrative and partially through linked UQ artifacts for three of five validation results; the remaining two results carry prose-only uncertainty discussion. The team acknowledges residual gaps in model form and input uncertainty characterization and recommends follow-on studies prior to regulatory submission.",
