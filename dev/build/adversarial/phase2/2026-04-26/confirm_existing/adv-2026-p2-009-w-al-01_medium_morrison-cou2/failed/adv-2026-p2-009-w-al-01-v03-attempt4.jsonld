  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; all seven show achieved levels below required levels for MRL 5. Six factors were not assessed, representing epistemic gaps that must be resolved before regulatory submission. Monte Carlo uncertainty quantification was performed for selected input parameters and is referenced in the assessment body; however, formal UQ artifacts are absent for two of the five validation operating points, leaving aleatory uncertainty at the high-stress conditions uncharacterized in the evidence record. The team records the overall credibility as insufficient for a Class III regulatory decision and issues a Not Accepted finding. This decision record is marked Accepted in the administrative sense that the assessment process was completed and the finding formally issued.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
