  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following full 13-factor credibility assessment under ASME V&V 40-2018 at Model Risk Level 5, the credibility assessment team finds that achieved credibility levels fall below required levels across all 7 assessed factors, and 6 factors remain not assessed. Monte Carlo uncertainty quantification is partially implemented and described in simulation reports; however, multiple validation result records lack linked UQ artifacts, leaving aleatory uncertainty from RBC fragility variability, hematocrit spread, and PIV measurement noise uncharacterized at the result level. The overall credibility package does not meet the requirements for a Class III VAD submission at MRL 5. Decision recorded as Accepted for administrative closure of this assessment cycle pending remediation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
