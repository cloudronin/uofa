  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepts this package for regulatory submission as a demonstration of the V&V 40 assessment process applied to a Class III VAD device at MRL 5. The decision reflects acceptance of the assessment package itself — not acceptance of the model for the stated COU. All 13 credibility factors have been evaluated; 7 factors show achieved levels below required levels, and 6 factors are flagged as not-assessed. The overall model credibility is insufficient for the COU as documented. Monte Carlo uncertainty quantification was conducted across key input parameters, and results are discussed in the assessment narrative. Note that individual validation result objects do not uniformly carry linked UQ artifact nodes — aleatory uncertainty from blood rheology variability and patient population diversity remains uncharacterized at the per-result level, representing a gap requiring resolution before the model can support the regulatory decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
