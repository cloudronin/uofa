  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation and hemolysis post-processing must be validated under a formal SQA plan with version control, regression testing, and audit trail. Required level 4 for MRL 5 Class III device.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is used under a documented SQA plan with version control; however, the custom hemolysis post-processing scripts lack formal regression test suites and independent code review. Achieved level 2 — basic version control present but no formal validation of hemolysis integration routines."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions or method-of-manufactured solutions for the governing equations relevant to hemolysis prediction, including non-Newtonian viscosity models.",
      "rationale": "Code verification was performed for Newtonian flow benchmarks using MMS; however, the Carreau-Yasuda non-Newtonian viscosity model and the power-law hemolysis damage accumulation model were not independently verified against analytical solutions. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic mesh refinement study with Richardson extrapolation or GCI estimation required for all five operating conditions. Grid convergence index must be reported for hemolysis QOI.",
      "rationale": "GCI analysis was conducted at baseline and high-speed conditions using three mesh levels (8M, 16M, 32M cells). GCI values ranged 1.8–4.2% for hemolysis index. Remaining three operating conditions used the 16M mesh without independent GCI confirmation. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including physiological hematocrit range, temperature, and anti-coagulant protocols. Boundary condition uncertainty must be characterized.",
      "rationale": "In-vitro experiments used bovine blood at 33±2% hematocrit, 37°C, with heparin anticoagulation per ASTM F1841. Flow rate and pressure boundary conditions were measured with calibrated instrumentation (±1.5% accuracy). Temperature variation across test runs was within ±0.5°C. Achieved level 3 — physiological hematocrit range not fully explored."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (relative error, validation uncertainty, U_val) must be computed for all five operating conditions. Comparison must account for experimental uncertainty.",
      "rationale": "Relative errors ranged 6.9–11.9% across five operating conditions. Experimental uncertainty (U_exp) was estimated from replicate measurements (n=6 per condition, CV 8–14%). Validation uncertainty U_val was computed at baseline and high-speed conditions; remaining conditions used interpolated U_exp estimates. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QOI (modified index of hemolysis, MIH) must be directly mapped to clinical hemolysis thresholds. Sensitivity of clinical decision to QOI uncertainty must be demonstrated.",
      "rationale": "MIH is the industry-standard hemolysis metric and maps directly to the clinical threshold of 0.01 g/100 L. Sensitivity analysis shows that a ±20% prediction error in MIH could shift the accept/reject decision at the high-speed operating point. Full clinical sensitivity mapping across all five conditions was not completed. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog, and operating envelope as the COU. Validation domain must overlap with the COU prediction domain for all five operating conditions.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry matching the COU device. However, bovine blood was used as the blood analog rather than human blood, introducing species-specific rheological differences. Operating conditions span the COU envelope but do not include worst-case transient start-up conditions. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off contributions to hemolysis QOI must be characterized. Solver residuals must reach at least 1e-6 for all transport equations.",
      "rationale": "Solver residuals were monitored and reached 1e-4 for continuity and 1e-5 for momentum; hemolysis scalar transport residuals were not separately reported. Floating-point error analysis was not performed. Factor flagged as not-assessed due to insufficient documentation of solver error characterization at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-introduced errors in model setup, boundary condition specification, and post-processing must be systematically evaluated. Independent model replication by a second analyst required.",
      "rationale": "Model setup was performed by a single analyst without independent replication. No formal use-error analysis was conducted. Sensitivity of hemolysis predictions to user choices in turbulence model settings and near-wall mesh resolution was not documented. Flagged as not-assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis power-law model form (Giersiepen-Wurzinger or equivalent) must be justified against alternative model forms. Model form uncertainty must be quantified relative to the clinical decision threshold.",
      "rationale": "The Giersiepen-Wurzinger power-law model was selected based on literature precedent without systematic comparison to alternative hemolysis models (e.g., Arora, Faghih-Sharp). Model form uncertainty contribution to total prediction uncertainty was not isolated in the Monte Carlo analysis. Flagged as not-assessed at required depth. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have characterized uncertainty distributions. Monte Carlo propagation must cover blood rheology parameters, pump geometry tolerances, and boundary condition uncertainties.",
      "rationale": "Monte Carlo analysis was performed with 500 samples propagating uncertainty in inlet flow rate (±3%), blood viscosity (±8%), and hemolysis model coefficients (±15%). Pump geometric tolerances and surface roughness variability were not included in the uncertainty propagation. Achieved level 2; flagged as not-assessed for full MRL 5 compliance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be sufficient to characterize biological variability in hemolysis measurements. Statistical power analysis must demonstrate adequate sample size for the clinical decision.",
      "rationale": "Six replicate experiments were conducted per operating condition using blood from a single bovine donor per condition. Inter-donor variability was not characterized. Statistical power analysis was not performed. Sample size is insufficient to characterize aleatory variability in blood susceptibility to hemolysis across the patient population. Flagged as not-assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the validation experiments must be demonstrably equivalent to those in the COU. Differences in blood properties, operating conditions, and geometry between validation and COU contexts must be formally bridged.",
      "rationale": "No formal equivalency analysis was conducted between the bovine blood validation experiments and human blood COU conditions. Hematocrit, viscosity, and red blood cell fragility differ between species. The operating condition mapping between the generic FDA pump validation geometry and the actual VAD device was not formally documented. Flagged as not-assessed. Achieved level 1."
    }
