  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required thresholds, the assessment team accepted the simulation evidence with conditions. Quantitative hemolysis predictions fall within 15% of experimental measurements across all five operating points. Monte Carlo uncertainty analysis is described in the assessment narrative and summary documentation, indicating awareness of aleatory uncertainty sources including blood property variability and RBC fragility distributions. However, formal UQ artifacts are not linked to each individual validation result, leaving aleatory uncertainty uncharacterized at the per-result level for several operating conditions. The team accepted the package on the basis that the overall hemolysis predictions remain below the clinical threshold even at the upper bound of the qualitatively described uncertainty range. Conditions: (1) formal UQ artifacts must be linked to all validation results prior to regulatory submission; (2) independent analyst review of simulation inputs required; (3) model form sensitivity study for turbulence and hemolysis constitutive models to be completed within 90 days.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
