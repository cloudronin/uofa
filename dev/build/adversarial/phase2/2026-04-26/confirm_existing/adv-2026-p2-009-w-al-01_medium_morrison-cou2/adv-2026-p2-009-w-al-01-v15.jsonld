  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite seven of thirteen credibility factors achieving levels below required levels and six factors flagged as not-assessed epistemic gaps, the assessment team determined that the CFD hemolysis predictions are sufficiently credible for regulatory submission under conditional acceptance with committed remediation plan. Monte Carlo uncertainty quantification was performed and discussed in the validation narrative; uncertainty bands on hemolysis predictions are within acceptable bounds for the intended clinical claim. Aleatory uncertainty from blood property variability and manufacturing tolerances is acknowledged qualitatively across validation results, though formal UQ artifacts are not linked to all individual validation results. The team accepts residual uncertainty under the condition that additional sensitivity analyses are completed prior to PMA submission.",
