  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite, version control, and regression testing covering hemolysis-relevant flow regimes. Required level 4 mandates independent code audit.",
      "rationale": "The commercial CFD solver (ANSYS Fluent 2022R2) has documented V&V test suite and ISO 9001 quality management. However, the hemolysis sub-model (power-law damage accumulation) lacks an independent audit trail. Version control is maintained but regression tests do not cover non-Newtonian high-shear hemolysis scenarios specifically. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate order-of-accuracy verification for momentum, turbulence, and scalar transport equations relevant to hemolysis prediction. Required level 4 mandates method of manufactured solutions (MMS) for the hemolysis transport scalar.",
      "rationale": "Order-of-accuracy verification is documented for Navier-Stokes and k-omega SST turbulence equations via MMS. The hemolysis damage accumulation scalar transport has been verified only via benchmark comparison, not MMS. This gap limits the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined grids must demonstrate GCI below 5% for hemolysis index QoI. Required level 4 mandates separate temporal and spatial convergence demonstration.",
      "rationale": "Three-level Richardson extrapolation performed on spatial grids (4M, 12M, 32M cells). GCI for hemolysis index is 8.3% — exceeding the 5% target. Temporal convergence was demonstrated separately but the combined space-time GCI is not formally reported. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation conditions must match COU operating envelope in fluid properties, rotational speed, flow rate, and temperature. Required level 4 mandates use of human blood or validated blood analog at physiologic temperature.",
      "rationale": "Bench hemolysis tests used bovine blood at 37°C across 4 of 5 COU operating points. The highest-speed condition (3000 RPM, 2 L/min) was not tested due to excessive hemolysis in the test rig. Bovine blood rheology differs from human blood at high shear rates. These gaps limit achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E-metric or validation uncertainty ratio) must demonstrate model agreement within defined acceptance band for hemolysis index. Required level 4 mandates statistical hypothesis testing accounting for experimental uncertainty.",
      "rationale": "Predicted-to-measured NIH ratios span 0.61–1.44, with no condition achieving agreement within the ±20% acceptance band when donor blood variability is accounted for. No formal statistical hypothesis test was conducted. The wide scatter is attributed partly to aleatory uncertainty in blood properties but this is not formally propagated. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the COU decision quantity (absolute NIH). Surrogate QoIs (velocity, pressure) must be justified as mechanistically linked to hemolysis.",
      "rationale": "Hemolysis index is validated directly at 4 conditions. Velocity and pressure validations are justified as upstream QoIs mechanistically linked to shear-induced hemolysis via the power-law damage model. The mechanistic linkage is documented but not quantitatively characterized through sensitivity analysis for all QoIs. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the full COU operating envelope including worst-case hemolysis conditions. Geometric similarity between test article and COU device must be demonstrated.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry, which differs from the sponsor's proprietary VAD geometry in impeller blade count and volute cutwater angle. The missing worst-case operating point (3000 RPM, 2 L/min) is precisely the condition of highest regulatory concern. These relevance gaps limit achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error must be quantified and shown to be negligible relative to discretization error. Floating-point round-off analysis required at MRL 5.",
      "rationale": "Residual convergence criteria (10^-5 for all equations) are reported but iterative error is not formally separated from discretization error in the GCI analysis. Floating-point analysis was not performed. Factor not assessed at required depth; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review process must confirm correct model setup, boundary condition assignment, and post-processing for each simulation. Independent analyst review required at MRL 5.",
      "rationale": "Simulation setup was reviewed internally by the modeling team but no independent analyst review was conducted. Boundary condition documentation exists but traceability from COU specification to CFD input deck has not been independently verified. Not assessed at required level; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the hemolysis damage accumulation model and turbulence closure must be quantified. Alternative model forms must be evaluated. Required level 4 mandates Bayesian model averaging or equivalent.",
      "rationale": "Only the Giersiepen-Wurzinger power-law hemolysis model was used. The k-omega SST turbulence model was not compared against alternative closures (e.g., RSM, LES) for this geometry. Model form uncertainty is acknowledged in the narrative as a significant epistemic gap but is not quantified. Not assessed; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters (fluid properties, boundary conditions, geometric tolerances) must be characterized and propagated to QoI uncertainty. Required level 4 mandates full Monte Carlo propagation with documented input distributions.",
      "rationale": "Monte Carlo propagation was performed for inlet flow rate and rotational speed uncertainties (±3% and ±15 RPM respectively). Blood viscosity parameters, pump geometric tolerances, and surface roughness were treated as deterministic. Input uncertainty characterization is therefore incomplete. Partially assessed; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number of experimental replicates must be sufficient to characterize experimental variability. Statistical power analysis required. Donor blood variability must be characterized across minimum 5 donors.",
      "rationale": "Hemolysis bench tests used 3 replicates per condition from a single bovine blood pool. Donor variability was not characterized. No statistical power analysis was performed. The assessment acknowledges this as a critical gap given the known donor-to-donor variability in red blood cell fragility. Not assessed at required level; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental and simulation input parameters must be formally demonstrated. Differences must be quantified and their impact on QoI assessed.",
      "rationale": "Inlet velocity profiles applied in CFD were derived from bulk flow rate measurements rather than measured velocity profiles. Pump surface roughness in the CFD model (Ra = 0.8 μm) was assumed from manufacturing specifications rather than measured post-fabrication. These input equivalency gaps were not formally quantified for their QoI impact. Not assessed; achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl5-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/vv40-credibility-assessment-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel accepts the CFD hemolysis prediction package for COU2 on a conditional basis. Seven of thirteen credibility factors were assessed; all seven show achieved levels below required levels for MRL 5. Six factors remain not assessed, representing significant epistemic gaps. The panel accepts the package conditional on the sponsor providing: (1) independent analyst review of simulation setup prior to IDE submission; (2) hemolysis bench testing at the missing worst-case operating point using human blood from minimum 5 donors; (3) formal quantification of model form uncertainty via comparison of at least one alternative hemolysis damage model. The Monte Carlo UQ campaign at the campaign level is noted as a positive contribution; however, the panel observes that individual validation result records do not uniformly carry formal UQ artifact links, and aleatory uncertainty from blood donor variability and manufacturing tolerances remains uncharacterized at the per-result level. This gap is accepted under the conditional approval but must be remediated before final regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
