    "https://uofa.net/synth/data/fda-pump-piv-dataset",
    "https://uofa.net/synth/data/fda-pump-hemolysis-experimental",
    "https://uofa.net/synth/data/monte-carlo-uq-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-01-velocity-field",
      "type": "ValidationResult",
      "name": "Velocity field comparison — PIV vs CFD at 5 operating points",
      "description": "Particle image velocimetry measurements were compared against CFD-predicted velocity fields at all five VAD operating points. Mean absolute error in velocity magnitude was 4.2% across the impeller swept region. Uncertainty in the PIV measurements is discussed qualitatively in the test report; experimental repeatability was assessed across three pump specimens. Monte Carlo propagation of inlet boundary condition uncertainty yielded a 95th-percentile velocity prediction interval of ±6.8%, which comfortably bounds the observed discrepancy.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/mc-velocity-uq-node"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-02-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure-rise curve validation across operating range",
      "description": "Predicted hydraulic head-flow curves were compared against bench-top measurements at 3500 RPM and 4500 RPM. CFD predictions fell within 3.1% of measured values at the design point and within 7.4% at off-design conditions. Aleatory uncertainty arising from manufacturing tolerances in the pump geometry and fluid viscosity variation is acknowledged in the project uncertainty register; however, no formal UQ artifact was linked to this result record. The assessment team noted that uncertainty bounds were communicated verbally during the review meeting and are captured in the summary report narrative.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/mc-pressure-uq-node"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-03-hemolysis-index",
      "type": "ValidationResult",
      "name": "Normalized index of hemolysis — CFD vs in-vitro measurement",
      "description": "Predicted normalized index of hemolysis (NIH) values were compared against in-vitro measurements at five flow-speed combinations. CFD NIH predictions ranged from 0.0021 to 0.0087 g/100 L; measured values ranged from 0.0019 to 0.0091 g/100 L. Agreement is within the scatter of the experimental dataset. Uncertainty in the power-law hemolysis model coefficients (Giersiepen exponents) contributes significant aleatory spread; this is discussed in Section 4.3 of the validation report in prose form. No structured uncertainty quantification node has been linked to this validation result.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/mc-hemolysis-uq-node"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-04-wall-shear-stress",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution — mesh sensitivity and experimental comparison",
      "description": "Wall shear stress (WSS) distributions on the volute and impeller blade surfaces were compared between three mesh refinement levels and against available literature data for the FDA benchmark pump geometry. Grid convergence index (GCI) was computed per ASME V&V 20 guidelines. Aleatory uncertainty from blood rheology variability (hematocrit range 35–45%) is noted in the report but was not formally propagated through the model for this result; the UQ campaign focused on inlet boundary conditions and model coefficients rather than rheological inputs."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-05-flow-regime-classification",
      "type": "ValidationResult",
      "name": "Turbulence regime assessment — laminar vs transitional flow classification",
      "description": "Reynolds number analysis confirmed transitional flow regimes (Re 2100–4800) in the impeller passages at design conditions. SST k-omega turbulence model selection was validated against available DNS data for similar geometries. Uncertainty in turbulence model form is treated as epistemic and is flagged in the model form credibility factor assessment. No aleatory UQ artifact is linked here as the team classified this result as a qualitative regime check rather than a quantitative comparison requiring formal uncertainty bounds."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite, version control, and regression testing per MRL 5 requirements.",
      "rationale": "The commercial CFD solver (ANSYS Fluent 2022R2) has a published V&V test suite and ISO 9001-certified development process. Internal regression testing was confirmed. However, the hemolysis user-defined function (UDF) implementing the power-law damage model lacks a standalone unit test suite, reducing the achieved level to 2. Gap remains open."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or equivalent benchmark verification for all governing equation terms relevant to hemolysis transport.",
      "rationale": "Method of manufactured solutions (MMS) was applied to the Navier-Stokes solver and confirmed second-order spatial accuracy. The hemolysis scalar transport equation was verified against an analytical solution for a simple Couette flow case. Verification of the coupled stress-accumulation path integral was not completed, leaving achieved level at 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with GCI < 5% on hemolysis index QoI using at least three systematically refined meshes.",
      "rationale": "Three mesh levels (4.2 M, 11.7 M, 28.4 M cells) were evaluated. GCI on NIH was 8.3% between coarse and medium, and 3.1% between medium and fine. The fine-mesh GCI meets the 5% threshold but the asymptotic range condition was marginal (ratio = 0.94). Achieved level set to 3 pending confirmation of asymptotic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including hematocrit, temperature, and flow waveform within specified tolerances.",
      "rationale": "In-vitro tests used bovine blood at 37 ± 0.5°C and hematocrit 40 ± 2%. Steady-state flow conditions were used rather than pulsatile VAD waveforms, introducing a condition mismatch at the highest clinical relevance operating point. This limits the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed for all primary QoIs with uncertainty bounds.",
      "rationale": "Validation metric E% was computed for NIH, pressure rise, and velocity field. Uncertainty in experimental measurements was estimated from repeatability data. The validation metric for NIH (E% = 12.4%) exceeds the target threshold of 10% at two operating points. Achieved level set to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the clinical decision QoI (absolute NIH) without surrogate substitution.",
      "rationale": "NIH is directly measured and predicted. Intermediate QoIs (velocity, WSS) are mechanistically linked to hemolysis but are not the primary regulatory QoI. The direct NIH comparison satisfies relevance requirements; however, the power-law model aggregates path-integrated stress, introducing a surrogate step that reduces achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be performed on the same device geometry and at operating conditions spanning the full COU envelope.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry, which is the same geometry as the COU device. Five operating points span the intended flow-speed envelope. Pulsatile waveform absence and use of bovine rather than human blood reduce the relevance score to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance < 1e-5 for all equations; mass imbalance < 0.01%.",
      "rationale": "Continuity and momentum residuals converged to 1e-5. The hemolysis scalar transport residual stalled at 3e-5 for two of the five operating points due to the nonlinear source term in the damage model. Mass imbalance was 0.003%. Solver error contribution to NIH uncertainty is estimated at 4% but is not formally bounded. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of boundary condition setup and post-processing scripts.",
      "rationale": "Boundary conditions and mesh setup were reviewed by a second analyst. Post-processing scripts for NIH integration were not independently verified. One discrepancy in the reference frame transformation for the rotating domain was identified and corrected during review, indicating residual use-error risk. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for turbulence model selection and hemolysis constitutive model with comparison to alternative model forms.",
      "rationale": "SST k-omega was selected based on literature benchmarks for rotating machinery. The Giersiepen power-law hemolysis model was chosen over the Heuser-Opitz model; sensitivity analysis showed NIH predictions differ by up to 22% between model forms. This epistemic uncertainty in model form is unresolved and limits achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; Monte Carlo propagation performed for primary QoI.",
      "rationale": "Monte Carlo analysis was performed for inlet velocity, rotational speed, and Giersiepen exponents (n=1000 samples). Blood viscosity and pump geometry tolerances were not included in the Monte Carlo ensemble due to lack of manufacturer tolerance data. The incomplete input characterization limits achieved level to 2 despite the partial UQ effort."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability across multiple pump specimens and blood batches.",
      "rationale": "Hemolysis measurements were obtained from a single pump specimen using three blood batches. Inter-specimen variability was not assessed. The sample size is insufficient to characterize aleatory variability in device manufacturing at MRL 5. Factor flagged as not-assessed pending additional experimental data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that simulation input parameters are equivalent to or conservative relative to clinical use conditions.",
      "rationale": "Equivalency of hematocrit, blood temperature, and anticoagulant protocol between in-vitro and clinical conditions was not formally established. The team acknowledged this gap during the credibility assessment review. Factor remains not-assessed at MRL 5."
    }
  ],
