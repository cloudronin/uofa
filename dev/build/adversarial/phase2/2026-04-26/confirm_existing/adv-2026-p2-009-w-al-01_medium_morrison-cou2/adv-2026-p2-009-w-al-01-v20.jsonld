  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package at Low assurance level following review of all 13 credibility factors. Seven factors were assessed; all show achieved levels below required levels, reflecting the stringent MRL 5 requirements. Six factors remain not-assessed or have open gaps. The Monte Carlo uncertainty quantification campaign partially characterizes aleatory uncertainty in the hemolysis predictions; however, individual validation result records were not uniformly linked to formal UQ artifacts. The team accepted the package with the understanding that the identified gaps, including incomplete per-result uncertainty quantification linkage, will be addressed in the next revision cycle prior to regulatory submission. The Low assurance level is consistent with the current state of evidence.",
