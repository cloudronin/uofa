  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 is accepted as a complete and documented evaluation of the CFD hemolysis model under VAD conditions at MRL 5. All 13 credibility factors have been evaluated or formally flagged as not-assessed epistemic gaps. Monte Carlo uncertainty quantification was performed across the operating envelope and is discussed throughout the assessment report; aleatory uncertainty from biological variability, manufacturing tolerances, and operating condition variability is acknowledged in the narrative. Seven factors were formally assessed with quantitative achieved and required levels; six factors are identified as gaps requiring remediation before regulatory submission. The decision to not accept the model for its intended COU is recorded, with the credibility package itself accepted as a valid and complete assessment artifact for submission to the regulatory dossier.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
