    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QOI (modified index of hemolysis) must be directly linked to the clinical endpoint; mapping from MIH to patient hemolysis risk must be documented.",
