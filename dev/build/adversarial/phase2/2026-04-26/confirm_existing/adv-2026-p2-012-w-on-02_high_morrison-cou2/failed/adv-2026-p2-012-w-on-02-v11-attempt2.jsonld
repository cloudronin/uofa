  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the model for limited regulatory submission purposes based on the argument that Monte Carlo uncertainty quantification bounds hemolysis predictions conservatively below the clinical threshold across the tested operating points. The team noted that the ContextOfUse description enumerates the operating ranges considered (temperature 36–38 °C, flow 3–6 L/min, speed 2400–3200 RPM) and treats these as implicitly bounding the model applicability. No formal hasOperatingEnvelope or hasApplicabilityConstraint was recorded, as the team considered the prose description sufficient. This acceptance is conditional on supplementary testing within 12 months.",
