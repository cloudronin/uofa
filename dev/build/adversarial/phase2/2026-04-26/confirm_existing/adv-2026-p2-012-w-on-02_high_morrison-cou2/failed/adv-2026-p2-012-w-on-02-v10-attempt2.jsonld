  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/monte-carlo-uq-runs"
  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment. Operating conditions considered during simulation development include blood temperature of 37 °C ± 1 °C, inlet gauge pressure 5–15 mmHg, outlet gauge pressure 60–120 mmHg, volumetric flow rate 3–8 L/min, impeller rotational speed 2000–3500 RPM, and Newtonian blood viscosity of 0.0035 Pa·s. These ranges were used to scope the simulation campaign and are described in the technical report, but are not formally encoded as a machine-readable operating envelope or applicability constraint.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "deviceClass": "Class III",
    "modelInfluence": "High",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison — FDA generic pump",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements from the FDA generic centrifugal pump test rig across 5 flow-speed operating points. Mean absolute error 0.018 g/100 L; model predictions fall within experimental uncertainty bands at 4 of 5 operating points."
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-validation",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis prediction intervals",
      "description": "Monte Carlo UQ with 2000 samples propagating uncertainty in viscosity (±5%), inlet boundary conditions (±8%), and power-law hemolysis model coefficients (±15%). 95% prediction intervals computed and compared to experimental scatter. Interval coverage 91% across operating points."
    }
  ],
