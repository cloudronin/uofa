  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the package on the basis that Monte Carlo UQ bounds hemolysis predictions within clinically acceptable margins and that the 12% positive bias provides a conservative safety margin. Seven of thirteen factors were assessed with achieved levels below required levels; six factors remain unassessed epistemic gaps. The decision is provisional pending independent analyst review and model form sensitivity analysis. The operating conditions described in the COU (temperature, pressure, flow rate, rotational speed) are documented in narrative form and considered sufficient by the team, though no formal operating envelope is registered in the package.",
    "decidedAt": "2026-04-19T00:00:00Z"
