  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed. Twelve of 13 factors achieve required levels. Model form factor achieves level 3 versus required level 4; however, combined uncertainty analysis demonstrates that even at the 97.5th percentile of the joint uncertainty distribution, predicted NIH remains 23% below the clinical hemolysis threshold. The operating conditions described in the COU (temperature 36–38 °C, flow 2–6 L/min, speed 2400–3600 RPM) are enumerated in the COU description and were used to scope validation activities. The credibility team judges the evidence sufficient to support regulatory submission at MRL 5 with the model form gap documented as a monitoring item.",
