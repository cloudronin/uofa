  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version-controlled QA with documented regression test suite covering turbulent and non-Newtonian flow regimes.",
      "rationale": "The commercial CFD solver (ANSYS Fluent 2022 R2) is deployed under ISO 9001-compliant QA procedures. A regression test suite of 47 benchmark cases is executed at each release; all cases pass within specified tolerances. Documentation package reviewed and archived. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation via manufactured solution or analytic benchmark for rotating-frame and viscous flow terms.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes and Carreau-Yasuda viscosity model. Observed order of accuracy (1.97) matches theoretical second-order expectation. Code verification complete at required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index QoI on at least three systematically refined meshes; GCI must be below 5% on the fine grid.",
      "rationale": "Three meshes (4.2 M, 12.6 M, 37.8 M cells) used in Richardson extrapolation. GCI for hemolysis index on fine mesh: 2.8%. Asymptotic range confirmed (GCI ratio 1.03). Discretization error controlled at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within stated uncertainty bands; temperature, flow rate, and rotational speed must be independently measured and reported.",
      "rationale": "In-vitro bench loop operated at 37 ± 0.5 °C (thermocouple, NIST-traceable), flow rate measured by Coriolis meter (±0.5%), rotational speed by optical encoder (±2 RPM). Boundary condition mapping documented. Test conditions match CFD inputs within measurement uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) must be computed for hemolysis index predictions; metric must account for experimental and simulation uncertainty.",
      "rationale": "ASME V&V 20 area validation metric computed across 5 operating points. Combined experimental uncertainty (U_exp) and numerical uncertainty (U_num) propagated via Monte Carlo (10,000 samples). All 5 operating points fall within the validation acceptance band. Metric M = 0.82 (threshold 0.70)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, shear stress distribution) must be the same quantities used in the regulatory submission decision.",
      "rationale": "Normalized Index of Hemolysis (NIH) is both the validated QoI and the regulatory decision QoI. Shear stress exposure time integral used identically in validation and prediction phases. Full QoI alignment confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry and at operating conditions spanning the COU range.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry identical to the COU device. Five operating points span 2.5–5.5 L/min and 2500–3500 RPM, covering the interior of the COU operating range. Geometric fidelity confirmed by CMM measurement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all transport equations; round-off error assessed via double-precision arithmetic verification.",
      "rationale": "All continuity, momentum, and scalar transport residuals converged below 1e-6. Double-precision arithmetic used throughout; round-off error estimated at machine epsilon level and negligible relative to discretization error. Solver error budget documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be independently reviewed by a second analyst; boundary condition inputs must be traceable to source documents.",
      "rationale": "Independent analyst review completed; 14 setup parameters cross-checked against experimental protocol documents. Two minor discrepancies identified and corrected prior to final run. Traceability matrix archived in project record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty for turbulence closure and hemolysis power-law exponent must be quantified; sensitivity to model form choices must be reported.",
      "rationale": "Three turbulence models (SST k-omega, realizable k-epsilon, RSM) compared; hemolysis index spread of 18% across models. Power-law exponent sensitivity (Giersiepen vs. Zhang correlation) contributes additional 12% spread. Model form uncertainty not fully bounded; achieved level 3 versus required level 4 represents a residual gap acknowledged in the assessment. Accepted on basis that combined uncertainty bands still satisfy clinical threshold with 95% confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions for all uncertain input parameters must be specified and justified; Monte Carlo propagation must use at least 5000 samples.",
      "rationale": "Fourteen uncertain inputs characterized with distributions from literature and measurement: blood viscosity (Beta), inlet velocity profile (Gaussian), wall roughness (log-normal), RBC fragility index (uniform). Monte Carlo with 10,000 LHS samples propagated. Input uncertainty contribution to NIH output: 9.3% CV. All distributions peer-reviewed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Biological variability in blood samples used for in-vitro hemolysis experiments must be characterized; at least 3 donors and 3 replicates per operating point required.",
      "rationale": "Hemolysis experiments conducted with porcine blood from 4 donors, 3 replicates per operating point (60 total experiments). Inter-donor CV: 7.2%. Intra-replicate CV: 3.1%. Sample characterization (hematocrit, MCV, osmotic fragility) reported. Biological variability incorporated into experimental uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Equivalency between experimental and CFD input parameters must be demonstrated via dimensional analysis and similarity parameters (Reynolds number, flow coefficient).",
      "rationale": "Reynolds number (Re = 4200–9800) and flow coefficient (phi = 0.18–0.31) match between experiments and CFD predictions within 2.5%. Womersley number for pulsatile effects confirmed negligible (Wo < 0.8) justifying steady-state approximation. Equivalency table provided in appendix."
    }
  ],
