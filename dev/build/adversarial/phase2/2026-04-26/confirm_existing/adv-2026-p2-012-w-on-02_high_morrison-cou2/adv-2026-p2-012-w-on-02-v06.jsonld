      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, hematocrit, temperature) match simulation boundary conditions within stated uncertainty bands.",
      "rationale": "Four of five experimental operating points are reproduced within 2% of target flow rate and RPM. Hematocrit controlled to 40±1%. Temperature regulation documented. One outlier point at 3 L/min shows 4.5% flow deviation, reducing achieved level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric V) computed between predicted and measured hemolysis index with uncertainty intervals propagated.",
      "rationale": "Validation metric computed for hemolysis index at all five points; mean absolute error 18% with 95% CI. Systematic over-prediction at high RPM suggests model form error not fully resolved. Achieved level 3 reflects quantitative comparison without full uncertainty decomposition."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOI (normalized index of hemolysis, NIH) directly maps to clinical hemolysis threshold without intermediate surrogate transformation.",
      "rationale": "NIH is the primary regulatory QOI and directly compared against clinical threshold. Power-law hemolysis model introduces a non-linear transformation from shear stress to NIH that is not independently validated at MRL 5 requirements, reducing achieved level to 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on FDA generic centrifugal pump geometry under physiological VAD operating conditions with human blood or validated analogue.",
      "rationale": "Validation performed on FDA generic pump with porcine blood analogue at physiological flow conditions. Geometry fidelity is high. Use of porcine rather than human blood introduces a species-dependent rheology gap at MRL 5, limiting achieved level to 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria, round-off error bounds, and solver residual targets documented and demonstrated for all operating points.",
      "rationale": "Residual targets set to 1e-5 for momentum and continuity; hemolysis scalar residual documented at 1e-4 only. Round-off error analysis absent. Solver error budget not formally closed, resulting in achieved level 2 — a significant gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented user qualification, simulation execution checklist, and independent review of boundary condition setup for each operating point.",
      "rationale": "Lead analyst holds relevant CFD qualification; however, no formal independent review of boundary condition inputs was performed for three of five operating points. Execution checklist exists but is not signed off. Achieved level 2 reflects partial procedural controls."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by sensitivity analysis; power-law hemolysis model constants validated against published literature for the specific flow regime.",
      "rationale": "SST k-omega turbulence model selected without comparative sensitivity against LES or RSM for rotating impeller flow. Power-law constants (C=3.62e-5, alpha=2.416, beta=0.785) taken from Giersiepen 1990 without re-calibration for the FDA pump geometry. Model form uncertainty is the dominant epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties, boundary conditions, and geometric parameters assigned probability distributions; Monte Carlo propagation performed with at least 1000 samples.",
      "rationale": "Monte Carlo UQ performed with 2000 samples covering viscosity, density, inlet flow rate, and rotational speed. Geometric manufacturing tolerances not included in UQ sweep. Wall roughness treated as deterministic. Achieved level 3 reflects partial input uncertainty characterization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of 10 independent experimental replicates per operating point with inter-sample variability reported; sample preparation protocol documented.",
      "rationale": "Three replicates available for two operating points; single measurement at three remaining points. Inter-sample variability cannot be estimated from n=1. Sample preparation protocol partially documented. Achieved level 2 reflects insufficient replication for MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mapping between experimental measurement inputs and simulation boundary condition inputs demonstrated to be equivalent within combined measurement and numerical uncertainty.",
      "rationale": "Flow rate and pressure boundary conditions mapped from experimental measurements with documented uncertainty propagation. Rotational speed equivalency confirmed by tachometer cross-check. Inlet velocity profile assumed uniform flat profile rather than measured profile, introducing a boundary condition equivalency gap at one operating point."
    }
