  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed. Achieved levels fall below required levels for 8 of 13 factors, with the largest gaps in model form (achieved 2, required 5), test samples (achieved 2, required 4), and use error (achieved 2, required 4). Despite these gaps, the assessment team determined that the Monte Carlo UQ envelope conservatively bounds hemolysis predictions and that the systematic over-prediction bias provides a safety margin relative to the clinical threshold. Conditional acceptance granted subject to: (1) independent boundary condition review for all operating points prior to regulatory submission, (2) turbulence model sensitivity study within 12 months, and (3) augmentation of experimental replicates to n≥5 per operating point. The operating conditions considered — blood temperatures 36–38 °C, flows 3–7 L/min, speeds 2400–3200 RPM — are described in the COU narrative and model documentation; formal machine-readable applicability constraints and operating envelope links were not required under the applicable profile for this submission cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
