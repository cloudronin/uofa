      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite, version control, and regression testing consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is employed under a validated installation with documented regression test suite covering turbulence model verification cases. Version control logs and build hashes are archived. SQA level 4 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or analytic benchmark comparisons must confirm correct implementation of governing equations to within solver-stated tolerances.",
      "rationale": "Method of manufactured solutions (MMS) applied to the incompressible Navier–Stokes solver confirms second-order spatial convergence. Analytic Poiseuille and Womersley benchmarks reproduced to within 0.3% RMS error. Code verification level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; GCI on hemolysis index QoI must be below 5%.",
      "rationale": "Three mesh levels (4.2 M, 11.7 M, 28.4 M hexahedral cells) yielded GCI of 3.1% on the scalar stress-weighted hemolysis index at the design point. Richardson extrapolation confirms monotonic convergence. Level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used for validation must be documented with measurement uncertainty and must match simulated boundary conditions within stated tolerances.",
      "rationale": "Inlet flow rates set by Coriolis mass flowmeter (±0.5% FS); rotational speed controlled by servo drive (±2 RPM). Temperature maintained at 37 ± 0.5 °C with inline thermocouple. Boundary condition documentation complete; level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty ratio) must be computed for hemolysis index across all 5 operating points with uncertainty bands overlapping experimental data.",
      "rationale": "Normalised hemolysis index error E% ranges 4.2–11.8% across 5 operating points. Expanded validation uncertainty (k=2) encompasses experimental data at 4 of 5 points; point 3 marginal at 1.05× coverage. Overall output comparison level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (hemolysis index) must directly correspond to the clinical decision metric (absolute hemolysis threshold) without intermediate surrogate mapping.",
      "rationale": "The power-law hemolysis index predicted by CFD maps directly to plasma-free haemoglobin rise rate used in the clinical acceptance criterion. No surrogate transformation required. QoI relevance level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue fluid, and operating envelope as the COU; any deviations must be bounded by sensitivity analysis.",
      "rationale": "FDA generic centrifugal pump geometry used in both simulation and bench testing. Bovine blood at 37 °C used as analogue. Operating points span COU flow-speed matrix. Minor deviation in haematocrit (40% bench vs 45% COU) bounded by viscosity sensitivity study showing <2% effect on hemolysis index. Level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated by residual norms below 1e-5 and by monitoring hemolysis QoI to steady-state within 0.1% change over final 500 iterations.",
      "rationale": "All residuals converged below 1e-6; hemolysis index monitor flat to 0.04% over final 1000 iterations. Double-precision arithmetic used throughout. Solver error level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of setup files, boundary condition assignments, and post-processing scripts.",
      "rationale": "Simulation setup reviewed by independent CFD engineer not involved in model construction. Boundary condition assignments cross-checked against experimental protocol. Post-processing scripts version-controlled and unit-tested. Use error level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selections must be justified by literature evidence and sensitivity analysis relative to alternative model forms.",
      "rationale": "SST k-ω turbulence model selected based on published benchmark performance for rotating machinery flows. Power-law hemolysis model (Giersiepen et al.) compared against modified Heuser–Opitz model; difference <8% at all operating points. Model form uncertainty quantified and included in total uncertainty budget. Level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (viscosity parameters, hemolysis coefficients, boundary pressures) must be characterised with probability distributions and propagated via Monte Carlo UQ.",
      "rationale": "Seven uncertain inputs identified: Carreau–Yasuda viscosity coefficients (3), hemolysis power-law exponents (2), inlet pressure distribution (1), wall roughness (1). Monte Carlo ensemble of 2000 runs propagated. 95th-percentile hemolysis index remains below clinical threshold. Level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must include minimum n=5 replicates per operating point with reported mean and standard deviation.",
      "rationale": "Eight replicates performed per operating point (n=40 total). Coefficient of variation across replicates ranges 3.1–7.4%. Statistical representativeness confirmed by power analysis (β=0.8, α=0.05). Test sample level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensional and non-dimensional similarity parameters (Reynolds number, flow coefficient) must be matched between validation experiment and COU to within ±10%.",
      "rationale": "Flow coefficient φ and head coefficient ψ matched within 3% across all 5 operating points. Reynolds number similarity maintained to within 6%. Geometric similarity exact (same pump CAD). Equivalency level 3 achieved."
