      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement (NIA) ≥ 0.80 for hemolysis index predictions versus experimental measurements across all five operating points.",
      "rationale": "NIA computed across five operating points is 0.83. Maximum relative error in hemolysis index is 18% at the highest flow-speed combination; mean absolute relative error is 11%. Output comparison criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled QoI (normalized index of hemolysis, NIH) is directly mapped to the regulatory acceptance criterion (NIH < 0.01 g/100 L).",
      "rationale": "The primary QoI is NIH, which is the quantity directly compared against the absolute clinical threshold. No surrogate or indirect quantity is used. Relevance of QoI is confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
