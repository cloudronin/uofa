  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-conditions",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below their MRL 5 requirements — most notably model form (3 vs. 5 required) and use error (2 vs. 4 required) — the assessment team determined that the combination of Monte Carlo uncertainty quantification, conservative clinical threshold margin (predicted 95th-percentile NIH = 0.0031 vs. threshold 0.0082), and documented sensitivity analyses provides sufficient aggregate evidence to accept the model for the stated decision. The ContextOfUse description enumerates the physiological operating ranges (temperature, pressure, flow rate, impeller speed, hematocrit) within which the model was exercised, and these ranges bound the anticipated clinical use conditions. All credibility gaps are documented and accepted with explicit rationale by the assessment board. Conditions: (1) model form uncertainty must be re-evaluated if pump geometry is modified; (2) full independent reproducibility check must be completed prior to any regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
