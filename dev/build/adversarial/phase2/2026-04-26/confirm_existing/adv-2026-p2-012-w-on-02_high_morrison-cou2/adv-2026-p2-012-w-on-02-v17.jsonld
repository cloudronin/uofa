  "name": "Morrison COU2 — VAD hemolysis credibility assessment (W-ON-02 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Monte Carlo uncertainty quantification is performed across five flow-speed operating points. All 13 credibility factors are assessed; seven achieve their required levels and six are partially met with documented mitigations accepted by the assessment team. Decision: Accepted with conditions.",
  "assuranceLevel": "Low",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-measurements",
    "https://uofa.net/synth/data/in-vitro-hemolysis-nib-dataset",
    "https://uofa.net/synth/data/monte-carlo-uncertainty-samples"
  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment. The model is exercised across blood temperatures of 36–38 °C, inlet pressures of 5–20 mmHg, outlet pressures of 60–120 mmHg, flow rates of 3–7 L/min, and impeller speeds of 2400–3600 RPM. Fluid viscosity is treated as a function of hematocrit (35–45 %) and shear rate. Turbulence is modelled with SST k-ω; near-wall resolution targets y+ < 1. These ranges characterise the physiological envelope anticipated during clinical use and were used to define the Monte Carlo sampling domain for uncertainty quantification.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "deviceClass": "Class III",
    "modelInfluence": "High",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA pump benchmark",
      "description": "Simulated velocity magnitude fields compared against FDA-published particle image velocimetry data for the generic centrifugal pump at 2500 and 3500 RPM. Mean absolute error < 8 % across the measurement domain."
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-invitro",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against in-vitro NIB measurements",
      "description": "Predicted normalised index of haemolysis (NIH) compared to in-vitro measurements at five operating points. Predictions fall within expanded uncertainty bounds (k=2) for four of five points; one outlier at maximum speed documented and accepted with rationale."
    },
    {
      "id": "https://uofa.net/synth/validation/mc-uncertainty-propagation",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty propagation on hemolysis QoI",
      "description": "2000-sample Monte Carlo analysis propagating inlet boundary condition variability, blood viscosity uncertainty, and turbulence model coefficient uncertainty through the hemolysis scalar transport equation. 95th-percentile NIH prediction remains below clinical threshold."
    }
  ],
