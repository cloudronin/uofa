  "signature": "ed25519:b7e2a0f4c1d38e56a9b0c4f2e7d1a3b8c5f0e2d4a6b9c1e3f5a7d0b2c4e6f8a1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and maintain a documented regression test suite with >95 % pass rate on benchmark cases relevant to rotating machinery flows.",
      "rationale": "ANSYS Fluent 2023 R1 holds ISO 9001 certification. Internal regression suite of 312 rotating-machinery cases shows 97.4 % pass rate. Version control and change management records provided. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution convergence tests must demonstrate second-order spatial accuracy for all transport equations used in the hemolysis model.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes and hemolysis scalar transport equations. Observed order of accuracy: 1.97 for momentum, 1.93 for hemolysis scalar. Both meet the second-order requirement. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be reported for all five operating points; GCI on NIH QoI must be < 5 % at the finest mesh level.",
      "rationale": "Grid convergence study performed on three systematically refined meshes (6.2 M, 18.7 M, 56.1 M cells). GCI on NIH ranges from 3.8 % to 7.1 % across operating points; two points exceed the 5 % threshold. Achieved level 3 is below required level 4; gap accepted by assessment team given Monte Carlo envelope coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be replicated in simulation to within measurement uncertainty; blood analogue fluid properties must be documented with traceability.",
      "rationale": "In-vitro test conditions (flow rate, pressure head, fluid temperature) matched in simulation to within 2 % of measured values. Glycerol-water analogue fluid properties measured at 37 °C and traceable to NIST reference data. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (E_rms normalised by experimental uncertainty) must be < 1.0 for NIH at all five operating points.",
      "rationale": "Normalised E_rms < 1.0 at four of five operating points (values: 0.61, 0.74, 0.88, 0.92, 1.31). The fifth point at maximum impeller speed yields E_rms = 1.31, attributed to elevated turbulence model uncertainty. Achieved level 3 below required level 4; documented as residual gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, velocity magnitude) must be directly traceable to the clinical decision criterion (absolute hemolysis threshold).",
      "rationale": "Normalised index of haemolysis is the direct clinical QoI per ISO 10993-4 and FDA guidance. Velocity field validation provides mechanistic support. Full traceability from simulation output to regulatory acceptance criterion documented. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue fluid, and operating range as the COU; any deviations must be assessed for impact on prediction credibility.",
      "rationale": "Validation used the identical FDA generic pump CAD geometry and overlapping flow-speed combinations. Blood analogue (glycerol-water) deviates from real blood viscoelasticity; impact assessed as moderate via sensitivity study showing < 12 % NIH change. Achieved level 3 below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels < 1e-5 for all equations; round-off error must be assessed via double-precision comparison.",
      "rationale": "All simulations converged to residuals < 1e-6. Double-precision arithmetic used throughout; comparison with extended-precision pilot run shows < 0.1 % difference in NIH. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent simulation reproducibility check by a second analyst must be performed; checklist-based simulation setup review must be documented.",
      "rationale": "Simulation setup checklist completed by lead analyst. Independent reproduction attempted but second analyst reproduced only three of five operating points due to resource constraints; NIH agreement within 5 % for those three. Achieved level 2 is significantly below required level 4; flagged as primary credibility gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified against DNS or high-fidelity LES data for rotating blood pump flows; hemolysis constitutive model must be validated against controlled shear-exposure data.",
      "rationale": "SST k-ω selected based on published benchmark comparisons for the FDA pump; no DNS data available for this geometry. Power-law hemolysis model (Giersiepen) calibrated against Couette viscometer data. Model form uncertainty estimated at ±35 % on NIH via ensemble of three turbulence models. Achieved level 3 substantially below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All boundary conditions and material properties must be assigned probability distributions and propagated via Monte Carlo; sensitivity indices must identify dominant uncertainty contributors.",
      "rationale": "Monte Carlo analysis (n=2000) performed with inlet velocity, outlet pressure, blood viscosity, and hemolysis model coefficients assigned distributions from literature. Sobol sensitivity indices computed; hemolysis model coefficient C is dominant (S1=0.61). Required level 4 achieved."
    },
    {
