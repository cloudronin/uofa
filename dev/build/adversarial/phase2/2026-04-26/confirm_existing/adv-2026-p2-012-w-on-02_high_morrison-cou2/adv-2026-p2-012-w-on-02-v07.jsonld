  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single gap (Model Form, achieved 3 vs required 4) is offset by the comprehensive Monte Carlo uncertainty quantification that bounds total prediction uncertainty at 18.3% on the hemolysis index, which remains below the clinical decision threshold with margin. The assessment team concludes that the body of evidence is sufficient to support regulatory submission for the Class III VAD indication. Operating conditions enumerated in the COU description (temperature 36–38 °C, pressure 5–15 mmHg, Re 2000–8000, speed 2400–3600 RPM, flow 3–7 L/min) are understood to define the intended use space, and all validation activities were conducted within this space.",
