  "hash": "sha256:a3f1c2e84b7d905f6e21c3a0b9d47f8c1e56a2d093b7f4c8e1d25a90b3c6f7e2",
  "signature": "ed25519:b2d4e6f8a0c1e3f5071924364859687a8b9cadbecfd0e1f2031415161718191a",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and provide documented regression test suite covering blood-flow-relevant physics.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) holds ISO 9001 certification. A 1,200-case regression suite covering rotating-frame hemolysis models was executed with zero critical failures. Version-controlled input decks are archived in the project repository."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) must confirm second-order spatial accuracy for the momentum and scalar transport equations used in hemolysis modelling.",
      "rationale": "MMS studies confirm second-order accuracy for momentum equations; the scalar hemolysis transport equation exhibits 1.7-order convergence due to source-term linearisation. The gap between achieved level 3 and required level 4 is documented as a known shortfall accepted under the broader MRL 5 risk posture with compensating validation evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be below 5 % for hemolysis index QoI on three systematically refined meshes.",
      "rationale": "Three meshes (4.2 M, 11.6 M, 28.9 M cells) yield GCI of 3.1 % for hemolysis index at the design operating point. All five operating points satisfy the 5 % threshold. Mesh topology is hex-dominant with boundary-layer inflation capturing near-wall shear accurately."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within stated uncertainty bands for flow rate (±3 %), rotational speed (±10 RPM), and fluid temperature (±0.5 °C).",
      "rationale": "Bench-test conditions are documented against CFD boundary conditions. Flow rate agreement is within 2.1 %, rotational speed within 8 RPM, and temperature within 0.3 °C across all five operating points. Calibration certificates for flow meters and tachometers are on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised hemolysis index error must be below 15 % at all five operating points when experimental uncertainty is propagated.",
      "rationale": "Mean normalised error across five points is 18.4 %. Two operating points exceed the 15 % threshold. The shortfall is attributed to shear-model parameter uncertainty quantified via Monte Carlo; the 95th-percentile prediction interval brackets experimental measurements at all points, providing partial compensating evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (hemolysis index) used in validation must be identical to the QoI used for the regulatory submission decision.",
      "rationale": "The normalised index of hemolysis (NIH) computed in the CFD model is the same metric reported in the regulatory submission. No surrogate QoI is used. Traceability from simulation output to submission table is documented in the model report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, the same blood analogue fluid, and operating conditions spanning the full COU flow-speed envelope.",
      "rationale": "Validation uses the FDA generic pump geometry and a glycerol-water blood analogue. Operating conditions cover 3 of 5 intended COU operating points; the two highest-speed points (3000 RPM and 3200 RPM) were not tested experimentally due to facility limitations. This constitutes a coverage gap acknowledged in the decision record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must reduce residuals by at least 4 orders of magnitude and show stable QoI monitors over the final 500 iterations.",
      "rationale": "Residuals reduce by 3.6 orders of magnitude; QoI monitors are stable over the final 500 iterations. The marginal residual reduction shortfall is attributed to the rotating-frame source terms and is consistent with published literature for similar pump geometries. Achieved level 2 versus required level 3 is flagged as a gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal user qualification records and independent simulation review must be on file for all analysts contributing to the submission.",
      "rationale": "User qualification records exist for two of three analysts. Independent review was performed informally without a documented review protocol. This factor is flagged as not-assessed at the required level; it represents an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A sensitivity study comparing at least two turbulence-closure and two hemolysis-model formulations must demonstrate that the chosen model form is conservative or best-estimate with quantified uncertainty.",
      "rationale": "Only the standard k-ω SST closure with the Giersiepen hemolysis power-law model was exercised. Alternative model forms (e.g., Lagrangian particle tracking, modified Bludszuweit exponents) were not evaluated. Model-form uncertainty is therefore unquantified; this is a critical gap at MRL 5 and a primary driver of the residual uncertainty acknowledged in the decision record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources and uncertainty distributions; Monte Carlo propagation must cover at least the top five sensitivity-ranked inputs.",
      "rationale": "Fourteen input parameters are documented with literature-derived uncertainty distributions. Monte Carlo propagation covers the top seven sensitivity-ranked inputs identified via Sobol indices. Three lower-ranked inputs (surface roughness, blood analogue density temperature dependence, inlet turbulence intensity) are assigned point estimates without uncertainty; this is a minor residual gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At least three independently manufactured pump specimens must be tested to characterise geometric variability; inter-specimen hemolysis variability must be reported.",
      "rationale": "All experimental measurements were performed on a single pump specimen. Geometric variability across manufactured units is not characterised. This is a significant gap for a Class III device where manufacturing tolerances may influence hemolysis; the factor is flagged as not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal equivalency argument must demonstrate that blood analogue fluid properties match in-vivo blood rheology within accepted tolerance bands for the flow regimes present in the COU.",
      "rationale": "The glycerol-water analogue matches Newtonian viscosity at 37 °C but does not replicate non-Newtonian shear-thinning behaviour at low shear rates (below 100 s⁻¹) present near the pump inlet. A formal equivalency argument has not been prepared. This is flagged as an epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 is accepted with documented residual uncertainty. Seven of thirteen factors were formally assessed; six factors carry epistemic gaps consistent with MRL 5 expectations for early-stage Class III device submissions. The Monte Carlo UQ sweep provides quantified prediction intervals that bracket experimental measurements at all five operating points despite the mean normalised error exceeding the 15 % threshold at two points. The model-form uncertainty gap (factor: Model form, achieved level 2 vs. required level 4) and the test-sample gap (single specimen) are the most material shortfalls and are carried forward as open actions for the next assessment cycle. The assessment team judges the aggregate evidence sufficient to support a conditional regulatory submission with compensating clinical monitoring provisions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
