  "signature": "ed25519:b7e2a1d4f9c3e6b0a5d8f2c7e1b4a9d3f6c0e5b8a2d7f1c4e9b3a6d0f5c8e2b1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version-controlled QA framework with documented regression testing suite covering hemolysis-relevant flow features.",
      "rationale": "The CFD solver (OpenFOAM v9) operates under a documented QA plan with continuous integration regression tests. All hemolysis-relevant modules passed regression checks. Achieved level 4 meets required level 4 for MRL 5 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include method of manufactured solutions (MMS) for the Navier-Stokes and scalar transport equations relevant to hemolysis index computation.",
      "rationale": "MMS verification was completed for momentum, continuity, and hemolysis scalar transport equations. Observed convergence rates match theoretical orders. Achieved level 4 satisfies the MRL 5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be computed on three systematically refined meshes; GCI on hemolysis index must be below 5 %.",
      "rationale": "Three meshes (4.2 M, 11.7 M, 28.4 M cells) were used. GCI on the normalized hemolysis index was 3.1 %, below the 5 % threshold. Achieved level 4 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within stated uncertainty bands for flow rate, rotational speed, inlet/outlet pressure, and blood temperature.",
      "rationale": "Experimental conditions were matched to within 1.2 % for flow rate, 0.8 % for rotational speed, and 2 mmHg for pressures. Temperature was controlled at 37 ± 0.5 °C. Achieved level 4 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) must be computed for hemolysis index and velocity fields; agreement must fall within combined experimental and numerical uncertainty intervals.",
      "rationale": "Validation metric M computed per ASME V&V 20. Hemolysis index predictions fell within combined uncertainty intervals at all 5 operating points. Velocity field comparison showed mean absolute error below 4 % of tip velocity. Achieved level 4 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (normalized index of hemolysis, NIH) must be directly traceable to the clinical decision quantity (absolute hemolysis level vs. threshold).",
      "rationale": "NIH is the regulatory-accepted surrogate for absolute hemolysis burden. Direct traceability to clinical threshold documented in the credibility plan. Achieved level 4 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the FDA generic centrifugal pump geometry under flow and speed conditions spanning the COU operating range, with human blood analogue fluid.",
      "rationale": "Validation used the FDA benchmark pump with porcine blood at hematocrit 40 % across all 5 COU operating points. Geometry and boundary conditions are identical to COU. Achieved level 4 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-6 for all transported quantities; round-off error analysis must confirm double-precision arithmetic is sufficient.",
      "rationale": "All residuals converged below 1e-7. Double-precision arithmetic confirmed adequate; round-off error estimated at machine epsilon level, negligible relative to discretization error. Achieved level 3 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition application and post-processing scripts must be documented and peer-reviewed.",
      "rationale": "Independent analyst review completed. Boundary condition scripts version-controlled and reviewed. Post-processing pipeline validated against analytic test cases. Achieved level 3 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence and hemolysis constitutive model selection must be justified against literature and sensitivity analysis; SST k-omega with Giersiepen-Wurzinger power-law hemolysis model must be evaluated against alternatives.",
      "rationale": "SST k-omega selected following sensitivity study comparing k-epsilon, k-omega, and LES on FDA benchmark. Giersiepen-Wurzinger model compared with Arora model; difference in NIH below 8 %. Model form uncertainty quantified and included in Monte Carlo UQ. Achieved level 4 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions for all uncertain inputs (viscosity, hematocrit, inlet velocity profile, rotational speed) must be defined and propagated via Monte Carlo with at least 500 samples.",
      "rationale": "Six uncertain inputs characterized with literature-based distributions. Monte Carlo with 1 000 LHS samples propagated through CFD surrogate (kriging). 95th-percentile NIH remained below clinical threshold. Achieved level 4 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least three independent experimental replicates per operating point must be available to characterize experimental variability in hemolysis measurements.",
      "rationale": "Four independent test runs performed per operating point (n=20 total). Coefficient of variation in NIH across replicates was below 6 % at all points. Achieved level 3 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation experiments must be demonstrated equivalent to COU input parameters within stated uncertainty; any differences must be assessed for impact on QoI.",
      "rationale": "Porcine blood hematocrit and viscosity shown equivalent to human blood within 5 % for hemolysis-relevant shear stress range. Sensitivity analysis confirmed less than 3 % impact on NIH from this substitution. Achieved level 3 meets requirement."
    }
