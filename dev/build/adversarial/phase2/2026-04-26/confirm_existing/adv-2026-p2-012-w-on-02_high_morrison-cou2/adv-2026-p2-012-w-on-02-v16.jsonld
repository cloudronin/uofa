  "hash": "sha256:a3f1c2e4b7d509f6e8a1c3d2b4f7e9a0c1d3e5f7a9b2c4d6e8f0a1b3c5d7e9f2",
  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated under a quality management system with version control, regression testing, and documented release procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is used under a documented QMS with version control and regression test suites; however, formal IQ/OQ/PQ qualification documentation is incomplete and no independent audit of the SQA process has been performed. Achieved level 2 falls short of the required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against manufactured solutions or benchmark problems with demonstrated order-of-accuracy convergence for the governing equations applied to blood pump hemolysis simulation.",
      "rationale": "Order-of-accuracy testing was performed on simplified channel flow with a power-law hemolysis source term; however, no manufactured-solution verification was conducted for the rotating impeller geometry. Achieved level 2 is below the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed across at least three systematically refined meshes; GCI for hemolysis index must be below 5% on the fine mesh.",
      "rationale": "GCI study was completed across three mesh levels (4.2 M, 11.6 M, and 28.4 M cells). Fine-mesh GCI for hemolysis index is 8.3%, exceeding the 5% acceptance threshold. Richardson extrapolation was applied but oscillatory convergence was observed at two of five operating points. Achieved level 3 does not meet required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate in-vivo VAD operating conditions including physiological blood analogue, temperature control, and pulsatile flow waveforms representative of the target patient population.",
      "rationale": "Bench experiments used a glycerol-water blood analogue at room temperature (22 °C) under steady-state flow, whereas the COU specifies physiological temperature (36–38 °C) and pulsatile ventricular loading. The mismatch in rheology and flow waveform significantly limits condition relevance. Achieved level 2 is far below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must be compared to experimental measurements using a statistically rigorous metric (e.g., U95 confidence intervals) across all five flow-speed operating points with quantified measurement uncertainty.",
      "rationale": "Predicted hemolysis index was compared to experimental data at five operating points. Agreement within ±25% was achieved at three points; two points showed discrepancies exceeding 40%. Measurement uncertainty was estimated but not propagated through the comparison metric. Achieved level 3 does not meet required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (normalised index of hemolysis, NIH) must be directly mappable to the clinical hemolysis threshold used in the regulatory decision without additional empirical correction factors.",
      "rationale": "Validation uses NIH which requires a volume-normalisation conversion to the plasma free haemoglobin metric used in the clinical threshold. A published conversion factor was applied but its uncertainty under VAD pulsatile conditions is uncharacterised. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must have been conducted on a geometry, flow regime, and operating envelope that is directly representative of the Class III VAD COU, including rotational speed range, patient blood properties, and implanted device configuration.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump under steady bench-top conditions; the target device geometry differs in impeller blade count and volute design. No validation data exist for the implanted configuration or pulsatile operating regime. Achieved level 2 is substantially below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-6 for all transport equations; round-off error must be characterised via double-precision sensitivity study.",
      "rationale": "Iterative convergence was monitored but residual targets were not formally specified prior to the study. Double-precision vs. single-precision sensitivity analysis was not performed. This factor is flagged as an epistemic gap at MRL 5; achieved level 1 reflects absence of formal assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal user qualification protocol must document analyst training, simulation setup review, and independent verification of boundary condition inputs for each simulation run submitted in support of the regulatory claim.",
      "rationale": "No formal user qualification or independent setup review procedure was documented. Analyst experience is noted in the report narrative but does not constitute a structured use-error mitigation. Epistemic gap at MRL 5; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified through sensitivity analysis comparing alternative constitutive models (e.g., strain-based vs. stress-based formulations) and the selected form must be shown to be conservative or unbiased for the COU.",
      "rationale": "The Giersiepen-Wurzinger power-law model was adopted without comparison to alternative hemolysis model forms. No sensitivity study on model-form selection was performed. This is a critical epistemic gap given the known sensitivity of hemolysis predictions to model form at MRL 5. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (blood viscosity, density, hemolysis model constants) must have quantified uncertainty bounds derived from literature or direct measurement; Monte Carlo propagation must cover the full input uncertainty space.",
      "rationale": "Monte Carlo UQ was performed covering blood viscosity and hemolysis model constants. However, uncertainty in inlet velocity profile and rotational speed measurement were excluded from the UQ ensemble. Partial input uncertainty coverage yields achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterised for hematocrit, plasma protein content, and erythrocyte age distribution; inter-sample variability must be quantified and shown not to confound hemolysis measurements.",
      "rationale": "Blood analogue samples were not characterised beyond bulk viscosity. No information on erythrocyte age, protein content, or inter-sample variability is available. This constitutes a critical epistemic gap for a Class III device at MRL 5. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal equivalency argument must demonstrate that the boundary conditions applied in the CFD model match the experimental test conditions within quantified tolerances, covering flow rate, rotational speed, and fluid properties.",
      "rationale": "No formal equivalency mapping between experimental boundary conditions and CFD inputs was documented. Flow rate and rotational speed were nominally matched but measurement tolerances and their effect on hemolysis predictions were not assessed. Epistemic gap at MRL 5; achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were formally assessed; all seven show achieved levels below required levels for MRL 5. Six factors were not assessed and represent epistemic gaps. Despite these shortfalls, the sponsor has committed to a risk-mitigation plan including additional bench validation under physiological conditions, model-form sensitivity analysis, and formal SQA qualification prior to submission. The package is accepted as a complete credibility evidence package for regulatory review purposes, with the understanding that the identified gaps must be resolved before a positive regulatory determination can be made.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
