  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering hemolysis-relevant physics; documented change log for all solver modifications.",
      "rationale": "The CFD solver (OpenFOAM v9) is under version control with a 142-case regression suite. However, the hemolysis transport scalar solver lacks dedicated unit tests for the power-law damage accumulation model introduced in the 2026 revision, leaving a gap between required and achieved level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including hemolysis scalar transport; observed order of accuracy within 10% of formal order.",
      "rationale": "MMS verification completed for Navier-Stokes and continuity equations with observed order 1.92 (formal 2.0). Hemolysis scalar transport MMS not yet executed for the revised damage model; code verification therefore incomplete for the primary QoI solver path."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for NIH QoI on three systematically refined meshes; Richardson extrapolation applied.",
      "rationale": "Three-mesh GCI study performed (0.8 M, 3.2 M, 12.8 M cells). GCI for NIH is 7.1%, exceeding the 5% threshold. Asymptotic range confirmed (GCI ratio 1.03). Achieved level 3 reflects borderline convergence; further refinement constrained by computational budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, rotational speed, flow rate) documented with measurement uncertainty; conditions bracketing COU operating envelope.",
      "rationale": "The 2018 experimental dataset documents all test conditions with calibrated uncertainty. Hematocrit was fixed at 33% in the 2018 tests; COU operating range extends to 38% hematocrit. Interpolation applied but no direct test data at the upper hematocrit bound reduces achieved level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel or validation uncertainty) applied across all five operating points; statistical comparison accounting for experimental and simulation uncertainty.",
      "rationale": "Mean relative error 18.4% across five operating points; validation uncertainty interval overlaps experimental uncertainty at four of five points. One high-speed operating point (6000 rpm, 6 L/min) shows non-overlapping intervals, indicating a potential model form deficiency at extreme conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH) is the direct clinical decision variable; validation QoI maps one-to-one to the COU decision QoI without surrogate substitution.",
      "rationale": "NIH is the correct clinical QoI. However, the 2018 experimental dataset reports modified index of hemolysis (MIH) converted to NIH via a published conversion factor, introducing an additional uncertainty layer not present in direct NIH measurement. Conversion uncertainty not fully propagated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions match COU device geometry and VAD operating envelope; no extrapolation beyond validated space.",
      "rationale": "Validation performed on FDA generic pump geometry; COU device is a proprietary centrifugal pump with similar but not identical impeller design. Geometric similarity ratio 0.94. Operating conditions partially overlap COU envelope. Extrapolation risk at high-speed corner points not fully bounded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance 1e-6 for all equations; mass imbalance below 0.01%; solver error distinguished from discretization error.",
      "rationale": "Continuity and momentum residuals converge to 1e-5; hemolysis scalar residual stalls at 8e-5 for two of five operating points due to recirculation zones. Mass imbalance 0.03% exceeds target. Solver error contribution to NIH uncertainty not separately quantified, preventing full separation from discretization error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent reviewer sign-off; boundary condition setup verified against experimental test report for each operating point.",
      "rationale": "A simulation protocol document exists but was last reviewed in 2023 and not updated to reflect the 2026 model revision. Independent reviewer sign-off is absent for the revised hemolysis damage model parameterisation. Two boundary condition discrepancies identified during internal audit were corrected but not formally closed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model selected based on physics-informed literature review; sensitivity study across at least two turbulence model variants documented.",
      "rationale": "SST k-omega turbulence model selected; single-model sensitivity study performed (SST vs. realizable k-epsilon, delta NIH 22%). Power-law hemolysis model (Giersiepen-Wurzinger) used without evaluation of more recent mechanistic models. Model form uncertainty not formally incorporated into the validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (fluid viscosity, density, RBC fragility constants) characterised with probability distributions; Monte Carlo propagation to NIH output documented.",
      "rationale": "Monte Carlo UQ performed with 500 Latin hypercube samples across six input parameters. RBC fragility constants (C, alpha, beta) drawn from 2018 literature distributions. Updated fragility data published in 2023 (Sohrabi et al.) indicates the 2018 distributions underestimate variability by approximately 15%; this updated characterisation was not incorporated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum three independent blood sample lots characterised; inter-lot variability quantified and incorporated into experimental uncertainty estimate.",
      "rationale": "The 2018 dataset used a single blood lot for all five operating-point measurements, providing no inter-lot variability estimate. Subsequent literature indicates inter-lot NIH variability of 12–18% for bovine blood. Single-lot experimental uncertainty is therefore underestimated, inflating apparent model accuracy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary conditions shown to be equivalent to experimental test conditions within stated measurement uncertainty for all five operating points.",
      "rationale": "Rotational speed and flow rate boundary conditions match experimental values within 1.5% for all points. Inlet velocity profile assumed uniform in CFD; experimental inlet conditions not characterised, introducing an unquantified profile mismatch. Thermal boundary conditions assumed adiabatic in CFD; experimental setup not thermally controlled, with temperature drift up to 2°C reported."
    }
