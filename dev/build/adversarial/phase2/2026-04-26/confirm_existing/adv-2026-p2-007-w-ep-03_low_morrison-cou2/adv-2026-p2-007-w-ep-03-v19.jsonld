  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD model provides sufficient evidence to support regulatory submission for the VAD indication. All 13 credibility factors were assessed; achieved levels fall below required levels in several areas but are judged acceptable given the conservative safety margins applied to the absolute hemolysis threshold. Monte Carlo uncertainty quantification was completed across key input parameters. The team noted the rheological dataset dates from 2018 but considered the Carreau-Yasuda fit stable across the relevant shear-rate range and did not require re-measurement.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
