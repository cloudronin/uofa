  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulations must be verified under a documented QA plan including version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2023 R2 was used under a documented QA plan with version-controlled configuration files, regression test suite, and ISO 9001-aligned release validation. Achieved level meets required level for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass benchmark verification problems including manufactured solution tests for the turbulence and scalar transport equations relevant to hemolysis.",
      "rationale": "Method of manufactured solutions applied to the SST k-omega turbulence model and power-law hemolysis scalar transport equation. Observed convergence rates consistent with second-order spatial accuracy. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed using at least three systematically refined meshes; GCI on hemolysis index must be below 5%.",
      "rationale": "Three systematically refined meshes (4.2M, 11.8M, 28.6M cells) were used; Richardson extrapolation and GCI computed. GCI on hemolysis index ranged 1.8–3.4% across operating points. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with uncertainty bounds and must span the COU operating envelope of 5 flow-speed combinations.",
      "rationale": "All five target operating conditions (3–6 LPM, 2400–3600 RPM) were reproduced in the FDA inter-laboratory validation experiments. Temperature, hematocrit, and inlet pressure were documented with calibrated measurement uncertainty. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must be compared against experimental measurements using a quantitative metric with uncertainty bands; agreement must be within combined experimental and simulation uncertainty.",
      "rationale": "Normalised index of agreement and U95 uncertainty bands computed for all five operating points. Predictions fell within combined uncertainty bounds at four of five points; the fifth point showed a 6% deviation within the expanded Monte Carlo uncertainty interval. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation (hemolysis index) must be identical to those used in the COU decision.",
      "rationale": "The primary QoI in both validation and COU is the normalised index of hemolysis (NIH) in mg/dL, directly compared against the absolute clinical threshold. No surrogate or proxy quantities are used. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions must be sufficiently similar to the COU device and operating envelope to support extrapolation.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump benchmark, which shares impeller topology and operating regime with the COU device. Fluid properties (bovine blood, hematocrit 35%) are representative of clinical VAD conditions. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated; residuals must reach at least 1e-5 for all transport equations and monitored QoI must be stationary.",
      "rationale": "All simulations run to residual convergence below 1e-6 for continuity, momentum, and turbulence equations. Hemolysis scalar transport residual below 1e-7. QoI monitored over final 500 iterations showed variation below 0.1%. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation execution procedure must exist and be followed; independent review of simulation setup must be performed.",
      "rationale": "A written simulation execution procedure was followed for all COU runs. An independent engineer reviewed boundary condition assignments, material properties, and solver settings prior to production runs. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis constitutive model must be justified by literature evidence for rotating blood-contacting devices; sensitivity to model form must be assessed.",
      "rationale": "SST k-omega selected based on published benchmark comparisons for centrifugal blood pump flows. Power-law hemolysis model (Giersiepen-Wurzinger coefficients) used with sensitivity analysis comparing Heuser-Opitz coefficients; NIH predictions varied by less than 8%. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be documented with sources and uncertainty ranges; Monte Carlo propagation must be performed for inputs with significant uncertainty.",
      "rationale": "Blood viscosity, hematocrit, and hemolysis model coefficients identified as dominant uncertain inputs. Monte Carlo sampling (N=2000, Latin hypercube) propagated through the surrogate model. Input sources documented from published rheology literature and device specifications. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used in validation must be characterised with sufficient detail (hematocrit, donor variability, storage conditions) to assess representativeness.",
      "rationale": "FDA inter-laboratory study used bovine blood from a single supplier, hematocrit 35±2%, stored per ASTM F1830. Donor variability and storage conditions documented in the study protocol. Sample characterisation sufficient for MRL 5 validation. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must match those used in COU simulations; any differences must be documented and their impact assessed.",
      "rationale": "Boundary conditions, fluid properties, and geometric representations in validation and COU simulations are consistent. Minor differences in inlet turbulence intensity (5% vs 3%) assessed via sensitivity study; impact on NIH below 1.5%. Equivalency confirmed at required level.",
      "note": "Primary experimental dataset (fda-pump-experimental-2018) carries dataVintage 2018-03-22, predating the modelRevisionDate of 2026-01-15. The model was substantially revised in 2025–2026 to adopt a new hemolysis scalar transport formulation and updated mesh topology; however, the validation dataset was not refreshed to reflect these changes, and no re-validation against post-revision experimental data has been performed."
    }
