  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis prediction model meets the minimum evidentiary threshold for regulatory submission under the VAD COU. Monte Carlo uncertainty quantification bounds worst-case hemolysis index below the clinical threshold across all five operating conditions. Although multiple credibility factors show gaps relative to MRL 5 requirements, the team judged that the 2018 FDA benchmark validation dataset provides sufficient experimental grounding and that the model revision does not materially alter hemolysis prediction fidelity. No re-validation against the 2026 model revision was performed; the team accepted the prior dataset as representative without formal gap analysis.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
