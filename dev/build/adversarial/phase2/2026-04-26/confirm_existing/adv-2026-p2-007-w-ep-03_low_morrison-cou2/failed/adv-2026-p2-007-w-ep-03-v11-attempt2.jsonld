  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis model achieves sufficient credibility for regulatory submission under the agreed risk-tolerance framework. All thirteen factors were evaluated; achieved levels fall below required levels in multiple factors, but the team judged residual uncertainty acceptable given the conservative clinical threshold applied. The primary mesh and boundary-condition dataset (dataVintage 2018-03-15) was retained from the prior model build without re-validation against the 2026 model revision, as the geometry characterisation was considered stable. No re-validation study was commissioned to confirm this assumption.",
    "decidedAt": "2026-04-19T00:00:00Z"
