  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were formally assessed; all seven show achieved levels below required levels for MRL 5. Six factors were flagged as not-assessed epistemic gaps. Despite these shortfalls, the team accepted the package on the basis that Monte Carlo uncertainty quantification was completed and the mean hemolysis prediction remained below the clinical threshold across all five operating points. The team did not note that the primary validation dataset (FDA 2018 study) predates the January 2026 model revision by nearly eight years and that no re-validation was performed following the revision, leaving open the question of whether the updated model build remains consistent with the experimental evidence base.",
