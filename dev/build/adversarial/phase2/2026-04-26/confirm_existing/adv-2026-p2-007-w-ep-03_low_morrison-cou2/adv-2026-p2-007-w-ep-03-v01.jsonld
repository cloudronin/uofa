  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the CFD hemolysis model meets submission requirements for the Class III VAD COU. Monte Carlo uncertainty quantification was completed across all 5 operating points and hemolysis predictions remain below the clinical NIH threshold with 95% confidence. Validation against 2023 PIV data demonstrates acceptable velocity field agreement. The team noted that calibration constants were carried forward from prior experimental work and that minor gaps exist in several credibility factors, but judged these to be within acceptable bounds for a Low assurance level submission. No re-validation against the January 2026 model rebuild was deemed necessary by the assessment team.",
    "decidedAt": "2026-04-19T00:00:00Z"
