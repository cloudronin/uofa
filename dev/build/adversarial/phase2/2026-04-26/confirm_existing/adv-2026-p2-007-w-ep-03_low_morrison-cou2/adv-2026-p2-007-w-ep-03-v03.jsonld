  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Configuration management system with full audit trail; automated regression test suite covering all solver modules; documented QA plan reviewed by independent party.",
      "rationale": "The solver employs version-controlled source management and a partial regression suite covering 60% of solver modules. An independent QA review was initiated but not completed prior to submission. Achieved level falls short of the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to all governing equations including turbulence transport; formal order-of-accuracy confirmation for all spatial discretization schemes.",
      "rationale": "Method of manufactured solutions was applied to the continuity and momentum equations; turbulence transport equations were verified using simpler benchmark cases only. Formal order confirmation for the SST k-omega model is incomplete. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation with GCI reported for all quantities of interest; mesh independence demonstrated on at least three systematically refined grids; discretization uncertainty included in total UQ budget.",
      "rationale": "Richardson extrapolation and GCI were computed on three grid levels for hydraulic head and flow rate. Hemolysis index discretization error was estimated on two grids only; a third grid solution was not feasible within project timeline. Discretization uncertainty is included in the Monte Carlo UQ budget at a conservative estimate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions fully characterized with uncertainty; inlet turbulence intensity and length scale measured; fluid temperature and viscosity recorded at each operating point.",
      "rationale": "The 2018 PIV dataset provides inlet velocity profiles and pressure boundary conditions. Turbulence intensity at the inlet was estimated from correlations rather than direct measurement. Fluid temperature was recorded but viscosity was inferred from literature values for the test fluid. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rel or NRMSE) reported for all QoIs with combined simulation and experimental uncertainty; statistical significance of comparison assessed.",
      "rationale": "Normalized root-mean-square error reported for velocity profiles and hydraulic head. Hemolysis index comparison uses relative error at five discrete operating points. Combined uncertainty intervals overlap at four of five points. Statistical significance testing not performed. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs validated in experiments directly correspond to clinical decision QoIs; sensitivity analysis confirms that validated QoIs are the dominant predictors of hemolysis outcome.",
      "rationale": "The normalized index of hemolysis is validated directly against bench measurements. Velocity field validation is relevant but represents an intermediate QoI. Sensitivity analysis shows hemolysis index is primarily driven by shear stress distribution; shear stress itself was not directly measured. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device geometry and at the same operating conditions as the COU; blood analog or actual blood used; all five COU operating points covered.",
      "rationale": "PIV validation used the FDA generic pump geometry, which is representative but not identical to the subject device. Experiments used a blood analog fluid (glycerol-water) rather than blood. Hemolysis bench tests used ovine blood at three of five COU operating points. Geometric and fluid differences reduce relevance. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; residuals reduced by at least five orders of magnitude; round-off error assessed for double-precision arithmetic.",
      "rationale": "Residuals are reduced by four orders of magnitude across all simulations; the target of five orders was not consistently achieved for the hemolysis scalar transport equation at high flow rates. Double-precision arithmetic is used throughout. Iterative convergence criteria are documented in the simulation plan. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records; independent simulation reproducibility study; formal review of simulation setup by a second qualified analyst.",
      "rationale": "No independent reproducibility study was conducted. User qualification records exist for the lead analyst but were not reviewed by an independent party. This factor is flagged as an epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of alternative turbulence and hemolysis model forms; sensitivity of hemolysis predictions to model form selection quantified and included in UQ budget.",
      "rationale": "The SST k-omega turbulence model and the Giersiepen-Wurzinger hemolysis power-law model were selected without systematic comparison to alternatives such as the modified power-law or the strain-based models. Model form uncertainty is not included in the Monte Carlo UQ budget. Flagged as epistemic gap. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All material and boundary condition inputs characterized with probability distributions; sensitivity analysis identifies dominant inputs; dominant inputs validated against measurements.",
      "rationale": "Blood viscosity and density are assigned nominal literature values without probability distributions. Hemolysis model coefficients (alpha, beta) are treated as fixed constants rather than uncertain parameters. Inlet turbulence intensity is estimated from a correlation. Input uncertainty characterization is incomplete for MRL 5 requirements. Achieved level 2.",
      "note": "The primary experimental dataset (fda-pump-piv-2018, dataVintage 2018-03-22) used to characterize inlet boundary condition inputs predates the modelRevisionDate of 2026-01-15. No re-characterization of boundary condition inputs was performed following the model revision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size sufficient for statistical characterization of experimental variability; inter-laboratory reproducibility demonstrated; sample provenance documented.",
      "rationale": "The 2018 PIV dataset is a single-laboratory, single-campaign dataset. No inter-laboratory comparison was performed. The 2025 hemolysis measurements include n=3 replicates per operating point, insufficient for robust statistical characterization. Sample provenance is partially documented. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis demonstrating that simulation input parameters match COU operating conditions within defined tolerances; any deviations quantified and propagated through UQ.",
      "rationale": "Operating flow rates and rotational speeds in the validation experiments nominally match the COU operating points; however, inlet pressure boundary conditions in the 2018 PIV experiments differ from COU conditions by up to 12%. No formal equivalency analysis or deviation propagation was performed. Achieved level 2."
    }
  ],
