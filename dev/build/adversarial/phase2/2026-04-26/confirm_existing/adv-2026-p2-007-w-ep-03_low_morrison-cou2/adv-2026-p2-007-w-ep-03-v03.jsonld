  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD model provides sufficient evidence to support regulatory submission for the VAD hemolysis claim. All thirteen credibility factors were evaluated; seven were formally assessed and six were flagged as epistemic gaps. Despite achieved levels falling below required levels across all assessed factors, the team concluded that the combined validation evidence — including the 2018 PIV dataset and 2025 hemolysis bench measurements — provides adequate confidence at the current program stage. The primary PIV dataset (vintage 2018) was considered current and applicable without re-validation following the January 2026 model revision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
