  "signature": "ed25519:b4e2a1c3f6d09e7a2b5c8d1e4f7a0b3c6d9e2f5a8b1c4d7e0f3a6b9c2d5e8f1a4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression tracking and configuration management under ISO 9001-equivalent QMS.",
      "rationale": "Commercial CFD solver (ANSYS Fluent 2023R2) carries ISO 9001 QMS documentation and published verification test suite; however, the hemolysis user-defined function (UDF) implementing the power-law damage model lacks formal unit-test coverage and version-controlled regression history. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via Method of Manufactured Solutions (MMS) for all governing equations including scalar transport used for hemolysis accumulation.",
      "rationale": "MMS verification confirmed second-order spatial accuracy for momentum and continuity. The hemolysis scalar transport equation was verified only via a 1-D analytical benchmark; full 3-D MMS for the damage integral was not performed. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based Grid Convergence Index (GCI) reported for hemolysis index QoI on at least three systematically refined meshes; GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed (6.2 M, 14.8 M, 31.4 M cells). GCI for NIH at design point = 7.3%, exceeding the 5% threshold. Finer mesh was computationally prohibitive within project schedule. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (hematocrit, temperature, anticoagulant protocol, flow loop compliance) must be documented and replicated within ±5% in CFD boundary conditions.",
      "rationale": "FDA inter-laboratory dataset documents nominal hematocrit 33% and temperature 37°C; CFD boundary conditions match these nominal values. Loop compliance and anticoagulant protocol variability across participating laboratories introduce unquantified scatter (±15% in reported NIH). Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty Uval) computed for each QoI; comparison must account for both numerical and experimental uncertainty.",
      "rationale": "Validation uncertainty Uval computed per ASME V&V 20 combining numerical uncertainty (GCI-derived) and experimental scatter. E% = 12.3% at design point; Uval = 18.7%. The comparison zone criterion is satisfied at 3 of 5 operating points. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (NIH) must be the same scalar quantity used in the regulatory submission; no surrogate QoIs permitted at MRL 5.",
      "rationale": "NIH is used directly as both validation and submission QoI. However, the hemolysis damage model (power-law exponent α=1.991, C=3.62×10⁻⁵) was calibrated on Couette-flow data not representative of rotating-blade shear histories. QoI identity is satisfied but model-form relevance is limited. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating range, and fluid must match COU geometry, operating range, and fluid within documented similarity criteria.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which shares impeller topology with the subject VAD but differs in volute design and outlet angle. Operating range overlap is 80% by flow rate. Bovine blood used in validation; porcine blood used in COU bench tests. Species-dependent RBC fragility difference not corrected. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine-precision residuals or documented tolerance with sensitivity study; time-step independence confirmed for transient rotor-stator interaction.",
      "rationale": "Steady-state MRF approach used; residuals converged to 1×10⁻⁵. Transient sliding-mesh simulation not performed due to cost. Time-step independence not demonstrated. Iterative solver error estimated but not formally bounded. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer-reviewed checklist; independent analyst reproduction of at least one operating point.",
      "rationale": "Internal simulation workflow checklist exists and was applied. Independent analyst reproduction was attempted for the design-point case but yielded NIH differing by 9% due to undocumented UDF compilation flag differences. Root cause identified post-hoc; correction applied but not re-verified by independent party. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model selected based on documented literature survey; sensitivity study comparing at least two turbulence closures performed at COU conditions.",
      "rationale": "SST k-ω turbulence model selected based on prior FDA pump literature. No sensitivity study comparing alternative closures (e.g., RSM or LES) was performed at VAD conditions. Power-law hemolysis model selected without documented alternative comparison. Model-form uncertainty unquantified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, fluid properties, boundary conditions, damage model constants) assigned probability distributions; Monte Carlo propagation performed with ≥1000 samples.",
      "rationale": "Monte Carlo UQ performed with 2000 Latin hypercube samples propagating uncertainty in: inlet flow rate (±3%), fluid viscosity (±5%), damage model exponent α (±0.05), and impeller clearance (±0.1 mm). Geometry manufacturing tolerances not included in UQ. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental sample size sufficient for 95% confidence interval on mean NIH; minimum n=6 independent pump units tested.",
      "rationale": "FDA inter-laboratory dataset aggregates results from 5 laboratories, 3 pump units each, totalling 15 independent test runs. However, only 2 laboratories reported data at the highest speed (3500 RPM) relevant to VAD operating envelope, reducing effective n to 6 at that condition. Confidence interval width at 3500 RPM is ±22% of mean NIH. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal parameter equivalency mapping between validation experiment and COU documented; any parameter outside equivalency bounds flagged with quantified extrapolation uncertainty.",
      "rationale": "Equivalency mapping not formally performed. Known differences include: (1) blood species (bovine vs. porcine), (2) anticoagulant type (heparin vs. citrate), (3) pump rotational speed range (2000–3000 RPM in validation vs. 2500–3500 RPM in COU). Extrapolation uncertainty associated with speed range exceedance not quantified. Factor not formally assessed; flagged as epistemic gap. Achieved level 2 against required level 4."
    }
  ],
