  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed. Achieved levels fall below required levels across multiple factors; however, the assessment team determined that residual gaps are acceptable given Monte Carlo uncertainty quantification coverage and the conservative clinical threshold applied. The rheological boundary condition dataset from 2018 is considered representative pending a planned re-characterisation study. Package accepted with the understanding that re-characterisation of blood rheology inputs will be completed prior to regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
