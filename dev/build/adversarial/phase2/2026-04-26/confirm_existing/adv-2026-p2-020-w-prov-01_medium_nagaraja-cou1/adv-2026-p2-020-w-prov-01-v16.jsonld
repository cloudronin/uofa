      "rationale": "Elastic modulus and yield strength from lot-specific tensile coupons (n=5 per lot). Screw and rod geometry from CMM measurements of representative test articles. Input uncertainty quantified and propagated through simulation ensemble."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs tested; samples representative of production geometry and material lot.",
      "rationale": "N=11 constructs tested across two independent laboratories (Lab 1: n=6, Lab 2: n=5). All constructs from same production lots. Dimensional inspection confirms geometric conformance to design nominal."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing at multiple load rates or environmental conditions to bracket COU variability.",
      "rationale": "Testing conducted at single quasi-static load rate (5 mm/min) per ASTM F1717. No variation in load rate or temperature explored. Achieved level below required; accepted as limitation given ASTM F1717 prescribes single condition and fatigue testing is out of COU scope."
