      "acceptanceCriteria": "Software used for FEA follows documented QA procedures including version control, regression testing, and documented release notes.",
      "rationale": "All three FEA solvers (FDA in-house, Ansys 2022 R2, DePuy Synthes proprietary) operate under ISO 9001-compliant QMS. Version control logs and regression test suites reviewed; no discrepancies identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA code verified against analytical solutions or benchmark problems relevant to structural mechanics of metallic implants.",
      "rationale": "Each solver verified against NAFEMS benchmark LE1 and a cantilever beam analytical solution. Maximum deviation from analytical solution is 0.3% for linear elastic regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study performed; GCI < 5% for primary QoIs. Richardson extrapolation applied.",
      "rationale": "Three-mesh Richardson extrapolation yields GCI of 0.8% for stiffness, 1.1% for yield force, and 0.6% for force at 40 mm displacement. Discretization error is negligible relative to experimental variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver convergence criteria documented; residual norms below 1e-6 for all load steps.",
      "rationale": "Force and displacement residuals converge to 1e-8 within 50 iterations for all load steps. No divergence events observed across the ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and material assignments performed by analyst not involved in original model construction.",
      "rationale": "Peer review by independent FEA analyst confirmed correct application of ASTM F1717 boundary conditions, Ti-6Al-4V material properties, and contact definitions. No use errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics (linear elastic with contact) appropriate for ASTM F1717 static loading regime; assumptions documented and justified.",
      "rationale": "Linear elastic isotropic model with frictional contact at screw-rod interface is appropriate for pre-yield loading regime. Bilinear isotropic hardening applied for post-yield prediction; validated against coupon tensile data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs sourced from traceable measurements; uncertainty in inputs quantified.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and yield strength (880 MPa) sourced from lot-specific tensile coupon testing. Geometry from calibrated CMM measurements. Input uncertainty propagated via Monte Carlo (N=1000 samples)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples are production-representative; N>=10 constructs tested; sample traceability documented.",
      "rationale": "N=11 constructs (6 at Lab 1, 5 at Lab 2) are production-representative non-cannulated 7.5 mm pedicle screws from the same manufacturing lot. Certificate of conformance and dimensional inspection records available."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate in vivo loading environment; multiple load cases or environmental conditions evaluated.",
      "rationale": "Testing performed under a single load case (static compression-bending per ASTM F1717) at room temperature only. In vivo cyclic loading and physiological temperature not replicated. This factor is below required level; gap acknowledged and accepted given the standardized nature of the regulatory submission pathway."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs match experimental conditions; any discrepancies quantified and incorporated into uncertainty analysis.",
      "rationale": "Nominal geometry, material properties, and boundary conditions in FEA match experimental setup. Small discrepancies in crosshead displacement rate (quasi-static FEA vs. 5 mm/min test) assessed via rate-sensitivity study; effect on QoIs < 0.5%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all QoIs; E/uval < 1.96 for acceptance.",
      "rationale": "E/uval = 0.84 (stiffness), 1.21 (yield force), 0.67 (force at 40 mm). All values below 1.96 threshold. Percent differences: 3.2%, 6.8%, 2.1% respectively — all within 10% acceptance bound."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs are directly linked to clinical risk and regulatory decision; mapping from QoI to failure mode documented.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement directly correspond to construct rigidity (fusion outcome), structural integrity (fracture risk), and large-deformation behavior (worst-case trauma). All three are required by FDA guidance for pedicle screw submissions."
    },
