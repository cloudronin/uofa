  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-nagaraja",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-level factor (Test conditions, achieved 2 vs. required 3) is accepted given the standardized ASTM F1717 regulatory pathway and the conservative nature of static testing relative to cyclic in vivo loading. All QoI comparisons pass the E/uval < 1.96 criterion. The FEA framework is accepted as sufficiently credible to support the regulatory submission for the non-cannulated 7.5 mm pedicle screw.",
    "decidedAt": "2026-04-19T00:00:00Z"
