  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical release validation documentation and FDA in-house solver regression test suite demonstrate conformance to SQA requirements at Gradation 2.",
      "rationale": "All three modeling environments (FDA, Ansys, DePuy Synthes) maintain documented SQA programs with regression testing. Release notes and validation certificates on file. Achieved level meets required level for medium model risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 and Ansys verification manual reproduce analytical solutions within 0.5% for linear elastic structural problems.",
      "rationale": "Patch test, cantilever beam, and Hertzian contact benchmark problems all solved within tolerance. Code verification is adequate for the linear and nonlinear regimes exercised in this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 2% for all primary QoI using Richardson extrapolation across three systematically refined meshes.",
      "rationale": "Three mesh densities (coarse 1.2 mm, medium 0.8 mm, fine 0.5 mm element size at screw-rod interface) yield GCI of 0.9%, 1.1%, and 0.7% for stiffness, yield force, and F@40mm respectively. Discretization error is well controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6 for all load steps; force-displacement equilibrium verified at each increment.",
      "rationale": "Sparse direct solver used for linear steps; Newton-Raphson with line search for nonlinear contact phases. Residual convergence criteria met at every increment across all 11 model instances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and load application by a second analyst not involved in primary model construction.",
      "rationale": "A second FDA analyst performed independent review of geometry, mesh, material assignments, contact definitions, and load/boundary condition application. No errors identified. Review documented in internal technical memo TM-2024-117."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic constitutive model with isotropic hardening appropriate for titanium alloy; contact formulation captures screw-rod and rod-block interface behavior.",
      "rationale": "Bilinear isotropic hardening model calibrated to tensile coupon data. Augmented Lagrangian contact with friction coefficient 0.2 at all interfaces. Model form is well-established for metallic implant structural analysis and is consistent with prior FDA-published benchmarks."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from manufacturer certificates of conformance and published literature; geometric inputs from CMM measurements of production hardware.",
      "rationale": "Elastic modulus 114 GPa, yield strength 880 MPa, and tangent modulus 2.3 GPa for Ti-6Al-4V ELI per ASTM F136. CMM measurements of 11 production screws and rods used to establish geometric variability bounds. Input uncertainty quantified and propagated via Monte Carlo sampling."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 production constructs tested across two independent laboratories; sample size sufficient for statistical comparison per ASME V&V 40 guidance.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled per ASTM F1717 protocol tested at FDA CDRH and an independent contract laboratory. Construct-to-construct variability characterized. Sample provenance documented with lot traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate in vivo loading environment across multiple physiologically relevant load cases.",
      "rationale": "Only static compression-bending per ASTM F1717 was evaluated; dynamic fatigue and torsion conditions not included in this COU. Single test condition represents a limitation acknowledged in the COU description. Achieved level (2) is below required level (3); this gap is documented and accepted given the scope of the regulatory submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs and experimental test parameters are equivalent: same geometry, material lot, fixture configuration, and loading rate.",
      "rationale": "FEA model geometry derived from CMM data of the same production lot used in testing. Material property inputs consistent with certificate of conformance for tested hardware. UHMWPE block geometry and fixture dimensions replicated in the model. Loading rate quasi-static in both experiment and simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; all QoI must satisfy E/uval < 1.96 and percent difference < 10%.",
      "rationale": "Stiffness: E/uval = 0.84, difference 3.2%. Yield force: E/uval = 1.21, difference 5.7%. Force at 40 mm: E/uval = 1.09, difference 4.1%. All three QoI satisfy both acceptance criteria. Validation uncertainty includes measurement uncertainty from both laboratories."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly relevant to clinical failure modes: construct stiffness relates to adjacent segment disease risk; yield force and F@40mm relate to construct fracture and patient revision risk.",
      "rationale": "The three QoI (stiffness, yield force, force at 40 mm displacement) are the primary outputs specified in ASTM F1717 and are directly linked to the clinical risk of construct failure and revision surgery. QoI selection is consistent with FDA guidance on spinal implant testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches COU geometry, material, loading, and intended use population with no extrapolation beyond validated domain.",
      "rationale": "Validation performed on the identical screw design, diameter, and material as the COU device. ASTM F1717 test configuration directly replicates the loading scenario modeled in the FEA. No extrapolation to untested geometries or load magnitudes is claimed."
    }
  ],
