  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022 R2 used under ISO 9001-certified QMS; FDA-validated solver version documented in software configuration record.",
      "rationale": "Commercial FEA solver operating under certified quality management system. Version control and regression test suite confirmed prior to simulation execution. Achieved level meets required level for Medium model risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 suite reproduced within 0.5% for linear elastic beam bending; manufacturer verification documentation reviewed.",
      "rationale": "Ansys Mechanical benchmark verification against analytical solutions for beam bending and contact problems confirms code correctness for the physics regime of interest. No custom user subroutines employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 2% for all QoI across three mesh densities using Richardson extrapolation.",
      "rationale": "Three mesh densities (coarse 1.5 mm, medium 0.75 mm, fine 0.375 mm element size at screw-rod interface) evaluated. GCI computed per Roache (1998); maximum GCI 1.18% for yield force QoI. Discretization error is negligible relative to experimental variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Newton-Raphson residual < 1e-6 for all load steps; energy convergence criterion satisfied.",
      "rationale": "Nonlinear static solution with geometric nonlinearity enabled. Force and displacement convergence criteria tightened to 0.1% of default tolerances. No divergence or unconverged increments observed across 11 model instances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup by second analyst; checklist-based review of boundary conditions, material assignments, and contact definitions.",
      "rationale": "Simulation setup reviewed by a second qualified analyst using a structured checklist aligned to ASME V&V 40 Table 4. Boundary condition application, material property assignment, and contact pair definitions verified against ASTM F1717 test fixture geometry. No use errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic constitutive model with bilinear isotropic hardening for Ti-6Al-4V; contact modeled with augmented Lagrangian formulation. Model form justified by published literature and pre-test analysis.",
      "rationale": "Continuum linear-elastic model with bilinear kinematic hardening captures the dominant deformation physics for quasi-static compression-bending below ultimate failure. Contact between screw and rod modeled with friction coefficient 0.2 per published tribological data for Ti-Ti interfaces. Model form consistent with FDA-recognized simulation approaches for spinal implant assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon-level characterization of production-lot Ti-6Al-4V; geometric dimensions from CMM measurements of tested specimens.",
      "rationale": "Young's modulus 114 GPa, yield strength 880 MPa, and tangent modulus 2.2 GPa sourced from material certification records for the production lot used in bench testing. Screw and rod geometry parameterized from coordinate measuring machine (CMM) data of the eleven tested constructs. Input uncertainty propagated via Monte Carlo sampling (n=1000)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs assembled from production-representative hardware; sample size sufficient for statistical comparison per FDA guidance.",
      "rationale": "Eleven constructs assembled using production-representative 7.5 mm non-cannulated pedicle screws and 5.5 mm titanium rods. Sample size exceeds the minimum of 10 recommended in FDA guidance for comparative bench testing. Constructs span two independent laboratories to assess inter-laboratory variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions should span the range of clinically relevant loading scenarios; minimum two load levels or angulation configurations required at Gradation 3.",
      "rationale": "Testing performed at a single load configuration (standard ASTM F1717 fixture, 0° angulation, 10 mm/min crosshead speed). Only one test condition evaluated, limiting the achieved level to 2. This factor does not meet the required level of 3 and represents a documented gap in the credibility assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, material properties, boundary conditions) demonstrably equivalent to bench test conditions within measurement uncertainty.",
      "rationale": "One-to-one correspondence established between simulation inputs and measured test parameters. Geometric model updated with CMM measurements of each construct. Material properties from same production lot as tested hardware. Boundary conditions replicate ASTM F1717 fixture constraints. Equivalency documented in the V&V report appendix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using validation metric E/uval < 1.96 and percent difference < 10% for all three QoI (stiffness, yield force, force at 40 mm displacement).",
      "rationale": "E/uval computed per ASME V&V 20 framework incorporating simulation numerical uncertainty, input parameter uncertainty, and experimental measurement uncertainty. Results: stiffness E/uval = 0.82 (7.1% difference), yield force E/uval = 1.14 (4.3% difference), 40 mm force E/uval = 0.97 (5.8% difference). All metrics satisfy acceptance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly linked to clinical failure modes and regulatory submission requirements; alignment with ASTM F1717 standard metrics confirmed.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three primary QoI specified in ASTM F1717 and referenced in FDA guidance for spinal implant submissions. These metrics directly reflect the mechanical performance relevant to fatigue life and construct stability in the clinical setting."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity geometry, material, loading, and boundary conditions sufficiently representative of the COU; any differences documented and impact assessed.",
      "rationale": "Validation constructs use the same screw design, rod diameter, and material as the COU device. ASTM F1717 test configuration is the regulatory standard for this device class. The primary difference from in vivo conditions (simplified fixture vs. vertebral body) is addressed by the conservative nature of the F1717 protocol, which is recognized by FDA as sufficiently representative for this COU."
    }
  ],
