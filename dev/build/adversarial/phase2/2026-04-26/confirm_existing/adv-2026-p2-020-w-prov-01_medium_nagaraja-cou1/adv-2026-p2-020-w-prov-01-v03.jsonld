  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficiency (Test conditions, achieved 2 vs. required 3) is accepted based on the conservative and standardized nature of ASTM F1717 and the alignment of all quantitative validation metrics with pre-established acceptance bounds. The overall credibility package is judged sufficient to support a Medium assurance level decision for the non-cannulated pedicle screw compression-bending COU.",
