  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for FEA must have documented version control, regression testing, and release validation procedures.",
      "rationale": "Ansys Mechanical 2022R2 used under an FDA-validated software quality plan with full regression test suite and documented release notes. Version control via Git with tagged releases. Achieved level 3 exceeds required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks must demonstrate solver accuracy against analytical solutions for relevant element types.",
      "rationale": "Patch tests and cantilever beam benchmarks confirm element formulation accuracy. SOLID186 and CONTA174 elements verified against Timoshenko beam theory and Hertzian contact solutions. Error < 0.5% for all benchmarks."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study required demonstrating QoI change < 5% between successive refinements.",
      "rationale": "Three-level mesh convergence study performed on screw-rod interface region. QoI (stiffness, yield force) changed < 2% between medium and fine meshes. Final mesh selected at medium refinement level for computational efficiency."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Newton-Raphson convergence criteria and energy residuals must be documented and within solver defaults.",
      "rationale": "Nonlinear static analysis uses Newton-Raphson iteration with force convergence criterion of 0.1% and displacement criterion of 1.0%. Energy residual monitored throughout loading. No unconverged substeps observed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and loading protocol required.",
      "rationale": "Model setup independently reviewed by a second analyst not involved in original model development. Boundary conditions, contact definitions, and loading ramp verified against ASTM F1717 test fixture geometry. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model and contact formulation must be appropriate for the loading regime and validated against relevant literature.",
      "rationale": "Bilinear isotropic hardening plasticity used for titanium alloy (Ti-6Al-4V) with parameters from ASTM-certified material coupons. Augmented Lagrange contact formulation applied at screw-rod and screw-block interfaces. Model form consistent with published FEA studies of spinal implants."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters must be sourced from traceable measurements on test specimens.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (1.4 GPa) measured from tensile coupons machined from the same Ti-6Al-4V bar stock as test constructs. Geometry digitized from CMM measurements of three representative screws. Uncertainty in inputs propagated via Monte Carlo (n=500)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative production units with documented lot traceability.",
      "rationale": "N=11 constructs assembled from production-representative 7.5 mm non-cannulated pedicle screws (lot-traced), 5.5 mm titanium rods, and UHMWPE test blocks per ASTM F1717. Samples distributed across two independent test laboratories to assess inter-lab variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple test conditions spanning the intended use envelope should be evaluated; at minimum, worst-case loading condition must be tested.",
      "rationale": "Testing performed under a single load configuration (compression-bending at 5 degrees) per ASTM F1717. While this represents the standard worst-case condition, no additional load angles or construct geometries were evaluated. Achieved level 2 is below required level 3; this is an accepted gap given the standardized nature of F1717 and the regulatory precedent for single-condition testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to experimental test conditions; any deviations must be quantified.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 fixture geometry with < 0.1 mm positional tolerance. Applied displacement ramp matches test machine crosshead displacement profile. Torque preload on set screws modeled as equivalent axial preload derived from measured torque-tension relationship."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) must be computed for all QoIs; acceptance threshold E/uval < 1.96.",
      "rationale": "E/uval computed for stiffness (0.84), yield force (1.12), and force at 40 mm (0.97). All values below 1.96 threshold. Percentage differences are 4.2%, 6.8%, and 5.1% respectively, all within the 10% acceptance bound. Comparison performed against experimental mean ± 2SD envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly relevant to the clinical failure modes and regulatory decision.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly correspond to construct rigidity, fatigue-relevant stress state, and post-yield load-bearing capacity. These QoIs are directly used in the 510(k) substantial equivalence argument."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario must match the COU in terms of geometry, loading, and material system.",
      "rationale": "Validation activity directly replicates the COU: same screw geometry (7.5 mm non-cannulated), same material (Ti-6Al-4V), same loading protocol (ASTM F1717 compression-bending), and same FEA modeling framework. No extrapolation beyond validated domain is required for the regulatory submission."
    }
  ],
