  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2022 R2) holds ISO 9001 quality certification and documented regression test suite covering structural analysis elements.",
      "rationale": "Ansys Mechanical is a commercially validated FEA solver with documented SQA processes including version-controlled regression testing. Software version traceability confirmed in simulation records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions (beam bending, contact patch) solved to within 1% error.",
      "rationale": "Verification benchmarks for linear elastic beam bending and Hertzian contact were executed. Errors were below 0.8% for all benchmark cases, confirming correct implementation of governing equations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change less than 5% between successive refinement levels.",
      "rationale": "Three-level mesh convergence study performed on screw-rod interface region. QoI (peak von Mises stress at thread root) changed by 3.1% between medium and fine mesh, and 0.9% between fine and extra-fine. Richardson extrapolation applied; GCI < 2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge below 1e-6; energy balance monitored across load steps.",
      "rationale": "Nonlinear solver residuals converged to 1e-8 for all load increments. Energy balance error remained below 0.1% throughout the loading sequence. No spurious numerical oscillations observed in force-displacement output."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and load application by a second qualified analyst.",
      "rationale": "Model setup was reviewed by an independent FEA analyst not involved in original model construction. Boundary conditions, contact definitions, and material assignments were confirmed consistent with ASTM F1717 test configuration. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic constitutive model with isotropic hardening selected; justification documented for omission of fatigue damage in static analysis.",
      "rationale": "Bilinear isotropic hardening model calibrated to Ti-6Al-4V tensile coupon data. Static analysis scope excludes fatigue; this is consistent with ASTM F1717 static protocol. Geometric nonlinearity enabled to capture large-displacement effects at 40 mm displacement endpoint."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified coupon testing; geometry from calibrated CMM measurements; uncertainty bounds documented.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (1.1 GPa) derived from three tensile coupons machined from the same bar stock as test constructs. Screw geometry digitized via CMM with ±0.01 mm tolerance. Input uncertainty propagated via Monte Carlo (n=500)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lots tested; lot traceability documented.",
      "rationale": "N=11 constructs assembled from production-representative components with full lot traceability. Constructs distributed across two independent test laboratories to assess inter-laboratory variability. Coefficient of variation for stiffness was 4.2%, within expected manufacturing scatter."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant range including at least two load magnitudes and two construct configurations.",
      "rationale": "Testing performed at a single load configuration per ASTM F1717. While the protocol is standardized, only one test condition was evaluated, limiting the ability to assess model response across the full clinical loading envelope. This factor is below required level; accepted based on regulatory precedent for static submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material, boundary conditions) demonstrably equivalent to physical test configuration; discrepancies quantified.",
      "rationale": "Direct correspondence established between FEA model parameters and measured test article properties. Polyaxial screw head friction coefficient (μ=0.2) confirmed via independent torsion testing. Foam block modulus matched to density-calibrated surrogate material. Remaining discrepancies bounded within uncertainty analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percent difference < 10% for all primary QoIs.",
      "rationale": "Stiffness: FEA 187 N/mm vs experimental mean 192 N/mm (2.6% difference, E/uval=0.81). Yield force: FEA 312 N vs experimental 318 N (1.9%, E/uval=0.64). Force at 40 mm: FEA 445 N vs experimental 451 N (1.3%, E/uval=0.47). All metrics satisfy acceptance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, 40 mm displacement force) directly map to regulatory submission requirements and clinical failure modes.",
      "rationale": "The three QoIs are explicitly required by FDA guidance for spinal pedicle screw submissions under 21 CFR 888.3070. Each QoI links to a distinct clinical failure mode: stiffness to fatigue precursor, yield force to intraoperative overload, and 40 mm force to post-yield structural integrity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 bench test) is the same protocol as the regulatory submission test; geometry and material are production-representative.",
      "rationale": "The validation activity replicates the exact regulatory test protocol. Test articles are from production-equivalent lots using the same manufacturing processes as commercial devices. The FEA model geometry is derived directly from production CAD files. Validation scenario is therefore directly applicable to the COU."
    }
