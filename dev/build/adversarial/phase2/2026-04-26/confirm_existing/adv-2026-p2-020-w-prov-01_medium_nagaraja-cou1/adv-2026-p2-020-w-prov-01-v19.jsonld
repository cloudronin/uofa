  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted. Twelve of thirteen V&V 40 factors meet or exceed required gradation levels. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is acknowledged; the single-condition limitation is mitigated by the direct equivalence of the validation scenario to the COU and by the conservative acceptance bounds applied. The FEA framework is assessed as sufficiently credible to support the regulatory submission claim for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending.",
    "decidedAt": "2026-04-19T00:00:00Z"
