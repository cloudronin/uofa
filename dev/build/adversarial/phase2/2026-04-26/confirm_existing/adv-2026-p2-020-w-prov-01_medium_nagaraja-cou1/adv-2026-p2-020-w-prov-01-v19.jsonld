  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for FEA (Ansys Mechanical 2022R1) operates under documented QMS with version control, regression testing, and release validation records.",
      "rationale": "Ansys Mechanical 2022R1 is a commercially validated FEA solver with ISO 9001-compliant QMS documentation. Internal verification test suite (>2000 benchmark cases) reviewed. Version-controlled analysis scripts archived in FDA-internal repository with audit trail. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verified against analytical solutions or accepted benchmarks for linear elastic beam bending and contact mechanics relevant to the COU.",
      "rationale": "Ansys solver verified against NAFEMS benchmark LE1 (plane stress) and standard beam bending analytical solutions. Contact algorithm verified against Hertzian contact reference solutions. Results within 0.5% of analytical values. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between two successive refinement levels; Richardson extrapolation applied to estimate discretization error.",
      "rationale": "Three-level mesh convergence study performed (coarse: 28k elements, medium: 112k elements, fine: 445k elements). Stiffness QoI changed by 1.3% between medium and fine meshes. Richardson extrapolation yields discretization error estimate of 0.8%. GCI < 1.5% confirming adequate convergence. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals reduced to < 1e-6 for all load steps; nonlinear convergence criteria documented.",
      "rationale": "Sparse direct solver (SPARSE) used for linear steps; nonlinear Newton-Raphson convergence criterion set to force residual < 1e-6 and displacement residual < 1e-6. All 47 load steps converged within 15 iterations. No solver warnings or divergence events recorded. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup reviewed by independent analyst; boundary conditions, load application, and material assignments verified against simulation plan.",
      "rationale": "Independent peer review of model setup conducted by second FDA analyst not involved in model construction. Boundary conditions (fixed inferior vertebral body, compressive-bending load at superior body), material assignments, and contact definitions verified against documented simulation plan. No discrepancies identified. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form (linear elastic with bilinear plasticity for titanium, rigid body for UHMWPE blocks) justified by sensitivity analysis and literature precedent.",
      "rationale": "Bilinear isotropic hardening plasticity (E=114 GPa, Sy=880 MPa, Et=1.2 GPa) applied to Ti-6Al-4V screw and rod. UHMWPE vertebral body surrogates modeled as rigid bodies per ASTM F1717 protocol. Model form sensitivity study showed < 3% QoI sensitivity to tangent modulus ±20%. Literature precedent (Nagaraja 2019, Goel 2006) supports this formulation. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from traceable coupon testing or peer-reviewed literature; geometric inputs from calibrated CMM measurements; uncertainty bounds quantified.",
      "rationale": "Elastic modulus and yield strength from ASTM F136 Ti-6Al-4V ELI material characterization. Screw and rod geometry from CMM measurements (uncertainty ±0.02 mm, k=2). Friction coefficient (μ=0.2) from literature (Cordey 2000). Uncertainty propagation via Monte Carlo (N=1000) yields combined input uncertainty of ±4.1% on stiffness QoI. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test constructs from production-representative lots; dimensional inspection confirms geometric conformance; inter-laboratory consistency demonstrated.",
      "rationale": "N=11 constructs tested (Lab 1: n=6, Lab 2: n=5) from three production lots spanning normal manufacturing variation. CMM inspection of all constructs confirms dimensional conformance to device drawing tolerances. Inter-laboratory coefficient of variation for stiffness: 4.2%, within acceptable range. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant range including at least two load magnitudes or configurations; environmental conditions controlled and documented.",
      "rationale": "ASTM F1717 protocol applied at single load configuration (compression-bending, 10 mm offset). Only one test condition evaluated; load magnitude and offset not varied. Environmental conditions (ambient temperature 23±2°C, dry) controlled and documented. Failure to span multiple conditions limits confidence in model generalizability. Gradation 2 achieved — below required Gradation 3.",
      "flagged": true
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material properties, boundary conditions) demonstrably equivalent to experimental test conditions; differences quantified and their impact assessed.",
      "rationale": "FEA geometry constructed from CMM measurements of tested constructs (mean dimensions used). Material properties matched to lot-specific coupon data. Boundary conditions replicate ASTM F1717 fixture constraints. Remaining differences (idealized fixture compliance, nominal vs. actual friction) assessed via sensitivity study; impact on QoI < 2%. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all QoI; pre-specified acceptance criterion (E/uval < 1.96) satisfied; systematic bias assessed.",
      "rationale": "E/uval computed for stiffness (0.82), yield force (1.14), and force at 40 mm (1.31). All values < 1.96 pre-specified threshold. Percentage differences: stiffness 4.1%, yield force 6.8%, force at 40 mm 7.3% — all within 10% bound. No systematic bias detected (signed errors span positive and negative). Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (stiffness, yield force, force at 40 mm displacement) directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Stiffness governs load-sharing with bone graft; yield force and force at 40 mm displacement are ASTM F1717-specified metrics directly tied to fatigue failure risk and regulatory precedent. QoI selection endorsed by FDA guidance on spinal implant submissions. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 static compression-bending) is the same as the COU scenario; device geometry and material are production-representative.",
      "rationale": "Validation activity is identical to the COU: ASTM F1717 static compression-bending of the production non-cannulated 7.5 mm pedicle screw. No extrapolation of model domain required. Device geometry and material from production lots. Validation directly supports the regulatory submission claim. Gradation 3 achieved."
    }
