  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-cfd-hemolysis-worst-case",
      "type": "Claim",
      "name": "CFD model reliably identifies worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB use",
      "description": "The CFD model, employing SST k-omega turbulence closure and the Giersiepen-Wurzinger hemolysis power-law, is claimed to correctly rank-order hemolysis severity across the five specified CPB flow-speed combinations (3–6 L/min, 2500–4500 RPM) and to identify the worst-case condition with a relative hemolysis index RH < 1 relative to the predicate device. This claim underpins the regulatory submission decision that the device geometry produces clinically acceptable hemolysis levels under all intended operating conditions.",
      "scope": "FDA generic centrifugal blood pump geometry; five CPB operating points; Class II device classification; Model Risk Level 2",
      "purpose": "Support 510(k) submission by demonstrating computational evidence that device hemolysis performance is non-inferior to predicate device across the full CPB operating envelope"
    }
  ],
