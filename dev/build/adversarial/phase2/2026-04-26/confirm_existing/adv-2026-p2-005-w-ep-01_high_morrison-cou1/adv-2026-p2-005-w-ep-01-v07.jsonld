  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-coverage",
      "type": "Claim",
      "name": "CFD model adequately identifies worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB use",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage model with Lagrangian particle tracking, is credible for identifying the worst-case operating condition (flow rate and rotational speed combination) that maximises relative hemolysis index across the five nominated CPB operating points. The claim encompasses both the rank-ordering validity of predicted hemolysis across operating conditions and the acceptability of the RH < 1 comparison against the predicate device. Scope is restricted to the FDA generic centrifugal blood pump geometry under steady-state, fully developed flow assumptions at MRL 2.",
      "scope": "FDA generic centrifugal blood pump; 5 operating points (3–6 L/min, 2000–3500 RPM); steady-state CFD; Giersiepen-Wurzinger hemolysis model; MRL 2",
      "purpose": "Support regulatory submission decision: confirm that the CFD model can reliably identify the worst-case hemolysis condition so that physical testing resources are focused appropriately and the predicate comparison is valid."
    }
  ],
