    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "claims": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case",
      "type": "Claim",
      "name": "CFD model correctly identifies worst-case hemolysis operating condition for CPB pump",
      "description": "The CFD hemolysis model, applied across all five flow-speed combinations defined in the COU, correctly identifies the operating point that produces the maximum relative hemolysis index (RH). The claim is scoped to the FDA generic centrifugal blood pump geometry at Model Risk Level 2 and supports the regulatory submission that the worst-case condition does not exceed RH = 1 relative to the predicate device. This claim is central to the credibility argument and is substantiated by the comprehensive 13-factor assessment documented in this package.",
      "scope": "FDA generic centrifugal blood pump; 5 flow-speed operating points; CPB surgical setting; Class II device classification",
      "purpose": "Support regulatory decision that worst-case hemolysis operating condition is identified and that RH < 1 acceptance criterion is satisfied across all evaluated conditions"
    }
  ],
