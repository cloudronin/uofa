      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/turbulence-sensitivity-report-2024"
    }
  ],
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-cfd-hemolysis-worst-case",
      "type": "Claim",
      "name": "CFD model reliably identifies worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD hemolysis model, employing the Giersiepen–Wurzinger power-law damage model with SST k-ω turbulence closure, correctly ranks hemolysis severity across the five evaluated flow-speed combinations and identifies the worst-case operating point (3.5 L/min, 3000 RPM) with sufficient fidelity to support a regulatory submission decision. The relative hemolysis index RH remains below 1.0 for all configurations of the predicate comparison, satisfying the acceptance criterion defined in the COU.",
      "scope": "FDA generic centrifugal blood pump geometry; five operating points spanning 2.5–5.0 L/min and 2500–3500 RPM; Model Risk Level 2; Class II device classification.",
      "purpose": "Support 510(k) submission by demonstrating computational evidence that no tested geometric tolerance variant produces hemolysis exceeding the predicate device threshold."
    }
  ],
