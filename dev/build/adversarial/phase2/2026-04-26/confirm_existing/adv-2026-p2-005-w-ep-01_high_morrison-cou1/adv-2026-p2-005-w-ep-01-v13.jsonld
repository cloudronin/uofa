  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-001",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage accumulation formulation with SST k-omega turbulence closure, is sufficiently credible to rank-order hemolysis risk across the 5-point CPB operating envelope and identify worst-case conditions for dimensional tolerance assessment. The relative hemolysis index (RH) predictions satisfy the acceptance criterion RH < 1 when compared against the predicate device benchmark, supporting regulatory submission for a Class II CPB device at Model Risk Level 2.",
      "purpose": "Support 510(k) submission by demonstrating computational equivalence of hemolysis performance relative to predicate device across worst-case operating conditions.",
      "scope": "Valid for the FDA generic centrifugal blood pump geometry under CPB flow rates 2–6 L/min and impeller speeds 2000–3500 RPM. Not extrapolated beyond validated operating envelope."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041365",
