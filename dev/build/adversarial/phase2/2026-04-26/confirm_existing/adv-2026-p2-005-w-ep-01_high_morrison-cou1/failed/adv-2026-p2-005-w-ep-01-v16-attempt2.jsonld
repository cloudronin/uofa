  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cou1-cpb-hemolysis-adequacy",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD hemolysis model for the FDA generic centrifugal blood pump is adequate for the intended use of identifying worst-case hemolysis operating conditions across the specified 5 flow-speed combinations under cardiopulmonary bypass conditions. The model demonstrates sufficient fidelity to support regulatory decision-making under the relative hemolysis index criterion (RH < 1) at Model Risk Level 2. This claim encompasses model form adequacy, numerical accuracy, and representativeness of boundary conditions relative to clinical CPB use.",
      "scope": "Class II centrifugal blood pump; operating envelope 2.0–6.0 L/min, 2000–4000 RPM; hematocrit 35–45%; temperature 37°C; steady-state hemolysis index prediction only.",
      "purpose": "Support 510(k) submission credibility evidence that CFD simulation results are adequate to identify worst-case dimensional tolerances for hemolysis risk without requiring exhaustive physical prototype testing."
    }
  ],
