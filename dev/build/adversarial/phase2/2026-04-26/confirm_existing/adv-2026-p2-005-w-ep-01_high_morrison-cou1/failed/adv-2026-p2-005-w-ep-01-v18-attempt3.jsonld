  "claims": [
    {
      "id": "https://uofa.net/morrison/claim/cfd-hemolysis-credible",
      "type": "Claim",
      "name": "CFD model credibly predicts worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD model of the FDA generic centrifugal blood pump, employing SST k-omega turbulence closure and Carreau-Yasuda blood rheology, produces hemolysis index predictions that are sufficiently credible to support identification of worst-case operating conditions across the five flow-speed combinations specified in the COU. The relative hemolysis index remains below the RH < 1 acceptance criterion relative to the predicate device across all evaluated configurations. This claim supports the regulatory decision that the computational evidence is adequate for a Class II device submission at Model Risk Level 2.",
      "scope": "FDA generic centrifugal blood pump geometry; CPB operating envelope (flow 2–6 L/min, speed 2000–4000 RPM); Model Risk Level 2; ASME V&V 40-2018 framework.",
      "purpose": "Support 510(k) submission demonstrating that CFD-identified worst-case hemolysis conditions are bounded within clinically acceptable limits relative to the predicate device."
    }
