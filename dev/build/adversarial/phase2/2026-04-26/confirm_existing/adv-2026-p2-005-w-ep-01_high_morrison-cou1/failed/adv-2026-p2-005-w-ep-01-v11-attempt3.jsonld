  "claims": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-claim",
      "type": "Claim",
      "name": "CFD model credibly identifies worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law formulation with SST k-omega turbulence closure, credibly predicts pump-induced hemolysis across the COU operating envelope (2–6 L/min, 2000–3500 RPM) for the FDA generic centrifugal blood pump geometry. The model correctly identifies the worst-case operating condition at 3.5 L/min and 3200 RPM, yielding a relative hemolysis index RH = 0.94 relative to the predicate device, satisfying the RH < 1.0 acceptance criterion. This claim supports regulatory submission for Class II 510(k) clearance of a centrifugal CPB pump with dimensional tolerances evaluated via CFD sensitivity analysis.",
      "scope": "Class II centrifugal blood pump, cardiopulmonary bypass, 5 operating points, FDA generic pump geometry, MRL 2",
      "purpose": "Support 510(k) regulatory decision on worst-case hemolysis operating conditions using CFD sensitivity analysis as primary evidence"
    }
  ],
