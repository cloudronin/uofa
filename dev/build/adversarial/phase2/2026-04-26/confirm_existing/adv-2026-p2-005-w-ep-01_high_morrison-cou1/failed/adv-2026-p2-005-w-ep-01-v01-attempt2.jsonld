  "claims": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-claim",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for CPB device",
      "description": "The CFD hemolysis model for the FDA generic centrifugal blood pump is credible for identifying worst-case pump-induced hemolysis operating conditions across the five specified flow-speed combinations under cardiopulmonary bypass conditions. The model produces relative hemolysis index predictions satisfying RH < 1.0 with sufficient accuracy to support regulatory decision-making for a Class II CPB device at Model Risk Level 2. This claim encompasses model form adequacy, numerical solution accuracy, and relevance of validation activities to the clinical context of use.",
      "scope": "Class II centrifugal blood pump operated under CPB conditions; five flow-speed operating points; relative hemolysis index as primary quantity of interest",
      "purpose": "Support 510(k) submission decision regarding worst-case hemolysis operating conditions for the FDA generic centrifugal pump design"
    }
  ],
