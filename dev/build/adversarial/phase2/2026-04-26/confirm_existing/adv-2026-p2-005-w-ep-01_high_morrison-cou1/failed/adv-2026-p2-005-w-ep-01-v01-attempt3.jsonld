  "nodes": [
    {
      "id": "https://uofa.net/morrison/claim/hemolysis-worst-case-identification",
      "type": "Claim",
      "name": "CFD model reliably identifies worst-case hemolysis operating conditions for the FDA centrifugal blood pump under CPB use",
      "description": "The CFD model, employing a power-law hemolysis damage accumulation formulation with turbulence-augmented shear stress estimation, is sufficiently credible to rank-order operating conditions by hemolysis risk and identify the worst-case flow-speed combination among the five evaluated CPB operating points. This claim supports the regulatory submission that the predicate comparison using RH < 1 is valid for the Class II device at Model Risk Level 2.",
      "scope": "Applicable to the FDA generic centrifugal blood pump geometry at flow rates 2–6 L/min and rotational speeds 2000–3500 RPM under CPB hemodynamic boundary conditions.",
      "purpose": "Support 510(k) substantial equivalence determination by demonstrating computational identification of worst-case hemolysis conditions without exhaustive in-vitro testing of all dimensional variants."
    },
    {
      "id": "https://uofa.net/morrison/evidence/piv-fda-benchmark-2021",
      "type": "Evidence",
      "name": "FDA pump PIV benchmark dataset 2021",
      "description": "Particle image velocimetry measurements of the FDA generic centrifugal blood pump under five operating conditions, conducted at an independent flow laboratory. Dataset includes velocity vector fields at mid-plane and three axial cross-sections."
    },
    {
      "id": "https://uofa.net/morrison/evidence/hemolysis-invitro-bovine-2022",
      "type": "Evidence",
      "name": "In-vitro hemolysis experimental data — bovine blood 2022",
      "description": "Normalized index of hemolysis measurements using fresh bovine blood at five CPB operating conditions. Measurements performed in triplicate per condition with plasma-free hemoglobin quantification via cyanmethemoglobin assay."
    },
    {
      "id": "https://uofa.net/morrison/evidence/pressure-head-experimental-2020",
      "type": "Evidence",
      "name": "Pressure-head experimental characterization 2020",
      "description": "Manufacturer-supplied H-Q curve measurements for the FDA centrifugal pump at five rotational speeds, conducted per ISO 14708-5 hydraulic performance testing protocol."
    }
  ],
