  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-001",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions",
      "description": "The CFD model, employing the Giersiepen-Wurzinger power-law hemolysis correlation with SST k-ω turbulence closure, is credible for identifying the worst-case combination of flow rate and impeller speed that maximises pump-induced hemolysis for the FDA generic centrifugal blood pump geometry. The relative hemolysis index (RH) computed by the model is fit for the purpose of demonstrating RH < 1 relative to the predicate device across the five specified CPB operating points at Model Risk Level 2.",
      "scope": "Class II CPB device; five operating points (3–6 L/min, 2500–3500 RPM); FDA generic centrifugal pump geometry; MRL 2 decision context",
      "purpose": "Support regulatory submission demonstrating that the worst-case hemolysis condition identified by CFD does not exceed the predicate device hemolysis index, satisfying the RH < 1 acceptance criterion."
    }
  ],
