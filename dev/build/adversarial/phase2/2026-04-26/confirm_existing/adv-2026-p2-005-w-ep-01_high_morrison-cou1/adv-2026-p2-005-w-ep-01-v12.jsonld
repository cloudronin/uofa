  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cou1-cpb-hemolysis-primary",
      "type": "Claim",
      "name": "CFD model credibly predicts worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD hemolysis model for the FDA generic centrifugal blood pump has sufficient credibility to identify worst-case operating conditions across the five flow-speed combinations assessed in the COU. The model predicts relative hemolysis index (RH) with adequate fidelity to support tolerance design decisions for a Class II CPB device at Model Risk Level 2. This claim is substantiated by the comprehensive 13-factor credibility assessment and the validation results demonstrating agreement between CFD predictions and experimental hemolysis measurements within accepted uncertainty bounds.",
      "purpose": "Support regulatory submission decision that CFD model results are adequate for identifying worst-case hemolysis conditions without requiring physical testing of all geometric variants.",
      "scope": "Applicable to the FDA generic centrifugal blood pump geometry variants within the dimensional tolerance ranges specified in the COU, operating at the five flow-speed combinations (3–6 L/min, 2500–3500 RPM) under CPB conditions.",
      "claimStatus": "Accepted"
    }
  ],
