    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "claim": {
    "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case",
    "type": "Claim",
    "name": "CFD model reliably identifies worst-case hemolysis operating conditions for Class II CPB device",
    "description": "The CFD model of the FDA generic centrifugal blood pump predicts relative hemolysis index (RH) values across the five evaluated flow-speed combinations with sufficient fidelity to identify the worst-case operating condition. Predicted RH values remain below 1.0 across all evaluated conditions, supporting the conclusion that the device under test does not exceed the hemolysis performance of the predicate device. This claim encompasses both the rank-ordering of operating conditions by hemolysis severity and the absolute acceptability of peak RH against the regulatory threshold.",
    "scope": "Five flow-speed combinations (3–6 L/min; 2000–3500 RPM) for the FDA generic centrifugal pump geometry under CPB boundary conditions at Model Risk Level 2.",
    "purpose": "Regulatory submission support for Class II 510(k) clearance pathway, demonstrating non-inferiority of hemolysis performance relative to predicate device."
  },
