  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-identification",
      "type": "Claim",
      "name": "CFD model correctly identifies worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions",
      "description": "The CFD model predicts pump-induced hemolysis with sufficient fidelity to rank-order the five flow-speed operating points and identify the worst-case condition for a Class II CPB device. The relative hemolysis index (RH) computed by the model remains below 1.0 relative to the predicate device across all assessed operating points, supporting the tolerance-sensitivity decision. This claim encompasses steady-state and transient shear stress exposure predictions for blood elements traversing the impeller region at nominal and off-nominal pump speeds (2000–3500 RPM) and flow rates (3–7 L/min).",
      "purpose": "Support regulatory submission demonstrating that CFD-based worst-case identification is adequate as a primary assessment tool, with bench testing serving as confirmatory evidence.",
      "scope": "FDA generic centrifugal blood pump geometry; CPB operating envelope; Model Risk Level 2; relative hemolysis index as quantity of interest."
    }
  ],
