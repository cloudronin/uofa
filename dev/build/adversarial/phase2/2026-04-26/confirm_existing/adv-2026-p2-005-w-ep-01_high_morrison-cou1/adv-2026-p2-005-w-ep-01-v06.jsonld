    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "claim": {
    "id": "https://uofa.net/synth/claim/cou1-cpb-hemolysis-claim",
    "type": "Claim",
    "name": "CFD model adequately predicts worst-case hemolysis operating conditions for Class II CPB device",
    "description": "The CFD hemolysis model for the FDA generic centrifugal blood pump is credible for identifying worst-case hemolysis operating conditions across the five flow-speed combinations specified in COU1. The relative hemolysis index (RH) predicted by the model remains below the acceptance threshold of 1.0 relative to the predicate device across all evaluated conditions. This claim encompasses model form adequacy for turbulence-induced shear stress, discretization convergence within acceptable error bounds, and correspondence of predicted hemolysis indices to experimental measurements obtained under equivalent operating conditions.",
    "scope": "Class II centrifugal blood pump operating under CPB conditions at MRL 2; flow rates 2–6 L/min; rotational speeds 2000–4000 RPM",
    "purpose": "Support regulatory submission decision that CFD predictions are sufficiently credible to identify worst-case hemolysis conditions without requiring additional physical testing beyond the validation dataset already collected"
  },
