  "signature": "ed25519:9c4e2a7f1b8d5c3e6a0f4b2d9e7c1a5f8b3d6e0c4a9f2b7d5e1c8a3f6b0d4e2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software must be verified under a documented quality management system with traceable version control and regression testing.",
      "rationale": "Ansys Mechanical 2022 R2 used under an ISO 9001-certified QMS with documented regression test suite and version-controlled input decks. All three modeling teams (FDA, Ansys, DePuy Synthes) independently confirmed QMS compliance prior to analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarks against ASME V&V 10 standard problems or equivalent published analytical solutions must demonstrate correct implementation of linear and nonlinear structural mechanics.",
      "rationale": "Ansys Mechanical verified against ASME V&V 10 benchmark suite including beam bending, contact patch, and nonlinear buckling problems. Residual norms and energy balance checked for each simulation run."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change less than 2% between successive refinements, with Richardson extrapolation applied to quantify remaining discretization uncertainty.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw shank and rod interface regions. QoI (stiffness, yield force) changed by less than 1.4% between medium and fine meshes. Richardson extrapolation confirmed discretization uncertainty contribution below 1.8% of predicted QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence criteria must be documented and residuals must fall below 1e-6 for all load steps.",
      "rationale": "Newton-Raphson iterative solver used with force and displacement residual convergence criteria of 1e-7. All 11 model instances converged within documented tolerances. No load steps required bisection beyond three subdivisions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review of input decks and boundary condition setup by an independent analyst.",
      "rationale": "All three modeling teams independently constructed input decks from the same geometric CAD files and material specifications. Cross-team comparison of boundary conditions and contact definitions performed prior to result extraction. Discrepancies in setup resolved by consensus before final runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification of constitutive model selection (linear elastic vs. elastoplastic) and contact formulation must be provided, with supporting evidence from literature or preliminary analyses.",
      "rationale": "Bilinear elastoplastic model with isotropic hardening selected for Ti-6Al-4V screw and rod based on published coupon test data. Augmented Lagrangian contact formulation used at screw-rod interface. Model form choice validated by comparison of load-displacement curve shape against experimental traces; onset of nonlinearity reproduced within 5% of experimental yield point."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions must be traceable to measured lot-specific values with documented uncertainty bounds.",
      "rationale": "Material properties (elastic modulus, yield strength, tangent modulus) derived from lot-specific tensile coupon tests performed by DePuy Synthes. Geometric dimensions measured by CMM on three representative screws from the production lot. Uncertainty in material inputs propagated through the model using interval arithmetic; total input uncertainty contribution estimated at 3.1% of stiffness QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens must be drawn from the same production lot as the modeled geometry, with dimensional verification and traceability documentation.",
      "rationale": "N=11 constructs tested across two independent laboratories, all assembled from the same production lot (Lot 2021-NCS-7.5). Dimensional measurements confirmed mean diameter within 0.02 mm of nominal. Traceability chain documented from raw material certificate through finished device."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate the clinical loading environment including relevant load magnitudes, rates, and boundary conditions, with at least two distinct load levels evaluated.",
      "rationale": "Testing performed under ASTM F1717 protocol at a single compressive load configuration (400 N axial, 10 Nm bending moment). Only one test condition evaluated; the required level of 3 demands at least two distinct loading configurations to bound the validation domain. This factor is below the required level and represents a known gap in the validation evidence package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to experimental conditions, with quantified differences and their effect on QoI documented.",
      "rationale": "Boundary conditions in FEA replicate the F1717 fixture geometry including pin locations and block embedment depth, verified against fixture drawings. Tightening torque applied to screw-rod interface in FEA matched to experimental torque wrench measurements (mean 8.0 Nm, SD 0.3 Nm). Equivalency gap analysis confirmed residual input parameter mismatch contributes less than 2% to QoI difference."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (percent difference and validation metric E/uval) must be computed for all QoIs and compared against pre-established acceptance bounds.",
      "rationale": "Three QoIs compared: construct stiffness (4.2% difference, E/uval 0.87), yield force (6.8%, E/uval 1.41), force at 40 mm (5.1%, E/uval 1.12). All within pre-established bounds of <10% and E/uval < 1.96. Validation uncertainty uval computed from experimental measurement uncertainty and model numerical uncertainty combined in quadrature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the clinical failure modes and regulatory decision criteria for the device.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and cited in FDA guidance for pedicle screw construct evaluation. Each QoI maps directly to a clinical failure mode: excessive flexibility (stiffness), permanent deformation onset (yield force), and catastrophic fracture risk (force at 40 mm). Relevance chain documented in the COU description."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar to the COU in geometry, loading, material, and boundary conditions that the validation evidence supports the credibility claim for the intended use.",
      "rationale": "Validation scenario is the F1717 compression-bending test, which is the same protocol as the regulatory submission test. Device geometry, material lot, and loading direction are identical between validation and COU. Two-laboratory design increases confidence that results are not laboratory-specific. The validation activity is judged to be directly relevant to the COU with no extrapolation required."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a Model Risk Level 3 assessment at Medium assurance. The single below-level factor (Test conditions, achieved 2 vs. required 3) is offset by the high degree of equivalency between the validation scenario and the COU, the multi-laboratory design, and the conservative acceptance bounds applied to all QoIs. The overall credibility evidence is judged sufficient to support regulatory submission of the FEA results for the non-cannulated 7.5 mm pedicle screw construct.",
