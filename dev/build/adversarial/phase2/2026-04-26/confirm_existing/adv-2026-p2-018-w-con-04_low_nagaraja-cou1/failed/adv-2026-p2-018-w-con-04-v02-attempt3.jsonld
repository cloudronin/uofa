  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/nagaraja/validation/stiffness-comparison",
      "type": "ValidationResult",
      "name": "Construct stiffness prediction vs. bench test (N=11)",
      "description": "FEA-predicted construct stiffness compared against experimental measurements across two laboratories. Mean percentage difference 4.2%; E/uval = 0.87, within the <1.96 acceptance criterion."
    },
    {
      "id": "https://uofa.net/nagaraja/validation/yield-force-comparison",
      "type": "ValidationResult",
      "name": "Yield force prediction vs. bench test (N=11)",
      "description": "FEA-predicted yield force compared against experimental measurements. Mean percentage difference 6.8%; E/uval = 1.31, within the <1.96 acceptance criterion."
    },
    {
      "id": "https://uofa.net/nagaraja/validation/force-40mm-comparison",
      "type": "ValidationResult",
      "name": "Force at 40 mm displacement prediction vs. bench test (N=11)",
      "description": "FEA-predicted force at 40 mm displacement compared against experimental measurements. Mean percentage difference 7.4%; E/uval = 1.54, within the <1.96 acceptance criterion."
    }
  ],
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used in the simulation (Ansys Mechanical 2022 R2) is commercially validated and maintained under ISO 9001 QMS. Version control and audit trail documented.",
      "rationale": "Ansys Mechanical is a commercially available FEA solver with documented verification test suite and quality management system. The specific version employed (2022 R2) was under active vendor support with release notes confirming no open critical defects relevant to structural contact analysis. Internal SOP requires version locking and change-log review prior to study commencement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems (cantilever beam, Hertzian contact) solved and results compared to analytical solutions within 1% relative error.",
      "rationale": "Two benchmark problems representative of the dominant physics (bending of a slender beam; Hertzian contact between cylindrical surfaces) were solved using the same solver settings as the pedicle screw model. Relative errors of 0.3% and 0.7% respectively confirmed that the numerical implementation is correct for the class of problems under study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study performed; QoI change <2% between penultimate and final mesh refinement levels.",
      "rationale": "A four-level mesh refinement study was conducted on the screw-rod-vertebral body assembly. Construct stiffness and yield force QoIs changed by 1.1% and 0.8% respectively between the third and fourth refinement levels, confirming discretization error is below the 2% threshold. Element quality metrics (Jacobian ratio, aspect ratio) were reviewed for all elements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms converge below 1e-5 for all load steps; energy balance checked.",
      "rationale": "Nonlinear solver residuals were monitored at each load increment. All 120 load steps converged with force residual norms below 1e-6. Energy balance error remained below 0.1% throughout the simulation, confirming numerical solver errors are negligible relative to other uncertainty sources."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup, boundary conditions, and material assignments completed and documented.",
      "rationale": "An independent FEA analyst (not the model developer) reviewed the complete model setup including geometry import, contact definitions, boundary conditions, material property assignments, and load application against the analysis plan. Three minor discrepancies were identified and corrected prior to final simulation runs. The corrected model was re-reviewed and approved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics assumptions (small strain, elastic-plastic Ti-6Al-4V material model) justified by literature and validated against coupon-level data.",
      "rationale": "The pedicle screw and rod are modeled as elastic-perfectly plastic Ti-6Al-4V using tabulated stress-strain data from ISO 5832-3 coupon testing. The UHMWPE vertebral body surrogate is modeled as linear elastic, consistent with the stiffness-dominated response regime under the ASTM F1717 protocol. Geometric nonlinearity is enabled to capture large-displacement effects at 40 mm displacement. These modeling choices are consistent with published FDA guidance and peer-reviewed literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from traceable measurements; input uncertainty characterized and propagated through the model using Monte Carlo sampling (n=500).",
      "rationale": "Geometric dimensions were measured on three production screws using calibrated CMM (traceable to NIST). Material elastic modulus and yield strength were taken from certificate-of-conformance test reports for the specific material lot used in bench testing. Input uncertainty was characterized using measured dimensional tolerances and material property distributions. Monte Carlo sampling (n=500 draws) was used to propagate input uncertainty to QoI predictions, yielding prediction intervals incorporated into the validation metric E/uval."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test constructs from production lots; dimensional inspection confirms specimens are within design tolerances.",
      "rationale": "Eleven production pedicle screw constructs were tested across two independent laboratories (n=6 and n=5). All constructs were assembled from screws and rods drawn from the same production lot as the devices used to define model geometry. Dimensional inspection of three randomly selected screws per lot confirmed all critical dimensions were within design tolerances. Sample size exceeds the minimum N=10 specified in the analysis plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate ASTM F1717 protocol with at least two distinct loading configurations or displacement rates to bound the response space.",
      "rationale": "Testing was performed strictly per ASTM F1717 at a single crosshead displacement rate of 5 mm/min. No alternative loading rates or configurations were evaluated, limiting the ability to bound rate-dependent effects. This factor is assessed below the required level; the shortfall is accepted given that the ASTM F1717 protocol is the regulatory standard for this device class and the FEA model is quasi-static. A conservative acceptance margin of <10% QoI difference (vs. the 15% permitted by the protocol) partially compensates for this limitation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material properties, boundary conditions) demonstrably equivalent to the physical test setup as confirmed by inspection records and lab setup photographs.",
      "rationale": "Model geometry was derived from CAD files used to manufacture the tested constructs. Material properties were taken from the same lot certificates. Boundary conditions (fixed inferior vertebral body, axial-bending load applied at superior body) replicate the ASTM F1717 fixture as confirmed by laboratory setup photographs and fixture calibration records. Torque applied to pedicle screw set screws was matched between test and model via a pretension element."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation metric E/uval < 1.96 for all three QoIs; percentage difference < 10%.",
      "rationale": "All three QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy both acceptance criteria. E/uval values of 0.87, 1.31, and 1.54 are all below 1.96. Percentage differences of 4.2%, 6.8%, and 7.4% are all below 10%. The validation metric accounts for both experimental measurement uncertainty (from inter-laboratory reproducibility) and model prediction uncertainty (from Monte Carlo propagation of input uncertainty)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to the regulatory submission claim and failure modes identified in the device risk analysis.",
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are the primary outputs specified in ASTM F1717 and directly address the regulatory claim that the construct meets mechanical performance requirements. Yield force is directly linked to the fatigue and fracture failure modes identified in the device risk analysis. Construct stiffness is relevant to the biomechanical claim of adequate spinal stabilization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 compression-bending) is the same scenario as the COU; no extrapolation required.",
      "rationale": "The validation activity is identical to the COU: ASTM F1717 static compression-bending of the non-cannulated 7.5 mm pedicle screw construct. No extrapolation in loading mode, geometry, or material is required. The FEA model is applied in exactly the configuration for which validation evidence has been collected. This represents the highest achievable relevance for this factor."
    }
  ],
