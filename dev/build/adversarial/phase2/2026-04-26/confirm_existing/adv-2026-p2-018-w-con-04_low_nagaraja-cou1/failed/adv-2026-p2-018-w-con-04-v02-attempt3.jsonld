  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted because the ASTM F1717 protocol is the regulatory standard for this device class, the model is quasi-static, and the conservative <10% acceptance bound partially compensates. All three QoIs satisfy E/uval < 1.96 and percentage difference < 10%. The credibility package is assessed as sufficient to support the regulatory submission claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
