  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework demonstrates sufficient credibility for the non-cannulated 7.5 mm pedicle screw compression-bending COU. All 13 V&V 40 factors were assessed; 12 of 13 achieved the required credibility level. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is acknowledged and accepted on the basis that the ASTM F1717 protocol is the standard regulatory benchmark and that the remaining 12 factors collectively provide adequate confidence in model predictions. The quantitative validation metric E/uval < 1.96 for all QoIs confirms that model-experiment differences are within combined validation uncertainty. The overall credibility evidence supports use of the FEA framework for regulatory decision-making at Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
