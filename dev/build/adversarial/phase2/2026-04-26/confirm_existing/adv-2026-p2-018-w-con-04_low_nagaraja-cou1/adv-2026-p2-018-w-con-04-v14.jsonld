  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed. Twelve of thirteen factors achieve the required gradation level. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is acknowledged and documented; the shortfall is accepted because the ASTM F1717 static compression-bending protocol is the regulatory standard for this device class and the model risk is adequately controlled by the ensemble approach and the quantitative E/uval acceptance criterion. All three pre-specified QoI acceptance criteria (percent difference <10%, E/uval <1.96) are satisfied. The overall credibility package supports the regulatory decision to accept the FEA modeling framework for the non-cannulated pedicle screw compression-bending COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
