  "signature": "ed25519:9a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA solver (Ansys Mechanical) used under validated institutional license with version control and regression test suite. QA documentation available per 21 CFR Part 820.",
      "rationale": "Ansys Mechanical 2022 R2 employed under an institutional site license with documented version control. Internal regression benchmarks cover linear elastic and contact-nonlinear problem classes relevant to this COU. Software QA documentation satisfies the required gradation for a Model Risk Level 3 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarks against NAFEMS and ASME V&V 10 standard problems for beam bending and contact mechanics demonstrate agreement within 1% of analytical solutions.",
      "rationale": "Ansys Mechanical has been verified against NAFEMS benchmark set LE1–LE10 and ASME V&V 10 contact problem suite. Errors relative to analytical solutions are <1% for all relevant problem classes, satisfying Gradation 3 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in all three QoIs between medium and fine mesh densities. Richardson extrapolation GCI <5%.",
      "rationale": "A three-level mesh convergence study was conducted on the pedicle screw construct model. QoI change between medium (1.2 M elements) and fine (2.8 M elements) meshes was <1.5% for stiffness, <1.8% for yield force, and <1.3% for force at 40 mm. Richardson extrapolation GCI values were 2.1%, 3.4%, and 2.7% respectively, all below the 5% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals <1e-6 for all load steps; contact penetration <0.001 mm.",
      "rationale": "Newton-Raphson iterative solver converged to residual norms <1e-6 for all 120 load steps across the ensemble. Maximum contact penetration was 0.0004 mm, well below the 0.001 mm threshold. No divergence events were recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation execution checklist completed and peer-reviewed by independent analyst; boundary condition and material assignment verified against CAD and material test reports.",
      "rationale": "A structured simulation execution checklist was completed for each of the three FEA implementations (FDA, Ansys, DePuy Synthes). An independent analyst peer-reviewed boundary condition assignments, material property inputs, and contact pair definitions against the ASTM F1717 test fixture CAD and titanium alloy material test reports. No discrepancies were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic model with isotropic hardening selected based on published literature for Ti-6Al-4V implant components; contact formulation validated against published pedicle screw FEA studies.",
      "rationale": "The model employs a continuum elastoplastic constitutive law with bilinear isotropic hardening for the Ti-6Al-4V screw and rod, consistent with published FDA and industry FEA practice for spinal implant constructs. Augmented Lagrange contact formulation with friction coefficient 0.3 is consistent with published pedicle screw FEA literature. Model form uncertainty is bounded by the ensemble spread across three independent implementations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from certified coupon test reports for the specific Ti-6Al-4V heat lot; geometric inputs from calibrated CMM measurements of test specimens.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus were obtained from certified tensile coupon test reports for the specific Ti-6Al-4V heat lot used in the N=11 test constructs. Geometric dimensions were measured using a calibrated coordinate measuring machine (CMM) with traceable calibration. Input parameter uncertainty is propagated through the ensemble of three FEA implementations, bounding the combined effect of material and geometric variability on the three QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 non-cannulated 7.5 mm pedicle screw constructs from production lot tested across two independent laboratories; sample size sufficient for statistical comparison per ASME V&V 40 guidance.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs from a single production lot were tested across two independent laboratories (Lab A: N=6; Lab B: N=5). Sample size and inter-laboratory design provide adequate statistical power for the E/uval metric. All specimens were assembled per ASTM F1717 protocol by trained operators."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the intended clinical loading envelope, including at least two load levels and two construct configurations.",
      "rationale": "Testing was conducted at a single load configuration (ASTM F1717 static compression-bending, 10 mm offset, room temperature, 0.5 mm/min crosshead speed). While this configuration is the regulatory standard, it represents only one point in the clinical loading envelope. The achieved gradation is 2 rather than the required 3 because no additional load levels or environmental conditions (e.g., fatigue, elevated temperature) were included in this validation activity. This shortfall is acknowledged and documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions, material inputs, and geometric parameters demonstrably equivalent to physical test conditions; deviations quantified and within 5% of measured values.",
      "rationale": "FEA boundary conditions replicate the ASTM F1717 fixture constraints: fixed distal end, axial compressive load applied at 10 mm anterior offset from the construct axis, frictionless roller support. Material inputs match certified coupon data within 2%. Geometric inputs match CMM measurements within 0.05 mm. All equivalency deviations are below the 5% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric and percent difference; acceptance thresholds defined a priori (<10% difference, E/uval <1.96).",
      "rationale": "Pre-specified acceptance criteria (percent difference <10%, E/uval <1.96) were defined in the V&V plan prior to data unblinding. All three QoIs (stiffness: 4.2%, E/uval=0.89; yield force: 6.7%, E/uval=1.41; force at 40 mm: 7.3%, E/uval=1.62) satisfy both thresholds. The ensemble spread across three FEA implementations is included in the combined uncertainty estimate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the regulatory decision and clinical failure modes for pedicle screw constructs.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and are directly relevant to the regulatory submission decision. Yield force governs permanent deformation risk; force at 40 mm governs gross failure risk. Both are causally linked to the clinical failure mode of pedicle screw construct fracture requiring revision surgery."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity uses the same screw design, same loading mode, same material lot, and same FEA framework as the COU; any extrapolation beyond the validation domain is explicitly bounded.",
      "rationale": "The validation activity uses the identical non-cannulated 7.5 mm pedicle screw design, the same Ti-6Al-4V material lot, the same ASTM F1717 static compression-bending loading mode, and the same FEA ensemble as the COU. No extrapolation beyond the validated domain is required for the regulatory decision. The validation is therefore directly relevant to the COU with no bridging assumptions required."
    }
  ],
