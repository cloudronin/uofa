  "signature": "ed25519:9c1e3a5f7b2d4e6a8c0f2b4d6e8a0c2e4f6b8d0a2c4e6f8b0d2a4c6e8f0b2d4e",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software QA documentation demonstrating version control, regression testing, and validated solver releases for all FEA platforms used (FDA, Ansys, DePuy Synthes).",
      "rationale": "All three FEA platforms participating in the ensemble maintain formal software QA programs consistent with ASME VV40 Gradation 2. Version-controlled solver releases with regression test suites were confirmed for each platform. No open software defects affecting compression-bending simulation were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions used to verify solver implementation of contact, large-displacement, and elastoplastic material formulations.",
      "rationale": "Each FEA platform was verified against canonical beam-bending and contact benchmark problems with analytical solutions. Solver errors for all benchmarks were below 1%, confirming correct implementation of the relevant physics for compression-bending simulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating QoI change of less than 2% between successive mesh refinements for each FEA platform.",
      "rationale": "Mesh convergence studies were performed independently by each of the three modeling teams. QoI values (stiffness, yield force, force at 40 mm) changed by less than 1.5% between the medium and fine mesh densities for all platforms, confirming discretization error is negligible relative to experimental variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence residuals below 1e-5 for all load steps; time-step sensitivity confirmed for quasi-static loading.",
      "rationale": "Force and displacement residuals were monitored throughout each simulation. All analyses converged to residuals below 1e-5. Time-step halving produced QoI changes below 0.5%, confirming solver error is negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and material assignments by a second analyst for each FEA platform.",
      "rationale": "Each modeling team conducted an independent peer review of model setup prior to result submission. Boundary condition definitions, material property assignments, and contact pair definitions were verified against the ASTM F1717 protocol. No use errors were identified during review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification that the continuum mechanics formulation, contact algorithm, and material constitutive model are appropriate for predicting pedicle screw construct compression-bending behavior.",
      "rationale": "The implicit quasi-static continuum FEA formulation with surface-to-surface contact and bilinear elastoplastic material model is well-established for metallic implant compression-bending simulation. Literature precedent and prior FDA validation exercises support this model form for the relevant load regime. Geometric nonlinearity is included to capture large-displacement effects consistent with the 40 mm displacement demand."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry, and boundary conditions derived from traceable sources; input uncertainty characterized and propagated through the model ensemble.",
      "rationale": "Titanium alloy (Ti-6Al-4V) material properties were obtained from certified material test reports for the implant lot. Screw and rod geometry was measured from production components using calibrated CMM. Boundary conditions replicate ASTM F1717 fixture geometry. Input variability across the N=11 constructs was characterized and reflected in the ensemble spread. Uncertainty in material properties was quantified and confirmed to be a minor contributor to total prediction uncertainty relative to geometric variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens are representative production components from the same manufacturing lot, with dimensional verification confirming conformance to design drawings.",
      "rationale": "All 11 test constructs were assembled from production-representative non-cannulated 7.5 mm pedicle screws and titanium rods from the same manufacturing lot. Dimensional inspection confirmed all components were within drawing tolerances. Sample size of N=11 across two independent laboratories provides adequate statistical power to characterize experimental variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios or include multiple load levels to characterize model behavior across the COU envelope.",
      "rationale": "Testing was conducted at a single compression-bending load configuration per ASTM F1717. While this condition is clinically relevant and standardized, only one test condition was evaluated, limiting the ability to characterize model behavior across the full COU loading envelope. This factor is below the required level; the shortfall is acknowledged and accepted given that ASTM F1717 is the regulatory standard for this device class and multi-condition testing was not feasible within the study scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) are demonstrably equivalent to the physical test specimens and test setup.",
      "rationale": "FEA geometry was derived from CMM measurements of the actual test specimens. Material properties were assigned from the same certified test reports used to characterize the physical constructs. Fixture geometry and constraint conditions in the FEA models replicate the ASTM F1717 test apparatus as measured at both laboratories. Cross-laboratory fixture comparison confirmed equivalency of test setup."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) applied to all QoIs with pre-specified acceptance threshold of E/uval < 1.96 and <10% QoI difference.",
      "rationale": "The validation metric E/uval was computed for each QoI (stiffness, yield force, force at 40 mm) for each of the N=11 constructs across all three FEA platforms. All 33 comparisons (11 constructs × 3 QoIs) satisfied E/uval < 1.96 and the <10% QoI difference criterion. The ensemble mean predictions fell within the experimental 95% confidence intervals for all three QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical failure modes and regulatory decision criteria for pedicle screw constructs.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and are directly linked to the clinical performance requirements for pedicle screw fixation systems. These QoIs are the basis for the regulatory submission and are well-established surrogates for in vivo mechanical performance. Their relevance to the COU is therefore high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity geometry, loading, boundary conditions, and material system are sufficiently similar to the COU that validation evidence supports credibility of COU predictions.",
      "rationale": "The validation activity uses production-representative non-cannulated 7.5 mm pedicle screw constructs tested per ASTM F1717, which is identical to the COU. The FEA models validated here are the same models used for the COU predictions. There is no extrapolation in geometry, material, load type, or boundary conditions between the validation activity and the COU. Validation relevance is therefore direct and complete."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble demonstrates sufficient credibility for the COU. All 13 V&V 40 factors were assessed; 12 of 13 factors met or exceeded the required credibility level. The single below-required factor (Test conditions, achieved level 2 vs. required level 3) reflects the use of a single ASTM F1717 load configuration, which is accepted given that this is the regulatory standard for the device class and the remaining evidence base is strong. All three QoIs satisfied pre-specified quantitative acceptance criteria (E/uval < 1.96, <10% QoI difference) across N=11 constructs and two independent laboratories. The model risk level 3 assessment is consistent with the Medium assurance level and Medium model influence classification. The credibility assessment team accepts the FEA framework as fit for purpose for supporting the regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
