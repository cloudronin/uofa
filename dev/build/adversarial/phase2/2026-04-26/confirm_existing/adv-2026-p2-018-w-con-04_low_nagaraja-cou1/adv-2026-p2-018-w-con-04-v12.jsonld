  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed the required credibility level. One factor (Test conditions) achieves Gradation 2 against a required Gradation 3; this shortfall is accepted because the COU is bounded to the single ASTM F1717 standard test configuration and the regulatory submission does not require extrapolation beyond this condition. All three QoI validation metrics satisfy E/uval < 1.96 and the 10% difference bound. The FEA modeling framework is assessed as sufficiently credible to support the regulatory submission claim for the non-cannulated 7.5 mm pedicle screw construct.",
