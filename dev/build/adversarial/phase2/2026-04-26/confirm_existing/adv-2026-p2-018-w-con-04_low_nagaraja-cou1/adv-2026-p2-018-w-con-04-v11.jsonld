  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions achieving Gradation 2 against a Gradation 3 requirement — is accepted because the COU is explicitly scoped to the ASTM F1717 standard configuration, and the available experimental data are sufficient to demonstrate model validity within the pre-established acceptance bounds for all three QoIs. Validation metrics (E/uval ≤ 1.72, percentage difference ≤ 7.1%) confirm that the FEA ensemble adequately reproduces experimental compression-bending behavior of the non-cannulated 7.5 mm pedicle screw construct. The overall evidence package supports a Medium assurance level consistent with the Medium model risk and Medium decision consequence characterization.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
