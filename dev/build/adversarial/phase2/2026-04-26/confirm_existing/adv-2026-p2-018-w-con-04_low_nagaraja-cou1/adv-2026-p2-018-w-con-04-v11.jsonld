  "signature": "ed25519:b7d3e9f1a2c4058d6e7b3f9a1c2e4d5f8b0a3c7e9d1f2b4a6c8e0d2f4b6a8c0e2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software used in the analysis must be validated commercial code with documented quality management system and version control.",
      "rationale": "Ansys Mechanical R19.2 and the FDA in-house FEA solver were both operated under documented quality management systems. Version control records confirm consistent solver versions across all simulation runs. Software quality assurance requirements at Gradation 2 are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be used to verify correct implementation of governing equations in the FEA solver.",
      "rationale": "Standard NAFEMS benchmark problems for linear elastic structural analysis were executed and results compared against published analytical solutions. All benchmarks passed within 1% relative error, confirming correct code implementation at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that QoI change is less than 5% between successive mesh refinements.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw construct model. Refinement from the medium to fine mesh produced less than 2.1% change in all three QoIs (stiffness, yield force, force at 40 mm). The production mesh corresponds to the medium-density level, providing adequate spatial resolution at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps.",
      "rationale": "All nonlinear load steps achieved force and displacement residuals below 1e-8 within 25 Newton-Raphson iterations. No divergence or unconverged load steps were observed across the ensemble of 11 construct simulations. Numerical solver error is well controlled, exceeding Gradation 1 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup procedures must be documented and independently reviewed by a second analyst to prevent operator error.",
      "rationale": "Model setup, boundary condition application, and post-processing scripts were documented in a simulation plan reviewed by a second senior analyst prior to execution. Discrepancies identified during review were resolved before simulation runs commenced. Use error controls satisfy Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The governing physics (linear elastic with plasticity for titanium alloy) must be justified by material characterization data and literature precedent.",
      "rationale": "Ti-6Al-4V material behavior is represented by a bilinear isotropic hardening model calibrated to coupon tensile test data. Contact between screw and UHMWPE block is modeled with Coulomb friction (mu=0.2), consistent with published tribological data for this material pair. The model form is appropriate for the quasi-static compression-bending regime and satisfies Gradation 3 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions used in the model must be traceable to measurements performed on the test articles or published material specifications.",
      "rationale": "Geometric dimensions were extracted from CMM measurements of production screws. Elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (2.3 GPa) were derived from lot-specific tensile coupon tests. UHMWPE block properties were taken from ASTM F648 specification values. All model inputs are traceable to physical measurements, satisfying Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be production-representative and sufficient in number (N≥10) to characterize experimental variability.",
      "rationale": "Eleven production-representative non-cannulated 7.5 mm pedicle screw constructs were tested, exceeding the N=10 minimum. Constructs were assembled from the same production lot used for the reference geometry. Dimensional inspection confirmed all constructs were within drawing tolerances. Test sample requirements at Gradation 3 are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing must be conducted under at least two distinct test conditions (e.g., load levels or environmental conditions) to bound the model response space.",
      "rationale": "Testing was conducted under a single ASTM F1717 standard test configuration (10° caudal angulation, 5 mm/min crosshead speed, ambient temperature). Only one test condition was evaluated, which is below the Gradation 3 requirement for multiple conditions. This shortfall is acknowledged and accepted given that the COU is limited to the F1717 standard configuration and the single-condition data are sufficient to meet the validation acceptance bounds for this specific use case."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs must be shown to be equivalent to experimental conditions through direct measurement or documented traceability.",
      "rationale": "Boundary conditions in the FEA model replicate the F1717 fixture geometry as measured by laboratory coordinate metrology. Applied displacement rate and constraint conditions match the experimental protocol. CMM-measured screw geometry was used directly as model geometry, ensuring equivalency between simulation inputs and physical test article parameters at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation metric E/uval must be less than 1.96 for all QoIs, and percentage difference must be less than 10%.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm displacement) satisfy both acceptance criteria. Maximum E/uval across QoIs is 1.72 (force at 40 mm); maximum percentage difference is 7.1% (force at 40 mm). The validation uncertainty uval incorporates experimental repeatability (two laboratories) and model parameter uncertainty propagated through the ensemble. Output comparison requirements at Gradation 3 are fully satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in the validation activity must be the same as, or directly linked to, the QoIs required by the COU decision.",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — are the primary mechanical performance metrics specified in ASTM F1717 and directly inform the regulatory submission decision regarding structural adequacy of the pedicle screw construct. There is no transformation or inference gap between validation QoIs and decision-relevant QoIs. Relevance requirements at Gradation 3 are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must match the COU in terms of geometry, loading mode, material, and scale.",
      "rationale": "The validation activity uses the identical screw geometry, material, loading mode (compression-bending), fixture configuration, and displacement range as the COU. Testing was performed at full scale with no geometric simplification. The validation scenario is directly representative of the COU without extrapolation, satisfying Gradation 3 relevance requirements."
    }
  ],
