      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used in the simulation must be under version control with documented QA procedures and regression testing.",
      "rationale": "Ansys Mechanical 2022 R2 employed with full version control, documented QA plan, and regression test suite covering relevant element types. FDA in-house solver similarly managed under CDRH software QA framework. Achieved level exceeds required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
