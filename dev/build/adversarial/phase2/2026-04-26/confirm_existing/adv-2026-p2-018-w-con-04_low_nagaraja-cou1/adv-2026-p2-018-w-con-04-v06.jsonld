  "signature": "ed25519:b4e7d2a1f3c6e9b2d5a8f1c4e7b0d3a6f9c2e5b8d1a4f7c0e3b6d9a2f5c8e1b4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
