  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA software (Ansys Mechanical) used under institutional quality management system with documented version control and regression testing.",
      "rationale": "Ansys Mechanical 2022 R1 is a commercially validated solver subject to vendor QA processes. The modeling team maintains a version-controlled simulation environment with documented software qualification records consistent with Gradation 2 requirements for medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks executed against NAFEMS standard test cases; results within 1% of reference solutions.",
      "rationale": "Ansys Mechanical passed NAFEMS linear static and contact benchmark suites. Beam bending and contact patch test results were within 0.3% of analytical reference solutions, satisfying Gradation 2 numerical code verification requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating QoI change <2% between successive refinements; GCI reported.",
      "rationale": "A three-level mesh refinement study was conducted on the pedicle screw–rod–vertebral body assembly. Stiffness QoI changed by 1.1% between the medium and fine meshes. Grid Convergence Index (GCI) was computed at 0.8%, confirming discretization error is well controlled at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria tightened to 1e-6; energy balance monitored across all load steps.",
      "rationale": "All nonlinear load steps converged to a force residual norm below 1e-6. Energy balance checks confirmed no artificial energy generation. Iterative solver tolerance was set one order of magnitude tighter than default, satisfying Gradation 2 numerical solver requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup by a second analyst; documented checklist review of boundary conditions and material assignments.",
      "rationale": "A second qualified analyst independently reviewed the FEA setup including boundary conditions, contact definitions, material assignments, and load application. A formal checklist was completed and archived. No discrepancies were identified, satisfying Gradation 2 use error requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Physics assumptions (linear elasticity for titanium alloy, frictional contact at screw-rod interface) justified by literature and material characterization data; geometric fidelity verified against CAD.",
      "rationale": "Linear elastic constitutive behavior for Ti-6Al-4V is well established for sub-yield loading regimes. Frictional contact at the screw-rod interface was modeled with a coefficient of friction derived from tribological testing reported in the literature. Full 3D geometry was reconstructed from OEM CAD files, ensuring geometric fidelity. Model form assumptions are appropriate for the ASTM F1717 compression-bending scenario at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing of implant-grade Ti-6Al-4V; geometric inputs verified against CMM measurements of test specimens.",
      "rationale": "Elastic modulus (114 GPa) and Poisson's ratio (0.34) for Ti-6Al-4V were obtained from uniaxial tensile coupon tests on material from the same heat lot as the test constructs. Rod and screw geometry was verified against coordinate measuring machine (CMM) data from three representative specimens. Input parameter uncertainty was propagated through the model using interval arithmetic, yielding a combined input uncertainty contribution of ±3.2% on stiffness QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs tested; constructs sourced from production lots with documented traceability; dimensional inspection completed.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. All constructs were drawn from production lots with full material and dimensional traceability. CMM inspection confirmed all constructs within engineering drawing tolerances. Sample size supports statistical comparison at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicated in simulation; environmental conditions (temperature, humidity) documented; loading rate verified against ASTM F1717 specification.",
      "rationale": "Testing was conducted under ambient laboratory conditions (22±2°C, 45±10% RH) consistent with ASTM F1717. Loading rate of 25 mm/min was applied and replicated in the quasi-static FEA. However, only a single test condition (one load level, one construct geometry) was evaluated. The absence of multiple loading conditions limits the achieved level to Gradation 2, representing a noted gap relative to the required Gradation 3. This gap was accepted given the deterministic nature of the ASTM F1717 protocol and the high consistency of experimental results across both laboratories."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters (geometry, material properties, boundary conditions) demonstrably equivalent to experimental test conditions; documented parameter mapping table.",
      "rationale": "A parameter mapping table was prepared documenting the correspondence between each experimental test condition and the corresponding FEA input. Screw geometry, rod diameter, UHMWPE block dimensions, and fixation torque were all matched between experiment and simulation. Boundary conditions replicate the ASTM F1717 fixture geometry as confirmed by fixture CAD comparison. Equivalency is established at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (percent difference and validation uncertainty ratio E/uval) computed for all three QoIs; acceptance bounds pre-specified before unblinding.",
      "rationale": "Three QoIs were compared: construct stiffness, yield force, and force at 40 mm displacement. Percent differences were 4.2%, 6.1%, and 5.8% respectively, all within the pre-specified 10% bound. Validation uncertainty ratios E/uval were 0.87, 1.31, and 1.12, all below the 1.96 threshold. Acceptance criteria were documented in the validation plan prior to unblinding of experimental results, satisfying Gradation 3 output comparison requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly map to regulatory submission endpoints and clinical performance indicators for pedicle screw constructs.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the primary mechanical performance endpoints specified in ASTM F1717 and referenced in FDA guidance for spinal fixation systems. These QoIs directly inform the regulatory decision regarding construct mechanical adequacy. The mapping from QoIs to clinical performance is well established in the spinal implant literature, satisfying Gradation 3 relevance requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 compression-bending, non-cannulated 7.5 mm screw) is identical to the COU scenario; no extrapolation required.",
      "rationale": "The validation activity directly replicates the COU: the same non-cannulated 7.5 mm pedicle screw design, the same ASTM F1717 compression-bending loading protocol, and the same QoIs are used in both validation and the intended regulatory submission context. No extrapolation in geometry, loading mode, or material is required. This direct correspondence satisfies Gradation 3 relevance of validation activities to the COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for non-cannulated pedicle screw compression-bending achieves the required credibility levels for 12 of 13 V&V 40 factors. The single shortfall in Test conditions (achieved Gradation 2 vs. required Gradation 3) is accepted given the deterministic nature of the ASTM F1717 protocol, the high inter-laboratory reproducibility of experimental results, and the conservative acceptance bounds applied to all QoI comparisons. All quantitative acceptance criteria (percent difference <10%, E/uval <1.96) are satisfied for all three QoIs. The overall credibility evidence is sufficient to support a Medium assurance level conclusion for this Class II device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
