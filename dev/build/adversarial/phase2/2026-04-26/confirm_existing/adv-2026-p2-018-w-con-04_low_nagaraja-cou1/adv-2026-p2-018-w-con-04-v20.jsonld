    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios or deficiency is explicitly documented.",
      "rationale": "Testing was conducted at a single axial compressive load offset (5 mm) per ASTM F1717. The clinical loading environment includes variable offsets and combined torsion; therefore this factor achieves level 2 rather than the required level 3. This shortfall is explicitly acknowledged and does not preclude acceptance given the medium model risk level and the margin observed in the output comparison metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
