  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical commercial solver used with documented version control and regression test suite. FDA in-house scripts version-controlled in Git with unit tests covering all post-processing routines.",
      "rationale": "All three modeling teams (FDA, Ansys, DePuy Synthes) operate under documented software quality management systems. Ansys Mechanical R2022 R2 is a commercially validated solver; FDA scripts are maintained under Git with CI regression testing. Achieved level meets required level for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions (cantilever beam, Hertzian contact) solved prior to construct simulation; results within 1% of analytical solution.",
      "rationale": "Canonical benchmark cases including cantilever bending and Hertzian contact were executed by each modeling team. All results fell within 1% of analytical reference values, confirming correct implementation of the governing equations for the contact-dominated compression-bending scenario."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating <2% change in all three QoIs between the production mesh and the next-finer refinement level.",
      "rationale": "A three-level mesh refinement study was performed on the non-cannulated screw geometry. QoI variation between production mesh (element edge length 0.3 mm at screw-rod interface) and the fine mesh was 0.9% for stiffness, 1.4% for yield force, and 1.7% for force at 40 mm, all within the 2% threshold. Richardson extrapolation confirmed negligible higher-order error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear solver residuals converge below 1e-4 for force and displacement norms at every load step; no unconverged increments in production runs.",
      "rationale": "Ansys Mechanical nonlinear static solver with automatic time-stepping was employed. Force and displacement residual norms converged below 1e-5 at all load steps. No unconverged increments were recorded across the full 40 mm displacement ramp for any of the three modeling teams."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by a second analyst; documented pre-simulation checklist covering boundary conditions, material assignments, and contact definitions.",
      "rationale": "Each modeling team completed a pre-simulation checklist and underwent independent peer review of boundary condition assignments, material property mappings, and contact pair definitions. Cross-team comparison of setup parameters revealed no discrepancies beyond intentional modeling choices, confirming use error was controlled."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic constitutive model with isotropic hardening validated against coupon-level tensile data for Ti-6Al-4V; contact modeled with penalty-based frictional formulation.",
      "rationale": "The continuum elastoplastic model with isotropic hardening (Ramberg-Osgood) was validated against Ti-6Al-4V coupon tensile data provided by DePuy Synthes. Frictional contact (mu=0.2) at screw-rod and screw-vertebral body interfaces was confirmed appropriate for the lubricated polyethylene block test setup. Model form adequacy is supported by the close agreement observed in the validation comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports; geometric dimensions from CMM measurements of production hardware; input uncertainty quantified via interval analysis on material and geometric parameters.",
      "rationale": "Ti-6Al-4V elastic modulus, yield strength, and hardening parameters were derived from certified material test reports (lot-specific). Screw and rod geometry was characterized by coordinate measuring machine (CMM) on three production units per batch. Input uncertainty was propagated through interval arithmetic, contributing to the validation uncertainty budget reported in the E/uval metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lots; samples characterized by CMM and hardness testing; traceability to manufacturing records documented.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested, drawn from two independent production lots. Each construct was characterized by CMM dimensional inspection and Vickers hardness testing. Full traceability to manufacturing records and material certifications was maintained, supporting the representativeness of the test sample population."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "ASTM F1717 standard test conditions replicated; load application rate, fixture alignment, and environmental conditions documented and controlled across both laboratories.",
      "rationale": "Testing was conducted under ASTM F1717 standard conditions at two laboratories with documented fixture alignment protocols and environmental controls. However, only a single test condition (standard F1717 loading angle and rate) was evaluated; no variation in loading angle or rate was explored. This limits the achieved level to Gradation 2 despite otherwise rigorous test execution, representing the one factor below the required threshold for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material properties, boundary conditions) derived directly from measurements on the tested hardware; documented traceability between test specimens and corresponding simulation instances.",
      "rationale": "For each of the eleven experimental constructs, the corresponding simulation instance used geometry and material properties derived from measurements on that specific construct. Boundary conditions replicated the F1717 fixture kinematics as measured by laboratory instrumentation. Full traceability between each physical specimen and its simulation counterpart is documented in the validation report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; acceptance threshold E/uval < 1.96 for all three QoIs; validation uncertainty budget explicitly documented.",
      "rationale": "The E/uval metric was computed for all three QoIs incorporating experimental measurement uncertainty (inter-laboratory reproducibility), simulation numerical uncertainty (discretization, solver), and input parameter uncertainty. Results: stiffness E/uval=0.87, yield force E/uval=1.31, force at 40 mm E/uval=1.54. All values fall below the pre-established threshold of 1.96, confirming adequate model accuracy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly linked to clinical failure modes (construct loosening, screw fracture) and regulatory submission requirements.",
      "rationale": "The three selected QoIs are directly specified in ASTM F1717 and are the primary metrics cited in FDA guidance for pedicle screw construct evaluation. Each QoI maps to a clinically relevant failure mode: stiffness to construct loosening under cyclic loading, yield force to permanent deformation risk, and force at 40 mm to catastrophic fracture potential. The selection is therefore fully justified for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (F1717 compression-bending, non-cannulated 7.5 mm screw) is identical to the COU scenario; no extrapolation required.",
      "rationale": "The validation activity is congruent with the COU: the same screw geometry (non-cannulated 7.5 mm), the same loading protocol (ASTM F1717 static compression-bending), and the same QoIs are used in both the validation and the intended regulatory submission. No extrapolation in geometry, loading mode, or material is required, maximizing the relevance of the validation evidence to the COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-acceptance",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed the required level for Medium model risk. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — is acknowledged and accepted on the basis that the F1717 standard prescribes a single canonical loading condition and no clinically relevant alternative condition exists for this device type. All three QoIs satisfy the pre-established E/uval acceptance criterion (threshold 1.96; achieved values 0.87, 1.31, 1.54). The FEA modeling framework is accepted as adequately credible for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
