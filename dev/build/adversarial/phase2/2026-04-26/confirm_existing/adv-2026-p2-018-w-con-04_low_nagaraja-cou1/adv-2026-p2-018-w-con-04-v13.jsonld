  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the non-cannulated pedicle screw FEA ensemble is accepted at Medium assurance level. All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed the required level for a Model Risk Level 3, Medium assurance COU. The single shortfall — Test conditions achieving level 2 against a required level 3 — is acknowledged and partially mitigated by the conservative nature of the ASTM F1717 standard configuration. All three QoIs pass the quantitative validation metric (E/uval < 1.96). The FEA framework is credible for use in the regulatory submission supporting the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
