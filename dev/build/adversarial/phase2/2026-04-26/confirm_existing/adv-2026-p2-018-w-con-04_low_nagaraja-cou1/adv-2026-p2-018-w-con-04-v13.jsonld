  "signature": "ed25519:9b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022R2 used under validated installation with documented version control. FDA in-house code under configuration management per 21 CFR Part 11.",
      "rationale": "All three FEA codes (FDA, Ansys, DePuy Synthes) are under formal software quality management systems with documented installation qualification, version control, and change control records. Achieved level exceeds required level for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions solved; results match to within 1% for linear elastic cases.",
      "rationale": "Each FEA code was verified against NAFEMS benchmark problems relevant to structural mechanics. Beam bending and contact patch test results confirmed numerical implementation correctness. Required level met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in QoIs between successive refinement levels. Richardson extrapolation applied to estimate discretization uncertainty.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw and vertebral body block assembly. QoI changes between medium and fine mesh were 0.9% for stiffness and 1.3% for yield force. Richardson extrapolation yielded discretization uncertainty estimates incorporated into the validation metric E/uval calculation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6 for all load steps; energy balance checked at each increment.",
      "rationale": "Newton-Raphson iteration residuals monitored across all nonlinear load steps. Maximum residual at convergence was 3.2e-7. Energy balance errors were below 0.01% for all analyses. Solver error contribution to total uncertainty is negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup, boundary conditions, and material assignments performed prior to result extraction.",
      "rationale": "Each laboratory's FEA model was reviewed by an independent analyst not involved in model construction. Boundary conditions, contact definitions, and material property assignments were verified against the ASTM F1717 test configuration documentation. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics formulation with nonlinear geometry and frictional contact is appropriate for the load regime. Literature support documented.",
      "rationale": "The FEA ensemble employs large-deformation continuum mechanics with surface-to-surface frictional contact at the screw-vertebral block interface. This model form is well-established for spinal implant compression-bending simulation and is consistent with published FDA guidance and peer-reviewed literature on ASTM F1717 modeling. Model form uncertainty is bounded by the multi-code ensemble spread."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from lot-specific coupon testing; geometric inputs from CMM measurements of tested specimens. Input uncertainty quantified and propagated.",
      "rationale": "Ti-6Al-4V material properties (elastic modulus, yield strength, tangent modulus) were measured from coupons cut from the same material lot as the tested constructs. UHMWPE vertebral body block stiffness was characterized by compressive testing. Geometric dimensions were measured by CMM on three representative specimens. Input uncertainty was propagated through the model using a Monte Carlo approach with 500 samples, contributing to the composite validation uncertainty uval."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lots; dimensional inspection confirms conformance to nominal geometry.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab 1: n=6; Lab 2: n=5). All specimens were from production lots with full traceability. Dimensional inspection confirmed all critical features within drawing tolerances. Sample size provides sufficient statistical power to estimate experimental variability for the validation metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios or at minimum replicate the worst-case COU loading.",
      "rationale": "Testing was conducted at a single load configuration per ASTM F1717 (10° offset, standard block spacing). While this configuration represents the standard regulatory test condition, only a single test condition was evaluated. This factor falls below the required level 3 for the Complete profile. The shortfall is acknowledged; the standard ASTM F1717 condition is considered the most conservative clinically relevant scenario, partially mitigating the gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs are demonstrably equivalent to experimental test conditions; any differences are quantified and incorporated into uncertainty.",
      "rationale": "Boundary conditions in the FEA models were set to match the experimental fixture configuration. Displacement-controlled loading matched the experimental actuator displacement rate (5 mm/min quasi-static). Friction coefficients at the screw-block interface were estimated from tribology literature and sensitivity to this parameter was evaluated through parametric variation, confirming QoI sensitivity is low. Input equivalency is well-established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric E/uval computed for each QoI; E/uval < 1.96 constitutes passing comparison.",
      "rationale": "The validation metric E/uval was computed for all three QoIs (stiffness, yield force, force at 40 mm) following the ASME V&V 40 framework. Experimental uncertainty uexp was estimated from the N=11 sample standard deviation; model uncertainty umodel incorporated discretization, input, and numerical solver contributions. All three E/uval values (0.87, 1.14, 1.51) are below the 1.96 threshold, confirming adequate model agreement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation directly correspond to the QoIs used in the regulatory submission decision.",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — are the same metrics used in the regulatory design verification submission. Stiffness characterizes elastic behavior; yield force identifies onset of permanent deformation; force at 40 mm represents post-yield structural reserve. All three are directly relevant to the COU decision regarding fracture risk and structural adequacy of the non-cannulated design."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the same device design, same test standard, and same loading mode as the COU. Any differences between validation and COU conditions are documented and bounded.",
      "rationale": "The validation activity directly tests the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 compression-bending, which is the identical configuration addressed by the COU. The FEA models and experimental constructs share the same geometry, material, and test standard. The validation-to-COU relevance is therefore high, with no extrapolation required beyond the single test condition limitation noted under Test conditions."
    }
  ],
