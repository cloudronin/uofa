  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen credibility factors have been assessed and achieved levels meet or exceed required levels for Model Risk Level 5. The combined uncertainty budget, incorporating discretization error (GCI 3.2 %), turbulence model-form uncertainty (9.2 %), rheological parameter uncertainty (Monte Carlo, 5000 samples), and batch-to-batch blood variability (±6 %), yields a total expanded uncertainty of 14.8 % on the hemolysis index QoI at 95 % coverage. All predicted NIH values remain below the clinical acceptance threshold of 0.04 mg/dL even at the upper bound of the combined uncertainty interval. The credibility evidence is judged sufficient to support regulatory submission for the Class III VAD indication. The orphan claim (https://uofa.net/synth/claim/vad-cfd-hemolysis-credible) is bound to this UnitOfAssurance as the primary evidentiary claim supporting the hemolysis acceptance argument.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
