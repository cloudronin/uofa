      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-piv-comparison",
      "type": "ValidationResult",
      "name": "Velocity field comparison against PIV measurements",
      "description": "Particle image velocimetry (PIV) measurements were acquired at five meridional planes within the pump volute at three operating conditions. CFD-predicted axial and radial velocity components were compared against PIV data. Area-weighted RMS deviation across all planes and conditions: 4.7 % of the local bulk velocity. Systematic bias in the impeller wake region: +2.1 %. Monte Carlo propagation of boundary condition uncertainties (inlet velocity ±2 %, rotational speed ±0.5 %) was performed yielding 95 % prediction intervals that encompass 91 % of PIV measurement points.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/uq-piv-montecarlo",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo boundary condition propagation",
        "sampleCount": 2000,
        "coverageProbability": 0.95,
        "expandedUncertainty": 0.047
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-invitro",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction vs. in-vitro measurements (5 operating points)",
      "description": "CFD-predicted normalized index of hemolysis (NIH) was compared against in-vitro plasma-free haemoglobin measurements at five flow-speed combinations spanning the VAD operating envelope. Predicted NIH values ranged from 0.0038 to 0.0071 mg/dL; measured values ranged from 0.0041 to 0.0079 mg/dL. Mean absolute percentage error: 7.3 %. All predictions fall below the clinical acceptance threshold of 0.04 mg/dL. A Monte Carlo analysis propagating rheological model parameter uncertainties (power-law exponent ±8 %, consistency index ±12 %) was conducted.",
      "hasUncertaintyQuantification": {
