  "name": "Morrison COU2 — VAD hemolysis credibility assessment (COMPOUND-01 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Monte Carlo uncertainty quantification is performed for the primary hemolysis QoI; all 13 credibility factors are assessed and reported at or above required levels. Decision: Accepted. This package is a synthetic adversarial sample embedding a COMPOUND-01 trigger: the bound claim carries no prov:wasDerivedFrom provenance (W-EP-01, Critical) and one validation result omits hasUncertaintyQuantification (W-AL-01, High).",
  "bindsRequirement": "https://uofa.net/morrison/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-acceptability",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-centrifugal",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-piv-measurements",
    "https://uofa.net/morrison/data/hemolysis-in-vitro-5op-points",
    "https://uofa.net/morrison/data/monte-carlo-uncertainty-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 5 operating points",
      "description": "Particle image velocimetry measurements acquired at 5 flow-speed combinations were compared against CFD-predicted velocity fields. Normalized RMS error across all planes is 6.8%, within the 10% acceptance criterion. Grid convergence index reported at 1.2% for the finest mesh. Uncertainty quantification via Monte Carlo propagation of inlet boundary condition variability yields a 95th-percentile hemolysis index prediction interval of [0.003, 0.011] NIH units, below the 0.020 NIH clinical threshold.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/monte-carlo-hemolysis-piv",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo",
        "sampleSize": 2000,
        "confidenceLevel": 0.95,
        "description": "Monte Carlo propagation of inlet flow rate and rotational speed variability through the CFD hemolysis model. Latin hypercube sampling with 2000 realizations. Output: 95th-percentile prediction interval on normalized index of hemolysis."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-invitro-comparison",
      "type": "ValidationResult",
      "name": "In-vitro hemolysis index comparison across 5 operating conditions",
      "description": "Normalized index of hemolysis (NIH) values predicted by the power-law hemolysis model were compared against in-vitro measurements from three independent laboratories. Mean absolute percentage error across all 5 operating points is 14.3%, within the pre-specified 20% acceptance criterion. Model predictions are conservative (over-predict hemolysis) at 4 of 5 operating points, supporting regulatory acceptance. Sensitivity analysis identifies shear stress exponent as the dominant uncertainty driver."
    }
  ],
