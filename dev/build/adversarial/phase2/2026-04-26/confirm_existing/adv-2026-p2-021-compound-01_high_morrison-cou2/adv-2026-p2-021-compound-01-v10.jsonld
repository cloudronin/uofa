  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, unit test suite with >80% coverage, and release validation report.",
      "rationale": "ANSYS Fluent 2023R1 is deployed under an ISO 9001-certified QMS. Version control via Git with tagged release. Unit test suite achieves 91% line coverage. Release validation report reviewed and accepted by the assessment team. Achieved level equals required level; factor is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufacturer verification suite must include benchmark problems spanning laminar and turbulent rotating-frame flows with documented order-of-accuracy confirmation.",
      "rationale": "Fluent verification suite includes Taylor-Couette, rotating lid-driven cavity, and Stokes flow benchmarks. Observed order of accuracy is 1.97 for velocity (theoretical: 2.0). All benchmark residuals converge to machine precision. Code verification is satisfied at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study using at least three systematically refined meshes; GCI < 2% on hemolysis index QoI; Richardson extrapolation applied.",
      "rationale": "Three meshes (4.2M, 11.7M, 31.4M cells) generated with systematic refinement ratio 1.63. GCI on NIH = 1.2% (fine-to-medium) and 2.8% (medium-to-coarse). Richardson extrapolation applied; asymptotic convergence confirmed (GCI ratio = 1.04). Discretization error factor satisfied at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental operating conditions must match COU operating envelope within ±5% on flow rate and rotational speed; fluid temperature controlled to ±1°C.",
      "rationale": "In-vitro experiments conducted at 5 operating points spanning the VAD clinical envelope (2.5–5.0 L/min, 2400–3600 RPM). Flow rate deviation ≤2.1%, speed deviation ≤1.4% relative to CFD boundary conditions. Temperature maintained at 37±0.5°C. Test conditions factor satisfied at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (MAPE or NRMSE) must be defined a priori and reported against a pre-specified acceptance threshold; comparison must cover all 5 operating points.",
      "rationale": "MAPE on NIH was pre-specified at ≤20%. Achieved MAPE = 14.3% across all 5 operating points from three independent laboratory measurements. Bland-Altman analysis shows no systematic bias. Output comparison factor satisfied at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation (NIH, velocity field) must be directly traceable to the clinical endpoint (hemolysis below 0.020 NIH) and to the COU decision.",
      "rationale": "The normalized index of hemolysis is the direct regulatory QoI. Velocity field comparison supports mechanistic credibility of the hemolysis model inputs (shear stress distribution). Both QoIs are explicitly linked to the COU decision criterion. Relevance of QoI factor satisfied at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid (bovine blood or validated analog), and operating envelope as the COU; any deviations must be documented with impact assessment.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry (identical to COU geometry). Bovine blood at physiological hematocrit (40±2%) used in all experiments. Operating envelope spans full clinical range. One minor deviation: experiments conducted at sea-level atmospheric pressure vs. clinical altitude variation; impact assessed as negligible (<0.5% NIH change). Relevance factor satisfied at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance ≤1×10⁻⁵ for all equations; mass balance error <0.1%; solution monitored via QoI convergence history.",
      "rationale": "All simulations converged to continuity residual 3×10⁻⁶, momentum residuals <8×10⁻⁶, and k-ω residuals <5×10⁻⁶. Mass imbalance <0.02%. NIH QoI monitored over last 500 iterations; variation <0.3%. Numerical solver error factor satisfied at required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second qualified analyst; documented checklist covering boundary conditions, material properties, and solver settings.",
      "rationale": "Simulation setup reviewed by a second CFD analyst with 8 years of cardiovascular device experience. Checklist of 47 items completed and signed. Boundary condition specification, turbulence model selection (SST k-ω), and hemolysis model coefficients verified against published literature. Use error factor satisfied at required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified for rotating internal flow; hemolysis power-law model coefficients must be sourced from peer-reviewed calibration studies; model form uncertainty must be quantified.",
      "rationale": "SST k-ω selected based on published benchmark studies for rotating blood pump flows (Hariharan et al., 2011; Fraser et al., 2012). Hemolysis power-law coefficients (C=3.62×10⁻⁵, α=2.416, β=0.785) from Giersiepen et al. calibration. Model form uncertainty estimated via comparison of three turbulence models (SST k-ω, realizable k-ε, RSM); NIH spread = ±8%, within acceptance band. Model form factor satisfied at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs must have documented sources with uncertainty bounds; sensitivity analysis must identify inputs contributing >5% to output variance.",
      "rationale": "Blood viscosity (Carreau-Yasuda model), density, and hemolysis coefficients sourced from peer-reviewed literature with ±1σ uncertainty bounds. Inlet flow rate and rotational speed uncertainties from pump manufacturer specifications. Sobol sensitivity analysis (2000 samples) identifies shear stress exponent α as dominant input (62% of NIH variance), followed by inlet flow rate (21%). All inputs documented in the simulation data package. Model inputs factor satisfied at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent biological replicates per operating point; blood source and hematocrit documented; inter-laboratory reproducibility assessed.",
      "rationale": "Three independent bovine blood draws used per operating point (n=15 total experiments across 5 operating points). Hematocrit 40±2% confirmed by centrifugation. Experiments replicated across two independent laboratories; inter-lab coefficient of variation on NIH = 7.3%, within the pre-specified 15% threshold. Test samples factor satisfied at required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary conditions must be derived from measured experimental inlet profiles; equivalency between experimental and simulation inputs must be demonstrated quantitatively.",
      "rationale": "Inlet velocity profiles for CFD extracted from PIV measurements at the pump inlet plane. Rotational speed boundary condition set from encoder measurements (±0.5 RPM accuracy). Quantitative equivalency: flow rate agreement <2.1%, rotational speed agreement <0.4%, inlet turbulence intensity within ±15% relative. Equivalency of input parameters factor satisfied at required level 4."
    }
