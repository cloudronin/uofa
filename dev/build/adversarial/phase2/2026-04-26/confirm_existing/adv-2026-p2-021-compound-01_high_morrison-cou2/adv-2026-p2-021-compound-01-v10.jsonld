  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at or above required levels for Model Risk Level 5. PIV velocity comparison achieves NRMSE 6.8% against a 10% threshold. In-vitro hemolysis comparison achieves MAPE 14.3% against a 20% threshold. Monte Carlo uncertainty quantification confirms 95th-percentile NIH prediction of 0.011 NIH, below the 0.020 NIH clinical threshold. Conservative bias at 4 of 5 operating points provides additional regulatory confidence. Grid convergence index 1.2% on the fine mesh is within the 2% requirement. Independent review of simulation setup completed with no findings. The credibility evidence package is assessed as sufficient to support regulatory submission for the Class III VAD device under the stated COU.",
