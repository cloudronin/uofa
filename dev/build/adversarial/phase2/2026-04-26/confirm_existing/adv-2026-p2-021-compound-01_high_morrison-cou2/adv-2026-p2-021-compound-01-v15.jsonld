  "name": "Morrison COU2 — VAD hemolysis credibility assessment (COMPOUND-01 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. All 13 credibility factors are assessed; achieved levels meet or exceed required levels at each factor, supporting an Accepted decision. Monte Carlo uncertainty quantification is performed on the primary validation result. A secondary exploratory validation result (mesh-independence study) was conducted under controlled laboratory conditions and is included for completeness; that result predates the UQ protocol and does not carry a hasUncertaintyQuantification record. The binding claim captures the team's consolidated hemolysis-acceptability assertion; provenance tracing to the underlying experimental dataset is recorded at the UnitOfAssurance level via wasDerivedFrom rather than duplicated on the claim node itself.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-hemolysis-acceptability",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-mrl5",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-dataset-2019",
    "https://uofa.net/synth/data/morrison-mrl5-monte-carlo-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-primary-hemolysis-uq",
      "type": "ValidationResult",
      "name": "Primary hemolysis validation — Monte Carlo UQ sweep across 5 operating points",
      "description": "CFD-predicted normalized index of hemolysis (nIH) compared against in-vitro photometric measurements at 5 flow-speed combinations (3 L/min at 2400 RPM, 4.5 L/min at 2400 RPM, 3 L/min at 3600 RPM, 4.5 L/min at 3600 RPM, 6 L/min at 3600 RPM). Monte Carlo sampling (N=500) applied to inlet velocity profile uncertainty, fluid viscosity, and power-law hemolysis model coefficients. 95th-percentile prediction interval bounds reported.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/morrison-cou2-monte-carlo",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo",
        "sampleCount": 500,
        "coverageInterval": "95th percentile"
      },
      "comparisonMetric": "Normalized index of hemolysis (nIH)",
      "passFail": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh-independence study — Richardson extrapolation on three grid levels",
      "description": "Grid convergence study performed on coarse (2.1 M cells), medium (6.8 M cells), and fine (18.4 M cells) meshes at the 4.5 L/min, 3600 RPM operating point. Richardson extrapolation yields a grid convergence index (GCI) of 1.3% on nIH, confirming discretization error is below the 2% threshold required at MRL 5. Study predates the formal Monte Carlo UQ protocol adopted for the primary validation sweep and is included as supporting evidence for the discretization-error credibility factor only.",
      "comparisonMetric": "Grid Convergence Index (GCI) on nIH",
      "passFail": "Pass"
    }
  ],
