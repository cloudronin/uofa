  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and maintain a version-controlled regression test suite with documented pass/fail records for hemolysis-relevant benchmark cases.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under an ISO 9001-certified quality management system. Regression test suite covers 47 internal flow benchmarks; all pass records archived in the project QMS repository. Achieved level equals required level for MRL 5 Class III context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate second-order spatial convergence on at least two canonical internal-flow manufactured solutions relevant to rotating machinery.",
      "rationale": "Method of manufactured solutions applied to a rotating annular Couette flow and a swirling pipe flow. Observed order of accuracy 1.97 and 2.01 respectively, confirming second-order convergence. Code verification evidence archived in project technical report TR-CV-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index on the primary quantity of interest must be below 2% at the COU operating points.",
      "rationale": "Richardson extrapolation across three mesh levels yields GCI of 1.3% on nIH at the 4.5 L/min, 3600 RPM point (worst case). All five COU operating points evaluated; maximum GCI 1.7%. Requirement satisfied. Supporting evidence: mesh-independence validation result (morrison-cou2-mesh-independence)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions must replicate COU fluid properties (hematocrit 35±2%, temperature 37±0.5°C) and geometric fidelity (FDA generic pump geometry, tolerance ±0.05 mm).",
      "rationale": "In-vitro experiments conducted with porcine blood at hematocrit 35.1±1.8%, temperature 37.0±0.4°C. Pump impeller and volute fabricated to ±0.03 mm tolerance per CMM report. Test conditions judged highly representative of COU. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted nIH must fall within ±15% of measured nIH across all five operating points, with systematic bias below 5%.",
      "rationale": "Point-by-point comparison shows maximum deviation of 11.3% and mean signed bias of 2.8%. All five operating points satisfy the ±15% envelope. Comparison performed against photometric hemolysis measurements with expanded uncertainty U95=4.2% (k=2). Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (nIH) must be directly mappable to the clinical decision threshold without auxiliary model transformations.",
      "rationale": "nIH is the direct regulatory QoI per FDA guidance. No auxiliary transformation required; predicted nIH compared directly against the absolute clinical threshold of 0.01 g/100 L. Relevance judged high. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the full COU operating envelope (flow rates 3–6 L/min, speeds 2400–3600 RPM) using the same pump geometry as the COU device.",
      "rationale": "Five validation points bracket the COU operating envelope. Same FDA generic pump geometry used in both simulation and experiment. No geometric extrapolation required. Validation activities judged highly relevant to COU. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must achieve residual reduction of at least four orders of magnitude for all transport equations; mass imbalance below 0.01%.",
      "rationale": "All simulations run to six-order residual reduction for continuity, momentum, and turbulence equations. Mass imbalance across pump control volume: maximum 0.003%. Iterative solver error judged negligible relative to other error sources. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition inputs must be traceable to calibrated measurement records.",
      "rationale": "Independent peer review of simulation setup conducted by senior CFD engineer (not involved in model development). All boundary conditions traced to calibrated flowmeter (NIST-traceable, ±0.5%) and tachometer (±0.1%) records. Use error controls judged adequate. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by sensitivity analysis; hemolysis power-law model coefficients must be sourced from peer-reviewed literature with demonstrated applicability to porcine blood at 37°C.",
      "rationale": "SST k-ω turbulence model selected after sensitivity study comparing k-ε realizable and SST k-ω; SST k-ω shows 3.1% lower nIH bias. Hemolysis power-law coefficients (C=1.228×10⁻⁷, α=0.7622, β=2.416) from Giersiepen et al. validated for porcine blood at 37°C. Model form uncertainty incorporated in Monte Carlo UQ sweep. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions for all uncertain model inputs must be documented and propagated through the hemolysis model via Monte Carlo sampling (N≥200).",
      "rationale": "Uncertain inputs identified: inlet velocity profile (uniform vs. developed, ±5%), dynamic viscosity (3.2±0.3 mPa·s), and hemolysis model coefficients (±10% per literature scatter). All three propagated via Monte Carlo N=500. Distribution parameters documented in UQ report UQ-RPT-002. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum three independent blood samples per operating point; sample-to-sample variability documented and reported as expanded uncertainty.",
      "rationale": "Four independent porcine blood draws used per operating point (n=4 replicates). Sample-to-sample variability expressed as standard deviation; pooled across operating points, CV=3.1%. Expanded uncertainty U95 computed per GUM. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (fluid properties, rotational speed, flow rates) must match experimental conditions within stated measurement uncertainty bands.",
      "rationale": "Rotational speed set in simulation to match tachometer readings within 0.1%. Flow rates matched to calibrated Coriolis flowmeter readings within 0.5%. Fluid viscosity matched to rheometer measurements at 37°C within 2%. All parameters within equivalency tolerance bands. Achieved level 3 meets required level 3."
    }
