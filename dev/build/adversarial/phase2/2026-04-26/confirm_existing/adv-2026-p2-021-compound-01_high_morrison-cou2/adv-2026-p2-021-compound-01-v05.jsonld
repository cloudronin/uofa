  "name": "Morrison COU2 — VAD hemolysis credibility assessment (COMPOUND-01 test)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed on most but not all validation results. Full 13-factor assessment is included. Decision outcome is Accepted based on the overall credibility argument; however, the package embeds a W-EP-01 condition (the bound Claim carries no prov:wasDerivedFrom provenance link) and a W-AL-01 condition (one ValidationResult omits hasUncertaintyQuantification), together triggering COMPOUND-01.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-absolute-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-measurements",
    "https://uofa.net/synth/data/fda-pump-hemolysis-in-vitro",
    "https://uofa.net/synth/data/monte-carlo-uncertainty-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 3500 RPM, 5 L/min",
      "description": "Particle image velocimetry measurements of the FDA pump internal flow field compared to CFD predictions at the primary operating point. Normalised RMS velocity error is 8.3%, within the required 10% acceptance band. Mesh sensitivity study (3 levels, GCI < 2%) and iterative convergence to residual 1e-6 confirmed prior to comparison.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-velocity-field-piv-uq",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo — 500 samples over inlet velocity, viscosity, and rotational speed tolerances",
        "coverageInterval": "95%",
        "description": "Monte Carlo propagation of inlet boundary condition uncertainty (±3%), blood viscosity uncertainty (±8%), and rotational speed tolerance (±15 RPM) through the CFD solver. Resulting 95% coverage interval on normalised RMS velocity error is [5.1%, 11.4%]; the point estimate of 8.3% lies within the interval centre. Sensitivity indices confirm rotational speed as the dominant contributor (Sobol first-order index 0.61)."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-five-points",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index validation across 5 flow-speed operating points",
      "description": "Predicted normalised index of hemolysis (NIH) values from the power-law hemolysis model are compared against in-vitro measurements at 5 operating points spanning 3000–5000 RPM and 3–7 L/min. Mean absolute error is 12.4% across all points; the maximum single-point error is 18.7% at the 3000 RPM / 7 L/min corner condition. All predicted NIH values remain below the absolute clinical threshold of 0.056 g/100 L. Validation is conducted on a geometrically identical pump replica with blood analogue fluid; fluid rheology is matched to within published tolerance bands.",
      "description2": "NOTE: Uncertainty quantification was considered out of scope for this specific result set because the in-vitro measurement uncertainty characterisation report was not available at the time of submission. The credibility argument relies on the point-estimate comparison and the conservative acceptance margin."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-wall-shear-stress-sensitivity",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution sensitivity validation",
      "description": "Wall shear stress (WSS) distributions predicted by the CFD model are compared against micro-PIV near-wall measurements at the impeller blade pressure surface. Area-averaged WSS agreement is within 14% of measured values. Spatial correlation coefficient R=0.91 across 120 measurement points. This result supports the hemolysis sub-model's dependence on local shear exposure history.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-wss-uq",
        "type": "UncertaintyQuantification",
        "method": "Latin Hypercube Sampling — 200 samples over near-wall mesh refinement parameters and fluid viscosity",
        "coverageInterval": "90%",
        "description": "LHS-based propagation of near-wall y+ variability (0.8–2.0) and blood analogue viscosity (±6%) through the turbulence-resolving near-wall model. The 90% coverage interval on area-averaged WSS error is [9.2%, 19.1%]. The point estimate of 14% lies within this band. Dominant uncertainty source is y+ selection (Sobol index 0.54)."
      }
    }
  ],
