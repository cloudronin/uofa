  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering all active physics modules; configuration management documented to ASME V&V 10.1 guidance.",
      "rationale": "ANSYS Fluent 2023R1 is used under a validated installation qualification (IQ) and operational qualification (OQ) protocol. The solver version is locked in the project configuration management plan. A 47-case regression suite covering rotating-frame, turbulence, and scalar transport modules is executed at project initiation and after any patch application. All 47 cases pass within prescribed tolerances. IQ/OQ records are archived and traceable to the simulation package. Achieved level 4 meets required level 4 for MRL 5 Class III context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using Method of Manufactured Solutions (MMS) for all active governing equations; observed order within 10% of formal order.",
      "rationale": "MMS verification is performed for the incompressible RANS equations with the SST k-omega turbulence closure and the power-law hemolysis scalar transport equation. Observed spatial order of accuracy is 1.94 (formal order 2.0) for momentum, 1.97 for turbulent kinetic energy, and 1.88 for the hemolysis scalar — all within the 10% tolerance band. Temporal discretisation is verified separately for the transient impeller passage simulation; observed order 1.96 vs. formal 2.0. Results are documented in the Code Verification Report CVR-2025-07."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) below 2% for all quantities of interest on the production mesh; three systematically refined mesh levels with refinement ratio ≥ 1.3.",
      "rationale": "Three mesh levels (6.2M, 14.1M, 31.8M cells; refinement ratio ~1.33) are used for the GCI study. GCI for velocity magnitude at the pump outlet is 1.7%, meeting the 2% criterion. GCI for the hemolysis index NIH is 3.1%, exceeding the criterion. The NIH GCI exceedance is attributed to the steep shear gradients near the impeller tip clearance gap where the power-law model is most sensitive. A targeted local refinement study reduces NIH GCI to 2.4% but does not reach 2% within available computational budget. Achieved level 3 reflects this gap; required level 4 is not met for this factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions (fluid rheology, rotational speed, flow rate, temperature) match COU operating envelope within documented tolerance bands; deviations formally assessed.",
      "rationale": "In-vitro experiments use a glycerol-water blood analogue (dynamic viscosity 3.5 ± 0.2 mPa·s at 37°C, matching human blood within published range). Pump speed is controlled to ±15 RPM of target; flow rate is controlled to ±0.1 L/min. Temperature is maintained at 37 ± 0.5°C throughout each test run. All five operating points in the COU envelope are replicated in the in-vitro rig. The one deviation — use of a rigid acrylic housing rather than the clinical titanium housing — is assessed as having negligible effect on internal flow field based on a sensitivity simulation showing <1% change in NIH."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or NRMSE) computed for all QoIs; metric value within pre-specified acceptance band; statistical significance assessed.",
      "rationale": "Normalised root-mean-square error (NRMSE) is computed for velocity field (8.3%, within 10% band) and wall shear stress (14.0%, within 15% band). For the hemolysis index, mean absolute percentage error across 5 operating points is 12.4%; the pre-specified band was 10%, so this QoI does not meet the acceptance criterion. The maximum single-point error of 18.7% at the 3000 RPM / 7 L/min corner is flagged. Statistical significance of the velocity comparison is assessed via Wilcoxon signed-rank test (p < 0.01, n=120 spatial locations). No equivalent statistical test is applied to NIH due to the small sample of 5 operating points. Achieved level 3 reflects the NIH comparison exceedance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validated QoIs directly map to the decision-critical quantity (absolute NIH); no surrogate QoIs used without documented bridging argument.",
      "rationale": "The primary COU decision quantity is the absolute normalised index of hemolysis (NIH) in units of g/100 L. The validation QoI is the identical scalar quantity computed from the same power-law hemolysis model and compared against the same measurement protocol (modified index of hemolysis, converted to NIH via the ASTM F1841 formula). No surrogate QoI is used. The velocity field and WSS comparisons serve as supporting QoIs to verify the flow physics underlying the hemolysis prediction; their relevance chain to NIH is documented in the Validation Plan VP-2025-03, Section 4.2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the COU device geometry, fluid, and operating conditions; any deviations bridged with formal similarity argument.",
      "rationale": "Validation experiments use the FDA generic pump geometry, which is the same geometry as the COU device. Blood analogue fluid is used rather than human blood; a formal bridging argument based on matched Reynolds number and Stokes number is documented (Bridging Report BR-2025-02). The operating envelope of 3000–5000 RPM and 3–7 L/min covers all 5 COU operating points. However, the clinical VAD implant configuration introduces a cannula inlet geometry not present in the in-vitro rig; a sensitivity simulation shows up to 6% change in NIH at the 5000 RPM / 3 L/min point, which is not fully bounded. This unresolved geometric deviation limits the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance ≤ 1e-5 for all equations; mass imbalance < 0.01% of inlet mass flow.",
      "rationale": "All steady-state RANS simulations are run to normalised residual convergence of 1e-6 for continuity and momentum, 1e-5 for turbulence scalars, and 1e-6 for the hemolysis transport equation. Mass imbalance at convergence is 0.003% of inlet mass flow across all operating points. For the transient impeller passage simulation, phase-averaged quantities are monitored over 10 impeller revolutions; cycle-to-cycle variation in NIH is less than 0.4%. Solver floating-point arithmetic is double precision throughout. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second qualified analyst; documented checklist covering boundary conditions, material properties, turbulence model selection, and post-processing scripts.",
      "rationale": "A 42-item simulation setup checklist (SSC-2025-01) is completed by the lead analyst and independently reviewed by a second CFD engineer with 8 years of rotating machinery experience. Discrepancies identified during review (two boundary condition label errors and one incorrect reference frame assignment) are corrected prior to production runs. The corrected setup is re-reviewed and signed off. Post-processing scripts for NIH integration are version-controlled and unit-tested against analytical solutions for simple shear flow. The independent review record is archived in the project document management system."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty for the power-law hemolysis constitutive relation formally quantified; alternative model forms evaluated; dominant uncertainty source identified.",
      "rationale": "The power-law hemolysis model (Giersiepen et al. 1990, as modified by Heuser and Opitz 1980) is selected based on literature prevalence for centrifugal pump applications. Three alternative hemolysis model forms are simulated (Bludszuweit 1995, Taskin et al. 2012, and a mechanistic membrane model); predicted NIH values span a factor of 2.3 across model forms at the 5000 RPM / 3 L/min operating point, indicating substantial model form uncertainty. A formal Bayesian model selection analysis is not performed due to the limited in-vitro dataset (5 operating points insufficient for posterior discrimination). Model form uncertainty is therefore characterised qualitatively rather than quantitatively. This represents a significant credibility gap; achieved level 2 is well below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterised with probability distributions; Monte Carlo propagation performed; sensitivity indices computed for all inputs contributing more than 5% of output variance.",
      "rationale": "Twelve model input parameters are identified in the uncertainty register (UR-2025-01): inlet velocity profile, blood viscosity, rotational speed, hemolysis model coefficients (α, β), red blood cell volume fraction, temperature, surface roughness, and four turbulence model constants. Probability distributions are assigned to all 12 parameters based on literature data or measurement uncertainty reports. Monte Carlo propagation (500 samples, Latin Hypercube Sampling) is performed for the velocity field and WSS QoIs. For the NIH QoI, Monte Carlo propagation is performed only over the 4 hemolysis model coefficients; the remaining 8 parameters are held at nominal values due to computational cost constraints. Sobol sensitivity indices are computed for the 4 propagated parameters. The incomplete propagation for NIH limits achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum 3 independent experimental replicates per operating point; measurement uncertainty characterised and reported; outlier assessment performed.",
      "rationale": "Each of the 5 operating points is tested in 4 independent experimental runs on separate days using freshly prepared blood analogue fluid. Mean and standard deviation of NIH are computed across replicates. Measurement uncertainty is characterised per ISO/IEC Guide 98-3 (GUM); expanded uncertainty (k=2) on NIH measurement is ±9.3% of the mean value. Outlier assessment using Grubbs test at α=0.05 identifies no outliers across the 20 replicate measurements. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of all simulation input parameters against in-vitro experimental conditions; deviations formally bounded; equivalency metric computed.",
      "rationale": "Fluid rheology, rotational speed, flow rate, and temperature are matched quantitatively between simulation and experiment (deviations within tolerance bands as documented under Test Conditions factor). However, the inlet velocity profile applied as a CFD boundary condition is a fully-developed pipe flow profile, while the in-vitro rig uses a short-entry inlet with a developing boundary layer. Laser Doppler Anemometry measurements of the rig inlet profile are available but were not used to specify the CFD boundary condition; instead the analytical profile was used for simplicity. A sensitivity study shows up to 4.8% difference in predicted NIH depending on inlet profile specification. This unresolved input equivalency gap limits achieved level to 2, below required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-dr01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility argument for the CFD hemolysis prediction model is accepted on the basis that: (1) the primary decision quantity NIH remains below the absolute clinical threshold of 0.056 g/100 L at all 5 operating points with a minimum margin of 31%; (2) the velocity field and WSS validation results meet their acceptance criteria, supporting confidence in the underlying flow physics; (3) Monte Carlo uncertainty quantification on the hemolysis model coefficients confirms that the NIH predictions remain sub-threshold across the 95% coverage interval; (4) software quality assurance, code verification, and solver error factors all meet required levels. The identified credibility gaps — discretization error GCI exceedance for NIH (3.1% vs. 2% criterion), model form uncertainty spanning a factor of 2.3 across hemolysis constitutive models, incomplete Monte Carlo propagation for NIH over all input parameters, and inlet profile equivalency deviation — are acknowledged. These gaps are judged acceptable given the conservative NIH margin, the Class III regulatory context, and the commitment to address model form uncertainty in a subsequent validation study prior to PMA submission. The decision is conditional on the model being used only within the validated operating envelope of 3000–5000 RPM and 3–7 L/min.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
