  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at gradations meeting or exceeding required levels for MRL 5, Class III device. Monte Carlo UQ confirms NIH predictions remain below clinical hemolysis threshold at 95th percentile across all five VAD operating points. Validation activities use the FDA generic pump geometry with fully documented experimental conditions. Independent reviewer sign-off obtained. The credibility evidence package is judged sufficient to support the regulatory submission claim that CFD-predicted absolute hemolysis levels are credible for the stated COU.",
