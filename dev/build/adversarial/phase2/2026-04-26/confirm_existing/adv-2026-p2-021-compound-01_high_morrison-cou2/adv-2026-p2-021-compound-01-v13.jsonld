  "signature": "ed25519:b1c4e7a2d5f8b3c6e9a1d4f7b0c3e6a9d2f5b8c1e4a7d0f3b6c9e2a5d8f1b4c7",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-sqa",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver must have documented V&V test suite, version-controlled release notes, and traceable defect-management log covering hemolysis-relevant flow physics at MRL 5.",
      "rationale": "ANSYS Fluent 2023 R1 used. Vendor V&V test suite covers rotating machinery and non-Newtonian flow regimes. Version control and defect logs reviewed; no open defects affecting hemolysis or turbulence computation pathways. SQA gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-code-verification",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent analytic benchmark must confirm spatial and temporal order-of-accuracy for Navier-Stokes and species transport solvers used in hemolysis computation.",
      "rationale": "Vendor-published MMS results for incompressible Navier-Stokes confirm second-order spatial accuracy. Internal benchmark of the power-law hemolysis scalar transport equation against analytic Couette solution shows L2 error convergence rate 1.98, meeting gradation 3 threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-discretization-error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be computed for the primary hemolysis QoI on at least three mesh levels. GCI_fine must be below 5 % for the production mesh to be accepted.",
      "rationale": "Three-level mesh refinement study documented in ValidationResult vr-mesh-sensitivity. GCI_fine = 2.7 % for NIH at nominal operating point, satisfying the 5 % threshold. Asymptotic convergence confirmed (GCI ratio 0.98). Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-test-conditions",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, rotational speed, flow rate) must be documented with measurement uncertainty and must bracket the intended VAD operating envelope.",
      "rationale": "FDA interlaboratory dataset provides fully documented test conditions including hematocrit 35±2 %, temperature 37±0.5 °C, and flow rates 3–7 L/min. Operating envelope for the target VAD (2000–6000 RPM, 3–7 L/min) is fully bracketed. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-output-comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric or equivalent) must be applied to NIH predictions versus experimental measurements. Metric must account for both experimental and simulation uncertainty.",
      "rationale": "ASME V&V 20 area validation metric applied to NIH predictions at five operating points. All points fall within the validation acceptance band (|E|/U_val < 1.0). Mean absolute error 8.3 %. Experimental uncertainty from interlaboratory repeatability study included. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-qoi-relevance",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH) must be directly mappable to the clinical hemolysis acceptance criterion (plasma free hemoglobin threshold) with a documented conversion factor and associated uncertainty.",
      "rationale": "NIH directly corresponds to the plasma free hemoglobin (pfHb) rise rate via the Heuser-Opitz conversion. Conversion factor uncertainty (±6 %) propagated through UQ analysis. Clinical threshold expressed in NIH units for direct comparison. QoI relevance gradation 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-validation-relevance",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry (FDA generic centrifugal pump), same blood analogue fluid properties, and overlapping operating conditions with the target VAD COU. Geometry and boundary condition similarity must be formally documented.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry — identical to the COU device geometry. Glycerol-water blood analogue (viscosity matched to 37 °C whole blood at 35 % hematocrit) used in experiments. Five of the 15 validation operating points are within the target VAD envelope. Formal similarity matrix completed. Gradation 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-solver-error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all transport equations. Residual history and mass imbalance must be reported for each production simulation.",
      "rationale": "All production simulations converged to continuity residual 8e-6 and momentum residuals below 5e-6. Mass imbalance below 0.01 % in all cases. Hemolysis scalar transport residual below 1e-6. Convergence histories archived in simulation log. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-use-error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be independently reviewed by a qualified analyst not involved in model development. Boundary condition specification, material property assignment, and solver settings must be verified against the COU specification document.",
      "rationale": "Independent review of simulation setup conducted by senior CFD analyst (not a model developer). Boundary conditions, rotating domain interfaces, and hemolysis model coefficients verified against COU specification rev. 3. Two minor discrepancies identified and corrected prior to production runs. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-model-form",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection must be justified with reference to literature benchmarks for rotating blood-contacting devices. Model form uncertainty must be estimated and included in the total uncertainty budget.",
      "rationale": "SST k-ω turbulence model selected based on published benchmarks for centrifugal blood pump flows (Hariharan et al. 2011, Good et al. 2016). Power-law hemolysis model (Giersiepen-Wurzinger) preferred over linear damage accumulation for pulsatile conditions. Model form uncertainty estimated at ±15 % NIH (dominant uncertainty source) via comparison of three hemolysis model variants. Included in Monte Carlo UQ. Gradation 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-model-inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (viscosity, density, hemolysis coefficients, inlet velocity profile) must be characterised with probability distributions and propagated through the UQ analysis.",
      "rationale": "Six uncertain input parameters characterised: blood viscosity (log-normal, CV=8 %), density (normal, CV=1 %), hemolysis model coefficients α and β (uniform ±12 %), inlet velocity profile shape parameter (uniform ±5 %), and rotational speed (normal, CV=1 %). All propagated through Monte Carlo analysis documented in ValidationResult vr-hemolysis-bench. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-test-samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must be obtained from at least three independent test runs per operating point using fresh blood samples with documented donor demographics and storage conditions.",
      "rationale": "FDA interlaboratory dataset provides measurements from six independent laboratories, each performing three test runs per operating point using fresh bovine blood (storage <24 h post-collection). Donor demographics and hematocrit distributions documented. Inter-laboratory variability quantified (CV 12–18 % across operating points). Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/synth/factor/cf-input-equivalency",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary conditions (inlet velocity profile, outlet pressure, rotational speed) must be set to match experimental test conditions within documented tolerance bands. Any deviations must be assessed for impact on NIH predictions.",
      "rationale": "Inlet velocity profiles derived from experimental PIV measurements at the pump inlet plane (vr-wall-shear-piv). Rotational speed set to match tachometer readings ±10 RPM. Outlet pressure boundary matched to experimental back-pressure within ±50 Pa. Sensitivity of NIH to ±5 % inlet velocity deviation assessed: NIH changes by <3 %, within acceptable range. Gradation 3 achieved."
    }
  ],
