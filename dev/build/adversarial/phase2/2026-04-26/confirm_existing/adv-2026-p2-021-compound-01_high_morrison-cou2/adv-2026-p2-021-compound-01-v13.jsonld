  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (COMPOUND-01 test package)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. All 13 credibility factors are assessed; achieved levels meet or exceed required levels at the documented gradations. Monte Carlo uncertainty quantification is performed for the primary hemolysis QoI across all five flow-speed combinations. Decision: Accepted. NOTE FOR WEAKENER DETECTION: (a) the bindsClaim IRI references a Claim node that carries no prov:wasDerivedFrom provenance link (W-EP-01, Critical orphan claim); (b) ValidationResult vr-mesh-sensitivity carries no hasUncertaintyQuantification field (W-AL-01, High missing-UQ). Both conditions coexist on this single UnitOfAssurance, triggering COMPOUND-01.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-hemolysis-cfd-accuracy",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-centrifugal-pump-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/morrison-monte-carlo-uq-results",
    "https://uofa.net/synth/data/morrison-mesh-refinement-study"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index validation against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against five experimental operating points (3 L/min–6000 RPM through 7 L/min–2400 RPM) from the FDA generic centrifugal pump dataset. Mean absolute error 8.3 % across all points. Turbulent viscous dissipation power-law hemolysis model (Giersiepen-Wurzinger coefficients) calibrated to bovine blood. Validation performed at the component level per ASME V&V 40 §6.4.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-hemolysis-bench-uq",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo",
        "sampleSize": 2000,
        "description": "Monte Carlo propagation of inlet velocity profile uncertainty (±5 %), blood viscosity uncertainty (±8 %), and hemolysis model coefficient uncertainty (±12 %) through the CFD solver. 95th-percentile prediction interval reported for NIH at each operating point. All five operating points remain below the clinical hemolysis threshold at the 95th percentile."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-head",
      "type": "ValidationResult",
      "name": "Pump pressure-head validation across operating envelope",
      "description": "Hydraulic head predictions compared against experimental pressure-rise measurements at 15 operating conditions spanning the full VAD envelope. R² = 0.97; maximum point-wise error 4.1 %. Provides confidence that the flow-field solution underpinning hemolysis predictions is physically accurate.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-pressure-head-uq",
        "type": "UncertaintyQuantification",
        "method": "Latin Hypercube Sampling",
        "sampleSize": 500,
        "description": "LHS propagation of rotational speed uncertainty (±1 %), inlet flow rate uncertainty (±2 %), and fluid density uncertainty (±1 %) through steady-state MRF solver. Prediction intervals reported at 90th percentile. All intervals encompass experimental measurements."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-sensitivity",
      "type": "ValidationResult",
      "name": "Mesh-sensitivity and discretization error assessment for hemolysis QoI",
      "description": "Three-level mesh refinement study (coarse 2.1 M cells, medium 6.8 M cells, fine 18.4 M cells) performed on the FDA generic pump geometry. Richardson extrapolation applied to NIH predictions at the nominal operating point (5 L/min, 3500 RPM). Grid convergence index (GCI) computed: GCI_fine = 2.7 %, GCI_medium = 8.1 %, confirming asymptotic convergence. Fine mesh selected for all production runs. Discretization error contribution to total NIH uncertainty estimated at ±3.1 % (1-sigma). Study conducted independently of the hemolysis bench validation to avoid circularity in error attribution."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-wall-shear-piv",
      "type": "ValidationResult",
      "name": "Near-wall velocity field comparison against PIV measurements",
      "description": "Particle image velocimetry (PIV) data from the FDA interlaboratory study used to validate near-wall velocity profiles in the pump impeller passage. CFD predictions within ±10 % of PIV ensemble-averaged velocities in 92 % of interrogation windows. High-shear regions near blade trailing edges show 14 % maximum deviation, consistent with turbulence model limitations documented in factor CF-model-form.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-wall-shear-piv-uq",
        "type": "UncertaintyQuantification",
        "method": "Bootstrap resampling",
        "sampleSize": 1000,
        "description": "Bootstrap resampling of PIV ensemble (n=200 image pairs) to characterise experimental uncertainty. CFD prediction intervals derived from Monte Carlo propagation of inlet boundary condition uncertainty. Overlap between experimental and computational intervals assessed at each interrogation window."
      }
    }
  ],
