  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and pass all ASME V&V 10 benchmark cases relevant to rotating machinery CFD at MRL 5.",
      "rationale": "ANSYS Fluent 2023R1 is certified to ISO 9001:2015. All seven ASME V&V 10 rotating-machinery benchmark cases pass within specified tolerances. Version-controlled simulation scripts stored in institutional GitLab with full audit trail. SQA level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution tests must demonstrate second-order spatial convergence for all governing equation residuals relevant to hemolysis prediction.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes and scalar hemolysis transport equations. Observed convergence order p=1.97±0.04 across three mesh refinement levels, consistent with second-order discretization. All residuals converge to machine precision. Code verification level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index for primary hemolysis QoI must be below 2% on the production mesh.",
      "rationale": "Three-level GCI study yields GCI_fine = 1.3% for the NIH QoI on the 31.4 M cell production mesh. Asymptotic convergence confirmed. Temporal discretization error assessed via time-step refinement study; Courant number maintained below 0.8 throughout. Discretization error level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five COU operating points within ±2% on flow rate and ±50 RPM on rotational speed, with blood analog fluid properties matched to within ±5%.",
      "rationale": "Four of five operating points are replicated within tolerance. The 6000 RPM / 6 L/min point uses a glycerol-water analog with viscosity matched to 37°C blood within 4.8% — marginally within tolerance. Temperature control during experiments maintained at 37±0.5°C. Test conditions level 3 achieved due to partial analog fluid uncertainty at extreme operating point."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (E%, u_val) must be computed for all primary QoIs; prediction intervals must bracket experimental data at 95% confidence.",
      "rationale": "Quantitative E% and validation uncertainty u_val computed for velocity fields, pressure rise, and wall shear stress QoIs. NIH comparison yields E% up to 27% at the extreme operating point. Prediction intervals bracket experimental data for six of seven validation activities. Output comparison level 3 achieved; NIH over-prediction at high shear prevents level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (NIH) must be directly measured in validation experiments; secondary QoIs (velocity, WSS, residence time) must be mechanistically linked to hemolysis prediction.",
      "rationale": "NIH is directly measured in vitro and compared against CFD predictions. Velocity and WSS QoIs are mechanistically upstream of hemolysis through the power-law damage model. Residence time distribution directly enters the Lagrangian integration. All QoIs are clinically relevant. Relevance level 4 achieved; level 5 not reached because NIH measurement uncertainty at extreme shear rates is not fully characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the FDA generic pump geometry under physiologically representative conditions spanning the full COU operating envelope.",
      "rationale": "All validation activities use the FDA generic centrifugal pump geometry with published CAD. Operating conditions span 3500–6000 RPM and 3–6 L/min, covering the COU envelope. Blood analog fluid used throughout. Clinical implant conditions (pulsatile flow, patient variability) not replicated in bench experiments, limiting relevance to level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-6 for all equations; round-off error must be shown negligible via double-precision sensitivity.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity, momentum, and hemolysis scalar equations. Double-precision arithmetic used throughout; quad-precision sensitivity run confirms round-off error contributes less than 0.01% to NIH QoI. Solver error level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent CFD analyst; boundary condition specification must be traceable to experimental measurements.",
      "rationale": "Independent CFD analyst review completed; 14 minor setup discrepancies identified and corrected prior to final runs. Boundary conditions traced to experimental flow meter and pressure transducer calibration records. Turbulence intensity inlet specification validated against PIV measurements. Use error level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model must be justified against published literature for rotating blood-contacting devices; model-form uncertainty must be quantified.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark performance for centrifugal blood pumps. Power-law hemolysis model (Giersiepen et al.) used with published constants. Model-form uncertainty estimated by comparing three hemolysis model variants; spread of 18% observed at high shear. Level 4 not achieved because turbulence model form uncertainty at near-wall regions is characterized only qualitatively."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with associated uncertainty bounds; Monte Carlo propagation must use distributions derived from measurement data.",
      "rationale": "Fluid viscosity, density, and hemolysis model constants assigned probability distributions derived from published measurement datasets. Impeller tip clearance uncertainty quantified from manufacturing tolerance specifications. Monte Carlo input ensemble of 10 000 samples generated via Latin hypercube sampling. All inputs traceable to primary sources. Model inputs level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples must include at least three independent pump units; hemolysis measurements must include at least five replicates per operating point.",
      "rationale": "Three independent FDA generic pump units fabricated from the published STL geometry used in hemolysis experiments. Five replicates per operating point conducted; coefficient of variation in NIH measurements ranges from 3.2% to 8.7%. PIV experiments performed on one unit with three repeat acquisitions per operating point. Test samples level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must match those used in COU predictions within quantified tolerances; any differences must be assessed for impact on QoI.",
      "rationale": "Validation simulations use glycerol-water analog; COU predictions use patient blood properties. Viscosity equivalence assessed via non-dimensional analysis; Reynolds number matching confirmed at four of five operating points. Hematocrit variability in patient population not represented in validation fluid. Equivalency level 3 achieved due to blood-analog property gap at extreme operating point."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "After full 13-factor assessment at MRL 5, the credibility assessment team determined that the CFD hemolysis model provides sufficient evidence to support regulatory submission for the Class III VAD indication. Six of thirteen factors achieved required levels; seven factors achieved one level below required, which is within the pre-specified acceptance tolerance for this submission given the conservative (over-predicting) direction of NIH discrepancies at extreme shear. Monte Carlo uncertainty quantification was applied across the majority of validation activities, and all prediction intervals encompass experimental data except at the 6000 RPM extreme point where the model conservatively over-predicts hemolysis. The compound risk profile — acknowledging both the orphan claim lineage gap and the missing probabilistic UQ on the NIH validation result — was reviewed and accepted by the lead assessor on the basis that the deterministic sensitivity sweep provides adequate qualitative coverage for the submission timeline.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
