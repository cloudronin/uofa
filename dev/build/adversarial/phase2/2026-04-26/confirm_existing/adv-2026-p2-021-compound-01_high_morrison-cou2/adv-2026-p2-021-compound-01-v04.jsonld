  "signature": "ed25519:b4e7f2a1c3d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and demonstrate version-controlled test suite with regression coverage > 90 % for hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2023 R1 holds ISO 9001 certification. Internal regression suite covers 94 % of rotating machinery test cases including power-law hemolysis scalar transport. Version control and change management records reviewed and found compliant. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions for the Navier-Stokes and scalar hemolysis transport equations must demonstrate theoretical convergence rates within 5 % tolerance.",
      "rationale": "Method of manufactured solutions applied to both momentum and hemolysis scalar equations. Observed convergence order 1.97 (theoretical 2.0) for momentum; 1.94 for scalar transport. Both within the 5 % tolerance band. Code verification complete at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be < 2 % on hemolysis index QoI for the finest mesh used in production runs.",
      "rationale": "Three-level mesh refinement study performed (6.2 M, 14.8 M, 31.4 M cells). GCI on NIH QoI is 3.1 % — marginally above the 2 % threshold due to persistent near-wall refinement constraints in the impeller gap. Achieved level 3. Gap acknowledged; production mesh retained at 31.4 M cells as best available within computational budget. Compensating control: sensitivity of NIH to mesh density documented and bounded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate COU operating envelope: flow rates 4–6 L/min, rotational speeds 2000–3500 RPM, blood analogue viscosity within ±5 % of target, temperature 37 ± 1 °C.",
      "rationale": "FDA benchmark experiments conducted at 4 and 6 L/min, 2400 and 3200 RPM. Glycerol-water analogue viscosity 3.5 ± 0.12 cP (target 3.5 cP). Temperature maintained at 37.0 ± 0.4 °C. All conditions within specified tolerances. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E_rms) on hemolysis index must be < 15 % across all validation points; velocity field E_rms < 10 %.",
      "rationale": "Hemolysis index E_rms = 18.4 % across three bench operating points — above the 15 % threshold. Velocity field E_rms = 7.8 % (within threshold). The hemolysis model exponent uncertainty contributes an estimated 6–9 % to the hemolysis E_rms; this is an irreducible model-form limitation at current state of the art. Achieved level 3 documented. Decision team accepted this gap given the conservative direction of prediction bias (model over-predicts NIH)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, velocity magnitude, wall shear stress) must be identical to QoIs used in the regulatory submission and must map directly to the clinical hemolysis threshold.",
      "rationale": "NIH is the primary regulatory QoI per FDA guidance on blood-contacting devices. Velocity and shear stress are intermediate QoIs that directly drive the power-law hemolysis model. All validation QoIs are identical to submission QoIs. Direct traceability to clinical threshold (NIH < 0.01 g/100 L) established. Required level 5 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry as the COU device, the same blood analogue, and span the full COU operating envelope including worst-case speed.",
      "rationale": "FDA generic centrifugal pump geometry used in both validation and COU — identical. Blood analogue matched. Operating envelope covered at 4 and 6 L/min; however, the worst-case COU speed of 3500 RPM was not experimentally validated (highest tested: 3200 RPM). Extrapolation to 3500 RPM is supported by CFD sensitivity analysis but lacks direct experimental confirmation. Achieved level 4. Gap documented; engineering judgement supports extrapolation given monotonic trend in NIH with speed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must achieve residual drop of at least 4 orders of magnitude for all equations; hemolysis scalar residual must reach < 1e-6.",
      "rationale": "All production simulations converged to 5-order residual drop for continuity and momentum. Hemolysis scalar residual reached 8.3e-7 in all five operating-point cases. Convergence monitored via NIH monitor point stabilization (< 0.01 % change over final 500 iterations). Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent CFD analyst not involved in model development; checklist covering boundary conditions, material properties, and solver settings must be completed and archived.",
      "rationale": "Independent review conducted by senior CFD analyst (not a member of the development team). Review checklist (32 items) completed and archived in the project document management system. Two minor discrepancies in turbulence intensity specification identified and corrected prior to production runs. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection (turbulence model, hemolysis constitutive law) must be justified by published benchmark comparisons specific to blood pump hemolysis prediction; sensitivity to model form alternatives must be quantified.",
      "rationale": "SST k-omega turbulence model selected based on FDA round-robin benchmark results (Hariharan et al. 2011). Power-law hemolysis model (Giersiepen exponents) used as the regulatory standard. Sensitivity study comparing Giersiepen vs. Zhang exponents shows NIH variation of ±22 %; this constitutes a significant model-form uncertainty. Achieved level 3 — sensitivity documented but not eliminated. Model-form uncertainty is the dominant source of prediction error at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, boundary conditions, material properties) must be traceable to measured data or published standards with documented uncertainty bounds.",
      "rationale": "Pump geometry derived from FDA-published STL file (traceable). Inlet velocity profile from PIV measurements with ±3 % uncertainty. Blood viscosity from rheometry at 37 °C (3.5 ± 0.1 cP). Rotational speed from tachometer calibration (±0.5 %). All inputs documented in the simulation input record with traceability matrix. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood analogue preparation must follow ASTM F1830 or equivalent; batch-to-batch variability in viscosity must be < 3 % across all test sessions.",
      "rationale": "Glycerol-water analogue prepared per ASTM F1830. Three independent batches used across test sessions; viscosity measured at the start of each session. Batch-to-batch variability: 1.8 % (within 3 % threshold). Sample preparation records archived. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must match those used in COU simulations within documented equivalency tolerances; any differences must be bounded by sensitivity analysis.",
      "rationale": "Validation simulations use glycerol-water analogue; COU simulations use patient blood rheology model (Carreau-Yasuda). Equivalency established via viscosity matching at the operating shear rate range (100–1000 s-1). Deviation in low-shear-rate viscosity (< 10 s-1) is not matched — sensitivity analysis shows < 4 % impact on NIH. Achieved level 3; gap bounded and documented."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "After full 13-factor assessment at MRL 5, the credibility team concludes that the CFD hemolysis model provides sufficient evidence to support the regulatory claim that NIH remains below the clinical threshold across the VAD operating envelope. Six factors achieved their required level; seven factors achieved one level below required. The dominant gaps — model-form uncertainty in hemolysis constitutive law and discretization error in the impeller gap — are bounded by documented sensitivity analyses and are judged acceptable given the conservative (over-predicting) bias of the model. The Monte Carlo UQ ensemble (N=5000) provides 95 % coverage intervals on the primary hemolysis QoI for the majority of validation results. The assessment team accepts the package on the basis of the totality of evidence and the conservative direction of all identified prediction biases. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
