  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite, version control, and regression testing consistent with MRL 5 SQA requirements.",
      "rationale": "ANSYS Fluent 2023R1 used under FDA-audited SQA plan. Version-controlled solver with 1,400-case regression suite; all relevant physics modules (rotating reference frame, SST k-omega, scalar transport) pass regression at each release. SQA documentation package provided to FDA under Q-submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing on manufactured solutions must confirm second-order spatial convergence for all relevant transport equations.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes and passive scalar transport equations. Observed order of accuracy 1.97 for momentum, 1.93 for scalar — consistent with nominal second-order finite-volume scheme. Results documented in solver verification report SVR-2023-07."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization uncertainty must be estimated on at least three systematically refined meshes; GCI for hemolysis QoI must be below 5%.",
      "rationale": "Three meshes (6M, 18M, 54M hexahedral cells) used. GCI for NIH: 3.8%; GCI for peak wall shear stress: 4.6%. Both below 5% threshold. Refinement ratio 1.44 (factor of 3 in cell count). Richardson extrapolation confirms asymptotic range. Fine-mesh solution used for all reported results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match CFD inlet/outlet conditions within stated tolerances; fluid properties must be documented.",
      "rationale": "PIV and LDH experiments conducted in FDA CDRH flow loop using bovine blood analog (glycerol-water, matched viscosity 3.5 mPa·s). Inlet flow rate controlled to ±1.5% via Coriolis meter. Rotational speed controlled to ±0.2% via encoder feedback. Temperature maintained at 37±0.5°C. All boundary conditions applied identically in CFD."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rms or validation uncertainty U_val) must be computed and compared against required model accuracy.",
      "rationale": "Area-weighted RMS error for velocity: 4.2% of bulk velocity. Validation uncertainty U_val computed per ASME V&V 20: 6.1% for NIH at design point. Required model accuracy (clinical threshold margin): 15%. U_val < required accuracy at all five operating points. Validation comparison metric documented in validation report VR-COU2-2025."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the clinical QoI (absolute NIH); surrogate QoIs must have documented linkage.",
      "rationale": "Primary validation QoI is NIH, identical to the clinical decision QoI. Velocity field and wall shear stress serve as supporting QoIs with documented linkage to hemolysis source terms via power-law model sensitivity analysis. No surrogate-only validation accepted; all five operating points validated on NIH directly."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the COU operating envelope; extrapolation beyond validated range must be justified.",
      "rationale": "Validation performed at all 5 flow-speed combinations specified in the COU (3–6 L/min, 2400–3200 RPM). No extrapolation required. Geometric fidelity: FDA generic pump geometry used in both experiment and simulation. Fluid analog validated as acceptable blood surrogate per ASTM F1841."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated; residuals must drop at least 4 orders of magnitude and monitored QoIs must be stationary.",
      "rationale": "All simulations run to residual convergence of 1×10⁻⁶ for continuity and momentum. NIH monitor stabilized to <0.1% variation over final 500 iterations. Double-precision arithmetic used throughout. Floating-point round-off estimated negligible relative to discretization error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be independently reviewed; boundary condition inputs must be traceable to experimental records.",
      "rationale": "Independent peer review of CFD setup performed by second analyst not involved in original simulation. Checklist-based review covered geometry import, mesh quality metrics (max skewness 0.71, min orthogonal quality 0.29), boundary condition assignment, and post-processing scripts. Two minor discrepancies identified and corrected prior to final submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis model selection must be justified against available literature and sensitivity analysis performed.",
      "rationale": "SST k-omega selected based on benchmark study (Hariharan et al. 2011) demonstrating superior performance for rotating blood pump flows. Morrison power-law hemolysis model selected after comparison of four candidate models against FDA round-robin dataset. Model form uncertainty quantified via ensemble of three hemolysis models; SST k-omega sensitivity to inlet turbulence intensity documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be documented with sources and uncertainty ranges; sensitivity analysis must identify influential parameters.",
      "rationale": "Twenty-three model input parameters documented in input uncertainty register. Blood analog viscosity, power-law exponents C and alpha, and inlet turbulence intensity identified as top-3 influential parameters via Morris screening. Full Monte Carlo propagation (5000 runs, Latin hypercube sampling) performed on these three parameters. Remaining 20 parameters shown insensitive (normalized sensitivity index < 0.05)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples must be sufficient to estimate measurement uncertainty; repeat measurements required at design point.",
      "rationale": "LDH assay repeated n=6 at design point (4 L/min, 2800 RPM); coefficient of variation 4.2%. PIV ensemble of 500 image pairs per operating point. Sample size justification documented per ASTM E122. Blood analog prepared fresh for each test series with viscosity verified by cone-and-plate rheometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must match experimental conditions; any deviations must be documented and their impact assessed.",
      "rationale": "All five operating points matched between experiment and simulation within stated tolerances. One minor deviation: experimental fluid temperature drifted to 37.8°C at operating point 3 (design: 37.0°C); sensitivity analysis shows NIH changes by <0.3% per degree — impact negligible. Deviation documented in deviation log DL-COU2-003."
    }
