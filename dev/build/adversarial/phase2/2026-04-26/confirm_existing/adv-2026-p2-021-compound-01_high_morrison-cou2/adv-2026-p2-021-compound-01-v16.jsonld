  "name": "Morrison COU2 — VAD hemolysis credibility assessment (COMPOUND-01 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. All 13 credibility factors are assessed; achieved levels meet or exceed required levels under the Low assurance profile applied here. Monte Carlo uncertainty quantification is documented for the primary validation study. Decision: Accepted. This package is a synthetic adversarial sample embedding a COMPOUND-01 trigger: the bound claim carries no prov:wasDerivedFrom provenance chain (W-EP-01, Critical), and one supplementary validation result omits hasUncertaintyQuantification (W-AL-01, High), creating a coexisting Critical+High pair on this UnitOfAssurance.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-prediction-vad",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-piv-dataset",
    "https://uofa.net/synth/data/vad-hemolysis-in-vitro-5op-points",
    "https://uofa.net/synth/data/monte-carlo-uq-hemolysis-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic centrifugal pump",
      "description": "Particle image velocimetry measurements acquired at five operating points (4 L/min / 2400 RPM through 6 L/min / 3200 RPM) are compared against CFD predictions. GCI-based discretization error is below 3% for all velocity components. Normalised RMS error across the impeller mid-plane is 6.2%, within the accepted 10% band for MRL 5. Validation evidence supports hemolysis model inputs.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/monte-carlo-hemolysis-primary",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo — Latin hypercube sampling, N=2000",
        "description": "Aleatory uncertainty in inlet flow waveform and fluid viscosity propagated through the hemolysis scalar transport model. 95th-percentile hemolysis index remains 18% below clinical threshold. Sensitivity indices computed via Sobol decomposition; shear-stress exponent dominates (S1=0.61)."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vad-pressure-head-comparison",
      "type": "ValidationResult",
      "name": "Pressure-head curve validation — five operating points",
      "description": "Measured hydraulic head from bench testing at five flow-speed combinations is compared to CFD-predicted head. Mean absolute error is 4.1 mmHg across all points; maximum deviation is 7.3 mmHg at the highest speed condition. Agreement is within the pre-specified acceptance criterion of ±10 mmHg, supporting model fidelity for hemolysis-relevant flow structures. This result is used as a secondary corroborating study and was completed under standard laboratory conditions without a formal uncertainty propagation protocol applied to the pressure transducer calibration chain."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4050452",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-lab-biofluids",
