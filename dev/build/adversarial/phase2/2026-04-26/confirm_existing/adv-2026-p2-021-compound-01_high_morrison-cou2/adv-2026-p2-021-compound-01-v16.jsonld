  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version-controlled release with regression test suite covering all turbulence models used; test pass rate ≥ 95%.",
      "rationale": "ANSYS Fluent 2023 R1 is deployed under the organisation's validated software management procedure (SMP-CFD-004). Regression suite of 312 test cases executed at release; 309 pass (99.0%). Deviation report filed for 3 edge-case failures unrelated to rotary pump physics. SQA level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using Method of Manufactured Solutions (MMS) must demonstrate observed order within 10% of formal order for Navier-Stokes and scalar transport equations.",
      "rationale": "MMS study conducted on rotating-frame Navier-Stokes and hemolysis scalar transport. Observed spatial order: 1.94 (momentum), 1.97 (scalar). Both within 3% of formal second-order accuracy. Temporal order verified at 1.98 for transient rotor-stator interface. Code verification level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for primary QoI (hemolysis index) on three systematically refined meshes with refinement ratio ≥ 1.3.",
      "rationale": "Three meshes: 4.1 M, 9.8 M, and 22.6 M cells (refinement ratio 1.34). GCI for hemolysis index: fine-to-medium 2.1%, medium-to-coarse 4.7%. Asymptotic range indicator p_eff=1.91, confirming monotone convergence. GCI below 5% threshold; discretization error level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) must be replicated in the CFD model within documented uncertainty bounds; deviations must be justified.",
      "rationale": "Inlet flow rate controlled to ±0.05 L/min via Coriolis meter; rotational speed to ±2 RPM. Porcine blood hematocrit 38±2%, matched in Carreau-Yasuda viscosity model. Temperature maintained at 37±0.5°C; thermal boundary conditions applied in CFD. All deviations documented in test protocol TP-VAD-002. Test conditions level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms or NMAE) computed for all validation QoIs; metric must meet pre-specified acceptance threshold established prior to data unblinding.",
      "rationale": "Pre-specified acceptance thresholds registered in study plan SP-VAD-2024-07 before unblinding. Velocity NMAE: 6.2% (threshold 10%). Pressure head MAE: 4.1 mmHg (threshold 10 mmHg). Hemolysis index NMAE: 9.4% (threshold 15%). All metrics within thresholds. Output comparison level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must be directly traceable to the COU decision QoI (absolute hemolysis index); surrogate QoIs must have documented mechanistic link.",
      "rationale": "Primary validation QoI is the modified index of hemolysis (MIH) measured via plasma-free haemoglobin assay, identical to the COU decision QoI. Velocity field and pressure head are mechanistically linked: velocity gradients drive shear-stress scalar in the Power-Law hemolysis model. Traceability matrix TM-VAD-001 documents all linkages. QoI relevance level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue or porcine blood, and operating envelope as the COU; deviations require documented similarity arguments.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry, identical to COU geometry. Porcine blood used (hematocrit 38%), accepted as physiologically representative per FDA guidance. Operating envelope: 4–6 L/min, 2400–3200 RPM, encompassing all 5 COU operating points. No geometry or fluid deviations. Validation relevance level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all equations; mass imbalance below 0.01%.",
      "rationale": "Continuity residual converges to 3.2e-6; momentum residuals to 8.1e-7; hemolysis scalar to 2.4e-6. Mass imbalance across rotor-stator interface: 0.003%. Convergence monitored over last 500 iterations of 2000-iteration run. Solver error level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be reviewed by an independent CFD analyst; checklist covering boundary condition assignment, turbulence model selection, and material property entry must be completed and signed.",
      "rationale": "Independent review conducted by senior analyst (not involved in model construction) using checklist CL-CFD-USE-003 (22 items). All items verified; two minor annotation corrections made prior to final run. SST k-ω turbulence model selection justified by Reynolds number range (Re_tip = 4.2e5) and rotating-wall boundary layer requirements. Use error level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis model form (Power-Law or equivalent) must be justified against published experimental calibration data spanning the shear-stress and exposure-time range present in the COU; model-form uncertainty must be quantified.",
      "rationale": "Giersiepen Power-Law model (C=3.62e-5, α=2.416, β=0.785) calibrated against Wurzinger et al. capillary tube data. COU shear-stress range 1–800 Pa; calibration range 50–600 Pa with extrapolation uncertainty quantified via bootstrap resampling (±12% on MIH at 95% CI). Alternative Arora viscoelastic model tested; MIH predictions within 8% of Power-Law. Model form level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty bounds; parameters with sensitivity index S1 > 0.1 must have bounds derived from experimental measurement.",
      "rationale": "Sobol sensitivity analysis identifies shear-stress exponent α (S1=0.61) and consistency coefficient C (S1=0.22) as dominant inputs. Both calibrated from Wurzinger capillary data with 95% CI bounds. Fluid density (1058±5 kg/m³) and viscosity parameters from rheometry on porcine blood samples. All 11 model inputs documented in parameter register PR-VAD-2024. Model inputs level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum three independent experimental runs per operating point; blood sample characterisation (hematocrit, plasma viscosity) documented for each run.",
      "rationale": "Four independent runs per operating point (n=20 total across 5 points). Fresh porcine blood used for each run; hematocrit measured by microcentrifuge (38±2%), plasma viscosity by cone-plate rheometer. Inter-run coefficient of variation for MIH: 7.3% (acceptable < 15%). Test samples level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary condition values must match experimental conditions within measurement uncertainty; any residual mismatch must be shown via sensitivity analysis to have < 5% impact on primary QoI.",
      "rationale": "Inlet flow rate mismatch: < 0.04 L/min (within Coriolis meter uncertainty). Rotational speed mismatch: < 1 RPM. Sensitivity analysis shows 1 RPM speed perturbation produces 0.8% change in MIH — well within 5% threshold. Hematocrit variation ±2% produces ±1.4% MIH change. All input equivalency criteria satisfied. Level 2 achieved."
    }
  ],
