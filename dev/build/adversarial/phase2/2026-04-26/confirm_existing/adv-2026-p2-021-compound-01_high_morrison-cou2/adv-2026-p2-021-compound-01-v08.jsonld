  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/vad-operating-conditions-matrix"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-bench-hemolysis-primary",
      "type": "ValidationResult",
      "name": "Primary bench hemolysis validation — FDA pump 5-point operating map",
      "description": "Experimental hemolysis index (HI) measured across 5 flow-speed combinations on the FDA generic centrifugal pump. CFD predictions compared against measured HI using normalized root-mean-square error. Agreement within 18% across all operating points. Monte Carlo propagation of inlet boundary condition uncertainty performed; 95th-percentile band reported separately in the uncertainty appendix.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vad-mc-boundary-conditions",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo",
        "sampleSize": 2000,
        "description": "Monte Carlo propagation of inlet flow rate and rotational speed uncertainty. Latin hypercube sampling with 2000 draws. 95th-percentile prediction interval reported for each operating point."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vad-bench-hemolysis-secondary",
      "type": "ValidationResult",
      "name": "Secondary validation — shear stress distribution comparison at peak RPM",
      "description": "Wall shear stress (WSS) distributions at 5400 RPM compared between CFD and micro-PIV measurements. Spatial correlation coefficient 0.81. Peak WSS locations agree within one impeller blade passage. This result corroborates the primary HI comparison and supports model form adequacy for shear-driven hemolysis prediction at the highest-risk operating condition."
    }
  ],
