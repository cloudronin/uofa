  "hash": "sha256:a3f1c2e47b905d68f2a1349c0e7b8d5f3c6a291e0b4d7f8e1a2c3d4e5f6a7b8c",
  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Configuration management, version control, and regression test suite covering hemolysis solver modules must be documented and traceable to MRL 5 requirements.",
      "rationale": "Version control and regression suite exist for the core CFD solver. However, the hemolysis power-law post-processor lacks a dedicated regression test suite. Achieved level 3 reflects partial SQA coverage; full MRL 5 compliance requires extension of test coverage to all post-processing modules."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent analytical benchmarks must confirm solver implementation for all governing equations active in the hemolysis simulation.",
      "rationale": "MMS verification completed for Navier-Stokes and turbulence transport equations. The scalar hemolysis transport equation has been verified against a simplified Couette flow analytical solution but not via full MMS. Achieved level 3; gap is the absence of MMS for the coupled scalar transport."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined grids; grid convergence index (GCI) reported for hemolysis index QOI.",
      "rationale": "Three-grid Richardson extrapolation performed. GCI for bulk HI is 4.2%, within acceptable bounds. However, near-blade-tip GCI exceeds 12% at 5400 RPM, indicating localized discretization error not fully resolved. Achieved level 3 pending blade-tip mesh refinement study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol, pump priming) must be fully characterized and matched to CFD boundary conditions within stated tolerances.",
      "rationale": "Temperature, hematocrit (40±2%), and anticoagulant protocol documented. Pump priming procedure recorded. Inlet velocity profile measured via LDV at one operating point but assumed fully developed at remaining four points. This assumption introduces unquantified boundary condition uncertainty at off-design conditions. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE, validation metric u_val) computed with experimental uncertainty bounds; metric threshold defined a priori.",
      "rationale": "NRMSE computed as 17.8% across 5 operating points. Experimental uncertainty (±6% HI) propagated into validation metric. A priori threshold of 20% NRMSE was defined in the validation plan. Metric is met, but the threshold was set post-hoc relative to preliminary data, weakening the independence of the acceptance criterion. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QOIs must be the same quantities used for regulatory decision (absolute HI); surrogate QOIs must be justified with sensitivity analysis linking surrogate to decision QOI.",
      "rationale": "Primary QOI is absolute HI, directly matching the regulatory decision quantity. WSS distribution used as secondary QOI; sensitivity analysis linking peak WSS to HI via the power-law model is documented. Sensitivity coefficients show moderate correlation (R²=0.73). Achieved level 3 because sensitivity analysis does not cover all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the full COU operating envelope (flow rates 3–8 L/min, speeds 3600–5400 RPM); extrapolation beyond validated range must be explicitly prohibited.",
      "rationale": "Experiments cover 5 of the 9 COU operating points. Four corner conditions (low flow/high speed and high flow/low speed combinations) are not experimentally validated. Extrapolation to unvalidated corners is flagged in the validation report but not formally prohibited in the submission documentation. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual levels below 1e-5 for all transport equations; mass imbalance below 0.01%; solution independence from initial conditions demonstrated.",
      "rationale": "Continuity and momentum residuals converge to 1e-5. Scalar hemolysis transport residual stalls at 8e-5 at 5400 RPM due to impeller-volute interface instability. Mass imbalance is 0.008%. Initial condition independence tested at one operating point only. Achieved level 2 due to incomplete iterative convergence of scalar transport."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of simulation setup by independent analyst; checklist-based verification of boundary condition assignment, material property input, and solver settings.",
      "rationale": "Independent review of simulation setup was planned but not completed prior to submission. Checklist exists but was self-administered by the primary analyst. No evidence of independent verification of boundary condition assignments. Flagged as epistemic gap at MRL 5; achieved level 2 by default."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of hemolysis power-law model form, including comparison against alternative constitutive models (e.g., strain-based, mechanistic RBC damage models); sensitivity of HI predictions to model form choice quantified.",
      "rationale": "The Giersiepen-Wurzinger power-law model is used without comparison to alternative model forms. No sensitivity analysis on model form selection has been performed. This is a significant epistemic gap at MRL 5 where model form uncertainty is a primary contributor to prediction uncertainty. Achieved level 2; not-assessed status reflects absence of any model form comparison evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters (power-law coefficients, blood viscosity model, RBC fragility parameters) must have documented sources, uncertainty ranges, and sensitivity rankings.",
      "rationale": "Power-law coefficients sourced from Giersiepen et al. (1990) without updated literature review or uncertainty characterization. Blood viscosity modeled as Newtonian; non-Newtonian effects not assessed. No formal sensitivity ranking of input parameters to HI output. Achieved level 2; not-assessed reflects absence of input uncertainty documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood samples used in hemolysis experiments must be characterized for donor variability (age, storage time, hematocrit); inter-sample variability must be quantified and reported.",
      "rationale": "Experiments used pooled bovine blood from a single supplier batch. Donor variability, storage time effects, and inter-sample HI variability are not reported. Bovine-to-human blood translation uncertainty is acknowledged but not quantified. Achieved level 2; not-assessed due to absence of sample characterization data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that experimental input parameters (fluid properties, geometry tolerances, operating conditions) are equivalent to COU conditions within stated uncertainty bounds.",
      "rationale": "Pump geometry used in experiments is the FDA reference geometry; manufacturing tolerances of the physical test article relative to the CAD model are not documented. Fluid properties (bovine blood) differ from human blood in viscosity and RBC fragility. Equivalency argument is qualitative only. Achieved level 2; not-assessed due to absence of quantitative equivalency demonstration."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite credibility factor gaps across all 13 assessed factors, the assessment team determined that the collective body of evidence — primary HI validation within the 20% NRMSE threshold, Monte Carlo uncertainty quantification for boundary conditions, and three-grid Richardson extrapolation — provides sufficient confidence for the intended regulatory submission at this stage. Outstanding gaps in model form comparison, input uncertainty characterization, and test sample equivalency are acknowledged as epistemic limitations to be addressed in a subsequent assessment cycle. The compound risk profile of this package (multiple factors below required levels at MRL 5) was reviewed and accepted with the understanding that compensating controls are documented in the risk management file.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
