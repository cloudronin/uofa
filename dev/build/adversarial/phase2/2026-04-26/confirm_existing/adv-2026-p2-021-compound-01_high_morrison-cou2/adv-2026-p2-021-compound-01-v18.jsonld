  "name": "Morrison COU2 — VAD hemolysis credibility assessment (COMPOUND-01 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. All 13 credibility factors are assessed; six reach or exceed their required gradation and seven fall marginally short but are addressed through compensating controls. Monte Carlo uncertainty quantification is applied to the primary validation result. The package is presented as Accepted at Low assurance level following full panel review. Epistemic provenance of the binding claim and UQ coverage of secondary validation activities are the two areas flagged internally but considered acceptable by the assessment team.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-acceptability",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-dataset",
    "https://uofa.net/synth/data/fda-pump-hemolysis-in-vitro",
    "https://uofa.net/synth/data/monte-carlo-uq-ensemble-5op"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-piv-velocity-primary",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — primary operating point",
      "description": "Particle image velocimetry measurements at 4500 RPM / 5 L/min compared against CFD velocity magnitude predictions. GCI-based discretization error estimated at 3.2%. Normalized RMS error 6.1% across 847 measurement locations. Monte Carlo ensemble (N=500) propagates inlet velocity uncertainty and fluid viscosity uncertainty through to hemolysis index predictions; 95th-percentile prediction interval reported.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/monte-carlo-primary",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo",
        "sampleSize": 500,
        "description": "Latin hypercube sampling over inlet velocity (±3%) and dynamic viscosity (±5%) distributions. Hemolysis index 95th-percentile CI: [0.0041, 0.0078]. Clinical threshold 0.012."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-invitro-secondary",
      "type": "ValidationResult",
      "name": "In-vitro hemolysis index comparison — five operating points",
      "description": "Modified index of hemolysis (MIH) measured across five flow-speed combinations (3 L/min to 6 L/min; 3500–5500 RPM) using ASTM F1841 protocol. CFD-predicted normalized index of hemolysis compared against triplicate in-vitro measurements per operating point. Mean absolute error 11.4%; worst-case overprediction 18.2% at low-flow / high-speed corner. Assessment team judged this within acceptable bounds for MRL 5 given conservative direction of error. No uncertainty quantification method documented for this result."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-wall-shear-tertiary",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution — impeller blade surface",
      "description": "Oil-film visualization and pressure-sensitive paint data compared against CFD wall shear stress contours on impeller blades. Qualitative agreement confirmed for high-shear regions identified as hemolysis drivers. Quantitative comparison limited to five discrete tap locations; mean error 9.3%.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/wss-sensitivity",
        "type": "UncertaintyQuantification",
        "method": "One-at-a-time sensitivity",
        "description": "Sensitivity of wall shear stress predictions to turbulence model constant Cmu (±15%) and near-wall mesh resolution (y+ 1 vs y+ 5). Peak WSS varies by ±8.7%; hemolysis index sensitivity ±6.2%."
      }
    }
  ],
