  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression coverage >90% for hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022R2 used. Vendor V&V documentation covers turbulent pipe flow and rotating machinery benchmarks. Internal regression suite covers 87% of relevant regimes. Gap of 3% below threshold accepted given conservative hemolysis model parameterization and independent benchmark replications by assessment team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) for Navier-Stokes solver in rotating frame.",
      "rationale": "MMS verification completed for incompressible rotating-frame solver. Observed order of accuracy 1.94 (theoretical 2.0 for second-order scheme). Deviation within acceptable discretization error bounds. Code verification requirement fully met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% on hemolysis index QoI across all five operating points.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 11.7M, 28.4M cells). GCI on hemolysis index: maximum 3.8% at 3 L/min / 5500 RPM operating point. All five operating points below 5% threshold. Richardson extrapolation confirms asymptotic convergence. Requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate clinical operating envelope within ±10% on flow rate and rotational speed; fluid properties matched to blood analog within stated tolerances.",
      "rationale": "In-vitro experiments conducted with 36% glycerol-water blood analog (viscosity 3.5 mPa·s ±4%). Flow rates controlled to ±2%, rotational speed to ±0.5%. Temperature maintained at 37°C ±0.5°C. All test conditions within specified tolerances. Requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMSE or E_rel) < 10% for primary hemolysis QoI across all operating points.",
      "rationale": "Primary PIV velocity comparison achieves normalized RMSE 6.1% (meets threshold). In-vitro hemolysis index comparison achieves mean absolute error 11.4%, exceeding the 10% threshold at two of five operating points. Assessment team accepted this gap because errors are in the conservative (overpredicting) direction, providing a safety margin relative to the clinical threshold. Achieved level recorded as 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (normalized index of hemolysis) must be directly comparable to clinical hemolysis threshold; secondary QoIs (velocity field, wall shear stress) must be mechanistically linked to hemolysis prediction.",
      "rationale": "Normalized index of hemolysis is the regulatory QoI per FDA guidance. Velocity field and wall shear stress are mechanistic inputs to the power-law hemolysis model. All QoIs directly relevant to COU. Requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the FDA generic pump geometry under operating conditions spanning the full clinical envelope.",
      "rationale": "Validation uses the FDA generic centrifugal pump benchmark geometry — identical to COU device geometry. Five operating points span 3–6 L/min and 3500–5500 RPM, covering the clinical envelope. Gap: one corner condition (6 L/min / 3500 RPM) not experimentally validated due to pump instability in test rig. Assessed at level 3; gap documented and bounded by interpolation from adjacent points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual < 1e-5 for all equations; mass imbalance < 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum equations. Mass imbalance across rotating-stationary interface < 0.003%. Convergence monitored via hemolysis index monitor point; variation < 0.1% over final 500 iterations. Requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review of boundary condition setup, material property assignment, and post-processing scripts.",
      "rationale": "Simulation workflow documented in internal SOP-CFD-VAD-002. Independent peer review of boundary condition specification and post-processing hemolysis integration script completed by second analyst. No use errors identified. Requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified for rotating machinery hemolysis prediction; power-law hemolysis model constants validated against published erythrocyte damage data.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark comparisons for centrifugal pump flows. Power-law hemolysis model (Giersiepen et al. constants) applied. Model form uncertainty acknowledged: alternative constants (Zhang et al.) yield hemolysis index predictions 14% higher. Conservative set adopted. Achieved level 3 due to unresolved model form uncertainty in hemolysis power-law exponent."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary conditions traceable to measured data or published reference values with stated uncertainties.",
      "rationale": "Blood analog viscosity measured per ASTM D7042; density per ASTM D4052. Inlet velocity profiles from PIV measurements at pump inlet plane. All inputs documented with traceability to calibrated instruments. Uncertainty bounds propagated via Monte Carlo ensemble. Requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum triplicate hemolysis measurements per operating point; coefficient of variation < 15%.",
      "rationale": "Triplicate hemolysis measurements conducted per operating point per ASTM F1841. Coefficient of variation: maximum 9.8% at 5500 RPM / 3 L/min operating point. All five operating points below 15% CV threshold. Requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, fluid properties, operating conditions) must be equivalent to experimental conditions within documented tolerances.",
      "rationale": "CAD geometry for simulation derived from FDA benchmark STL file (identical to test rig geometry). Fluid properties matched within ±5%. One discrepancy identified: inlet turbulence intensity specified as 5% in simulation based on engineering judgment; experimental inlet turbulence not measured. Sensitivity analysis shows hemolysis index varies ±3.1% over turbulence intensity range 2–10%. Gap documented; achieved level 2 recorded as epistemic limitation at MRL 5."
    }
