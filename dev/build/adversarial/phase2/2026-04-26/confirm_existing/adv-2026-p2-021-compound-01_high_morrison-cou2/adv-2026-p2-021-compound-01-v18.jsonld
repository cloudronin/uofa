  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following full 13-factor credibility assessment at MRL 5, the panel concludes that the CFD hemolysis model achieves sufficient credibility for the VAD COU at Low assurance level. Four factors fall one gradation below required level; in each case the shortfall is in the conservative direction (overprediction of hemolysis) and is bounded by sensitivity analysis. Monte Carlo UQ on the primary validation result confirms the 95th-percentile hemolysis index prediction (0.0078) remains below the clinical threshold (0.012) with adequate margin. The compound risk profile — model form uncertainty combined with the absence of UQ documentation on the secondary in-vitro validation result — was discussed by the panel; the team judged that the conservative error direction and the primary result UQ coverage provide sufficient compensating assurance for acceptance at Low assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
