  "signature": "ed25519:b7e2a1f3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented verification test suite with pass/fail records; version-controlled source; formal release process with regression testing.",
      "rationale": "ANSYS Fluent 2023 R1 used under FDA-recognized software quality management plan. Full regression suite of 312 benchmark cases executed at release; all pass. Version control via Git with signed commits. Software validation report archived in QMS. Achieved level 4 meets required level 4 for MRL 5 Class III device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or analytical benchmark comparison demonstrating second-order spatial convergence for governing equations used in hemolysis prediction.",
      "rationale": "Method of manufactured solutions applied to the SST k-omega turbulence model and power-law hemolysis transport equation. Observed order of accuracy 1.97 ± 0.08 across three mesh refinements, consistent with second-order discretization. Benchmark results archived and independently reproduced by a second analyst."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI below 5% for all primary QoIs on the production mesh; Richardson extrapolation performed on at least three systematically refined meshes.",
      "rationale": "Three meshes (1.2 M, 4.8 M, 19.2 M cells) used. GCI for NIH: 2.8%; GCI for peak WSS: 3.1%; GCI for volute exit pressure: 1.4%. All below 5% threshold. Production mesh is the 4.8 M cell intermediate mesh, providing balance between accuracy and computational cost for Monte Carlo ensemble runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate COU operating envelope within ±5% for flow rate, rotational speed, and fluid temperature; hematocrit controlled to physiological range.",
      "rationale": "In-vitro experiments conducted at 37 °C ± 0.5 °C, hematocrit 33 ± 2%, flow rates 3–6 L/min ± 1.5%, rotational speeds 2400–3600 RPM ± 0.8%. All within specified tolerances. FDA-traceable calibration records provided for all instruments. Test matrix spans full COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error, validation uncertainty) computed for each QoI; comparison must account for both experimental and numerical uncertainty.",
      "rationale": "Validation metric U_val computed per ASME V&V 20 for velocity, NIH, and WSS. Experimental uncertainty U_exp estimated from repeated trials (n=6 per operating point). Numerical uncertainty U_num from GCI. Model form error E = (D - S) compared against U_val = sqrt(U_exp^2 + U_num^2). All QoIs satisfy |E| < U_val at 95% confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validated QoIs must directly correspond to the decision-critical QoIs defined in the COU; hemolysis index must be the primary validated quantity.",
      "rationale": "Primary QoI is NIH (normalized index of hemolysis), which is the direct clinical decision quantity. Secondary QoIs (velocity field, WSS) support mechanistic understanding of hemolysis sources. All three QoIs are validated against experimental data. No surrogate QoI substituted for the clinical endpoint."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid analogue, and operating range as the COU; no geometric simplifications that affect hemolysis prediction pathways.",
      "rationale": "Validation experiments performed on the FDA generic centrifugal pump geometry — identical to the COU device. Porcine blood used as fluid analogue (viscosity matched to human blood at 37 °C). Operating range covers all 5 COU flow-speed combinations. No geometric simplifications applied; full impeller and volute geometry retained in both CFD and experiment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual levels below 1e-6 for all equations; round-off error assessed via double-precision arithmetic confirmation.",
      "rationale": "All simulations run in double precision. Continuity residual converged to 1e-7; momentum to 1e-7; turbulence quantities to 1e-6; hemolysis transport to 1e-8. Convergence monitored via mass imbalance (< 0.01%) and NIH monitor point stabilization over final 500 iterations. No solver divergence events recorded across 2000 Monte Carlo ensemble runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup by a second qualified CFD analyst; documented checklist of boundary condition and model parameter settings.",
      "rationale": "Simulation setup reviewed by a second CFD analyst with 10+ years of cardiovascular device experience. Checklist of 47 setup parameters verified independently. Boundary conditions, turbulence model coefficients, hemolysis model constants, and rotating reference frame settings all confirmed. One minor discrepancy in inlet turbulence intensity specification identified and corrected prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis model form (power-law vs. strain-based) justified by literature review and sensitivity analysis; turbulence model selection justified for rotating machinery at physiological Reynolds numbers.",
      "rationale": "Power-law hemolysis model (Giersiepen et al. modified by Zhang et al.) selected following comparative study against three alternative model forms. SST k-omega turbulence model selected based on published benchmarks for rotating impeller flows at Re 10^4–10^5. Model form sensitivity: ±18% variation in NIH across model forms, documented and propagated into total uncertainty budget. Selected model form produces smallest systematic bias against experimental NIH data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters; distributions justified by experimental characterization or literature; Monte Carlo propagation performed.",
      "rationale": "Seven uncertain inputs identified: blood viscosity (log-normal, CV=8%), pump rotational speed (normal, ±1%), inlet flow rate (normal, ±1.5%), hemolysis model exponent alpha (uniform, ±10%), hemolysis model coefficient C (uniform, ±15%), hematocrit (normal, ±6%), and fluid temperature (normal, ±0.5°C). All distributions justified by experimental measurement or published physiological data. 5000-sample Monte Carlo ensemble executed on the 4.8 M cell production mesh."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum 3 independent experimental replicates per operating point for primary QoI; sample-to-sample variability quantified and reported.",
      "rationale": "Six independent experimental replicates performed at each of the 5 operating points (n=30 total hemolysis measurements). Coefficient of variation across replicates: 4.2–7.8% for NIH, 3.1–5.6% for WSS. Sample variability incorporated into experimental uncertainty estimate U_exp. Fresh blood samples used for each replicate to avoid hemolysis pre-conditioning artifacts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary conditions must be set to match experimentally measured inlet conditions; any discrepancies between simulation inputs and experimental conditions must be quantified and their effect on QoIs bounded.",
      "rationale": "Inlet velocity profiles extracted from PIV measurements at the pump inlet plane and prescribed as CFD boundary conditions via radial profile interpolation. Outlet pressure set to time-averaged experimental measurement. Rotational speed set to tachometer-measured value ± 0.8%. Residual discrepancies in inlet turbulence intensity (CFD: 5% assumed; experimental: not directly measured) assessed via sensitivity run showing < 2% effect on NIH — within numerical uncertainty band."
    }
  ],
