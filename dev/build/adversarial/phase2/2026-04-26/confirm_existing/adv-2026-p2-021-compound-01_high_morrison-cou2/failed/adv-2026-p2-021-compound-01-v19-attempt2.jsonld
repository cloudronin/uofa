  "synthetic": true,
  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/vad-cfd-hemolysis-prediction-claim",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental-piv",
    "https://uofa.net/synth/data/fda-generic-pump-hemolysis-bench"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-piv-velocity-field",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 2500 RPM, 5 L/min",
      "description": "Particle image velocimetry (PIV) measurements in the FDA generic centrifugal pump at the nominal VAD operating point. CFD velocity magnitudes compared against experimental PIV maps across 12 cross-sectional planes. Mean absolute error 4.2% of bulk velocity; 95th-percentile error 11.7%. Mesh sensitivity study performed (three mesh levels, GCI < 2%). Turbulence model: SST k-omega. Boundary conditions matched to experimental rig within 0.5%.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/uq-piv-velocity",
        "type": "UncertaintyQuantification",
        "method": "Grid Convergence Index (GCI) and experimental measurement uncertainty propagation",
        "coverageProbability": 0.95,
        "description": "Monte Carlo propagation of inlet boundary condition variability (flow rate ±2%, rotational speed ±10 RPM) combined with GCI-based discretization uncertainty. Combined expanded uncertainty on velocity magnitude: ±6.1% at 95% coverage."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index",
      "type": "ValidationResult",
      "name": "Normalized index of hemolysis (NIH) prediction vs bench measurement",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro hemolysis measurements across 5 flow-speed operating points. Power-law hemolysis model (Giersiepen-Wurzinger) applied to Lagrangian particle trajectories. Predicted NIH values range 0.0031–0.0089 g/100 L; measured values 0.0028–0.0095 g/100 L. Relative error within 18% at all points. Stress-exposure integration performed over 10 000 particle tracks per operating condition. Laminar sublayer resolved (y+ < 1 on all wetted surfaces)."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-head",
      "type": "ValidationResult",
      "name": "Pump pressure-head HQ curve validation",
      "description": "CFD-predicted pump head compared against experimental HQ curve measurements across 7 flow rates at 2500 RPM. Predicted head within 3.8% of measured values across the full operating range. Steady-state frozen-rotor interface used; transient sliding-mesh sensitivity check performed at design point (difference < 1.5%). Validation supports confidence in overall flow-field fidelity as prerequisite for hemolysis pathway accuracy.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/uq-pressure-head",
        "type": "UncertaintyQuantification",
        "method": "Experimental uncertainty propagation and CFD numerical uncertainty",
        "coverageProbability": 0.95,
        "description": "Experimental pressure transducer uncertainty (±0.5% FS) combined with GCI-based numerical uncertainty (GCI < 1.8%). Combined uncertainty on predicted head: ±4.3% at 95% coverage probability."
      }
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042689",
