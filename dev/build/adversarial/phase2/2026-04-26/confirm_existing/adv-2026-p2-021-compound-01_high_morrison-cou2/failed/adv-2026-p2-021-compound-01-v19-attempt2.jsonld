  "hash": "sha256:a3f8c1d2e7b04596f1a2d3c4e5f6a7b8c9d0e1f2a3b4c5d6e7f8091a2b3c4d5",
  "signature": "ed25519:b7e2a4f1c3d5e8091b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8091a2b3c4d5e6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite with traceability to ASME-VV40 requirements; configuration management system must log all solver version changes.",
      "rationale": "ANSYS Fluent 2023R1 used with documented release notes and regression test suite. However, project-level configuration management log does not capture mid-project patch update (23.1.1 to 23.1.2); traceability gap prevents full Gradation 4 credit. Achieved Gradation 3 (solver has institutional V&V suite but project CM incomplete)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent code verification for all governing equation terms relevant to hemolysis transport, including scalar transport for hemolysis power-law model.",
      "rationale": "MMS verification completed for Navier-Stokes solver (published ANSYS verification manual). Scalar transport verification for the user-defined hemolysis source term was performed in-house on a 2D Couette flow benchmark but not against an independent MMS solution. Gradation 3 achieved; Gradation 4 requires independent MMS for UDF."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with at least three systematically refined meshes; GCI < 2% on hemolysis index QoI; y+ < 1 on all blood-contacting surfaces.",
      "rationale": "Three-level mesh refinement performed (6M, 18M, 54M cells). GCI on NIH = 1.7% (meets threshold). y+ < 1 confirmed on impeller and volute surfaces. Richardson extrapolation applied. Achieved Gradation 3 because oscillatory convergence observed at one off-design operating point (4 L/min, 2000 RPM); GCI undefined at that point and conservatively excluded from formal GCI statement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within stated tolerances; blood analog fluid properties must be documented with traceability to lot certificates.",
      "rationale": "Glycerin-water blood analog used at 37°C with viscosity 3.5 mPa·s (±0.1). Flow rates and rotational speeds matched to COU envelope for 4 of 5 operating points. Fifth point (6 L/min, 3000 RPM) tested at 35°C due to rig thermal drift; temperature correction applied analytically. Lot certificate for glycerin available; water purity certificate not retained. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed for all QoIs; metric must account for both numerical and experimental uncertainty.",
      "rationale": "Validation metric computed per ASME V&V 20 for velocity field (E% = 4.2%) and pump head (E% = 3.8%). For NIH, relative error computed but combined uncertainty interval not formally propagated through hemolysis model (experimental hemolysis uncertainty estimated at ±15% but not combined with CFD numerical uncertainty in a single metric). Gradation 3 achieved; Gradation 4 requires full combined uncertainty metric on NIH."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must include the primary clinical surrogate (NIH) and at least one intermediate flow-field QoI (velocity, pressure) that is mechanistically linked to hemolysis prediction.",
      "rationale": "Validation QoIs include NIH (primary clinical surrogate), velocity field (PIV comparison), and pump head (HQ curve). NIH is the direct regulatory QoI for hemolysis assessment. Velocity field provides mechanistic linkage: shear stress distributions driving hemolysis model are derived from the same velocity solutions validated against PIV. Full Gradation 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use a geometry representative of the COU device; operating conditions must span the COU envelope; patient population variability (hematocrit, viscosity) must be addressed.",
      "rationale": "FDA generic centrifugal pump geometry used for validation; COU device is a proprietary design with similar specific speed and impeller topology. Geometric similarity documented (specific speed within 8%). Operating conditions cover 4 of 5 COU points directly. Hematocrit variability (35–45%) not addressed in validation experiments; only single blood-analog viscosity tested. Gradation 3 achieved; patient population variability gap prevents Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to at least 10^-5 for all residuals; round-off error assessed for double-precision arithmetic.",
      "rationale": "Double-precision arithmetic confirmed. Continuity residual converges to 10^-4 at all operating points; momentum and turbulence residuals reach 10^-5. Continuity residual does not reach 10^-5 target due to complex impeller-volute interface; mass imbalance < 0.01% accepted as engineering criterion. Gradation 2 achieved; Gradation 3 requires all residuals at 10^-5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition specification documented with traceability to COU requirements document.",
      "rationale": "Boundary conditions documented in simulation plan traceable to COU requirements. Independent analyst review performed for 3 of 5 operating points; remaining 2 points reviewed only by primary analyst due to schedule constraints. Gradation 2 achieved; Gradation 3 requires independent review of all operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis power-law model constants must be justified for the specific blood analog and shear exposure regime; turbulence model selection must be validated for rotating machinery hemolysis applications.",
      "rationale": "Giersiepen-Wurzinger power-law constants used without re-calibration to current blood analog lot. Literature survey identifies three alternative constant sets with up to 40% variation in predicted NIH. SST k-omega selected based on general rotating machinery guidance; no hemolysis-specific turbulence model sensitivity study performed. Significant model form uncertainty unquantified. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis on all uncertain model inputs (fluid properties, hemolysis model constants, boundary conditions) with contribution ranking; inputs must be traceable to measurement data with stated uncertainty.",
      "rationale": "Model input uncertainty not formally assessed at MRL 5. Blood viscosity and density assumed nominal; hemolysis model constants taken from 1990 literature without uncertainty bounds. No sensitivity analysis or parameter ranking performed. Monte Carlo UQ applied only to boundary conditions (flow rate, speed), not to constitutive model parameters. Flagged as epistemic gap; Gradation 2 assigned by default for partial documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize measurement variability; statistical power analysis to justify sample size for hemolysis index comparison.",
      "rationale": "Hemolysis experiments performed with n=3 replicates per operating point. No statistical power analysis performed to justify n=3 for the required precision on NIH comparison. Coefficient of variation across replicates ranges 8–22%, suggesting higher n required for Gradation 3. Flagged as gap; Gradation 2 assigned."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between validation experiment input parameters and COU input parameters; any differences quantified and their impact on QoI assessed via sensitivity analysis.",
      "rationale": "Formal equivalency mapping not performed. FDA generic pump geometry used for validation differs from proprietary COU device; no quantitative assessment of geometric dissimilarity impact on hemolysis prediction. Blood analog viscosity differs from physiological range expected in VAD patients (hematocrit 35–45%); impact not assessed. Epistemic gap at MRL 5; Gradation 2 assigned."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou2-vad-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the overall evidence package is judged sufficient for regulatory submission under a risk-managed framework. The two highest-weighted factors (Relevance of QoI, Discretization Error) meet or approach required levels. Remaining gaps are documented as epistemic uncertainties with compensating controls: (1) conservative hemolysis threshold applied (50% below clinical limit); (2) post-market surveillance plan includes hemolysis monitoring at 3 and 12 months. Monte Carlo UQ on boundary conditions bounds prediction uncertainty for the primary NIH QoI. Assessment team accepts residual model form uncertainty as bounded by literature sensitivity range.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
