  "name": "Morrison COU2 — VAD hemolysis credibility assessment (COMPOUND-01 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed on selected factors but one validation result intentionally omits the hasUncertaintyQuantification field (W-AL-01, High). The bound claim carries no prov:wasDerivedFrom provenance link (W-EP-01, Critical). Both defects coexist on this single UnitOfAssurance, triggering COMPOUND-01.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-absolute-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-dataset-2022",
    "https://uofa.net/synth/data/fda-pump-hemolysis-experimental-2021"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — centrifugal pump impeller region",
      "description": "Particle image velocimetry (PIV) measurements acquired at 5 operating points (3–6 L/min, 2400–3600 RPM) were compared against CFD-predicted velocity fields in the impeller and volute regions. Normalized root-mean-square error across all planes was 8.3%. Uncertainty quantification via Monte Carlo propagation of boundary-condition variability was performed; 95th-percentile prediction interval reported.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/piv-monte-carlo-bc-variability",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo",
        "description": "500-sample Monte Carlo propagation of inlet flow-rate (±3%) and rotational speed (±0.5%) uncertainties through the CFD solver. Output: 95th-percentile confidence interval on normalized velocity RMSE.",
        "coverageProbability": 0.95
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index absolute-level validation — 5 operating conditions",
      "description": "Predicted normalized index of hemolysis (NIH) values from the CFD model were compared against in-vitro hemolysis measurements obtained using the ASTM F1841 protocol across 5 flow-speed combinations. Mean absolute percentage error was 14.7%; all predictions fell within the expanded measurement uncertainty band of the experimental data. Model systematically under-predicts NIH at high shear (6 L/min, 3600 RPM) by approximately 11%, attributed to limitations of the power-law hemolysis constitutive model. Validation accepted at required credibility level for this factor."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4054944",
  "wasAttributedTo": "https://uofa.net/synth/org/fda-cdrh-osel-dbdm",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e4b7d09e6f2a1b3c5d7e9f0a2b4c6d8e0f1a3b5c7d9e1f3a5b7c9d1e3f",
  "signature": "ed25519:9b2e4f6a8c0d2e4f6a8c0d2e4f6a8c0d2e4f6a8c0d2e4f6a8c0d2e4f6a8c0d2e",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under formal configuration management with documented verification test suite passing at release. All user-accessible scripts version-controlled.",
      "rationale": "ANSYS Fluent 2023 R1 deployed under FDA CDRH software quality system. Full regression test suite (1,847 cases) executed and passed. All case setup scripts archived in Git repository with SHA-256 checksums. SQA level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for all governing equations using manufactured solutions; convergence rate within 10% of formal order.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes and scalar transport equations. Observed convergence order 1.87 vs. formal order 2.0 for momentum; 1.74 vs. 2.0 for hemolysis scalar — within 13% of formal order. Achieved level 3 due to marginal deviation in scalar convergence; required level 4 not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based Grid Convergence Index (GCI) below 5% for NIH quantity of interest on at least three systematically refined meshes.",
      "rationale": "Three-mesh Richardson extrapolation performed: coarse (4.2M cells), medium (12.1M cells), fine (31.8M cells). GCI for NIH at design point: 7.2% — exceeds 5% threshold. Achieved level 3. Mesh refinement constrained by available HPC allocation; further refinement deferred."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be measured with calibrated instruments and reported with expanded uncertainty.",
      "rationale": "All test conditions measured with NIST-traceable instruments. Flow rate: Coriolis meter (±0.5% FS). Speed: optical tachometer (±2 RPM). Temperature: PT100 (±0.1°C). Hematocrit: centrifuge method (±1%). Expanded uncertainties (k=2) reported in test report TR-2021-047. Level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or MAPE) computed for all QoIs with statistical significance test; model error must be within expanded experimental uncertainty for at least 80% of test cases.",
      "rationale": "MAPE for NIH: 14.7% across 5 operating points. Model error falls within expanded experimental uncertainty (k=2) for 3 of 5 cases (60%), below the 80% threshold. Systematic over-prediction at high shear attributed to constitutive model limitation. Achieved level 3; required level 4 not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, velocity field) must be directly traceable to the clinical decision metric (absolute hemolysis threshold); surrogate QoIs require documented bridging argument.",
      "rationale": "NIH is the primary clinical QoI and is directly compared. Velocity field serves as surrogate QoI with bridging argument: wall shear stress integrates to NIH via power-law model. Bridging argument documented in analysis plan AP-COU2-003. Achieved level 4; level 5 would require prospective clinical correlation data not available at this stage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry, at COU operating conditions, with COU-representative fluid. Deviations require documented similarity arguments.",
      "rationale": "Validation used FDA generic pump geometry (identical to COU geometry). Operating conditions span COU range (3–6 L/min, 2400–3600 RPM). Fluid: porcine blood at 37°C (COU uses human blood); similarity argument documented noting comparable rheology. Achieved level 3 due to species difference in blood rheology; level 5 requires human blood or validated equivalence study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual levels below 1e-6 for all equations; mass imbalance below 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6 (continuity, momentum, k, omega, scalar). Mass imbalance: 0.003% at worst case. Convergence monitored via NIH monitor point stabilization over final 500 iterations. Level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent qualified analyst; checklist completed and signed.",
      "rationale": "Independent review performed by senior CFD engineer (not involved in model development) using FDA internal checklist CL-CFD-007. All 42 checklist items verified. No use errors identified. Level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified by benchmark studies on representative geometries; sensitivity of NIH to model form documented.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark studies on centrifugal pump geometries (Hariharan et al. 2011). Power-law hemolysis model (Giersiepen et al.) selected; known to under-predict at high shear. Model form sensitivity study conducted: NIH varies ±18% across three constitutive models. Achieved level 3; level 5 requires model form uncertainty to be below 5%, not achievable with current hemolysis models."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, BCs, material properties) documented with sources and uncertainties; CAD-to-mesh fidelity verified.",
      "rationale": "Geometry sourced from FDA generic pump STL file (revision 3.1, publicly available). Mesh generated from CAD with maximum surface deviation 0.02 mm verified by GeoMagic inspection. Blood viscosity: Carreau-Yasuda fit to published rheometry data (uncertainty ±4%). All inputs tabulated in input data record IDR-COU2-2022. Level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum 3 independent blood samples per operating condition; sample-to-sample variability characterized and reported.",
      "rationale": "Three independent porcine blood draws used per operating condition (n=3). Sample-to-sample coefficient of variation in NIH: 8.2% (acceptable). However, only a single experimental run per sample was performed due to blood volume constraints; ASTM F1841 recommends duplicate runs. Achieved level 3; level 4 requires duplicate runs per sample."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary conditions must match experimental conditions within combined measurement uncertainty; deviations must be quantified and their effect on QoI assessed.",
      "rationale": "Inlet flow rates matched to within 1.2% of experimental values (within measurement uncertainty). Rotational speed matched to within 5 RPM. Fluid temperature deviation: CFD uses 37°C isothermal; experiments ranged 36.5–38.1°C. Temperature sensitivity study shows ±0.3% effect on NIH per degree — acceptable. Hematocrit: CFD uses 33% (mean of samples); individual samples ranged 31–36%. Effect on NIH: ±2.1%. Achieved level 3 due to hematocrit spread; level 4 requires tighter control or explicit uncertainty propagation for all deviations."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required (numerical code verification, discretization error, output comparison, relevance of validation activities, model form, test samples, equivalency of input parameters), the overall credibility evidence package is accepted for the intended regulatory submission stage. The compound shortfalls are acknowledged as epistemic gaps at MRL 5; compensating controls include independent reviewer sign-off, Monte Carlo uncertainty quantification on primary validation result, and conservative safety margins applied to the NIH acceptance threshold. The assessment team concludes that the evidence is sufficient to support a low-assurance decision at this development stage, with commitments to address discretization error and model form uncertainty in the next submission cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
