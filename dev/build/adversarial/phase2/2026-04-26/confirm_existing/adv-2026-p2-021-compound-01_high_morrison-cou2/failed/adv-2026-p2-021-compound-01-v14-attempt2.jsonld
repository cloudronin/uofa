  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-absolute",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-dataset",
    "https://uofa.net/synth/data/hemolysis-experimental-mrl5"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-piv-velocity-fields",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic pump",
      "description": "Particle image velocimetry (PIV) measurements of the FDA generic centrifugal pump were compared against CFD-predicted velocity fields at three operating points. Agreement assessed via GCI-based discretization error bounds. Mean normalized RMS error across planes: 8.3%. Validation activities conducted under controlled in-vitro conditions replicating VAD operating envelope.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-piv-gci",
        "type": "UncertaintyQuantification",
        "method": "Grid Convergence Index (GCI) on three systematically refined meshes; experimental PIV uncertainty estimated via cross-correlation bias correction.",
        "coverageProbability": 0.95
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-absolute",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index prediction vs. in-vitro NIH measurements",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared to in-vitro measurements across five flow-speed combinations spanning the VAD operating envelope. The power-law hemolysis model (Giersiepen-Wurzinger coefficients) was applied to Lagrangian particle tracks. Predicted NIH values fell within 22% of measured values at 4 of 5 operating points; one outlier at high shear exhibited 41% over-prediction. Validation dataset comprises 15 independent pump units tested per ASTM F1841.",
      "description2": "NOTE: No uncertainty quantification record is attached to this result. Monte Carlo sensitivity runs were conducted internally but outputs were not formally archived as a UQ object prior to package assembly."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-head",
      "type": "ValidationResult",
      "name": "Pump pressure-head curve validation",
      "description": "Simulated H-Q curves compared against manufacturer bench-test data at five rotational speeds. CFD predictions within 5% of measured head at design point; off-design deviation up to 11%. Uncertainty quantification via Monte Carlo propagation of inlet boundary condition variability (flow rate ±3%, fluid viscosity ±2%).",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-hq-montecarlo",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo propagation (N=2000 samples) over inlet flow rate and blood viscosity distributions; 95th-percentile prediction interval reported.",
        "coverageProbability": 0.95
      }
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a documented QMS with regression test suite covering hemolysis-relevant solver modules; version control with full audit trail required at MRL 5.",
      "rationale": "Solver (ANSYS Fluent 2023 R1) operates under ISO 9001 QMS with documented regression suite. However, the hemolysis-specific UDF (user-defined function) for power-law damage accumulation lacks an independent unit-test record. Achieved level 3 reflects partial QA coverage; required level 4 is not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) or equivalent for all governing equation terms including turbulence closure used in hemolysis prediction.",
      "rationale": "MMS verification performed for Navier-Stokes core; SST k-omega turbulence model verified against canonical channel flow. Hemolysis UDF transport equation not independently verified via MMS. Achieved level 3; gap to required level 4 documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based mesh convergence study on at least three systematically refined meshes; GCI < 5% on hemolysis QoI required at MRL 5.",
      "rationale": "Three-mesh GCI study completed (coarse: 4.2M cells, medium: 12.1M, fine: 31.7M). GCI on NIH QoI: 9.4% — exceeds the 5% threshold. Achieved level 3 reflects acceptable convergence trend but unmet GCI target."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope within ±5% of target flow-speed combinations; fluid temperature, hematocrit, and anticoagulation protocol documented.",
      "rationale": "In-vitro tests conducted with bovine blood at 37°C, hematocrit 33±2%, heparin anticoagulation per ASTM F1841. Flow rate control within ±3.1%. Temperature drift ±0.8°C across test duration. Hematocrit variability slightly exceeds the ±2% target at two test points. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel, validation metric M) must be computed with uncertainty bounds; comparison must demonstrate model adequacy within defined tolerance for all 5 operating points.",
      "rationale": "Relative error E_rel computed at all 5 operating points. Four points within 22% tolerance; one high-shear outlier at 41%. Validation metric M computed without full experimental uncertainty propagation. Achieved level 2 due to outlier and incomplete uncertainty budget in comparison metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the regulatory submission QoI (absolute NIH); surrogate QoIs require demonstrated correlation with NIH at MRL 5.",
      "rationale": "Primary validation QoI is NIH — directly matching the regulatory submission QoI. Secondary QoIs (velocity fields, pressure head) are relevant surrogates with demonstrated physical coupling. Relevance is high but surrogate-to-NIH correlation is empirical rather than analytically derived. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the target device geometry (FDA generic pump) under the target operating conditions (VAD envelope); no surrogate geometry substitution permitted at MRL 5.",
      "rationale": "Validation conducted on FDA generic centrifugal pump geometry — the reference geometry for this COU. Operating conditions span the VAD envelope. However, validation fluid is bovine blood rather than human blood; rheological differences introduce unquantified extrapolation uncertainty. Achieved level 3; gap to required level 5 is the largest in the assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual < 1e-5 for all equations; round-off error assessment for double-precision arithmetic on hemolysis UDF.",
      "rationale": "Continuity residual converges to 1e-4 (one order above target); momentum and turbulence equations reach 1e-6. Hemolysis UDF accumulation exhibits staircase artifact at low shear rates attributed to insufficient sub-iteration count. Double-precision confirmed. Achieved level 2 due to continuity residual shortfall and UDF artifact."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of boundary condition setup, material property assignment, and post-processing scripts; error log reviewed.",
      "rationale": "Simulation workflow documented in internal technical report TR-2024-07. Independent peer review conducted by second analyst; one boundary condition discrepancy (outlet pressure specification) identified and corrected post-review. Post-processing scripts not independently verified. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty must be quantified via comparison of at least two turbulence closures and two hemolysis damage models; sensitivity of NIH prediction to model form documented.",
      "rationale": "Model form assessment not completed. Single turbulence closure (SST k-omega) and single hemolysis model (Giersiepen-Wurzinger) used throughout. No alternative model form comparisons conducted. Flagged as epistemic gap at MRL 5. Achieved level 1 (not assessed)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis of NIH output to all model input parameters (fluid properties, boundary conditions, hemolysis model coefficients); Sobol indices or equivalent global sensitivity measure required at MRL 5.",
      "rationale": "Global sensitivity analysis not performed. Local one-at-a-time sensitivity conducted for three parameters (viscosity, inlet velocity, hemolysis exponent) but Sobol indices not computed. Epistemic gap flagged. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample population; inter-unit variability in hemolysis measurements across ≥10 pump units documented with confidence intervals.",
      "rationale": "Hemolysis measurements available from 15 pump units per ASTM F1841 but inter-unit variability analysis not formally conducted. Raw data archived; statistical reduction not completed. Epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency demonstration that simulation input parameters (geometry, operating conditions, fluid properties) match experimental conditions within defined tolerances; traceability matrix required.",
      "rationale": "Traceability matrix between simulation inputs and experimental conditions not produced. Geometry equivalency assumed from CAD-to-mesh pipeline without formal dimensional verification against physical test article. Epistemic gap. Achieved level 1."
    }
  ],
