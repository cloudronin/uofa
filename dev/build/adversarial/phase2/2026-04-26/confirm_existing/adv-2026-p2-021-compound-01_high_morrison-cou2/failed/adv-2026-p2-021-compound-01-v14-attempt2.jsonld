  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team determined that the weight of evidence from PIV velocity validation, pressure-head curve agreement, and documented GCI convergence trends is sufficient to support conditional acceptance for regulatory submission. Residual gaps in model form, model inputs, test samples, and equivalency of input parameters are acknowledged as epistemic limitations to be addressed in subsequent assessment cycles. The hemolysis absolute NIH predictions at 4 of 5 operating points within 22% of measured values, combined with conservative clinical safety margins applied by the sponsor, support a conditional Accepted decision pending completion of the outstanding epistemic gap analyses.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
