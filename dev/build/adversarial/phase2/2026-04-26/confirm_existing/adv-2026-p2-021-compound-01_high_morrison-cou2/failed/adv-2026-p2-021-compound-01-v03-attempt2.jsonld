  "conformsToProfile": "https://uofa.net/vocab#ProfileComplete",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed on selected validation results but not uniformly applied. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Accepted pending post-market surveillance.",
  "assuranceLevel": "Low",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "couName": "VAD use",
  "decision": "Accepted",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-prediction",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-measurements",
    "https://uofa.net/synth/data/hemolysis-index-experimental-runs",
    "https://uofa.net/synth/data/monte-carlo-uq-samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-01-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis Index Comparison — 5 Operating Points",
      "description": "Computational hemolysis index (HI) predictions compared against in-vitro measurements at 5 flow-speed combinations. Normalized index of hemolysis (NIH) computed from lysed RBC counts. Mean absolute error across operating points is 0.0031 g/100L. Monte Carlo UQ with 1000 samples applied; 95% prediction interval bounds reported for each operating condition.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/mc-hemolysis-1000-samples",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo",
        "sampleCount": 1000,
        "confidenceLevel": 0.95,
        "description": "Monte Carlo sampling over inlet velocity boundary condition uncertainty (±3%), fluid viscosity (±2%), and power-law hemolysis model coefficient k (±8%). Sensitivity indices computed via Sobol decomposition."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-02-velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity Field Validation Against PIV Measurements",
      "description": "Time-averaged velocity magnitude and turbulent kinetic energy fields compared against particle image velocimetry (PIV) data collected on the FDA generic centrifugal pump benchmark geometry. Validation performed at 2500 RPM, 6 L/min operating condition. Spatially averaged L2-norm error in velocity magnitude is 4.7% across 1,847 measurement points in the impeller passage and volute. Turbulent kinetic energy agreement within 12% in the bulk flow region; elevated discrepancy (up to 31%) observed near blade trailing edge due to unresolved secondary flow structures at the RANS closure level.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/piv-measurement-uncertainty",
        "type": "UncertaintyQuantification",
        "method": "GUM propagation",
        "description": "Measurement uncertainty for PIV data estimated via GUM (Guide to the Expression of Uncertainty in Measurement). Systematic bias from seeding particle lag estimated at 0.8% of peak velocity. Random uncertainty from cross-correlation peak fitting estimated at 1.1% of peak velocity. Combined standard uncertainty reported per spatial location."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-03-pressure-head-curve",
      "type": "ValidationResult",
      "name": "Pump Pressure-Head Curve Validation",
      "description": "Predicted pump pressure rise (ΔP) versus flow rate curve compared against bench-top hydraulic measurements across 8 operating points from 3 L/min to 8 L/min at 2500 RPM. Maximum deviation between CFD prediction and experimental measurement is 4.2 mmHg (5.1% relative error) at the lowest flow rate; agreement improves to 1.8% at the design point. Validation supports confidence in the bulk flow field predictions that underlie the hemolysis transport model."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-04-wall-shear-stress-distribution",
      "type": "ValidationResult",
      "name": "Wall Shear Stress Distribution — Blade Surface",
      "description": "Wall shear stress (WSS) magnitude on impeller blade pressure and suction surfaces compared against micro-pillar sensor array measurements from the FDA pump benchmark dataset. Area-averaged WSS on the pressure surface agrees within 9.3%; suction surface agreement is 14.7%, with local hotspots near the blade leading edge showing up to 22% overprediction attributed to RANS eddy-viscosity limitations in regions of adverse pressure gradient. WSS is a primary driver of the power-law hemolysis model; elevated WSS overprediction introduces conservative bias in hemolysis index predictions.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/wss-sensor-uncertainty",
        "type": "UncertaintyQuantification",
        "method": "Calibration-based propagation",
        "description": "Micro-pillar sensor calibration uncertainty of ±6% (k=2 coverage factor) propagated through WSS extraction. CFD numerical uncertainty from mesh refinement study (Richardson extrapolation, GCI < 2.1%) added in quadrature with sensor uncertainty to yield combined expanded uncertainty of ±7.8% on area-averaged WSS."
      }
    }
  ],
