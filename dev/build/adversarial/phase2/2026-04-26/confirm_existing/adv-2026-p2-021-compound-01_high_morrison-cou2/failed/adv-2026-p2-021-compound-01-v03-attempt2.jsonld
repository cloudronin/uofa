  "hash": "sha256:a3f8c2d14e7b905f6c3a1d82e4f0b7c9d5e2a1f8b4c6d3e9a0f7b2c5d8e1a4f6",
  "signature": "ed25519:b7e3a1c9d4f2b08e5c7a3d1f9b4e6c2a8d5f1b3e7c9a2d4f6b0e8c3a5d7f2b1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation and post-processing must be validated under a quality management system with documented version control, regression testing, and change control procedures consistent with MRL 5 requirements.",
      "rationale": "ANSYS Fluent 2023 R1 is used under an ISO 9001-certified QMS with documented version control. Regression test suite covers 847 canonical cases. However, the in-house hemolysis post-processing script lacks formal V&V documentation and has not undergone independent code review, limiting the achieved level to Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions or manufactured solutions for all governing equation terms relevant to the hemolysis transport model, including advection-diffusion of the hemolysis scalar and turbulence model terms.",
      "rationale": "Method of Manufactured Solutions (MMS) applied to the Navier-Stokes solver and scalar transport equation. Observed order of accuracy (1.97) consistent with second-order spatial discretization. MMS not applied to the hemolysis power-law source term implementation; this gap reduces achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Spatial and temporal discretization errors must be quantified using Richardson extrapolation or equivalent method. Grid Convergence Index (GCI) must be reported for all quantities of interest. Achieved level requires GCI < 5% on primary QoI.",
      "rationale": "Three-level mesh refinement study performed (3.2M, 9.7M, 28.4M cells). GCI on hemolysis index is 3.8% (fine-to-medium) and 7.1% (medium-to-coarse). Temporal convergence confirmed with 2° impeller rotation per time step. GCI on WSS hotspot regions exceeds 5% threshold at blade trailing edge, preventing achievement of Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to replicate in the computational model. Working fluid properties, rotational speed, inlet/outlet boundary conditions, and temperature must be characterized with measurement uncertainty reported.",
      "rationale": "Test conditions documented per FDA pump benchmark protocol. Blood analog fluid (36% glycerol-water) properties measured at 37°C ± 0.5°C. Rotational speed controlled to ±5 RPM. Inlet turbulence intensity estimated from upstream pipe flow correlation rather than direct measurement, introducing uncharacterized uncertainty that limits achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics must be defined a priori. Validation metric must account for both experimental measurement uncertainty and numerical prediction uncertainty. Agreement criterion must be specified before comparison is performed.",
      "rationale": "Validation metric defined as normalized root-mean-square error (NRMSE) on hemolysis index across 5 operating points. A priori acceptance threshold set at NRMSE < 15%. Achieved NRMSE is 11.3%. However, the comparison does not formally account for model-form uncertainty in the power-law hemolysis exponent, which is treated as a fixed parameter rather than a calibrated uncertainty source."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation activities must be directly relevant to the clinical decision quantity (absolute hemolysis index). Surrogate quantities must have demonstrated mechanistic linkage to the primary QoI.",
      "rationale": "Hemolysis index is the primary QoI and is directly measured in validation experiments. Velocity field and WSS are validated as intermediate quantities with documented mechanistic linkage to the power-law hemolysis model. Pressure-head curve validates bulk flow field. All four validation QoIs are clinically relevant. Minor gap: platelet activation potential, which shares the same shear-stress pathway, is not separately validated, preventing achievement of Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed at conditions sufficiently close to the COU operating envelope. Geometric similarity, Reynolds number similarity, and hemolytic stress similarity must be demonstrated or justified.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry, which differs from the proprietary VAD impeller geometry used in the COU. Geometric similarity is approximate (similar specific speed, different blade count and sweep angle). Reynolds number range overlaps for 3 of 5 COU operating points. Hemolytic stress levels in validation experiments bracket the COU range. The geometric dissimilarity is the primary factor limiting achieved level to 3 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence errors must be quantified and demonstrated to be negligible relative to discretization errors. Residual convergence criteria must be specified and achieved for all transported quantities including the hemolysis scalar.",
      "rationale": "Iterative convergence monitoring not formally documented for the hemolysis scalar transport equation. Mass, momentum, and turbulence residuals reach 1e-5 as specified, but hemolysis scalar residual convergence criterion was not defined a priori. This factor is flagged as not-assessed due to the missing scalar convergence documentation, representing an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-introduced error in model setup, boundary condition specification, and post-processing must be assessed. Independent verification of model setup by a second qualified analyst is required at MRL 5.",
      "rationale": "Independent verification of CFD model setup has not been performed. Boundary condition specification and mesh generation were performed by a single analyst without peer review of setup files. Post-processing scripts were not independently verified. This factor is flagged as not-assessed; independent review is planned for the next submission cycle."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty arising from turbulence closure selection and hemolysis constitutive law must be quantified. Alternative model forms must be evaluated or justified as not applicable. Sensitivity of hemolysis predictions to model form choices must be reported.",
      "rationale": "k-ω SST turbulence model selected based on prior literature consensus for rotating machinery. No alternative turbulence model comparison (e.g., RSM, LES) has been performed. Power-law hemolysis model (Giersiepen-Wurzinger) selected without comparison to alternative constitutive laws (Arora, Goubergrits). Model form uncertainty is unquantified and this factor is flagged as not-assessed at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters must be characterized and propagated through the model. Input parameters include fluid properties, rotational speed, inlet flow conditions, and hemolysis model coefficients. Sensitivity analysis must identify dominant input uncertainty contributors.",
      "rationale": "Monte Carlo UQ performed over three input parameters (inlet velocity, viscosity, hemolysis model coefficient k). Remaining input parameters including hemolysis model exponent α, RBC mechanical properties, and outlet pressure boundary condition are treated as deterministic. Incomplete input uncertainty characterization limits achieved level to 2; factor flagged as not-assessed pending full input uncertainty inventory."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological variability in test samples (blood analog properties, RBC fragility) must be characterized. Sample-to-sample variability must be quantified and reported as a component of experimental uncertainty.",
      "rationale": "Blood analog fluid (glycerol-water) used in place of human blood. Biological variability in RBC fragility, which is the primary determinant of hemolysis threshold, is not represented in the test sample. Inter-donor variability in hemolysis susceptibility spans approximately one order of magnitude in published literature. This factor is flagged as not-assessed; the use of a blood analog is a known limitation of the benchmark dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the validation model must be demonstrated to be equivalent to or conservative relative to the COU input parameters. Differences in fluid properties, operating conditions, and geometry between validation and COU must be formally assessed.",
      "rationale": "Formal equivalency assessment between validation model inputs and COU inputs has not been performed. Key differences include: (1) blood analog vs. whole blood rheology, (2) FDA generic geometry vs. proprietary VAD geometry, (3) steady-state inlet boundary condition vs. pulsatile VAD operating profile. These differences are acknowledged but have not been quantified in terms of their impact on hemolysis prediction fidelity."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 is accepted with conditions. Seven of thirteen credibility factors have been assessed; all assessed factors show achieved levels below required levels, consistent with the high stringency of MRL 5 for a Class III VAD device. Six factors remain not-assessed and represent epistemic gaps that must be addressed in the next submission cycle. The hemolysis index validation demonstrates NRMSE of 11.3% against the 15% acceptance threshold, and Monte Carlo UQ bounds are reported for primary validation results. The compound gap in model form uncertainty and geometric relevance is acknowledged; post-market surveillance is required to validate hemolysis predictions against clinical hemolysis data within 24 months of device approval. Conditional acceptance is granted based on the adequacy of the assessed factors and the committed remediation plan for not-assessed factors.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
