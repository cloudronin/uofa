    "https://uofa.net/synth/data/fda-pump-piv-dataset-2023",
    "https://uofa.net/synth/data/fda-pump-hemolysis-bench-2022",
    "https://uofa.net/synth/data/vad-operating-conditions-sweep-2023"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-piv-velocity-field-001",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 3500 RPM, 5 L/min",
      "description": "Particle image velocimetry measurements compared against CFD velocity predictions in the impeller region. Systematic grid refinement study performed; Richardson extrapolation applied. Monte Carlo propagation of inlet boundary condition uncertainty performed across 500 samples.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/monte-carlo-piv-001",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo",
        "sampleSize": 500,
        "description": "Monte Carlo UQ propagating inlet velocity and viscosity uncertainty through the CFD solver for velocity field QoI."
      },
      "comparisonMetric": "GCI < 2.1% on velocity magnitude; mean absolute error 4.3% against PIV ensemble"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-bench-002",
      "type": "ValidationResult",
      "name": "Hemolysis index bench validation across 5 operating points",
      "description": "Normalized index of hemolysis (NIH) predicted by the Giersiepen-Wurzinger power-law model embedded in CFD compared against in-vitro measurements at 5 flow-speed combinations. Lagrangian particle tracking used to accumulate scalar stress history. Predictions fall within 18% of measured NIH at 4 of 5 operating points; one outlier at low-flow high-speed condition shows 34% deviation attributed to recirculation zone sensitivity.",
      "comparisonMetric": "Mean NIH error 18%; worst-case 34% at low-flow high-speed condition"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-head-003",
      "type": "ValidationResult",
      "name": "Pump pressure-head curve validation",
      "description": "Hydraulic performance (H-Q curve) validated against manufacturer bench data across full operating envelope. CFD predictions within 5% of measured head at all tested flow rates. Uncertainty quantification performed via Latin hypercube sampling of surface roughness and clearance gap tolerances.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/lhs-pressure-003",
        "type": "UncertaintyQuantification",
        "method": "Latin Hypercube Sampling",
        "sampleSize": 200,
        "description": "LHS propagation of geometric tolerance uncertainty (surface roughness, impeller tip clearance) through hydraulic performance QoI."
      },
      "comparisonMetric": "H-Q error < 5% across operating envelope; 95% CI band within measurement uncertainty"
    }
