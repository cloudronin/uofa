  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite with regression testing and version-controlled releases consistent with MRL 5 requirements.",
      "rationale": "ANSYS Fluent 2023R1 used with documented SQA plan including regression test suite of 847 canonical cases, ISO 9001-certified development process, and traceable release notes. SQA level assessed as Gradation 4 — fully meets MRL 5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include manufactured solution testing and order-of-accuracy confirmation for all active physics modules.",
      "rationale": "Method of manufactured solutions applied to incompressible Navier-Stokes and scalar transport (hemolysis) modules. Observed order of accuracy 1.94 (expected 2.0 for second-order scheme); deviation within acceptable tolerance. Code verification complete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index must be computed on at least three systematically refined meshes; GCI < 5% required on all primary QoI.",
      "rationale": "Three-mesh refinement study performed (4.2M, 11.7M, 28.4M cells). GCI on velocity magnitude 2.1%; GCI on NIH 7.8% — exceeds the 5% threshold due to sensitivity of Lagrangian particle trajectories to near-wall mesh density in the volute tongue region. Achieved level 3 against required level 4; gap documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with traceability to calibrated instrumentation and controlled fluid properties matching COU operating envelope.",
      "rationale": "PIV and NIH bench tests conducted at controlled temperature (37 ± 0.5°C), using bovine blood analog at matched hematocrit (40 ± 2%). Calibration certificates available for all instrumentation. One operating point (low-flow high-speed) tested with substitute fluid due to sample availability; introduces minor test condition mismatch. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics must be computed with uncertainty bounds on both simulation and experimental sides; systematic bias must be characterized.",
      "rationale": "Quantitative comparison performed using E% and GCI-adjusted confidence intervals. Experimental uncertainty estimated via ASME PTC 19.1. Systematic bias of +12% on NIH identified and attributed to power-law model constants calibrated on older RBC data. Bias not corrected in predictions; contributes to achieved level 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation must be the same quantities used in the regulatory submission decision (absolute NIH); surrogate QoI require explicit mapping with uncertainty.",
      "rationale": "Primary QoI is NIH directly compared against clinical threshold. Velocity field used as secondary QoI for mechanistic confidence. Direct correspondence between validation QoI and COU decision QoI established. Minor gap: validation NIH measured at steady-state while COU includes transient ramp-up; transient contribution estimated at <5% of total hemolysis budget. Achieved level 4 vs required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full COU operating envelope including device geometry, fluid properties, and all five target flow-speed combinations.",
      "rationale": "Validation performed on FDA generic pump geometry — same geometry as COU device. All 5 flow-speed combinations tested in bench. Fluid properties matched to clinical VAD operating range. Residual gap: patient-specific blood rheology variability not captured in bench protocol. Achieved level 4 vs required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to machine-precision-appropriate residual levels; round-off error assessed for double-precision arithmetic.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum; mass imbalance < 0.01%. Double-precision arithmetic used throughout. Solver error contribution to total numerical uncertainty estimated at <0.1% via floating-point sensitivity study. Fully meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation workflow must include documented peer review of setup parameters, boundary conditions, and post-processing scripts.",
      "rationale": "Independent peer review of CFD setup performed by second qualified analyst. Boundary condition specification, turbulence model selection (SST k-omega), and Lagrangian tracking parameters reviewed and signed off. Post-processing scripts version-controlled and reviewed. No use errors identified. Meets requirement at level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty must be quantified across plausible alternative model forms for hemolysis prediction; sensitivity to power-law exponent selection documented.",
      "rationale": "Three hemolysis model forms evaluated: Giersiepen-Wurzinger, Taskin, and Fraser power-law variants. NIH predictions vary by up to 40% across model forms at high-shear operating points. SST k-omega selected for turbulence; RANS model form uncertainty not fully characterized for rotating machinery with strong curvature effects. Significant model form uncertainty gap — achieved level 3 vs required level 5. Largest credibility gap in this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty characterization; Monte Carlo or equivalent UQ must propagate input uncertainty to QoI.",
      "rationale": "Monte Carlo UQ performed across 12 uncertain input parameters including inlet velocity profile, blood viscosity, RBC fragility index, and geometric tolerances. Parameter distributions derived from literature and manufacturer specifications. 500-sample Monte Carlo; 95% CI on NIH is ±22% of mean prediction. Input uncertainty fully characterized at level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient experimental replicates must be available to characterize inter-sample variability; minimum n=5 replicates per operating point for NIH measurement.",
      "rationale": "NIH measurements: n=5 replicates at 4 operating points; n=3 replicates at the low-flow high-speed condition due to blood analog availability. PIV: n=1000 image pairs per condition (statistically sufficient). Shortfall at one operating point reduces achieved level to 3 vs required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to experimental conditions; any mismatches must be assessed for impact on QoI.",
      "rationale": "Systematic equivalency assessment performed comparing CFD boundary conditions against measured experimental conditions for all 5 operating points. Temperature, rotational speed, flow rate, and fluid properties matched within measurement uncertainty. No material mismatches identified. Equivalency fully established at level 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Aggregate credibility evidence reviewed across all 13 ASME V&V 40 factors. Seven factors fully meet or exceed requirements; six factors show gaps against MRL 5 requirements, with model form uncertainty representing the largest gap (achieved 3 vs required 5). Monte Carlo UQ on model inputs and hydraulic performance provides quantified uncertainty bounds. The assessment team concludes that the collective evidence, including the favorable H-Q curve validation and velocity field agreement, provides sufficient credibility for the intended regulatory submission, with the model form gap explicitly documented as a limitation for reviewer consideration. Decision: Accepted with documented gaps.",
