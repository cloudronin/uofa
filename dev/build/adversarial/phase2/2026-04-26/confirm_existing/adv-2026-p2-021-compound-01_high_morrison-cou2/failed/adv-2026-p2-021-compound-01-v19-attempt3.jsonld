  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and provide a full verification test suite with documented pass/fail records.",
      "rationale": "The CFD solver holds ISO 9001 certification. A verification test suite of 142 cases is maintained; 7 edge-case failures remain open as known defects. Achieved level 3 because defect closure plan is not yet formally approved, falling one gradation below the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must demonstrate theoretical convergence rate for all governing equations relevant to hemolysis prediction.",
      "rationale": "Order-of-accuracy testing confirms second-order convergence for momentum and continuity. The scalar hemolysis transport equation achieves only first-order convergence on skewed mesh elements near the impeller leading edge, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be below 5% for all quantities of interest on the production mesh.",
      "rationale": "Three-level mesh refinement study performed. GCI for pressure head is 2.1%; GCI for NIH is 8.7% due to shear-stress sensitivity in the gap region. Production mesh GCI exceeds the 5% threshold for the primary QoI, placing achieved level at 3 rather than the required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match COU operating envelope within stated tolerances; fluid properties must be characterised at test temperature.",
      "rationale": "In-vitro tests used bovine blood at 37 °C with viscosity characterised by rheometry. Flow rates controlled to ±0.15 L/min. Rotational speed held to ±15 RPM. Temperature drift of ±1.2 °C observed during long-duration runs; this exceeds the ±0.5 °C tolerance specified for viscosity stability, reducing achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g. E_rms or GCI-normalised error) must demonstrate agreement within validation uncertainty for all QoIs.",
      "rationale": "Velocity field RMS error 8%; pressure head MAE 4.2 mmHg; NIH deviation up to 31% at one operating point. The NIH over-prediction at 5 L/min 2000 RPM exceeds the acceptance band, preventing achievement of level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the clinical decision variable (absolute NIH) without surrogate substitution.",
      "rationale": "Validation activities target NIH directly, matching the COU decision variable. No surrogate QoI substitution was made. Velocity field validation is complementary and supports confidence in the flow solution underpinning hemolysis prediction. Required and achieved levels both at 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same device geometry, blood analogue, and operating envelope as the COU; any deviation must be formally justified.",
      "rationale": "Validation used the FDA generic pump geometry, which approximates but does not replicate the proprietary VAD impeller geometry. Blood analogue (bovine blood) differs from human blood rheology. Operating points cover 4 of 5 COU flow-speed combinations. Geometric and fluid differences reduce achieved level to 3 against the required 5 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must reach residual norms below 1e-6 for all equations; floating-point round-off sensitivity must be documented.",
      "rationale": "Momentum and continuity residuals converge to 1e-7. The hemolysis scalar transport equation stalls at 8e-6 on two operating points due to source-term stiffness near the impeller tip. This exceeds the 1e-6 threshold, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation execution protocol with independent reviewer sign-off must be in place; analyst training records must be current.",
      "rationale": "A simulation execution protocol exists and has been followed. Independent reviewer sign-off was obtained for mesh generation and boundary condition assignment. Analyst training records are current for 2 of 3 analysts; the third analyst's CFD certification lapsed 4 months prior to the study, reducing achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model must be validated against published literature benchmarks and sensitivity to model constants documented at MRL 5.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is used. Literature benchmarks show the model under-predicts hemolysis in high-shear gap flows by up to 40%. Sensitivity analysis of the model constants C, alpha, beta was performed but not formally compared against independent experimental datasets. Large gap between required level 5 and achieved level 2 reflects fundamental model form uncertainty at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary conditions must be characterised with stated uncertainties; epistemic gaps must be formally identified.",
      "rationale": "Fluid density and viscosity characterised by rheometry with ±3% uncertainty. Inlet velocity profile assumed fully developed; this assumption is not validated for the specific pump inlet geometry. Outlet pressure boundary set from clinical operating range. The unvalidated inlet profile assumption constitutes an epistemic gap reducing achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A minimum of three independent in-vitro replicates per operating point must be available; inter-replicate variability must be quantified.",
      "rationale": "Two independent in-vitro replicates were performed at each of 5 operating points. The required minimum of three replicates was not met due to blood supply constraints. Inter-replicate variability ranges from 4% to 19% NIH; the high variability at two operating points further limits confidence. Achieved level 2 reflects insufficient replicate count against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrably equivalent to COU input parameters; any non-equivalence must be formally bounded.",
      "rationale": "Validation simulations used bovine blood properties; COU requires human blood. Viscosity difference up to 12% at physiological shear rates. Pump geometry is the FDA generic model, not the proprietary VAD impeller. No formal equivalency bounding analysis was performed. These combined non-equivalences result in achieved level 2 against the required level 5, representing the largest credibility gap in the assessment."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team determined that the CFD model provides sufficient evidence to support a conditional regulatory submission. The velocity field and pressure head validations demonstrate the solver captures macroscopic flow physics. The NIH prediction, while exceeding the 25% acceptance criterion at one operating point, is conservatively over-predictive, providing a safety margin. Compensating controls include a 20% safety factor applied to the NIH acceptance threshold and a commitment to repeat validation with human blood and the production impeller geometry prior to final regulatory submission. The compound uncertainty arising from model form limitations and geometric non-equivalence is acknowledged; the conditional acceptance is contingent on completion of the supplementary validation protocol within 6 months.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
