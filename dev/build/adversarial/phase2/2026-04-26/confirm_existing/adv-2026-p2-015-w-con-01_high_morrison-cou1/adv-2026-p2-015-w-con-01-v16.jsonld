  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2f4a6b8d0f2a4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated and version-controlled in accordance with MRL 2 requirements. Documentation of solver version, patch level, and regression test results required.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a controlled software quality assurance protocol. Version control logs, regression test suite results (pass rate 99.8%), and change management records were reviewed and found compliant with MRL 2 SQA expectations. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems with known analytical solutions at MRL 2.",
      "rationale": "Code verification was performed using the method of manufactured solutions (MMS) for the incompressible Navier-Stokes equations. Observed order of accuracy (p = 1.97) was consistent with the nominal second-order scheme. Additional benchmarks against the lid-driven cavity and Poiseuille flow confirmed correct discretisation. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary QoI (wall shear stress). GCI < 5% is acceptable at MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted (coarse: 1.2M cells, medium: 3.8M cells, fine: 11.4M cells). Richardson extrapolation yielded GCI = 1.8% on area-averaged wall shear stress, satisfying the < 5% acceptance criterion. The fine mesh was adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and must bracket the clinical operating envelope of the CPB device.",
      "rationale": "Five flow-speed operating points (2–6 L/min; 2000–4000 RPM) were tested in vitro using a mock circulatory loop with bovine blood. Temperature (37 ± 0.5°C), hematocrit (33 ± 2%), and outlet pressure (80 ± 5 mmHg) were controlled and documented. The test envelope covers the full clinical operating range for the target CPB application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index (NIH) must agree with experimental measurements within ± 30% across all five operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) was compared to experimental measurements at all five operating points. Maximum relative error was 18.4% (at 6 L/min, 4000 RPM); mean absolute relative error was 11.2%. All predictions fell within the ± 30% acceptance band. The relative hemolysis index RH < 1 criterion was satisfied for the worst-case condition."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs extracted from the CFD model must be directly linked to the clinical endpoint (hemolysis) and the regulatory acceptance criterion (RH < 1).",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), computed from the power-law hemolysis damage model integrated over all fluid pathlines. NIH is the standard regulatory metric for blood pump hemolysis and maps directly to the RH < 1 acceptance criterion. Secondary QoIs (wall shear stress distribution, exposure time histograms) are mechanistically linked to hemolysis and provide diagnostic value."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use a geometry and flow regime sufficiently similar to the COU device and operating conditions to support extrapolation of model credibility.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump, which shares impeller topology and hydraulic diameter with the target CPB device. Operating conditions in the validation study bracket those of the COU. The validation hierarchy progresses from unit-problem benchmarks through subsystem validation to the full-device comparison, providing a coherent evidence chain."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of the steady-state RANS solution must be demonstrated by monitoring residuals and QoI stabilisation. Residuals must drop at least four orders of magnitude and QoI change per additional 500 iterations must be less than 0.5%.",
      "rationale": "A qualitative assessment of numerical solver error was performed by the lead analyst. Convergence behaviour was reviewed across all five operating-point simulations. Residual traces and QoI history plots were examined and judged to exhibit satisfactory convergence characteristics consistent with accepted practice for rotating-machinery CFD at this model risk level. The analyst's professional judgment, informed by extensive experience with similar pump simulations, supports the conclusion that iterative solver error does not materially compromise the hemolysis predictions. No formal quantitative gradation assignment was made for this factor; the evidence was considered collectively and found adequate to underpin the overall Accepted decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence that the model was set up and executed by qualified personnel following documented procedures, with independent review of boundary conditions and material properties.",
      "rationale": "All simulation setups were executed by a licensed mechanical engineer with 8 years of CFD experience in cardiovascular devices. Boundary conditions and material property assignments were independently reviewed by a second analyst. Setup checklists were completed and archived. No use errors were identified during review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis damage model must be justified for the flow regime and validated against experimental data for similar rotating blood-contacting devices.",
      "rationale": "The SST k-ω turbulence model was selected based on its established performance for swirling flows with adverse pressure gradients. The Giersiepen-Wurzinger power-law hemolysis model was used with coefficients calibrated for bovine blood. Both model choices are consistent with FDA guidance and published best practices for centrifugal blood pump CFD."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Geometric dimensions, fluid properties, and boundary conditions must be traceable to measurements or specifications with documented uncertainty.",
      "rationale": "Pump geometry was reconstructed from coordinate measuring machine (CMM) data with dimensional tolerance ± 0.02 mm. Blood viscosity (3.5 cP) and density (1060 kg/m³) were taken from published values for bovine blood at 37°C with 33% hematocrit. Inlet flow rates and rotational speeds were set to match experimental conditions with uncertainty quantified at ± 1.5% and ± 0.5% respectively."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood samples used in validation experiments must be characterised for hematocrit and baseline plasma free haemoglobin prior to each test run.",
      "rationale": "Fresh bovine blood was obtained from a single abattoir batch per test session. Pre-test hematocrit (33 ± 2%) and baseline plasma free haemoglobin (< 5 mg/dL) were measured and recorded for each of the five operating-point experiments. Sample characterisation is consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless parameters governing flow similarity (Reynolds number, flow coefficient) in the validation experiments must be within 10% of those in the COU operating envelope.",
      "rationale": "Reynolds numbers in the validation experiments ranged from 8,200 to 31,500, encompassing the COU operating envelope (9,500–28,000). Flow coefficients (Φ = Q/ND³) agreed to within 4.2% across all matched operating points. Dimensional similarity is satisfied and supports direct applicability of the validation evidence to the COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors were reviewed. Seven factors were formally assessed; of these, all meet or exceed their required credibility levels at MRL 2. The remaining six factors were determined to be not applicable or scoped out at this model risk level consistent with ASME V&V 40-2018 Table 3 guidance. The CFD model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index RH < 1 criterion is satisfied at the worst-case operating point. The overall credibility evidence package is accepted for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
