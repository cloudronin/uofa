  "signature": "ed25519:9a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software used for simulation is under documented version control and has undergone unit and integration testing consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R1 was used for all simulations. The software is a commercially validated solver with documented QA processes. Version control was maintained throughout the study and all solver settings were archived. Achieved Gradation 2 consistent with MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Code verification activities confirm solver correctly implements governing equations for incompressible viscous flow at the level required for MRL 2.",
      "rationale": "Standard benchmark cases (lid-driven cavity, Poiseuille flow) were run and results compared against analytical solutions with residuals below 1e-6. No code-level errors were identified. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Mesh convergence study demonstrates discretization error is quantified and within acceptable bounds for hemolysis index prediction.",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 2.1M, 5.4M, and 11.8M cells. Richardson extrapolation was applied to estimate the grid convergence index (GCI). Peak shear stress values converged within 3.2% between the medium and fine meshes. The 5.4M cell mesh was selected for production runs. Achieved Gradation 3 exceeds the MRL 2 requirement of Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation are documented and traceable to the simulation boundary conditions.",
      "rationale": "Experimental hemolysis measurements were conducted at 2500 RPM and 5 LPM using bovine blood with hematocrit 35±2%. Temperature was maintained at 37°C. Boundary conditions in the CFD model were set to match these conditions. Traceability between test protocol and simulation inputs is documented in the study report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation outputs are compared against experimental measurements using a defined metric and the comparison falls within an acceptable tolerance band.",
      "rationale": "Normalized index of hemolysis (NIH) predicted by CFD was compared against experimental measurements across five operating points. Mean absolute error was 12.4%, within the ±15% acceptance band defined a priori. All five operating points met the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The quantities of interest computed by the model (hemolysis index, shear stress distribution) are directly relevant to the clinical question of pump-induced hemolysis.",
      "rationale": "The primary QoI is the relative hemolysis index (RH) derived from integrated scalar shear stress along particle pathlines using the Giersiepen-Wurzinger power-law model. This QoI is the accepted metric for comparative hemolysis assessment in FDA guidance documents and is directly linked to the acceptance criterion RH < 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments were conducted on a geometry and under flow conditions sufficiently representative of the COU to support extrapolation of credibility evidence.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is the same geometry used in the COU. Operating conditions span the clinical range of 2–6 LPM and 2000–3500 RPM. The validation scenario is considered directly representative of the COU with no significant geometric or hemodynamic extrapolation required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence of the solver is confirmed with residuals below defined thresholds for all governing equations.",
      "rationale": "All simulations were run to steady-state convergence with continuity residuals below 1e-5 and momentum residuals below 1e-6. Mass imbalance across the domain was less than 0.01%. No solver divergence events were observed across the 25 production simulation cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for Class II device with medium model influence.",
      "rationale": "Use error assessment is scoped out at MRL 2 per the ASME V&V 40 standard requirements matrix. The model is operated by trained simulation engineers following a documented simulation protocol. No assessment of Gradation level is required or performed for this factor at the applicable risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The appropriateness of the turbulence model and hemolysis power-law formulation for predicting pump-induced blood damage is evaluated through a qualitative expert review and sensitivity analysis.",
      "rationale": "A comprehensive qualitative assessment was conducted by two independent subject-matter experts in computational hemodynamics to evaluate the suitability of the SST k-omega turbulence closure and the Giersiepen-Wurzinger hemolysis model for the CPB COU. Experts reviewed the theoretical basis of the model form, its published validation history across analogous rotary blood pump geometries, and its sensitivity to turbulence model constants under the shear stress regimes encountered in the FDA pump. The consensus finding was that the model form is well-suited to the COU, with known conservatism in the hemolysis power-law exponents providing a safety margin consistent with the RH < 1 acceptance criterion. Sensitivity runs varying the turbulence intensity at the inlet between 1% and 10% showed less than 4% variation in predicted NIH, confirming robustness of the model form selection. This qualitative expert review, combined with the published literature base supporting SST k-omega for similar devices, provides high confidence in model form adequacy at the applicable risk level. No structured Gradation level assignment was deemed necessary given the depth of the qualitative evidence gathered."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor combination.",
      "rationale": "Model inputs assessment is not required at MRL 2 per the ASME V&V 40 requirements matrix for a Class II device with medium model influence. Input parameters are documented and traceable but formal Gradation-level assessment is not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Test sample characterization beyond what is captured under Test Conditions is not required at MRL 2. Blood analog properties used in experiments are documented in the test protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU.",
      "rationale": "Equivalency of input parameters between the validation scenario and the COU is not formally assessed at MRL 2. The validation geometry is identical to the COU geometry, and operating conditions overlap substantially, providing inherent equivalency without requiring a formal Gradation-level determination."
    }
  ],
