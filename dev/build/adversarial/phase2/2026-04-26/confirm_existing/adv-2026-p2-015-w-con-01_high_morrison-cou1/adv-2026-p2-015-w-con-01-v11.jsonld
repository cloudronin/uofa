  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and found to meet or exceed requirements for Model Risk Level 2. Seven factors received formal level assignments with achieved levels meeting required levels; the remaining factors including numerical solver error were evaluated through documented qualitative assessment consistent with MRL 2 expectations. Discretization error GCI of 3.2% and output comparison agreement within combined uncertainty at all five operating points provide strong quantitative grounding. The assessment team unanimously concludes that the CFD model demonstrates sufficient credibility for the intended COU of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
