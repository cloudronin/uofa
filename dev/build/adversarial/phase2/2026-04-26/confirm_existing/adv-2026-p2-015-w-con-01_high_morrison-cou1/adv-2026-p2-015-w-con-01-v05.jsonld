  "signature": "ed25519:b4e9d3f2a1c0b5e8d7f6a5c4b3e2d1f0a9c8b7e6d5f4c3b2a1e0d9c8b7a6f5e4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression testing suite, and documented release notes must be present for the CFD platform used.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-certified quality management system. Regression test suite results and version-controlled solver configuration files were reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests or method-of-manufactured-solutions results must confirm correct solver implementation for relevant equation sets.",
      "rationale": "The Navier-Stokes solver was verified against the Taylor-Green vortex benchmark and a manufactured-solution test for the power-law hemolysis transport equation. Observed convergence rates matched theoretical expectations to within 3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the hemolysis index QoI and must demonstrate monotonic convergence across at least three mesh refinement levels.",
      "rationale": "Three mesh levels (2.1M, 5.8M, 14.6M cells) were evaluated. GCI for the normalized hemolysis index was 1.4% between the medium and fine meshes, confirming discretization error is well within acceptable bounds. The fine mesh was selected for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used in validation must be documented and traceable to the physical test setup, including flow rates, rotational speeds, and fluid properties.",
      "rationale": "Validation experiments were conducted at the FDA laboratory under documented protocols. Inlet flow rates (2–6 L/min) and rotational speeds (2000–3500 RPM) are fully traceable to calibrated instrumentation records. Fluid properties (bovine blood analogue) are specified per ASTM F1841."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index values must be compared quantitatively against experimental measurements with stated uncertainty bounds; agreement within 15% relative error required at MRL 2.",
      "rationale": "Predicted normalized index of hemolysis (NIH) was compared against five experimental operating points. Maximum relative error was 11.3% at the 6 L/min, 3500 RPM condition. All five points fell within the 15% acceptance band when experimental uncertainty (±8%) is accounted for."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (NIH, shear stress distribution) must be the same quantities used in the clinical decision-making context.",
      "rationale": "The primary QoI — normalized index of hemolysis — is directly used in the regulatory submission comparison (RH < 1 criterion). Shear stress scalar fields are intermediate QoIs feeding the power-law hemolysis model, and both are identical between validation and COU contexts."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions must be sufficiently similar to the COU pump geometry and operating envelope to support extrapolation of credibility evidence.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump — the same geometry class as the COU device. Operating conditions (flow rates and RPM) bracket the COU operating envelope. Geometric differences between the generic pump and the specific CPB device are within 8% on key hydraulic dimensions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for continuity and momentum equations; mass imbalance must be below 0.01%.",
      "rationale": "All production simulations converged to residuals below 1e-6 for continuity, momentum, and species transport equations. Global mass imbalance was below 0.004% in all cases. Convergence histories are archived in the simulation record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Analyst training records, simulation setup checklists, and independent review sign-off must be on file to demonstrate that operator error has been adequately controlled.",
      "rationale": "A qualitative assessment of use error risk was conducted by the credibility assessment team. The simulation workflow was executed by two senior CFD analysts each holding more than eight years of experience with rotating machinery hemolysis modeling. An independent technical reviewer with regulatory submission experience performed a line-by-line review of boundary condition assignments, material property inputs, and post-processing scripts prior to result acceptance. The team's internal simulation execution checklist — covering 47 setup verification items — was completed and signed for each of the five operating-point simulations. Peer review comments were resolved and documented in the project record. Based on the depth of analyst expertise, the structured checklist protocol, and the independent review process, the credibility assessment team concludes that use error risk is adequately controlled for this COU and does not represent a credibility gap that would affect the Accepted decision outcome."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category per the ASME V&V 40 credibility matrix.",
      "rationale": "Model form uncertainty assessment is not required at Model Risk Level 2 for a Class II device with medium model influence. This factor is scoped out of the formal assessment in accordance with the MRL 2 credibility requirements matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category per the ASME V&V 40 credibility matrix.",
      "rationale": "Formal model input uncertainty quantification is not required at Model Risk Level 2. Material property and boundary condition uncertainties are documented qualitatively in the simulation report but a full sensitivity analysis is not mandated for this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category per the ASME V&V 40 credibility matrix.",
      "rationale": "Statistical characterization of test sample variability is not required at Model Risk Level 2. The validation dataset uses a single well-characterized pump specimen consistent with MRL 2 expectations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category per the ASME V&V 40 credibility matrix.",
      "rationale": "Formal equivalency analysis of input parameters between the validation context and the COU is not required at Model Risk Level 2. Qualitative equivalency is addressed under the Relevance of Validation Activities factor."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Seven credibility factors were formally assessed at Model Risk Level 2 for a Class II CPB device with medium model influence and high decision consequence. All seven assessed factors achieved their required credibility levels: Software quality assurance (2/2), Numerical code verification (2/2), Discretization error (3/2), Test conditions (2/2), Output comparison (2/2), Relevance of quantities of interest (2/2), Relevance of validation activities (2/2), and Numerical solver error (2/2). Use error was assessed through a documented qualitative process involving experienced analysts and independent review. Six remaining factors are not required at MRL 2 per the ASME V&V 40 credibility matrix. The totality of credibility evidence supports an Accepted decision for the intended use of this CFD model to identify worst-case hemolysis operating conditions for the CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
