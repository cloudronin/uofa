  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R1) is a commercially validated code with documented version control, regression testing, and release notes. Software QA procedures including user qualification records and change-control logs were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Code verification was performed through comparison against analytical solutions for laminar pipe flow and lid-driven cavity benchmarks. Results confirm correct implementation of the incompressible Navier-Stokes solver and the power-law hemolysis model within acceptable tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted on the baseline pump geometry. Richardson extrapolation yielded a grid convergence index (GCI) below 2% for the hemolysis index QoI at all five operating points, confirming discretization error is well-controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) were controlled and documented per ASTM F1841 protocols. Boundary conditions applied in the CFD model were derived directly from measured test data, ensuring traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values were compared against experimentally measured values across all five operating points. Mean prediction error was 11.4%, within the acceptance band defined for MRL 2 validation activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "The primary QoI, the relative hemolysis index (RH), directly maps to the clinical endpoint of pump-induced hemolysis. The power-law scalar transport model outputs volume-integrated hemolysis damage that is physically meaningful and directly comparable to the RH < 1 acceptance criterion used in the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Validation experiments were conducted on the same FDA generic centrifugal pump geometry under overlapping flow-speed conditions. The validation domain covers the operating envelope of the COU, providing direct relevance to the intended prediction use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 1 for MRL 2.",
      "rationale": "Iterative convergence was monitored via residual norms (below 1e-6 for all equations) and mass-flow imbalance (below 0.01%). Time-step independence was verified for the transient rotating-frame simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is not required at Model Risk Level 2 for this COU. The factor is scoped out per the MRL 2 factor applicability matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "rationale": "A qualitative assessment of model form adequacy was performed by the modeling team. The power-law hemolysis model (Giersiepen-Wurzinger formulation) is the de facto standard for CFD-based hemolysis prediction in rotary blood pumps and has been extensively applied in the peer-reviewed literature for centrifugal pump geometries comparable to the FDA generic pump. Subject matter expert review confirmed that the turbulence closure (SST k-omega) and the scalar hemolysis transport equation are appropriate representations of the dominant physical mechanisms under CPB operating conditions. No alternative model forms were identified that would materially improve predictive fidelity within the constraints of the COU. The qualitative assessment supports the conclusion that model form adequacy is sufficient for the intended use.",
      "acceptanceCriteria": "Model form must be judged adequate by subject matter expert review for the COU operating regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2. Key inputs (viscosity, density, hemolysis model coefficients) were assigned nominal literature values consistent with prior FDA pump studies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Test sample characterization beyond standard ASTM F1841 requirements is not required at MRL 2 for this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal equivalency analysis of input parameters between validation and COU conditions is not required at MRL 2. Qualitative review confirmed operating conditions are within the validated envelope."
    }
  ],
