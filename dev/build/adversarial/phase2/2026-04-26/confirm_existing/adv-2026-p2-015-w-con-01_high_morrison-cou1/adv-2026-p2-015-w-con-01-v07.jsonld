  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software version control, issue tracking, and regression testing documented for ANSYS Fluent 2022R2. SQA plan on file.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated CFD solver with documented SQA procedures. Version control records confirm solver version consistency across all simulation runs. Regression test suite confirms no solver-level defects affecting hemolysis-relevant physics. Gradation 2 achieved and required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver passes published benchmark verification cases for incompressible Navier-Stokes with rotating reference frames.",
      "rationale": "ANSYS Fluent has been verified against ASME V&V 20 benchmark cases for rotating machinery flows. Internal benchmark suite results provided by vendor confirm code correctness for the relevant physics regime. Gradation 2 requirement met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI on at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study conducted: coarse (4.2M cells), medium (11.8M cells), fine (31.4M cells). GCI for the relative hemolysis index QoI was 3.1% between medium and fine meshes, satisfying the <5% threshold. Richardson extrapolation applied. Achieved Gradation 3 exceeds the required Gradation 2 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (flow rates, rotational speeds, fluid properties) documented and matched to CFD inlet/outlet conditions within stated tolerances.",
      "rationale": "All five operating conditions (3 flow rates × rotational speeds per FDA protocol) were reproduced in CFD with inlet velocity profiles derived from PIV measurements. Temperature-corrected blood analog viscosity (36% glycerol-water) applied. Boundary condition fidelity confirmed against experimental test log. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted RH index within ±15% of experimental measurements for all 5 operating conditions.",
      "rationale": "CFD-predicted relative hemolysis index compared against experimental hemolysis measurements at all five operating conditions. Maximum discrepancy of 11.3% observed at the highest flow-speed combination. All predictions within the ±15% acceptance band. Gradation 2 achieved for output comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to the clinical decision criterion and is extracted from CFD outputs without surrogate transformation.",
      "rationale": "The relative hemolysis index is computed directly from CFD shear stress field using the Giersiepen-Wurzinger power-law model integrated along particle tracks. This QoI is the same metric used in the regulatory submission acceptance criterion (RH < 1). No surrogate or proxy metric substitution required. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic centrifugal pump geometry under CPB-representative operating conditions.",
      "rationale": "Validation experiments performed on the FDA benchmark centrifugal pump geometry using blood-analog fluid at physiologically representative flow rates (2–8 L/min) and rotational speeds (2500–3500 RPM). Geometry, fluid, and operating regime are directly representative of the CPB COU. No significant extrapolation from validation domain to COU required. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence residuals < 1e-5 for all transport equations; mass imbalance < 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum equations. Mass imbalance across pump domain confirmed below 0.005% for all five operating conditions. Double-precision arithmetic used throughout. Achieved Gradation 2 exceeds the MRL 2 requirement of Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup, boundary condition specification, and post-processing scripts conducted by a qualified CFD engineer not involved in the primary analysis.",
      "rationale": "A qualitative assessment of use error was conducted through structured peer review of all simulation inputs, meshing decisions, turbulence model selection, and post-processing workflows. The reviewing engineer, holding 12 years of cardiovascular CFD experience, identified and resolved two minor boundary condition specification ambiguities prior to final simulation execution. No systematic use errors were identified in the final simulation set. The review process followed the team's internal simulation governance procedure (SOP-CFD-007 Rev C), which requires independent sign-off on all Class II device simulations. Given the structured review process and the low complexity of the post-processing pipeline for this COU, the assessment team determined through expert consensus that use error risk is appropriately controlled for the intended decision at MRL 2. This qualitative determination was judged sufficient without formal assignment of a numerical gradation level, consistent with the team's interpretation of ASME V&V 40 guidance for factors where the primary control mechanism is procedural rather than quantitative."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Turbulence model selection justified by comparison against PIV data; hemolysis power-law model constants validated against published experimental datasets.",
      "rationale": "SST k-omega turbulence model selected based on published comparisons for rotating cardiovascular flows. Model predictions compared against PIV velocity fields from FDA benchmark study showing mean velocity error < 8%. Giersiepen-Wurzinger hemolysis model constants taken from literature meta-analysis. Model form uncertainty assessed as acceptable for the relative comparison intended use. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Geometric model dimensions verified against engineering drawings; fluid property inputs verified against measured values with stated uncertainty.",
      "rationale": "CAD geometry verified against FDA benchmark pump engineering drawings with dimensional tolerance confirmation. Blood analog fluid viscosity measured at 37°C using cone-plate rheometer; density confirmed by gravimetric measurement. All material property inputs traceable to measurement records. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2; single-geometry comparative analysis is sufficient for the intended regulatory decision.",
      "rationale": "Test sample variability assessment is not required at MRL 2 for a comparative CFD study using a single benchmark geometry. The COU does not require characterization of manufacturing variability across a sample population. Scoped out per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2; direct use of experimental boundary conditions eliminates need for separate equivalency demonstration.",
      "rationale": "Boundary conditions applied in CFD are derived directly from experimental measurements for the same operating conditions. No parameter transformation or surrogate mapping is required, making formal equivalency assessment unnecessary at MRL 2. Scoped out per MRL 2 assessment plan."
    }
  ],
