  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors met or exceeded their required Gradation levels at MRL 2. The six non-assessed factors were confirmed as not required under the MRL 2 applicability matrix. The CFD model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index predictions are within the combined experimental uncertainty band at all five operating points, and the RH < 1 acceptance criterion is satisfied. The credibility evidence package supports regulatory submission for 510(k) clearance.",
