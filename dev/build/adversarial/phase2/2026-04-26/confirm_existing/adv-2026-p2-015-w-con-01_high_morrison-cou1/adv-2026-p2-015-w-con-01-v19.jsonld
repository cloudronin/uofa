  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Software versioning, regression testing, and change control documentation must meet Gradation 2 requirements for MRL 2.",
      "rationale": "ANSYS Fluent 2022 R1 used under ISO 9001-certified QMS. Version control, regression test suite (450 cases), and change-control records reviewed. All SQA artifacts meet or exceed the Gradation 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy testing on canonical benchmark cases must demonstrate convergence consistent with the solver's nominal discretization order.",
      "rationale": "Method of manufactured solutions applied to lid-driven cavity and pipe-flow benchmarks. Observed order of accuracy 1.94 (nominal 2nd-order). Code verification requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be reported; GCI on QoI (shear stress integral) must be below 5% for the fine-grid solution.",
      "rationale": "Three-grid Richardson extrapolation performed at all five operating points. Fine-grid GCI on volume-averaged scalar shear stress ranged 1.2–2.8%, well below the 5% threshold. Discretization error is adequately controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, flow rate, rotational speed) must be documented and shown to match simulation boundary conditions within ±5%.",
      "rationale": "FDA benchmark experimental conditions reproduced: bovine blood analogue at 37 °C, Hct 35%, flow rates 2.5–6 L/min, speeds 2000–3500 RPM. Boundary condition matching confirmed within ±3% across all operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) must agree with experimental measurements within the combined experimental uncertainty band at each operating point.",
      "rationale": "RH predictions compared to FDA experimental data at all five flow-speed combinations. Maximum deviation 8.3% at 2.5 L/min / 3500 RPM, within the ±10% combined uncertainty band. Output comparison criterion satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoI used in validation (scalar shear stress integral, RH index) must be directly traceable to the clinical hemolysis endpoint specified in the COU.",
      "rationale": "The relative hemolysis index is the direct regulatory endpoint for CPB device clearance. Scalar shear stress integral is the mechanistic driver in the power-law hemolysis model (Giersiepen-Wurzinger). Both QoIs are clinically and mechanistically relevant to the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must use the same pump geometry, operating envelope, and blood analogue as the COU; extrapolation beyond the validated envelope must be justified.",
      "rationale": "Validation performed on the identical FDA generic centrifugal pump geometry at operating conditions spanning the full COU envelope. No extrapolation required. Validation activities are directly applicable to the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Residual convergence and mass-conservation error must be documented for each simulation; residuals must reach at least 1e-5 and mass imbalance must be below 0.1%.",
      "rationale": "All simulations converged to continuity residual 1e-6 and momentum residuals 1e-7. Mass imbalance across pump domain below 0.01% in all cases. Solver error is negligible and well within acceptance bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Use error assessment scoped out per MRL 2 applicability matrix. Simulation execution performed by trained CFD engineers under documented SOPs; no additional use-error evaluation required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The selected turbulence model and hemolysis sub-model must be justified against published literature for rotating blood-contacting devices.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark studies for centrifugal blood pumps (Fraser et al., Hariharan et al.). Power-law hemolysis model validated for this class of device. Model form choices are well-supported."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (blood viscosity, density, hemolysis model coefficients) and geometric inputs must be traceable to published sources or direct measurement; sensitivity to key inputs must be characterised.",
      "rationale": "A comprehensive qualitative assessment of model input credibility was performed. Blood rheological properties were drawn from the Ballyk et al. non-Newtonian viscosity model and cross-checked against the Merrill-Pelletier experimental dataset for bovine blood at Hct 35%. Geometric inputs were derived from the FDA-published STL geometry with dimensional tolerances verified by coordinate measuring machine to ±0.02 mm. Hemolysis model coefficients (C = 1.8×10⁻⁶, α = 0.765, β = 2.416) were taken from the Giersiepen-Wurzinger correlation as tabulated in Taskin et al. (2012). A structured sensitivity sweep across ±15% variation in viscosity and ±10% in hemolysis exponents demonstrated that the RH index varies by less than 12% across the full parameter range, confirming that the model output is not unduly sensitive to plausible input uncertainty. The assessment team concluded that model inputs are adequately characterised for the COU, though no formal Gradation-level scoring was assigned given the primarily qualitative nature of the sensitivity analysis and the absence of a probabilistic uncertainty propagation framework in this assessment cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Test sample characterisation scoped out per MRL 2 applicability matrix. FDA benchmark experimental data used directly; sample provenance is documented in the FDA dataset metadata."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Equivalency of input parameters between validation and COU contexts not formally assessed at MRL 2. Operating conditions for validation and COU are identical by design, providing implicit equivalency."
    }
  ],
