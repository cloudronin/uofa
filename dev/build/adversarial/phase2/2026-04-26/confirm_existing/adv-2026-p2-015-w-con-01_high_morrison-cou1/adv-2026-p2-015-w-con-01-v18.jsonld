  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software used for CFD simulation must be under documented version control with traceable build records and documented verification tests at Gradation 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented QA procedures. Version control records, regression test logs, and release notes were reviewed and confirmed to satisfy Gradation 2 requirements for MRL 2. No custom solver modifications were introduced."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Numerical code must be verified against at least one analytical or manufactured solution relevant to rotating-frame turbulent flow at Gradation 2.",
      "rationale": "Code verification was performed using the method of manufactured solutions for the incompressible Navier-Stokes equations in a rotating reference frame. Observed order of accuracy was 1.97, consistent with the nominal second-order discretization. Results documented in the simulation report appendix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Discretization error must be estimated using a formal Richardson extrapolation or equivalent grid convergence index (GCI) approach across at least three mesh refinement levels.",
      "rationale": "Three systematically refined meshes (4.2M, 11.7M, 28.4M cells) were used. GCI values for the hemolysis index QoI were below 2.1% on the medium mesh, exceeding the Gradation 2 threshold. The achieved level of 3 reflects the documented extrapolated error bound and formal uncertainty quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to reproduce boundary conditions in the simulation, including flow rates, rotational speeds, and fluid properties.",
      "rationale": "Test conditions from the FDA benchmark dataset are fully documented. Inlet flow rates (2.5–6.0 L/min), impeller speeds (2000–3500 RPM), and blood analog fluid properties (glycerol-water, viscosity 3.5 mPa·s) were applied as boundary conditions in the CFD model with less than 1% deviation from reported experimental values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Model output must be compared against experimental measurements using a quantitative metric with defined acceptance bounds.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values were compared against experimental measurements across all 5 operating points. The mean absolute percentage error was 8.3%, within the pre-specified 15% acceptance bound. Bland-Altman analysis confirmed no systematic bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The QoIs used in validation must be directly traceable to the clinical endpoint of hemolysis risk and must match the quantities used in the COU decision.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the standard metric for pump-induced hemolysis in regulatory submissions. The relative hemolysis index (RH) derived from NIH is the direct acceptance criterion for the COU. Traceability from CFD output to clinical endpoint is established through the power-law hemolysis model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must cover the operating envelope of the COU, including the range of flow rates and impeller speeds relevant to CPB clinical use.",
      "rationale": "Validation was performed on the FDA generic pump geometry under flow conditions spanning the full clinical CPB operating range (2.5–6.0 L/min, 2000–3500 RPM). The validation domain encompasses all five operating points evaluated in the COU, confirming adequate coverage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category given documented commercial solver validation.",
      "rationale": "At Model Risk Level 2, formal numerical solver error assessment beyond code verification is not required per ASME V&V 40 Table 4. The commercial solver's published verification and validation documentation satisfies the applicable requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU scope.",
      "rationale": "Use error assessment is not required at MRL 2 for this device class and COU. Simulation inputs were reviewed by a second analyst for consistency with the test report, providing adequate assurance without formal use error quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "rationale": "Model form credibility was evaluated through a comprehensive qualitative assessment of the governing equations, turbulence closure selection, and hemolysis damage model. The SST k-ω turbulence model was selected based on its established performance for rotating machinery flows with adverse pressure gradients, supported by published benchmark studies on centrifugal pump hemolysis prediction (Goubergrits et al., 2016; Taskin et al., 2012). The power-law hemolysis model (modified Giersiepen-Wurzinger) was validated against RBC fragility data across the relevant shear stress range (50–500 Pa, 1–500 ms exposure). Sensitivity analyses on turbulence model constants and hemolysis model coefficients were conducted, demonstrating that the relative hemolysis index ranking of operating conditions is robust to parameter variation within published uncertainty ranges. The qualitative assessment confirms that the model form is appropriate for identifying worst-case hemolysis conditions within the CPB operating envelope, consistent with the COU decision criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU scope.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2. Input parameters (geometry, fluid properties, boundary conditions) were sourced from the FDA benchmark dataset with documented traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU scope.",
      "rationale": "Test sample characterization beyond what is provided in the FDA benchmark dataset is not required at MRL 2. The five operating point combinations provide adequate coverage of the CPB flow-speed envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU scope.",
      "rationale": "Equivalency of input parameters between the validation context and the COU is not formally required at MRL 2. The FDA benchmark conditions are sufficiently representative of the CPB COU operating environment to support the intended use without additional equivalency demonstration."
    }
  ],
