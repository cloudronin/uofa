  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2. Discretization error achieved Gradation 3, exceeding the Gradation 2 requirement. The six factors designated as not-assessed are consistent with MRL 2 scoping per ASME V&V 40 Table 4. The model form factor was evaluated through a comprehensive qualitative assessment confirming appropriateness of turbulence closure and hemolysis damage model for the CPB COU. The relative hemolysis index predictions are within the pre-specified 15% acceptance bound across all five operating points. The credibility evidence package supports acceptance of the CFD model for identifying worst-case hemolysis operating conditions for the Class II CPB device.",
