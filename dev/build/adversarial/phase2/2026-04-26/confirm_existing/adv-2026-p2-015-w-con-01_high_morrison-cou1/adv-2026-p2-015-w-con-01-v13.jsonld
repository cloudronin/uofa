  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the Morrison COU1 CFD hemolysis model at Model Risk Level 2. Seven factors were formally assessed against required and achieved levels; all seven met or exceeded their required gradation levels. Six factors were assessed qualitatively or scoped at Gradation 1, consistent with MRL 2 expectations. The relative hemolysis index RH = 0.87 at the worst-case operating point satisfies the RH < 1 acceptance criterion. Grid convergence, code verification, output comparison, and validation relevance all demonstrate adequate credibility for the intended regulatory submission. The overall credibility evidence is judged sufficient to support the Accepted decision for this Class II CPB device submission.",
