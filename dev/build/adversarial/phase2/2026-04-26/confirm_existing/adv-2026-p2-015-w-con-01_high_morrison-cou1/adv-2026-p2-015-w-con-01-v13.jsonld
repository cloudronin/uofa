      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA documentation confirms version control, regression testing, and release validation procedures are in place for the CFD solver at MRL 2.",
      "rationale": "ANSYS Fluent 2021 R2 is used under an FDA-recognized SQA framework. Version control logs, regression test suites, and installation qualification records were reviewed and found compliant with ASME V&V 40 Gradation 2 requirements. No deviations identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
