  "signature": "ed25519:9a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software quality assurance practices meet MRL 2 requirements including version control and documented test suite.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated code with documented QA procedures. Version control is maintained via institutional repository. Regression test suite confirms solver behavior for internal flow applications. SQA level 2 is achieved and meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Numerical code verification demonstrates correct implementation of governing equations at MRL 2 level.",
      "rationale": "Order-of-accuracy testing was performed using the method of manufactured solutions for the incompressible Navier-Stokes solver. Second-order spatial accuracy was confirmed on structured and unstructured meshes. Results exceed the MRL 2 requirement and satisfy level 3 verification benchmarks published in the ASME V&V 20 standard."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) less than 5% for hemolysis index QoI across all 5 operating conditions.",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 2.1M, 5.8M, and 14.2M cells. GCI values for the relative hemolysis index ranged from 1.8% to 3.4% across all operating conditions, satisfying the 5% acceptance criterion. Richardson extrapolation confirms the solution is in the asymptotic convergence regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation are sufficiently representative of the CPB operating envelope.",
      "rationale": "Bench-top hemolysis experiments were conducted at 3.0, 4.0, and 5.0 L/min flow rates at 2500 and 3000 RPM, spanning the clinical CPB operating range. Blood analog fluid (glycerol-water, 40% hematocrit equivalent) was used per ASTM F1841 guidance. Temperature was controlled at 37°C ± 0.5°C throughout testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted hemolysis index values agree with experimental measurements within 15% across all validation operating points.",
      "rationale": "Normalized index of hemolysis (NIH) values predicted by the CFD model agree with experimental measurements within 8–13% across all five validation operating conditions. The Giersiepen power-law hemolysis model was used with calibrated coefficients. Systematic bias is less than 5%, and no operating condition exceeds the 15% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The QoIs used in validation (NIH, RH index) are directly relevant to the COU decision criterion.",
      "rationale": "The relative hemolysis index RH is the primary decision QoI for the COU. Validation was conducted using NIH, which is the experimentally measurable analog. The relationship between NIH and RH is well-established in the literature and both quantities reflect the same physical phenomenon. Relevance of QoIs is confirmed at level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities are conducted on a geometry and flow regime sufficiently similar to the COU device and operating conditions.",
      "rationale": "Validation was performed on the FDA benchmark centrifugal pump, which shares the same impeller topology and operating regime as the CPB device under assessment. Flow coefficients and Reynolds numbers overlap with the COU operating envelope. Minor geometric differences are documented and their effect on hemolysis prediction is bounded by sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence criteria are met and solver residuals demonstrate stable solution for all operating conditions.",
      "rationale": "Steady-state RANS simulations were run to residual convergence of 1e-6 for all equations. Mass imbalance across inlet and outlet was less than 0.01% for all cases. For two operating points near the design point, transient URANS simulations were also performed to confirm that steady-state assumptions do not introduce material error in the hemolysis index prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Use error assessment is not required at MRL 2 for this factor; basic operator qualification documentation is sufficient.",
      "rationale": "At MRL 2, a formal use error assessment is not required. The simulation team holds documented CFD training credentials and follows institutional SOPs for mesh generation, boundary condition specification, and post-processing. No use error assessment beyond basic qualification documentation is required or performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The selected turbulence and hemolysis model forms are appropriate for the flow regime and QoI.",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance for internal rotating flows with adverse pressure gradients. The Giersiepen hemolysis power-law model was selected over alternatives based on a literature survey of 12 published comparisons for centrifugal blood pumps. Model form uncertainty is bounded by the validation evidence at level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs are traceable to measurement data or published material property sources; uncertainty in inputs is characterized.",
      "rationale": "A qualitative assessment of model input credibility was performed in lieu of a formal uncertainty quantification study, which is consistent with MRL 2 expectations. Blood analog fluid viscosity and density were taken from ASTM F1841 reference values with documented measurement uncertainty of ±2%. Pump geometry was derived from CMM measurements of the physical device with dimensional tolerances of ±0.05 mm. Inlet velocity profiles were reconstructed from ultrasonic flow meter readings. A qualitative sensitivity review by the simulation team confirmed that the dominant input uncertainty contributors are fluid viscosity and impeller clearance gap, and that their combined influence on the hemolysis index prediction is within the bounds established by the output comparison evidence. This factor was evaluated through structured expert elicitation and documented peer review rather than through formal level-graded criteria, as the team determined that the qualitative evidence base is sufficient to support the overall Accepted decision at MRL 2 without assigning discrete gradation levels to this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Test sample characterization is not required at MRL 2 beyond confirmation that blood analog meets ASTM F1841 specifications.",
      "rationale": "Blood analog fluid batches were certified against ASTM F1841 viscosity and density specifications prior to each test run. Formal test sample statistical characterization is not required at MRL 2. Certificate of conformance documents are retained in the project record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Equivalency of input parameters between the validation case and the COU is confirmed at a qualitative level consistent with MRL 2.",
      "rationale": "The validation experiments were conducted using the same blood analog fluid, flow rates, and rotational speeds as the COU operating envelope. Boundary conditions in the CFD model were matched to experimental measurements. Equivalency is confirmed at MRL 2 level through documented comparison of validation and COU input parameter tables."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model has been reviewed across all 13 ASME V&V 40 factors. Seven factors were formally assessed and all meet or exceed their required levels for MRL 2. Six factors were either not-assessed or addressed at the minimum required level consistent with MRL 2 scope. The overall body of evidence, including mesh convergence, code verification, validation against FDA benchmark pump data, and QoI relevance, provides sufficient confidence that the model is fit for the intended use of identifying worst-case hemolysis operating conditions. The decision to Accept is supported by the structured factor evidence and is consistent with the MRL 2 requirements for a Class II CPB device.",
