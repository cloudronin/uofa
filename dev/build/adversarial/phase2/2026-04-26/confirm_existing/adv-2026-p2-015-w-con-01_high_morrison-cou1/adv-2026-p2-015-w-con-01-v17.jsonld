  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted. Seven of thirteen factors were formally assessed; all assessed factors met or exceeded their required credibility levels. The remaining six factors were either scoped out or addressed at the minimum level appropriate for MRL 2. Validation evidence demonstrates acceptable agreement between CFD predictions and experimental hemolysis measurements across all 5 operating points. The relative hemolysis index RH < 1 acceptance criterion is satisfied. The assessment team concludes that the model has sufficient credibility for the stated context of use.",
