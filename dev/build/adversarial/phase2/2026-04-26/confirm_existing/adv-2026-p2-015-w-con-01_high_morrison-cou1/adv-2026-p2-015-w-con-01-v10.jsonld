      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Code passes manufactured-solution and benchmark verification cases relevant to rotating machinery.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver; second-order spatial convergence confirmed. Rotating-frame benchmark (lid-driven cavity with body force) also passed. Meets Gradation 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% on hemolysis index QoI across all operating points.",
      "rationale": "Three-level mesh refinement study conducted (1.2M, 4.8M, 19.2M cells). Richardson extrapolation yields GCI of 2.1% for the scalar hemolysis index at the worst-case operating point. Achieves Gradation 3 against a Gradation 2 requirement, providing margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature) replicated in simulation within ±5%.",
      "rationale": "Laboratory test conditions for the FDA pump loop (37°C saline-blood analog, 5 L/min nominal flow, 80 mmHg head) reproduced in CFD boundary conditions. Deviations < 2% on all controlled parameters. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted relative hemolysis index within 15% of experimental mean across all five operating points.",
      "rationale": "CFD-predicted RH values compared against in-vitro hemolysis measurements at 5 flow-speed combinations. Maximum deviation 11.3%, mean deviation 6.8%. All predictions fall within experimental uncertainty bands. Gradation 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs (shear-stress-based hemolysis index, relative hemolysis RH) directly map to the clinical endpoint and regulatory acceptance criterion.",
      "rationale": "The relative hemolysis index RH is the direct regulatory comparator used in FDA guidance. Scalar hemolysis index derived from Giersiepen power-law model is the established surrogate. Both QoIs are clinically meaningful and directly used in the submission decision. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments performed on the same device geometry, fluid, and operating envelope as the COU.",
      "rationale": "Validation conducted on the FDA generic centrifugal pump geometry — the same geometry as the COU device. Blood analog fluid (bovine blood, 37°C) used in experiments; CFD uses matched viscosity and density. Operating envelope (2–8 L/min, 1750–3500 RPM) spans the COU envelope. High relevance; Gradation 2 requirement met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence monitored; residuals < 1e-5 and mass imbalance < 0.01% at all operating points.",
      "rationale": "Steady-state RANS simulations converged to scaled residuals below 1e-6 for all equations. Global mass imbalance < 0.005%. Torque and hemolysis index monitored over iterations; variation < 0.1% over final 500 iterations. Exceeds Gradation 1 requirement; Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Use error assessment is not required at Model Risk Level 2 for this device classification. Scoped out per MRL 2 assessment matrix. No requiredLevel or achievedLevel assigned."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Turbulence model selection justified; hemolysis constitutive model validated against published data.",
      "rationale": "SST k-omega turbulence model selected based on published comparative studies for rotating blood pump geometries. Giersiepen hemolysis power-law model parameters validated against Heuser and Opitz shear-exposure data. Model form uncertainty estimated at 8% via literature comparison. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis index to key input parameters (viscosity, impeller tip clearance, inlet velocity profile) quantified; dominant inputs identified.",
      "rationale": "A qualitative assessment of model input uncertainty was performed through structured expert elicitation and literature review. Blood viscosity (non-Newtonian effects), impeller tip clearance tolerance (±0.05 mm), and inlet velocity profile shape were identified as the three dominant input uncertainties. Engineering judgment, supported by prior published parametric studies on analogous centrifugal pumps, indicates that the combined influence of these inputs on the hemolysis index QoI is within the validation uncertainty band already demonstrated in the output comparison factor. The assessment team concluded that the model input uncertainty does not materially alter the credibility conclusion, and that the qualitative characterisation is commensurate with the MRL 2 requirements for this device class. A formal quantitative sensitivity analysis (e.g., Morris screening or Sobol indices) was considered but deemed disproportionate given the supporting experimental validation data already available. This factor is considered satisfactorily addressed through the qualitative pathway."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Test sample characterisation beyond what is captured in test conditions and output comparison is not required at MRL 2. Scoped out per assessment matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Equivalency of input parameters between validation and COU is addressed implicitly through the relevance factors. Standalone assessment not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been addressed at a level commensurate with Model Risk Level 2 for a Class II CPB device. Seven factors were formally assessed with structured evidence; all seven achieved their required gradation levels or higher. Three factors were scoped out as not required at MRL 2. The model inputs factor was addressed via a qualitative pathway supported by expert elicitation and published parametric data, and the assessment team determined this to be sufficient. CFD-predicted hemolysis indices fall within 15% of experimental measurements across all five operating points, and the relative hemolysis index RH < 1 acceptance criterion is met. The overall credibility body of evidence is judged sufficient to support the intended regulatory submission use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
