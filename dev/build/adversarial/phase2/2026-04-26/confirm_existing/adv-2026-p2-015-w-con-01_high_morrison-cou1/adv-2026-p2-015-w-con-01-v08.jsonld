  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels at Model Risk Level 2. Discretization error and numerical solver error achieved levels above the required minimum, providing additional confidence margin. The three not-assessed factors are appropriately scoped out per ASME V&V 40 Table 3 for the combination of medium model influence and high decision consequence at MRL 2. The model form factor was evaluated through structured qualitative expert review and determined to be fit for purpose for identifying relative worst-case hemolysis operating conditions. The overall credibility evidence is sufficient to support an Accepted decision for use of the CFD model in the CPB hemolysis regulatory submission.",
