  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model applied to the FDA generic centrifugal blood pump under CPB conditions is accepted at Medium assurance level for MRL 2. Seven of thirteen credibility factors were formally assessed; all seven meet or exceed their required levels. The remaining six factors were scoped out or not assessed in accordance with ASME V&V 40 Table 3 guidance for MRL 2. The model demonstrates adequate fidelity for identifying worst-case hemolysis operating conditions, with validation evidence from the FDA benchmark dataset supporting the COU. The relative hemolysis index predictions are sufficiently accurate to support the regulatory comparison against the predicate device using the RH < 1 acceptance criterion.",
