  "signature": "ed25519:9c4b2a7f1e3d6c8a0b5f2e4d7a9c1b3e6f8d0a2c4b6e8f0d2a4c6b8e0f2a4c6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD analysis must be validated and documented under a quality management system appropriate for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is developed and maintained under ISO 9001-compliant QMS. Version control, release notes, and regression test suites are documented. The simulation workflow scripts were managed under Git with tagged releases. All solver inputs and outputs were archived in a traceable manner consistent with MRL 2 requirements. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate that the numerical implementation correctly solves the governing equations to a level consistent with MRL 2.",
      "rationale": "Code verification was performed using manufactured solutions for the incompressible Navier-Stokes equations. Second-order spatial convergence was confirmed on structured benchmark meshes. The hemolysis transport scalar equation was verified against an analytical diffusion-convection solution. Observed order of accuracy matched theoretical expectations within 5% tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified using a systematic mesh refinement study with at least three mesh levels; GCI must be reported for key QoIs.",
      "rationale": "A three-level mesh refinement study was conducted with coarse (2.1M cells), medium (6.8M cells), and fine (18.4M cells) meshes. Grid Convergence Index (GCI) for the relative hemolysis index was 1.3% on the fine mesh. The asymptotic range ratio was 1.02, confirming convergence. The medium mesh was selected for production runs, with GCI of 3.1%, well within the 5% threshold for MRL 2. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable, with boundary conditions matching simulation inputs within acceptable tolerances.",
      "rationale": "The FDA benchmark experimental dataset provides fully documented test conditions including fluid viscosity (glycerol-water mixture, 3.5 cP), inlet flow rates (2.5, 3.5, 5.0, 6.0, 7.0 L/min), and rotational speeds (2000, 2500, 3500, 4500 RPM). Uncertainty in flow rate measurement was ±2%, and rotational speed uncertainty was ±10 RPM. All boundary conditions applied in simulation were traceable to the published experimental protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics between simulation outputs and experimental measurements must be reported for all primary QoIs.",
      "rationale": "Pressure rise across the pump was compared against experimental measurements at 20 operating points. Mean absolute error was 4.2% with maximum error of 9.1% at off-design conditions. The relative hemolysis index showed agreement within 12% across all validated operating points. Validation metrics were computed using ASME V&V 20 procedures including experimental uncertainty propagation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation activities must be directly relevant to the clinical decision being supported.",
      "rationale": "The primary QoI is the relative hemolysis index (RH), which is the direct metric used in the regulatory acceptance criterion (RH < 1 compared to predicate device). Validation activities used the same RH formulation as the COU assessment. Secondary QoIs (pressure-flow curves, velocity fields) are mechanistically linked to hemolysis generation and provide supporting evidence for model fidelity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be sufficiently similar to the COU in terms of geometry, operating conditions, and fluid properties to support extrapolation of model credibility.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is identical to the COU device geometry. Operating conditions in validation (2000–4500 RPM, 2.5–7.0 L/min) span the full COU operating envelope. Fluid properties in validation used a blood analogue with matched viscosity. The degree of extrapolation from validation to COU is minimal, supporting confidence in model predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence and round-off errors must be assessed and shown to be negligible relative to discretization error for all production simulations.",
      "rationale": "Iterative convergence was assessed through a comprehensive qualitative evaluation of residual behavior and key monitor point stability across all production simulations. Residuals for continuity, momentum, and scalar transport equations were monitored throughout each simulation run. The assessment team reviewed convergence histories and judged that solver errors were negligible relative to other error sources based on the stable plateau behavior observed in hemolysis index monitor points over the final 500 iterations. This qualitative assessment, conducted by an experienced CFD analyst with 15 years of rotating machinery simulation experience, provides sufficient assurance that numerical solver error does not materially affect the credibility conclusion at MRL 2. The assessment is consistent with standard practice in the cardiovascular device simulation community and is supported by the close agreement between simulation and experimental results observed in the output comparison factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Potential for user error in model setup and execution must be identified and mitigated through documented procedures.",
      "rationale": "Simulation setup was performed using a documented standard operating procedure (SOP-CFD-001) covering mesh generation, boundary condition assignment, solver settings, and post-processing. An independent reviewer checked all simulation inputs against the SOP prior to execution. No use errors were identified during the review process."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The mathematical model form must be appropriate for the physics of the COU, with model form assumptions documented and justified.",
      "rationale": "The Reynolds-Averaged Navier-Stokes (RANS) approach with SST k-omega turbulence closure was selected based on published benchmarking studies for centrifugal blood pump flows. The power-law hemolysis model (Giersiepen-Wurzinger) was applied with coefficients calibrated to human red blood cell fragility data. Model form assumptions including Newtonian blood rheology and rigid wall assumption were assessed as appropriate for the flow regime and operating conditions of the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs including geometry, boundary conditions, and material properties must be documented with sources and uncertainty estimates.",
      "rationale": "Pump geometry was derived from the FDA-published CAD files for the generic centrifugal pump. Blood rheology parameters (density 1056 kg/m3, dynamic viscosity 3.5 mPa·s) were sourced from published literature with uncertainty bounds. Inlet boundary conditions were specified as fully developed velocity profiles with 5% turbulence intensity. All model inputs are documented in the simulation technical report with traceability to source data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not applicable at MRL 2 for computational-only assessment where experimental samples are not generated as part of the V&V activities.",
      "rationale": "Test samples factor is not assessed at MRL 2 for this COU. The V&V activities rely on the publicly available FDA benchmark dataset rather than newly generated experimental samples. This is acceptable per ASME V&V 40 Table 3 for MRL 2 assessments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 as the validation dataset uses the same geometry and operating envelope as the COU.",
      "rationale": "Equivalency of input parameters is not assessed separately at MRL 2 because the validation activities were conducted on the identical pump geometry and within the same operating envelope as the COU. The relevance factors address the degree of similarity between validation and COU conditions. This scoping decision is consistent with ASME V&V 40 guidance for MRL 2."
    }
  ],
