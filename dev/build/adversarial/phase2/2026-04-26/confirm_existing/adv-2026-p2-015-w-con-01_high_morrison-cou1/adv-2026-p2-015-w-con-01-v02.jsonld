  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required Gradation levels at MRL 2. Six factors were formally scoped out as not required under the applicable ASME V&V 40 risk matrix for a Class II device at MRL 2. The Model Form factor was evaluated through a comprehensive qualitative assessment supported by multi-model sensitivity analysis and published benchmark comparisons; the resulting confidence is consistent with the overall Accepted determination. The relative hemolysis index criterion (RH < 1) is satisfied with a mean margin of 29%, providing additional confidence in the model's predictive adequacy for the stated COU. The credibility assessment team unanimously concludes that the simulation evidence is sufficient to support regulatory submission for the CPB hemolysis evaluation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
