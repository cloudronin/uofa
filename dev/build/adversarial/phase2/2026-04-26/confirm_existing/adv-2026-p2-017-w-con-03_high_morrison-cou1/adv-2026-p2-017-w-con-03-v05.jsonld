  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented test suite and release notes covering the hemolysis power-law implementation.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional SQA plan. Version-controlled UDFs for power-law hemolysis model; regression test suite executed with zero failures prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical rotating-disk flow must confirm second-order spatial convergence.",
      "rationale": "Method of manufactured solutions applied to rotating-disk Couette flow. Observed order of accuracy 1.97 ± 0.04, confirming second-order spatial discretisation as expected."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for NIH quantity of interest must be below 5% on the fine-grid solution.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 5.8M, 14.6M cells). GCI on NIH at 3 L/min / 3500 RPM is 2.8%, satisfying the 5% threshold. Fine mesh adopted for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) must be documented and reproduced in simulation to within ±2%.",
      "rationale": "PIV and NIH bench tests conducted at 37 °C ± 0.5 °C with Newtonian blood analogue. Flow rates set via calibrated Coriolis meter (±0.5%). CFD inlet profiles matched to within 1.1% of measured bulk flow rate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation metric (E_rel) for NIH across 5 operating points must be below 10% using ASME V&V 20 uncertainty framework.",
      "rationale": "E_rel ranges from 3.1% to 8.7% across all 5 flow-speed combinations when experimental uncertainty (U_exp = 6.2%) and numerical uncertainty (U_num = 2.8%) are propagated. All points within acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH and relative hemolysis index RH) must be directly linked to the clinical endpoint and regulatory acceptance criterion.",
      "rationale": "NIH is the standard ISO 10993-4 haemocompatibility metric; RH < 1 is the FDA-accepted criterion for predicate comparison. Both QoIs are directly traceable to the COU decision criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
