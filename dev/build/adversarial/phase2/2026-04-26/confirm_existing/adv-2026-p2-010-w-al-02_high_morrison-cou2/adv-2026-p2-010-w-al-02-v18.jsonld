  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented test suite; all simulation scripts archived and traceable to results.",
      "rationale": "The CFD solver (OpenFOAM v9) is maintained under Git version control with a comprehensive regression test suite covering 47 canonical flow cases. All simulation input decks, mesh generation scripts, and post-processing routines are archived in the project repository with SHA-256 checksums. Software QA documentation reviewed and found complete for MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions must confirm expected convergence rates for all discretization schemes used in the hemolysis model.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes and scalar hemolysis transport equations confirms second-order spatial convergence (observed order 1.94 on unstructured meshes). Temporal convergence verified separately at first and second order. Code verification complete and documented in verification report VR-COU2-2025."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the production mesh at all five operating points.",
      "rationale": "Three-level mesh refinement study performed (coarse: 4.2M cells, medium: 11.7M cells, fine: 31.4M cells) following Celik et al. GCI methodology. GCI values for hemolysis index range from 1.8% to 3.6% across five operating points on the medium mesh selected for production runs. Asymptotic convergence confirmed; discretization error quantified and within acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be measured and reported with uncertainty; CFD boundary conditions must replicate experimental conditions within measurement uncertainty.",
      "rationale": "Inlet flow rates controlled by Coriolis mass flow meter (±0.5% full scale); rotational speed measured by optical encoder (±0.1 RPM). Fluid temperature maintained at 37°C ± 0.5°C. All five operating points replicated in CFD within the stated measurement uncertainties. Boundary condition fidelity documented in test report TR-COU2-BC-2025."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E_norm) for hemolysis index must fall within experimental uncertainty band at all five operating points; statistical hypothesis test at 95% confidence.",
      "rationale": "Normalized prediction error E_norm computed at all five operating points ranges from 0.03 to 0.18, all within the ±2σ experimental uncertainty band. Two-sample t-test confirms no statistically significant bias (p = 0.23). Output comparison judged satisfactory for absolute hemolysis prediction at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, velocity field) must be the same quantities used in the regulatory submission decision.",
      "rationale": "The normalized index of hemolysis (NIH) computed from CFD shear stress history is the identical metric used in the clinical risk threshold comparison. Velocity field comparison provides secondary QoI validation. No surrogate or proxy quantities employed; QoI relevance is direct and complete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating range, and blood analog fluid as the COU.",
      "rationale": "Validation experiments conducted on the FDA generic centrifugal pump geometry (identical to COU geometry) at all five COU operating points using porcine blood (hematocrit 33±2%) as the test fluid. No geometric simplifications or fluid substitutions introduced. Validation activity relevance rated high; all COU conditions directly covered."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-6 for all transport equations; mass balance error below 0.01%.",
      "rationale": "All simulations run to residual convergence below 1×10⁻⁶ for continuity, momentum, and hemolysis scalar transport. Global mass imbalance confirmed below 0.005% for all five operating points. Convergence histories archived. Numerical solver error assessed as adequately controlled for MRL 5 at gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second qualified analyst; documented checklist of model configuration parameters.",
      "rationale": "An independent senior CFD analyst reviewed all simulation setup files against a 42-item configuration checklist. Two minor discrepancies in turbulence model wall treatment flags were identified and corrected prior to production runs. Final configuration verified by both analysts. Use error controls rated adequate for the required gradation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by comparison against higher-fidelity reference data; hemolysis constitutive model must be validated against literature data spanning the shear stress range encountered in the COU.",
      "rationale": "SST k-ω turbulence model selected based on comparative study against LES reference data for rotating impeller flows; SST k-ω showed lowest velocity field error (3.8% vs. 6.1% for k-ε RNG). Power-law hemolysis constitutive model (Giersiepen et al. coefficients) validated against 14 literature datasets spanning shear stress 1–800 Pa and exposure times 0.001–10 s, covering the full COU operating envelope. Model form uncertainty estimated at ±12% on NIH predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterized with probability distributions; Monte Carlo propagation must yield 95% prediction intervals on hemolysis index at each operating point. A screening sensitivity study is referenced in the UQ documentation.",
      "rationale": "Fourteen uncertain model inputs characterized with probability distributions derived from literature and experimental measurement: inlet flow rate (normal, CV=0.8%), rotational speed (normal, CV=0.05%), blood viscosity (log-normal, CV=12%), hematocrit (normal, CV=6%), and ten hemolysis model coefficients (uniform bounds from literature range). Monte Carlo UQ performed with N=2000 samples using Latin hypercube sampling; 95% prediction intervals computed at all five operating points. The project technical report (Section 4.3) describes a screening sensitivity study performed during model development that identified inlet flow rate and rotational speed as the dominant variance contributors; this screening analysis informed the input distribution prioritization used in the Monte Carlo propagation. Model inputs factor assessed at gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point; sample-to-sample variability characterized and reported.",
      "rationale": "Five independent experimental replicates performed at each of the five operating points (25 total experiments) using fresh porcine blood from separate donors. Inter-replicate coefficient of variation for NIH ranges from 4.2% to 8.7% across operating points. Sample variability incorporated into the experimental uncertainty budget used for output comparison. Test sample factor assessed as meeting gradation 3 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient) must match between validation experiments and COU operating conditions within 5%.",
      "rationale": "Reynolds numbers at all five validation operating points match COU conditions within 1.8–3.4%. Flow coefficients match within 2.1%. Fluid density and viscosity equivalence confirmed via rheometry. Equivalency of input parameters assessed as fully met at gradation 3; no extrapolation from validation to COU conditions required."
    }
  ],
