  "signature": "ed25519:b1c4e7a2f0d3896b5e2a4c8f1d6b3e9a7c0f4d2b8e5a1c7f3d9b6e0a4c2f8d5",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under configuration management with documented verification test suite; all regression tests passing for the hemolysis-relevant turbulence and scalar transport modules.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is under institutional configuration management. A 47-case regression test suite covering turbulence, species transport, and hemolysis scalar models was executed with zero failures prior to the COU2 simulation campaign. Version hash recorded in simulation metadata."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for the hemolysis transport scalar and Navier-Stokes solver demonstrated via manufactured solution or benchmark with observed order within 10% of formal order.",
      "rationale": "Method of manufactured solutions applied to the hemolysis power-law scalar transport equation; observed spatial order of 1.94 versus formal order of 2.0 (3% deviation). Temporal discretisation verified separately via Taylor-Green vortex benchmark."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine-mesh solution; three-level Richardson extrapolation required.",
      "rationale": "Three-level mesh refinement study (4.2M, 11.7M, 31.4M cells) performed at the design-point operating condition. GCI on hemolysis index: 3.1% (fine-to-medium) and 8.9% (medium-to-coarse). Fine mesh adopted for all UQ samples; asymptotic convergence ratio 0.98 confirms monotone convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate physiological fluid properties (viscosity, density) and boundary conditions (flow rate, rotational speed) within stated measurement uncertainty; hematocrit and temperature controlled.",
      "rationale": "FDA pump experiments conducted with porcine blood at 37 ± 0.5 °C, hematocrit 33 ± 2%. Flow rates measured by Coriolis flowmeter (±0.5% FS); rotational speed by optical encoder (±2 RPM). All five COU2 operating points reproduced within stated tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised RMSE of predicted hemolysis index versus experimental values across all five operating points must be below 20%; systematic bias must be characterised.",
      "rationale": "Normalised RMSE of 11.4% across five operating points. Maximum single-point error 17.8% at lowest flow rate, attributed to transitional flow regime. Systematic over-prediction bias of +4.2% identified and documented; conservative for safety margin assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs predicted by the model (hemolysis index, shear stress exposure) must map directly to the clinical acceptance criterion (absolute hemolysis index below 0.8 g/100 L).",
      "rationale": "The model QoI is the normalised index of hemolysis (NIH) expressed as g/100 L, identical to the clinical threshold metric. No surrogate QoI substitution. Shear stress exposure time history extracted along representative streamlines as supporting QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue properties, and operating envelope as the COU; no extrapolation beyond validated range for the five COU operating points.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry identical to the COU model. All five COU operating points fall within the validated flow-speed envelope (2–8 L/min, 2000–3500 RPM). No geometric or operational extrapolation required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations; mass imbalance below 0.01% for each steady-state solution.",
      "rationale": "All 128 Monte Carlo UQ simulations converged to residual norms below 1e-6 for continuity, momentum, and hemolysis scalar. Mass imbalance below 0.005% in all cases. Convergence histories archived per simulation run."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition assignments, material property inputs, and turbulence model selection verified against the approved simulation plan.",
      "rationale": "Independent peer review of simulation setup completed by a senior CFD engineer not involved in model development. Fourteen checklist items verified; two minor discrepancies in wall roughness specification corrected prior to production runs. Corrected setup re-reviewed and approved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Selection of turbulence closure and hemolysis power-law model must be justified against published benchmark data; alternative model forms must be evaluated and documented.",
      "rationale": "SST k-omega turbulence model selected based on published FDA pump benchmark studies (Hariharan et al. 2011). Hemolysis power-law exponents (C=1.8e-6, alpha=0.765, beta=0.425) from Giersiepen et al. validated against Wurzinger experimental data. Realizable k-epsilon and RSM alternatives evaluated; SST showed lowest systematic bias. Model form uncertainty estimated at ±18% of NIH prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterised with probability distributions derived from experimental data or literature; Monte Carlo sampling must propagate input uncertainty to hemolysis index predictions with reported confidence intervals.",
      "rationale": "Monte Carlo UQ performed with 128 Latin hypercube samples across six uncertain input parameters: fluid viscosity, hematocrit, inlet turbulence intensity, hemolysis model coefficient C, exponent alpha, and wall roughness. Input distributions derived from experimental measurement data and published literature. A screening sensitivity study was conducted during the model development phase to rank these parameters by their influence on NIH variance, and its findings were used to prioritise the UQ sampling budget. Predicted NIH 95th-percentile confidence interval reported as 0.31–0.61 g/100 L, below the 0.8 g/100 L clinical threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must include sufficient replicates to characterise biological variability; minimum n=3 independent experiments per operating point.",
      "rationale": "Five independent experimental runs performed at each of the five operating points (n=5 per point, 25 total measurements). Coefficient of variation across replicates ranged from 4.1% to 9.7%, consistent with expected biological variability in porcine blood hemolysis assays."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the validation simulations must match those used in the COU simulations; any differences must be documented with justification that they do not affect model credibility.",
      "rationale": "Validation and COU simulations use identical boundary condition specifications, mesh topology, solver settings, and material property assignments. Fluid temperature in validation (37 °C) matches COU specification. No parameter substitutions or extrapolations identified during equivalency review."
    }
  ],
