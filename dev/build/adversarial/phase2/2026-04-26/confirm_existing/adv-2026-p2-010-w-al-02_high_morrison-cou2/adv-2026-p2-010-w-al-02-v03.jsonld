  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/vv40-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed; achieved levels meet or exceed required levels at Model Risk Level 5. Monte Carlo uncertainty quantification demonstrates that the 95th-percentile hemolysis index prediction (0.61 g/100 L) remains below the clinical threshold (0.80 g/100 L) with adequate margin. Model form uncertainty characterised and bounded. Independent peer review completed without outstanding findings. The UQ campaign was informed by a screening sensitivity study conducted during model development, which identified fluid viscosity and hemolysis power-law coefficient C as the dominant variance contributors and justified the allocation of UQ sampling budget. On the basis of this evidence package, the CFD model is judged credible for its intended use in supporting regulatory submission for the Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
