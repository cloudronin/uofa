      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI less than 5% on hemolysis index QoI across all five operating points.",
      "rationale": "Three-level mesh refinement study performed; GCI values range from 1.8% to 4.3% across operating points. Wall y+ maintained below 1 on all blood-contacting surfaces."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, rotational speed) replicated within 2% of nominal values across all test points.",
      "rationale": "FDA benchmark experimental conditions documented in Hariharan et al. (2011) reproduced with inlet velocity profiles and rotational speeds matched to within 1.5% across all five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized hemolysis index prediction error less than 20% at all five operating points relative to experimental mean; velocity field RMSE less than 10% of peak velocity.",
      "rationale": "Hemolysis index predictions fall within 12–18% of experimental means across all five operating points. PIV velocity field RMSE is 7.4% of peak impeller tip velocity. Quantitative agreement satisfies MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (normalized index of hemolysis, NIH) directly maps to clinical hemolysis threshold; secondary QoIs (shear stress distribution, exposure time) support mechanistic interpretation.",
      "rationale": "NIH is the regulatory-accepted hemolysis metric for VAD submissions. Shear stress and Lagrangian exposure-time distributions are computed as supporting QoIs to inform mechanistic credibility of the power-law hemolysis model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry is the FDA generic centrifugal pump; operating conditions span the clinical VAD envelope; blood analog fluid properties match in-vivo viscosity and density within 5%.",
      "rationale": "Validation performed directly on FDA generic centrifugal pump geometry under operating conditions bracketing the clinical VAD envelope (3–8 L/min, 2500–3500 RPM). Glycerol-water blood analog matches whole-blood viscosity within 3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance of 1e-6 for continuity and momentum; hemolysis index change less than 0.1% over final 500 iterations.",
      "rationale": "All simulations converged to residuals below 1e-6. Hemolysis index monitored as a convergence criterion; variation less than 0.05% over final 500 iterations across all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent simulation review by second analyst; documented simulation setup checklist completed for each operating point.",
      "rationale": "All five simulation setups independently reviewed by a second CFD analyst against a documented 42-item setup checklist. No discrepancies identified. Checklist records archived in project quality management system."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison to DNS or high-fidelity LES data for rotating internal flows; hemolysis power-law model coefficients sourced from peer-reviewed calibration studies.",
      "rationale": "SST k-omega turbulence model selected based on published LES comparison for rotating pump geometries (Byskov et al.). Giersiepen-Wurzinger power-law hemolysis model coefficients taken from Taskin et al. calibration. Model form uncertainty acknowledged in UQ narrative."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs characterized with probability distributions; Monte Carlo propagation performed with minimum 1000 samples; 95% prediction intervals reported for hemolysis index at each operating point. A screening sensitivity study was conducted to rank input contributions prior to Monte Carlo sampling.",
      "rationale": "Fourteen uncertain input parameters — including blood viscosity, hemolysis model coefficients (C, alpha, beta), inlet velocity profile shape, and surface roughness — were assigned probability distributions based on literature data. Monte Carlo UQ with 1500 Latin Hypercube samples was executed. The UQ report notes that a one-at-a-time screening sensitivity study was conducted to prioritize parameter ranges prior to the full Monte Carlo run; this screening identified hemolysis coefficient C and shear exponent alpha as potentially dominant drivers. However, a formal variance-based or rank-correlation sensitivity analysis was not completed, and no structured sensitivity analysis record has been linked to this assessment package. The 95% prediction intervals on NIH span ±16% to ±23% across operating points, satisfying the acceptance criterion despite the uncharacterized input driver ranking."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point; inter-laboratory reproducibility data available for at least two operating points.",
      "rationale": "FDA benchmark dataset provides five independent experimental replicates per operating point from the FDA interlaboratory study (Hariharan et al. 2011, Stewart et al. 2012). Inter-laboratory coefficient of variation on NIH ranges from 8% to 14% across operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Fluid properties, boundary conditions, and geometric parameters in the simulation match experimental conditions within stated tolerances; any deviations documented and assessed for impact.",
      "rationale": "All simulation input parameters cross-referenced against experimental measurement reports. Pump impeller geometry reconstructed from FDA-published CAD; dimensional deviations less than 0.05 mm. Fluid property deviations documented and assessed as having less than 2% impact on NIH predictions."
    }
