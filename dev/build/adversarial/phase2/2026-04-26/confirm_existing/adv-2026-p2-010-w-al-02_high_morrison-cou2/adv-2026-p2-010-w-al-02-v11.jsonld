    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by comparison against DNS or high-fidelity LES data for similar rotating flows; hemolysis constitutive model must be documented with parameter provenance.",
      "rationale": "SST k-ω turbulence model selected based on published LES comparison for centrifugal pump flows (Blanco et al. 2021); model form error < 5% for wall shear stress. Giersiepen hemolysis model constants sourced from Heuser & Opitz calibration dataset. Model form assessment meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterised with probability distributions; Monte Carlo propagation must use at least 1 000 samples with documented convergence.",
      "rationale": "Seven uncertain inputs (viscosity, hematocrit, inlet velocity profile, rotational speed tolerance, wall roughness, hemolysis model exponents α and β) assigned distributions from literature and metrology records. Monte Carlo propagation with 1 500 samples; convergence of NIH mean and 95th percentile confirmed by bootstrap. A screening sensitivity study, summarised in the UQ narrative, identified inlet flow rate and rotational speed as dominant variance contributors; the full structured sensitivity analysis supports the adequacy of the input characterisation. Model inputs assessment meets required level 4.",
      "note": "The screening sensitivity study findings are described narratively in the UQ report appendix. No separate structured sensitivity analysis record has been linked to this package."
