  "signature": "ed25519:9c4e2a1f7b3d5e8c0a6f4b2e9d7c5a3f1e8b6d4c2a0f9e7d5c3b1a8f6e4d2c0",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented test suite; all simulation scripts must be archived and reproducible.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional license with documented release validation suite. All case files, boundary condition scripts, and post-processing routines stored in institutional GitLab repository with tagged release corresponding to submission. Independent re-run confirmed identical results. SQA level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified against analytical solutions or established benchmarks for laminar and turbulent internal flow; hemolysis power-law implementation must be verified against published reference data.",
      "rationale": "Solver verified against Poiseuille flow (laminar), Womersley oscillatory flow, and the FDA nozzle benchmark (turbulent). Hemolysis power-law (Giersiepen-Wurzinger) implementation verified against published tabulated results. All errors within expected floating-point tolerance. Code verification level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must be performed; GCI must be reported for all primary QoIs; discretization error must be included in total uncertainty budget.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 11.7M, 31.4M cells). Richardson extrapolation yields GCI < 2.1% for hemolysis index, wall shear stress, and impeller exit velocity. Discretization uncertainty incorporated into Monte Carlo uncertainty budget as a bounded interval. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions must be documented with traceable measurement uncertainty; operating conditions must span the COU envelope.",
      "rationale": "In-vitro hemolysis measurements performed at all five COU operating points using bovine blood with documented hematocrit (35±2%) and temperature (37±0.5°C). Flow rates measured with Coriolis meter (±0.3% FS), pressure with calibrated transducers (±0.5% FS). Test conditions fully documented with NIST-traceable calibration certificates. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) must be computed for each operating point; comparison must account for both experimental and simulation uncertainty.",
      "rationale": "Normalized error E% computed at all five operating points: range 3.1%–11.4%. Validation metric computed per ASME V&V 20 incorporating both experimental uncertainty and simulation numerical uncertainty. At all points, |E| < u_val, indicating model is within validation uncertainty. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be the same as, or directly related to, the QoIs used in the regulatory submission context.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH, g/100L) measured directly in both in-vitro experiments and CFD post-processing using identical power-law integration. No surrogate QoIs used. Direct correspondence between validation and COU QoIs confirmed. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow regime, and blood analog that are representative of the COU device and operating envelope.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry — the same geometry used in the COU. Operating envelope (2–6 LPM, 2000–3500 RPM) matches COU specification. Bovine blood used as analog with documented rheological properties. Turbulence regime (Re 8000–22000) consistent across validation and COU. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated; residuals must reach steady-state or periodic convergence; solver settings must be documented.",
      "rationale": "All simulations run to residual convergence < 1e-5 for continuity, momentum, and turbulence equations. Mass imbalance < 0.01% at all operating points. Steady-state confirmed by monitoring hemolysis index and impeller torque over last 500 iterations. Solver settings (relaxation factors, discretization schemes) fully documented. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence that the model was applied correctly by qualified personnel; independent review of boundary condition setup and post-processing.",
      "rationale": "Simulation setup reviewed independently by a second CFD engineer not involved in model development. Boundary conditions, turbulence model selection, and hemolysis post-processing scripts verified against documented simulation plan. No discrepancies identified. User qualification documented. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified for the flow regime; hemolysis model form must be appropriate for the shear history and exposure time range in the device.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark comparisons for rotating internal flows with adverse pressure gradients. Giersiepen-Wurzinger power-law hemolysis model applicable for exposure times 0.001–0.7 s and shear stresses 50–400 Pa — ranges confirmed to encompass the pump operating envelope via Lagrangian particle tracking. Model form uncertainty estimated and included in UQ budget. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be identified and their distributions characterized; input uncertainty must be propagated to QoI uncertainty.",
      "rationale": "Six uncertain inputs identified: inlet velocity profile shape, blood dynamic viscosity, hematocrit, hemolysis model coefficients (alpha, beta), and wall roughness. Distributions assigned based on literature and measurement data. All six inputs propagated via Monte Carlo (n=2000) to hemolysis index output distribution. A screening sensitivity study described in the project technical report was used to prioritize these inputs during model development; however, the formal sensitivity analysis record has not been linked to this assurance package as a structured artifact. Input characterization achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient replicate measurements to characterize experimental variability; sample size justification provided.",
      "rationale": "Three independent test runs performed at each of the five operating points using fresh bovine blood samples from separate draws. Coefficient of variation for NIH across replicates < 8% at all points, consistent with published inter-laboratory variability for this assay. Sample size deemed sufficient for MRL 5 requirements given the narrow CV. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Boundary conditions and material properties used in the simulation must be demonstrably equivalent to those in the validation experiments and the COU.",
      "rationale": "Inlet boundary conditions derived from PIV measurements on the FDA generic pump at matched flow rates; velocity profiles imported directly into CFD as tabulated boundary data. Blood viscosity and density set to experimentally measured values from the same blood batch used in hemolysis tests. Hematocrit matched to within 1% between simulation inputs and experimental samples. Equivalency confirmed for all five operating points. Achieved level 4."
    }
  ],
