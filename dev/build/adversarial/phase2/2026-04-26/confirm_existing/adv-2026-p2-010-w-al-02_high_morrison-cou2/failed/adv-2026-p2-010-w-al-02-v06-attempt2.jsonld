  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-piv-measurements",
    "https://uofa.net/synth/data/hemolysis-in-vitro-5op-points"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-mc-uq-result",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ validation — absolute hemolysis index across 5 operating points",
      "description": "Monte Carlo sampling (n=2000) over inlet boundary condition variability and blood viscosity uncertainty. Predicted hemolysis index distributions compared against in-vitro measurements at all five flow-speed combinations. 90th-percentile predicted HI remained below clinical threshold at all points. A screening sensitivity study referenced in the technical report identified inlet velocity profile as the dominant contributor, but this analysis is documented informally and has not been linked as a structured sensitivity analysis record in this package."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification for centrifugal pump CFD",
      "description": "Richardson extrapolation applied across three mesh refinement levels (4.2M, 11.7M, 31.4M cells). Grid convergence index computed for shear stress and velocity magnitude at impeller exit. GCI < 2.1% for all QoIs on the fine mesh. Discretization error included in total uncertainty budget."
    }
  ],
