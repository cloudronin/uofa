      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, operating envelope, and blood analogue as the COU; any deviations formally quantified.",
      "rationale": "FDA generic pump geometry matches COU geometry. Experiments used glycerol-water analogue rather than porcine blood; viscosity matched but viscoelastic effects uncharacterised. Operating envelope partially overlaps COU range. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual < 1e-6 for all equations; demonstration that solver round-off does not affect hemolysis QoI.",
      "rationale": "Momentum residuals converge to 1e-5; hemolysis scalar residual stalls at 1e-4 at high-speed operating points. Round-off analysis not performed. Gradation 2 achieved."
    },
