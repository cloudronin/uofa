  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed; required levels met or exceeded across all factors. Monte Carlo UQ (2000 Latin hypercube samples) demonstrates 95th-percentile NIH of 0.0082 g/100 L, below the clinical threshold of 0.01 g/100 L across all five COU operating points. Systematic over-prediction bias of 8% is conservative. A screening sensitivity study conducted during model development qualitatively identified exposure-time integration path and turbulent viscosity ratio as dominant inputs; these findings are summarised in the UQ narrative. The credibility assessment team considers the evidence sufficient to support regulatory submission at MRL 5 for this Class III device.",
    "decidedAt": "2026-04-19T00:00:00Z"
