  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version-controlled release with documented unit and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "The commercial CFD solver (ANSYS Fluent 2022R2) is under ISO 9001-certified QMS. Regression test suite of 412 cases executed at each release; all hemolysis-relevant turbulence and transport model tests pass. Version control and release notes archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions for the Navier-Stokes and scalar transport equations employed in the hemolysis model.",
      "rationale": "Method of manufactured solutions applied to the power-law hemolysis scalar transport equation. Observed order of accuracy (1.92) is consistent with the nominal second-order spatial discretisation. Verification report VER-CFD-2023-07 on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be < 5% on the production mesh; three-mesh Richardson extrapolation required.",
      "rationale": "Three-level structured-hex mesh sequence (4.1 M, 11.3 M, 30.7 M cells) used. GCI on normalised hemolysis index: 3.2% (fine-to-medium), 1.1% (medium-to-coarse ratio check). Production mesh is the 11.3 M cell mesh; GCI 3.2% satisfies the < 5% criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) must be reproduced in simulation to within measurement uncertainty.",
      "rationale": "Five operating points (3–6 L/min, 2000–3500 RPM) replicated from FDA bench protocol. Inlet velocity profiles derived from ultrasonic Doppler measurements; fluid viscosity matched to within 1.5% of reported phosphate-buffered saline analogue properties."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalised index of hemolysis (NIH) must fall within ±20% of experimental mean across all five operating points; systematic bias must be characterised.",
      "rationale": "Predicted NIH agrees with experimental mean within 12–18% across all five operating points. Systematic over-prediction of 8% at high-shear conditions is documented and attributed to power-law model calibration range. Bias is conservative (over-predicts hemolysis) and is acceptable for regulatory submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (absolute NIH) must be directly mapped to the clinical acceptability criterion without intermediate surrogate transformation.",
      "rationale": "NIH is directly compared against the clinical threshold of 0.01 g/100 L. No surrogate or relative-to-predicate normalisation is applied. QoI mapping documented in COU2 requirements traceability matrix RTM-COU2-2024."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and fluid analogue as the COU; operating envelope of validation cases must bracket the COU operating envelope.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry identical to the COU device. Operating envelope of validation cases (2000–3500 RPM, 3–6 L/min) fully brackets the COU envelope (2500–3200 RPM, 4–5.5 L/min). Fluid analogue viscosity and density within 2% of clinical blood analogue."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of hemolysis scalar residuals to < 1e-5; mass imbalance < 0.01% at each operating point.",
      "rationale": "All five operating-point simulations converged to hemolysis scalar residual < 8e-6. Global mass imbalance < 0.004%. Convergence histories archived in run logs RL-COU2-OP1 through RL-COU2-OP5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; checklist-based review covering boundary condition assignment, material property entry, and post-processing scripts.",
      "rationale": "Independent peer review completed by senior CFD engineer not involved in original setup. 47-item checklist (BC assignment, material properties, solver settings, post-processing) signed off. Two minor discrepancies (inlet turbulence intensity entry) identified and corrected prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The power-law hemolysis model must be assessed for applicability to the shear-stress and exposure-time ranges present in the VAD COU; model-form uncertainty must be bounded.",
      "rationale": "Power-law exponents (C=3.62e-7, alpha=2.416, beta=0.785) validated against Wurzinger et al. and Giersiepen et al. datasets. Shear stress range in COU (10–450 Pa) falls within calibration envelope. Model-form uncertainty estimated at ±15% NIH via comparison with two alternative hemolysis models; this is included in the Monte Carlo UQ distribution. A screening sensitivity study performed during model selection identified exposure-time integration path and turbulent viscosity ratio as the two inputs with highest qualitative influence on NIH; these findings are discussed in the UQ report narrative but were not carried forward into a formal ranked sensitivity analysis linked to this assessment package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterised with probability distributions derived from measurement data or literature; distributions must be documented and traceable.",
      "rationale": "Twelve uncertain inputs identified: power-law coefficients (3), fluid viscosity, inlet flow rate, rotational speed, wall roughness, turbulence intensity, turbulent Prandtl number, and three geometric tolerances. Distributions (normal, log-normal, uniform) assigned from calibration datasets and manufacturer tolerances. Input characterisation documented in UQ plan UQP-COU2-2024. Note: relative influence of these twelve inputs on NIH variance has not been formally ranked via a structured sensitivity analysis; the UQ plan references a qualitative screening exercise but no Sobol indices or Morris screening indices are reported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must include at least three independent replicates per operating point; inter-replicate variability must be reported.",
      "rationale": "FDA bench dataset provides five independent replicates per operating point (n=25 total). Coefficient of variation across replicates: 6–11%. Inter-replicate variability incorporated into experimental uncertainty bands used in output comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to experimental conditions; any deviations must be assessed for impact on QoI.",
      "rationale": "Fluid density and viscosity in simulation match experimental analogue within 1.5%. Rotational speed boundary condition matches tachometer measurements within 0.3%. Inlet flow rate matches Coriolis meter measurements within 0.8%. No deviations exceed 2%; impact on NIH assessed as negligible via perturbation runs."
    }
  ],
