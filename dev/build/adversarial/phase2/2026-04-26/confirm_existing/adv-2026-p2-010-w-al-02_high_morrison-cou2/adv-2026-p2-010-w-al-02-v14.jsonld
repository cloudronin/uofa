  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/piv-velocity-field-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic centrifugal pump",
      "description": "Particle image velocimetry measurements compared against CFD-predicted velocity fields at three operating points. Normalized RMS error below 8% across all measurement planes. Provides primary spatial validation evidence for the hemolysis-relevant flow structures."
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-absolute-comparison",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index validation against in-vitro measurements",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against five in-vitro measurements spanning the VAD operating envelope. Monte Carlo UQ bounds (5th–95th percentile) reported for each prediction. The accompanying project technical report notes a screening sensitivity study was performed identifying inlet turbulence intensity and blood viscosity as potentially influential parameters; however, no ranked sensitivity indices are formally linked here."
    },
