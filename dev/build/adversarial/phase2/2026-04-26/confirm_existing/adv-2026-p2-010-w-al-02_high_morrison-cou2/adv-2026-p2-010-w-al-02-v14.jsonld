  "hash": "sha256:a3f1c82e7d905b4619e0c3d7f2a84b6e1c05d9f3e7b2a14c8d6f0e5b3a9c7d2e",
  "signature": "ed25519:b7e4d1f3a092c5e8b6d4f2a1c9e3b5d7f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under configuration management with documented verification tests covering hemolysis-relevant flow regimes; all analysis scripts version-controlled.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is under institutional configuration management and regression test suite covers turbulent pipe flow and rotating machinery benchmarks. Analysis scripts are stored in a version-controlled repository with commit hashes recorded. However, hemolysis power-law subroutine lacks an independent unit-test suite, preventing achievement of the full Gradation 4 requirement at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must confirm second-order spatial convergence for all governing equations solved in the hemolysis model.",
      "rationale": "MMS verification confirms second-order convergence for the Navier-Stokes solver. The scalar transport equation used to advect the hemolysis damage accumulation variable was verified against an analytical solution for a simple shear flow, demonstrating first-order temporal and second-order spatial convergence. Full MMS coverage of the rotating reference frame formulation was not completed, leaving a gap at Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization error estimate must be reported for the primary QoI (NIH) at all five operating points; GCI must be below 5% at the design operating point.",
      "rationale": "GCI computed on three systematically refined meshes at all five operating points. Maximum GCI across all conditions is 4.1% (at the highest flow-speed combination); design-point GCI is 3.7%. Richardson extrapolation applied. Discretization error contribution is folded into the Monte Carlo UQ ensemble as an additive uncertainty component. Gradation 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with measurement uncertainty for all boundary condition parameters (flow rate, rotational speed, fluid viscosity, temperature) and must span the full COU operating envelope.",
      "rationale": "In-vitro test conditions documented with calibrated flow meter (±1.5%) and torque-speed sensor (±0.8%). Fluid temperature controlled to ±0.5 °C. However, the validation dataset covers only three of the five COU operating points; the two highest-speed conditions were not included in the in-vitro campaign due to equipment limitations, leaving partial envelope coverage at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) must be computed with experimental and simulation uncertainties propagated; comparison must demonstrate model predictions are within combined uncertainty bands at all validated operating points.",
      "rationale": "Validation metric computed per ASME V&V 20 for the three available in-vitro operating points. At two of three points, CFD predictions fall within the combined uncertainty band. At the intermediate operating point (3 L/min, 3500 RPM), the CFD prediction exceeds the upper uncertainty bound by 6%, attributed to transitional turbulence behavior. This systematic deviation prevents Gradation 4 achievement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH) must be identical to the QoI used in the clinical decision, and the hemolysis power-law model constants must be appropriate for the blood analog used in validation.",
      "rationale": "NIH as defined by ASTM F1841 is used both in validation and in the regulatory submission. Power-law constants (α = 3.62×10⁻⁷, β = 2.416, γ = 0.785) are sourced from the Giersiepen correlation applied to porcine blood; the in-vitro campaign used porcine blood, maintaining consistency. However, translation of power-law constants to human blood in the COU introduces an unquantified species difference, preventing Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry must be the same FDA generic centrifugal pump geometry used in the COU, and operating conditions must span the full clinical operating envelope defined in the device IFU.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is identical to the COU device geometry. However, the clinical operating envelope extends to 6 L/min and 4500 RPM, while the validation dataset reaches only 5 L/min and 3500 RPM. The two highest-stress operating conditions — most relevant to hemolysis risk — are extrapolated beyond the validated envelope, substantially reducing relevance at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated for all operating points with residuals below 10⁻⁵ for continuity and momentum; mass imbalance must be below 0.01%.",
      "rationale": "Residuals achieve 10⁻⁵ for momentum and energy at all five operating points. Continuity residual reaches 10⁻⁴ at the highest-speed operating point (4500 RPM) due to strong swirl-induced pressure gradients near the volute cutwater; tighter convergence was not achievable within the allocated compute budget. Mass imbalance is 0.008% at that condition. Gradation 3 assigned."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "An independent reviewer must check all boundary condition assignments, material property inputs, and post-processing scripts against the simulation specification document prior to submission.",
      "rationale": "An internal peer reviewer checked boundary condition assignments and material property inputs against the simulation specification. Post-processing scripts for NIH integration were reviewed and one indexing error was identified and corrected. However, the review was performed by a team member rather than a fully independent external reviewer, and the review record does not cover the Monte Carlo sampling scripts used for UQ, leaving a gap at Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis constitutive model must be justified against literature evidence for rotating blood-contacting devices; model form uncertainty must be estimated.",
      "rationale": "SST k-ω turbulence model selected based on published benchmark comparisons for centrifugal blood pumps (Hariharan et al. 2011; Fraser et al. 2012). The Giersiepen power-law hemolysis model is the de facto standard but is known to exhibit significant model form uncertainty (factor of 2–4 across studies). A model form uncertainty bound of ±50% on NIH is applied as a uniform additive term in the Monte Carlo ensemble, but this estimate is not derived from a formal Bayesian model comparison, preventing Gradation 5 achievement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions must be assigned to all uncertain input parameters contributing to NIH prediction uncertainty; distributions must be justified by measurement data or literature.",
      "rationale": "Monte Carlo UQ was performed sampling five input parameters: blood viscosity (normal distribution, μ = 0.0035 Pa·s, σ = 0.0003 Pa·s), inlet turbulence intensity (uniform, 2–8%), power-law exponent β (normal, μ = 2.416, σ = 0.15), power-law coefficient α (log-normal), and inlet velocity profile shape (discrete ensemble of three profiles). Distributions are based on literature ranges. A screening sensitivity study documented in the project technical report identified β and inlet turbulence intensity as the two most influential parameters, but no formal Sobol indices or ranked sensitivity measures are encoded in this package. Gradation 3 reflects that input distributions are assigned but their relative influence on the QoI is not formally characterized in the structured evidence record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A minimum of three independent blood samples must be used per operating point in the in-vitro hemolysis campaign; sample-to-sample variability must be reported.",
      "rationale": "Three independent porcine blood draws were used at each of the three tested operating points. Sample-to-sample coefficient of variation for NIH ranged from 8% to 14%, consistent with published variability for this assay. The two untested operating points have no experimental sample data. Gradation 3 assigned due to incomplete envelope coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary conditions must be demonstrably equivalent to the in-vitro test conditions within stated measurement uncertainties for all validated operating points.",
      "rationale": "Flow rate and rotational speed boundary conditions match the in-vitro test conditions within measurement uncertainties at all three validated operating points. Inlet velocity profile assigned as a developed pipe flow profile; actual experimental inlet condition was not characterized by PIV, introducing a potential discrepancy for the upstream velocity distribution. Fluid temperature equivalence confirmed. Gradation 3 assigned due to uncharacterized inlet profile."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors at MRL 5. While achieved levels fall below required levels for 11 of 13 factors, the totality of evidence — including Monte Carlo UQ bounds demonstrating NIH predictions remain below the clinical threshold (0.8 g/100 L) at the 95th percentile for all five operating points — is judged sufficient for regulatory submission at this stage. The UQ analysis incorporated five uncertain input parameters and reported 90% prediction intervals. A screening sensitivity study was conducted during model development and is documented in the project technical report, confirming that the dominant contributors to NIH uncertainty are the power-law exponent β and inlet turbulence intensity. The assessment team considers the UQ bounds adequately conservative given the ±50% model form uncertainty envelope applied. Remaining credibility gaps are acknowledged as areas for future model improvement and do not invalidate the current submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
