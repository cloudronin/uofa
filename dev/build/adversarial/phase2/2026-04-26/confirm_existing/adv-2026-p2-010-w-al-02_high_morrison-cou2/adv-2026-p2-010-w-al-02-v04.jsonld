  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control, regression testing suite, and documented release procedures must be in place for the CFD solver and all post-processing scripts.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is under formal version control with regression test suites covering hemolysis post-processing routines. All scripts are archived in a validated repository with audit trail. Achieved level equals required level for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include comparison against analytical solutions or established benchmark problems for rotating-frame Navier-Stokes and scalar transport equations used in the hemolysis model.",
      "rationale": "Numerical code verification was performed against the FDA nozzle benchmark (FDA Critical Path) and a rotating-disk analytical solution. Residuals and order-of-accuracy checks confirm correct implementation of the power-law hemolysis transport scalar."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index and pressure rise at all five operating points; GCI must be below 5% for the primary QoI.",
      "rationale": "Richardson extrapolation and GCI analysis performed on three systematically refined meshes (4.2 M, 11.7 M, 28.4 M cells). GCI for hemolysis index at the worst-case operating point is 3.8%. Discretization error is bounded and included in the UQ input uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, hematocrit, temperature, rotational speed) must be documented and matched within stated tolerances in the simulation boundary conditions.",
      "rationale": "All five experimental operating points are replicated in the CFD model with fluid properties matched to the porcine blood analogue (glycerol-water, 42% hematocrit). Temperature variation of ±1°C is within the tolerance band used for the UQ input distributions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (NRMSE, validation uncertainty Uval) must be reported for hemolysis index predictions against experimental measurements at each operating point.",
      "rationale": "NRMSE of 8.2% and validation uncertainty Uval of 0.11 NIH (normalised index of hemolysis) computed across all five operating points. Simulation outputs fall within experimental uncertainty bounds at four of five points; the fifth point discrepancy is attributed to inlet swirl uncertainty and is captured in the Monte Carlo UQ ensemble."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs (normalised hemolysis index, local shear stress maxima) must be directly linked to the clinical acceptance criterion (absolute hemolysis threshold) with no intermediate transformation that introduces unquantified uncertainty.",
      "rationale": "The hemolysis index is computed directly from the Giersiepen-Wurzinger power-law model applied to Lagrangian particle trajectories. The QoI is dimensionally consistent with the clinical threshold (NIH < 0.1 g/100 L) without additional scaling. Relevance is high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (FDA generic centrifugal pump) and operating regime as the COU; blood analogue properties must be representative of clinical blood.",
      "rationale": "Validation activities use the FDA generic centrifugal pump at identical flow-speed combinations as the COU. The blood analogue (42% hematocrit glycerol-water) is an accepted surrogate for porcine and human blood in hemolysis studies per ASTM F1841."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated via residual monitoring; solver round-off and floating-point error must be bounded relative to discretization error.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum; mass imbalance is below 0.01%. Double-precision arithmetic used throughout; round-off error is negligible relative to the 3.8% GCI-derived discretization uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence of independent review of simulation setup, boundary condition specification, and post-processing scripts by a qualified CFD analyst not involved in the original simulation.",
      "rationale": "An independent CFD analyst reviewed the simulation setup documentation, boundary condition files, and hemolysis post-processing scripts. No errors were identified. Reviewer sign-off is archived in the project quality record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis constitutive model must be justified relative to the flow regime (Re, Womersley number) and the power-law exponents must be drawn from peer-reviewed sources appropriate for the shear-stress range encountered.",
      "rationale": "SST k-omega turbulence model selected based on rotational flow benchmark studies. Giersiepen-Wurzinger hemolysis model exponents (α=0.785, β=2.416, C=3.62e-7) sourced from Wurzinger et al. 1986 and confirmed appropriate for the shear-stress range 10–500 Pa encountered in the pump. Model form uncertainty is included in the UQ budget as a discrete scenario uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters must have assigned probability distributions based on experimental characterisation or published data; distributions must be propagated through Monte Carlo UQ with at least 500 samples.",
      "rationale": "Eleven uncertain inputs (fluid viscosity, hematocrit, inlet velocity profile shape, rotational speed tolerance, wall roughness, hemolysis model exponents, and temperature) are assigned distributions from experimental characterisation data. Monte Carlo propagation uses 1000 Latin hypercube samples per operating point. A screening sensitivity study performed during model development informed the selection and bounding of input distributions; the study identified inlet swirl angle and hemolysis exponent α as the parameters with the largest contribution to output variance, and their distributions were subsequently tightened using additional experimental data. All 95th-percentile hemolysis index predictions remain below the clinical threshold of 0.1 NIH."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must include sufficient replicates (n ≥ 5 per operating point) to characterise measurement variability; sample-to-sample variability must be reported.",
      "rationale": "Seven replicate hemolysis measurements per operating point were performed. Coefficient of variation across replicates ranges from 4.1% to 9.7%. Measurement variability is incorporated as an additive uncertainty component in the validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the validation simulations must be demonstrably equivalent to those used in the COU simulations; any differences must be documented and their impact on QoI assessed.",
      "rationale": "Validation and COU simulations share identical boundary condition specifications. The only difference is rotational speed: validation uses 3500 RPM nominal while COU spans 3000–4500 RPM. The additional operating points are within the validated flow regime and the hemolysis model has been exercised across the full speed range in the UQ ensemble."
    }
  ],
