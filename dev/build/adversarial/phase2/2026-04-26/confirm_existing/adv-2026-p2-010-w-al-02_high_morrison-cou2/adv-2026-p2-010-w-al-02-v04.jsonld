  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and achieved levels meet or exceed required levels at MRL 5. Monte Carlo uncertainty quantification with 1000 samples per operating point demonstrates that 95th-percentile hemolysis index predictions remain below the clinical threshold of 0.1 NIH across all five VAD operating conditions. Validation uncertainty is quantified and within acceptable bounds. The assessment team is satisfied that the CFD model provides sufficient credibility to support the regulatory submission for the Class III VAD device.",
