  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite, version control, and regression testing consistent with MRL 5 requirements.",
      "rationale": "The commercial CFD solver (ANSYS Fluent 2022R2) is under ISO 9001-certified QMS; regression test suite covers all relevant turbulence and hemolysis sub-models. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification must confirm correct numerical implementation of governing equations.",
      "rationale": "MMS verification confirms second-order spatial accuracy for both velocity and scalar hemolysis transport equations. Temporal discretization verified via Richardson extrapolation on a canonical rotating-disk problem."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all QoIs at all five operating points; GCI must be below 5% for hemolysis index.",
      "rationale": "Three-level mesh refinement study performed; GCI ranges from 4.8% to 11.2% across operating points. The highest GCI values occur at off-design conditions. Achieved level (3) falls below required level (4) due to insufficient convergence at two operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with uncertainty bounds; fluid temperature, hematocrit, and flow rate must be controlled and reported.",
      "rationale": "FDA benchmark experimental data provides flow rate and pressure head with stated uncertainty. Hematocrit and blood analog viscosity are documented. Temperature control is reported for bench tests. Minor gap in shear exposure history documentation reduces achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must be compared to experimental measurements with statistical metrics (RMSE, bias, coverage of prediction intervals) reported.",
      "rationale": "Hemolysis index predictions compared to FDA benchmark data at five operating points. RMSE is 18% of mean experimental value; 80% of predictions fall within experimental uncertainty bands. Prediction interval coverage from Monte Carlo UQ is 74%, slightly below the 80% threshold required for level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis, NIH) must be directly relevant to the clinical decision criterion and match the regulatory submission metric.",
      "rationale": "NIH is the regulatory-accepted hemolysis metric for VAD submissions per FDA guidance. The computational QoI is identical to the clinical acceptance criterion. No surrogate or proxy metric is used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating range, and fluid as the COU; any deviations must be justified and bounded.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry, which is a simplified representative geometry rather than the actual device. Operating range overlap is 80%. Blood analog fluid properties match within stated bounds. Geometry simplification reduces achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria must be documented; residuals must reach at least 1e-5 for all equations; mass imbalance must be below 0.1%.",
      "rationale": "Residuals reach 1e-4 for momentum and continuity equations; hemolysis scalar transport equation residuals plateau at 5e-4 at two operating points. Mass imbalance is 0.08%. Incomplete scalar convergence at off-design points reduces achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocols, independent review of model setup, and checklist-based QA review must be completed and archived.",
      "rationale": "Simulation protocol is documented and archived. Independent internal review was performed. However, no external independent verification of boundary condition setup was conducted, and the checklist was not formally signed off by a second analyst. Achieved level is 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis model form (power-law or mechanistic) must be justified relative to the flow regime; turbulence model selection must be validated against benchmark shear stress data.",
      "rationale": "Power-law hemolysis model (Giersiepen-Wurzinger) is used. Turbulence model is SST k-omega. Benchmark comparisons show acceptable pressure-head predictions but hemolysis model form is known to have significant uncertainty under complex recirculating flows present in VAD operation. No alternative model form comparison was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterized with probability distributions; Monte Carlo sampling must propagate input uncertainty to QoI predictions; a screening sensitivity study must identify dominant input drivers.",
      "rationale": "Monte Carlo UQ was performed with 1,200 samples propagating uncertainty in viscosity, hematocrit, hemolysis model coefficients, and rotational speed. Input distributions were assigned based on literature and measurement uncertainty. A screening sensitivity study described in the technical report identified rotational speed and inlet flow rate as dominant contributors to hemolysis index variance. The structured sensitivity analysis results are embedded in the UQ narrative and confirm that these two inputs account for approximately 78% of output variance. Achieved level is 3 due to limited characterization of wall shear stress model input uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental replicates must be sufficient to characterize biological and measurement variability; minimum of three independent replicates per operating point required.",
      "rationale": "FDA benchmark dataset provides two to three replicates per operating point. Biological variability in blood analog properties across replicates is not fully characterized. Sample size is insufficient to distinguish measurement uncertainty from biological variability at MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Computational boundary conditions must be shown equivalent to experimental conditions within stated uncertainty bounds; any non-equivalencies must be quantified.",
      "rationale": "Inlet velocity profiles matched to experimental PIV measurements within 5%. Outlet pressure boundary condition matched to experimental back-pressure within measurement uncertainty. Rotational speed equivalency confirmed. Minor non-equivalency in inlet turbulence intensity specification (assumed 5% versus unmeasured experimental value) reduces achieved level to 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction is accepted at the current assurance level. Monte Carlo uncertainty quantification has been completed across all five operating points with 1,200 samples, propagating uncertainty in the four dominant input categories. The UQ results and associated screening sensitivity study described in the technical report provide confidence that the prediction intervals are meaningful. While several credibility factors show achieved levels below required levels — notably model form (2 vs 4), numerical solver error (2 vs 3), and discretization error (3 vs 4) — the overall evidence package is sufficient to support a conditional acceptance with acknowledged limitations. The decision is accepted with the understanding that the model form uncertainty represents the largest unresolved credibility gap and should be addressed in subsequent assessments.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
