      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI is the normalized index of hemolysis (NIH) directly used in the regulatory submission; secondary QoIs (shear stress distribution) are also tracked.",
      "rationale": "NIH is the direct regulatory QoI and is the primary model output. Shear stress distribution is tracked as a secondary QoI to support mechanistic interpretation. Achieved gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic pump geometry under VAD operating conditions (flow rates 2–8 L/min, speeds 2000–3500 RPM).",
      "rationale": "Validation experiments used the FDA generic pump geometry at four of the five target operating points. The fifth point (8 L/min, 3500 RPM) was extrapolated from the validation dataset. Achieved gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual < 1e-6 for all equations; floating-point round-off assessed via double-precision comparison.",
      "rationale": "Residuals converged to 1e-5 for continuity and momentum; hemolysis scalar residual stalled at 3e-5 for two operating points. Double-precision comparison not performed. Achieved gradation 2."
    },
