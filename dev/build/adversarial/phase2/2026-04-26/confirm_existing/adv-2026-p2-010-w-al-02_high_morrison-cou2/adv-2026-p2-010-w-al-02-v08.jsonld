  "signature": "ed25519:b1d4f7a2c9e305b8d1f6a3c07e2b94d5f8a1c3e6b0d2f5a8c1e4b7d0f3a6c9e2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering blood-analog fluid properties; formal change-control process in place.",
      "rationale": "The CFD solver is under version control and a regression test suite exists, but the test suite does not include blood-analog viscosity models specifically. Change-control documentation is incomplete for the hemolysis submodel. Achieved level 3 is below the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification for all governing equations including the hemolysis power-law transport equation using manufactured solutions.",
      "rationale": "Order-of-accuracy verification was completed for the Navier-Stokes solver using the method of manufactured solutions. The hemolysis scalar transport equation was verified only through comparison with an analytical solution on a simplified geometry, not via a full manufactured-solution campaign. Achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis index QoI across all five operating points with GCI below 5%.",
      "rationale": "Three-level mesh refinement study was performed and GCI computed for pressure rise and flow uniformity. GCI for the hemolysis index itself was computed at three of the five operating points; the two highest-speed conditions were assessed only on the medium and fine mesh. GCI values ranged 4.2–11.7%, exceeding the 5% threshold at high-speed conditions. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol) documented and traceable; uncertainty in boundary conditions quantified.",
      "rationale": "FDA pump experimental data include documented flow rates and rotational speeds. Fluid temperature and hematocrit variability across test runs are reported as nominal values only; lot-to-lot variability in blood analog fluid is not characterized. Boundary condition uncertainty is propagated in the Monte Carlo UQ but relies on assumed distributions rather than measured variability. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty) reported for hemolysis index at all five operating points; statistical comparison accounts for experimental repeatability.",
      "rationale": "Normalized error E% was computed at all five operating points; values range 8–31%. Experimental repeatability (n=3 replicates) is available for three operating points; the remaining two have single measurements. The Monte Carlo 95% prediction interval brackets experimental data at four of five points. Achieved level 3 due to incomplete replication and high E% at peak-speed condition."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (hemolysis index) is identical to the COU QoI; no surrogate quantities used.",
      "rationale": "The primary QoI in both validation and COU is the normalized index of hemolysis (NIH). However, the validation dataset uses bovine blood analog rather than human blood, introducing a species-dependent correction factor. The correction is applied but its uncertainty is not formally propagated. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating conditions, and fluid properties match COU conditions within documented similarity criteria.",
      "rationale": "Validation used the FDA generic pump geometry which differs from the specific VAD impeller geometry in blade count and tip clearance. Operating conditions span the COU envelope but the highest-flow COU condition (6 L/min at 3500 rpm) lies at the boundary of the validation dataset. Similarity is partially established; extrapolation uncertainty is not quantified. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual levels below 1e-5 for all equations; round-off error assessed for double-precision arithmetic.",
      "rationale": "Residuals for continuity and momentum converge to 1e-4; hemolysis scalar residual reaches 5e-4 at the highest-speed operating point. Double-precision arithmetic is confirmed. Iterative convergence is insufficient for the hemolysis equation at demanding conditions. Achieved level 2, below required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; checklist-based review of boundary conditions, material properties, and solver settings documented.",
      "rationale": "An internal peer review of simulation inputs was performed by a second analyst. The review checklist covered boundary conditions and mesh quality but did not independently re-run the simulation or verify the hemolysis model constants against the original Giersiepen et al. source. One material property (dynamic viscosity temperature coefficient) was found to be inconsistently applied across operating points during review; corrected for final submission. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification provided for choice of hemolysis power-law model versus mechanistic red-blood-cell damage models; model form uncertainty quantified or bounded.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is used. A qualitative comparison to the Arora mechanistic model is provided in the technical report, noting the power-law model is widely used in regulatory submissions. Model form uncertainty is not quantified; the screening sensitivity study referenced in the UQ narrative examined input parameter variability but did not evaluate alternative hemolysis model forms. Achieved level 2, significantly below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry tolerances, fluid properties, boundary conditions) characterized with probability distributions; distributions validated against measurement data.",
      "rationale": "Monte Carlo UQ propagates uncertainty in inlet flow rate (±5%), rotational speed (±1%), and fluid viscosity (±8%) using assumed normal distributions. Geometric tolerances from manufacturing drawings are incorporated. The hemolysis model exponent coefficients (alpha, beta) are treated as fixed nominal values from literature; their uncertainty is not included in the Monte Carlo sampling. The screening sensitivity study mentioned in the UQ narrative identified these coefficients as potentially influential but they were not subsequently included in the formal UQ. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize measurement variability; sample size justification provided.",
      "rationale": "Three replicate experiments were performed at three of five operating points; single measurements at the remaining two. No formal sample size justification is provided. Measurement uncertainty for the hemolysis index is estimated from the three-replicate subset and applied uniformly, which may underestimate variability at untested conditions. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that simulation input parameters (geometry, fluid properties, operating conditions) are equivalent to the physical test article within quantified tolerances.",
      "rationale": "The FDA generic pump CAD geometry was used directly for simulation. The physical test article was fabricated from the same CAD file but surface roughness and internal clearances were not measured post-fabrication. Fluid properties were matched to nominal values; actual test-fluid viscosity measurements were not provided by the experimental team. Equivalency is assumed rather than demonstrated for these parameters. Achieved level 2, well below required level 4 at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below their required thresholds, the assessment team accepted the package on the basis that Monte Carlo uncertainty quantification bounds the hemolysis prediction interval below the clinical threshold across all five operating points with 95% confidence. A screening sensitivity study was conducted during model development and its findings are documented in the UQ technical narrative, providing qualitative assurance that dominant input drivers were considered. The team judged the residual credibility gaps to be acceptable given the conservative clinical threshold margin (predicted NIH 0.0041 versus threshold 0.0100) and the regulatory precedent for this model form in prior 510(k) submissions. All factors were formally assessed; no factors were left unscoped.",
    "decidedAt": "2026-04-19T00:00:00Z"
