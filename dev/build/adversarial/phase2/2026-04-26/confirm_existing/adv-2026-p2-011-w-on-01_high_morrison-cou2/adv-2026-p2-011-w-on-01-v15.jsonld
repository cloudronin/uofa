  "hash": "sha256:a3f7c2e18b054d9e6c2a1f3b7d9e4c5a2f1b8e3d7c6a4f2b9e1d3c7a5f4b2e8",
  "signature": "ed25519:b4e9d1c3f7a2e5b8d4c6a1f3e9b2d7c5a4f1e8b3d6c2a9f5e1b4d7c3a6f2e8b1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control, issue tracking, regression test suite, and release documentation must meet ASME V&V 40 Gradation 4 requirements for MRL 5 Class III device submissions.",
      "rationale": "The CFD solver (OpenFOAM v9) is managed under a formal version-controlled repository with tagged releases. A regression test suite of 47 benchmark cases is executed on each release candidate. Issue tracking is maintained in a validated JIRA instance. Release notes document all code changes affecting hemolysis-relevant solvers. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing on canonical problems and comparison against analytic solutions must demonstrate correct implementation of governing equations to Gradation 4 standard.",
      "rationale": "Method of manufactured solutions (MMS) was applied to the Navier-Stokes solver and the power-law hemolysis transport equation. Observed order of accuracy (1.97 for velocity, 1.94 for scalar transport) is consistent with the nominal second-order spatial discretization. Code verification is complete at Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be computed on a minimum three-mesh sequence; GCI for QoI must be below 5% at Gradation 4.",
      "rationale": "Three structured-dominant meshes (2.1M, 8.4M, 33.6M cells) were generated following ASME V&V 20 guidelines. GCI for hemolysis index at the design operating point is 3.2% (fine-to-medium) and 3.8% (medium-to-coarse), satisfying the asymptotic convergence criterion. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with calibrated instrumentation and traceable uncertainty budgets sufficient for Gradation 3 comparison against simulation boundary conditions.",
      "rationale": "FDA benchmark experimental data were collected with calibrated Coriolis flow meters (±0.5% FS) and differential pressure transducers (±0.25% FS). Blood analog fluid viscosity was measured at 37°C with a cone-plate rheometer. Inlet velocity profiles were characterized by PIV. Boundary condition fidelity is sufficient for Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., validation uncertainty u_val) must demonstrate model agreement within the validation uncertainty band at Gradation 4, with systematic bias less than 10% of the experimental QoI range.",
      "rationale": "Validation comparison using the ASME V&V 20 validation uncertainty framework yields u_val = 18.4% for hemolysis index. Systematic bias is 8.7% relative to the experimental mean HI. The achieved Gradation 3 reflects that the validation uncertainty exceeds the Gradation 4 threshold of 15%. This gap was flagged and mitigated by bounding analysis demonstrating conservative hemolysis prediction in the safety-relevant direction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI must be directly traceable to the clinical endpoint (hemolysis-related adverse events) and the regulatory submission claim, documented at Gradation 4.",
      "rationale": "The hemolysis index (HI) is directly linked to plasma-free hemoglobin levels, which are the FDA-recognized surrogate endpoint for hemolysis-related adverse events in VAD submissions. The mapping from CFD-predicted HI to the clinical threshold (pfHb < 20 mg/dL) is documented in the credibility assessment plan. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the intended operating envelope (3–6 L/min, 3000–5000 RPM) with geometry and fluid properties representative of the target device at Gradation 4.",
      "rationale": "FDA benchmark validation used the generic centrifugal pump geometry, which is geometrically similar but not identical to the target VAD impeller. Validation experiments cover 4–6 L/min at 3500–5000 RPM, partially overlapping the full intended operating envelope. The 3–4 L/min range at 3000 RPM is extrapolated. Gradation 3 reflects this partial coverage gap; a sensitivity study confirmed monotonic HI behavior in the extrapolated region."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria must be documented and residuals must reach solver-specified thresholds; time-step sensitivity must be demonstrated at Gradation 3.",
      "rationale": "All steady-state RANS simulations were run to normalized residuals below 1e-6 for continuity and momentum. Transient simulations used a Courant number of 0.8 with time-step sensitivity confirmed by halving the time step and observing less than 1.5% change in cycle-averaged HI. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation workflow must include documented user qualification records, input review checklists, and an independent technical review at Gradation 3.",
      "rationale": "All simulation analysts hold documented CFD competency qualifications (minimum 3 years hemodynamic CFD experience). Pre- and post-processing checklists were completed for each simulation case. An independent technical reviewer (not the simulation analyst) reviewed mesh quality metrics, boundary condition assignments, and post-processing scripts. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Selection and justification of turbulence model, hemolysis damage accumulation model, and constitutive relations must be documented with supporting literature evidence at Gradation 4.",
      "rationale": "The SST k-omega turbulence model was selected based on published benchmarks for rotating machinery hemodynamics. The power-law Giersiepen-Wurzinger hemolysis model was used; its known limitations for low-shear regimes are documented. Model form uncertainty is quantified by comparing three hemolysis model variants (GW, Taskin, Arora). Gradation 3 reflects that no single model form has been validated to Gradation 4 certainty for VAD-scale geometries; the ensemble spread is reported as model-form uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources, measurement uncertainties, and sensitivity rankings via Monte Carlo or equivalent method at Gradation 4.",
      "rationale": "Monte Carlo uncertainty quantification (N=10,000 Latin hypercube samples) was performed across nine input parameters including inlet flow rate, fluid density, viscosity, hemolysis model coefficients (C, alpha, beta), and rotational speed. Sobol sensitivity indices identify hemolysis model coefficient C as the dominant contributor (S1=0.61). All input distributions are traceable to calibrated measurements or literature with stated confidence intervals. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for relevant material properties with traceability to the intended clinical use fluid at Gradation 3.",
      "rationale": "Validation experiments used porcine blood and glycerol-saline blood analog (40% hematocrit equivalent viscosity). Porcine blood rheology was characterized at 37°C. The blood analog was selected per ASTM F1841 guidance. Hematocrit variability (±2%) is included in the input uncertainty budget. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrated equivalent to experimental conditions through documented parameter mapping and dimensional analysis at Gradation 3.",
      "rationale": "Dimensionless flow coefficient (phi) and head coefficient (psi) were used to map experimental operating points to simulation boundary conditions. Reynolds number matching was verified within 2% across all validation cases. Rotational speed was matched to within 0.5 RPM of experimental setpoints. Gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for the CFD hemolysis prediction model supporting the VAD 510(k) submission. Seven factors achieved their required gradation levels outright. Six factors initially fell below required levels; mitigation actions (bounding analyses, ensemble model-form uncertainty reporting, operating envelope sensitivity studies) were completed and reviewed. The overall evidence body is judged sufficient to support the regulatory claim that the CFD model predicts hemolysis index within an acceptable uncertainty band for the intended VAD operating conditions. The package conforms to ProfileMinimal; structured context-of-use scope is described in the package description and claim binding. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
