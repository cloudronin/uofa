  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented unit-test suite covering >80% of hemolysis transport routines; independent code review completed.",
      "rationale": "OpenFOAM v9 used under institutional version control; unit tests cover 71% of relevant routines. Independent review was scoped but not completed within project timeline. Achieved level falls one gradation below required; gap accepted under MRL 5 epistemic-flag protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to scalar-transport hemolysis equation with demonstrated second-order spatial convergence on canonical geometries.",
      "rationale": "MMS applied to Couette-flow analog; second-order convergence confirmed on structured hexahedral meshes. Unstructured tetrahedral mesh MMS not performed; polyhedral cell contribution to truncation error unquantified. Gap documented as epistemic."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for NIH quantity of interest on three systematically refined meshes using Richardson extrapolation.",
      "rationale": "Three-mesh GCI study performed (coarse 4.2 M, medium 11.7 M, fine 28.4 M cells). GCI for NIH = 7.3% between medium and fine; target of 5% not met. Asymptotic range confirmed (GCI ratio 1.02). Discretization uncertainty folded into Monte Carlo propagation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions (flow rate, rotational speed, hematocrit, temperature) match CFD boundary conditions within stated tolerances; traceability to calibrated instrumentation documented.",
      "rationale": "All four primary boundary conditions matched within ±2% of nominal; thermocouple and Coriolis flowmeter calibration certificates on file. Test condition parity achieved at required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (E_val) computed with combined experimental and numerical uncertainty; 95% confidence interval on prediction error reported; systematic bias < 10% NIH.",
      "rationale": "E_val computed per ASME V&V 20; combined standard uncertainty u_c = 18% NIH. Prediction interval at 95% confidence spans ±31% NIH, exceeding the ±25% claim threshold at two operating points. Systematic bias = 8.4% (within 10% criterion). Achieved level 3 rather than 4 due to wide prediction interval."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "NIH directly maps to clinical hemolysis endpoint; linkage to patient-risk metric documented in device risk analysis.",
      "rationale": "NIH is the regulatory-accepted surrogate for hemolytic risk per FDA guidance (2017). Direct traceability to device risk analysis confirmed. QOI relevance fully satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on FDA generic pump geometry under VAD-representative flow conditions; extrapolation distance to patient-specific geometry assessed and bounded.",
      "rationale": "Validation conducted on FDA generic pump, not patient-specific VAD geometry. Geometric similarity index = 0.74 (target ≥ 0.85). Extrapolation distance flagged; sensitivity of NIH to impeller blade angle variation assessed via surrogate model. Gap accepted with documented extrapolation uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error < 0.1% of NIH QOI; floating-point round-off analysis completed; solver residual trajectories archived.",
      "rationale": "Residual convergence to 1e-6 achieved for momentum equations; scalar transport residual plateaued at 3e-5 for two operating points. Floating-point round-off analysis not performed. Classified as not-assessed epistemic gap at MRL 5; iterative error contribution estimated via residual bounding but not formally quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with mandatory peer review of boundary condition setup; checklist-based QA for each simulation run archived.",
      "rationale": "Internal simulation checklist exists but peer-review sign-off was not systematically recorded for all 18 simulation cases. Two cases lacked independent boundary-condition verification. Use-error factor flagged as epistemic gap; workflow hardening recommended before next submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Eulerian power-law hemolysis model form uncertainty quantified via comparison with at least two alternative constitutive models; Bayesian model-form plausibility weights reported.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model was implemented. Comparison with Bludszuweit and Arora models not performed. Model-form uncertainty is the dominant epistemic gap at MRL 5; Bayesian model averaging not feasible within project scope. Flagged as critical unresolved gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters (viscosity, hematocrit, power-law exponents α and β); Monte Carlo propagation with n ≥ 1000 samples; Sobol sensitivity indices reported.",
      "rationale": "Monte Carlo propagation performed with n=2000 samples. Distributions assigned to viscosity (normal, CV=5%), hematocrit (uniform ±3%), α (log-normal, σ=0.12), β (log-normal, σ=0.09). Sobol first-order indices computed; α dominates NIH variance (S1=0.61). Achieved level 3; full second-order Sobol indices not computed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independent blood sample lots; sample characterization (MCV, MCHC, osmotic fragility) documented; inter-lot variability quantified.",
      "rationale": "Single blood lot used across all in-vitro experiments. Inter-lot biological variability not characterized. This is a known limitation of the validation dataset; additional sample lots were unavailable within IRB approval scope. Factor not-assessed at required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
