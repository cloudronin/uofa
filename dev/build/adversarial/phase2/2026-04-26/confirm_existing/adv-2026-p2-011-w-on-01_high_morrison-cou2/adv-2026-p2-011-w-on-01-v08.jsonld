  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-dr-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The panel reviewed all 13 ASME V&V 40 credibility factors. Seven factors were formally assessed; of these, three achieved the required level and four fell one gradation below required, with gaps documented under the MRL 5 epistemic-flag protocol. Six factors were classified as not-assessed epistemic gaps, consistent with the acknowledged limitations of the FDA generic pump validation dataset and the single-blood-lot experimental campaign. The Monte Carlo uncertainty propagation bounds the dominant input-parameter uncertainty (power-law exponent α). The model-form gap is the most consequential unresolved issue; the panel accepts the package conditional on the understanding that the Giersiepen-Wurzinger model has been the regulatory norm for this device class and that the ±25% NIH claim is interpreted as a probabilistic bound at the 80th percentile of the Monte Carlo ensemble rather than a deterministic guarantee. The structured Context of Use object is not present in this Minimal-profile submission; the intended-use scope — CFD hemolysis prediction for a Class III VAD at MRL 5 — is fully described in the package description, the bound Requirement node, and the bound Claim node, and the panel treated those prose descriptions as the operative scope definition.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
