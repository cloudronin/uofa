    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-piv-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison against FDA generic pump experimental data at 3500 RPM and 6 L/min"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction versus in-vitro measurements across five operating points"
    }
  ],
