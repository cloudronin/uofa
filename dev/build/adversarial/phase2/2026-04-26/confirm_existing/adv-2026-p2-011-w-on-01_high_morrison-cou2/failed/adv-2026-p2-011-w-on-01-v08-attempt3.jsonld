  "signature": "ed25519:b4e9d3c2a1f0e8d7c6b5a4f3e2d1c0b9a8f7e6d5c4b3a2f1e0d9c8b7a6f5e4d3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented unit tests, regression test suite, and version-controlled source with change logs traceable to MRL 5 requirements.",
      "rationale": "OpenFOAM v9 with hemolysis UDF is under Git version control; regression suite covers 47 canonical flow cases; all tests pass at the current release tag. SQA documentation reviewed and found adequate for MRL 5 at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) must confirm second-order spatial convergence for the Navier-Stokes and scalar transport equations.",
      "rationale": "MMS study performed on a rotating annular domain representative of the pump geometry. Observed order of accuracy is 1.97 for velocity and 1.93 for the hemolysis scalar, consistent with second-order discretization. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; GCI on hemolysis index QoI must be below 5%.",
      "rationale": "Three meshes (2.1 M, 6.4 M, 18.9 M cells) used; Richardson extrapolation yields GCI of 3.8% on the normalized hemolysis index at the design point. Asymptotic range confirmed. Gradation 3 requirement met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, hematocrit, temperature, rotational speed) must be documented with measurement uncertainty and shown to bracket the clinical VAD operating envelope.",
      "rationale": "Bench experiments conducted at 37°C, hematocrit 35±2%, viscosity 3.2±0.1 mPa·s, speeds 2000–3500 RPM in 500 RPM increments. Conditions documented in lab notebook LN-2023-047. Clinical envelope bounded. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized hemolysis index predictions must agree with experimental measurements within ±25% across the operating envelope, with systematic bias quantified.",
      "rationale": "Mean absolute percentage error across 12 operating points is 18.4%; maximum deviation is 23.1% at 2000 RPM / 6 L/min. Bias is negative (model under-predicts) by 6.2% on average. Agreement is within the ±25% acceptance band. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled QoIs (normalized hemolysis index, shear stress distribution) must be directly traceable to the clinical decision metric specified in the device submission.",
      "rationale": "The normalized hemolysis index is the primary QoI cited in the 510(k) substantial equivalence argument. Shear stress distribution is a secondary QoI used to identify high-risk zones. Both QoIs map directly to the clinical decision metric. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the FDA generic centrifugal pump geometry or a device with documented geometric similarity index above 0.85 relative to the target VAD.",
      "rationale": "Validation performed directly on the FDA generic centrifugal pump geometry per ASTM F1841. Geometric similarity index with the target VAD is 0.91. Fluid and operating conditions match the clinical envelope. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-6 for all transported quantities must be demonstrated, and floating-point round-off sensitivity assessed via double vs. extended precision comparison.",
      "rationale": "Residual convergence to 1e-5 is documented; the stricter 1e-6 target and extended-precision comparison have not been performed. This factor is flagged as an epistemic gap at MRL 5. Achieved level remains at Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented operator qualification protocol and at least one independent replication of the simulation setup by a second analyst must be on record.",
      "rationale": "Independent replication by a second analyst has not been completed. Operator qualification protocol is drafted but not formally executed. Epistemic gap flagged. Achieved level remains at Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Alternative hemolysis constitutive models (e.g., Giersiepen-Wurzinger vs. modified power-law) must be evaluated and model-form uncertainty quantified via sensitivity analysis.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model is implemented. No model-form sensitivity study comparing alternative constitutive relationships has been performed. Significant epistemic gap at MRL 5. Achieved level remains at Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters (viscosity, hematocrit, power-law exponents) must be propagated via Monte Carlo with at least 500 samples; 95th-percentile bounds on hemolysis index reported.",
      "rationale": "Monte Carlo propagation performed with 1000 samples across viscosity, hematocrit, and power-law coefficient distributions. 95th-percentile hemolysis index bound is 1.34× the nominal prediction. Distribution characterization of power-law exponents relies on literature values with limited experimental support, preventing Gradation 3. Achieved level: Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood samples used in hemolysis experiments must be characterized for donor variability (minimum n=3 donors) and lot-to-lot consistency documented.",
      "rationale": "Hemolysis experiments used a single pooled blood lot from one donor. Donor variability has not been characterized. This is a known epistemic gap that prevents Gradation 2. Achieved level remains at Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal parameter equivalency matrix must demonstrate that simulation input parameters match experimental conditions within stated uncertainty bounds for all boundary conditions.",
      "rationale": "Inlet velocity profiles are approximated as uniform; experimental inlet profiles were not measured. Formal equivalency matrix has not been constructed. Epistemic gap flagged at MRL 5. Achieved level remains at Gradation 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-minimal-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile review scope, the seven assessed credibility factors for CFD hemolysis prediction of the FDA generic centrifugal blood pump under VAD operating conditions meet their required gradation levels. The model is used to predict absolute hemolysis index for a Class III VAD device across the clinical flow envelope (3–6 L/min, 2000–3500 RPM) at Model Risk Level 5. Six factors remain as documented epistemic gaps (numerical solver error, use error, model form, test samples, equivalency of input parameters, and partial model inputs); these are acknowledged in the submission with a risk-informed rationale that the assessed factors provide sufficient credibility evidence for the intended regulatory decision under the Minimal profile. Monte Carlo uncertainty quantification bounds the 95th-percentile hemolysis index prediction. Decision: Accepted with epistemic gap disclosures.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
