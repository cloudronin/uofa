  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. This unit evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. The intended use is confined to pre-market regulatory submission supporting 510(k) substantial-equivalence argumentation for rotary blood pumps operating at 2–6 L/min, 1500–3500 RPM, with blood haematocrit 35–45%. Monte Carlo uncertainty quantification was performed across all 13 credibility factors; seven factors were formally assessed and all achieved levels fall below required levels at MRL 5; six factors remain flagged as epistemic gaps. Decision: Accepted under post-market surveillance condition.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-cfd-hemolysis-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset",
    "https://uofa.net/synth/data/fda-pump-hemolysis-benchmark-nih",
    "https://uofa.net/synth/data/monte-carlo-uq-ensemble-10k"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-grid-convergence-2026",
      "type": "ValidationResult",
      "name": "Grid convergence index study for FDA centrifugal pump at 2500 RPM — GCI < 4.2% on hemolysis index QoI"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-experimental-comparison-2026",
      "type": "ValidationResult",
      "name": "Comparison of predicted NIH hemolysis index against FDA benchmark experimental data; mean relative error 18.3% across five operating points"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-uq-sensitivity-2026",
      "type": "ValidationResult",
      "name": "Monte Carlo sensitivity analysis (N=10 000) identifying blood viscosity and power-law damage exponent as dominant uncertainty contributors"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042517",
