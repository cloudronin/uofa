  "signature": "ed25519:9f8e7d6c5b4a3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8c7b6a5f4e3d2c1b0a9f8e",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; formal SQA plan on file.",
      "rationale": "The CFD solver (OpenFOAM v9) is under Git version control with a CI regression suite of 47 test cases. SQA documentation reviewed and found compliant with required level 4 criteria for Class III device context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) for both momentum and scalar transport equations.",
      "rationale": "MMS verification demonstrated second-order spatial accuracy for the Navier-Stokes solver and first-order accuracy for the hemolysis power-law transport scalar, consistent with discretization scheme selection. Achieved level meets required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis index QoI on at least three systematically refined meshes; GCI below 5%.",
      "rationale": "Three-mesh Richardson extrapolation performed; GCI for hemolysis index QoI is 8.2%, exceeding the 5% threshold. Achieved level 3 falls below required level 4. Gap acknowledged in decision record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid viscosity, temperature) documented with measurement uncertainty quantified to ASME PTC 19.1 standards.",
      "rationale": "FDA generic pump bench tests conducted at 2500 RPM and 5 L/min with bovine blood analog. All boundary conditions documented with expanded uncertainty (k=2). Achieved level equals required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E%, validation uncertainty Uval) reported for hemolysis index; comparison includes uncertainty bands from both simulation and experiment.",
      "rationale": "Hemolysis index prediction error is 18% relative to experimental mean. Validation uncertainty Uval computed via Monte Carlo (N=1000). Error exceeds acceptance band at required level 4; achieved level assessed as 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical risk endpoints (hemolysis index, shear stress distribution) with documented traceability to device submission requirements.",
      "rationale": "Hemolysis index (HI) and area-weighted wall shear stress are the primary QoIs, directly traceable to FDA guidance on blood-contacting device safety. Traceability matrix provided. Achieved level 4 meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted on geometrically and operationally representative device configurations; similarity arguments documented.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under VAD-representative operating conditions. Geometric and operational similarity to the clinical device documented via similarity analysis. Achieved level 4 meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; residual norms and QoI convergence histories reported for all production simulations.",
      "rationale": "Iterative convergence monitoring was not systematically recorded for all production runs. QoI convergence histories are available for only 3 of 12 operating points. Factor flagged as epistemic gap at MRL 5; achieved level 2 below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second qualified analyst; checklist-based use-error assessment documented.",
      "rationale": "No independent analyst review of simulation setup was performed. Use-error checklist was not completed. Epistemic gap flagged; achieved level 2 below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for turbulence model selection (SST k-omega vs. LES) and hemolysis power-law exponents with sensitivity analysis across plausible model form alternatives.",
      "rationale": "Turbulence model sensitivity analysis not performed. Hemolysis power-law exponent selection (C=1.8e-6, alpha=0.765, beta=2.416) not justified against alternative parameter sets. Major epistemic gap at MRL 5; achieved level 2 substantially below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all influential input parameters (viscosity, density, inlet velocity profile, rotational speed) propagated through model via Monte Carlo or equivalent; global sensitivity indices reported.",
      "rationale": "Monte Carlo UQ performed for four input parameters (N=1000 samples). However, global sensitivity indices (Sobol) were not computed and inlet velocity profile uncertainty was excluded. Partial assessment; achieved level 3 below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point; inter-laboratory reproducibility data available.",
      "rationale": "Only single-laboratory, single-replicate hemolysis measurements available at most operating points. Inter-laboratory data not obtained. Achieved level 2 below required level 3; epistemic gap flagged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional analysis or non-dimensional parameter matching (Reynolds number, flow coefficient) between validation experiments and COU operating envelope documented.",
      "rationale": "Non-dimensional parameter matching between bench test conditions and intended VAD operating envelope not formally documented. Reynolds number equivalency assumed but not verified across full operating range. Achieved level 2 below required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile review scope, the seven assessed credibility factors collectively provide sufficient evidence for the intended use of CFD hemolysis prediction in the FDA generic centrifugal blood pump VAD context. Four factors achieved required levels; three factors with shortfalls (Discretization error, Output comparison, Model form) are accepted with documented gaps under the Minimal profile risk-acceptance framework. Six factors flagged as not-assessed represent epistemic gaps that would require resolution under a Complete profile submission. The decision team acknowledges that the absence of a formally structured Context of Use record in the package metadata does not impair the Minimal profile acceptance determination, as use scope is described in the UnitOfAssurance description and claim prose. Accepted pending Complete profile re-assessment prior to PMA submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
