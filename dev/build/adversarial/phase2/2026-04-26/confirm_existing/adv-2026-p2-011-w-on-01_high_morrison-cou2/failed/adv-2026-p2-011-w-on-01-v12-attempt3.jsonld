  "signature": "ed25519:b2e5f8a1c4d7e0f3a6b9c2d5e8f1a4b7c0d3e6f9a2b5c8d1e4f7a0b3c6d9e2f5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all relevant flow regimes; traceability to validated release.",
      "rationale": "OpenFOAM v8 deployed under ISO-compliant QMS with full regression test suite; all 47 verification cases passed. Version control and change management records are complete and traceable to the submitted solver build."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for all governing equations using method of manufactured solutions (MMS); convergence rates within 5% of theoretical.",
      "rationale": "MMS applied to incompressible Navier-Stokes and scalar transport equations. Observed convergence order 1.97 (theoretical 2.0) for velocity and 1.94 for scalar hemolysis index. Residuals below 1e-6 for all cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 3% for NIH QoI on the fine mesh; Richardson extrapolation applied across three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study conducted (2.1M, 8.4M, 33.6M cells). GCI on fine mesh: 1.8% for NIH, 2.1% for pressure rise. Richardson extrapolation confirms asymptotic convergence. Fine mesh selected for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented with measurement uncertainty; conditions span the VAD clinical operating envelope.",
      "rationale": "In-vitro tests conducted at 3, 4.5, and 6 L/min at 2000, 2750, and 3500 RPM using bovine blood analog (glycerol-water, matched viscosity). Temperature controlled at 37±0.5°C. All boundary conditions documented with calibrated instrumentation uncertainty budgets."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., validation uncertainty U_val) computed per ASME V&V 20; NIH prediction error within ±15% acceptance band across all operating points.",
      "rationale": "Validation uncertainty U_val computed per ASME V&V 20-2009. Mean NIH prediction error: 8.3% across 9 operating points. Maximum error: 13.7% at 6 L/min / 3500 RPM. All points within ±15% acceptance band. E/U_val ratio: 0.61, indicating model adequacy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, pressure rise, shear stress distribution) directly linked to device safety and performance claims for Class III VAD submission.",
      "rationale": "Primary QoI is normalized index of hemolysis (NIH), directly correlated to red blood cell damage risk in implantable VADs. Secondary QoIs (hydraulic pressure rise, peak shear stress) are standard FDA-recognized metrics for pump performance assessment. All QoIs map directly to the device safety claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use geometry, fluid, and operating conditions representative of the VAD COU; similarity parameters documented.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry — the reference benchmark for VAD hemolysis modeling. Fluid analog matched to blood viscosity. Operating envelope covers full clinical range. Geometric similarity to the subject device is documented in the similarity assessment report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence error quantified and demonstrated to be negligible relative to discretization error; solver tolerance study documented.",
      "rationale": "Iterative solver tolerance study conducted. Residual convergence to 1e-7 achieved for all production runs. Iterative error estimated at 0.3% of NIH, compared to GCI discretization error of 1.8%. Iterative error contribution is negligible and does not affect decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review; analyst qualification records on file; checklist-based run verification completed.",
      "rationale": "Simulation workflow documented in SOP-CFD-VAD-002. Two independent analysts reviewed mesh, boundary conditions, and post-processing scripts. Analyst qualification records confirm training on hemolysis CFD protocols. Pre-submission checklist completed and signed off."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage accumulation model selection justified by literature evidence and sensitivity analysis; model form uncertainty quantified.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark comparisons for rotating machinery hemolysis prediction. Power-law hemolysis model (Giersiepen-Wurzinger) validated against published RBC damage data. Model form sensitivity analysis conducted across three turbulence models; NIH variation: 6.2%. Model form uncertainty included in U_val budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo UQ performed for all uncertain input parameters; contribution ranking documented; total input uncertainty propagated to NIH QoI.",
      "rationale": "Monte Carlo analysis (n=2000 samples) performed over viscosity (±5%), inlet flow rate (±2%), rotational speed (±1%), and hemolysis model constants (±15%). Total input uncertainty on NIH: ±9.1% (95% CI). Hemolysis model constants identified as dominant contributor (67% of variance). Sobol indices documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient replicate measurements to characterize experimental variability; sample size justification documented.",
      "rationale": "Five replicate hemolysis runs performed at each of 9 operating points (45 total experiments). Coefficient of variation across replicates: 4.2–8.7%. Sample size justified by power analysis targeting 80% power to detect 15% NIH difference. Experimental uncertainty included in validation metric."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary conditions demonstrably equivalent to experimental conditions; any discrepancies quantified and shown to have negligible impact on QoI.",
      "rationale": "CFD inlet velocity profiles derived from PIV measurements at the pump inlet plane. Rotational speed matched to tachometer readings within 0.1%. Fluid property equivalence verified by rheometry. Discrepancy in inlet turbulence intensity (CFD: 5%, experiment: estimated 3–7%) assessed via sensitivity study; NIH impact: 1.4%, negligible relative to acceptance band."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at or above required levels for Model Risk Level 5. NIH prediction error within ±15% acceptance band at all operating points. Monte Carlo UQ confirms total uncertainty budget is acceptable for Class III VAD pre-market submission. The computational model is deemed credible for predicting absolute hemolysis levels in the FDA generic centrifugal pump geometry across the clinical VAD operating envelope (3–6 L/min, 2000–3500 RPM). Package accepted for regulatory submission support.",
