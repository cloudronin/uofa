  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions at Model Risk Level 5. The computational model is intended to predict absolute hemolysis index for a Class III VAD device operated at nominal clinical flow rates (3–6 L/min, 2000–3600 RPM). All 13 credibility factors have been evaluated; seven factors were assessed and six were flagged as epistemic gaps. Monte Carlo uncertainty quantification was performed. Despite gaps, the aggregate credibility evidence is judged sufficient for the Low assurance level declared. Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-requirement",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-prediction-claim",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset",
    "https://uofa.net/synth/data/hemolysis-index-measurements-2023"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison-run1",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data — nominal operating point"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "Velocity field comparison via PIV measurements at 4 L/min 3000 RPM"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4040497",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f2c1e4b7d09e5f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented version control, regression testing suite, and independent code review at MRL 5.",
      "rationale": "OpenFOAM v8 with institutional version control and automated regression tests. Independent third-party code review was not completed; achieved level falls one gradation below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification required for all active transport equations at MRL 5.",
      "rationale": "Order-of-accuracy confirmed for momentum and continuity equations. MMS verification for the scalar hemolysis transport equation was initiated but not completed to the required convergence criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes with GCI reported for all QoIs at MRL 5.",
      "rationale": "Three-mesh Richardson extrapolation performed for velocity and wall shear stress. GCI for hemolysis index was computed only on two mesh levels due to computational cost; reported uncertainty bounds are therefore conservative estimates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match simulation inlet/outlet conditions within 5% for flow rate and rotational speed.",
      "rationale": "Flow rate agreement within 3%; rotational speed agreement within 2%. Blood analog viscosity deviated by 8% from the Newtonian model used in simulation, exceeding the 5% threshold for viscosity matching."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) with uncertainty bands for all primary QoIs; statistical significance of agreement must be established.",
      "rationale": "Relative error for hemolysis index is 18% at nominal conditions. Velocity field RMSE within PIV measurement uncertainty. Statistical significance testing via bootstrap not completed; gap noted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must directly map to clinical decision endpoints; hemolysis index must be linked to patient safety thresholds per ISO 10993.",
      "rationale": "Hemolysis index is the primary QoI and maps to ISO 10993-4 thresholds. Shear stress distribution is a secondary QoI but its link to patient safety endpoints was not formally documented in the evidence package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate VAD operating envelope including pulsatile flow representative of cardiac assist conditions.",
      "rationale": "Steady-state validation performed at three operating points within the VAD envelope. Pulsatile validation not performed; clinical VAD operation includes pulsatile assist modes not covered by current validation activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off analysis required; solver residuals must reach 1e-6 for all equations.",
      "rationale": "Solver residual convergence documented at 1e-5 for momentum; floating-point and iterative error decomposition not performed. Factor flagged as epistemic gap at MRL 5; not assessed due to resource constraints."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records, simulation execution checklist, and independent review of model setup required at MRL 5.",
      "rationale": "No formal user qualification records or independent model-setup review were produced. Factor flagged as epistemic gap; assessment deferred pending establishment of simulation governance procedures."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model form uncertainty required; sensitivity to model form must be quantified.",
      "rationale": "k-omega SST turbulence model selected based on prior literature but no formal model-form sensitivity study was performed. Giersiepen–Wurzinger hemolysis model used without alternative model comparison. Critical gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions for all uncertain input parameters must be established and propagated via Monte Carlo or equivalent UQ method.",
      "rationale": "Monte Carlo UQ was initiated for inlet flow rate and viscosity. Distributions for remaining uncertain inputs (pump geometry tolerances, hematocrit variability) were not established. Factor not fully assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size analysis demonstrating statistical power for experimental hemolysis measurements; minimum n=5 independent runs required.",
      "rationale": "Experimental hemolysis measurements available from FDA dataset with n=3 independent runs. Sample size power analysis not performed. Factor flagged as not assessed due to insufficient sample documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between experimental and simulation input parameters with documented uncertainty in the mapping must be provided.",
      "rationale": "No formal equivalency mapping document was produced. Informal comparison of boundary conditions was performed but does not meet MRL 5 documentation requirements. Factor flagged as epistemic gap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The UnitOfAssurance is accepted at Low assurance level. The claim — that the CFD model can predict absolute hemolysis index for the FDA generic centrifugal pump under VAD operating conditions — is supported by seven assessed credibility factors and acknowledged epistemic gaps in six factors. All gaps are documented and judged tolerable given the Low assurance level designation and the conservative uncertainty bounds reported. The assessment team notes that the intended use scope (Class III VAD, 3–6 L/min, 2000–3600 RPM, steady-state analysis) is described in the Claim and Requirement prose; no structured Context of Use object was required under ProfileMinimal. Residual uncertainties are acknowledged and flagged for resolution in subsequent assessment cycles prior to any regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
