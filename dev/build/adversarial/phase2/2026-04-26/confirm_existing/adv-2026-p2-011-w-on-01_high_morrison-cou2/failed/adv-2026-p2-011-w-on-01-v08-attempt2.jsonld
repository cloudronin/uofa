      "name": "Hemolysis index comparison at 2500 RPM — CFD vs bench"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "Velocity field PIV comparison at design operating point"
    }
