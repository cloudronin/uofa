  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal Profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. This package evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. The intended use scope is CFD-based prediction of hemolysis index in a centrifugal VAD operating at 3500–5000 RPM and 4–6 L/min flow rate, supporting regulatory submission to FDA under 21 CFR Part 870. All 13 credibility factors have been assessed; seven factors achieved required levels and six carry residual gaps documented in the decision record. Monte Carlo uncertainty quantification was performed across blood viscosity, pump speed, and inlet boundary conditions. Decision: Accepted with conditions noted in the decision record.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-cfd-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-absolute-prediction-claim",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/fda-pump-piv-velocity-dataset",
    "https://uofa.net/synth/data/monte-carlo-uncertainty-samples-n10000"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison-vr001",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data at 4500 RPM, 5 L/min"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison-vr002",
