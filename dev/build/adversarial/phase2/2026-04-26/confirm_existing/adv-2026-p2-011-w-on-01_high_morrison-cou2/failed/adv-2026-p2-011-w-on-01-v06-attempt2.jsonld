  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Seven of thirteen credibility factors are fully assessed and meet or exceed required levels for MRL 5 at the nominal VAD operating point (5 L/min, 100 mmHg, 3600 RPM). The six not-assessed factors are documented epistemic gaps with bounding analyses indicating residual risk is within acceptable limits for a Low assurance-level submission. Validation uncertainty Uval = 14.1% encompasses the model-experiment NIH difference of 8.3%. The assessment team accepts the model for the stated prediction purpose pending Phase 2 completion of model-form and full Monte Carlo UQ activities.",
