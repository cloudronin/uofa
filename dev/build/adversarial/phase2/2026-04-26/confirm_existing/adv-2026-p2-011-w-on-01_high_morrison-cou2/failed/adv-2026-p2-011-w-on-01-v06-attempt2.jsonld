      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis model; all tests passing at submission.",
      "rationale": "OpenFOAM v8 with custom hemolysis scalar transport module is under git version control; 47 regression tests pass; code review documented per ISO 13485 QMS procedures."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations with demonstrated second-order convergence for velocity and scalar transport.",
      "rationale": "MMS verification confirms second-order spatial convergence (L2 norm) for both Navier-Stokes and power-law hemolysis scalar; temporal convergence verified to first order for BDF1 scheme used in steady-state approach."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for NIH QOI; GCI fine < 5% on production mesh.",
      "rationale": "Three-mesh GCI study on 4M, 12M, and 36M cell meshes yields GCI_fine = 3.2% for NIH; asymptotic ratio confirms grid convergence. Production mesh is 12M cells balancing accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, pressure rise, rotational speed, fluid properties) documented with measurement uncertainty; deviations from simulation BCs quantified.",
      "rationale": "FDA bench-top test conditions (5 L/min ± 0.05 L/min, 100 mmHg ± 2 mmHg, 3600 RPM ± 5 RPM) are fully documented; fluid viscosity and density measured at 37°C and matched in simulation within 1.5%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty Uval) computed for NIH; Uval encompasses model-experiment difference at 95% confidence.",
      "rationale": "Validation metric E = 8.3% for NIH; combined validation uncertainty Uval = 14.1% (95% CI) incorporating experimental, numerical, and input uncertainties. Model-experiment difference falls within Uval, satisfying acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOI used in validation (NIH in g/100L) is identical to the QOI required for the submission decision; no surrogate quantities substituted.",
      "rationale": "NIH is the direct regulatory QOI per FDA guidance on blood-contacting devices. The validation experiments measure NIH using the same modified Lagrangian power-law damage model as the simulation; no surrogate QOI substitution required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation domain overlaps COU operating envelope for all primary physics parameters; gaps between validation domain and COU documented and bounded.",
      "rationale": "Validation performed on the identical FDA generic centrifugal pump geometry at the nominal VAD operating point. Extrapolation to off-design conditions (4–6 L/min, 80–120 mmHg) assessed via sensitivity analysis; NIH sensitivity to flow rate is 12%/L·min⁻¹, bounded within Uval."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance ≤ 1e-6 for all equations; round-off error assessed as negligible relative to discretization error.",
      "rationale": "All residuals converge to 1e-7 within 3000 iterations; double-precision arithmetic used throughout; round-off error estimated at < 0.01% of NIH, negligible relative to 3.2% GCI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of simulation setup by independent analyst; checklist covering boundary condition assignment, material property entry, and mesh import verified.",
      "rationale": "Use error assessment scoped out at this submission stage; independent setup review planned for Phase 2 verification cycle. Flagged as epistemic gap at MRL 5 but not blocking acceptance at current credibility threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of NIH prediction to turbulence model choice (SST k-ω vs. RSM) and hemolysis constitutive law (power-law vs. strain-based) quantified.",
      "rationale": "Model form uncertainty not formally quantified in this submission package. Literature survey indicates power-law exponent uncertainty contributes ~20% NIH variability; formal model-form sensitivity study deferred. Identified as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo propagation of all uncertain input parameters (viscosity, density, power-law coefficients C and α) through simulation; 5th–95th percentile NIH band reported.",
      "rationale": "Monte Carlo UQ initiated but not completed for full parameter set; viscosity and density propagated (±2% each), but power-law coefficients C and α not yet propagated due to limited published uncertainty data. Partial UQ result not sufficient for MRL-5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental dataset includes ≥ 3 independent pump specimens with documented lot traceability; inter-specimen variability reported.",
      "rationale": "FDA benchmark dataset uses a single pump specimen; inter-specimen variability not characterized. Scoped out as the FDA benchmark is a community-standard dataset; additional specimens not available for this study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between experimental input parameters and simulation boundary conditions formally documented; any non-equivalent parameters identified with bounding analysis.",
      "rationale": "Equivalency mapping documented for primary parameters (flow rate, pressure, speed, temperature). Wall roughness not measured experimentally; smooth-wall assumption in simulation assessed via sensitivity to roughness height (0–50 μm) yielding < 4% NIH change. Formal equivalency matrix not yet finalized."
    }
  ],
