  "signature": "ed25519:b2d4e6f8a1c3e507294b6d8f0a2c4e6801b3d5f7a9c1e3f502b4d6f8a0c2e4f6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; independent code review completed.",
      "rationale": "The CFD solver (OpenFOAM v2106) is version-controlled and has a regression suite, but independent third-party code review was not completed. Achieved level 3 falls short of the required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations including scalar transport for hemolysis power-law model; convergence order confirmed.",
      "rationale": "MMS was applied to the Navier-Stokes solver and confirmed second-order spatial convergence, but the hemolysis scalar transport sub-model was not subjected to MMS independently. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes; GCI reported for hemolysis index QoI; GCI < 5%.",
      "rationale": "Richardson extrapolation performed on three meshes (2.1M, 8.4M, 33.6M cells). GCI for hemolysis index was 8.2%, exceeding the 5% threshold. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid rheology, temperature) documented with uncertainty bounds matching CFD inlet specification within 2%.",
      "rationale": "Inlet velocity profiles and fluid temperature were documented; however, blood analog viscosity uncertainty was reported at ±4.1%, exceeding the 2% matching criterion. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty Uval) computed for hemolysis index; Uval < 15% of mean experimental value; statistical overlap of prediction and experiment confidence intervals demonstrated.",
      "rationale": "E% for hemolysis index was 22% across the five operating points tested. Prediction intervals overlapped experimental confidence intervals at only 3 of 5 points. Uval exceeded the 15% threshold. Achieved level 3 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (hemolysis index HI) is directly linked to the clinical decision endpoint (transfusion trigger threshold) with documented traceability to the device submission QoI.",
      "rationale": "Hemolysis index is the primary QoI and is clinically relevant; however, the traceability matrix linking HI to the specific 510(k) submission acceptance criterion was incomplete at the time of assessment. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the FDA generic centrifugal pump geometry under VAD operating envelope (flow rate 3–8 L/min, speed 2000–3500 RPM); fluid is human blood or validated analog.",
      "rationale": "Validation experiments used a glycerol-water blood analog rather than human blood, and were conducted at a single operating point (2500 RPM, 5 L/min) rather than spanning the VAD envelope. Relevance gap is substantial; achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual norms below 1e-6 for all equations; floating-point round-off analysis documented.",
      "rationale": "Residuals converged to 1e-5 for continuity and momentum; the hemolysis scalar equation residual stalled at 1e-4 at high-shear near-wall regions. Round-off analysis was not performed. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and simulation execution checklist reviewed; at least one independent analyst reproduced key results.",
      "rationale": "Use error was flagged as an epistemic gap at MRL 5. No user qualification records were available and independent reproduction was not performed within the assessment window. Factor not assessed; achieved level assigned as 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis power-law model form justified against mechanistic red blood cell damage literature; sensitivity of HI to model-form assumptions quantified via alternative model comparison.",
      "rationale": "The Giersiepen-Wurzinger power-law model was used without comparison to alternative mechanistic models (e.g., Arora strain-based model). Model-form uncertainty was not quantified. Significant gap against required level 5; achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs characterised with probability distributions; Monte Carlo propagation of input uncertainty to HI output documented.",
      "rationale": "Monte Carlo UQ was performed for fluid viscosity, density, and inlet flow rate. However, hemolysis model coefficients (C, alpha, beta in the power-law) were treated as fixed constants rather than uncertain inputs. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient for statistical characterisation of hemolysis variability; batch-to-batch variability of blood analog documented.",
      "rationale": "Test sample characterisation was flagged as an epistemic gap. Only a single batch of blood analog was used; no batch-to-batch variability data were collected. Factor not assessed; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional analysis and similarity parameters (Reynolds number, Stokes number, shear-stress exposure time) verified equivalent between validation experiment and COU operating conditions.",
      "rationale": "Equivalency of dimensionless parameters between the bench validation setup and the intended VAD clinical operating envelope was not formally assessed. Reynolds number matching was approximate; Stokes number analysis absent. Factor not assessed; achieved level 1."
    }
  ],
