  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. The model is intended to predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Monte Carlo uncertainty quantification was performed; all 13 credibility factors were assessed under MRL-5 requirements. This package conforms to ProfileMinimal; the structured Context of Use block is captured in the associated requirement and claim prose rather than as a discrete hasContextOfUse node.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-cou2",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-vad-class3-accepted",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental",
    "https://uofa.net/synth/data/fda-pump-hemolysis-bench"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison-01",
      "type": "ValidationResult",
      "name": "Hemolysis index bench-to-CFD comparison at 2500 RPM, 5 L/min"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison-01",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA pump impeller plane"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4048693",
