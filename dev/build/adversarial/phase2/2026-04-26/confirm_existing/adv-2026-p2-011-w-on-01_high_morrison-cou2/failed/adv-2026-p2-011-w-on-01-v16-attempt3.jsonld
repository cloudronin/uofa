  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team determined that the CFD hemolysis prediction model for the FDA generic centrifugal blood pump meets the minimum credibility threshold for the intended VAD use scope as described in the claim and requirement documentation. All 13 ASME V&V 40 credibility factors were evaluated; achieved levels were reviewed against MRL-5 requirements. The team accepted the package under the ProfileMinimal submission pathway, noting that the full structured Context of Use specification is embedded in the binding requirement (https://uofa.net/synth/req/vad-hemolysis-mrl5-cou2) and the associated claim prose, and that residual factor gaps are acknowledged in individual factor rationales.",
