  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering hemolysis-relevant flow regimes; documented release notes.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and regression tests exist, but the test suite does not cover rotating-frame hemolysis-specific cases. Achieved level 3 falls short of required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent applied to governing equations including hemolysis transport scalar.",
      "rationale": "MMS was applied to the Navier-Stokes solver; however, the hemolysis power-law scalar transport equation was not independently verified by MMS. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index and velocity quantities of interest on three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study performed; GCI for hemolysis index is 4.2% and for peak velocity 1.8%. Richardson extrapolation applied. Achieved level 4 meets required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty; inlet velocity profiles and fluid rheology match simulation inputs within 5%.",
      "rationale": "Inlet boundary conditions were measured by PIV with documented uncertainty. Blood analog viscosity was characterized but temperature variation during experiments was not fully controlled, introducing a rheology mismatch. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) computed with experimental uncertainty bands; hemolysis index prediction within 15% of measured NIH.",
      "rationale": "Predicted NIH deviates from measured NIH by 22% at the primary operating point, exceeding the 15% acceptance threshold. Velocity field comparison meets threshold. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) are directly linked to the clinical endpoint of red blood cell damage in VAD patients.",
      "rationale": "Hemolysis index and volume-averaged shear stress are the primary QoIs and are directly traceable to the clinical risk of hemolysis in VAD patients. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic pump geometry at VAD-representative flow rates (3–6 L/min) and speeds (2500–3500 RPM).",
      "rationale": "Validation was performed at 2500 RPM and 5 L/min; however, the intended VAD operating envelope extends to 3500 RPM. Extrapolation beyond validated range is unquantified. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence verified to residual norms below 1e-6 for all transported quantities; time-step sensitivity study documented.",
      "rationale": "Residual convergence was monitored but time-step sensitivity for the hemolysis scalar was not independently documented. Factor flagged as not-assessed for the scalar transport component at MRL 5; achieved level 2 is below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup checklist reviewed by independent analyst; boundary condition assignment and turbulence model selection documented and peer-reviewed.",
      "rationale": "No independent review of simulation setup was performed. Turbulence model selection (k-omega SST) was justified by literature but not independently audited. Factor not-assessed at required level 3; achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Hemolysis power-law model form uncertainty quantified; alternative model forms (e.g., strain-based, energy dissipation) compared against experimental data.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model was used. No alternative model forms were evaluated. Model form uncertainty is a known epistemic gap at MRL 5. Achieved level 2 is substantially below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo uncertainty propagation performed for all material and boundary condition inputs; sensitivity indices (Sobol) reported for hemolysis index.",
      "rationale": "Monte Carlo UQ was performed with 500 samples propagating viscosity, density, and inlet velocity uncertainty. First-order Sobol indices were computed. Total-order indices were not computed due to computational cost. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates at each validation operating point; inter-laboratory reproducibility demonstrated.",
      "rationale": "Only two experimental replicates were available at the primary operating point. Inter-laboratory data were not obtained. Achieved level 2 is below required level 3; flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional analysis confirms that non-dimensional groups (Re, Stk) in validation experiments match those in the clinical VAD operating envelope.",
      "rationale": "Reynolds number matching was verified at the primary operating point but not across the full VAD speed range. Stokes number for red blood cells was not computed. Achieved level 2 is below required level 3; flagged as not-assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-cou2",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite six credibility factors not meeting required levels, the sponsor accepted residual risk based on: (1) the hemolysis index over-prediction is conservative with respect to patient safety; (2) compensating controls include post-market surveillance hemolysis monitoring; (3) the FDA generic pump geometry is a well-characterized benchmark and literature evidence partially compensates for gaps in model form and test sample factors. The assessment team concluded that the overall evidence package is sufficient for the intended low-risk decision tier, acknowledging that the structured Context of Use definition is embedded in the Claim and Requirement documentation rather than in a separate COU node.",
