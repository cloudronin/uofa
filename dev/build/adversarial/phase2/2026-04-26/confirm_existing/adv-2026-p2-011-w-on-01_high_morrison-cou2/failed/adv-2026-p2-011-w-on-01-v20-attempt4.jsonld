  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) operating conditions. The simulation model targets absolute hemolysis index prediction for a Class III VAD at Model Risk Level 5. Thirteen credibility factors are evaluated; seven are formally assessed and six are flagged as epistemic gaps. Monte Carlo uncertainty quantification is applied across all assessed factors. Intended use: pre-market regulatory submission support for a left-ventricular assist device indicated for end-stage heart failure patients. The model is intended to supplement bench testing by predicting hemolysis at off-design operating points inaccessible to physical test rigs. All intended-use scope detail is embedded in the Claim and Requirement prose below; no structured COU object is linked.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-regulatory-req",
  "bindsClaim": "https://uofa.net/synth/claim/vad-cfd-hemolysis-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-piv-dataset",
    "https://uofa.net/synth/data/fda-generic-pump-hemolysis-experimental"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements in FDA centrifugal pump"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037337",
