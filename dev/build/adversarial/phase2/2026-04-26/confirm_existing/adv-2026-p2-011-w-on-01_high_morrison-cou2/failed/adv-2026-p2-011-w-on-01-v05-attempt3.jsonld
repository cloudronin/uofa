  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all hemolysis sub-models; CI pipeline must pass all regression tests.",
      "rationale": "OpenFOAM v8 with hemolysis UDF is maintained under Git version control; 142-case regression suite passes CI. SQA documentation reviewed and found compliant with MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to Navier-Stokes and power-law hemolysis transport; L2 error norms must demonstrate expected convergence order.",
      "rationale": "MMS verification confirms second-order spatial convergence for velocity and first-order for hemolysis scalar transport. All norms within theoretical bounds for the discretization scheme employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for primary QoI (NIH index and peak shear stress) on three systematically refined meshes.",
      "rationale": "Three-mesh GCI study yields GCI_fine = 2.1% for NIH index and 3.8% for peak wall shear stress. Richardson extrapolation applied; discretization error is within acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) must match CFD inputs within stated uncertainty bands; temperature and hematocrit controlled.",
      "rationale": "In-vitro test loop operated at 37 ± 0.5 °C, hematocrit 30 ± 1%, flow rates 2–6 L/min matching CFD BCs. Pump speed set to 2500 RPM ± 10 RPM. Conditions documented in lab notebook and traceable to NIST standards."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E_rel) between predicted and measured NIH index must be below 15% across all validation points; systematic bias must be characterized.",
      "rationale": "Mean E_rel = 9.3% across five operating points; maximum E_rel = 13.8% at lowest flow rate. Systematic under-prediction of 6% identified and attributed to power-law model constants; bias documented and propagated to UQ."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from simulation (NIH index, time-averaged shear stress, recirculation zone volume) must map directly to clinical risk indicators for VAD hemolysis.",
      "rationale": "NIH index is the FDA-accepted primary endpoint for VAD hemolysis. Shear stress and recirculation metrics are mechanistically linked to red blood cell damage. QoI relevance confirmed by clinical advisory panel review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same FDA generic centrifugal pump geometry, physiological blood analog, and VAD operating envelope as the intended clinical COU.",
      "rationale": "Validation performed on FDA generic pump geometry (STL file sha256-verified). Blood analog (PDMS + glycerol, viscosity 3.5 mPa·s) matches clinical blood at 37 °C. Operating range 2–6 L/min covers full VAD envelope. Validation relevance rated high."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria: residuals below 1e-6 for all equations; mass imbalance below 0.01%; time-step sensitivity study confirms temporal discretization error is negligible.",
      "rationale": "All simulations converged to residuals below 1e-7. Mass imbalance 0.003%. Time-step halving study shows QoI change of 0.4%, well below the 2% threshold. Solver error contribution to total uncertainty budget is 0.8%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with mandatory peer review of mesh, boundary conditions, and post-processing scripts before results are accepted; independent re-run by second analyst.",
      "rationale": "Simulation workflow documented in 42-page SOP. Independent analyst reproduced NIH index within 1.2% using same inputs. Checklist-based review completed and signed off. Use error risk rated low."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model (SST k-omega) and hemolysis constitutive law (Giersiepen-Wurzinger power law) must be justified against published benchmark data for rotating blood-contacting devices.",
      "rationale": "SST k-omega selected based on systematic comparison of five turbulence models against FDA benchmark PIV data; SST yielded lowest velocity RMSE (4.2%). Power-law constants calibrated to Heuser-Opitz dataset. Model form uncertainty estimated at ±18% of NIH index and included in UQ budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain inputs (viscosity, density, power-law exponent, inlet velocity profile) based on traceable measurement data; Monte Carlo propagation with N ≥ 10000 samples.",
      "rationale": "Eight uncertain input parameters characterized with PDFs from literature and in-house measurements. Monte Carlo propagation with N = 50000 samples. 95th percentile NIH index = 0.0034 g/100 L, below FDA threshold. Sobol indices identify power-law exponent as dominant contributor (S1 = 0.61)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point; inter-replicate coefficient of variation (CV) below 10% for NIH index measurements.",
      "rationale": "Five independent experimental replicates performed at each of five operating points (25 total runs). Mean CV for NIH index = 6.8% across all conditions. Outlier analysis performed; no runs excluded. Sample adequacy confirmed by power analysis (power = 0.92 at alpha = 0.05)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient, head coefficient) must match between validation experiments and CFD model to within 2%.",
      "rationale": "Re_impeller matches to 0.8%, flow coefficient phi matches to 1.1%, head coefficient psi matches to 1.4%. All within the 2% equivalency threshold. Geometric fidelity confirmed by CMM measurement of test pump vs. CAD nominal: max deviation 0.03 mm."
    }
  ],
