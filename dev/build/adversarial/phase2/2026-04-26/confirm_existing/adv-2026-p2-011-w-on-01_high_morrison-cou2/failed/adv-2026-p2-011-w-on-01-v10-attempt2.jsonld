      "name": "FDA generic pump hemolysis benchmark comparison — CFD vs. experimental NIH index"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 2500 RPM operating point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034998",
