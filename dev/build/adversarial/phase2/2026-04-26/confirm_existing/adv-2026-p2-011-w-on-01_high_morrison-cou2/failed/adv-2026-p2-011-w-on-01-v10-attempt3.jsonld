  "signature": "ed25519:b7d3e9f1a2c4b6d8e0f2a4c6b8d0e2f4a6c8b0d2e4f6a8c0b2d4e6f8a0c2d4e6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression test suite coverage ≥90%, and documented release notes required at MRL 5.",
      "rationale": "CFD solver (OpenFOAM v9) is under version control with 84% regression test coverage. Release notes exist but do not address hemolysis-specific transport equation changes introduced in v9. Achieved level falls one gradation below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent analytic benchmark for all governing equations including hemolysis transport.",
      "rationale": "MMS verification was completed for Navier-Stokes and scalar transport equations. The power-law hemolysis source term was not included in the MMS suite; a simpler patch test was substituted, yielding one gradation shortfall."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined grids with GCI < 5% for hemolysis index QoI.",
      "rationale": "Three grids (4M, 11M, 28M cells) were used; GCI for velocity is 3.2% but GCI for hemolysis index is 8.7%, exceeding the 5% threshold. Achieved level set to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) documented with uncertainty bands and traceable to calibrated instruments.",
      "rationale": "Flow rate and RPM are documented with NIST-traceable calibration. Hematocrit was reported as nominal 35% without lot-to-lot variability data. Temperature uncertainty not reported. Two boundary condition parameters lack full uncertainty characterization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty Uval) computed for primary QoI with statistical comparison to experimental data including experimental uncertainty.",
      "rationale": "E% computed as 18.3% for normalized index of hemolysis; Uval estimated via Monte Carlo. Experimental uncertainty partially characterized. Comparison metric defined but confidence interval overlap analysis not performed, placing achieved level at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation directly correspond to the decision-relevant outputs specified in the device submission context, with documented traceability.",
      "rationale": "Normalized index of hemolysis (NIH) is the primary regulatory QoI and is directly validated. Secondary QoIs (shear stress distribution, recirculation volume) are not validated against experimental data, reducing relevance score by one gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments replicate COU geometry, operating range, fluid properties, and material interactions to within documented similarity criteria.",
      "rationale": "FDA generic pump geometry used in validation matches COU geometry exactly. However, validation was conducted at a single operating point (2500 RPM, 5 L/min); the COU requirement spans 2000–3500 RPM. Partial operating envelope coverage reduces achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and demonstrated; floating-point round-off and solver tolerance sensitivity assessed for hemolysis QoI.",
      "rationale": "Solver convergence residuals reported (1e-6 for all fields) but sensitivity of hemolysis index to solver tolerance not assessed. Round-off error analysis absent. Factor flagged as epistemic gap at MRL 5; achieved level defaulted to 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification, simulation execution checklist, and independent review of case setup files.",
      "rationale": "No formal user qualification record or independent case-setup review was performed. Simulation was executed by a single analyst without peer check of boundary condition assignments. Factor not assessed; epistemic gap acknowledged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model form uncertainty, including alternative model comparison or sensitivity study.",
      "rationale": "Power-law Giersiepen-Wurzinger hemolysis model selected without comparison to Arora or Faghih-Sharp models. k-ω SST turbulence model used without sensitivity study. Model form uncertainty is the dominant epistemic gap at MRL 5; factor not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; global sensitivity analysis (e.g., Sobol indices) performed to rank input influence on hemolysis QoI.",
      "rationale": "Monte Carlo sampling was performed over three parameters (viscosity, density, hemolysis exponent) but Sobol sensitivity indices were not computed. Twelve additional input parameters (surface roughness, inlet turbulence intensity, etc.) were held at nominal values without uncertainty characterization. Factor not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification provided; statistical power analysis for detection of hemolysis differences; batch-to-batch blood analog variability documented.",
      "rationale": "Experimental dataset contains n=5 repeat measurements. No statistical power analysis performed. Blood analog (bovine blood, single lot) used without inter-lot variability assessment. Factor not assessed; flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal similarity analysis demonstrating that simulation input parameters match experimental conditions within stated tolerances, including dimensional and non-dimensional parameter mapping.",
      "rationale": "No formal equivalency analysis between simulation inputs and experimental conditions was documented. Reynolds number matching was assumed implicitly but not verified. Womersley number and exposure time distribution not compared between CFD and bench test. Factor not assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, the assessment team accepted this package on the basis that (1) all seven assessed credibility factors have documented rationale and quantified shortfalls, (2) the six unassessed factors are conservatively bounded by worst-case assumptions in the Monte Carlo uncertainty propagation, and (3) the decision context is exploratory pre-submission screening rather than final regulatory submission. The team acknowledges that model form and model input gaps represent substantial epistemic uncertainty; a follow-on Complete-profile assessment is planned prior to formal 510(k) submission. The intended use scope — CFD prediction of absolute hemolysis for a Class III centrifugal VAD at MRL 5 — is fully described in the bound requirement (bindsRequirement) and the supporting claim (bindsClaim), and the assessment team treats those prose descriptions as the operative context of use for this screening decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
