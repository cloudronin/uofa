      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 5 Class III device submission.",
      "rationale": "CFD solver (ANSYS Fluent 2023R1) is under full ISO 9001 quality management. Version control, regression test suite, and release documentation satisfy Gradation 4 requirements for Class III regulatory use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via manufactured solution or equivalent benchmark.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes and scalar transport equations. Observed convergence rates match theoretical order. Code verification package reviewed and accepted by independent analyst."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be quantified on at least three systematically refined meshes; GCI on QoI < 5%.",
      "rationale": "Three-level mesh refinement study performed (coarse 4M, medium 12M, fine 32M cells). GCI for hemolysis index = 3.2%, satisfying the < 5% threshold. Richardson extrapolation applied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with measurement uncertainty for all primary inlet/outlet flow parameters.",
      "rationale": "Validation experiments conducted at FDA laboratory. Flow rate, rotational speed, inlet pressure, and fluid temperature documented with calibrated instrumentation. Measurement uncertainty < 2% for all primary parameters."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) must be computed and compared against acceptance threshold.",
      "rationale": "Normalized hemolysis index error E = 8.4% against FDA benchmark dataset. Validation uncertainty u_val computed per ASME V&V 20. Comparison falls within expanded uncertainty band; metric satisfies Gradation 4 threshold for this QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation must directly correspond to the clinical decision QoI (absolute hemolysis index) for Class III VAD regulatory submission.",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) — is identical in validation experiments and intended clinical use. No surrogate QoI substitution. Direct correspondence confirmed by clinical engineering review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation conditions must span the operating envelope of the intended VAD use case including flow rate range 3–6 L/min and speed range 2400–3600 RPM.",
      "rationale": "Validation experiments cover flow rates 3–6 L/min and rotational speeds 2400–3600 RPM, fully bracketing the intended VAD operating envelope. Fluid analogue (glycerol-water) viscosity matched to blood at 37°C within 4%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all equations; round-off error assessed.",
      "rationale": "All equation residuals converged below 1e-6. Double-precision arithmetic used throughout. Iterative convergence monitored via QoI stabilization over final 500 iterations. Round-off error estimated negligible relative to discretization error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; documented simulation plan must exist prior to execution.",
      "rationale": "Independent peer review of simulation setup plan conducted prior to execution. Reviewer confirmed boundary condition assignments, turbulence model selection (SST k-omega), and hemolysis power-law model parameters. No use errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty must be quantified; alternative turbulence and hemolysis constitutive models must be evaluated.",
      "rationale": "Model form uncertainty assessed by comparing SST k-omega, realizable k-epsilon, and RSM turbulence models. Hemolysis power-law exponent sensitivity study performed. Model form uncertainty contribution to total uncertainty budget: 14%. Documented in uncertainty quantification report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameter uncertainty must be propagated through the model via Monte Carlo or equivalent method; sensitivity indices reported.",
      "rationale": "Monte Carlo UQ with 10,000 samples performed. Input parameters: viscosity, density, pump speed, inlet flow rate, hemolysis model coefficients. Sobol sensitivity indices computed. Top contributor: hemolysis power-law exponent (S_i = 0.41)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient experimental replicates must exist to characterize experimental variability; minimum n=5 per operating point.",
      "rationale": "FDA benchmark dataset includes n=8 replicates per operating point across 6 operating conditions. Sample-to-sample variability characterized; coefficient of variation for NIH < 6% across all conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must match experimental conditions within stated tolerances.",
      "rationale": "Simulation input parameters (flow rate, rotational speed, fluid properties) matched to experimental conditions within measurement uncertainty. Parameter equivalency table documented and reviewed. No systematic offset identified."
    }
