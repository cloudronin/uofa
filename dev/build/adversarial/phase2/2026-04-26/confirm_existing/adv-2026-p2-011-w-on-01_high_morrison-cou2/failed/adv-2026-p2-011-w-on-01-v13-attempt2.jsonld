      "acceptanceCriteria": "Version-controlled solver with documented test suite covering blood-analog fluid properties; independent code review completed.",
      "rationale": "OpenFOAM v8 used with version control and regression test suite. Independent review of hemolysis subroutine not completed; achieved level falls one gradation below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to Navier-Stokes solver and hemolysis transport equation; order-of-accuracy confirmed.",
      "rationale": "MMS applied to momentum and continuity equations confirming second-order spatial accuracy. MMS not applied to the power-law hemolysis damage accumulation model; gap identified at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes; GCI reported for NIH and wall shear stress QoIs.",
      "rationale": "Three-level mesh refinement study performed (6M, 14M, 32M cells). GCI for NIH is 8.3%, exceeding the 5% target for MRL 5; finer mesh computationally prohibitive without HPC allocation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit) documented with uncertainty bounds and traceable to calibrated instrumentation.",
      "rationale": "FDA benchmark dataset provides flow rates and pressures but inlet velocity profiles are not spatially resolved; hematocrit variability across test replicates not reported. Significant gap relative to MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) applied to NIH predictions across all operating points with uncertainty intervals overlapping.",
      "rationale": "E_rel computed at 5 operating points; mean absolute error 18% for NIH. Experimental uncertainty bounds not fully characterized, limiting validation metric interpretation at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH) directly maps to clinical hemolysis threshold; sensitivity analysis confirms NIH is the dominant risk-driving output for the VAD intended use.",
      "rationale": "NIH selected as primary QoI consistent with ASTM F1841. Sensitivity analysis shows sub-lethal shear stress contributions not captured by scalar damage model; sub-hemolytic platelet activation not included in QoI set."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry, at overlapping operating conditions, with human blood or validated analog fluid.",
      "rationale": "Validation performed on FDA generic pump geometry with porcine blood analog. Patient-specific VAD operating envelopes (e.g., reduced preload states) not represented in validation dataset; extrapolation risk acknowledged."
    },
