  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for CFD-based hemolysis prediction of the FDA generic centrifugal blood pump under VAD operating conditions is accepted under Minimal profile conformance. All 13 credibility factors have been evaluated; 7 factors are fully assessed and 6 are flagged as epistemic gaps at MRL 5. The assessment team acknowledges that achieved levels fall below required levels across all assessed factors, consistent with the high model risk classification. The package is accepted as a complete and transparent documentation of the current credibility state, with identified gaps informing the risk management plan for the Class III device submission. Acceptance does not imply that the model is fit for regulatory decision-making without further gap closure.",
