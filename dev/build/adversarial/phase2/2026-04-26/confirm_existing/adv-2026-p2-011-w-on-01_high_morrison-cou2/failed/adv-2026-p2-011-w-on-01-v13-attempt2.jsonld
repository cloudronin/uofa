      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all influential model inputs (viscosity, density, hemolysis model constants, pump geometry tolerances); propagated through Monte Carlo UQ.",
      "rationale": "Flagged as epistemic gap at MRL 5. Monte Carlo UQ initiated but input distributions for hemolysis model constants (C, alpha, beta) based on literature ranges rather than experimentally calibrated posteriors."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum sample size analysis for experimental replicates; statistical characterization of inter-sample variability in hemolysis measurements; outlier detection protocol applied.",
      "rationale": "Flagged as epistemic gap at MRL 5. FDA benchmark dataset provides limited replicates (n=3 per operating point). Power analysis indicates n=8 required for 80% power at MRL 5; additional testing not feasible within project scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
