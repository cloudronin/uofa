  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Seven of thirteen credibility factors were formally assessed and all achieved levels meet or exceed required levels at Model Risk Level 5. The six not-assessed factors (use error, test samples, equivalency of input parameters, and three scoped items) are acknowledged as epistemic gaps and are bounded by conservative assumptions documented in the model inputs uncertainty analysis. The overall credibility evidence is judged sufficient for the intended regulatory submission scope as described in the Claim and Requirement nodes. The structured Context of Use object is absent from this Minimal-profile package; the intended-use scope is conveyed through the bindsClaim and bindsRequirement prose references.",
