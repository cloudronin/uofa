  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented version control, regression test suite with >95% pass rate, and traceable build artifacts for the CFD code used in VAD hemolysis prediction.",
      "rationale": "OpenFOAM v8 with internal regression suite (97% pass rate) and git-tagged release artifacts satisfies the MRL 5 software quality assurance requirement at Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must demonstrate second-order spatial convergence for the Navier-Stokes solver on canonical benchmark cases relevant to rotating machinery.",
      "rationale": "MMS study on lid-driven cavity and Taylor-Couette flow confirmed second-order convergence; benchmark results archived and traceable to solver version used in VAD simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all primary QoIs (NIH index, wall shear stress) using at least three systematically refined meshes with refinement ratio >= 1.3.",
      "rationale": "Three-level mesh refinement study (6M, 14M, 32M cells) yielded GCI < 3.2% for NIH index and < 5.1% for peak wall shear stress, meeting the Gradation 4 threshold for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with uncertainty bounds on flow rate (+/-2%), pressure head (+/-3%), and fluid temperature (+/-1 degC) for all validation cases.",
      "rationale": "FDA pump bench data includes calibrated flow meter (U=1.8%), differential pressure transducer (U=2.4%), and temperature-controlled bath (U=0.5 degC), satisfying Gradation 3 documentation requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation uncertainty U_val) must be computed for NIH index with explicit separation of numerical, experimental, and input uncertainty contributions.",
      "rationale": "Validation comparison yielded E_rel = 8.3% for NIH index; U_val computed via ASME V&V 20 framework with separated uncertainty contributions. Result falls within the Gradation 4 acceptance band for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled QoIs (NIH index, shear stress exposure time integral) must be demonstrated to be the quantities directly used in the regulatory decision context for Class III VAD hemolysis assessment.",
      "rationale": "NIH index is the FDA-recognized hemolysis metric for VAD submissions (FDA guidance 2017); the shear stress exposure integral maps directly to the power-law hemolysis model used in device labeling, confirming Gradation 3 QoI relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at operating conditions (flow rate, rotational speed, fluid viscosity) within 10% of the intended VAD COU operating envelope.",
      "rationale": "Validation cases span 3–7 L/min and 2000–3500 RPM, bracketing the 5 L/min, 2800 RPM VAD COU operating point; bovine blood analog fluid properties match within 5% of human blood at 37 degC, satisfying Gradation 4 relevance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels at least four orders of magnitude below initial residuals for all transport equations, with QoI monitors confirming steady-state or periodic convergence.",
      "rationale": "All transport equation residuals converged to 1e-6 (six orders of magnitude); NIH index monitor showed <0.1% variation over final 500 iterations, confirming Gradation 3 iterative convergence for the VAD operating point."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records and simulation execution logs must be archived to demonstrate that the analyst followed the validated workflow without undocumented deviations.",
      "rationale": "Use error assessment is scoped to the validation boundary of this submission; analyst qualification records are maintained in the sponsor quality system but have not been independently audited for this package. Gradation 2 not formally verified; flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis constitutive law must be justified through sensitivity studies and literature evidence demonstrating their applicability to the Reynolds number regime and shear stress magnitudes present in the VAD geometry.",
      "rationale": "SST k-omega turbulence model selected based on five-model sensitivity study (k-epsilon, RSM, LES, k-omega, SST); Giersiepen-Wurzinger power-law hemolysis model validated against published erythrocyte lysis data. Combined sensitivity analysis confirms Gradation 4 model form adequacy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions must be assigned to all uncertain model inputs (viscosity, density, inlet velocity profile, rotational speed) and Monte Carlo propagation must quantify their contribution to NIH index uncertainty.",
      "rationale": "Monte Carlo analysis (N=2000 samples) propagated uncertainty in six model inputs; viscosity and inlet turbulence intensity identified as dominant contributors (combined 73% of NIH index variance). Total model input uncertainty U_95 = +/-12% on NIH index, within Gradation 4 acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification and lot-to-lot variability assessment must be provided for biological fluid analogs used in hemolysis bench testing.",
      "rationale": "Test sample characterization was performed by the experimental partner; lot-to-lot variability data for bovine blood analog not available to the modeling team. Gradation 2 requirement acknowledged but not independently verified in this submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal mapping must be established between experimental boundary conditions and computational boundary conditions, with documented justification for any parameter substitutions (e.g., viscosity analog for blood).",
      "rationale": "Equivalency mapping between bench and CFD boundary conditions is documented in the test plan but has not been formally reviewed against ASME V&V 40 Gradation 3 criteria within this package. Flagged for completion in next submission cycle."
    }
  ],
