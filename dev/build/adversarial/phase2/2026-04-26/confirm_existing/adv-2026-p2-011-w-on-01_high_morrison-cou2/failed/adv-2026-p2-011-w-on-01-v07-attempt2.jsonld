  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and achieved levels meet or equal required levels at Model Risk Level 5 for the Class III VAD hemolysis prediction use case. Monte Carlo UQ bounds total hemolysis index uncertainty at ±9.2% (95th percentile), within the regulatory acceptance band. Validation metric u_val confirms model predictions fall within combined uncertainty for all five operating points. The credibility evidence package is accepted as sufficient to support regulatory submission for the intended VAD application. Structured Context of Use scope is articulated in the Claim node (https://uofa.net/synth/claim/vad-hemolysis-cfd-credibility-claim) and Requirement node (https://uofa.net/synth/req/vad-hemolysis-mrl5-requirement) per ProfileMinimal conventions.",
