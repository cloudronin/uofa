      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 2500 RPM VAD operating point"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index comparison against bench test data across five flow rates"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-pressure-head-comparison",
      "type": "ValidationResult",
      "name": "Pump pressure head H-Q curve validation under VAD operating conditions"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035282",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-simulation-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
