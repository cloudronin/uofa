  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control, regression testing suite, and documented QA procedures must be in place and auditable for a Class III device at MRL 5.",
      "rationale": "The CFD solver (OpenFOAM v9) is version-controlled under Git with a full regression test suite covering 47 canonical cases. QA documentation satisfies FDA software lifecycle guidance and ASME SQA requirements. Achieved level matches required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions must confirm expected convergence rates for all governing equation operators used in the hemolysis model.",
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes and power-law hemolysis transport operators. Second-order spatial convergence confirmed on structured and unstructured meshes. Temporal convergence verified at second order. Code verification complete at required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must demonstrate discretization error below 5% for hemolysis index QoI on the pump geometry at VAD operating conditions.",
      "rationale": "Three-level mesh refinement study (4.2M, 11.7M, 31.4M cells) performed at the nominal VAD operating point. GCI for hemolysis index QoI is 3.1%, within the 5% acceptance threshold. Grid convergence index formally documented per ASME V&V 20."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow waveform, fluid viscosity, hematocrit, temperature) must be documented with measurement uncertainty and reproduced in the simulation setup.",
      "rationale": "Bench test conditions fully documented: bovine blood at 37 °C, hematocrit 33±2%, inlet flow set by calibrated gear pump. All boundary conditions reproduced in CFD with matching uncertainty bounds. Test condition fidelity confirmed at required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) must be computed with combined experimental and numerical uncertainty, and the model must fall within the validation uncertainty band for hemolysis index.",
      "rationale": "Validation metric u_val computed following ASME V&V 20. Predicted hemolysis index deviates from experimental mean by 4.8%, well within the combined uncertainty band of ±12.3%. Comparison documented across five operating points spanning the VAD flow range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index predicted by the model must be directly linked to the clinical decision quantity (blood damage risk for VAD patients) with a documented mapping and sensitivity analysis.",
      "rationale": "Hemolysis index is the primary regulatory QoI for VAD premarket submissions. Sensitivity analysis confirms that hemolysis index is the dominant contributor to blood damage risk score. Direct mapping to ISO 10993-4 biocompatibility endpoint documented. QoI relevance confirmed at required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the FDA benchmark pump geometry under operating conditions that span the intended VAD clinical envelope, with documented similarity arguments for any departures.",
      "rationale": "Validation performed on the FDA generic centrifugal pump — the same geometry as the COU device surrogate. Operating conditions (1750–3500 RPM, 2–8 L/min) bracket the clinical VAD envelope. Similarity argument documented for blood analog substitution in subset of experiments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all transport equations; floating-point and round-off contributions must be bounded.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity, momentum, and hemolysis scalar equations. Double-precision arithmetic used throughout. Iterative solver error confirmed negligible relative to discretization error. Achieved level 3 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation protocol with peer review must be in place to prevent operator-induced errors in mesh setup, boundary condition specification, and post-processing of hemolysis index.",
      "rationale": "Simulation protocol document (SPD-VAD-CFD-002) peer-reviewed by two independent engineers. Checklist-based review performed for mesh topology, boundary condition assignment, and hemolysis post-processing scripts. No use errors identified during independent reproduction check."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The choice of turbulence closure and hemolysis constitutive model must be justified against available literature and sensitivity to model-form alternatives must be quantified.",
      "rationale": "SST k-omega turbulence model selected based on literature benchmark performance for rotating passage flows. Power-law Giersiepen-Wurzinger hemolysis model compared against modified Bludszuweit model; difference in hemolysis index less than 8%. Model-form uncertainty included in total uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (viscosity, hematocrit, hemolysis model coefficients) must be characterized with probability distributions and propagated through Monte Carlo UQ to bound their contribution to hemolysis index uncertainty.",
      "rationale": "Monte Carlo UQ performed with 5000 samples propagating uncertainty in blood viscosity (CV 6%), hematocrit (CV 4%), and hemolysis model coefficients (literature-derived distributions). 95th-percentile hemolysis index uncertainty is ±9.2%, within regulatory acceptance band. Input uncertainty fully characterized at required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A minimum of three independent experimental replicates must be available for each validation operating point to enable statistical characterization of experimental variability.",
      "rationale": "Five independent hemolysis test runs performed at each of five operating points (25 total runs). Coefficient of variation across replicates ranges from 4.1% to 9.7%. Statistical characterization of experimental scatter documented and incorporated into validation metric."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the validation simulations must be demonstrated to be equivalent to those in the COU, or differences must be bounded and shown not to materially affect the hemolysis index prediction.",
      "rationale": "Validation simulations used identical geometry, rotational speed range, and fluid properties to the COU specification. Minor difference in inlet turbulence intensity (validation: 5%, COU: 3–7%) assessed via sensitivity study; hemolysis index sensitivity to this parameter is less than 1.5%. Equivalency confirmed at required level 3."
    }
  ],
