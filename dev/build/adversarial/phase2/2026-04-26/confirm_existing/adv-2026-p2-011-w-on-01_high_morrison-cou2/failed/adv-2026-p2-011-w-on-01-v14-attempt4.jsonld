      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering all turbulence model variants used; documented release notes and change log.",
      "rationale": "OpenFOAM v9 source used with institutional fork; regression suite covers 80% of relevant test cases but turbulence model variants for non-Newtonian flow lack dedicated regression tests, yielding achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equation terms including power-law viscosity source; order-of-accuracy confirmed.",
      "rationale": "MMS applied to Navier-Stokes and continuity; power-law viscosity source term verified analytically but not via MMS in rotating reference frame, leaving a gap that caps achieved level at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for NIH QoI on three systematically refined meshes; Richardson extrapolation performed.",
      "rationale": "Three-mesh GCI study performed; GCI for NIH is 8.3%, exceeding the 5% threshold. Mesh refinement in impeller tip clearance region is constrained by computational budget, capping achieved level at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, temperature, hematocrit) documented with measurement uncertainty; matched in simulation setup.",
      "rationale": "FDA experimental conditions fully documented; inlet velocity profile measured by LDV and imposed as boundary condition; temperature and hematocrit recorded with calibrated instruments. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric) applied to NIH predictions; confidence intervals overlap criterion satisfied.",
      "rationale": "ASME V&V 20 validation metric computed; predicted NIH falls within experimental uncertainty at three of five operating points. At 3000 RPM / 3 L/min the metric exceeds threshold, preventing achievement of level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "NIH directly maps to the regulatory submission QoI; traceability from device requirement to simulation output quantity documented.",
      "rationale": "NIH is the primary regulatory metric for VAD hemolysis per ISO 10993-4 and FDA guidance. Traceability matrix links device requirement DR-VAD-003 to simulation output NIH_sim. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at device-representative operating conditions (rotational speed, flow rate, fluid properties); similarity parameters documented.",
      "rationale": "FDA pump geometry used in validation; however, blood analog fluid (glycerol-water) differs from clinical blood in viscoelastic properties. Similarity parameter analysis shows viscosity ratio within 12% but viscoelastic effects unquantified, capping achieved level at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence monitored; residuals below 1e-6 for all equations; round-off error estimated and shown negligible relative to discretization error.",
      "rationale": "Residuals converge to 1e-5 for momentum and continuity; pressure residual stalls at 3e-5 for high-RPM cases due to rotating-stationary interface treatment. Round-off analysis not performed, yielding achieved level 2 against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; checklist covering boundary condition assignment, turbulence model selection, and post-processing scripts verified.",
      "rationale": "Internal peer review conducted but no independent external reviewer engaged. Post-processing script for NIH integration reviewed internally only. Independent review required for level 3 not completed, yielding achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of NIH predictions to turbulence model choice (k-omega SST vs. RSM) and hemolysis model form (power-law vs. strain-based) quantified; dominant model form identified.",
      "rationale": "Model form uncertainty for turbulence closure and hemolysis constitutive model not systematically quantified. Epistemic gap flagged at MRL 5; resource constraints precluded multi-model ensemble runs. Achieved level 2 reflects single-model baseline only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo propagation of inlet velocity, hematocrit, and viscosity uncertainties through simulation; contribution ranking by Sobol indices.",
      "rationale": "Monte Carlo UQ performed with 500 samples across three input parameters; Sobol indices computed. Geometry tolerance uncertainty not included due to mesh regeneration cost, preventing full level 4 compliance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental blood analog samples; batch-to-batch variability in hematocrit and viscosity documented and propagated.",
      "rationale": "FDA dataset does not report batch-to-batch variability for blood analog fluid. Sample characterization data unavailable; epistemic gap prevents achievement of level 3. Flagged as data gap requiring future experimental campaign."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensional analysis confirming Reynolds number, Taylor number, and hemolysis power-law exponent equivalence between validation experiment and COU operating envelope.",
      "rationale": "Reynolds and Taylor number similarity confirmed across the 2500–5000 RPM range. Power-law exponent for hemolysis model calibrated against Giersiepen correlation; extrapolation uncertainty at extreme shear rates not bounded, capping achieved level at 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou2-vad-hemolysis-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-analyst",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under VAD conditions is accepted with conditions. Seven of thirteen factors achieved required levels; six factors show gaps predominantly in model form uncertainty and test sample characterization. The decision team determined that the identified gaps are bounded by conservative assumptions in the Monte Carlo UQ and that residual risk is acceptable for the intended regulatory submission context described in the bound requirement and claim. Conditions: (1) independent use-error review must be completed prior to final submission; (2) pressure residual convergence must be improved to 1e-6 for high-RPM operating points; (3) model form sensitivity study for turbulence closure must be initiated within 90 days.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
