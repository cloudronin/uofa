  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all blood-pump-relevant boundary condition types; ISO 9001 QMS evidence required.",
      "rationale": "OpenFOAM v9 with in-house hemolysis transport module is maintained under Git version control with a 142-case regression suite. QMS documentation satisfies ISO 9001:2015 requirements for Class III device software at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to the coupled Navier-Stokes and hemolysis transport equations; observed order of accuracy within 10% of theoretical order.",
      "rationale": "MMS study confirms second-order spatial accuracy (observed 1.93) and first-order temporal accuracy for the hemolysis scalar transport equation. Residuals converge to machine precision on benchmark cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on a three-level structured mesh sequence; Richardson extrapolation applied.",
      "rationale": "Three-level mesh refinement study (4.2 M, 12.6 M, 37.8 M cells) yields GCI of 3.1% for the normalized hemolysis index. Richardson extrapolation confirms monotonic convergence; discretization error is within the accepted threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions replicate physiological hematocrit (40±2%), temperature (37±0.5°C), and operating point within 2% of nominal CFD boundary conditions.",
      "rationale": "FDA benchmark experiments were conducted at 40% hematocrit, 37°C, and flow rates within 1.5% of CFD inlet conditions. Test condition equivalency is documented in the validation report and traceable to ASTM F1841."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) prediction within 20% of experimental mean; velocity field RMSE below 0.05 m/s in impeller outlet region.",
      "rationale": "CFD NIH prediction of 0.0031 mg/dL compares to experimental mean of 0.0028 mg/dL (10.7% error). Velocity RMSE of 0.038 m/s meets the acceptance criterion. Both comparisons satisfy the required level 4 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, shear stress distribution, residence time) are directly linked to the clinical risk of hemolysis in Class III VAD patients and mapped to device failure modes.",
      "rationale": "The selected QoIs — normalized index of hemolysis, volume-averaged shear stress, and red blood cell residence time — are the clinically accepted surrogates for hemolysis risk in rotary blood pumps per FDA guidance and ISO 10993-4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometrically and operationally similar centrifugal pump geometry at overlapping flow and rotational speed conditions; applicability argument documented.",
      "rationale": "All three validation studies used the FDA generic centrifugal pump geometry at operating conditions spanning the VAD clinical envelope. The applicability argument maps validation conditions to the intended COU operating space with documented similarity metrics."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Floating-point round-off and iterative convergence errors quantified relative to discretization error; solver error budget below 1% of GCI.",
      "rationale": "Numerical solver error was not formally assessed at MRL 5 due to resource constraints. This factor is flagged as an epistemic gap; iterative residuals were monitored but no formal error budget was constructed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification, simulation execution checklist, and independent review of boundary condition setup for each production run.",
      "rationale": "Use error was not formally assessed. Analysts hold relevant CFD qualifications and followed internal SOPs, but no formal use-error quantification or independent boundary condition audit was completed for this assessment cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis comparing power-law and strain-based hemolysis models; model-form uncertainty quantified via ensemble of three constitutive model variants.",
      "rationale": "Model form uncertainty was not assessed at this stage. The power-law Giersiepen-Wurzinger model was selected based on literature precedent, but no formal comparison against alternative hemolysis constitutive models was performed. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo propagation of blood viscosity, hematocrit, and inlet velocity profile uncertainties through the hemolysis model; 95th-percentile NIH uncertainty band reported.",
      "rationale": "Although Monte Carlo UQ infrastructure was established, formal propagation of input uncertainties to the hemolysis QoI was not completed. Blood rheology parameter distributions were documented but not propagated. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of three independent blood sample lots from different donors; inter-lot variability characterised and reported.",
      "rationale": "Test sample characterisation was not assessed within this V&V package scope. The FDA benchmark dataset used pooled samples; inter-lot variability data were not available to the modelling team. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping of all simulation input parameters to experimental counterparts; equivalency index computed for each parameter pair.",
      "rationale": "Equivalency of input parameters between the CFD model and the in-vitro experiments was not formally quantified. Boundary conditions were set to match nominal experimental values, but a systematic equivalency index analysis was not performed. Flagged as epistemic gap."
    }
  ],
