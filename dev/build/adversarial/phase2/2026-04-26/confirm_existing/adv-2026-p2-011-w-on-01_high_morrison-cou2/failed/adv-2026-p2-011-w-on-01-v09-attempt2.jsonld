  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. The model is intended for predicting absolute hemolysis indices for a Class III implantable VAD at operating points between 3 000 and 6 000 RPM with physiological flow rates of 3–6 L/min. Model Risk Level 5 applies. Monte Carlo uncertainty quantification was performed across all 13 credibility factors; seven factors were formally assessed and six were flagged as epistemic gaps. All assessed factors achieved levels meeting or exceeding required levels under the Minimal profile review. Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-requirement",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-vad-class3-claim",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-piv-dataset",
    "https://uofa.net/synth/data/hemolysis-in-vitro-benchmark-dataset"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison-r1",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark in-vitro data at 5 000 RPM / 5 L/min"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison-r2",
      "type": "ValidationResult",
      "name": "Velocity field validation via particle image velocimetry in the impeller outlet region"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-rise-comparison-r3",
      "type": "ValidationResult",
      "name": "Pump pressure-rise curve validation across three operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037497",
