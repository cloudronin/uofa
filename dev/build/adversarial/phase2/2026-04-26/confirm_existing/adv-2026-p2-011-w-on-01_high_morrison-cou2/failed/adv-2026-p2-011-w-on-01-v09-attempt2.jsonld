  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl5-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile review, the seven assessed credibility factors all meet or exceed required levels for the VAD hemolysis prediction use case. The six unassessed factors are acknowledged as epistemic gaps appropriate for a Minimal-profile submission. The assessment team concludes that the evidence package is sufficient for the intended submission stage. The scope of intended use — Class III VAD hemolysis prediction at MRL 5 — is described in the Claim and Requirement bindings and in the package description. Accepted pending escalation to Complete profile prior to regulatory submission.",
