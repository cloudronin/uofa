  "signature": "ed25519:b7e3d1f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold ISO 9001 certification and documented V&V test suite covering all boundary condition types used in the VAD simulation.",
      "rationale": "ANSYS Fluent 2023R2 carries ISO 9001:2015 certification. Internal QA suite of 312 regression tests executed; all pass. Version-controlled simulation scripts archived in institutional repository with audit trail."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to Navier-Stokes and scalar transport equations; observed order of accuracy within 10% of theoretical order.",
      "rationale": "MMS applied to incompressible N-S and power-law hemolysis transport. Observed spatial order 1.94 (theoretical 2.0) and temporal order 0.97 (theoretical 1.0); both within 10% tolerance. Code verification complete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes; GCI on hemolysis index QoI below 3%.",
      "rationale": "Three hexahedral-dominant meshes at 4.2M, 12.1M, and 34.8M cells. GCI for normalised hemolysis index: 1.8%. Asymptotic range confirmed (GCI ratio 1.02). Discretization error budget accepted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Bench test conditions (fluid temperature, hematocrit, inlet waveform) documented with measurement uncertainty and traceable to NIST standards.",
      "rationale": "Bovine blood hematocrit 35±1%, temperature 37±0.2°C, steady inlet at 5.0±0.05 L/min. All instruments NIST-traceable. Test conditions match simulation boundary conditions within stated uncertainty bands."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised hemolysis index prediction within 20% of experimental mean; velocity field L2 error below 5% of bulk velocity.",
      "rationale": "Predicted normalised hemolysis index 0.0042 vs. measured 0.0039 (7.7% deviation). Velocity field L2 error 3.1% of bulk velocity. Both criteria satisfied; output comparison accepted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical endpoints specified in the regulatory submission: hemolysis index, shear stress exposure time, and pressure rise.",
      "rationale": "Three QoIs — normalised hemolysis index, cumulative shear stress exposure, and pump pressure rise — are each explicitly cited in the 510(k) regulatory question. Mapping documented in traceability matrix TR-COU2-001."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenarios span the operating envelope of the VAD COU (2500–4500 RPM, 3–7 L/min); no extrapolation beyond validated range required.",
      "rationale": "Bench validation performed at five operating points covering the full VAD envelope. Interpolation only required for regulatory operating point; no extrapolation. Relevance confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residuals below 1e-6 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "All residuals converged below 1e-7; mass imbalance 0.003%. Double-precision arithmetic used throughout. Solver error contribution to QoI uncertainty estimated at 0.4% via perturbation study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup by analyst not involved in original model development; documented checklist of 45 setup items.",
      "rationale": "Independent review conducted by Dr. Chen (not a co-author). All 45 checklist items verified. Two minor boundary condition documentation gaps corrected prior to final run. Use error risk rated low."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage accumulation model justified by literature comparison and sensitivity analysis; model form uncertainty quantified.",
      "rationale": "SST k-omega turbulence model selected based on five-model comparison study against PIV data; lowest L2 error. Power-law hemolysis model (Giersiepen-Wurzinger) justified by meta-analysis of six competing formulations. Model form uncertainty ±18% on hemolysis index, included in total uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters characterised with probability distributions; Monte Carlo propagation with N≥5000 samples; 95th percentile hemolysis prediction remains below clinical threshold.",
      "rationale": "Monte Carlo analysis with N=5000 samples over viscosity (CV 8%), inlet velocity (CV 1%), and RBC fragility coefficient (CV 15%). 95th percentile normalised hemolysis index 0.0061, below clinical threshold of 0.010. Input uncertainty contribution 22% of total variance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum five independent blood sample batches from at least two donors; inter-batch variability characterised.",
      "rationale": "Six blood batches from three donors used. Inter-batch coefficient of variation on hemolysis index 9.3%. Donor variability incorporated into model input uncertainty distribution for RBC fragility parameter."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, fluid properties, operating conditions) demonstrated equivalent to bench test conditions through quantitative comparison table.",
      "rationale": "Equivalency matrix (Table 7 of assessment report) documents 14 input parameters. Maximum deviation: impeller tip clearance 3.1% above nominal due to manufacturing tolerance, propagated through sensitivity analysis with negligible effect on hemolysis QoI (<0.5%). Equivalency accepted."
    }
  ],
