      "acceptanceCriteria": "Documented version control, regression test suite covering hemolysis solver modules, and independent code review at MRL 5.",
      "rationale": "Version control is in place and a partial regression suite exists, but independent code review has not been completed. Achieved level 2 falls short of required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to Navier-Stokes and hemolysis transport equations; order-of-accuracy confirmed.",
      "rationale": "MMS was applied only to the Navier-Stokes solver; the hemolysis scalar transport equation was not subjected to MMS verification. Achieved level 2 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes; GCI < 5% for hemolysis index QoI.",
      "rationale": "Richardson extrapolation performed on three meshes (3M, 9M, 27M cells); GCI for hemolysis index is 8.3%, exceeding the 5% threshold. Achieved level 3 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match VAD operating envelope; blood analog fluid properties documented with uncertainty bounds.",
      "rationale": "Experiments used glycerin-water blood analog; viscosity and density are characterized but red blood cell deformability effects are unquantified. Achieved level 2 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (E%, NRMSE) computed with experimental uncertainty propagated; statistical hypothesis test at 95% confidence.",
      "rationale": "Mean hemolysis index error is 34% against experimental data; no formal statistical hypothesis test was conducted. Achieved level 2 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (normalized index of hemolysis, NIH) is directly linked to clinical hemolysis threshold for Class III VAD; sensitivity analysis confirms QoI dominance.",
      "rationale": "NIH is the primary QoI and is clinically relevant; however, sensitivity analysis shows that shear stress distribution—a secondary QoI—contributes 28% to total hemolysis variance and was not separately validated. Achieved level 2 is below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at VAD operating conditions (flow rate 3–7 L/min, pressure rise 60–120 mmHg) with human blood; geometric similarity confirmed.",
      "rationale": "Validation used the FDA generic pump geometry which differs from the target VAD impeller design; blood analog substituted for human blood. Achieved level 2 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
