      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All power-law coefficients (C, alpha, beta) characterized with probability distributions from literature meta-analysis; Monte Carlo propagation with N >= 10000 samples.",
      "rationale": "Monte Carlo UQ was performed with N=1000 samples using literature point estimates for power-law coefficients; distributional characterization from meta-analysis is absent. Factor not formally assessed against MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum 30 independent experimental runs with human blood from at least 5 donors; inter-donor variability characterized.",
      "rationale": "Experimental dataset comprises 6 runs with blood analog only; no human blood samples were used. Inter-donor variability is entirely uncharacterized. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and COU operating conditions; equivalency ratios within 10% for all critical parameters.",
      "rationale": "No formal equivalency mapping has been produced. Reynolds number and exposure time distributions differ between the FDA pump validation case and the target VAD COU. Flagged as epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepts the model for limited use in comparative hemolysis ranking between impeller design variants under VAD operating conditions (5 L/min, 100 mmHg), subject to the condition that absolute hemolysis predictions are not used directly for regulatory submission without closure of the six unassessed credibility factor gaps. The seven assessed factors all show achieved levels below required levels for MRL 5; however, the model's comparative predictive capability is deemed sufficient for design screening purposes. A gap closure plan with 12-month milestones has been agreed. The intended use scope—comparative CFD-based hemolysis screening for Class III VAD impeller design at MRL 5—is described in the claim and requirement nodes bound to this assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
