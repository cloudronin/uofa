  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the CFD hemolysis model for the VAD use scope described in the bound Claim (https://uofa.net/synth/claim/vad-hemolysis-cfd-claim) and Requirement (https://uofa.net/synth/req/vad-hemolysis-mrl5-requirement). Seven of thirteen credibility factors were assessed; all show achieved levels below required levels at MRL 5, but the team judged the gaps acceptable given the low assurance level decision tier and the conservative nature of the hemolysis model. Six factors remain as documented epistemic gaps. Acceptance is conditional on resolution of model form and model input gaps prior to Class III submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
