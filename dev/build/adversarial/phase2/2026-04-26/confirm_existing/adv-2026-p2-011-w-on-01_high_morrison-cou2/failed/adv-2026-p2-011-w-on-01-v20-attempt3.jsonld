      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records and simulation execution checklist reviewed against gradation 5 requirements for Class III device.",
      "rationale": "No formal user qualification or independent execution audit conducted. Use error is an unresolved epistemic gap at MRL 5."
    },
