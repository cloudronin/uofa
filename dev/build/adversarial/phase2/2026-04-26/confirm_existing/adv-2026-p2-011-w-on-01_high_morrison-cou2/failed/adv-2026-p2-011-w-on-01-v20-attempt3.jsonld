      "acceptanceCriteria": "Constitutive model selection justified with alternative model comparison and applicability domain analysis at gradation 5.",
      "rationale": "Power-law hemolysis model (Giersiepen-Wurzinger) applied without alternative model comparison. Model form uncertainty is a critical unresolved gap for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All material and boundary condition inputs characterized with probability distributions and propagated through Monte Carlo at gradation 5.",
      "rationale": "Monte Carlo UQ performed for three parameters (viscosity, density, RPM); remaining 11 input parameters treated as deterministic. Full input uncertainty characterization not achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size, donor variability, and measurement uncertainty of experimental hemolysis data documented and sufficient at gradation 5.",
      "rationale": "FDA pump dataset uses bovine blood from a single donor pool. Inter-donor and inter-species variability not characterized. Test sample adequacy is an unresolved epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental and simulation input parameters formally demonstrated with uncertainty overlap analysis at gradation 5.",
      "rationale": "Nominal input matching performed; formal equivalency analysis with uncertainty overlap not conducted. Gap identified but unresolved at MRL 5."
    }
