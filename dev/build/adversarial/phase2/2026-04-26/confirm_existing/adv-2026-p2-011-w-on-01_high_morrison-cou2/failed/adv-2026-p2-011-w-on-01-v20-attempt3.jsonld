      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with version-controlled source and regression testing at gradation 4 for MRL 5 Class III device context.",
      "rationale": "OpenFOAM solver used with documented regression suite; however, formal configuration management and independent code review are incomplete. Achieved gradation 3 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark verification demonstrating order-of-accuracy convergence at gradation 4.",
      "rationale": "Method of manufactured solutions applied to simplified channel flow; spatial order of accuracy confirmed at 1.9 (near second order). Full pump geometry verification not completed, limiting achievement to gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index reported with GCI below 5% on QoI at gradation 4.",
      "rationale": "Three-level mesh refinement study performed; GCI on hemolysis index is 8.2%, exceeding the 5% threshold. Discretization error characterized but not reduced to required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match VAD operating envelope with documented uncertainty at gradation 3.",
      "rationale": "FDA pump experiments conducted at 2500 RPM and 5 L/min; inlet turbulence intensity and fluid temperature uncertainty not fully characterized. Achieved gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms) applied to hemolysis index and velocity fields with statistical confidence bounds at gradation 4.",
      "rationale": "RMS error computed for hemolysis index (18%) and axial velocity (12%). Statistical confidence intervals not propagated through the comparison metric, limiting to gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to clinical hemolysis endpoint with documented traceability to device decision at gradation 4.",
      "rationale": "Hemolysis index is the primary clinical QoI; traceability to the 510(k) decision criterion is documented in the Claim node prose. Formal QoI sensitivity ranking not completed, limiting to gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation hierarchy explicitly maps bench experiments to VAD operating conditions with gap analysis at gradation 4.",
      "rationale": "Validation performed on FDA generic pump geometry at matched flow conditions; patient-specific geometry and hematocrit variability gaps identified but not quantitatively bridged. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off, and parallel decomposition errors bounded and reported at gradation 5 for MRL 5.",
      "rationale": "Solver error assessment not initiated. Residual convergence monitored to 1e-6 but formal error bounding per ASME V&V 40 gradation 5 requirements not performed. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
