  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression coverage >90% and version-controlled release notes traceable to ASME-VV40 SQA requirements at MRL 5.",
      "rationale": "OpenFOAM v8 used without formal SQA documentation meeting MRL 5 requirements. Internal regression suite covers ~55% of relevant solver paths. Achieved level 2 against required level 4; gap flagged for corrective action."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must demonstrate second-order spatial convergence for all governing equations relevant to hemolysis prediction.",
      "rationale": "MMS applied only to Navier-Stokes equations; scalar transport equation for hemolysis index not independently verified. Observed convergence order 1.6 for momentum, not assessed for hemolysis scalar. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on at least three systematically refined grids; GCI < 5% on QoI (NIH) required.",
      "rationale": "Three-grid GCI study performed; GCI on NIH = 8.3%, exceeding the 5% threshold. Spatial discretization error is the dominant numerical uncertainty contributor. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with uncertainty bounds; inlet velocity profile and fluid temperature must match simulation inputs within stated tolerances.",
      "rationale": "FDA benchmark experimental data provides mean inlet flow rate but lacks spatially resolved inlet velocity profile. Temperature recorded ±2°C but viscosity sensitivity not propagated. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) with statistical confidence intervals; model prediction must fall within experimental uncertainty band for primary QoI.",
      "rationale": "NIH prediction error E_rel = 18% against experimental mean; experimental uncertainty band ±12%. Prediction falls outside uncertainty band at primary operating point. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear stress exposure) must be directly mapped to clinical decision criteria for VAD device submission.",
      "rationale": "NIH is the primary regulatory QoI and is directly assessed. Wall shear stress distributions are reported but not formally linked to a clinical threshold in the submission context. Partial relevance mapping achieved; level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at operating conditions (flow rate, rotational speed, fluid properties) representative of the intended VAD clinical use envelope.",
      "rationale": "FDA benchmark pump geometry differs from the target VAD impeller design in blade count and tip clearance. Operating conditions partially overlap but do not span the full clinical envelope (3–6 L/min). Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual tolerance <1e-6 for all equations; round-off error assessed via double-precision verification.",
      "rationale": "Iterative residual convergence documented to 1e-4 only; double-precision round-off analysis not performed. Factor not assessed to required depth; flagged as epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review; user qualification records and simulation execution checklist required.",
      "rationale": "No formal use-error assessment conducted. Simulation executed by a single analyst without independent peer review of setup files or boundary condition assignments. Epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis constitutive law must be justified with sensitivity analysis; alternative model forms evaluated.",
      "rationale": "SST k-omega turbulence model selected based on prior literature but no formal sensitivity study comparing RSM or LES alternatives. Giersiepen hemolysis power-law used without evaluation of Arora or Faghih models. Significant model-form uncertainty unquantified. Achieved level 2 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs must have documented uncertainty distributions; Monte Carlo or equivalent propagation required at MRL 5.",
      "rationale": "Monte Carlo UQ performed for blood viscosity and inlet flow rate (2 of 7 sensitive inputs). Remaining inputs (surface roughness, fluid density temperature-dependence, RBC fragility index) treated as deterministic. Partial UQ coverage yields achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples (blood or blood analogue) must be characterised for hematocrit, RBC age distribution, and storage time; traceability to lot records required.",
      "rationale": "FDA benchmark data uses bovine blood analogue; hematocrit and RBC characterisation data not publicly available in dataset documentation. Sample traceability cannot be established. Epistemic gap. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional and non-dimensional similarity parameters (Reynolds number, specific speed, Stokes number for RBCs) must be matched between validation experiment and COU operating conditions.",
      "rationale": "No formal similarity analysis performed between FDA benchmark operating conditions and target VAD clinical envelope. Reynolds number at design point differs by ~22%. Equivalency of input parameters not established. Epistemic gap at MRL 5. Achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-cap",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team reviewed all 13 credibility factors for the CFD hemolysis prediction of the FDA centrifugal blood pump under VAD operating conditions. Although 7 of 13 assessed factors show achieved levels below required levels and 6 factors carry unresolved epistemic gaps, the team determined that the combined evidence is sufficient for a Low assurance level acceptance contingent on a corrective action plan (CAP). The CAP requires: (1) extension of Monte Carlo UQ to all 7 sensitive inputs within 90 days, (2) independent peer review of simulation setup files, (3) MMS verification of the hemolysis scalar transport equation, and (4) a formal similarity analysis mapping FDA benchmark conditions to the VAD clinical envelope. The decision reflects the Low assurance level designation and the non-life-critical use of this model output as a supplementary design screening tool rather than a primary regulatory submission artefact at this stage.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
