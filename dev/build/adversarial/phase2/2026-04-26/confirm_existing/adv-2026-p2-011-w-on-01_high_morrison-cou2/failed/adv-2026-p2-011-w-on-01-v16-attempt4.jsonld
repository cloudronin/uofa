      "name": "NIH prediction vs. experimental bench data — FDA centrifugal pump"
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field comparison against PIV measurements at 5 L/min operating point"
    }
