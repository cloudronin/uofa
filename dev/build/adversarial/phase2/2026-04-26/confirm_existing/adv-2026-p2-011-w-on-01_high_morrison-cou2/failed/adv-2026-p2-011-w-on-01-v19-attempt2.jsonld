  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and maintain a documented regression-test suite with 100% pass rate on CFD benchmark cases relevant to rotating hemodynamics.",
      "rationale": "OpenFOAM v8 deployment uses a version-controlled build with full regression suite; ISO 9001 certification documentation on file. Achieved level equals required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equation terms with observed order of accuracy within 10% of formal order.",
      "rationale": "MMS applied to incompressible Navier-Stokes and scalar transport (hemolysis power-law) terms. Observed second-order convergence confirmed for velocity and scalar fields. Residual norms below 1e-8."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported on three systematically refined meshes; GCI on hemolysis index QoI below 5%.",
      "rationale": "Three mesh levels (4.2M, 11.7M, 31.4M cells) yield GCI of 3.8% on the normalized hemolysis index. Asymptotic range confirmed; discretization error is within required tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity, temperature) match simulation inputs within stated measurement uncertainty bands.",
      "rationale": "In-vitro test loop operated at 5 L/min, 2500 RPM, 37°C with bovine blood analog (glycerol-water, 3.5 cP). All boundary conditions replicated in CFD within 2% of measured values. Temperature deviation less than 0.5°C."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predicted within 20% of experimental mean; pressure rise within 5%; velocity field L2 error below 15% of mean inlet velocity.",
      "rationale": "CFD NIH prediction: 0.0042 g/100L vs. experimental 0.0039 g/100L (7.7% error). Pressure rise 185 mmHg vs. 183 mmHg measured (1.1%). Velocity L2 error 9.3%. All criteria satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, peak shear stress, exposure time distribution) are directly linked to the clinical decision criterion for hemolysis safety under VAD operating conditions as specified in the device submission requirement.",
      "rationale": "NIH is the primary regulatory QoI per FDA guidance for VAD hemolysis assessment. Peak shear stress and Lagrangian exposure time are secondary QoIs tied directly to the power-law damage model. All QoIs traceable to the clinical requirement node."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the FDA generic centrifugal pump geometry under flow conditions overlapping the intended VAD operating envelope (2000–3600 RPM, 3–7 L/min).",
      "rationale": "All validation runs executed on the FDA benchmark geometry. Operating conditions span the VAD envelope specified in the bound requirement. No extrapolation beyond validated range required for the nominal operating point."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated by residual drop of at least four orders of magnitude and stability of QoI monitors over the final 500 iterations.",
      "rationale": "Pressure and velocity residuals drop six orders of magnitude. NIH monitor variance over final 500 iterations is 0.3%. Solver error contribution to total simulation uncertainty estimated at less than 1%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of simulation setup, boundary condition assignment, and post-processing scripts; documented checklist with sign-off.",
      "rationale": "A second CFD analyst independently reproduced the mesh, boundary conditions, and post-processing pipeline using only the documented simulation protocol. No discrepancies found. Checklist signed and archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison of k-omega SST, k-epsilon, and LES results against PIV data; hemolysis constitutive model validated against published shear-exposure datasets.",
      "rationale": "k-omega SST selected after three-model comparison; SST yields lowest velocity L2 error (9.3%) vs. k-epsilon (14.1%) and LES (8.8% but 40x cost). Power-law hemolysis model (Giersiepen coefficients) validated against Wurzinger shear-exposure data within 15%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in all model inputs (viscosity, density, power-law coefficients, rotational speed) propagated via Monte Carlo (n=500) and total input uncertainty contribution to NIH reported.",
      "rationale": "Monte Carlo ensemble of 500 runs propagates viscosity (±5%), density (±1%), power-law exponent (±8%), and rotational speed (±1%). 95th-percentile NIH uncertainty band is ±18%, within acceptable range for MRL 5 decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates per operating point; inter-replicate coefficient of variation on NIH below 15%.",
      "rationale": "Eight independent hemolysis experiments conducted at the nominal operating point (5 L/min, 2500 RPM). Coefficient of variation on NIH is 9.2%. Sample size sufficient for statistical comparison with CFD prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, fluid properties, rotational speed, flow rate) match experimental test article parameters within documented tolerance; any deviations assessed for impact on QoIs.",
      "rationale": "CAD geometry used in CFD matches test article within 0.05 mm manufacturing tolerance. Fluid properties set to measured values. Rotational speed matches tachometer reading within 0.4%. No significant QoI sensitivity to residual deviations confirmed by sensitivity analysis."
    }
  ],
