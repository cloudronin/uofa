  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. This package evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. All 13 credibility factors are assessed; seven factors achieved their required gradation levels and six were scoped out as epistemic gaps at MRL 5. Monte Carlo uncertainty quantification was performed. Decision: Accepted under the Minimal assurance profile. NOTE: intended-use scope is described only in the Claim and Requirement prose; no structured hasContextOfUse node is linked from this UnitOfAssurance.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-requirement",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-credibility-claim",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/monte-carlo-uq-samples-mrl5"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-level-comparison",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "CFD velocity field validation against PIV measurements in pump volute"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034918",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e4b7d09e6f2a1c3d5b8e0f4a7c9d2e5b8f1a4c7d0e3f6a9b2c5d8e1f4a7",
  "signature": "ed25519:b9e2d4f6a1c3e5b7d9f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a quality management system with documented version control, regression testing, and traceability to requirements at gradation 4 or higher for MRL 5.",
      "rationale": "The CFD solver (OpenFOAM v8) is operated under an ISO 9001-compliant QMS with full version control, automated regression test suite covering 95% of solver modules, and documented traceability matrix. Achieved gradation 4 meets the required level for MRL 5 VAD hemolysis prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions and manufactured solutions demonstrating correct order-of-accuracy convergence for all governing equations relevant to hemolysis prediction at gradation 4.",
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes and scalar transport equations confirms second-order spatial convergence and first-order temporal convergence. Three benchmark cases from the FDA Critical Path Initiative were reproduced within 5% of published reference values. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all quantities of interest with GCI below 5% on the fine grid; Richardson extrapolation required for at least two QoIs at gradation 4.",
      "rationale": "Three-level grid refinement study performed (coarse 4.2M, medium 11.7M, fine 28.4M cells). GCI for hemolysis index on fine grid is 8.3%, exceeding the 5% threshold. Richardson extrapolation performed for hemolysis index and wall shear stress. Achieved gradation 3 due to GCI exceedance; required level 4 not met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty quantification covering flow rate, rotational speed, fluid viscosity, and temperature; conditions must be representative of VAD operating envelope.",
      "rationale": "FDA generic pump experiments conducted at 2500 RPM and 5 L/min with bovine blood analog. Flow rate uncertainty ±0.5%, speed uncertainty ±10 RPM, viscosity measured at 37°C ±0.02 cP. Conditions span 80% of the intended VAD operating envelope. Gradation 3 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation metric u_val) must be computed with combined experimental and simulation uncertainty at gradation 4; statistical hypothesis testing required.",
      "rationale": "Relative error in hemolysis index is 14.2% against experimental mean. Combined uncertainty u_val computed per ASME V&V 20. No formal statistical hypothesis test applied due to limited experimental replicates (n=4). Achieved gradation 3; required level 4 not met due to absence of hypothesis testing and elevated relative error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, wall shear stress, velocity profiles) must be directly traceable to the clinical decision QoIs specified in the device submission requirement.",
      "rationale": "Hemolysis index (NIH normalized) is the primary QoI and maps directly to the FDA submission requirement for Class III VAD biocompatibility. Secondary QoIs (WSS, velocity profiles) support mechanistic understanding. Full traceability matrix documented in the V&V plan. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted at conditions sufficiently close to the intended COU geometry, flow regime, and fluid properties; any gap between validation conditions and COU must be quantified and bounded at gradation 4.",
      "rationale": "Validation performed on FDA generic pump geometry; intended COU is a proprietary centrifugal VAD with similar specific speed. Geometric similarity index 0.74; Reynolds number ratio 0.91. Gap analysis performed but extrapolation uncertainty not formally bounded with confidence intervals. Achieved gradation 3; required level 4 not met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all transport equations; round-off error assessed relative to discretization error at gradation 3.",
      "rationale": "All continuity, momentum, and scalar transport residuals converged to below 1e-6. Round-off error estimated at double precision is four orders of magnitude below discretization error. Iterative convergence monitored over last 500 iterations with variation below 0.1%. Gradation 3 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup, boundary condition specification, and post-processing must be independently reviewed by a qualified analyst not involved in the original simulation at gradation 3.",
      "rationale": "Independent technical review of simulation inputs, boundary conditions, and post-processing scripts performed by a senior CFD engineer not involved in original model setup. Review checklist based on FDA guidance for computational fluid dynamics in cardiovascular devices completed with no critical findings. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty arising from turbulence model selection, hemolysis damage model formulation, and non-Newtonian blood rheology must be quantified through model comparison studies and sensitivity analysis at gradation 5.",
      "rationale": "Model form uncertainty is flagged as an epistemic gap at MRL 5. Three turbulence models (k-omega SST, RSM, LES) were run at a single operating point but systematic model form uncertainty quantification across the full VAD operating envelope was not completed. Hemolysis damage model (Giersiepen-Wurzinger) is known to have high uncertainty; alternative model comparison not performed. Assessed gradation 2 reflects partial evidence only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs (fluid properties, boundary conditions, geometric tolerances) must be characterized with probability distributions and propagated through the model using Monte Carlo or equivalent methods to produce output uncertainty bounds at gradation 5.",
      "rationale": "Monte Carlo UQ performed for five input parameters (viscosity, density, inlet velocity profile, rotational speed, surface roughness) with 500 samples. However, blood rheology parameters and red blood cell fragility index were not included in the UQ due to lack of patient-specific data. Partial Monte Carlo coverage yields gradation 2; full gradation 5 requires all influential inputs characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for biological variability (hematocrit, RBC age, donor variability) and statistical power analysis must confirm adequate sample size at gradation 4.",
      "rationale": "FDA generic pump experiments used bovine blood analog (not human blood) with fixed hematocrit 35%. Biological variability between donors, RBC age effects, and patient population variability not characterized. Statistical power analysis not performed; n=4 replicates insufficient for gradation 4. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between simulation input parameters and experimental conditions must be formally demonstrated including dimensional analysis confirming dynamic similarity across all relevant dimensionless groups at gradation 4.",
      "rationale": "Reynolds and Taylor numbers matched between simulation and experiment. However, Stokes number for RBC deformation, Womersley number for pulsatile effects, and non-Newtonian Carreau model parameters were not formally matched. Dimensional analysis incomplete for hemolysis-relevant groups. Achieved gradation 2; required level 4 not met."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-minimal-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal assurance profile, the seven assessed credibility factors collectively demonstrate sufficient evidence to support the claim that the CFD model can predict hemolysis trends for the FDA generic centrifugal pump at the assessed operating point. Six factors flagged as not-assessed represent known epistemic gaps at MRL 5 that are acknowledged in the submission. The decision authority accepted the residual uncertainty given the low assurance level designation and the supporting Monte Carlo UQ results. The intended use scope — Class III VAD hemolysis prediction at 2500 RPM and 5 L/min for pre-submission FDA engagement — is described in the bound Requirement (https://uofa.net/synth/req/vad-hemolysis-mrl5-requirement) and Claim (https://uofa.net/synth/claim/vad-hemolysis-cfd-credibility-claim) nodes.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
