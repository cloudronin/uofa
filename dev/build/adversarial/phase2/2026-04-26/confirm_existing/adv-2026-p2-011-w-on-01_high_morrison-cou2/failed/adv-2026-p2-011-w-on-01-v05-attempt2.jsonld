  "signature": "ed25519:b7c3e9a2f4d1085e6c3b27a5e8f0d4c9b2a6e1f3d8c5b0a7e4f2d9c6b3a0e5f8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all relevant flow regimes; formal software quality plan required at MRL 5.",
      "rationale": "OpenFOAM v8 used with institutional version control and regression tests; however, no formal SQA plan was produced and hemolysis sub-model unit tests are incomplete. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent benchmark demonstrating correct implementation of governing equations and hemolysis transport model.",
      "rationale": "MMS verification completed for Navier-Stokes solver; hemolysis scalar transport equation verified against analytical solution for simple Couette flow only. Full rotating-frame MMS not performed. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic grid convergence study with Richardson extrapolation; GCI < 5% for hemolysis index QoI at MRL 5.",
      "rationale": "Three-level grid refinement study performed; GCI for hemolysis index is 11%, exceeding the 5% threshold. Spatial order of accuracy confirmed at 1.8. Temporal convergence verified. Achieved level 3 due to GCI exceedance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must bracket VAD operating envelope (flow rate 3–6 L/min, rotational speed 2400–3600 RPM); fluid properties must match blood analog within specified tolerances.",
      "rationale": "FDA pump experiments used glycerol-water blood analog at 37°C; flow rates 2.5–5 L/min partially bracket the VAD envelope. Upper flow rate and rotational speed extremes not covered. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rms) for hemolysis index within 20% of experimental mean; statistical significance demonstrated.",
      "rationale": "Predicted hemolysis index deviates 35–55% from experimental values across operating points. Trend prediction is qualitatively correct but absolute magnitudes are not within acceptance threshold. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (normalized index of hemolysis, NIH) must directly correspond to clinical hemolysis risk metric used in VAD regulatory submissions.",
      "rationale": "NIH is the standard regulatory QoI for VAD hemolysis assessment per FDA guidance; model outputs are directly mapped to NIH. Full correspondence confirmed. Achieved level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use a geometrically similar pump with equivalent Reynolds and Taylor numbers to the intended VAD COU; hematocrit must be within 5% of clinical range.",
      "rationale": "FDA generic pump geometry is a reasonable surrogate but differs from proprietary VAD impeller geometry. Blood analog hematocrit equivalent accepted. Geometric similarity gap reduces relevance score. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance 1e-6 for all equations; round-off error analysis documented.",
      "rationale": "Momentum and continuity residuals converge to 1e-5; hemolysis scalar residual stalls at 5e-5 in recirculation zones. Round-off analysis not formally documented. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification, simulation protocol, and independent review of setup parameters for VAD hemolysis predictions.",
      "rationale": "No formal user qualification protocol established. Simulation setup reviewed internally but not by independent third party. Epistemic gap flagged at MRL 5. Factor not formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mechanistic justification for choice of hemolysis damage accumulation model (power-law vs. strain-based); sensitivity to model form documented; alternative model forms evaluated.",
      "rationale": "Giersiepen-Wurzinger power-law hemolysis model selected; known to overpredict at low shear. Strain-based model evaluated in sensitivity study showing 40% variation in NIH. Model form uncertainty is the dominant uncertainty source. Achieved level 2 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and boundary condition inputs characterized with uncertainty bounds; Monte Carlo propagation performed for hemolysis model coefficients.",
      "rationale": "Monte Carlo UQ performed for hemolysis model coefficients (alpha, beta, C) using literature-derived distributions. Inlet boundary condition uncertainty not propagated. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point; inter-laboratory reproducibility data available.",
      "rationale": "FDA pump dataset provides single-laboratory measurements; no inter-laboratory reproducibility data available for hemolysis index. Sample size insufficient for statistical characterization at MRL 5. Not formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless parameters (Re, Taylor number, Womersley number) in validation experiments must match COU operating conditions within 10%.",
      "rationale": "Reynolds number matched within 8% across primary operating points. Taylor number for rotating frame differs by up to 18% at extreme speed conditions. Partial equivalency confirmed. Achieved level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl5-accepted-low",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The UoA is accepted at Low assurance for the VAD hemolysis prediction context. Seven of thirteen credibility factors were formally assessed; all show achieved levels below required levels for MRL 5, with model form uncertainty (factor gap: required 5, achieved 2) identified as the dominant risk. Six factors carry epistemic gaps. The assessment team accepts the package at Low assurance conditional on: (1) model form sensitivity bounds being communicated explicitly to the regulatory decision-maker, (2) the 35-55% hemolysis index deviation being treated as a conservative overestimate for safety purposes only, and (3) no use of absolute NIH predictions for device approval without supplementary in vitro hemolysis testing. The structured Context of Use scope is fully described in the bound Requirement node (https://uofa.net/synth/req/cou2-vad-hemolysis-mrl5) and Claim node (https://uofa.net/synth/claim/cou2-cfd-hemolysis-prediction-vad).",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
