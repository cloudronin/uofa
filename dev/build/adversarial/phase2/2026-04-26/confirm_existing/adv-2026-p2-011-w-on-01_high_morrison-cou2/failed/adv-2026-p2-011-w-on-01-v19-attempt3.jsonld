  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team reviewed all 13 credibility factors for the CFD hemolysis prediction model applied to the FDA generic centrifugal blood pump under VAD operating conditions (Class III, MRL 5, 2500 RPM, 5 L/min). Seven factors were fully assessed; all show achieved levels below required levels, consistent with the elevated epistemic demands of MRL 5. Six factors carry epistemic gap flags and are marked not-assessed. Despite these gaps, the team judges that the Low assurance level is appropriate for the current stage of development, that the identified gaps are documented and bounded, and that the model outputs are sufficient to support a preliminary regulatory interaction. The package is accepted with the understanding that all not-assessed factors must be resolved prior to final submission.",
