      "rationale": "Monte Carlo analysis performed for three parameters; Sobol indices not computed and geometric tolerance uncertainties excluded. Insufficient coverage for MRL 5 requirement; epistemic gap flagged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates with inter-laboratory reproducibility assessment for hemolysis index measurements.",
      "rationale": "Single laboratory provided all experimental data; inter-laboratory reproducibility study not conducted. Sample size insufficient to characterize biological variability at MRL 5."
    },
