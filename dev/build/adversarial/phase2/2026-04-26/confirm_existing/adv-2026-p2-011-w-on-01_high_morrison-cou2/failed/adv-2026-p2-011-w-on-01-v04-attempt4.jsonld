  "signature": "ed25519:9f8e7d6c5b4a3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8c7b6a5f4e3d2c1b0a9f8e",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented version control, regression test suite, and configuration management plan consistent with MRL 5 Low assurance requirements.",
      "rationale": "The CFD solver (OpenFOAM v8) is under version control with a registered regression test suite covering 47 benchmark cases. Configuration management records are complete and auditable. Achieved level 2 meets required level 2 for Low assurance at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification on canonical rotating-flow benchmark demonstrating expected convergence rate.",
      "rationale": "Method of manufactured solutions applied to rotating annular Couette flow confirms second-order spatial convergence (observed order 1.94). Taylor–Green vortex temporal verification confirms first-order temporal convergence for the selected implicit scheme. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI with GCI fine < 10% at nominal operating point.",
      "rationale": "Three-level structured mesh refinement study performed (coarse 2.1M, medium 5.8M, fine 14.2M cells). GCI for normalized hemolysis index is 6.3% at the fine level, satisfying the 10% threshold. Richardson extrapolation applied. Achieved level 2 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions reproduced in simulation within stated measurement uncertainty bands; fluid properties matched to within 5%.",
      "rationale": "Inlet velocity profiles, rotational speed, and fluid viscosity from the FDA round-robin dataset are reproduced in the CFD boundary conditions. Fluid properties (viscosity, density) match within 2.1% of experimental values. Inlet turbulence intensity set per measured PIV data. Achieved level 2 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., NRMSE or E_rel) for hemolysis index prediction within acceptable band relative to experimental scatter.",
      "rationale": "Normalized hemolysis index predicted within 18% of experimental mean across five operating points; experimental inter-laboratory scatter is 22%. Relative error is within the experimental uncertainty envelope. NRMSE = 0.14 across all validation cases. Achieved level 2 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated traceability from clinical hemolysis endpoint (plasma free hemoglobin) to modeled QoI (normalized index of hemolysis) with documented power-law damage model.",
      "rationale": "The NIH-based hemolysis index is directly traceable to plasma free hemoglobin via the Giersiepen–Wurzinger power-law model. Sensitivity analysis confirms hemolysis index is the dominant QoI driver for the VAD use scenario. Achieved level 2 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenarios share geometric similarity, Reynolds number range, and hemolysis damage model with the intended VAD COU; documented similarity argument.",
      "rationale": "FDA generic centrifugal pump geometry and operating envelope (2400–3600 RPM, 3–6 L/min) overlap substantially with the target VAD device envelope. Reynolds number similarity is maintained. Geometric differences are bounded by a documented similarity argument. Achieved level 2 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-5 for all transport equations at each time step; mass imbalance below 0.01%.",
      "rationale": "All momentum and continuity residuals converge below 1e-6 per time step. Global mass imbalance is 0.003%. Linear solver tolerance is set conservatively relative to discretization error. Achieved level 1 meets required level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation setup checklist and independent peer review of boundary condition specification.",
      "rationale": "A 42-item simulation setup checklist was completed and independently reviewed by a second analyst. Boundary condition files are archived with hash verification. No use errors identified during peer review. Achieved level 1 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for turbulence model selection (SST k-omega) and hemolysis damage model with sensitivity to model form alternatives documented.",
      "rationale": "SST k-omega selected based on published benchmark comparisons for rotating confined flows. Sensitivity study comparing SST, realizable k-epsilon, and LES shows hemolysis index varies by 12% across models; SST is closest to experimental data. Power-law damage model uncertainty quantified via Monte Carlo. Achieved level 2 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in blood viscosity, inlet flow rate, and rotational speed propagated through model via Monte Carlo; total input uncertainty contribution to hemolysis QoI quantified.",
      "rationale": "Monte Carlo UQ (n=500 samples) performed over viscosity (±5%), inlet flow rate (±3%), and rotational speed (±1%). Combined input uncertainty contributes ±9% to hemolysis index at 95th percentile. Distributions sourced from manufacturer specifications and clinical literature. Achieved level 2 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental dataset includes minimum three independent laboratories or test runs with documented sample preparation and measurement protocols.",
      "rationale": "FDA round-robin dataset includes five independent laboratory measurements of hemolysis index under identical operating conditions. Sample preparation and measurement protocols are documented per ASTM F1830. Achieved level 1 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented mapping between experimental input parameters and simulation boundary conditions with quantified equivalency gaps.",
      "rationale": "Inlet velocity profile, fluid temperature, hematocrit, and rotational speed are mapped from experimental records to simulation inputs. Hematocrit equivalency gap (experimental 35% vs. model 37%) is within the ±5% acceptance band. All other parameters are equivalent within measurement uncertainty. Achieved level 1 meets requirement."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed; achieved levels meet or exceed required levels for Low assurance at Model Risk Level 5. Monte Carlo UQ confirms combined uncertainty is within acceptable bounds for the VAD hemolysis prediction use. The claim that CFD can predict absolute hemolysis levels for the specified centrifugal pump geometry and operating envelope is supported with sufficient credibility evidence for pre-market submission purposes. No unresolved gaps remain at the declared assurance tier.",
