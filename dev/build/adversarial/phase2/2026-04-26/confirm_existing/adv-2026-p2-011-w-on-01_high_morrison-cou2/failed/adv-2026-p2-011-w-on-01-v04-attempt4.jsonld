  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. This package evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. The intended use is limited to pre-market submission support for a continuous-flow left ventricular assist device operating at 2400–3600 RPM and flow rates of 3–6 L/min. Monte Carlo uncertainty quantification is performed. All 13 credibility factors are addressed; achieved levels meet or exceed required levels for the declared Low assurance tier. Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-cfd-hemolysis-absolute-prediction",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-fda-centrifugal-pump-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset",
    "https://uofa.net/synth/data/hemolysis-nib-round-robin-2021"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-absolute-level-001",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index validation against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv-002",
      "type": "ValidationResult",
      "name": "Velocity field comparison with PIV measurements at nominal VAD operating point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041740",
