      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and a documented V&V test suite with regression coverage exceeding 90% of active code paths.",
      "rationale": "ANSYS Fluent 2023R1 holds ISO 9001 certification. Internal regression suite covers 93% of active solver paths. Release notes and change-control records reviewed and archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations; observed order of accuracy within 10% of formal order.",
      "rationale": "MMS applied to incompressible Navier-Stokes with power-law viscosity. Observed order 1.92 vs. formal order 2.0 (4% deviation). Code verification complete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes; GCI < 5% on hemolysis index QoI.",
      "rationale": "Three meshes (4.2M, 11.6M, 31.4M cells) used. GCI on hemolysis index is 7.3%, exceeding the 5% threshold. Partial credit awarded; gap documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within measurement uncertainty; inlet flow waveform reproduced to within 2%.",
      "rationale": "Bench test conducted at 4 L/min, 3000 RPM. CFD boundary conditions set from measured pressure-flow curves. Inlet waveform deviation 1.4%. Test conditions equivalence confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized error on hemolysis index QoI less than 15% across all operating points; statistical validation metric E < 1.",
      "rationale": "Mean normalized error on hemolysis index is 18% across five operating points; E-metric is 1.12. Exceeds acceptance threshold. Gap documented for remediation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (hemolysis index) directly maps to the clinical endpoint (plasma free hemoglobin) used in the 510(k) submission.",
      "rationale": "Hemolysis index computed from Giersiepen-Wurzinger power-law model maps directly to plasma free hemoglobin measurements reported in the predicate device submission. QoI relevance confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on geometrically identical FDA generic pump at operating conditions spanning the full VAD envelope.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry (identical to simulation geometry) at 2, 4, and 6 L/min across 2000–4000 RPM. Full VAD operating envelope covered."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated by residual drop of at least 4 orders of magnitude and stabilization of all QoI monitors.",
      "rationale": "All residuals dropped 5 orders of magnitude. Hemolysis index monitor stabilized within 0.1% over final 500 iterations. Solver error contribution assessed as negligible."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution protocol reviewed by independent analyst; all setup parameters traceable to approved configuration record.",
      "rationale": "Simulation setup protocol exists but independent review was performed by a co-investigator rather than an external reviewer. Traceability to configuration record confirmed. Minor gap in independence criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison of at least two RANS models against PIV data; hemolysis sub-model uncertainty quantified.",
      "rationale": "SST k-omega and realizable k-epsilon compared against PIV velocity fields. SST k-omega selected (lower normalized error). Hemolysis sub-model parametric uncertainty quantified via Monte Carlo but model-form uncertainty remains partially uncharacterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs characterized with documented uncertainty distributions; sensitivity analysis identifies dominant inputs.",
      "rationale": "Blood viscosity, density, and hemolysis model exponents characterized with PDFs from literature meta-analysis. One-at-a-time and Sobol sensitivity analysis performed. Hemolysis exponent identified as dominant input (Sobol index 0.61)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates at each operating point; inter-replicate coefficient of variation below 10%.",
      "rationale": "Four independent replicates performed at each of five operating points using fresh bovine blood from separate donations. CV ranged 4.2–8.7% across all operating points. Sample adequacy confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hematocrit, temperature, and anticoagulant protocol in bench experiments match simulation input assumptions within stated tolerances.",
      "rationale": "Bench tests conducted at 37 ± 0.5°C, hematocrit 33 ± 1%, EDTA anticoagulation per ASTM F1841. CFD inputs set to match nominal values. Equivalency of input parameters confirmed within tolerance."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed for CFD hemolysis prediction under VAD operating conditions (Class III device, MRL 5). Seven factors achieved required levels; six factors showed minor gaps (discretization GCI 7.3% vs. 5% threshold, output comparison E-metric 1.12, use error independence, model form sub-model uncertainty). Gaps are within acceptable remediation bounds given the Monte Carlo UQ coverage and the conservative hemolysis model selection. The assessment team accepts the model for the intended use of supporting hemolysis predictions in the 510(k) submission with documented limitations.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
