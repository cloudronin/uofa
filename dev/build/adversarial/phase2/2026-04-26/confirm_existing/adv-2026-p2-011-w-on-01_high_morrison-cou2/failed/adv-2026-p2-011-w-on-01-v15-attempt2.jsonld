  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted at Low assurance level consistent with the Minimal profile declaration. Seven of thirteen factors were fully assessed; six factors identified as epistemic gaps at MRL 5 are documented for future resolution. The model is accepted for use in the intended VAD hemolysis screening context as described in the bound requirement (https://uofa.net/synth/req/vad-hemolysis-mrl5-cou2) and claim (https://uofa.net/synth/claim/vad-cfd-hemolysis-absolute-prediction) under the operating envelope of 2000–3500 RPM and 2–6 L/min. Residual gaps in model form, test samples, and equivalency of input parameters are acknowledged and do not preclude Low-assurance acceptance for screening-level regulatory support.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
