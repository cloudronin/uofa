    }
  ],
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented unit tests, regression suite, and version-controlled release history traceable to MRL 5 requirements.",
      "rationale": "ANSYS Fluent 2022R2 has a documented QA framework including regression testing and release notes; however, blood-damage-specific solver extensions lack independent verification records, yielding achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent must confirm correct implementation of governing equations for non-Newtonian viscosity and scalar hemolysis transport.",
      "rationale": "MMS was applied to the Navier-Stokes solver and confirmed second-order spatial accuracy; the power-law hemolysis scalar transport equation was verified via simplified channel-flow benchmarks but not under rotating-frame conditions, limiting achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes; GCI < 5% on hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study performed (6M, 14M, 28M cells); GCI on bulk hemolysis index is 8.3%, exceeding the 5% threshold. Achieved level 3; required level 4 not met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit) must match CFD boundary conditions within stated uncertainty bands.",
      "rationale": "Bench experiments used porcine blood analog at 37 °C; inlet turbulence intensity was not measured and was assumed 5% in CFD. This unquantified discrepancy in inlet conditions reduces achieved level to 2 against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (E_val) computed with experimental uncertainty; systematic bias < 15% across operating envelope.",
      "rationale": "E_val computed at five operating points; mean bias 18.4% on hemolysis index exceeds 15% criterion. Velocity field comparison shows good agreement (E_val < 8%) but hemolysis QoI drives achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (normalized index of hemolysis, NIH; modified index of hemolysis, MIH) must directly correspond to clinical hemolysis risk metrics cited in the device submission.",
      "rationale": "NIH and MIH are the standard FDA-accepted hemolysis metrics for VAD submissions. Both QoIs are directly computed from the CFD scalar transport solution and map one-to-one to bench measurement outputs. Required and achieved levels both 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating range, and fluid properties as the intended VAD COU; any deviations must be bounded by sensitivity analysis.",
      "rationale": "Validation used the FDA generic pump geometry rather than the specific VAD impeller; geometric similarity is high but not identical. Sensitivity analysis on impeller tip clearance was not performed, reducing achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residuals < 1e-5 for all equations; time-step sensitivity study for transient rotor-stator interaction.",
      "rationale": "Steady-state MRF approach used; residuals converged to 1e-4 for continuity (target 1e-5 not achieved). Transient sliding-mesh simulation was not performed to quantify rotor-stator unsteadiness contribution. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with operator checklists; independent re-run by second analyst to confirm reproducibility.",
      "rationale": "Simulation workflow is documented in an internal SOP; however, independent re-run was not performed. Single-analyst execution introduces unquantified operator variability. Achieved level 2 against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for choice of turbulence model and hemolysis damage accumulation model; sensitivity study across at least two turbulence closure candidates.",
      "rationale": "SST k-omega turbulence model selected based on prior literature; no sensitivity study comparing SST to RSM or LES was performed. Giersiepen hemolysis power-law model used without evaluation of Arora or Taskin alternatives. Achieved level 2 against required level 4 represents a significant gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probabilistic characterization of all material and boundary input parameters; Monte Carlo propagation of input uncertainty to output QoI uncertainty.",
      "rationale": "Monte Carlo UQ performed over viscosity, density, and inlet flow rate distributions (1000 samples); however, hemolysis model coefficients (C, alpha, beta in Giersiepen model) were held fixed at literature point estimates rather than treated as uncertain inputs. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point to characterize aleatory variability in hemolysis measurements.",
      "rationale": "Experimental dataset contains only single-replicate measurements at each of the five operating points. Biological variability of porcine blood and pump-to-pump assembly variation are uncharacterized. Factor flagged as not-assessed due to insufficient replicate data; epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental fluid properties (porcine blood analog) and clinical blood properties; equivalency demonstrated via dimensionless parameter matching.",
      "rationale": "Porcine blood analog used in validation has different viscoelastic properties than human blood under VAD shear conditions. No formal dimensionless equivalency analysis (e.g., matching Reynolds and Stokes numbers with corrected viscosity) was performed. Factor flagged as not-assessed; epistemic gap at MRL 5."
    }
  ],
