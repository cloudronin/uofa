      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering >90% of relevant flow regimes; formal release documentation per ISO 9001.",
      "rationale": "OpenFOAM v8 with hemolysis UDF is managed under git version control with a 94-case regression suite. Release notes and QA documentation satisfy MRL-5 software quality requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to Navier-Stokes solver; order-of-accuracy confirmed within 5% of theoretical value.",
      "rationale": "MMS verification confirms second-order spatial accuracy (observed order 1.94 vs. theoretical 2.0) for the incompressible Navier-Stokes solver. Temporal discretization verified separately at first-order for steady-state frozen-rotor approach."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on three systematically refined meshes.",
      "rationale": "Three-mesh GCI study yields GCI_fine = 8.3% for the hemolysis index, exceeding the 5% threshold. Mesh refinement in the impeller-volute interface region is constrained by computational budget. Achieved level 3 rather than required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match CFD boundary conditions within stated uncertainty bands; temperature, hematocrit, and flow rate controlled and documented.",
      "rationale": "NIH round-robin experimental data collected at 37°C, hematocrit 33±1%, flow rate 5.0±0.05 L/min. All boundary conditions replicated in CFD within measurement uncertainty. Test condition equivalency confirmed by independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement (NIA) > 0.90 for hemolysis index; pressure-head comparison within 5% across operating range.",
      "rationale": "Hemolysis index NIA = 0.83, below the 0.90 threshold. Pressure-head prediction within 3.2%. The hemolysis constitutive model (power-law Giersiepen-Wurzinger) introduces systematic underprediction at high-shear zones. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (normalized index of hemolysis, scalar shear stress distribution, residence time) directly map to clinical risk endpoints specified in the device submission requirement.",
      "rationale": "Three QoIs — normalized index of hemolysis (NIH), area-weighted scalar shear stress, and red-blood-cell residence time — are directly traceable to the clinical hemolysis risk endpoint in the bound requirement document. Mapping table reviewed and approved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation hierarchy demonstrates progression from benchmark geometry to device geometry; operating conditions overlap with intended VAD use envelope.",
      "rationale": "Validation hierarchy: (1) Couette flow hemolysis benchmark, (2) FDA nozzle benchmark, (3) FDA generic centrifugal pump at 2.5 L/min, (4) FDA generic centrifugal pump at 5.0 L/min VAD operating point. Full overlap with intended use envelope confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residuals below 1e-6 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "All continuity and momentum residuals converge to 1e-7. Mass imbalance 0.003%. Iterative solver error is negligible relative to discretization error and is not the dominant error source."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition application and post-processing scripts verified against documented procedure.",
      "rationale": "Independent analyst review of boundary condition setup, mesh generation parameters, and hemolysis post-processing scripts completed. Two minor discrepancies identified and corrected prior to final run. Use error risk rated low."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified by sensitivity analysis; alternative model forms evaluated.",
      "rationale": "SST k-omega turbulence model selected based on literature consensus for rotating machinery. Power-law hemolysis model evaluated against Arora and Taskin models; 15% spread in predicted NIH across model forms. Model form uncertainty quantified via Monte Carlo but not fully resolved. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs characterized with uncertainty distributions; Monte Carlo propagation performed with N>=1000 samples.",
      "rationale": "Blood viscosity, density, hemolysis model constants (C, alpha, beta), inlet velocity profile, and rotational speed characterized with literature-derived uncertainty distributions. Monte Carlo propagation with N=2000 samples yields 95% confidence interval on NIH of ±18%. Input uncertainty is the dominant contributor to output uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental dataset includes minimum five independent runs with different blood donors; inter-sample variability characterized.",
      "rationale": "NIH round-robin dataset includes six independent experimental runs across three laboratories with different bovine blood lots. Inter-laboratory coefficient of variation 12%. Sample variability incorporated into validation comparison uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient) match between validation experiment and COU operating conditions within 10%.",
      "rationale": "Validation experiment Reynolds number Re=8,200 vs. COU Re=8,450 (difference 3.0%). Flow coefficient phi=0.062 vs. COU phi=0.064 (difference 3.2%). Rotational speed equivalency confirmed. Input parameter equivalency fully satisfied at MRL-5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under VAD operating conditions is accepted with conditions. Ten of thirteen credibility factors meet or exceed required levels for MRL-5. Three factors (discretization error, output comparison, model form) achieved level 3 against a required level 4; these gaps are accepted because (1) the GCI exceedance is bounded and conservative, (2) the NIA shortfall is within the known epistemic uncertainty of the hemolysis constitutive model, and (3) model form uncertainty is quantified and included in the Monte Carlo output distribution. The combined uncertainty on the NIH prediction is reported as a 95% confidence interval and is fit for the intended regulatory decision support use described in the bound requirement and claim documents. Conditions: discretization error gap to be resolved in next model revision; hemolysis model form sensitivity to be reported explicitly in the regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
