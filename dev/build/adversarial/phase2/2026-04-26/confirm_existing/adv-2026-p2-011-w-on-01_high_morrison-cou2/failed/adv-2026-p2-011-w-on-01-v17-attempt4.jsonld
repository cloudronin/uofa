      "type": "ValidationResult",
      "name": "Hemolysis index validation against FDA benchmark experimental data at VAD operating conditions"
    },
    {
      "id": "https://uofa.net/synth/validation/wall-shear-stress-piv",
      "type": "ValidationResult",
      "name": "Wall shear stress field comparison against PIV measurements in the FDA centrifugal pump geometry"
    }
  ],
