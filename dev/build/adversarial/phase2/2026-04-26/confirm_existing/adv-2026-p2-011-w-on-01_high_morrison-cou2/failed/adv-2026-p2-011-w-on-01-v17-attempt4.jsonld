  "signature": "ed25519:b1d4e7a0c3f6920d5e8b2a5c8f1d4e7a0c3f6920d5e8b2a5c8f1d4e7a0c3f692",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Verified CFD solver with documented test suite, version control, and regression testing covering hemolysis-relevant flow regimes.",
      "rationale": "OpenFOAM v8 with custom hemolysis transport module; unit and integration test suite covers 94% of solver paths; version-controlled under Git with tagged releases. Achieved level meets required level for MRL 5 under Minimal profile."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for both Navier-Stokes and hemolysis scalar transport equations confirm expected convergence rates.",
      "rationale": "Method of manufactured solutions applied to steady and transient laminar channel flow; second-order spatial convergence confirmed for velocity and hemolysis index fields. Temporal convergence verified at second order for BDF2 scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis index QoI on three systematically refined meshes; GCI fine < 5% on all reported quantities.",
      "rationale": "Three-mesh Richardson extrapolation performed on 4.2M, 12.1M, and 34.7M cell meshes. GCI fine = 3.1% for hemolysis index at design point. Mesh topology preserved across refinement levels to isolate discretization error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation to within measurement uncertainty; inlet velocity profiles, fluid temperature, and hematocrit documented.",
      "rationale": "FDA benchmark test conditions reproduced: inlet flow rate 2.5 L/min, rotational speed 3500 RPM, hematocrit 33%, temperature 37°C. Inlet velocity profile imposed from LDV measurements. Deviations from nominal conditions quantified and within ±2% for all parameters."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement and RMSE computed for hemolysis index and pressure rise against experimental data; statistical equivalence test at 95% confidence.",
      "rationale": "Hemolysis index RMSE = 0.018 (normalized), NIA = 0.91 against pooled experimental dataset. Pressure rise prediction within 4.2% of experimental mean across five operating points. Equivalence test passed at 95% CI for primary QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical hemolysis thresholds specified in FDA guidance for VAD pre-market submissions; traceability matrix documented.",
      "rationale": "Hemolysis index and normalized index of hemolysis are the primary QoIs; both map directly to FDA 510(k) hemolysis acceptance criteria. Traceability matrix links each computational QoI to a device performance requirement in the predicate device submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at flow conditions spanning the intended VAD operating envelope; geometric similarity between validation model and device geometry documented.",
      "rationale": "FDA generic pump geometry used as validation surrogate; operating envelope (1500–5000 RPM, 1–8 L/min) fully encompasses VAD clinical operating range. Geometric similarity ratio 1:1. Blood analog fluid properties matched to physiological range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error quantified separately from discretization error; residual norms and machine-epsilon analysis documented.",
      "rationale": "Iterative convergence monitored via residual norms (L2 < 1e-6 for all equations) but formal separation of solver error from discretization error not performed. Round-off error analysis not conducted. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review of setup files; independent re-run by second analyst to confirm reproducibility.",
      "rationale": "Simulation workflow documented in internal technical report but independent re-run by a second analyst not performed. Use error assessment deferred pending analyst availability. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis on constitutive model selection (Newtonian vs. non-Newtonian, turbulence closure) with quantified impact on hemolysis index QoI.",
      "rationale": "Newtonian blood model adopted without formal justification relative to Carreau-Yasuda alternative. SST k-omega turbulence closure selected based on literature precedent but not compared against RSM or LES for this geometry. Model form uncertainty not formally bounded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo uncertainty propagation from input parameter distributions (viscosity, density, power-law hemolysis constants) to QoI uncertainty bands; 95th percentile bounds reported.",
      "rationale": "Monte Carlo analysis initiated with 500 samples across hemolysis model constants (C, alpha, beta) but viscosity and density distributions not included. Convergence of output statistics not verified. Partial analysis insufficient for MRL 5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating condition; inter-laboratory variability assessed across at least two test sites.",
      "rationale": "Experimental data sourced from a single laboratory (FDA CDRH); only two replicates available at the primary operating point. Inter-laboratory comparison not conducted. Sample size insufficient to characterize biological and experimental variability at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between validation experiment input parameters and intended COU device operating parameters; equivalency metric defined and computed.",
      "rationale": "Qualitative mapping between FDA generic pump and target VAD geometry performed but no formal equivalency metric computed. Differences in impeller blade angle (12 degrees) and volute geometry not quantitatively assessed for impact on hemolysis prediction transferability."
    }
  ],
