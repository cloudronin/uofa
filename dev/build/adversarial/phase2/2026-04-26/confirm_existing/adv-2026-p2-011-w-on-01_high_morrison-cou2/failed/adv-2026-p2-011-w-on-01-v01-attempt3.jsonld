  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou2-vad-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "At Low assurance level with Model Risk Level 5, the Minimal-profile credibility assessment finds that seven of thirteen factors met their required gradation levels and six factors were assessed as not-assessed due to identified epistemic gaps. Under the Low assurance level threshold applicable to this VAD submission, the achieved credibility evidence is sufficient. The assessment team accepts the CFD hemolysis model for use in predicting normalized index of hemolysis for the FDA generic centrifugal blood pump under VAD operating conditions as described in the claim and requirement documentation.",
