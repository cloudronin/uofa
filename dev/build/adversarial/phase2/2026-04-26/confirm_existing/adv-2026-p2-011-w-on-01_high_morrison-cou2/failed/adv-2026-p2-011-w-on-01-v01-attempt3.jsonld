  "signature": "ed25519:9b2e4f7a1c3d6e8b0f2a5c7d9e1b4f6a8c0d2e4f7a9b1c3d5e7f0a2b4c6d8e0f2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented unit tests and regression suite covering all relevant flow regimes.",
      "rationale": "OpenFOAM v8 used with full version control, CI regression suite covering rotating machinery cases; all unit tests pass. Required gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to the governing equations with observed order of accuracy within 10% of formal order.",
      "rationale": "MMS applied to incompressible Navier-Stokes and power-law hemolysis transport equation; observed second-order convergence confirmed for all primary variables."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation with GCI < 5% on hemolysis index QoI across at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study performed (4.2 M, 11.7 M, 31.4 M cells); GCI on hemolysis index = 3.8%, within the 5% threshold. Discretization error formally bounded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions reproduced in simulation within stated measurement uncertainty; fluid properties matched to within 2%.",
      "rationale": "FDA benchmark operating conditions (2500 RPM, 6 L/min, 70 mmHg) reproduced; inlet velocity profile from LDV measurements applied directly as boundary condition. Fluid viscosity matched to 1.4% of experimental value."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement > 0.85 and mean absolute percentage error < 15% on hemolysis index across all validation operating points.",
      "rationale": "Across five operating points, mean absolute percentage error on normalized index of hemolysis = 11.2%; normalized index of agreement = 0.89. Both thresholds satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoIs (normalized index of hemolysis, shear stress distribution) are directly traceable to the clinical risk metric specified in the device submission requirements.",
      "rationale": "Normalized index of hemolysis is the primary QoI mandated by FDA guidance for VAD submissions; shear stress distribution is the secondary QoI. Both are directly computed by the model and compared against experimental data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating conditions within 15% of COU operating envelope in flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA benchmark pump geometry is identical to the device geometry. Validation operating points span 1500–3500 RPM and 2–8 L/min, encompassing the VAD COU operating envelope. Relevance gap is minimal."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated with residuals below 1e-6 for all transport equations; mass imbalance < 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-7; global mass imbalance 0.003%. Solver error contribution to hemolysis index uncertainty estimated at < 0.5% via perturbation analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol reviewed by independent analyst; checklist-based quality gate applied before result extraction.",
      "rationale": "Simulation execution protocol documented in lab SOP-CFD-004; independent review completed by senior analyst not involved in setup. No use errors identified during review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis prediction to turbulence model selection quantified; preferred model justified against experimental data.",
      "rationale": "Model form uncertainty associated with turbulence closure (k-omega SST vs. realizable k-epsilon) was identified as an epistemic gap at MRL 5. Comparative turbulence model study was initiated but not completed within the assessment window. Flagged as unresolved gap; does not affect Minimal-profile acceptance at Low assurance level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full characterization of input parameter uncertainty distributions with propagation through model via Monte Carlo (minimum 1000 samples).",
      "rationale": "Monte Carlo UQ was performed for geometric tolerances and fluid viscosity (500 samples); however, uncertainty in the hemolysis power-law exponent was not characterized due to lack of source data. Partial UQ noted as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental dataset includes minimum five independent repeat measurements per operating point to characterize experimental variability.",
      "rationale": "FDA benchmark dataset includes six independent repeat experiments per operating point; coefficient of variation on hemolysis index < 8% across all points. Sample adequacy confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensional analysis confirms geometric and dynamic similarity between validation experiment and COU; key non-dimensional parameters within 5%.",
      "rationale": "Reynolds number, flow coefficient, and head coefficient all within 3% between validation conditions and VAD COU operating point. Equivalency of input parameters confirmed by dimensional analysis."
    }
  ],
