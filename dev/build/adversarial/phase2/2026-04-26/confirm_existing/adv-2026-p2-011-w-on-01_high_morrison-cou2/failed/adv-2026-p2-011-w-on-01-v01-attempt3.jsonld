      "type": "ValidationResult",
      "name": "Hemolysis index benchmark comparison against FDA experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv-01",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements in pump volute"
    }
  ],
