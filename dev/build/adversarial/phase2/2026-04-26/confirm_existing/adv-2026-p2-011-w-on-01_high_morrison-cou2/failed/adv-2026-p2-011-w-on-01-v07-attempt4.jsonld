      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated within 2% of nominal; fluid properties characterised at test temperature; hematocrit controlled to ±1%.",
      "rationale": "FDA benchmark data used; inlet velocity profiles matched within 6%. Hematocrit reported as nominal 40% but uncertainty not bounded. Temperature effects on viscosity not propagated. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel < 10%) for hemolysis index across full operating envelope with uncertainty bands; statistical comparison using validation metric with coverage probability stated.",
      "rationale": "E_rel = 22% for absolute hemolysis index at 3500 RPM reference point; velocity field agreement within 12% mean absolute error. Uncertainty bands computed via Monte Carlo but coverage probability not formally stated. Achieved level 3 against required 5."
