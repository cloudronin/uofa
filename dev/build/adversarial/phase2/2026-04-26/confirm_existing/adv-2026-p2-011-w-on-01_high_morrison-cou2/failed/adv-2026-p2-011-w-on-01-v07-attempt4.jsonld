  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-conditional-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump under VAD operating conditions (Class III device, MRL 5, flow range 3–6 L/min, 2500–5000 RPM) is accepted with conditions. Despite multiple credibility factor gaps — particularly in model form uncertainty, equivalency of input parameters, and relevance of validation activities to the VAD COU — the assessment team determined that the model provides sufficient predictive confidence for the intended regulatory decision support role when supplemented by the documented compensating controls. Monte Carlo UQ bounds the dominant parametric uncertainties. Conditional acceptance is contingent on resolution of the six not-assessed factors prior to final regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
