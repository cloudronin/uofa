      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All input parameters characterised with probability distributions; global sensitivity analysis identifying dominant inputs; input uncertainty propagated to QoI uncertainty.",
      "rationale": "Epistemic gap at MRL 5. Monte Carlo UQ performed on five of eleven input parameters; remaining six treated as deterministic. Global sensitivity indices not computed. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental dataset includes sufficient replicates for statistical characterisation of measurement uncertainty; inter-laboratory reproducibility documented.",
      "rationale": "Epistemic gap at MRL 5. FDA benchmark dataset provides single-laboratory measurements with limited replication. Inter-laboratory reproducibility not established for hemolysis measurements. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
