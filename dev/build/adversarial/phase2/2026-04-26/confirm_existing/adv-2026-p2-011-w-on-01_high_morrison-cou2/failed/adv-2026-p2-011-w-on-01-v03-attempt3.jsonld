  "signature": "ed25519:b7d3e9f1a4c6082b5e8d2f0a3c7b1e4d6f9a2c5e8b1d4f7a0c3e6b9d2f5a8c1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all hemolysis-relevant routines; traceability from requirements to test cases required at MRL 5.",
      "rationale": "ANSYS Fluent 2022 R2 used with internal regression suite. Version control confirmed; however, hemolysis-specific user-defined functions lack independent unit tests. Achieved level 3 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent benchmark demonstrating solver correctness for rotating-frame Navier-Stokes and scalar transport at MRL 5.",
      "rationale": "Taylor-Green vortex and lid-driven cavity benchmarks passed. Rotating-frame scalar transport benchmark not available for the hemolysis damage integral; partial verification only. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) below 5 % for NIH quantity of interest on at least three systematically refined meshes.",
      "rationale": "Three-mesh GCI study performed (coarse 4 M, medium 8 M, fine 16 M cells). GCI for NIH = 8.3 %, exceeding the 5 % threshold. Achieved level 3 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, haematocrit) documented with measurement uncertainty at each validation operating point.",
      "rationale": "FDA benchmark provides nominal flow rates and rotational speeds; inlet velocity profiles and haematocrit uncertainty not fully characterised in published dataset. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., validation metric per ASME V&V 20) computed for NIH with experimental uncertainty bars; systematic bias less than 15 %.",
      "rationale": "Mean NIH bias 18 % across five operating points, marginally exceeding 15 % threshold. Validation metric computed per ASME V&V 20 but confidence intervals overlap at only three of five points. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that NIH predicted by CFD is the same quantity measured clinically and used in the device regulatory submission; mapping from model output to clinical endpoint documented.",
      "rationale": "NIH is the regulatory endpoint per ISO 10993-4 and FDA guidance. Mapping from CFD shear-stress integral to NIH via Giersiepen power-law model documented. Uncertainty in power-law exponents not fully propagated to clinical endpoint. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on geometry, fluid, and operating conditions representative of the intended VAD COU; similarity metrics documented for each relevant parameter.",
      "rationale": "Validation used FDA generic pump geometry, not the actual device geometry. Blood analogue fluid (glycerol-water) used instead of porcine blood. Geometric and fluid similarity documented but quantitative similarity metrics not computed. Achieved level 2 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual norms below 1e-5 for all transport equations; round-off error analysis documented for double-precision arithmetic.",
      "rationale": "Residuals converged to 1e-4 for continuity and momentum; hemolysis scalar transport residual stalled at 5e-4 due to source-term stiffness. Double-precision confirmed. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use-error analysis identifying potential misapplication of the model outside its validated operating envelope; documented safeguards or usage constraints.",
      "rationale": "No formal use-error analysis performed. The model has known sensitivity to rotational speed extrapolation beyond 5000 RPM; no usage constraints or operator guidance documented. Flagged as epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model selection (SST k-omega vs. LES) and hemolysis constitutive model form uncertainty on NIH prediction; sensitivity indices reported.",
      "rationale": "SST k-omega selected without comparative LES study. Giersiepen vs. Taskin hemolysis model comparison not performed. Model form uncertainty not quantified. Flagged as epistemic gap. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters (viscosity, haematocrit, pump speed tolerance); Monte Carlo or equivalent UQ propagation to NIH output with Sobol sensitivity indices.",
      "rationale": "Monte Carlo UQ performed for pump speed and viscosity only (2 of 6 identified uncertain inputs). Haematocrit, surface roughness, and inlet turbulence intensity not included. Sobol indices not computed. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient replicate experimental measurements to characterise inter-sample variability in NIH; minimum n=5 per operating point with statistical summary.",
      "rationale": "FDA benchmark dataset provides single-laboratory measurements with limited replication documentation. Inter-sample variability in blood analogue properties not reported. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstrated equivalency between CFD model input parameters and experimental conditions via dimensionless similarity parameters (Reynolds number, flow coefficient); deviations quantified.",
      "rationale": "Reynolds number matching documented at nominal operating point only. Flow coefficient equivalency not verified across the full operating envelope. Dimensional analysis incomplete. Achieved level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, the overall evidence package for CFD hemolysis prediction of the FDA generic centrifugal blood pump is accepted for the intended VAD regulatory submission support use. Seven of thirteen credibility factors were formally assessed; six factors were flagged as epistemic gaps at MRL 5. The assessment team acknowledges that achieved levels fall below required levels for five assessed factors, but accepts the package on the basis that (a) the NIH bias of 18 % is within the expected uncertainty band for power-law hemolysis models at this fidelity level, (b) Monte Carlo UQ bounds are available for the two dominant uncertain inputs, and (c) the validation geometry (FDA generic pump) is the closest publicly available surrogate for the actual device. Residual gaps in model form uncertainty, use-error analysis, and test-sample replication are acknowledged as limitations to be addressed in a subsequent MRL 5 full-profile assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
