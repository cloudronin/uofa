    "https://uofa.net/synth/data/fda-generic-pump-piv-measurements",
    "https://uofa.net/synth/data/morrison-hemolysis-in-vitro-baseline"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-vr-01",
      "type": "ValidationResult",
      "name": "CFD vs. in-vitro hemolysis index comparison at 5000 RPM, 5 L/min",
      "description": "Predicted normalised index of haemolysis (NIH) compared against in-vitro measurements from the FDA benchmark dataset. Mean absolute error 18 % across operating envelope; within accepted tolerance for MRL 5 low-fidelity hemolysis models."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-vr-02",
      "type": "ValidationResult",
      "name": "Velocity field PIV comparison — FDA centrifugal pump impeller plane",
      "description": "Simulated velocity magnitude compared against particle image velocimetry data at mid-plane. RMS deviation 12 % of mean inlet velocity; adequate for hemolysis-relevant shear-stress extraction."
    }
  ],
