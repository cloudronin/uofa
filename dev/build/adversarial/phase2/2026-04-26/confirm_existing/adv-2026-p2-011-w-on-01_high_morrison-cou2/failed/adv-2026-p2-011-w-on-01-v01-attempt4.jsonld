  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team determined that, for the intended submission scope — CFD-assisted design screening of the FDA generic centrifugal pump under VAD operating conditions — the achieved credibility factors are sufficient for a low-risk design-iteration decision. Seven factors were formally assessed; six epistemic gaps were identified and accepted as residual uncertainty consistent with the Low assurance level declared. The decision is conditional on restricting use to comparative (not absolute) hemolysis ranking. The structured Context of Use node was not linked in this package; use-scope information is captured in the Requirement and Claim prose bindings.",
