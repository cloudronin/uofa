  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering >90% of relevant flow regimes; documented release notes.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and regression-tested, but test coverage of high-shear hemolytic regimes reaches only 71%; required level 4 is not met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equation terms with observed order of accuracy within 10% of theoretical.",
      "rationale": "MMS was applied to continuity and momentum; the power-law hemolysis transport equation was not included in MMS verification, leaving a gap at required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI < 5% on the quantity of interest.",
      "rationale": "Three meshes (4M, 12M, 36M cells) were used; GCI on NIH is 8.3%, exceeding the 5% threshold. Achieved level 3 only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) match simulation inputs within stated measurement uncertainty.",
      "rationale": "Flow rate and speed are matched; blood analogue viscosity was measured at 25°C whereas simulations used 37°C values, introducing a systematic mismatch not fully quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., validation uncertainty U_val) computed and compared against decision threshold with statistical confidence interval reported.",
      "rationale": "U_val was computed via ASME V&V 20 procedure; the 95% confidence interval on NIH prediction error is ±42%, exceeding the ±20% decision threshold for level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation (NIH) is directly traceable to the clinical endpoint (hemolysis risk) with documented sensitivity analysis.",
      "rationale": "NIH is the regulatory QoI; a one-way sensitivity analysis was performed but global sensitivity (Sobol indices) required at level 4 was not completed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed at operating conditions spanning the full COU envelope (flow rates 3–8 L/min, speeds 2000–3500 rpm).",
      "rationale": "Experiments cover 2500 rpm and 6 L/min only; the broader VAD operating envelope is not covered, limiting relevance to a single operating point."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Round-off and iterative convergence errors quantified and shown negligible relative to discretization error.",
      "rationale": "Flagged as epistemic gap at MRL 5. Solver residuals were monitored but formal iterative error quantification per ASME V&V 20 was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and independent simulation reproducibility check by a second analyst.",
      "rationale": "Flagged as epistemic gap at MRL 5. No independent reproduction by a second analyst was conducted; user qualification records are incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Competing turbulence and hemolysis constitutive model forms evaluated; model-form uncertainty quantified via Bayesian model averaging or equivalent.",
      "rationale": "Flagged as epistemic gap at MRL 5. Only the Giersiepen power-law hemolysis model was used; no competing model-form analysis was performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full Monte Carlo UQ on all uncertain boundary conditions and material properties with convergence demonstrated at N≥10000 samples.",
      "rationale": "Flagged as epistemic gap at MRL 5. Monte Carlo was initiated (N=500) but convergence of NIH variance was not demonstrated; full UQ remains incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterisation of biological variability across multiple blood donors; minimum n=10 independent hemolysis measurements.",
      "rationale": "Flagged as epistemic gap at MRL 5. Hemolysis bench data derive from a single bovine blood batch; inter-donor variability is uncharacterised."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation test article geometry and the intended device geometry, with documented dimensional tolerances.",
      "rationale": "Flagged as epistemic gap at MRL 5. The FDA generic pump geometry used in validation differs from the intended commercial VAD impeller; no equivalency mapping exists."
    }
  ],
