  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented build and test suite; all regression tests pass.",
      "rationale": "OpenFOAM v8 used under institutional version control. Automated regression suite executed; all 142 test cases pass. Software quality documentation meets MRL 5 threshold at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent formal order-of-accuracy verification for governing equations.",
      "rationale": "MMS verification confirms second-order spatial accuracy for the incompressible Navier-Stokes solver. Observed order of accuracy 1.97 across three systematically refined grids. Code verification requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for primary QoI with GCI < 5% on fine grid.",
      "rationale": "Grid convergence index computed per Celik et al. (2008). Fine-grid GCI for hemolysis index: 3.2%. Discretization error quantified and within acceptance threshold for MRL 5 at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; operating point matches VAD design envelope.",
      "rationale": "FDA pump bench tests conducted at 3500 RPM, 5 L/min, 37 °C phosphate-buffered saline with bovine blood. Operating conditions documented with ±2% flow rate uncertainty. Conditions fall within the VAD operating envelope described in the bound Requirement node."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel) computed between model output and experimental measurement; metric within predefined tolerance.",
      "rationale": "Relative error on normalised index of hemolysis: 8.4% against experimental mean. Validation metric within the 10% tolerance specified in the bound Claim. Output comparison criterion satisfied at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to the clinical decision metric (absolute hemolysis index) specified in the device submission requirement.",
      "rationale": "Primary QoI is the normalised index of hemolysis (NIH), which is the regulatory metric for VAD haemocompatibility per ISO 10993-4. Direct correspondence between simulation output and clinical decision metric confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry and flow conditions representative of the intended VAD operating envelope.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry under flow conditions (2–8 L/min, 2500–5000 RPM) that bracket the intended VAD operating envelope. Representativeness judged adequate for Gradation 2 at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error characterised; solver residuals below 1e-6 for all transport equations.",
      "rationale": "Iterative residuals monitored but formal round-off error analysis not completed. Solver error contribution to total numerical uncertainty not separated from discretization error. Flagged as epistemic gap at MRL 5; required Gradation 3 not achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User influence on simulation outcomes characterised through analyst-to-analyst or lab-to-lab reproducibility study.",
      "rationale": "No inter-analyst reproducibility study conducted. Use error contribution to hemolysis prediction variability not quantified. Epistemic gap identified; Gradation 3 requirement not met under MRL 5 scrutiny."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis prediction to turbulence model and power-law damage model constants quantified; alternative model forms evaluated.",
      "rationale": "Single turbulence model (SST k-ω) and single power-law hemolysis model (Giersiepen et al.) used without comparison to alternative forms. Model form uncertainty not bounded. Critical epistemic gap at MRL 5; required Gradation 4 not achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions assigned to uncertain input parameters; Monte Carlo propagation performed with convergence confirmed.",
      "rationale": "Monte Carlo UQ performed for inlet flow rate, fluid viscosity, and power-law exponent (1000 samples). Input distributions assigned based on literature. Convergence confirmed via bootstrapping. Achieved Gradation 2; full sensitivity decomposition (Gradation 3) not completed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification provided; biological variability in blood rheology characterised across donor population.",
      "rationale": "Experimental data from single bovine blood pool; donor-to-donor biological variability not characterised. Sample size for hemolysis assay not formally justified. Epistemic gap; Gradation 2 not achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between simulation input parameters and experimental conditions formally documented with quantified differences.",
      "rationale": "Bovine blood rheology used in experiments; human blood properties assumed in simulation without formal equivalency mapping. Viscosity and yield stress differences not propagated to output uncertainty. Epistemic gap at MRL 5."
    }
  ],
