      "name": "Hemolysis index prediction vs. experimental bench data — FDA pump 3500 RPM"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison-r2",
      "type": "ValidationResult",
      "name": "Velocity field comparison against PIV measurements at design operating point"
    }
  ],
