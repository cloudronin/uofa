  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Verified software version control, regression testing suite, and documented QA procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (OpenFOAM v9) is under formal version control with a documented regression test suite covering 47 benchmark cases. QA procedures are compliant with FDA guidance on software validation for medical device simulations. Achieved gradation matches required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution tests and order-of-accuracy analysis demonstrating second-order convergence for the governing equations.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver confirms second-order spatial accuracy. Temporal convergence verified for unsteady impeller rotation cases. Code verification is complete and meets required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index below 5% for hemolysis index QoI across three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study (2.1M, 6.8M, 18.4M cells) yields GCI of 3.2% for the normalized hemolysis index, satisfying the acceptance threshold. Discretization error is bounded and documented per ASME V&V 20."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) replicated within stated tolerances in simulation boundary conditions.",
      "rationale": "FDA pump bench experiments conducted at 2500 RPM, 5 L/min, using bovine blood at 37°C. Simulation boundary conditions match within 1.5% for flow rate and 0.8% for rotational speed. Fluid viscosity uncertainty propagated via Monte Carlo sampling."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis within 20% of experimental mean across all operating points, with uncertainty intervals overlapping experimental uncertainty bands.",
      "rationale": "Predicted NIH of 0.0034 g/100 L compared to experimental mean of 0.0031 g/100 L (9.7% relative error). Monte Carlo 95% confidence interval [0.0028, 0.0041] encompasses experimental uncertainty band. Quantitative output comparison satisfies required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that normalized index of hemolysis directly maps to the clinical decision quantity (absolute hemolysis level) required for Class III device submission.",
      "rationale": "The NIH quantity of interest is the FDA-accepted metric for hemolysis in blood-contacting devices and directly supports the regulatory submission decision for the VAD under Class III classification. Relevance is fully established through documented traceability to device risk assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the identical FDA generic pump geometry under VAD-representative operating conditions, with blood analog properties within specified physiological range.",
      "rationale": "Validation dataset uses the FDA generic centrifugal pump geometry — the same geometry as the COU device surrogate — operated across the full VAD duty cycle envelope (2000–3500 RPM, 3–8 L/min). Validation activities are directly relevant to the intended clinical use scope as described in the claim and requirement documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all transported quantities; mass imbalance below 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6 for velocity, pressure, and scalar transport equations. Global mass imbalance is 0.003%. Solver error contribution is negligible relative to discretization and model form uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review of setup parameters, boundary condition assignments, and post-processing scripts.",
      "rationale": "Simulation setup reviewed by two independent analysts. Boundary condition assignment, turbulence model selection, and hemolysis power-law model parameterization are documented in the simulation plan. Post-processing scripts version-controlled and independently verified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis comparing at least two hemolysis constitutive model forms (e.g., Giersiepen-Wurzinger vs. modified power-law) with experimental discrimination.",
      "rationale": "Model form uncertainty for the hemolysis constitutive relationship is identified as an epistemic gap at MRL 5. Only the Giersiepen-Wurzinger power-law model was evaluated; comparative assessment against alternative model forms was not completed within the current assessment scope. Flagged for future work."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters (viscosity, density, pump geometry tolerances) with Monte Carlo propagation demonstrating output sensitivity.",
      "rationale": "Monte Carlo uncertainty quantification was initiated but full probability distribution characterization for geometric manufacturing tolerances of the pump impeller was not completed. Input uncertainty for blood viscosity and density is propagated; geometric uncertainty remains an open epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates per operating point to characterize inter-sample variability in hemolysis measurements.",
      "rationale": "Available FDA pump experimental dataset provides three replicates per operating point. Statistical characterization of inter-sample hemolysis variability is insufficient to meet required gradation at MRL 5. Additional experimental replicates are needed to fully assess this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative mapping demonstrating that validation experiment input parameters are equivalent to or conservative relative to the intended VAD clinical operating envelope.",
      "rationale": "The validation experiment operating envelope partially overlaps the clinical VAD duty cycle but equivalency has not been formally quantified. Operation at extreme low-flow conditions (below 3 L/min) relevant to VAD weaning scenarios is not covered by the validation dataset. Equivalency assessment is an open epistemic gap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, the seven assessed credibility factors all achieve their required gradation levels, and the six not-assessed factors are formally documented as epistemic gaps consistent with MRL 5 practice. The CFD model demonstrates sufficient credibility for the intended use as a Class III VAD hemolysis prediction tool under the operating conditions described in the claim and requirement documentation. The assessment team accepts this package subject to documented gap closure commitments for model form, model inputs, test samples, and equivalency factors in the next assessment cycle.",
