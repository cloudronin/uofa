      "type": "ValidationResult",
      "name": "Absolute hemolysis index comparison against FDA pump bench data"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-01",
      "type": "ValidationResult",
      "name": "Mesh convergence study for centrifugal pump impeller region"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037090",
