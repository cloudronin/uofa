      "id": "https://uofa.net/synth/validation/vr-hemolysis-mrl5-001",
      "type": "ValidationResult",
      "name": "CFD hemolysis absolute-level validation against FDA pump PIV and in-vitro data at VAD operating conditions"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-uncertainty-montecarlo-001",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification sweep across inlet flow rate and rotational speed design space for VAD operating envelope"
    }
  ],
