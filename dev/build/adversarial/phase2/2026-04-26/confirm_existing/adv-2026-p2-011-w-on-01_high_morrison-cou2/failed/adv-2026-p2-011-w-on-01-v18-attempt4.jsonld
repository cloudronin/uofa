  "hash": "sha256:a3f7c2e1b509d64e8f2a1c7b3d0e5f9a2b4c6d8e0f1a3b5c7d9e1f3a5b7c9d2",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold ISO 9001 certification and a documented software quality plan covering version control, regression testing, and release validation.",
      "rationale": "The solver (ANSYS Fluent 2023 R1) carries ISO 9001:2015 certification. A project-specific SQA plan documents version pinning at 23.1.0, automated regression suite of 412 cases, and sign-off by a designated SQA engineer. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) must demonstrate second-order spatial convergence for the momentum and scalar transport equations governing hemolysis.",
      "rationale": "MMS applied to the power-law hemolysis scalar transport equation on three systematically refined meshes. Observed order of accuracy is 1.97 ± 0.04, consistent with second-order FVM discretization. Code verification is complete and meets the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the hemolysis index QoI must be less than 5% on the production mesh, computed from a three-mesh Richardson extrapolation study.",
      "rationale": "Three-mesh GCI study (coarse 4.2 M, medium 12.6 M, fine 37.8 M cells) yields GCI_fine = 3.1% for the volume-averaged hemolysis index at the design operating point. The production mesh is the fine mesh. Criterion satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at VAD-representative flow rates (4–6 L/min) and rotational speeds (6000–9000 RPM) using bovine blood with hematocrit 35 ± 2%.",
      "rationale": "In-vitro experiments performed at 4, 5, and 6 L/min and 6000, 7500, 9000 RPM using fresh bovine blood (hematocrit 35.4 ± 1.8%). Temperature maintained at 37 °C. Test conditions match the VAD operating envelope specified in the intended-use narrative embedded in the Claim node."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of model accuracy (NIMA) for hemolysis index predictions must be within ±15% across all nine validation operating points.",
      "rationale": "NIMA computed for all nine flow-rate/speed combinations. Maximum deviation is 11.3% at 9000 RPM / 4 L/min. Mean absolute error is 6.8%. All points fall within the ±15% acceptance band. Output comparison criterion met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must be directly linked to the clinical risk metric specified in the FDA guidance for blood-contacting devices.",
      "rationale": "NIH is the FDA-recommended metric per the 2017 FDA Guidance on Computational Fluid Dynamics for Blood Pumps. The model outputs NIH directly. The Claim node explicitly references the FDA guidance and maps NIH to patient safety risk. QoI relevance is fully established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the FDA generic centrifugal pump geometry or a geometry with documented geometric similarity index ≥ 0.90 relative to the clinical device.",
      "rationale": "Validation performed on the FDA generic centrifugal pump benchmark geometry (Hariharan et al. 2011). The clinical device geometric similarity index relative to the benchmark is 0.93 per independent CAD comparison. Validation activities are directly relevant to the intended use scope described in the Requirement node."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated by residual reduction of at least four orders of magnitude and stabilization of the hemolysis QoI to within 0.1% over the final 500 iterations.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum. Hemolysis QoI variation over the final 500 iterations is less than 0.05% in all nine operating-point cases. Solver error criterion satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation execution checklist and independent peer review of all boundary condition inputs must be on file for each operating-point simulation.",
      "rationale": "A 47-item simulation execution checklist was completed for each of the nine operating-point cases. An independent CFD engineer reviewed all boundary condition assignments and turbulence model settings. No use errors were identified. Criterion met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis model form (power-law Giersiepen–Wurzinger or equivalent) must be justified by literature evidence and sensitivity analysis demonstrating that model-form uncertainty contributes less than 20% of total prediction uncertainty.",
      "rationale": "The Giersiepen–Wurzinger power-law model is selected based on a structured literature review of 14 hemolysis model forms. Model-form sensitivity analysis via model-averaging across three candidate formulations shows model-form contribution is 14% of total uncertainty budget. Criterion satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions must be assigned to all uncertain input parameters (viscosity, density, power-law coefficients) and propagated via Monte Carlo with at least 1000 samples.",
      "rationale": "Monte Carlo UQ performed with 2500 Latin hypercube samples across seven uncertain inputs including blood viscosity, density, and the three Giersiepen–Wurzinger coefficients. 95th-percentile prediction interval for NIH is reported. Input uncertainty criterion met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least three independent blood sample lots must be used across the validation experiments to capture inter-donor variability.",
      "rationale": "Four independent bovine blood lots from different donors were used across the nine validation experiments. Inter-lot variability in baseline hemolysis was characterized and incorporated into the experimental uncertainty bounds. Test sample criterion satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (fluid properties, rotational speed, flow rate) must be matched to measured experimental values within ±2% for each validation case.",
      "rationale": "Simulation boundary conditions were set to experimentally measured values for each of the nine cases. Maximum deviation between specified and measured flow rate is 1.4%; for rotational speed, 0.8%. All deviations are within the ±2% equivalency criterion."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed under ASME V&V 40-2018 have achieved levels meeting or exceeding required levels for Model Risk Level 5. Monte Carlo UQ confirms prediction intervals are within regulatory acceptance thresholds for NIH. The composite credibility evidence supports the claim that the CFD model is fit for regulatory submission in support of the Class III VAD device. The assessment team accepts this Unit of Assurance. Note: the structured Context of Use object is not linked in this Minimal-profile package; the intended-use scope is described in the Claim and Requirement prose nodes referenced by bindsClaim and bindsRequirement.",
