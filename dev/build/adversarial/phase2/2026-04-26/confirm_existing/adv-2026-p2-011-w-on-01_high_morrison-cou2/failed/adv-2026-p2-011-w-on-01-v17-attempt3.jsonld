  "signature": "ed25519:b4e7f1a2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9fa",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification with documented V&V test suite covering hemolysis-relevant flow regimes; all regression tests passing.",
      "rationale": "ANSYS Fluent 2023R1 holds ISO 9001 certification. Internal benchmark suite of 47 hemolysis-relevant test cases executed; all pass within specified tolerances. Version-controlled simulation scripts stored in institutional GitLab repository with full audit trail. Achieved level equals required level of 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations with demonstrated second-order spatial convergence for velocity and pressure fields.",
      "rationale": "MMS applied to incompressible Navier-Stokes solver; observed convergence order of 1.97 for L2 velocity error and 1.94 for pressure error on three systematically refined grids. Temporal discretization verified separately with analytical unsteady Couette flow solution. Achieved level of 3 meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) on NIH quantity of interest must be below 3% using Richardson extrapolation on three grids with refinement ratio ≥ 1.3.",
      "rationale": "Three grids (4.2M, 12.6M, 37.8M cells) with refinement ratio 1.44 applied. GCI on NIH = 2.1%, satisfying the <3% criterion. Apparent order of convergence p = 1.89, consistent with second-order scheme. Time-step independence confirmed: NIH change <0.4% halving time step from 1e-4 to 5e-5 s. Achieved level 4 equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within ±5% for flow rate and rotational speed; fluid temperature and viscosity documented.",
      "rationale": "FDA benchmark experimental conditions replicated: flow rate 5.0 L/min (±2.1%), rotational speed 3500 RPM (±0.8%), fluid temperature 37°C, dynamic viscosity 0.0035 Pa·s. Inlet velocity profile prescribed from PIV measurements. Achieved level 3 equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rms) computed for primary QoI (NIH) and secondary QoI (velocity field) with statistical uncertainty bounds reported.",
      "rationale": "NIH prediction error: 11.3% relative to experimental mean across 5 operating conditions; within ±15% acceptance band. Velocity field RMS error 8.2% of peak velocity against PIV data. Experimental uncertainty (±6.8% for NIH) propagated into comparison. Validation uncertainty U_val = 13.1%, confirming model is within validation domain. Achieved level 3 equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH) directly maps to the regulatory submission metric for blood trauma assessment in Class III VAD devices per FDA guidance.",
      "rationale": "NIH is the primary FDA-accepted metric for hemolysis assessment in VAD pre-market submissions (FDA guidance document 2010). The simulation QoI is computed using the same power-law damage accumulation model (Giersiepen et al.) as required by the submission framework. Direct traceability from simulation output to regulatory decision metric established. Achieved level 4 equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic centrifugal pump geometry under overlapping operating conditions (flow rate, RPM, fluid properties) with hemolysis as the measured output.",
      "rationale": "Validation dataset uses the identical FDA generic centrifugal pump geometry. Operating conditions span 2.5–7.0 L/min and 2500–5000 RPM, encompassing the VAD clinical operating envelope. Blood analog fluid (40% glycerol-water, viscosity-matched) used in experiments. Hemolysis directly measured via plasma-free hemoglobin assay. High geometric and condition relevance to intended COU. Achieved level 4 equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated with residuals below 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "Residuals converged to 1e-4 for momentum equations and 1e-5 for continuity. Mass imbalance 0.03%, marginally exceeding the 0.01% criterion. Iterative convergence monitoring over last 200 iterations confirms stable solution. Achieved level 2 falls below required level 3; flagged as gap but not disqualifying under Minimal profile assessment framework given low sensitivity of NIH to residual level in this regime.",
      "flaggedGap": true
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution checklist with independent review of boundary condition setup, turbulence model selection, and post-processing scripts by a qualified second analyst.",
      "rationale": "Simulation setup checklist completed by primary analyst. Independent review of boundary conditions performed but turbulence model selection (SST k-ω) was not independently verified against alternative model sensitivity study. Post-processing scripts for NIH calculation reviewed. Achieved level 2 is below required level 3; partial mitigation via documented checklist. Gap acknowledged.",
      "flaggedGap": true
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model form uncertainty and hemolysis constitutive model alternatives with sensitivity quantified against NIH QoI.",
      "rationale": "Model form uncertainty for both turbulence closure (SST k-ω vs. RSM vs. LES) and hemolysis power-law exponents not systematically evaluated. Epistemic gap at MRL 5 due to absence of model form sensitivity study. Required level 4 not achievable with current dataset. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo or polynomial chaos UQ propagating input parameter distributions (viscosity, inlet velocity profile, rotational speed uncertainty) through model to NIH output distribution.",
      "rationale": "Monte Carlo UQ initiated (N=5000 samples) but convergence of NIH output distribution not confirmed; coefficient of variation of sample mean still decreasing at N=5000. Full input uncertainty characterization for blood rheology parameters (yield stress, shear-thinning exponent) not completed. Epistemic gap flagged at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating condition with inter-laboratory reproducibility demonstrated across at least two test facilities.",
      "rationale": "FDA benchmark dataset provides single-laboratory measurements. Inter-laboratory reproducibility study not available for hemolysis outputs. Experimental sample size insufficient to characterize batch-to-batch variability in blood analog preparation. Required level 3 not achievable with existing public dataset. Epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment fluid (glycerol-water analog) and clinical blood rheology, including non-Newtonian effects, documented with quantitative similarity metrics.",
      "rationale": "Glycerol-water analog fluid used in validation experiments does not replicate non-Newtonian shear-thinning behavior of blood at low shear rates (<50 s⁻¹). Formal equivalency mapping between analog and clinical blood not performed. Viscosity matched only at 37°C and 300 s⁻¹ reference shear rate. This constitutes a significant epistemic gap for MRL 5 assessment. Not assessed."
    }
