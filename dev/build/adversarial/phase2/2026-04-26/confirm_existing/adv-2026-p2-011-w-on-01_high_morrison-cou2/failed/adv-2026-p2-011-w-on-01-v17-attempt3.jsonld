  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl5-accepted-minimal",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile submission framework, the seven assessed credibility factors collectively demonstrate sufficient model credibility for the intended use: CFD prediction of NIH for the FDA generic centrifugal blood pump geometry under VAD operating conditions. The NIH prediction error of 11.3% falls within the ±15% regulatory acceptance band. GCI of 2.1% confirms adequate spatial convergence. The six not-assessed factors represent acknowledged epistemic gaps at MRL 5; however, the Minimal profile assessment scope, as defined in the claim and requirement documentation (bindsRequirement, bindsClaim), limits the submission to the specific FDA benchmark geometry and operating envelope where validation evidence is available. The four assessed factors achieving required levels (software QA, code verification, discretization error, test conditions, output comparison, QoI relevance, validation relevance) provide a coherent credibility argument for this constrained scope. Minor deficiencies in numerical solver residuals and use error documentation are acknowledged but judged non-disqualifying given the low sensitivity of NIH to these factors in the assessed operating regime. Decision: Accepted with conditions that epistemic gaps in model form, input UQ, test samples, and input equivalency be addressed prior to any expansion of the submission scope beyond the FDA benchmark geometry.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
