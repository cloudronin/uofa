  "signature": "ed25519:b7e3a1f2c8d405b6e9a2c3d7f0b1e4a8c5d2f6b3e7a0c4d1f8b5e2a9c6d3f0b4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal configuration management, regression test suite covering >90% of solver code paths, and documented release procedures required at MRL 5.",
      "rationale": "The CFD solver has version control and a partial regression suite but lacks formal configuration management documentation and full release procedures. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including turbulence closure; order-of-accuracy confirmation required.",
      "rationale": "MMS was applied to laminar Navier-Stokes only. Turbulence model terms and the hemolysis transport equation were not verified via MMS. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI < 2% on hemolysis index QoI; temporal refinement study required for transient rotor-stator interaction.",
      "rationale": "Three-mesh Richardson extrapolation performed; GCI on hemolysis index is 4.7%, exceeding the 2% threshold. Temporal refinement was not completed. Achieved gradation 3 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match VAD operating envelope (2000–3500 RPM, 3–6 L/min); fluid temperature, hematocrit, and inlet turbulence intensity must be documented and controlled.",
      "rationale": "Experimental data used standard saline surrogate rather than porcine blood at physiological hematocrit. Inlet turbulence intensity was not reported. Significant mismatch with VAD operating fluid conditions. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) applied to hemolysis index with uncertainty bounds on both simulation and experiment; systematic bias characterised.",
      "rationale": "Only qualitative contour comparisons and a single-point percent-error metric were reported. Experimental uncertainty was not propagated. No formal validation metric computed. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (normalised index of hemolysis, NIH) must be directly computed and compared; secondary QoIs (shear stress exposure time, platelet activation) must also be assessed for Class III device.",
      "rationale": "NIH was computed but secondary QoIs (platelet activation potential, shear exposure time distribution) were not evaluated. For a Class III VAD the full QoI set is required. Achieved gradation 3 against required gradation 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the target device geometry at target operating conditions; animal or clinical data required to close the gap from bench to in-vivo for Class III.",
      "rationale": "Validation was conducted on the FDA generic pump benchmark, not the specific VAD geometry under regulatory review. No animal or clinical hemolysis data were incorporated. Achieved gradation 2 against required gradation 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to machine-precision residuals or demonstrated residual insensitivity; floating-point round-off analysis required for hemolysis accumulation integral.",
      "rationale": "Iterative residual convergence criteria were not documented. Floating-point accumulation error in the hemolysis integral was not analysed. Flagged as epistemic gap at MRL 5. Achieved gradation 1 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification programme, blind re-analysis by independent analyst, and sensitivity study on user-controlled parameters (mesh topology, turbulence model constants).",
      "rationale": "No independent blind re-analysis performed. User-controlled parameter sensitivity was not systematically explored. Epistemic gap flagged. Achieved gradation 1 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of hemolysis constitutive model selection (power-law vs mechanistic); sensitivity to turbulence model choice (SST k-omega vs RSM) must be quantified at MRL 5.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was used without comparison to alternative mechanistic models. Turbulence model sensitivity was not assessed. Critical epistemic gap at MRL 5. Achieved gradation 1 against required gradation 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (blood viscosity parameters, hemolysis model constants C and alpha) characterised with probability distributions; Monte Carlo propagation with >1000 samples required.",
      "rationale": "Monte Carlo UQ was performed with 500 samples on two of five uncertain parameters. Hemolysis model constants were treated as fixed. Achieved gradation 2 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterisation of experimental sample variability (n ≥ 10 independent runs); donor variability in blood rheology must be quantified for biological fluid.",
      "rationale": "Experimental dataset comprised three repeat runs from a single donor pool. Statistical characterisation of inter-sample variability was not performed. Epistemic gap flagged. Achieved gradation 1 against required gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental boundary conditions and simulation inputs; dimensional analysis confirming dynamic similarity; documented treatment of any surrogate fluid corrections.",
      "rationale": "No formal equivalency analysis between saline-surrogate experimental conditions and blood-filled VAD simulation inputs was documented. Surrogate fluid correction factors were not applied. Epistemic gap flagged. Achieved gradation 1 against required gradation 4."
    }
  ],
