  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The UoA is accepted under the Minimal profile with conditions. Seven of thirteen credibility factors were assessed; four achieved their required levels and three fell one gradation below required. Six factors remain not-assessed and constitute documented epistemic gaps. The assessment team determined that the achieved credibility is sufficient for the intended regulatory submission scope—pre-market notification for a Class III left-VAD at the specified operating point—given that the hemolysis index prediction error of 15.5% is within the clinical safety margin established by the sponsor's risk analysis. Conditions: (1) model form comparison study to be completed before pivotal submission; (2) GCI to be reduced below 5% in next simulation revision; (3) independent replication to be performed within 90 days.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
