      "rationale": "OpenFOAM v9 used with institutional version control. Regression suite executed; 94% path coverage confirmed. Release notes archived in project repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical Couette and pipe-flow cases demonstrates observed order within 10% of theoretical order.",
      "rationale": "Richardson extrapolation applied to Couette flow benchmark; observed order 1.93 versus theoretical 2.0, within acceptance band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% on hemolysis index QoI using at least three systematically refined meshes.",
      "rationale": "Three-mesh GCI study performed; GCI on hemolysis index is 7.2%, exceeding the 5% threshold. Achieved level 3 rather than required level 4; gap documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature) match CFD inputs within stated uncertainty bands.",
      "rationale": "PIV experiments conducted at 5 L/min ± 0.05 L/min, 3500 RPM ± 10 RPM, 37 °C ± 0.5 °C; CFD boundary conditions set to nominal values within stated bands."
    },
