      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized model error on hemolysis index below 15% relative to experimental mean; systematic bias quantified.",
      "rationale": "Predicted hemolysis index 0.0082 versus measured 0.0071; normalized error 15.5%, marginally outside criterion. Bias attributed to stress-based hemolysis model constants calibrated on different pump geometry."
    },
    {
      "type": "CredibilityFactor",
