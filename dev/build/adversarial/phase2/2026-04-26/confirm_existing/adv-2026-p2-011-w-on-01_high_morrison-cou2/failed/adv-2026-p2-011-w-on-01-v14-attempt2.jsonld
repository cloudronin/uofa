      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite and release notes must be demonstrated.",
      "rationale": "OpenFOAM v8 used with full version control; automated regression test suite covers 94% of relevant solver modules. Release notes and change logs archived in institutional repository."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent benchmark must confirm correct order-of-accuracy implementation.",
      "rationale": "MMS verification confirms second-order spatial accuracy for velocity and pressure fields. Taylor-Green vortex benchmark reproduces analytic solution within 0.3% at equivalent mesh resolution."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for primary QoI (hemolysis index) on the fine grid.",
      "rationale": "Three-level GCI study performed on coarse (2.1M), medium (5.8M), and fine (14.3M) cell meshes. GCI on fine grid is 3.2% for hemolysis index, satisfying the 5% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be replicated within documented tolerance bands in the simulation setup.",
      "rationale": "Inlet flow rate (6 L/min) and pressure head (70 mmHg) match FDA benchmark protocol within 1.5%. Blood analog fluid properties (glycerol-water) reproduced within 2% of target viscosity."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must fall within two standard deviations of experimental mean across available benchmark datasets.",
      "rationale": "Predicted normalized index of hemolysis (NIH) of 0.0041 g/100L falls within 1.4 standard deviations of the FDA benchmark experimental mean (0.0038 ± 0.0006 g/100L)."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly traceable to the device performance metrics cited in the bound Requirement.",
      "rationale": "NIH and shear stress exposure time (SSET) are the primary QoIs; both are explicitly listed in the bound Requirement node as the decision-relevant metrics for VAD biocompatibility evaluation."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must operate within the same rotational speed and flow regime as the intended VAD operating envelope.",
      "rationale": "Validation experiments conducted at 2500 RPM and 6 L/min, matching the nominal VAD operating point. Reynolds number similarity confirmed; no extrapolation beyond validated regime required for the bound Claim."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Round-off and iterative convergence errors must be bounded and shown negligible relative to discretization error.",
      "rationale": "Iterative convergence to residual 1e-6 achieved, but formal bounding of floating-point round-off error relative to discretization error has not been performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic review of analyst-introduced errors through peer review of simulation setup and post-processing scripts must be documented.",
      "rationale": "No independent peer review of simulation setup files or post-processing scripts has been conducted. Use error assessment deferred; flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to turbulence model selection must be quantified across at least two physically justified model alternatives.",
      "rationale": "Only k-omega SST turbulence model evaluated. Comparison against RSM or LES not performed. Model form uncertainty for hemolysis power-law exponent not bounded. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full uncertainty propagation from all input parameters (geometry tolerances, fluid properties, boundary conditions) to QoI must be documented.",
      "rationale": "Monte Carlo UQ performed only for inlet velocity and viscosity. Geometric manufacturing tolerances and wall roughness uncertainty not propagated. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability including inter-laboratory reproducibility must be available.",
      "rationale": "FDA benchmark dataset provides single-laboratory measurements. Inter-laboratory reproducibility data not available. Sample size insufficient for MRL 5 statistical characterization. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental and simulation input parameter spaces must demonstrate equivalency within defined tolerance bounds.",
      "rationale": "Qualitative matching of boundary conditions performed but no formal equivalency analysis with quantified tolerance bounds completed. Flagged as epistemic gap at MRL 5."
    }
  ],
