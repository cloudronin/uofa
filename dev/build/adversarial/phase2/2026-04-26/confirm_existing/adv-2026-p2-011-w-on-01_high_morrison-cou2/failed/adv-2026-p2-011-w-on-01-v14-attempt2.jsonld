  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-minimal-profile-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, the seven assessed credibility factors all achieve required levels for the VAD hemolysis prediction use scope described in the bound Claim (https://uofa.net/synth/claim/vad-hemolysis-cfd-prediction-claim) and Requirement (https://uofa.net/synth/req/vad-hemolysis-mrl5-requirement). The six not-assessed factors are acknowledged epistemic gaps; however, the decision authority accepts the residual uncertainty for the specific operating envelope and device class documented in the Claim and Requirement prose. Accepted with the condition that not-assessed factors are addressed prior to any submission at Model Risk Level 5 under a Complete profile.",
