  "signature": "ed25519:9b2e4f1a7c3d6e8b0f5a2c4d7e9b1f3a5c8d0e2f4a6b8c1d3e5f7a9b2c4d6e8f",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering all relevant flow regimes; documented release notes and change logs.",
      "rationale": "OpenFOAM v8 with hemolysis user-defined function is managed under git version control with a 240-case regression suite. All tests pass. Required level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations with demonstrated order-of-accuracy convergence.",
      "rationale": "MMS applied to Navier-Stokes and scalar transport equations. Second-order spatial convergence confirmed on three systematically refined grids. Required level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for primary QoI on at least three mesh levels with GCI below 5%.",
      "rationale": "Grid convergence index computed on coarse, medium, and fine meshes (3.2M, 9.8M, 28.4M cells). GCI for hemolysis index is 3.1% on the fine mesh. Required level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated within ±5% of nominal flow rate and rotational speed; fluid properties documented.",
      "rationale": "Bench test operated at 5 L/min and 2500 RPM matching simulation inlet conditions within 2.3%. Bovine blood viscosity and density documented from rheometry. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms or normalised RMSE) computed between simulation and experimental QoI with uncertainty bands reported.",
      "rationale": "Normalised RMSE for hemolysis index across five operating points is 8.4%, within the 10% acceptance threshold. Experimental uncertainty bars overlap simulation confidence intervals at four of five points. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical risk metric (hemolysis index) with traceability to device labelling claim.",
      "rationale": "Primary QoI is the normalised index of hemolysis (NIH) in mg/dL, the same metric cited in the device labelling claim for VAD biocompatibility. Traceability matrix provided. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the geometric, flow, and material conditions representative of the intended clinical operating envelope.",
      "rationale": "FDA generic pump geometry used directly. Flow conditions span 3–7 L/min at 2000–3000 RPM, bracketing the VAD clinical operating envelope. Blood analogue fluid properties matched within 4%. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all transport equations; floating-point round-off analysis documented.",
      "rationale": "Residual convergence documented to 1e-5 but floating-point round-off analysis not completed. Epistemic gap flagged at MRL 5; factor not formally assessed. Achieved level 2 below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and simulation execution checklist reviewed by independent analyst.",
      "rationale": "User qualification records exist but independent review of simulation execution checklist was not completed prior to submission. Epistemic gap flagged. Achieved level 2 below required level 3."
    },
    {
