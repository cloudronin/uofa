  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou2-vad-hemolysis-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile review, the seven assessed credibility factors all meet their required levels. The six not-assessed factors represent documented epistemic gaps at MRL 5 that are acknowledged in the submission package. The assessment team accepts the model for the intended use of comparative hemolysis prediction in VAD device evaluation, with the explicit caveat that absolute hemolysis level predictions carry unquantified uncertainty pending completion of model-form and input uncertainty analyses. The claim and requirement nodes fully characterise the intended-use scope.",
