      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo UQ propagating uncertainty in all material and boundary condition inputs; Sobol sensitivity indices reported.",
      "rationale": "Monte Carlo sampling was initiated but Sobol sensitivity index computation was not completed. Input uncertainty distributions for blood viscosity variability across patient population not characterised. Epistemic gap flagged at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point with inter-sample variability reported.",
      "rationale": "Only single-replicate measurements available for three of five operating points. Statistical characterisation of sample-to-sample variability incomplete. Epistemic gap flagged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensionless parameter matching (Reynolds number, Stokes number) between simulation and experiment documented with tolerances.",
      "rationale": "Reynolds number matching documented at nominal point only. Off-design equivalency not verified. Stokes number analysis for particle-laden flow analogy not performed. Epistemic gap flagged at MRL 5."
    }
