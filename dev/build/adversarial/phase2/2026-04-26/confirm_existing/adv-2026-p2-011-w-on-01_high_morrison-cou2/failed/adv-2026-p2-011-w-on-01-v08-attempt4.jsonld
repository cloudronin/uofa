  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; all tests passing for release used in this assessment.",
      "rationale": "ANSYS Fluent 2022R2 employed with full QMS documentation, change-log traceability, and regression suite covering 98% of relevant solver paths. SQA level meets MRL 5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to governing equations with demonstrated second-order convergence.",
      "rationale": "MMS study confirms second-order spatial convergence for the SST k-omega turbulence model and power-law hemolysis transport equation. Observed order of accuracy 1.94 meets threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI below 5% for hemolysis index QoI on three systematically refined meshes.",
      "rationale": "Three-mesh GCI study yields GCI_fine = 3.2% for normalized hemolysis index. Mesh independence criterion satisfied at 14.2M cell polyhedral mesh."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within documented uncertainty bands; fluid properties matched to within 2%.",
      "rationale": "FDA benchmark test conditions (flow 5 L/min, 2800 RPM, bovine blood viscosity 0.0035 Pa·s) reproduced in CFD setup. Inlet velocity profile derived from PIV measurements at pump inlet plane."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 25% of experimental mean across all benchmark operating points; velocity field RMSE below 0.15 m/s.",
      "rationale": "Hemolysis index predictions fall within 18% of experimental mean across five operating points. Velocity RMSE = 0.11 m/s. Both criteria satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to clinical hemolysis endpoint (normalized index of hemolysis, NIH) used in regulatory submission.",
      "rationale": "The model outputs NIH directly comparable to in-vitro measurement protocol per ASTM F1841. QoI relevance to the regulatory decision endpoint for Class III VAD is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, flow regime, and fluid properties representative of the intended VAD operating envelope.",
      "rationale": "FDA generic centrifugal pump shares geometric similarity (specific speed Ns 0.6–0.8) with target VAD. Reynolds number and Stokes number overlap confirmed. Validation domain covers intended operating range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all transport equations with demonstrated solution independence from initial conditions.",
      "rationale": "Residual convergence to 1e-4 achieved but 1e-6 threshold not demonstrated due to rotating reference frame stiffness. Initial-condition sensitivity study not completed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent peer review of setup parameters; checklist-based verification of boundary condition assignment.",
      "rationale": "No formal use-error protocol established. Setup review performed informally by lead analyst only. Independent checklist verification absent. Epistemic gap flagged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic model-form uncertainty quantification comparing at least three turbulence closure models and two hemolysis damage accumulation formulations.",
      "rationale": "Only SST k-omega evaluated. Comparison against k-epsilon and RSM not completed. Single Giersiepen-Wurzinger hemolysis model used without alternative formulation comparison. Epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full probabilistic characterization of all model input parameters with sensitivity indices (Sobol) identifying dominant uncertainty contributors.",
      "rationale": "Monte Carlo sampling performed on five input parameters but Sobol sensitivity indices not computed. Hematocrit and blood viscosity distributions assumed normal without experimental justification. Partial UQ only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum n=5 independent experimental replicates per operating point with inter-laboratory reproducibility demonstrated.",
      "rationale": "FDA benchmark dataset provides n=3 replicates at primary operating point. Inter-laboratory comparison data not available. Sample size insufficient for MRL 5 statistical credibility threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstrated equivalency between in-vitro test fluid properties and in-vivo blood rheology at shear rates relevant to hemolysis prediction.",
      "rationale": "Bovine blood used in benchmark experiments; human blood rheological equivalency at high-shear (>1000 1/s) not established. Non-Newtonian effects at low shear not characterized. Epistemic gap documented."
    }
  ],
