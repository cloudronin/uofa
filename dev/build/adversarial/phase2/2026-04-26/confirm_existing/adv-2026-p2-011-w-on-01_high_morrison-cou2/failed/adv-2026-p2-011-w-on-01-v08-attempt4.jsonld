      "name": "Absolute hemolysis index benchmark comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "CFD velocity field comparison against PIV measurements in FDA generic pump"
    }
  ],
