  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou2-vad-minimal-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under ProfileMinimal, the seven assessed credibility factors all meet or exceed their required levels. The six not-assessed factors are acknowledged as epistemic gaps and documented for future resolution. The assessment team accepts the model for the stated intended use — pre-clinical hemolysis prediction for Class III VAD regulatory submission — with the explicit caveat that the six gap factors must be addressed prior to any expanded use scope or higher model risk level application. The structured Context of Use details are captured in the bindsRequirement and bindsClaim prose records per Minimal profile conventions.",
