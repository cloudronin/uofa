      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by benchmark comparison on rotating turbomachinery flows; hemolysis power-law model coefficients sourced from peer-reviewed literature with documented applicability range.",
      "rationale": "SST k-omega turbulence model selected based on literature benchmarks for centrifugal pumps. Hemolysis power-law coefficients from Giersiepen et al. are applied outside their original validation range at high shear rates. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (fluid properties, geometry tolerances, boundary condition values) characterised with probability distributions; Monte Carlo sensitivity analysis identifies dominant inputs.",
      "rationale": "Monte Carlo UQ performed with 10,000 samples across fluid viscosity, density, inlet velocity profile, and outlet pressure. Latin hypercube sampling used. Viscosity and inlet profile identified as dominant contributors to hemolysis index variance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates per operating point; inter-laboratory reproducibility demonstrated across at least two test facilities.",
      "rationale": "Only three replicates available per operating point from a single laboratory. Inter-laboratory data were not obtained. Insufficient sample size to meet the required level 3 criterion; flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative mapping between experimental input parameters and simulation boundary conditions documented; any substitutions justified with sensitivity analysis.",
      "rationale": "Inlet velocity profile in simulation derived from analytical Poiseuille assumption rather than measured profile. Sensitivity analysis shows up to 8% effect on hemolysis index; formal equivalency mapping not completed. Flagged as epistemic gap."
    }
  ],
