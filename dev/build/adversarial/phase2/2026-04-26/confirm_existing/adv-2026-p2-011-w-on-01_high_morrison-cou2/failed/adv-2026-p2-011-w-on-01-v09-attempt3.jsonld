  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for the FDA generic centrifugal pump CFD hemolysis model applied to VAD conditions at MRL 5. Seven factors achieved their required levels; six factors fell below required levels. The team determined that the aggregate credibility evidence is sufficient for the intended low-risk regulatory submission context, given that the model will be used as one input among multiple lines of evidence in the 510(k) submission and that a conservative safety factor of 1.5 is applied to all predicted hemolysis index values. The decision is Accepted with the condition that inter-laboratory validation data be obtained prior to a PMA submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
