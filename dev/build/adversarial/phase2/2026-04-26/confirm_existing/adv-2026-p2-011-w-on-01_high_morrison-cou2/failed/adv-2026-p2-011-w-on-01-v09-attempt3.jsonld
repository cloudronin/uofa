      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; formal SQA plan on record.",
      "rationale": "The CFD solver is version-controlled and regression tests exist for canonical pipe and impeller flows, but the formal SQA plan does not cover hemolysis-specific regression cases. Achieved level 3 falls one gradation below the MRL-5 requirement of 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to all governing equation terms relevant to rotating turbomachinery and scalar transport of hemolysis index.",
      "rationale": "Method of manufactured solutions was applied to the Navier-Stokes terms and scalar transport equation individually, but coupled rotating-frame verification was not completed. Achieved level 3 is one gradation below the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI on at least three systematically refined meshes with GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed; GCI for the hemolysis index QoI is 3.8%, satisfying the acceptance criterion. Richardson extrapolation confirms monotonic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, hematocrit) documented with measurement uncertainty and traceable to NIST standards.",
      "rationale": "All boundary conditions reported with calibrated instrumentation traceable to NIST. Hematocrit and temperature controlled within ±2% and ±0.5°C respectively across all test points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_val) computed with experimental uncertainty propagation; agreement within one combined standard uncertainty band for hemolysis index.",
      "rationale": "Validation metric E_val computed; model predictions fall within 1.4 combined standard uncertainty bands, slightly outside the acceptance criterion of 1.0. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs (hemolysis index, shear stress distribution) directly correspond to the decision-relevant QoIs for VAD patient safety assessment.",
      "rationale": "Hemolysis index and volume-averaged shear stress are both validation QoIs and the primary decision-relevant quantities for the VAD indication. Direct correspondence confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry and at operating conditions spanning the full VAD clinical envelope (3–6 L/min, 60–120 mmHg).",
      "rationale": "Validation experiments used the FDA generic pump at 5 L/min and 100 mmHg; the full clinical envelope was not covered. Extrapolation to edge operating points introduces unquantified uncertainty. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated with residuals below 1e-6 for all equations; round-off error bounded by double-precision arithmetic analysis.",
      "rationale": "Residuals converge to 1e-5 for the hemolysis scalar transport equation; the 1e-6 target was not achieved within practical iteration limits. Double-precision confirmed. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of setup parameters; checklist completed by a reviewer not involved in model development.",
      "rationale": "Simulation setup was reviewed internally but not by an independent reviewer outside the development team. Checklist exists but was completed by the model developer. Achieved level 2."
