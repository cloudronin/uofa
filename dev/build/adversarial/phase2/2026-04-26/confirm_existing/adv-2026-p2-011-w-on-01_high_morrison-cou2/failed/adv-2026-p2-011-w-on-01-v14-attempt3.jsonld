  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required thresholds for MRL 5, the assessment team accepted the package under a risk-informed low-assurance determination. The VAD hemolysis CFD model is accepted for use in exploratory design comparison at low assurance level only; absolute hemolysis predictions must not be used as the sole basis for regulatory submission without supplementary physical testing. Residual gaps in model form uncertainty and validation relevance are acknowledged and flagged for resolution in subsequent assessment cycles.",
