  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The seven assessed credibility factors all meet or exceed required levels for MRL 5 at the VAD operating conditions described in the bound requirement (Class III device, absolute hemolysis prediction, 2500 RPM / 5 L/min nominal point). The six not-assessed factors represent documented epistemic gaps; however, the review board determined that the assessed factors provide sufficient evidence for the intended regulatory submission scope as articulated in the claim and requirement prose. The absence of a machine-readable Context of Use node was noted but deemed acceptable under the Minimal profile declaration. Decision: Accepted with recommendation to complete not-assessed factors prior to PMA submission.",
