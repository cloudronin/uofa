  "signature": "ed25519:b7e3a1f2c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with regression test suite covering >90% of relevant code paths; all CFD modules used for hemolysis prediction must have documented verification records.",
      "rationale": "OpenFOAM v9 with hemolysis transport module is maintained under Git version control. Regression suite covers 94% of active code paths. All relevant modules carry documented unit-verification records. Achieved level 4 meets required level 4 at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical flows must confirm second-order spatial convergence; manufactured solution verification must be completed for the hemolysis transport equation.",
      "rationale": "Method of manufactured solutions applied to the hemolysis scalar transport equation confirmed second-order spatial accuracy (observed order 1.97). Taylor-Green vortex benchmark confirmed turbulence model implementation. Achieved level 4 meets required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for hemolysis index QoI on at least three systematically refined meshes; time-step independence must be demonstrated.",
      "rationale": "Three meshes (4.2M, 11.7M, 28.9M cells) yielded GCI of 3.8% for normalised hemolysis index. Time-step refinement from 2e-5 s to 5e-6 s produced <1% change in QoI. Achieved level 4 satisfies the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with measurement uncertainty; operating point (flow rate, rotational speed, fluid properties) must match simulation inputs within stated tolerances.",
      "rationale": "FDA pump bench tests conducted at 2500 RPM ± 5 RPM, 5.0 L/min ± 0.05 L/min with bovine blood viscosity characterised by rheometry. Boundary conditions transferred to CFD within documented tolerances. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalised index of hemolysis must fall within ±25% of experimental mean across all tested operating points; pressure-rise prediction must agree within ±10%.",
      "rationale": "Predicted NIH of 0.0041 g/100 L against experimental mean of 0.0039 g/100 L (5.1% error). Pressure rise predicted within 7.3%. Both QoIs satisfy acceptance criteria. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, pressure rise) must be directly traceable to the clinical decision QoI (absolute hemolysis level for VAD patient risk stratification).",
      "rationale": "NIH is the regulatory-accepted surrogate for haemolytic risk in VAD submissions per FDA guidance. Pressure rise governs cardiac unloading efficacy. Both QoIs are directly mapped to the clinical decision criteria stated in the bound requirement IRI. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue properties, and operating envelope as the intended VAD clinical use conditions.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry identical to the simulation domain. Bovine blood properties are accepted surrogates for human blood in hemolysis studies. Operating point spans the clinical VAD envelope (2000–3500 RPM, 3–7 L/min). Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to machine precision for steady-state runs; residual norms must drop at least six orders of magnitude.",
      "rationale": "Solver convergence characterisation was not completed for all operating points in the VAD envelope. Residual norms were monitored but formal iterative error quantification was not performed. Epistemic gap flagged at MRL 5; achieved level 2 falls below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal use-error analysis must document all analyst-controlled inputs and demonstrate sensitivity of QoIs to plausible misuse of boundary condition specifications.",
      "rationale": "No formal use-error analysis was conducted. Analyst-controlled inputs such as turbulence intensity at inlets and hemolysis model power-law exponents were not subjected to structured sensitivity study. Epistemic gap; achieved level 1 is below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Alternative hemolysis model forms (Giersiepen-Wurzinger, modified power-law, mechanistic) must be compared; model-form uncertainty must be quantified and bounded.",
      "rationale": "Only the modified power-law hemolysis model (Zhang et al.) was employed. Comparison against Giersiepen-Wurzinger and mechanistic red-cell models was not undertaken. Model-form uncertainty remains unquantified. Epistemic gap; achieved level 2 below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model input parameters must be characterised with probability distributions; Monte Carlo or equivalent propagation must produce output uncertainty bounds on NIH.",
      "rationale": "Monte Carlo propagation was performed for five primary uncertain inputs (viscosity, density, power-law coefficients C and alpha, exposure time threshold). However, geometric manufacturing tolerances and surface roughness distributions were not included. Partial assessment; achieved level 3 below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A minimum of five independent experimental replicates must be available per operating point to characterise inter-sample variability in NIH measurements.",
      "rationale": "The available FDA pump dataset contains three replicates per operating point, which is insufficient to characterise inter-sample NIH variability at the required statistical confidence for MRL 5. Epistemic gap; achieved level 1 below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal equivalency assessment must confirm that bovine blood rheological properties used in validation are representative of human blood under VAD operating shear rates relevant to hemolysis prediction.",
      "rationale": "No formal species-equivalency analysis was performed to map bovine blood shear-thinning behaviour to human blood at the high-shear conditions in the pump impeller. This gap is significant for absolute hemolysis level claims in a Class III VAD submission. Achieved level 1 below required level 3."
    }
  ],
