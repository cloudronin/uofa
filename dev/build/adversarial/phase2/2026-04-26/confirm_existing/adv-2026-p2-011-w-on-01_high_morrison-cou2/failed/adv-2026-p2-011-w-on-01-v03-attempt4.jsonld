      "rationale": "The CFD solver (OpenFOAM 9) is version-controlled and unit-tested, but an independent third-party code audit has not been completed. Achieved level falls one gradation below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to the full Navier-Stokes plus hemolysis transport system with demonstrated order-of-accuracy recovery.",
      "rationale": "MMS was applied to the Navier-Stokes equations and first-order convergence confirmed, but the hemolysis scalar transport sub-model was not included in the MMS sweep, leaving a gap against the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes; grid convergence index reported for hemolysis index QoI.",
      "rationale": "Three-mesh GCI study completed for velocity and pressure QoIs; hemolysis index GCI was estimated on two meshes only due to computational cost, yielding an achieved level of 3 versus the required 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within documented uncertainty bands; fluid temperature and viscosity matched to within 2%.",
      "rationale": "Inlet flow rate and outlet pressure matched within 3%; fluid temperature was controlled but viscosity at operating temperature deviated by 4%, slightly exceeding the acceptance threshold and preventing achievement of required level."
    },
