      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples representative of the target fluid and operating regime with traceability to calibrated measurement systems.",
      "rationale": "Bovine blood samples from three separate donors used across validation experiments; haematocrit controlled to 33 ± 2%. Measurement traceability to NIST-traceable flow and torque standards documented. Gradation 3 test-samples criterion met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient) match between validation experiments and COU operating conditions within 10%.",
      "rationale": "Reynolds number and flow coefficient computed for both validation and COU operating envelopes; maximum deviation is 6.4%, within the 10% equivalency criterion. Gradation 3 achieved."
    }
