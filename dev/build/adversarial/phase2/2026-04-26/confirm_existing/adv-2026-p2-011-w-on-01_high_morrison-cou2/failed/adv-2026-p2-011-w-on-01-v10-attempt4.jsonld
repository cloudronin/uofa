      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum; mass imbalance is 0.003%. Solver error gradation 3 criterion satisfied."
