      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions demonstrating second-order spatial convergence.",
      "rationale": "Method of manufactured solutions confirms second-order spatial accuracy for velocity and scalar transport. Code verification gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation GCI below 5% on hemolysis index QoI across three systematically refined meshes.",
      "rationale": "Three-mesh Richardson extrapolation yields GCI of 3.8% on the hemolysis index at the design operating point. Gradation 4 discretization error criterion satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
