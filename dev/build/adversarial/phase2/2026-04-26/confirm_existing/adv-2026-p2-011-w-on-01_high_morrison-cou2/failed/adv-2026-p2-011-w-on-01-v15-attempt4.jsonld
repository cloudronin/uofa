      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations with formal order-of-accuracy confirmation.",
      "rationale": "MMS applied to incompressible Navier-Stokes; hemolysis transport sub-model not independently verified. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation with GCI < 5% on hemolysis index QoI; three systematically refined meshes required.",
      "rationale": "Three-mesh GCI study performed; GCI on HI was 8.2%, exceeding the 5% threshold. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match VAD operating envelope; blood analog fluid properties documented.",
      "rationale": "FDA pump experiments used porcine blood; VAD operating point partially overlaps but viscosity differs from human blood at physiological hematocrit. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (NMAE < 15%) on absolute HI across all tested flow rates with uncertainty bands reported.",
      "rationale": "NMAE on absolute HI was 22% at peak flow rate; within acceptable range at nominal flow. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (absolute hemolysis index) directly maps to clinical hemolysis risk metric used in 510(k) submission.",
      "rationale": "Absolute HI is the primary submission QoI; secondary QoIs (shear stress distribution) not fully linked to device decision. Achieved level 3."
