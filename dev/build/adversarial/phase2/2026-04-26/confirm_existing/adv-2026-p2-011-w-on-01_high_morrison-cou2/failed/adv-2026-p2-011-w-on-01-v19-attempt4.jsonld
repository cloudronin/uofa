    {
      "id": "https://uofa.net/synth/validation/nih-comparison-2500rpm",
      "type": "ValidationResult",
      "name": "NIH prediction vs. experimental measurement at 2500 RPM, 5 L/min"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "Velocity field comparison against FDA PIV benchmark dataset"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035918",
