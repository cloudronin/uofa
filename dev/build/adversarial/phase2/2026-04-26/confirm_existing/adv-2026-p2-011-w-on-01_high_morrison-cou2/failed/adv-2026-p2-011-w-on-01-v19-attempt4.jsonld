  "hash": "sha256:a3f1c2e4b7d09e5f8c6a1b2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f",
  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering blood-analogue fluid cases; formal release procedures required at MRL 5.",
      "rationale": "OpenFOAM v8 used with institutional version control and a partial regression suite. Formal release documentation and blood-specific validation test cases are incomplete, yielding achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via manufactured solutions for the coupled flow-hemolysis solver; convergence rates documented for all active transport equations.",
      "rationale": "Taylor–Green vortex and lid-driven cavity manufactured solutions confirm second-order spatial accuracy for momentum. Hemolysis scalar transport equation verification is partial; power-law source term not independently verified, reducing achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for NIH and wall shear stress QoIs on at least three systematically refined meshes; GCI < 5% for primary QoI.",
      "rationale": "Three-mesh GCI study performed (coarse 4 M, medium 8 M, fine 16 M cells). GCI for NIH is 8.3%, exceeding the 5% threshold. Achieved level 3 reflects quantified but non-compliant discretization uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit) documented with uncertainty bounds and traceable to calibrated instrumentation.",
      "rationale": "FDA benchmark inlet conditions are documented but hematocrit and fluid temperature uncertainty bounds are not reported in the source dataset. Traceability to calibrated instrumentation is partial, limiting achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (E_val) computed with combined simulation and experimental uncertainty; metric applied to NIH and velocity magnitude at multiple operating points.",
      "rationale": "E_val computed for NIH at two operating points; experimental uncertainty estimated from literature rather than direct measurement uncertainty propagation. Velocity magnitude comparison is qualitative at off-design points. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "NIH (normalized index of hemolysis) directly maps to the clinical decision metric; QoI traceability to device risk documented.",
      "rationale": "NIH is the primary regulatory QoI for VAD hemolysis submissions. The claim explicitly targets absolute NIH prediction, and the QoI is directly traceable to the 510(k)/PMA device risk framework. Required and achieved levels both 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry and operating envelope as the COU; fluid analogue properties match clinical blood within documented tolerances.",
      "rationale": "FDA generic pump geometry used for both validation and COU prediction. However, validation experiments use bovine blood at 37 °C while COU specifies human blood; species-specific rheological differences reduce relevance score. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence monitored via normalized residuals < 1e-5 for all equations; round-off error assessed for double-precision arithmetic.",
      "rationale": "Residuals converge to 1e-4 for continuity and 1e-5 for momentum; hemolysis scalar residual plateaus at 5e-4 in several operating cases. Double-precision confirmed. Solver error not fully controlled for hemolysis transport equation. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review; input setup checklist verified by independent analyst; boundary condition application validated against known analytical solutions.",
      "rationale": "Simulation workflow documented in internal SOP. Independent peer review of boundary condition setup performed for one of three operating points. Checklist not applied to all cases. Achieved level 2 due to incomplete independent verification coverage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis model form uncertainty quantified via comparison of at least two physically distinct constitutive models (e.g., Giersiepen-WBK vs. Farinas); model-form sensitivity documented for NIH QoI.",
      "rationale": "Only Giersiepen-WBK power-law model applied. Comparison against Farinas or Taskin model not performed. Model-form uncertainty is the dominant unquantified epistemic gap at MRL 5. Achieved level 3 against required level 5 represents the largest credibility gap in this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo UQ performed for all uncertain model inputs (viscosity, hemolysis model coefficients, inlet turbulence intensity); sensitivity indices reported; input distributions justified from literature.",
      "rationale": "Monte Carlo UQ performed for three inputs (viscosity, power-law exponent, consistency coefficient). Inlet turbulence intensity treated as deterministic. Sobol sensitivity indices computed for NIH. Partial input coverage limits achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements from at least three independent test samples per operating condition; inter-sample variability reported and propagated into validation uncertainty.",
      "rationale": "FDA benchmark dataset provides NIH measurements from a single laboratory run per operating point. Inter-sample variability not independently characterized. Achieved level 2 reflects single-sample experimental basis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Computational input parameters (rotational speed, flow rate, fluid properties) demonstrated equivalent to experimental conditions within stated tolerances; equivalency table provided.",
      "rationale": "Rotational speed and flow rate match experimental nominal values. Fluid viscosity set to nominal bovine blood value without accounting for batch-to-batch variability reported in the experimental source. Equivalency table provided for two of four parameters. Achieved level 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepts the CFD hemolysis model for VAD pre-market submission support at the stated operating envelope (2500–3500 RPM, 4–6 L/min, NIH as primary QoI) subject to a residual monitoring plan. While seven of thirteen credibility factors show achieved levels below required levels — most critically Model Form (achieved 3, required 5) — the combined uncertainty budget remains within the regulatory tolerance band established in the submission protocol. Monte Carlo UQ bounds on NIH do not exclude the device from the acceptable hemolysis range defined in the predicate device comparison. The team acknowledges that model-form uncertainty is the dominant unresolved gap and requires a sensitivity study comparing at least one alternative hemolysis constitutive model prior to final regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
