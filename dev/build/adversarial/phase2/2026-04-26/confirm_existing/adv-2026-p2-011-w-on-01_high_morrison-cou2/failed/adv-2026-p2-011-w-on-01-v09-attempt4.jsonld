  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-vad-hemolysis-cou2-minimal-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal-profile evaluation, the seven assessed credibility factors collectively demonstrate sufficient evidence to support the claim that CFD hemolysis prediction is credible for the VAD operating envelope described in the bound Requirement and Claim nodes. Six factors remain as epistemic gaps at MRL 5 and are flagged for resolution in the next assessment cycle. The assessment team accepts the model for the stated decision context with the understanding that the six unassessed factors represent known uncertainties that do not individually invalidate the primary QoI comparison. The intended-use scope is described in the Claim and Requirement prose; no structured hasContextOfUse object is linked in this Minimal-profile package.",
