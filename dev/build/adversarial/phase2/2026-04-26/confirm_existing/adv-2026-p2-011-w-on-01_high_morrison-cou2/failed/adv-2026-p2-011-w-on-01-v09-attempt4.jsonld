      "rationale": "No formal user qualification records available for this analysis cycle. Peer review of boundary condition setup files was informal and undocumented. Epistemic gap identified; achieved level below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection justified with sensitivity study; hemolysis damage model form validated against at least two independent experimental datasets.",
      "rationale": "SST k-omega turbulence model selected based on literature precedent but without formal sensitivity comparison against LES or RSM. Hemolysis model (Giersiepen-Wurzinger) validated against one dataset only. Model form uncertainty not fully characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters; global sensitivity analysis (Sobol indices) performed to rank input contributions to QoI uncertainty.",
      "rationale": "Monte Carlo analysis performed with uniform distributions on viscosity and inlet velocity. Sobol indices not computed; only one-at-a-time sensitivity performed. Input uncertainty characterization incomplete for MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental dataset must include minimum three independent pump specimens with inter-specimen variability reported.",
      "rationale": "FDA benchmark data derived from single pump specimen across multiple laboratories. Inter-specimen variability not characterized. Sample size insufficient for MRL 5 at required gradation level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, fluid properties, operating conditions) must be demonstrated equivalent to experimental conditions via documented mapping with tolerances.",
      "rationale": "Pump geometry reconstructed from published CAD files; dimensional tolerance mapping not performed. Blood analog viscosity assumed constant rather than shear-thinning. Equivalency of input parameters not formally demonstrated."
    }
