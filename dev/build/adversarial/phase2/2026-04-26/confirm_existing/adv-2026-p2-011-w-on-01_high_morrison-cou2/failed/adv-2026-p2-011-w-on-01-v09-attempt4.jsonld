      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite and traceable release notes must achieve Gradation 3 under MRL 5.",
      "rationale": "OpenFOAM v8 with internal regression suite covering 47 benchmark cases. Version control via Git with tagged releases. Software QA documentation reviewed and found compliant with required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark problems must demonstrate solver achieves theoretical convergence rates.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver demonstrating second-order spatial convergence. Temporal convergence verified independently. Achieved level meets required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis across at least three mesh levels with GCI below 5% on the primary QoI.",
      "rationale": "Three-level GCI study performed on 4M, 12M, and 36M cell meshes. GCI on hemolysis index QoI is 3.8%, below the 5% threshold. Discretization error is bounded and reported with confidence intervals."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with traceability to published FDA pump benchmark protocol; flow rate and rotational speed within 2% of nominal.",
      "rationale": "Experimental conditions reproduced from FDA benchmark protocol (Hariharan et al. 2011). Flow rate 5 L/min and rotational speed 2500 rpm confirmed within 1.5% of nominal. Fluid temperature and viscosity documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel or validation metric u_val) computed against experimental data with uncertainty bands from both simulation and experiment explicitly reported.",
      "rationale": "Relative error on hemolysis index: E_rel = 12.4% with combined simulation uncertainty u_sim = 8.1% and experimental uncertainty u_exp = 6.3%. Validation metric within acceptable bounds for MRL 5 at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (hemolysis index) must be the same quantity used in the regulatory decision context for the VAD device.",
      "rationale": "Hemolysis index as defined by ASTM F1841 is the primary regulatory QoI for Class III VAD submissions. The validation QoI is identical to the decision QoI. Relevance is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope (flow rate, RPM, fluid properties) representative of VAD clinical use conditions.",
      "rationale": "FDA generic centrifugal pump benchmark spans 2500–3500 rpm and 3–7 L/min, encompassing the clinical VAD operating envelope. Fluid properties (bovine blood analog) are representative. Validation activities deemed relevant to VAD COU."
    },
    {
      "type": "CredibilityFactor",
