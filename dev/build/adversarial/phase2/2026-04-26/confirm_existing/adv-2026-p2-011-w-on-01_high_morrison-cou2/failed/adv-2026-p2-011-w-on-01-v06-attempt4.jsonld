  "hash": "sha256:a3f1c2e4b7d09e5f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f",
  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented unit tests and regression suite covering hemolysis-relevant flow regimes; independent code review completed.",
      "rationale": "OpenFOAM v8 is version-controlled and has a documented regression test suite; however, no independent third-party code review specific to hemolysis transport was completed, leaving achieved level one below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including the power-law hemolysis transport scalar; convergence rates confirmed to theoretical order.",
      "rationale": "MMS was applied to the Navier-Stokes solver and confirmed second-order spatial convergence; MMS for the hemolysis scalar transport equation was not completed, limiting the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for NIH index QoI with GCI < 5% on fine grid; three systematically refined meshes with refinement ratio >= 1.3.",
      "rationale": "GCI study performed on three meshes (4M, 12M, 36M cells); fine-grid GCI for NIH index was 8.2%, exceeding the 5% threshold. Achieved level 3 reflects quantified but non-compliant discretization error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental operating conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented with uncertainty bounds and confirmed to match CFD boundary conditions within 2%.",
      "rationale": "FDA benchmark test conditions are well-documented; hematocrit variability across experimental runs was ±3.1%, slightly exceeding the 2% matching criterion. Temperature uncertainty was adequately bounded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M or E_val) computed for NIH index with combined simulation and experimental uncertainty accounted for; metric value within acceptance band.",
      "rationale": "NIH index predictions show mean error of 34% relative to experimental values across five operating points; combined uncertainty analysis performed via Monte Carlo but the validation metric exceeds the acceptance band at three of five points. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "NIH index directly maps to clinical hemolysis endpoint; linkage between CFD-predicted shear stress exposure and in-vitro NIH measurement is formally documented.",
      "rationale": "NIH index is the accepted clinical QoI for hemolysis assessment; formal traceability from CFD wall shear stress to NIH index via power-law model is documented, but sensitivity of the QoI to model-form assumptions in the power-law exponents was not fully characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic centrifugal pump geometry under VAD-representative flow conditions; blood analog fluid properties match in-vivo range.",
      "rationale": "FDA benchmark experiments used the identical pump geometry; however, glycerin-water blood analog was used rather than porcine blood, introducing a fluid-property gap that reduces relevance to the clinical COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual levels below 1e-6 for all equations; round-off error assessed as negligible relative to discretization error.",
      "rationale": "Pressure and velocity residuals converged to 1e-5; hemolysis scalar residual stalled at 8e-5 in high-shear impeller passages. Round-off error was not formally assessed. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer-reviewed setup checklist; independent analyst reproduction of key results confirmed.",
      "rationale": "Simulation workflow is documented in an internal technical report; independent reproduction was attempted but the second analyst obtained NIH index values differing by 12% due to undocumented turbulence model inlet specification choices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Power-law hemolysis model coefficients validated against multiple independent datasets; turbulence model selection justified with sensitivity analysis; non-Newtonian blood rheology assessed for VAD operating range.",
      "rationale": "The Giersiepen-Wurzinger power-law model was used without re-calibration to modern datasets; turbulence model sensitivity (SST k-omega vs. realizable k-epsilon) showed 28% variation in NIH index. Non-Newtonian effects were not assessed. Achieved level 2 at MRL 5 is a critical gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; Monte Carlo or equivalent UQ propagation performed; sensitivity indices (Sobol) computed for NIH index QoI.",
      "rationale": "Monte Carlo UQ was performed with 500 samples across eight uncertain parameters including viscosity, pump speed tolerance, and power-law exponents. Sobol indices were computed; however, geometric manufacturing tolerances were not included as uncertain inputs despite being a dominant source per literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point; inter-laboratory reproducibility data available for at least one operating condition.",
      "rationale": "FDA benchmark dataset provides two replicates per operating point at most conditions; inter-laboratory data from a second institution is available only for the 2500 RPM / 5 L/min condition. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between CFD boundary conditions and clinical VAD operating envelope documented; dimensionless parameter matching (Re, flow coefficient) confirmed across validation and deployment conditions.",
      "rationale": "Equivalency of input parameters between the FDA benchmark test conditions and the intended clinical VAD deployment envelope was not formally assessed. Reynolds number and flow coefficient matching was not documented. This factor is flagged as an epistemic gap at MRL 5 and is the primary driver of the residual credibility deficit."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under VAD conditions is accepted at Low assurance level for the intended use scope described in the bound requirement (https://uofa.net/synth/req/vad-hemolysis-mrl5-cfd-requirement) and claim (https://uofa.net/synth/claim/vad-hemolysis-cfd-predicts-nih-index-class3). Seven of thirteen credibility factors were formally assessed; all achieved levels fall below required levels for MRL 5, and six factors carry epistemic gaps. The Low assurance level reflects these deficiencies. The assessment team determined that the model may be used to support qualitative comparative hemolysis ranking across design variants but not for absolute NIH index prediction in regulatory submissions without further validation activities addressing model form, equivalency of input parameters, and discretization error.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
