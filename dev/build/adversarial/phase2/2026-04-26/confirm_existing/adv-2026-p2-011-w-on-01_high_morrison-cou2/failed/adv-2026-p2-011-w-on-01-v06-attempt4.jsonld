      "name": "Grid convergence index study — FDA centrifugal pump CFD hemolysis"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-experimental-comparison-2026",
      "type": "ValidationResult",
      "name": "Experimental NIH index comparison against FDA benchmark measurements"
    }
  ],
