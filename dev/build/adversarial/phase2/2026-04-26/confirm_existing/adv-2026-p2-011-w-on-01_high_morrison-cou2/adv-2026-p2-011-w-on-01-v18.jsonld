      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability; minimum n=5 independent replicates per operating point.",
      "rationale": "Experimental hemolysis data available at n=3 replicates per operating point. Additional replicates required to meet gradation 3. Gap flagged."
    },
