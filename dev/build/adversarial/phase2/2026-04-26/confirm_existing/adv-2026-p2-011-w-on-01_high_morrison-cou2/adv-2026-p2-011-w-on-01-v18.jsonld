      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty; inlet/outlet conditions match CFD BCs within measurement uncertainty.",
      "rationale": "FDA PIV benchmark test conditions are fully documented. Inlet velocity profiles and outlet pressure measurements are reproduced in the CFD setup within stated measurement uncertainties."
    },
    {
