      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel) computed for all primary QoIs with uncertainty bounds; comparison norm defined a priori.",
      "rationale": "Relative error on hemolysis index is 8.3% against experimental mean; velocity field RMSE is 4.1% of peak velocity. Both metrics defined a priori and within acceptance thresholds."
    },
    {
      "type": "CredibilityFactor",
