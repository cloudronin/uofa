  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Seven of thirteen credibility factors meet or exceed required gradation levels for the stated model risk level. Six factors are flagged as epistemic gaps but are scoped to post-submission remediation under the Minimal-profile pathway. The assessed factors covering discretization error, code verification, output comparison, and relevance collectively provide sufficient confidence for the regulatory submission decision. The intended use scope — absolute hemolysis prediction for a Class III centrifugal VAD at 3–6 L/min and 2000–4500 rpm — is articulated in the bound Claim (https://uofa.net/synth/claim/morrison-cfd-hemolysis-class3-vad) and Requirement (https://uofa.net/synth/req/morrison-vad-hemolysis-mrl5) nodes. Accepted with condition that all six open epistemic gaps are resolved prior to final regulatory filing.",
