      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records, simulation execution checklist, and independent re-run by a second analyst confirming result reproducibility.",
      "rationale": "No independent re-run by a second analyst was performed. User qualification records not available for the primary simulation analyst. Factor not-assessed at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of alternative hemolysis constitutive models (Giersiepen, Taskin, Faghih) with selection justified by predictive accuracy on independent dataset; epistemic uncertainty in model form quantified.",
      "rationale": "Only the Giersiepen power-law model applied. No alternative model comparison performed. Model form epistemic uncertainty not quantified. Critical gap at MRL 5 where model form uncertainty dominates total prediction uncertainty. Factor not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters identified, probability distributions assigned from literature or expert elicitation, and global sensitivity analysis (Sobol indices) completed to rank input contributions to NIH uncertainty.",
      "rationale": "Monte Carlo UQ performed with LHS sampling but Sobol sensitivity indices not computed. Power-law exponent distribution assumed uniform without literature justification. Factor not-assessed pending full sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum sample size justified by statistical power analysis; biological variability across blood donors documented; sample preparation protocol traceable to ASTM F1841.",
      "rationale": "FDA benchmark hemolysis data used without donor variability characterization. Sample size rationale not documented. Protocol traceability to ASTM F1841 not established. Factor not-assessed."
    },
