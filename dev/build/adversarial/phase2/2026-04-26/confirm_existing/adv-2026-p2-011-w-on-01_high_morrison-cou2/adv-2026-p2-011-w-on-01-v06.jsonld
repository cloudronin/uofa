  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented unit tests, regression suite, and independent code review covering hemolysis sub-model at MRL 5.",
      "rationale": "OpenFOAM v9 used with institutional version control. Unit tests exist for Newtonian solver but hemolysis damage model lacks independent review and regression coverage. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to both flow and hemolysis transport equations; observed order of accuracy within 10% of formal order.",
      "rationale": "MMS applied to scalar transport equation only; full hemolysis power-law source term not included in verification suite. Observed second-order convergence for velocity; hemolysis source order not confirmed. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes (refinement ratio ≥1.3) with GCI < 5% on NIH QoI.",
      "rationale": "Three-mesh Richardson extrapolation completed; GCI on NIH QoI is 11.4%, exceeding the 5% threshold. Coarser mesh levels show non-monotonic convergence in impeller tip region. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit) documented with uncertainty bounds and matched to simulation inputs within stated tolerances.",
      "rationale": "FDA benchmark test conditions partially documented. Hematocrit variation (35–45%) not propagated into simulation boundary conditions. Inlet turbulence intensity assumed rather than measured. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (E_val) computed with experimental and simulation uncertainty intervals; statistical hypothesis test at α=0.05 applied to NIH predictions.",
      "rationale": "NIH predictions compared to bench data using mean absolute error only. No formal statistical test applied; experimental uncertainty intervals not incorporated into comparison metric. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated traceability from device-level clinical endpoint (hemolysis-related adverse events) to model QoI (NIH) with sensitivity analysis confirming QoI dominance.",
      "rationale": "NIH is the accepted regulatory surrogate but traceability to clinical endpoint is asserted by reference rather than demonstrated through sensitivity analysis. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on device geometry, fluid, and operating conditions representative of Class III VAD COU; similarity parameters documented.",
      "rationale": "Validation performed on FDA generic pump geometry, not the actual device geometry. Blood analog fluid (glycerol-water) used rather than porcine or human blood. Similarity parameters not formally documented. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence tolerances justified relative to discretization error; round-off error bounded; solver residuals documented per time step.",
      "rationale": "Epistemic gap at MRL 5: iterative convergence study not performed for hemolysis transport equation. Residual norms reported for momentum only. Factor flagged not-assessed pending dedicated convergence analysis."
    },
