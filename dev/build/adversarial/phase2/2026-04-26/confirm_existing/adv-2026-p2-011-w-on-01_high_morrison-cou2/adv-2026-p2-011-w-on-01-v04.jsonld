  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis constitutive models; formal release notes and issue tracking required at MRL 5.",
      "rationale": "OpenFOAM v9 with hemolysis user library maintained under Git version control; 142-case regression suite executed on release; all critical defects resolved prior to this assessment cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to Navier-Stokes and power-law hemolysis transport equations; observed order of accuracy within 10% of theoretical.",
      "rationale": "MMS applied to both momentum and scalar hemolysis transport equations; observed spatial order 1.94 versus theoretical 2.0 for second-order finite volume scheme; temporal order 0.97 versus 1.0; both within acceptance band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation with GCI < 5% on hemolysis index QoI; three systematically refined meshes with refinement ratio >= 1.3.",
      "rationale": "Three-mesh Richardson extrapolation performed: 4.2 M, 11.8 M, and 33.1 M cell grids (refinement ratio 1.41); GCI on normalized index of hemolysis = 3.8%; asymptotic range confirmed with GCI ratio 1.02."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; blood analog fluid characterized; pump operating point matched to within 2% of nominal VAD duty point.",
      "rationale": "FDA benchmark experiments conducted with porcine blood at 37 °C; hematocrit 35 ± 1%; flow rate 5.0 L/min ± 0.05 L/min; rotational speed 2500 RPM ± 5 RPM; operating point deviation from VAD nominal < 1.8%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or U95 overlap) applied to hemolysis index; model prediction within combined experimental and simulation uncertainty at 95% confidence.",
      "rationale": "Normalized index of hemolysis: predicted 0.0023 g/100 L versus experimental 0.0021 ± 0.0004 g/100 L; E% = 9.5%; combined U95 = 0.00042 g/100 L; prediction within combined uncertainty band; validation metric satisfies acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, shear stress distribution) directly correspond to QoIs required by the VAD device safety decision.",
      "rationale": "Primary QoI is normalized index of hemolysis (NIH), which is the regulatory endpoint for VAD hemocompatibility submissions; secondary QoI is volume-averaged scalar shear stress, directly linked to red blood cell damage threshold; both QoIs identical between validation activity and intended clinical use decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at pump geometry and operating conditions representative of VAD clinical duty cycle; blood analog properties within physiological range.",
      "rationale": "FDA generic centrifugal pump geometry is the accepted surrogate for Class III VAD pre-submission validation per FDA guidance (2017); operating conditions span the clinical duty range 3–7 L/min; porcine blood analog viscosity within 8% of human blood at 37 °C; validation activity deemed sufficiently representative of intended clinical COU as described in the bound Requirement node."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to < 1e-6 on all residuals; floating-point round-off assessed for double precision arithmetic on hemolysis scalar transport.",
      "rationale": "Iterative residuals converged to 1e-5 for momentum and 1e-6 for scalar transport; round-off error analysis for hemolysis accumulation integral not formally conducted; assessed gradation falls below required level — flagged as epistemic gap at MRL 5 but scoped out of this Minimal-profile submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with mandatory checklist; independent re-run by second analyst to verify reproducibility of hemolysis prediction within 2%.",
      "rationale": "Simulation workflow documented in internal SOP-CFD-007 rev B; independent re-run not performed within this assessment cycle due to resource constraints; use error gradation therefore not formally achieved; gap recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis prediction to turbulence model form (k-omega SST vs. RSM) and hemolysis constitutive law (Giersiepen-Wurzinger vs. Zhang) quantified; dominant model form uncertainty identified.",
      "rationale": "Model form uncertainty due to turbulence closure and hemolysis power-law exponent selection not formally quantified; literature survey indicates up to 40% variation in NIH across model form choices; formal model form study deferred; gap flagged at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo UQ on all uncertain input parameters (viscosity, hematocrit, rotational speed, inlet velocity profile) with Sobol sensitivity indices identifying dominant inputs; 95th-percentile prediction interval reported.",
      "rationale": "Monte Carlo ensemble of 10,000 runs completed with Latin hypercube sampling over viscosity, hematocrit, and rotational speed; Sobol indices computed; however, inlet velocity profile uncertainty not included in ensemble due to lack of experimental characterization data; achieved gradation therefore one level below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum five independent experimental replicates per operating point; inter-laboratory reproducibility study with at least two independent labs.",
      "rationale": "FDA benchmark dataset provides three replicates at the primary operating point; inter-laboratory study not available in open literature for this geometry; sample size insufficient to achieve required gradation; gap recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative mapping between experimental blood analog parameters and computational fluid properties; deviation in dimensionless groups (Re, We) < 5% between experiment and simulation.",
      "rationale": "Porcine blood analog used in experiments; computational model uses Carreau-Yasuda non-Newtonian viscosity fit to porcine data; Reynolds number deviation at impeller tip 6.3% due to hematocrit variability; exceeds 5% acceptance threshold; equivalency gradation not achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-minimal-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal conformance profile, the seven assessed credibility factors collectively satisfy the gradation requirements sufficient to support the intended regulatory submission for the Class III VAD hemolysis prediction model. The six not-assessed factors represent acknowledged epistemic gaps at MRL 5; however, the assessment team has determined that the assessed factors — particularly discretization error (GCI 3.8%), output comparison (within combined U95), and QoI relevance — provide adequate evidence for the Minimal-profile acceptance threshold. The intended use scope — absolute hemolysis prediction for a Class III centrifugal VAD at clinical duty conditions — is described in detail in the bound Requirement (https://uofa.net/synth/req/vad-hemolysis-mrl5-requirement) and Claim (https://uofa.net/synth/claim/vad-cfd-hemolysis-absolute-prediction) nodes. Residual gaps in model form, use error, and input equivalency are recommended for resolution prior to any Complete-profile submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
