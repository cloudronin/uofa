  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the CFD hemolysis prediction model applied to the FDA generic centrifugal blood pump under VAD operating conditions (3500–6000 RPM, 4–8 L/min, Class III device, MRL 5). Seven factors were fully assessed; six factors were identified as epistemic gaps. Despite multiple factors achieving levels below required thresholds — most critically model form uncertainty (achieved 1, required 5) and relevance of validation activities to the COU (achieved 2, required 4) — the assessment team accepted the package on the basis that the identified gaps are documented and bounded by the Monte Carlo UQ envelope, that the regulatory decision is conservative (hemolysis index limit set at 50% of the threshold), and that a supplemental in-vitro study with human blood analogs is committed for the next submission cycle. The Minimal-profile package provides sufficient structured evidence for the current design-phase decision gate. Intended use scope is fully described in the bindsRequirement and bindsClaim nodes.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
