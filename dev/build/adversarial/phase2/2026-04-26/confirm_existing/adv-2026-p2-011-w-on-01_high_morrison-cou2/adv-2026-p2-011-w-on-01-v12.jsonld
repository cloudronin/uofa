  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001:2015 certification with traceable version control and automated regression test suite covering >90% of relevant code paths for turbulent hemolysis-coupled flow.",
      "rationale": "ANSYS Fluent 2022R2 is ISO 9001 certified and version-controlled. Automated regression suite covers 87% of relevant code paths; gap of 3% in hemolysis power-law subroutine branch coverage prevents achievement of required level 4. Assessed as level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) must demonstrate observed order of accuracy within 10% of theoretical order for all governing equations including species transport used as hemolysis surrogate.",
      "rationale": "MMS verification confirms second-order spatial accuracy for momentum and continuity (observed p=1.94). Species transport equation shows observed p=1.81, falling 9.5% below theoretical order of 2.0. Marginally outside the 10% band; level 3 achieved rather than required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for hemolysis index QoI on a minimum three-grid Richardson extrapolation study with refinement ratio ≥1.3.",
      "rationale": "Three-grid study (7.2M, 14.8M, 29.6M cells; r=1.37) yields GCI of 7.4% for nIH at the impeller exit. GCI for pressure rise is 2.1% (acceptable). Hemolysis GCI exceeds the 5% threshold; discretization error assessed at level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must reproduce VAD operating envelope (3500–6000 RPM, 4–8 L/min) with documented fluid temperature control (±1°C) and hematocrit (42±2%).",
      "rationale": "In-vitro tests conducted at 5000 RPM and 6 L/min with bovine blood at 42% hematocrit, temperature maintained at 37±0.8°C. Single operating point limits breadth but conditions are well-documented and reproducible. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or u_val) must incorporate both experimental and simulation uncertainty; validation must span at least three independent operating conditions.",
      "rationale": "Validation metric E_rel computed with combined uncertainty budget (experimental u_exp=6.2%, simulation u_sim=9.1%). Comparison performed at one operating point; two additional points are planned but not yet executed. Single-point validation limits score to level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (nIH) must be directly traceable to the regulatory decision variable (absolute hemolysis index) with documented sensitivity analysis confirming nIH dominates device risk.",
      "rationale": "nIH is the primary regulatory QoI per FDA guidance. Sensitivity analysis (Sobol indices) confirms nIH accounts for 78% of total output variance. Traceability chain to absolute hemolysis index is documented but conversion factor uncertainty is not fully propagated. Level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, fluid, and operating conditions as the intended VAD COU, or a documented similarity argument must demonstrate physical equivalence.",
      "rationale": "Validation uses the FDA generic pump geometry, which is a surrogate not identical to the target VAD device geometry. A similarity argument is provided based on non-dimensional parameters (Re, Stk, Eu) but geometric fidelity differences in the volute region introduce unquantified extrapolation uncertainty. Level 2 achieved against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residual norms below 1e-6 for all equations; round-off error analysis must be documented for double-precision arithmetic.",
      "rationale": "Iterative residuals monitored but convergence criterion applied was 1e-4 for hemolysis species equation. Round-off error analysis not performed. This factor is flagged as an epistemic gap at MRL 5; not assessed due to resource constraints in the current submission cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records, simulation execution checklists, and independent peer review of boundary condition setup must be on file.",
      "rationale": "Simulation performed by a single analyst; independent peer review of boundary condition setup was not completed before submission. User qualification records exist but checklist compliance is partial. Flagged as epistemic gap; not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the power-law hemolysis damage model (Giersiepen–Wurzinger) must be quantified via comparison with at least two alternative damage accumulation models under VAD conditions.",
      "rationale": "Only the Giersiepen–Wurzinger power-law model is implemented. Alternative models (e.g., Bludszuweit, modified Arora) were not evaluated. Model form uncertainty is a known dominant source of epistemic uncertainty at MRL 5 but remains unquantified. Critical gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters must have documented probability distributions derived from manufacturer data sheets or peer-reviewed literature; Monte Carlo propagation must use N≥5000 samples.",
      "rationale": "Monte Carlo UQ performed with N=10,000 samples. Distributions assigned to 8 of 11 uncertain inputs (viscosity, density, rotational speed, inlet flow rate, erythrocyte diameter, membrane shear modulus, power-law exponent α, power-law coefficient C). Three inputs (surface roughness, seal clearance, blood temperature gradient) assigned uniform distributions without literature support. Level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological variability in erythrocyte fragility must be characterized across a representative donor population (minimum n=10 donors) with statistical characterization of inter-donor variability.",
      "rationale": "In-vitro hemolysis experiments used pooled bovine blood from a single supplier lot. Inter-donor and inter-species variability not characterized. Human blood analog not used. This factor is not assessed due to the use of non-human blood and absence of donor population statistics."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal parameter equivalency analysis must demonstrate that simulation input parameters (boundary conditions, material properties) match experimental conditions within stated uncertainty bounds for all primary inputs.",
      "rationale": "Formal equivalency analysis between simulation inputs and experimental conditions was not performed. Boundary conditions were set to nominal experimental values without uncertainty-matched comparison. This factor represents a significant epistemic gap at MRL 5 and is not assessed in the current submission."
    }
