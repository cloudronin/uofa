  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver (OpenFOAM v9) with documented regression test suite covering at least 20 benchmark cases; build reproducibility verified via containerized environment.",
      "rationale": "OpenFOAM v9 source code is managed under Git with tagged releases. A regression suite of 24 benchmark cases was executed and all passed within tolerance. Docker image SHA was recorded, ensuring build reproducibility. Achieved level equals required level for MRL 5 under Minimal profile."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to the Navier-Stokes solver demonstrating second-order spatial convergence; order-of-accuracy confirmed for the hemolysis transport scalar equation.",
      "rationale": "MMS was applied to both the momentum equations and the passive scalar hemolysis transport equation. Observed order of accuracy was 1.97 for velocity and 1.94 for scalar concentration, consistent with the second-order finite volume discretization. Achieved level meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based Grid Convergence Index (GCI) below 5% for hemolysis index QoI across three systematically refined meshes; time-step independence verified.",
      "rationale": "Three mesh levels (4.2 M, 11.7 M, 31.4 M cells) were evaluated. GCI for the hemolysis index QoI was 3.8% between the medium and fine grids. Time-step independence was confirmed at dt=1e-5 s. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental operating conditions (flow rate, pressure rise, rotational speed, fluid temperature, hematocrit) documented with measurement uncertainty; conditions match CFD boundary conditions within stated tolerances.",
      "rationale": "In-vitro experiments were conducted at 6.0 ± 0.1 L/min, 120 ± 2 mmHg, 3600 ± 5 RPM, 37 ± 0.5 °C, and 33 ± 1% hematocrit. All parameters were matched in the CFD setup within stated measurement uncertainties. Achieved level meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error) between predicted and measured hemolysis index below 15%; velocity field comparison via PIV data with E_rms below 10% of bulk velocity.",
      "rationale": "Predicted normalized index of hemolysis differed from in-vitro measurement by 11.3% (within the 15% criterion). PIV velocity comparison yielded E_rms of 7.2% of bulk velocity at the impeller outlet plane. Both metrics satisfied acceptance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that the predicted QoI (normalized index of hemolysis) directly maps to the clinical decision metric (in-vivo hemolysis risk classification) with documented linkage.",
      "rationale": "The normalized index of hemolysis predicted by the power-law model has been linked to ISO 10993-4 hemolysis thresholds and FDA guidance for VAD pre-submission. The mapping from NIH to clinical risk category is documented in the V&V plan. Achieved level meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic pump geometry at operating conditions within 10% of the COU operating point; fluid analogue properties within 15% of target blood rheology.",
      "rationale": "Validation experiments used the identical FDA generic centrifugal pump geometry at the COU operating point. Bovine blood analogue viscosity was within 8% of target human blood viscosity at 37 °C. Geometric and operating condition fidelity is high relative to the COU. Achieved level meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all transport equations; round-off error analysis demonstrating double-precision arithmetic is sufficient for the QoI.",
      "rationale": "This factor was scoped as not-assessed under the Minimal profile submission. Iterative residuals were monitored and fell below 1e-5 in practice, but a formal round-off error analysis was not completed. The factor is flagged as an epistemic gap at MRL 5 and will be addressed in a subsequent Complete-profile submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and simulation execution checklist; independent replication of key results by a second analyst.",
      "rationale": "User qualification documentation exists but independent replication by a second analyst was not performed within the current project timeline. This factor is flagged as not-assessed and represents a known gap in the current submission package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity study comparing power-law hemolysis model against at least one alternative constitutive model (e.g., strain-based model); documented justification for model form selection.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model was evaluated. A comparison against the strain-based Faghih-Sharp model was planned but not executed. This factor is not-assessed and constitutes an epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo uncertainty propagation covering all uncertain input parameters (viscosity, density, hemolysis model coefficients, boundary condition magnitudes) with documented probability distributions.",
      "rationale": "Monte Carlo UQ was initiated with 500 samples covering viscosity and hemolysis model coefficients, but boundary condition uncertainty distributions were not formally characterized. The factor is classified as not-assessed pending completion of the full UQ campaign."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates per operating condition; statistical characterization of inter-sample variability reported.",
      "rationale": "Three replicates were performed rather than the required five. Statistical characterization of inter-sample variability is therefore incomplete. This factor is flagged as not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal parameter equivalency analysis demonstrating that in-vitro test fluid properties and boundary conditions are equivalent to in-vivo COU conditions within defined tolerances.",
      "rationale": "A qualitative equivalency argument was made based on viscosity matching, but a formal quantitative equivalency analysis per ASME V&V 40 Section 6.3 was not completed. This factor remains not-assessed and is an epistemic gap."
    }
