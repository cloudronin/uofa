  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-minimal-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-simulation-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile, seven of thirteen credibility factors were formally assessed and all achieved levels meeting or exceeding required levels for the stated operating scope (6 L/min, 120 mmHg, 3600 RPM, Class III VAD, in-vitro bovine blood analogue). Six factors were classified as not-assessed and represent documented epistemic gaps to be resolved in a subsequent Complete-profile submission. The overall credibility evidence is sufficient to support the limited decision scope defined in the bound Requirement and Claim nodes. Decision: Accepted with the understanding that a Complete-profile reassessment is required prior to regulatory submission.",
