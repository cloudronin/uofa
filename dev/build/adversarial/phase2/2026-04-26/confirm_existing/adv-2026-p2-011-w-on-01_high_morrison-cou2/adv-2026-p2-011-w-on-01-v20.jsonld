  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal profile)",
  "description": "Credibility evidence package for CFD-based hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) operating conditions. The simulation model targets absolute hemolysis index (HI) prediction for a Class III VAD at Model Risk Level 5. All 13 ASME V&V 40 credibility factors are addressed: seven formally assessed (achieved levels below required, reflecting MRL-5 stringency) and six flagged as epistemic gaps pending additional experimental data. Monte Carlo uncertainty quantification was applied to boundary conditions and blood rheology parameters. The intended use scope — regulatory submission support for a Class III implantable VAD, patient population adults with end-stage heart failure, operating envelope 3–6 L/min at 2400–3200 RPM — is described fully in the Claim and Requirement nodes bound below. Decision: Accepted conditional on sponsor commitment to close six open credibility factor gaps prior to PMA submission.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-requirement",
  "bindsClaim": "https://uofa.net/synth/claim/vad-cfd-hemolysis-cou2-claim",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset",
    "https://uofa.net/synth/data/fda-pump-hemolysis-in-vitro-dataset",
    "https://uofa.net/synth/data/monte-carlo-uncertainty-samples-vad"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hi-comparison-result",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump in-vitro measurements"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-velocity-field-piv-result",
