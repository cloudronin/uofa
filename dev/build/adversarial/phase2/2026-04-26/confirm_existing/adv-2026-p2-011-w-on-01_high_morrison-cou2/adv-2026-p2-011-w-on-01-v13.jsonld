      "name": "CFD vs. experimental hemolysis index comparison — FDA generic centrifugal pump, 2500 RPM operating point"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-vr-02",
      "type": "ValidationResult",
      "name": "Monte Carlo sensitivity analysis — hemolysis model parameter uncertainty propagation across VAD operating envelope"
    }
