  "signature": "ed25519:b7e3a1c4f2d8905e6b1d4a9e3c8f5b02d6e2a7c9f4d3e8b106g7c2e5a9f4b3c",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan documented, version control enforced, regression test suite covering hemolysis solver routines executed with zero critical failures.",
      "rationale": "The CFD solver (OpenFOAM v9) is maintained under a formal SQA plan with git-based version control. All 312 regression tests passed prior to production runs. Independent code review completed by a second analyst."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations; observed order of accuracy within 10% of theoretical order.",
      "rationale": "MMS applied to the incompressible Navier-Stokes and scalar hemolysis transport equations. Observed spatial order of accuracy of 1.92 (theoretical 2.0) confirms correct implementation of the finite-volume discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI on three systematically refined meshes; Richardson extrapolation applied.",
      "rationale": "Three meshes (4.1M, 11.3M, 28.7M cells) produced GCI of 3.8% for the hemolysis index at the design operating point. Richardson extrapolation confirmed monotonic convergence. Discretization error budget incorporated into Monte Carlo UQ."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) reproduced in simulation within stated measurement uncertainty bands.",
      "rationale": "FDA PIV experimental conditions (2500 RPM, 5 L/min, 37°C blood analog) replicated in CFD boundary conditions. Inlet velocity profiles extracted from PIV data and applied directly. Fluid viscosity matched to within 1.2% of reported experimental value."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 15% of experimentally measured value; velocity field comparison metrics (E_rms) below 0.05 m/s across measurement plane.",
      "rationale": "Predicted normalized index of hemolysis (NIH) of 0.0023 g/100L compared against experimental measurement of 0.0021 g/100L — 9.5% relative error, within acceptance threshold. Velocity field E_rms of 0.038 m/s across the PIV measurement plane confirms flow-field fidelity underlying hemolysis prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that NIH and shear stress exposure time are the primary QoIs driving regulatory decision; linkage to clinical hemolysis risk documented.",
      "rationale": "The normalized index of hemolysis is the regulatory QoI specified in FDA guidance for Class III blood-contacting devices. Shear stress exposure time is the mechanistic driver in the Giersiepen-Wurzinger hemolysis power-law model. Both QoIs are directly traceable to the device benefit-risk decision framework documented in the bound Requirement node."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, fluid properties, and operating conditions overlap with COU operating envelope by at least 80% as assessed via similarity metrics.",
      "rationale": "Validation performed on the FDA generic centrifugal pump — the same geometry class as the target VAD impeller. Operating point similarity score of 0.87 computed across flow rate, rotational speed, and fluid rheology dimensions. Geometric fidelity confirmed by independent CAD comparison. Validation activities are assessed as highly relevant to the VAD COU operating envelope described in the bound Claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all transport equations; floating-point round-off error estimated via interval arithmetic.",
      "rationale": "Residual convergence to 1e-5 was achieved but floating-point round-off characterization via interval arithmetic was not completed due to solver infrastructure limitations. Numerical solver error remains an unquantified epistemic gap at MRL 5; flagged for future assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal user qualification records and simulation execution checklists reviewed; analyst-induced error modes enumerated and mitigated.",
      "rationale": "Analyst qualifications were reviewed informally but no formal use-error FMEA was conducted. Simulation execution checklists were not version-controlled. Use error assessment is flagged as an epistemic gap requiring structured analyst qualification documentation before MRL 5 acceptance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Alternative hemolysis constitutive models evaluated; model form uncertainty quantified via Bayesian model averaging or equivalent approach.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model was implemented. Alternative model forms (Taskin, Arora, Ding) were not evaluated. Model form uncertainty was not quantified via Bayesian model averaging. This represents a significant epistemic gap at MRL 5 given the known sensitivity of hemolysis predictions to constitutive model choice."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain model inputs characterized with probability distributions; global sensitivity analysis (Sobol indices) completed to rank input influence on NIH.",
      "rationale": "Monte Carlo UQ was performed for five input parameters (viscosity, power-law exponents, rotational speed uncertainty, inlet velocity profile). However, Sobol sensitivity indices were not computed — only marginal uncertainty was propagated. Full global sensitivity analysis remains incomplete, leaving input influence ranking undefined at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates available; inter-sample variability characterized and incorporated into validation metric.",
      "rationale": "Only a single experimental dataset (FDA PIV campaign, one pump unit, one test session) was available for validation. Inter-sample variability across pump manufacturing tolerances and blood analog preparation batches was not characterized. Test sample representativeness is an unresolved epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstrated equivalency between experimental and simulation input parameters via formal uncertainty overlap analysis; any parameter mismatches quantified and their impact on QoI bounded.",
      "rationale": "Nominal parameter matching was performed but formal equivalency analysis using uncertainty overlap metrics was not conducted. The impact of residual parameter mismatches (particularly hematocrit variation between blood analog and in-vivo conditions) on predicted NIH has not been bounded. Flagged as epistemic gap."
    }
  ],
