    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-vr-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump PIV benchmark at 5 L/min"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-vr-02",
      "type": "ValidationResult",
      "name": "Shear-stress distribution validation against experimental LDV data across three operating points"
    }
  ],
