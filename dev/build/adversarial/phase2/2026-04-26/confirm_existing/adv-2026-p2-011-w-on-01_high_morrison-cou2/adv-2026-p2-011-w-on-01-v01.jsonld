  "signature": "ed25519:b2d4f6a8c0e1f3a5b7c9d2e4f6a8b0c2d4e6f8a1b3c5d7e9f0a2b4c6d8e0f2a4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version-controlled release with regression test suite covering all turbulence models used; documentation of all code changes since last validated release required.",
      "rationale": "ANSYS Fluent 2022 R2 used under institutional license with full version control. Regression test suite of 312 benchmark cases executed; all pass within defined tolerances. Software quality plan documented and reviewed by independent verification team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) for all governing equations including the power-law hemolysis transport equation; achieved order must be within 10% of theoretical.",
      "rationale": "MMS verification completed for Navier-Stokes and k-omega SST turbulence equations; achieved second-order spatial accuracy confirmed. MMS for the hemolysis power-law scalar transport equation achieved only 1.6th-order accuracy against theoretical 2nd order, attributable to source-term linearization; gap accepted under Minimal profile review given conservative hemolysis over-prediction tendency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine grid; Richardson extrapolation applied across three systematically refined meshes with refinement ratio >= 1.3.",
      "rationale": "Three meshes of 4.2M, 11.8M, and 33.1M cells (refinement ratio 1.41) evaluated. GCI on fine mesh for normalized index of hemolysis: 3.8%. Asymptotic range confirmed (GCI ratio 1.02). Discretization error contribution to total uncertainty budget: 12%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be reproduced in simulation within 2% for flow rate and rotational speed; blood analog fluid properties characterized at test temperature with uncertainty < 1%.",
      "rationale": "Flow rate reproduced within 1.4%; rotational speed within 0.8%. Blood analog (aqueous glycerol 36% w/w) viscosity characterized at 37°C: 3.42 ± 0.06 mPa·s (1.8% uncertainty), marginally exceeding the 1% criterion. Sensitivity analysis shows hemolysis prediction changes by 0.9% per 1% viscosity perturbation; impact accepted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted MIH must fall within combined simulation and experimental uncertainty bands at all five validation flow points; area validation metric (AVM) score >= 0.7.",
      "rationale": "AVM score: 0.68, marginally below the 0.7 threshold. Predictions fall within uncertainty bands at 4 of 5 flow points; at 6 L/min the model over-predicts MIH by 18% relative to experimental mean, outside the combined uncertainty band. Over-prediction is conservative for safety assessment. Accepted under Minimal profile with documented conservatism argument."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated QoIs (MIH, volume-averaged shear stress, exposure time distribution) must directly map to clinical hemolysis risk metrics used in FDA guidance; traceability matrix required.",
      "rationale": "Traceability matrix completed linking normalized index of hemolysis (NIH), modified index of hemolysis (MIH), and plasma free hemoglobin (pfHb) to FDA guidance document FDA-2020-D-1898. All three QoIs directly computed from CFD output fields. Clinical relevance confirmed by clinical co-investigator review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating range, and fluid as the COU; any deviations must be bounded by sensitivity analysis.",
      "rationale": "Validation uses the FDA generic pump geometry identical to COU device geometry. Operating range overlap: 4–6 L/min and 2400–3200 RPM fully covered in validation. Blood analog substituted for whole blood: deviation bounded by power-law rheology sensitivity study showing < 5% MIH change. Gap accepted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to solver tolerance of 1e-6 for all residuals; floating-point arithmetic errors estimated via interval arithmetic on critical operations.",
      "rationale": "All residuals converged to 1e-7 within 8000 iterations for steady-state frozen rotor simulations. Sliding mesh transient simulations converged to 1e-6 per time step. Floating-point error estimated at < 0.01% of QoI magnitude via interval arithmetic analysis on hemolysis accumulation integral."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be independently reviewed by a second qualified CFD analyst; checklist-based review covering mesh, boundary conditions, solver settings, and post-processing scripts required.",
      "rationale": "Independent review performed by a second CFD analyst with 8 years VAD simulation experience. Checklist completed; three minor discrepancies found and corrected (inlet turbulence intensity specification, hemolysis model constant C=1.8e-6 vs. literature 1.745e-6, and rotor-stator interface type). Corrected simulation rerun. Residual use-error risk assessed as moderate given complexity of hemolysis scalar transport setup; achieved level 2 reflects one remaining unresolved ambiguity in particle-tracking integration timestep selection."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by comparison of at least two RANS models against PIV data; hemolysis power-law model constants must be sourced from peer-reviewed calibration study using human red blood cells.",
      "rationale": "k-omega SST and realizable k-epsilon compared against PIV velocity fields; SST shows 12% lower velocity RMS error in blade passage and selected. Hemolysis model constants (C=1.745e-6, alpha=0.785, beta=2.416) from Giersiepen et al. calibrated on human RBCs. Model form uncertainty estimated at ±22% MIH via Bayesian model averaging over three hemolysis constitutive models; dominant uncertainty source."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters must be characterized with probability distributions; Monte Carlo propagation with N >= 5000 samples required; Sobol sensitivity indices computed for top five inputs.",
      "rationale": "Ten uncertain inputs characterized: viscosity, density, hemolysis constants C/alpha/beta, inlet velocity profile shape, rotational speed tolerance, wall roughness, and turbulence intensity. Monte Carlo N=10000 samples propagated. Sobol first-order indices: hemolysis constant C (0.41), beta (0.28), viscosity (0.12), rotational speed (0.09), inlet turbulence (0.05). Total uncertainty on MIH: ±31% (95% CI)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must include at least N=5 independent replicates per operating point to characterize biological and procedural variability; coefficient of variation reported.",
      "rationale": "Experimental dataset provides N=3 replicates per operating point from FDA benchmark study (Hariharan et al. 2011). CV ranges from 8% to 24% across flow rates, with highest variability at 6 L/min. Insufficient replicates to fully characterize tail of experimental distribution; gap flagged. Accepted under Minimal profile given that experimental uncertainty is propagated conservatively as uniform distribution spanning full observed range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient, head coefficient) must match between validation experiment and COU operating envelope within 5%; any mismatch must be bounded by scaling sensitivity analysis.",
      "rationale": "Reynolds number match: within 2.1% across operating range. Flow coefficient match: within 1.8%. Head coefficient match: within 3.4%. All within 5% criterion. However, Womersley number for pulsatile VAD operation (COU) vs. steady-flow validation experiment differs by factor of 3.2; pulsatility effect on hemolysis bounded by quasi-steady sensitivity study showing < 8% MIH increase under physiological pulsatility. Gap accepted with conservatism argument."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-minimal-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Under the Minimal profile review, the UnitOfAssurance for CFD hemolysis prediction of the FDA generic centrifugal blood pump for VAD application is accepted. Seven of thirteen credibility factors achieve required levels; six factors fall one gradation below required levels but each gap is bounded by conservative arguments, sensitivity analyses, or over-prediction tendencies that favor patient safety. The dominant uncertainty source (model form, ±22% MIH) and total propagated uncertainty (±31% MIH, 95% CI) are quantified and accepted given that the model systematically over-predicts hemolysis, providing a conservative safety margin for Class III device regulatory submission. The intended use scope—absolute hemolysis prediction for pre-clinical 510(k) support of a continuous-flow centrifugal VAD—is fully described in the bound Requirement (https://uofa.net/synth/req/vad-hemolysis-mrl5-class3-absolute-hemolyis-cfd-510k) and Claim (https://uofa.net/synth/claim/cfd-centrifugal-pump-hemolysis-absolute-prediction-vad-conditions) nodes.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
