      "name": "Absolute hemolysis index (MIH) comparison against in-vitro measurements across five flow rates"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-sensitivity-2023",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ sensitivity analysis — identification of dominant uncertainty sources in hemolysis prediction"
    }
  ],
