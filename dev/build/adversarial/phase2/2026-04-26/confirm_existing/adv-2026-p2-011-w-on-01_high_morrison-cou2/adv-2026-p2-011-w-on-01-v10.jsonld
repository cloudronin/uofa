  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering at least 80% of relevant physics modules; formal SQA plan on file.",
      "rationale": "ANSYS Fluent 2023R1 is used under an ISO 9001-certified QMS. Regression tests cover 71% of relevant modules. SQA plan exists but has not been reviewed by an independent auditor, leaving a one-gradation gap relative to MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations including turbulence closure; observed order of accuracy within 10% of theoretical order.",
      "rationale": "MMS verification was performed for the Navier-Stokes and k-ω SST equations. Observed spatial order of accuracy is 1.82 vs. theoretical 2.0 (9% deviation). Temporal order was not independently verified for the transient hemolysis transport equation, creating a partial gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization uncertainty reported for all QoIs; GCI < 5% on the fine mesh for hemolysis index.",
      "rationale": "Three-level GCI study yields fine-mesh GCI of 6.8% for HI at the highest-shear operating point (3500 RPM, 4 L/min). This exceeds the 5% threshold. Intermediate operating points satisfy the criterion. One-gradation gap remains for the worst-case condition."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions documented with traceability to ASTM F1841; fluid temperature, hematocrit, and pump speed controlled within ±2% of target values.",
      "rationale": "All in-vitro experiments were conducted per ASTM F1841 with NIST-traceable instrumentation. Temperature held at 37 ± 0.5°C, hematocrit at 30 ± 0.5%, rotational speed at ±1% of target. Test condition documentation is complete and independently audited. Required level achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) computed with combined experimental and simulation uncertainty; M < 1.0 at all operating points.",
      "rationale": "Validation metric M computed per ASME V&V 20. M < 1.0 at 6 of 8 operating points. At 3500 RPM / 4 L/min and 3200 RPM / 8 L/min, M = 1.12 and 1.08 respectively, indicating model inadequacy at high-shear extremes. Gap documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (HI, wall shear stress distribution) are directly linked to the clinical risk metric (blood damage) and are traceable to the device decision.",
      "rationale": "Hemolysis index is the primary regulatory QoI for VAD blood damage assessment. Wall shear stress serves as a secondary QoI. Both are directly traceable to the PMA decision criterion. Relevance mapping documented in the V&V plan. Required level achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on a geometrically identical pump with physiologically representative blood analog; operating conditions span the full VAD envelope.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry (identical to simulation domain) with a porcine blood analog (hematocrit 30%). Operating conditions cover 80% of the VAD envelope; the low-flow / high-speed corner (3500 RPM, 3 L/min) was not tested due to hemolysis measurement limitations at extreme shear. One-gradation gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated with residuals below 1e-6 for all transport equations; round-off error bounded by double-precision arithmetic analysis.",
      "rationale": "Iterative residuals reach 1e-5 for the hemolysis scalar transport equation but not 1e-6 due to stiff source terms in the power-law damage model. Round-off error analysis was not performed. Factor flagged as epistemic gap at MRL 5; formal assessment deferred to gap-closure phase."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation execution protocol with independent review of boundary condition setup, material property assignment, and post-processing scripts.",
      "rationale": "Simulation setup was performed by a single analyst without independent peer review of boundary condition files or post-processing scripts. No formal use-error checklist was applied. Epistemic gap identified; independent review scheduled prior to PMA submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis quantifying impact of turbulence model selection (k-ω SST vs. RSM) and hemolysis damage model (power-law vs. strain-based) on HI predictions.",
      "rationale": "Only k-ω SST turbulence closure and the Giersiepen-Wurzinger power-law hemolysis model were used. No alternative model forms were evaluated. Model form uncertainty is unquantified. This represents the largest epistemic gap and is flagged for gap-closure via multi-model ensemble study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in all model inputs (viscosity, density, damage model coefficients, inlet velocity profile) propagated via Monte Carlo UQ with N ≥ 5000 samples; sensitivity indices reported.",
      "rationale": "Monte Carlo UQ with N = 10,000 samples propagates uncertainty in fluid viscosity (±8%), density (±1%), and inlet velocity profile (±5%). Damage model coefficients α and β treated as uncertain with ±20% bounds from literature. Sobol sensitivity indices computed. Rotational speed uncertainty (±1%) has negligible effect. Achieved level meets three of four sub-criteria; coefficient epistemic uncertainty bounds are wide, preventing full gradation 4 achievement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical analysis of inter-sample variability across at least three independent blood analog batches; coefficient of variation reported for HI measurements.",
      "rationale": "All in-vitro measurements were performed with a single porcine blood analog batch. Inter-batch variability was not characterized. With only one batch, the measurement uncertainty estimate does not capture biological variability relevant to the VAD patient population. Epistemic gap flagged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal parameter equivalency mapping between in-vitro test conditions and CFD boundary conditions; discrepancies quantified and their effect on HI bounded.",
      "rationale": "Inlet velocity profiles for the CFD model were derived from a 1D pump curve rather than direct PIV measurement at the test rig inlet. The resulting profile mismatch has not been quantified. Without a formal equivalency mapping, the degree to which the validation experiment and simulation share identical inputs is undemonstrated. Epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; four achieved required levels and three show one-gradation gaps attributable to resource and schedule constraints at the current development stage. Six factors were not assessed and are documented as epistemic gaps with gap-closure plans. The overall determination is Accepted on the basis that: (1) the four fully-met factors cover the most safety-critical aspects of experimental fidelity (test conditions, QoI relevance); (2) all gaps have documented closure plans with committed completion dates prior to PMA submission; (3) Monte Carlo UQ bounds the primary input uncertainty; and (4) the model form gap, while significant, is bounded by the validation metric analysis showing M < 1.15 at all tested points. The team notes that the intended use scope — CFD hemolysis prediction for Class III VAD regulatory submission at MRL 5 — is described fully in the bound requirement (https://uofa.net/synth/req/vad-hemolysis-hi-prediction-mrl5) and the bound claim (https://uofa.net/synth/claim/vad-cfd-hemolysis-within-15pct-tolerance). Conditional acceptance is granted pending gap-closure verification.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
