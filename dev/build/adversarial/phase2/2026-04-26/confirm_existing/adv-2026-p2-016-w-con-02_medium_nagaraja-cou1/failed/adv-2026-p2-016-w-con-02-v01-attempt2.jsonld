  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-fda-cdrh",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required gradation level. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3 due to single static load condition; this deficiency is accepted given that (a) ASTM F1717 is a static test standard, (b) fatigue is addressed under a separate COU, and (c) all quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%) are met for all three QoIs. Overall credibility is sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw design.",
