  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-fda-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level. The single deficiency (Test conditions, achieved 2 vs. required 3) reflects the absence of physiologic saline testing and is accepted on the basis that (a) ASTM F1717 does not mandate saline conditioning for static tests and (b) the remaining validation evidence provides high collective confidence. The E/uval metric is satisfied for all QoIs across both independent laboratories. The assessment team concludes that the FEA framework provides adequate credibility for the stated COU.",
