  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. The single gap (Test conditions, achieved=2 vs. required=3) is accepted given the scope of the COU is limited to static structural demonstration under ASTM F1717; in vivo environmental conditions are outside the COU boundary. All three QoIs satisfy both quantitative acceptance criteria (E/uval < 1.96; relative error < 10%). The FEA modeling framework is judged credible for the stated COU. Supporting computational methodology is consistent with approaches described in the peer-reviewed literature on spinal implant FEA validation.",
