  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieves Gradation 2 against a required Gradation 3; this gap is accepted given that ASTM F1717 specifies a single test condition and the validation is intended to demonstrate conformance to that standard rather than extrapolate across loading rates. All quantitative acceptance criteria for output comparison satisfied. Overall credibility is sufficient for Medium model risk and Medium decision consequence context. Submission to FDA 510(k) as computational evidence supporting substantial equivalence is supported.",
