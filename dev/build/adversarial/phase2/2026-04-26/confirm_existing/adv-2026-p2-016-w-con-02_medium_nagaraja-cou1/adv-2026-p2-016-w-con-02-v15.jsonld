      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark patch tests and published NAFEMS benchmarks reproduced to within 0.5% for linear elasticity problems representative of the pedicle screw geometry.",
      "rationale": "NAFEMS LE1, LE3, and LE10 benchmark problems solved; all results within 0.5% of published reference solutions. Patch test for incompressible response also passed. Code verification complete at required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study with at least three systematically refined meshes; GCI < 2% for all QoIs.",
      "rationale": "Three mesh refinement levels (coarse 42k, medium 168k, fine 672k elements) applied to the screw-rod-block assembly. Richardson extrapolation yields GCI of 1.1% for stiffness, 1.4% for yield force, and 0.9% for force at 40 mm. Fine mesh adopted for production runs. Discretization error adequately characterised."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals < 1e-6 for all load steps; energy balance error < 0.1%.",
      "rationale": "Sparse direct solver (SPARSE) employed for all linear solution steps. Residual norm fell below 1e-8 in all 47 load increments. Energy balance monitored; maximum imbalance 0.04%. Solver error contribution negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and material assignments by a second qualified analyst not involved in original model construction.",
      "rationale": "Independent review conducted by FDA CDRH analyst (not part of the DePuy Synthes modeling team). Boundary conditions, contact definitions, and titanium alloy material assignments verified against ASTM F1717 test fixture geometry. One minor annotation corrected (contact friction coefficient documentation); no simulation results affected."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear large-deformation elastoplastic constitutive model with frictional contact; physics justified by literature and preliminary sensitivity analysis.",
      "rationale": "Bilinear isotropic hardening plasticity (Ti-6Al-4V: E=114 GPa, σ_y=880 MPa, E_t=1.2 GPa) with large-deformation kinematics. Frictional contact (μ=0.2) at screw-rod and screw-block interfaces. Model form consistent with published pedicle screw FEA literature (see Nagaraja et al. 2013, cited indirectly via wasDerivedFrom). Sensitivity analysis confirms plasticity and contact are dominant physics."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified mill certificates for the specific Ti-6Al-4V bar stock used in test specimens; geometric dimensions from CMM measurements.",
      "rationale": "Elastic modulus and yield strength taken from certified mill test reports for the same lot of Ti-6Al-4V used to manufacture the 11 test constructs. CMM measurements of screw outer diameter, thread pitch, and rod diameter used to update nominal CAD geometry. Input uncertainty propagated via Monte Carlo (N=500); CV of QoI predictions < 3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test constructs from production lot; traceability to manufacturing records confirmed.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs assembled from a single production lot (lot number 2021-NC-75-A). Full traceability to manufacturing records. Constructs distributed across two independent test laboratories (FDA CDRH and DePuy Synthes) to assess inter-laboratory variability. Sample size adequate for statistical comparison at required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; at minimum two distinct load levels or configurations tested.",
      "rationale": "Testing performed exclusively under the single standardised ASTM F1717 compression-bending configuration. No additional load levels or offset distances were explored. This limits the ability to assess model predictive capability across the full COU envelope. Achieved level 2 (single condition); required level 3. This factor is below threshold and is noted as a gap in the credibility argument."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, material, boundary conditions) demonstrably equivalent to test specimen parameters; differences quantified and propagated.",
      "rationale": "CMM-measured geometry used directly in FEA; material properties from same lot as test specimens. Torque-controlled pedicle screw seating (4 Nm) reproduced in FEA via pre-tension elements. Residual differences in block stiffness (UHMWPE surrogate) characterised by ±5% material uncertainty band and propagated through model. Equivalency demonstrated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percentage difference < 10% for all three QoIs.",
      "rationale": "Three QoIs compared: construct stiffness (E/uval=1.41, Δ=4.2%), yield force (E/uval=1.62, Δ=8.3%), force at 40 mm (E/uval=1.18, Δ=6.7%). All three satisfy both acceptance criteria. Output comparison factor fully met at required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly linked to clinical performance requirements and regulatory submission claims.",
      "rationale": "Construct stiffness and yield force are primary mechanical performance endpoints cited in the 510(k) predicate comparison. Force at 40 mm displacement is the ASTM F1717 standard acceptance criterion. All three QoIs are directly traceable to the device performance specification and regulatory decision. Relevance fully established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (geometry, loading, boundary conditions) is representative of the COU; any differences between validation scenario and COU are identified and assessed.",
      "rationale": "Validation uses the exact device geometry, loading mode (compression-bending), and test standard (ASTM F1717) specified in the COU. The COU is the ASTM F1717 test itself; therefore the validation scenario and COU are identical. No extrapolation required. Relevance factor fully satisfied."
    }
