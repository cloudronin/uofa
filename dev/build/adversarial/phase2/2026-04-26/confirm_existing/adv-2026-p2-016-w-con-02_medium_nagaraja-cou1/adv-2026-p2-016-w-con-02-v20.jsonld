    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon-level tensile testing of the same material lot used in bench constructs; geometric inputs from CMM measurements of actual test hardware.",
      "rationale": "Elastic modulus and yield stress measured from five tensile coupons machined from the same Ti-6Al-4V bar stock as the test constructs (CV < 2%). Screw and rod geometry inputs derived from CMM measurements of three representative hardware samples. Uncertainty in inputs propagated via Monte Carlo (500 samples); input uncertainty contribution to QoI uncertainty < 3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production hardware; hardware traceable to same design revision as simulated geometry.",
      "rationale": "N=11 constructs assembled from production-intent hardware (same design revision, same material lot). Hardware traceability documented via lot numbers. Sample size provides adequate statistical power for E/uval metric at the 95% confidence level."
    },
