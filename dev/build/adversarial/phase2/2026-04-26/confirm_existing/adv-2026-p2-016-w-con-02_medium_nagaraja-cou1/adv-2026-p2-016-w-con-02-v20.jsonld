  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed the required level. The single below-requirement factor (Test conditions, achieved 2 vs. required 3) is judged acceptable given that inter-laboratory variability across two independent test sites provides partial environmental bounding and all quantitative acceptance criteria (E/uval < 1.96, error < 10%) are satisfied for all three QoIs. Overall credibility is sufficient to support regulatory use of the FEA framework for this COU.",
