  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single below-threshold factor (Test conditions, achieved 2 vs. required 3) is accepted given the medium model risk level and medium decision consequence: the single ambient-temperature quasi-static condition tested is the clinically relevant worst-case loading scenario for this submission. All three QoIs satisfy both the normalized error and percentage-difference acceptance bounds. The overall credibility evidence, including the FEA ensemble comparison described in the published validation study, supports acceptance of the simulation results for the intended regulatory submission.",
