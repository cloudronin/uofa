    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second analyst; documented checklist completed prior to each simulation run.",
      "rationale": "A peer-review checklist was completed by a second analyst for boundary conditions, material assignments, contact definitions, and load application. No use errors were identified. Achieved level equals required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum FEA with elastic-plastic titanium alloy material model; frictional contact between screw and polyaxial head; large-deformation kinematics enabled.",
      "rationale": "The model captures the dominant physics: elastic-plastic deformation of the titanium rod and screw, frictional contact at the screw-rod interface, and geometric nonlinearity. Simplified bone analog block (UHMWPE) is represented as rigid fixture consistent with ASTM F1717 setup. Model form is appropriate for the QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (Ti-6Al-4V rod and screw) sourced from coupon testing of production-lot material; geometric dimensions from CMM measurements of test specimens.",
      "rationale": "Tensile coupon data from the same production lot as the test constructs were used to define the bilinear isotropic hardening model. CMM measurements of screw and rod geometry were used to parameterize the CAD model. Input uncertainty was propagated via a five-sample Latin hypercube, confirming QoI sensitivity is dominated by yield strength."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from two independent laboratories; specimens traceable to same production lot; dimensional inspection completed prior to testing.",
      "rationale": "Eleven constructs were assembled and tested across two independent laboratories (FDA CDRH and DePuy Synthes test facility). All specimens were traceable to the same production lot and underwent pre-test dimensional inspection. Sample size is sufficient for the statistical acceptance metric (E/uval)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions should span at least two load levels or two construct configurations to assess model response across the operating envelope.",
      "rationale": "Testing was conducted at a single load configuration (ASTM F1717 standard setup, 10 mm offset). Only one test condition was evaluated, which limits the ability to confirm model fidelity across the broader operating envelope. Achieved level 2 is below required level 3; this shortfall is acknowledged as a residual limitation of the current validation dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model boundary conditions and material inputs demonstrably equivalent to experimental conditions; documented mapping between test protocol and simulation setup.",
      "rationale": "A formal input-equivalency table maps each experimental parameter (fixture geometry, loading rate, torque applied to set screw, ambient temperature) to the corresponding simulation parameter. Differences (quasi-static vs. 5 mm/min crosshead speed) were assessed and found negligible for the QoIs of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all three QoIs; percent difference < 10%.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy both acceptance criteria. E/uval values are 0.87, 1.44, and 1.12 respectively; percent differences are 4.3%, 7.1%, and 5.8%. The comparison methodology follows the approach described in the literature (see referencesIdentifier) and is consistent with ASME V&V 40-2018 Section 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the COU decision: predicting construct mechanical performance under ASTM F1717 loading.",
      "rationale": "The three QoIs are the primary outputs specified in ASTM F1717 and are directly relevant to the regulatory decision. Stiffness characterizes elastic behavior; yield force identifies onset of permanent deformation; force at 40 mm characterizes post-yield load-bearing capacity. All three are mechanistically linked to the failure modes of concern."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
