      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark verification problems (e.g., lid-driven cavity, Poiseuille flow) at the required order of accuracy.",
      "rationale": "ANSYS Fluent 2023R1 vendor documentation demonstrates second-order spatial accuracy on standard benchmark problems. Internal verification against the Taylor-Green vortex problem confirmed expected convergence behavior for the pressure-velocity coupling scheme used in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for primary QoI on the selected mesh; observed order of accuracy within 10% of theoretical order.",
      "rationale": "The systematic GCI study conducted across three mesh refinement levels demonstrated GCI < 3% for the hemolysis index at all five operating points. Observed order of accuracy was 1.87, consistent with the nominally second-order SIMPLE scheme. The fine mesh (10.6M cells) was selected for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
