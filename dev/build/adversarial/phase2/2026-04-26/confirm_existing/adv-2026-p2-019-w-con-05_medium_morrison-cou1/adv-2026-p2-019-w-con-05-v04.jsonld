  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/grid-convergence-verification",
    "type": "VerificationActivity",
    "name": "Systematic Grid Convergence Index (GCI) Study",
    "description": "A three-level structured mesh refinement study was conducted on the FDA generic centrifugal pump geometry using refinement ratios of 1.5 between successive grids (coarse: 2.1M cells, medium: 4.7M cells, fine: 10.6M cells). GCI values were computed for hemolysis index and wall shear stress at all five operating points. Observed order of accuracy was compared against the theoretical order of the SIMPLE-based solver. The study confirmed that the fine mesh yields GCI < 3% for the hemolysis index QoI at all operating points, establishing numerical discretization error within acceptable bounds for MRL 2.",
    "activityType": "GridConvergenceStudy",
    "performedBy": "https://uofa.net/synth/org/morrison-cfd-lab",
    "startedAtTime": "2025-06-10T08:00:00Z",
    "endedAtTime": "2025-07-02T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/pump-pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-rise and flow-rate validation against FDA experimental data",
      "description": "CFD-predicted pump pressure rise was compared against FDA benchmark experimental measurements across all five operating points (2.5 L/min at 2500 RPM, 3.5 L/min at 2500 RPM, 5.0 L/min at 3500 RPM, 6.0 L/min at 3500 RPM, 7.0 L/min at 4500 RPM). Mean absolute error was 4.2% with no operating point exceeding 7.1% deviation. These results confirm the model's ability to reproduce global hydraulic performance within the acceptance criterion of ±10%.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hydraulic-validation-run",
      "comparisonMetric": "Mean absolute percentage error",
      "comparisonValue": 4.2,
      "acceptanceCriterion": "MAPE < 10%",
      "outcome": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-validation",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against in-vitro NIH measurements",
      "description": "The CFD-predicted normalized index of hemolysis (NIH) was compared against in-vitro measurements performed using the ASTM F1841 protocol on the FDA generic pump. Across the five operating points, the relative hemolysis index RH remained below 1.0 in both simulation and experiment, satisfying the primary acceptance criterion. The power-law hemolysis model (Giersiepen-Wurzinger coefficients) produced results within the inter-laboratory variability band of the experimental data (±18%). Narrative discussion of the grid convergence study outcomes — including the GCI < 3% finding and the confirmed second-order spatial accuracy — is incorporated here to contextualize the validation confidence; however, the formal evidence artifact for the grid convergence work is captured separately in the project record and is not linked as a generated output of the grid convergence verification activity within this package.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-validation-run",
      "comparisonMetric": "Relative hemolysis index RH",
      "comparisonValue": 0.87,
      "acceptanceCriterion": "RH < 1.0",
      "outcome": "Pass"
    }
  ],
