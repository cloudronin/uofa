    {
      "id": "https://uofa.net/synth/validation/hemolysis-benchmark-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis Index Comparison Against FDA Benchmark Experimental Data",
      "description": "Predicted normalized index of hemolysis (NIH) values from the CFD model were compared against published FDA benchmark experimental measurements for the generic centrifugal blood pump at five flow-speed operating points (2.5 LPM/2500 RPM through 7.0 LPM/3500 RPM). The relative hemolysis index RH remained below 1.0 at all operating points, satisfying the primary acceptance criterion. Discrepancies between model and experiment did not exceed 18% at any single operating point, consistent with MRL 2 expectations.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/experimental-comparison-activity",
      "comparisonMetric": "Relative Hemolysis Index (RH)",
      "acceptanceCriterionMet": true
    },
    {
      "id": "https://uofa.net/synth/validation/shear-stress-distribution-validation",
      "type": "ValidationResult",
      "name": "Wall Shear Stress Distribution Qualitative Validation",
      "description": "Computed wall shear stress distributions were compared qualitatively against particle image velocimetry (PIV) measurements from the literature for similar centrifugal pump geometries. High-shear regions near the impeller blade tips and volute cutwater were consistently reproduced by the CFD model. No quantitative discrepancy exceeded the bounds established for MRL 2 validation activities. This result supports confidence in the model's ability to correctly locate worst-case hemolysis regions.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/piv-comparison-activity",
      "comparisonMetric": "Wall Shear Stress (Pa)",
      "acceptanceCriterionMet": true
    }
