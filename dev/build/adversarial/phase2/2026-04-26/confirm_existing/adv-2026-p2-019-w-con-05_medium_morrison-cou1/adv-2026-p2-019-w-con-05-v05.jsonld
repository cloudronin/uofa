    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/grid-convergence-study",
    "type": "VerificationActivity",
    "name": "Grid Convergence Index (GCI) Study for Discretization Error Quantification",
    "description": "A three-level structured mesh refinement study was conducted on the FDA generic centrifugal blood pump geometry. Meshes of approximately 1.2M, 3.6M, and 10.8M hexahedral cells were generated using ANSYS ICEM-CFD. The GCI was computed for the primary quantity of interest (volume-averaged shear stress and hemolysis index) at each of the five flow-speed operating points. Richardson extrapolation was applied to estimate the continuum solution. All GCI values were confirmed to fall below 5%, satisfying the discretization error acceptance criterion for MRL 2.",
    "activityType": "MeshRefinementStudy",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-24T17:00:00Z",
    "wasAssociatedWith": "https://uofa.net/synth/org/morrison-vv40-team"
  },
