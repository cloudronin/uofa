  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). A grid-independence verification study was conducted to confirm spatial discretization convergence across three mesh refinement levels; results are discussed in the validation narrative but evidence records are attributed to the mesh sensitivity campaign rather than to the dedicated verification activity.",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-geometry-v2",
    "https://uofa.net/synth/data/cpb-operating-conditions-dataset"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/grid-independence-verification",
    "type": "VerificationActivity",
    "name": "Grid Independence Verification Study",
    "description": "A structured grid-independence study was performed on the FDA generic centrifugal blood pump geometry using three mesh refinement levels (coarse: 1.2M cells, medium: 4.8M cells, fine: 19.2M cells). Grid Convergence Index (GCI) values were computed for shear-stress-derived hemolysis index at all five operating points. The study confirmed that the medium mesh achieves GCI < 2% relative to the fine mesh, satisfying the MRL 2 discretization convergence requirement. Velocity profiles and wall shear stress distributions at the volute tongue were compared across refinement levels to verify monotonic convergence behavior.",
    "activityType": "GridConvergenceStudy",
    "performedBy": "https://uofa.net/synth/org/morrison-cfd-team",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-10-04T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-benchmark-result",
      "type": "ValidationResult",
      "name": "Hemolysis Index Benchmark Comparison",
      "description": "Predicted normalized index of hemolysis (NIH) values compared against published FDA experimental measurements at five operating conditions. Mean relative error 8.3%; all predictions within ±15% of experimental values. RH < 1 criterion satisfied at all operating points. The grid-independence study results informed selection of the medium mesh used in all production runs; convergence behavior was confirmed to be monotonic across refinement levels, supporting confidence in discretization adequacy.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-validation-campaign"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-sensitivity-narrative",
      "type": "ValidationResult",
      "name": "Mesh Sensitivity Assessment Narrative",
      "description": "Qualitative review of mesh sensitivity outcomes across the five flow-speed operating points. GCI values ranged from 0.4% to 1.9% for the hemolysis index QoI on the medium mesh relative to the fine mesh. Wall shear stress distributions showed less than 3% variation between medium and fine meshes in the impeller passage region. These results, discussed in the context of the broader validation campaign, confirm that the selected mesh density is adequate for MRL 2 requirements. Note: this narrative result was produced as part of the hemolysis validation campaign activity.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-validation-campaign"
    }
  ],
