    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis validation against FDA experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against published FDA experimental measurements for the generic centrifugal pump at five flow-speed operating points (3 L/min at 2000 RPM through 6 L/min at 3500 RPM). Mean absolute relative error was 8.3%, within the 15% acceptance criterion. The relative hemolysis index RH was below 1.0 for all nominal operating conditions, satisfying the acceptance criterion. Validation activities included direct comparison of predicted shear stress distributions against particle image velocimetry (PIV) data.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/bench-hemolysis-validation-experiment",
      "validationScore": 0.83,
      "acceptanceMet": true
    },
    {
      "id": "https://uofa.net/synth/validation/vr-sensitivity-operating-points",
      "type": "ValidationResult",
      "name": "Sensitivity analysis validation: worst-case operating point identification",
      "description": "The CFD model successfully ranked all five flow-speed combinations by hemolysis severity. The worst-case condition (4 L/min, 3200 RPM) identified by simulation was confirmed by independent bench testing to produce the highest NIH value among the tested conditions. Agreement between CFD rank-ordering and experimental rank-ordering was 100% across all five operating points. The grid convergence study results informed the discretization error bounds reported here; GCI analysis showed that the medium mesh used for production runs introduces a discretization uncertainty of ±2.1% on the NIH quantity of interest, which is well within acceptable bounds for MRL 2 assessment.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/sensitivity-validation-experiment",
