  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/grid-convergence-study",
    "type": "VerificationActivity",
    "name": "Grid Convergence Index (GCI) Study for CFD Hemolysis Model",
    "description": "A formal grid convergence study was performed on three systematically refined meshes (coarse 2.1M cells, medium 5.8M cells, fine 14.2M cells) following the Celik et al. (2008) GCI procedure. The study evaluated convergence of the volume-averaged scalar stress magnitude and the relative hemolysis index at all five operating points. GCI values below 3% were achieved on the medium-to-fine refinement pair, confirming adequate spatial discretization for the production mesh. Iterative convergence was verified by monitoring residuals to below 1e-5 for all transport equations.",
    "activityType": "GridConvergenceStudy",
    "performedBy": "https://uofa.net/synth/org/morrison-cfd-team",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-24T17:00:00Z"
  },
