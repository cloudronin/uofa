    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/grid-convergence-study",
    "type": "VerificationActivity",
    "name": "Spatial Grid Convergence Study — Centrifugal Pump CFD",
    "description": "A formal grid convergence index (GCI) study was conducted across three systematically refined mesh levels (coarse: 1.2M cells, medium: 4.1M cells, fine: 12.8M cells) for the FDA generic centrifugal pump geometry at the 2.5 L/min, 3500 RPM operating point. Richardson extrapolation was applied to estimate the discretization error in the predicted relative hemolysis index. The GCI for the fine mesh was computed as 1.3%, confirming mesh-independent hemolysis predictions within the required tolerance of 5%. Iterative convergence was verified by monitoring residuals to below 1e-6 for all transport equations.",
    "activityType": "GridConvergenceStudy",
