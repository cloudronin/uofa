  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/grid-independence-study",
    "type": "VerificationActivity",
    "name": "Grid Independence Study for CFD Hemolysis Model",
    "description": "A systematic grid independence study was performed on the FDA generic centrifugal blood pump geometry. Three mesh refinement levels were evaluated (coarse: 1.2M cells, medium: 4.8M cells, fine: 19.2M cells). The Richardson extrapolation method was applied to quantify discretization error in the wall shear stress and velocity magnitude fields. The study demonstrated grid convergence index (GCI) values below 2% for the fine-to-medium mesh transition, confirming that the medium mesh (4.8M cells) provides a mesh-independent solution for hemolysis index prediction. Numerical diffusion was assessed via the false diffusion parameter and found to be negligible at the selected mesh density.",
    "activityType": "GridConvergenceStudy",
    "startedAtTime": "2025-11-01T08:00:00Z",
    "endedAtTime": "2025-11-15T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-pump-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump Pressure Rise Validation Against Experimental Data",
      "description": "CFD-predicted pump pressure rise was compared against experimental measurements across 5 flow-speed operating points. Mean absolute error was 4.2% relative to measured values, within the accepted tolerance of 10% for MRL 2. Evidence for this result was generated by the experimental comparison activity.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/experimental-pressure-comparison"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Comparison Against Predicate Device",
      "description": "The computed relative hemolysis index (RH) was below 1.0 for all 5 operating conditions evaluated, satisfying the acceptance criterion RH < 1. The CFD model predicted worst-case hemolysis at the high-speed, low-flow operating point, consistent with experimental observations from the predicate device literature. The grid independence study results described in the verification activity narrative informed confidence in the numerical accuracy of these predictions; however, formal evidence artifacts from that study are catalogued separately in the internal project repository.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/experimental-pressure-comparison"
    }
  ],
