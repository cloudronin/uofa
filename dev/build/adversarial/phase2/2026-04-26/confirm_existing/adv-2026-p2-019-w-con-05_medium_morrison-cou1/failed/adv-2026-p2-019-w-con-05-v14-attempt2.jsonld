      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index validation against experimental measurements",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against in-vitro measurements from the Morrison et al. (2017) experimental campaign. Across all five operating points (2000–3500 RPM, 3–7 L/min), the CFD model predicted NIH within ±18% of experimental values. The relative hemolysis index RH remained below 1.0 for all worst-case candidate conditions, satisfying the acceptance criterion.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/in-vitro-hemolysis-validation-campaign",
      "validationScore": 0.87,
      "meetsAcceptanceCriteria": true
    },
