  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/grid-independence-study",
    "type": "VerificationActivity",
    "name": "Grid Independence and Spatial Convergence Study",
    "description": "A systematic grid independence study was performed across four mesh refinement levels (coarse: 1.2M cells, medium: 3.8M cells, fine: 9.1M cells, extra-fine: 21.4M cells) for the FDA generic centrifugal blood pump geometry. The grid convergence index (GCI) was computed following the Roache procedure. Pressure rise and flow-weighted shear stress distributions were monitored as primary QoIs. The study confirmed that the fine mesh (9.1M cells) achieves GCI < 2% for both QoIs, satisfying the discretization error requirement at MRL 2. Richardson extrapolation was applied to estimate the continuum limit and bound numerical uncertainty. All mesh levels used identical boundary conditions corresponding to the 2500 RPM, 5 L/min design point.",
    "activityType": "SpatialConvergenceStudy",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-10-02T17:00:00Z"
  },
