  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study for CFD Hemolysis Model",
    "description": "A systematic mesh refinement study was conducted across four mesh densities (coarse: 1.2M cells, medium: 3.8M cells, fine: 9.1M cells, very fine: 18.4M cells) for the FDA generic centrifugal blood pump geometry. The Richardson extrapolation method was applied to quantify discretization error in the scalar stress field and derived hemolysis index. Grid convergence index (GCI) values were computed for all five operating points. Results demonstrated monotonic convergence with GCI values below 3.2% for the fine mesh at all operating conditions, confirming mesh-independent solutions.",
    "activityType": "MeshRefinementStudy",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-10-04T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/bench-hemolysis-comparison",
      "type": "ValidationResult",
      "name": "Bench-top hemolysis index validation against experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against published experimental measurements from the FDA benchmark study. Across all five flow-speed operating points, relative errors ranged from 4.1% to 11.7%, with a mean absolute error of 7.3%. The model met the acceptance criterion of relative error below 15% at all points. Agreement was deemed sufficient to support MRL 2 credibility requirements.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/experimental-validation-run"
    },
    {
      "id": "https://uofa.net/synth/validation/scalar-stress-field-comparison",
      "type": "ValidationResult",
      "name": "Scalar stress field comparison against PIV measurements",
      "description": "Particle image velocimetry (PIV) measurements of the velocity field within the pump volute were compared against CFD predictions at the design operating point (5 L/min, 2500 RPM). The CFD model reproduced the primary recirculation zone and jet-wake structure with qualitative fidelity. Quantitative comparison of area-averaged scalar stress showed a 9.8% over-prediction relative to the PIV-derived estimate, within the accepted tolerance band. The mesh independence study narrative is referenced in the technical report appendix, confirming that the fine mesh was used for all validation comparisons.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/piv-comparison-activity"
    }
  ],
