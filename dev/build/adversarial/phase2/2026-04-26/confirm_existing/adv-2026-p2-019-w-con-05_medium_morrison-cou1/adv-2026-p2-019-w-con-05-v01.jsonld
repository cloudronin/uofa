    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/grid-independence-study",
    "type": "VerificationActivity",
    "name": "Grid Independence Study for CFD Hemolysis Model",
    "description": "A systematic grid independence study was performed on the FDA generic centrifugal blood pump geometry. Three mesh refinement levels (coarse: 1.2M cells, medium: 4.8M cells, fine: 19.2M cells) were evaluated at the nominal operating point (5 L/min, 3500 RPM). The Richardson extrapolation method was applied to quantify the grid convergence index (GCI) for wall shear stress and velocity magnitude at five cross-sectional planes. GCI values below 2% were achieved between the medium and fine meshes, confirming mesh-independent results. The medium mesh was selected for all subsequent simulations to balance accuracy and computational cost.",
    "activityType": "MeshConvergenceStudy",
    "performedBy": "https://uofa.net/synth/org/cfd-analysis-team",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-18T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison-001",
      "type": "ValidationResult",
      "name": "Hemolysis Index Bench Comparison — Nominal Operating Points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against in-vitro hemolysis measurements at five operating conditions (3–6 L/min, 2500–3500 RPM). Mean relative error across all conditions was 8.3%, within the 15% acceptance threshold. The computational results successfully reproduced the rank ordering of hemolysis severity across operating conditions, supporting the model's fitness for identifying worst-case conditions.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/bench-validation-testing",
      "comparisonMetric": "Normalized Index of Hemolysis (NIH)",
      "outcomeStatement": "Model predictions agree with experimental measurements within 15% relative error at all five operating points."
    },
    {
      "id": "https://uofa.net/synth/validation/rh-index-predicate-comparison-002",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Comparison Against Predicate Device",
      "description": "The relative hemolysis index (RH) was computed for the CFD model predictions and compared against published predicate device data. RH values ranged from 0.71 to 0.94 across the five flow-speed combinations, all satisfying the RH < 1 acceptance criterion. Narrative review of the grid independence study outputs confirmed that mesh-induced numerical diffusion was not a confounding factor in these results; however, the formal evidence artifact from the grid independence activity was filed separately under the verification dossier and is not directly cross-referenced here.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/bench-validation-testing",
      "comparisonMetric": "Relative Hemolysis Index (RH)",
      "outcomeStatement": "All RH values below 1.0; acceptance criterion satisfied at all operating conditions."
    }
