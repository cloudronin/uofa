  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2. The CFD model demonstrates adequate discretization convergence (GCI 1.3%), satisfactory agreement with FDA benchmark experimental data (pressure rise MAE 4.2%, velocity R² 0.94), and hemolysis predictions that satisfy the RH < 1 acceptance criterion across all five operating points. The six not-assessed factors are consistent with MRL 2 scope. The credibility body of evidence is sufficient to support the regulatory submission claim that the CFD model can identify worst-case hemolysis operating conditions for this Class II CPB device.",
