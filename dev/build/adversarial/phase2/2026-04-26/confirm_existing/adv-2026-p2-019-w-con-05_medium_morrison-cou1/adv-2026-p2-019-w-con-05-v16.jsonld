    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "activityType": "Discretization convergence study",
    "name": "Mesh independence study — FDA centrifugal pump",
    "description": "A structured mesh independence study was conducted across four successively refined hexahedral meshes (0.8 M, 2.1 M, 5.4 M, and 11.2 M cells) for the FDA generic centrifugal pump geometry at the 6 L/min, 3500 RPM operating point. Grid convergence index (GCI) was computed for the primary quantity of interest (volume-averaged shear stress) following the Celik et al. (2008) procedure. The fine-grid GCI was 1.3%, confirming that the 5.4 M cell mesh achieves discretization error below the 2% threshold required at MRL 2. The study was completed using ANSYS Fluent 2022R2 with double-precision arithmetic."
  },
