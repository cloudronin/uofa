  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. Validation results demonstrate RH < 1 at all five operating points with maximum discrepancy of 8.3%, within the 15% acceptance band. The mesh independence study confirmed GCI below 2.1% for the primary QoI. The CFD model is deemed sufficiently credible to support the COU decision of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
