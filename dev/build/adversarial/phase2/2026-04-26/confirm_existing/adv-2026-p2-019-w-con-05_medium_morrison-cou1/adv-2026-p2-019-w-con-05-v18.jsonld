  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study-v1",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study — Three-Level Grid Refinement",
    "description": "A systematic mesh independence study was performed on the FDA generic centrifugal blood pump geometry using three successively refined grids (coarse: 1.2M cells, medium: 4.8M cells, fine: 19.2M cells). The Grid Convergence Index (GCI) was computed for the relative hemolysis index QoI at all five operating points. GCI values for the fine-to-medium refinement ratio were below 2.1% across all operating conditions, confirming that the medium mesh is spatially converged within acceptable tolerances for MRL 2. The activity was executed in ANSYS Fluent 2022R2 using double-precision arithmetic and second-order spatial discretization.",
    "activityType": "MeshConvergenceStudy",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-18T17:00:00Z",
    "wasAssociatedWith": "https://uofa.net/synth/actor/morrison-cfd-analyst"
  },
