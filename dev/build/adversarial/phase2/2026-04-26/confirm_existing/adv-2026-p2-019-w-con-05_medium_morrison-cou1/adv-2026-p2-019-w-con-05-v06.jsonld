  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study-v1",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study for CFD Hemolysis Model",
    "description": "A systematic mesh independence study was conducted on the FDA generic centrifugal blood pump geometry. Three progressively refined meshes (coarse: 1.2M cells, medium: 4.8M cells, fine: 11.6M cells) were evaluated at the nominal operating point (5 L/min, 2500 RPM). Grid Convergence Index (GCI) was computed for the scalar stress field and the hemolysis index. The fine-to-medium GCI for the hemolysis index was 1.4%, confirming that the medium mesh is within the asymptotic range of convergence. This activity established the production mesh selection for all subsequent validation simulations.",
    "activityType": "MeshConvergenceStudy",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-18T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-benchmark-result-001",
      "type": "ValidationResult",
      "name": "Hemolysis Index Validation Against FDA Benchmark Data",
      "description": "CFD-predicted hemolysis indices for 5 flow-speed combinations were compared against published FDA experimental benchmark measurements. The relative hemolysis index (RH) remained below 1.0 for all operating points, satisfying the acceptance criterion. Pressure rise predictions agreed within 4.2% of experimental values. Scalar stress distributions showed qualitative agreement with particle-image velocimetry measurements. The production mesh selected via the mesh independence study (medium, 4.8M cells) was used for all runs reported here.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/cfd-validation-run-nominal-v1"
    },
    {
      "id": "https://uofa.net/synth/validation/sensitivity-sweep-result-001",
      "type": "ValidationResult",
      "name": "Hemolysis Sensitivity to Dimensional Tolerances",
      "description": "A parametric sweep of ±5% variations in impeller blade clearance and volute outlet diameter was performed across all 5 operating points. The worst-case RH across all tolerance combinations remained below 0.92, providing margin against the RH < 1 acceptance criterion. Results confirm that the CFD model is sufficiently sensitive to dimensional variation to support tolerance-setting decisions for the Class II device.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/cfd-sensitivity-sweep-v1"
    }
  ],
