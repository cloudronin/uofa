    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/grid-independence-study-va",
    "type": "VerificationActivity",
    "name": "Grid Independence Study for CPB CFD Model",
    "description": "A systematic grid independence study was conducted across four mesh refinement levels (coarse: 1.2M cells, medium: 3.8M cells, fine: 8.1M cells, extra-fine: 15.4M cells) for the FDA generic centrifugal blood pump geometry. The study evaluated convergence of scalar shear stress distributions and bulk hemolysis index predictions at the five COU flow-speed operating points. Richardson extrapolation was applied to quantify the grid convergence index (GCI) for each quantity of interest, confirming that the fine mesh (8.1M cells) achieves a GCI below 2% for hemolysis index across all operating conditions. The activity was completed prior to production simulation runs and its findings directly informed mesh selection for the validation campaign.",
    "activityType": "GridConvergenceStudy",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-18T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-validation-result-001",
      "type": "ValidationResult",
      "name": "Hemolysis Index Validation Against In Vitro Measurements",
      "description": "CFD-predicted relative hemolysis index (RH) values were compared against in vitro measurements from the Morrison et al. experimental dataset across all five flow-speed operating points. RH predictions fell within the acceptance band (RH < 1) for all operating conditions, with mean absolute error of 0.08 RH units. The validation confirms that the CFD model adequately captures the sensitivity of hemolysis to operating condition variations relevant to the COU. Narrative review of the grid independence study outcomes confirmed that mesh-related discretization error is not a dominant contributor to prediction uncertainty at the selected operating points.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/cpb-hemolysis-comparison-activity"
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-shear-stress-validation-result-002",
      "type": "ValidationResult",
      "name": "Wall Shear Stress Distribution Comparison",
      "description": "Spatially resolved wall shear stress distributions from the CFD model were compared against PIV-derived velocity gradient measurements at three axial planes within the pump volute. Agreement within 15% was observed across 92% of measurement locations, consistent with the MRL 2 validation requirements. The production mesh (8.1M cells) selected based on convergence criteria described in the grid independence study narrative showed no systematic bias attributable to mesh resolution. Evidence for this result was generated by the post-processing comparison activity.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/cpb-shear-stress-comparison-activity"
    }
