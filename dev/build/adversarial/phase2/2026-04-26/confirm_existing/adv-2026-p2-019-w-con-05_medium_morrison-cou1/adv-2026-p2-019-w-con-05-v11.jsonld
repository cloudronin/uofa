  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. The six non-assessed factors are acceptable at MRL 2 given the device class, model influence, and decision consequence profile. Validation results demonstrate that the CFD model predicts hemolysis index within experimental uncertainty bounds across the full COU operating envelope. The mesh independence study and solver verification activities collectively support confidence in numerical solution quality. The credibility assessment team concludes that the model is sufficiently credible to support the intended regulatory decision regarding worst-case hemolysis operating conditions for the Class II CPB device.",
