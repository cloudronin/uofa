  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study-001",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study for CFD Hemolysis Model",
    "description": "A systematic mesh-independence study was performed on the FDA generic centrifugal blood pump geometry. Three mesh densities (coarse: 1.2M cells, medium: 4.8M cells, fine: 18.6M cells) were evaluated at the nominal operating point (5 L/min, 3500 RPM). Richardson extrapolation was applied to estimate the grid convergence index (GCI) for the scalar shear stress field used in hemolysis index computation. The fine mesh achieved GCI < 1.2% for the volume-averaged shear stress, satisfying the MRL 2 discretization error requirement. The study confirmed that the medium mesh provides adequate accuracy for parametric sweeps across the five flow-speed operating combinations.",
    "activityType": "MeshConvergenceStudy",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-18T17:00:00Z",
    "wasAssociatedWith": "https://uofa.net/synth/org/morrison-vv40-team"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/solver-verification-result-001",
      "type": "ValidationResult",
      "name": "Numerical Solver Verification Result",
      "description": "The CFD solver (ANSYS Fluent 2023R2) was verified against the Taylor-Green vortex benchmark and the lid-driven cavity benchmark at Re=1000. Residual norms converged below 1e-6 for all transport equations. The solver verification activity confirmed that discretization and iterative errors are within acceptable bounds for MRL 2. Narrative review of mesh study outputs further supports that the chosen medium mesh (4.8M cells) produces hemolysis index predictions within 2.1% of the Richardson-extrapolated reference value, consistent with the mesh independence study findings described in the activity record.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/solver-verification-activity-001"
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-validation-result-001",
      "type": "ValidationResult",
      "name": "Hemolysis Index Validation Against Experimental Data",
      "description": "Predicted normalized index of hemolysis (NIH) values were compared against experimental measurements from three independent laboratories using the FDA generic blood pump geometry. At all five COU operating points, the relative hemolysis index RH remained below 1.0, satisfying the acceptance criterion. Mean absolute prediction error was 8.3% across operating points. Model outputs bracket experimental uncertainty bands at the 95% confidence level. The validation dataset included 72 experimental NIH measurements spanning flow rates of 2–8 L/min and rotational speeds of 2500–4500 RPM.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-experimental-comparison-activity-001"
    },
    {
      "id": "https://uofa.net/synth/validation/output-comparison-result-001",
      "type": "ValidationResult",
      "name": "Output Quantity Comparison — Pressure Rise and Shear Stress",
      "description": "Simulated pressure rise across the pump impeller was compared against PIV and pressure-tap experimental data from the FDA benchmark dataset. Volume-averaged shear stress distributions showed qualitative and quantitative agreement with experimental laser Doppler velocimetry measurements. All output comparisons were executed under the experimental comparison activity. The mesh independence study, described separately in the verification activity record, underpins confidence that the numerical solution is not contaminated by discretization-induced shear stress artifacts.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-experimental-comparison-activity-001"
    }
  ],
