  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors met or exceeded their required levels for Model Risk Level 2. The CFD hemolysis model demonstrated sufficient accuracy (MARE 8.3%) against in-vitro benchmarks across the full CPB operating envelope. The relative hemolysis index RH remained below 1.0 at all operating points, satisfying the primary acceptance criterion. The mesh independence study and solver verification provide adequate confidence in numerical accuracy. The six non-assessed factors are acceptable at MRL 2 given the medium model influence and availability of confirmatory in-vitro testing. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
