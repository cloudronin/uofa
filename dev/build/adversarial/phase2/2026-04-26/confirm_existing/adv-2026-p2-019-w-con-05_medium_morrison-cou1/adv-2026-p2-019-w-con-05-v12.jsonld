  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study for CFD Hemolysis Model",
    "description": "A structured mesh independence study was conducted using three successively refined hexahedral meshes (coarse: 1.2M cells, medium: 4.8M cells, fine: 19.2M cells) applied to the FDA generic centrifugal pump geometry. Grid convergence index (GCI) was computed for shear-stress-weighted hemolysis index at all five CPB operating points. The study confirmed that discretization error in the hemolysis index remained below 3.5% between medium and fine meshes, and the medium mesh was selected for production runs. Richardson extrapolation was applied to estimate the continuum limit. All runs used identical solver settings, boundary conditions, and turbulence model (SST k-omega) to isolate mesh effects.",
    "activityType": "MeshConvergenceStudy",
    "startedAtTime": "2025-09-10T08:00:00Z",
    "endedAtTime": "2025-09-18T17:00:00Z"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis Index Bench Comparison — 5 Operating Points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against in-vitro hemolysis measurements at five flow-speed combinations representative of CPB conditions. Predicted NIH ranged from 0.0021 to 0.0087 g/100L; measured values ranged from 0.0019 to 0.0091 g/100L. Mean absolute relative error was 8.3%, within the 15% acceptance threshold. The relative hemolysis index RH remained below 1.0 at all operating points, satisfying the primary acceptance criterion.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-bench-validation-runs",
      "validationStatus": "passed"
    },
    {
      "id": "https://uofa.net/synth/validation/solver-verification-result",
      "type": "ValidationResult",
      "name": "Numerical Solver Verification — Analytical Benchmark",
      "description": "The CFD solver was verified against the Taylor-Green vortex analytical benchmark and a Poiseuille flow channel case. Velocity field L2 errors were below 0.5% at the production mesh resolution. Solver convergence was confirmed by residual reduction of six orders of magnitude in all transport equations. These results confirm that the solver introduces negligible numerical error relative to the discretization uncertainty quantified in the mesh independence study.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/solver-benchmark-activity",
      "validationStatus": "passed"
    }
  ],
