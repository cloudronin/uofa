  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) used under an FDA-recognized quality management system with version-controlled scripts and documented validation suite.",
      "rationale": "All FEA runs executed under a 21 CFR Part 820-compliant QMS. Software version locked at Ansys 2022 R2; change-control records confirm no mid-study updates. Regression test suite of 47 benchmark cases executed prior to study initiation with zero failures. Required Gradation 2; achieved Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification demonstrated via comparison to analytical solutions for beam bending and contact problems representative of the pedicle screw geometry.",
      "rationale": "Euler-Bernoulli beam bending benchmark reproduced to within 0.3% of analytical solution. Hertzian contact verification case matched theory to within 1.1%. Both results satisfy Gradation 2 requirements for code verification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change of less than 2% between successive refinements; Richardson extrapolation applied to quantify numerical uncertainty.",
      "rationale": "Three-level mesh refinement study conducted (coarse 0.8 mm, medium 0.4 mm, fine 0.2 mm global element size at screw-rod interface). Richardson extrapolation yields GCI of 0.7% for stiffness QoI and 1.1% for yield force QoI, both well below the 2% threshold. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals monitored; force and moment equilibrium checked at each load step.",
      "rationale": "Newton-Raphson solver converged to residual norm below 1e-6 at every load increment across all 11 construct simulations. Energy balance error remained below 0.05% throughout. Gradation 2 achieved against Gradation 1 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs reviewed by a second analyst independent of the model developer; boundary condition and material assignment checklists completed and archived.",
      "rationale": "Independent peer review of all boundary conditions, material assignments, and contact definitions conducted by a senior biomechanical engineer not involved in model construction. Checklist of 34 items completed with zero discrepancies identified. Use error Gradation 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form appropriateness assessed by sensitivity analysis identifying dominant physics and confirming that simplifying assumptions (linear elasticity for titanium alloy below yield) are consistent with the COU loading regime.",
      "rationale": "Ti-6Al-4V rod and screw modeled as linear elastic below yield (E=114 GPa, nu=0.34); nonlinear contact with friction (mu=0.2) at screw-rod interface and screw-block interface. Sensitivity analysis confirms that contact friction coefficient is the dominant uncertain parameter (±15% effect on yield force). Bilinear plasticity activated beyond yield threshold; comparison to full nonlinear material model shows <1.5% difference in all QoIs within the pre-yield regime of interest. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports for the specific lot of Ti-6Al-4V used in the physical constructs; geometric dimensions measured by CMM on representative samples.",
      "rationale": "Material certificates for Ti-6Al-4V rod (AMS 4928) and screw (ASTM F136) provided by DePuy Synthes. CMM measurements on 3 of 11 constructs confirm nominal geometry within ±0.05 mm. Friction coefficient bounded by literature survey (0.15–0.25) and sensitivity-tested. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lot; traceability to device master record confirmed; sample-to-sample variability characterised.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from a single production lot with full traceability to device master record. Coefficient of variation for stiffness across samples was 4.2%, consistent with expected manufacturing variability. Gradation 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the clinically relevant range of loading rates and environmental conditions; at minimum two distinct test configurations evaluated.",
      "rationale": "Testing performed at a single quasi-static loading rate (5 mm/min) per ASTM F1717 protocol at ambient laboratory conditions (23±2°C, dry). A second loading rate or physiologically conditioned environment was not evaluated. Achieved Gradation 2 against required Gradation 3; this known gap is acknowledged and accepted given that quasi-static loading is the regulatory standard and dynamic loading is outside the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters (geometry, material, boundary conditions) confirmed to correspond to the physical test configuration within documented tolerances.",
      "rationale": "One-to-one mapping between FEA model inputs and physical construct parameters verified through a parameter equivalency matrix. Geometric deviations between nominal CAD and measured CMM data are within 0.05 mm; material property deviations are within 2% of certified values. Gradation 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval computed for all three QoIs; E/uval < 1.96 required for acceptance at 95% confidence.",
      "rationale": "E/uval values: stiffness 0.84, yield force 1.21, force at 40 mm 1.07. All three QoIs satisfy E/uval < 1.96. Percent differences: stiffness 3.1%, yield force 5.8%, force at 40 mm 4.4%, all within the pre-established <10% acceptance bound. Results consistent across both laboratories. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical risk of construct failure and are the quantities used in the regulatory submission.",
      "rationale": "A qualitative assessment was conducted by the credibility assessment team in consultation with the clinical affairs group to confirm that the three selected QoIs are the quantities most directly associated with the clinical failure modes of interest — namely construct loosening (stiffness), permanent deformation onset (yield force), and gross failure (force at 40 mm). The team concluded that the QoIs are fully representative of the COU risk profile and that no additional quantities are needed to characterise the relevant biomechanical behavior. This assessment is documented in the credibility assessment report and was reviewed by the FDA liaison without objection. The qualitative nature of this evaluation reflects the inherent difficulty of formally quantifying clinical relevance on a graduated numerical scale; the team's expert judgment, supported by the regulatory precedent established in the Nagaraja 2016 submission, provides sufficient basis for confidence in the QoI selection."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities (ASTM F1717 bench testing) are directly representative of the COU loading scenario and device configuration.",
      "rationale": "Validation testing performed using the identical device configuration, loading fixture, and test protocol specified in the regulatory COU. ASTM F1717 is the FDA-recognized consensus standard for pedicle screw construct testing. No extrapolation beyond the validated regime is required. Gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed their required gradation levels. The single exception — Test conditions (achieved Gradation 2 vs. required Gradation 3) — is accepted on the basis that ASTM F1717 quasi-static loading is the applicable regulatory standard and dynamic loading is outside the defined COU. The overall evidence package, including quantitative E/uval metrics below 1.96 for all three QoIs and consistent results across two independent laboratories, provides sufficient credibility to support regulatory submission. The credibility assessment team unanimously recommends acceptance.",
