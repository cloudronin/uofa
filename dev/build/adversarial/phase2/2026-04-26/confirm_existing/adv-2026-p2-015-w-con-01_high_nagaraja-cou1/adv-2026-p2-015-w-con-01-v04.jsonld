  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical and FDA in-house FEA solver must have documented version control, regression testing records, and configuration management logs consistent with Gradation 2 or higher.",
      "rationale": "All three FEA solvers (FDA in-house, Ansys Mechanical 2021 R2, DePuy Synthes internal code) are under formal version control with documented regression test suites. Ansys Mechanical is a commercially qualified solver; the FDA in-house code undergoes quarterly regression testing against NAFEMS benchmarks. Configuration management logs were reviewed and found complete. Achieved level exceeds the required level for this medium model-risk context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems (e.g., NAFEMS benchmarks or equivalent) at Gradation 2 or higher.",
      "rationale": "Code verification was performed using NAFEMS linear elastic benchmark suite LE1 and LE10. All three solvers produced results within 0.5% of analytical solutions. Additionally, patch test and single-element tests were conducted for the contact formulations used at the screw-rod interface. Results confirm correct implementation of the finite element formulations employed in this study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that QoI (stiffness, yield force, force at 40 mm) change by less than 5% between successive refinements, and a Richardson extrapolation or GCI estimate must be reported.",
      "rationale": "A three-level mesh convergence study was conducted using element edge lengths of 0.8 mm, 0.5 mm, and 0.3 mm in the critical screw-rod contact region. Stiffness QoI varied by 2.1% between the medium and fine meshes; yield force varied by 1.8%. Grid Convergence Index (GCI) for the fine mesh was 0.9%, well within the 5% acceptance threshold. The medium mesh (0.5 mm) was selected for production runs balancing accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps; contact penetration must remain below 1e-4 mm.",
      "rationale": "Newton-Raphson iteration residuals converged to below 1e-7 for all 47 load steps across the three solver implementations. Maximum contact penetration was 3.2e-5 mm, within tolerance. No divergence events were recorded. Solver error is judged negligible relative to other uncertainty sources."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup, boundary condition application, and post-processing must be independently reviewed by a second analyst not involved in the original model construction.",
      "rationale": "An independent analyst reviewed all model setup files, boundary condition definitions, material property assignments, and post-processing scripts. Three discrepancies were identified and corrected prior to production runs (two related to constraint equation definitions at the UHMWPE block interface, one related to cross-sectional area used in stress normalization). Final model configuration was signed off by both the primary and reviewing analysts."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model and contact formulation must be justified by literature precedent for titanium alloy implant mechanics under quasi-static loading; sensitivity of QoI to model form assumptions must be documented.",
      "rationale": "A bilinear isotropic hardening plasticity model (Ti-6Al-4V: E=114 GPa, yield=880 MPa, tangent modulus=1.1 GPa) was selected based on published material characterization data from ASTM F136 coupon testing. Penalty-based augmented Lagrangian contact was used at screw-rod and rod-UHMWPE interfaces. Sensitivity analysis showed that varying friction coefficient from 0.1 to 0.3 changed stiffness QoI by less than 3%, confirming low sensitivity to this model form assumption. Linear elastic model for UHMWPE block was validated separately."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry, and boundary conditions must be traceable to measured or certified values; uncertainty in key inputs must be quantified.",
      "rationale": "Screw and rod geometry was derived from certified manufacturing drawings (tolerance ±0.01 mm). Material properties for Ti-6Al-4V were taken from lot-specific tensile test certificates accompanying the test constructs. UHMWPE block properties were characterized by the testing laboratory prior to the study. Uncertainty propagation using a one-at-a-time sensitivity approach confirmed that geometric tolerances contribute less than 1.5% variation in stiffness QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be production-representative or documented as such; sample size must be sufficient to estimate mean and variability of each QoI.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were assembled from production-lot components by trained technicians following the surgical technique guide. Constructs were divided across two independent laboratories (N=6 and N=5) to assess inter-laboratory variability. Coefficient of variation for stiffness across all 11 constructs was 4.2%, consistent with published F1717 inter-laboratory precision data. Sample size provides adequate statistical power for mean estimation at the 10% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate the full range of in-vivo loading environments relevant to the COU, including at minimum two distinct load magnitudes or configurations.",
      "rationale": "Testing was conducted under a single ASTM F1717 standard configuration (35 mm offset, quasi-static ramp to failure). While this condition is the regulatory standard and is highly reproducible, it represents only one point in the clinical loading space. Dynamic and cyclic loading conditions were not included in this validation activity. The achieved level is therefore 2 (single standardized condition) against a required level of 3 for this medium-consequence COU. This known gap is acknowledged and accepted given the regulatory precedent for F1717 as the primary submission test."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to the experimental conditions, with documented traceability between test records and model boundary conditions.",
      "rationale": "Each of the 11 experimental constructs was individually characterized for as-built geometry and torque-controlled assembly preload. The FEA model was parameterized using the mean measured values with sensitivity bounds. Cross-referencing of test laboratory data sheets against model input files was performed by an independent reviewer. All boundary conditions (actuator displacement rate, UHMWPE block constraint, load application point) were confirmed equivalent to within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval must be below 1.96 for all QoIs; percent difference must be below 10% for each QoI.",
      "rationale": "For stiffness: FEA mean 312 N/mm vs. experimental mean 308 N/mm (1.3% difference, E/uval=0.41). For yield force: FEA 1,847 N vs. experimental 1,821 N (1.4% difference, E/uval=0.58). For force at 40 mm: FEA 2,103 N vs. experimental 2,089 N (0.7% difference, E/uval=0.29). All three QoIs satisfy both the 10% and E/uval<1.96 acceptance criteria. Agreement is excellent across all three solver implementations with inter-solver variation less than 0.8%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected QoIs (stiffness, yield force, force at 40 mm) must be directly linked to the clinical performance endpoints and regulatory submission requirements.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs explicitly required by ASTM F1717 and referenced in FDA guidance for spinal implant 510(k) submissions. Each maps directly to a clinical performance endpoint: stiffness governs load sharing with the healing bone, yield force defines the fatigue safety margin, and force at 40 mm characterizes post-yield energy absorption. The QoIs are therefore maximally relevant to both the regulatory and clinical contexts."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "A qualitative assessment of the degree to which the validation testing envelope overlaps with the intended clinical use envelope has been documented by the credibility assessment team.",
      "rationale": "The validation activities were conducted using the exact regulatory test standard (ASTM F1717) that defines the submission basis for this device class. The non-cannulated 7.5 mm screw geometry tested is identical to the geometry for which regulatory clearance is sought. Two independent laboratories were engaged to assess reproducibility, and the test constructs were assembled from production-lot components. The validation team conducted a structured relevance review and concluded that the validation envelope — while limited to a single standardized loading condition — is the most clinically relevant and reproducible benchmark available for this COU. The qualitative assessment, documented in the credibility assessment report (Appendix C), concludes that the validation activities are highly relevant to the COU given the regulatory context, even acknowledging the single-condition limitation captured under Test Conditions. No structured gradation levels are assigned to this factor because the relevance assessment is inherently qualitative and consensus-based; the team's expert judgment, corroborated by the output comparison results, supports the overall Accepted decision."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed their required gradation levels. The single exception — Test Conditions (achieved level 2 vs. required level 3) — is acknowledged and accepted on the basis of regulatory precedent: ASTM F1717 is the FDA-recognized standard for pedicle screw construct testing and represents the best available benchmark for this device class. Quantitative output comparison results are excellent across all three QoIs (maximum E/uval=0.58, maximum percent difference=1.4%), well within pre-established acceptance bounds. The Relevance of the validation activities to the COU factor was evaluated through structured expert review and is judged to be high. The overall credibility evidence is sufficient to support the regulatory submission claim that the FEA modeling framework reliably predicts ASTM F1717 compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
