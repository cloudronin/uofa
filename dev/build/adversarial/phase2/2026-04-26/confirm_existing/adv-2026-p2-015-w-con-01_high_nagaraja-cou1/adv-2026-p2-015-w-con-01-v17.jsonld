  "signature": "ed25519:b1d4e7a2f9c3056e8b1d4e7a2f9c3056e8b1d4e7a2f9c3056e8b1d4e7a2f9c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2). SQA documentation, version control, and regression testing records must be on file.",
      "rationale": "All three FEA codes (FDA in-house Abaqus scripts, Ansys Mechanical 2021 R2, DePuy Synthes proprietary solver) operate under documented SQA plans. Version control via Git with tagged releases; regression test suites executed prior to each simulation campaign. Achieved Gradation 3 reflects formal SQA plan with independent review sign-off, exceeding the Gradation 2 requirement for a Medium model-risk application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations for static structural analysis at Gradation 2 or above.",
      "rationale": "Patch tests, manufactured-solution benchmarks, and NAFEMS standard problems LE1 and LE10 were executed for each solver. Results agree with analytical solutions to within 0.3% for linear elastic regimes. Gradation 2 achieved: documented benchmark suite with pass/fail criteria applied before production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must be documented with GCI or equivalent error estimator. Discretization error contribution to total uncertainty budget must be quantified.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw shank and rod-screw interface regions, which govern stiffness and yield predictions. Grid Convergence Index (GCI) computed per Roache (1998); GCI < 1.2% for stiffness QoI and < 2.1% for yield force QoI across all three solver implementations. Discretization error is incorporated into the total validation uncertainty budget uval. Gradation 3 achieved due to formal GCI reporting with asymptotic convergence confirmation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must be reported and shown to be below tolerance thresholds consistent with QoI accuracy requirements.",
      "rationale": "All analyses are static implicit with direct sparse solvers (PARDISO / Multifrontal Massively Parallel Solver). Iterative solver residuals are not applicable; direct solver round-off errors estimated via condition number monitoring. Condition numbers remain below 1e8 for all load steps, ensuring numerical round-off is negligible relative to discretization and input uncertainty. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs, boundary conditions, and post-processing scripts must be independently reviewed by a second analyst prior to result acceptance.",
      "rationale": "Each simulation package (geometry, mesh, material cards, boundary condition scripts, post-processing macros) was reviewed by a second qualified FEA analyst not involved in the original setup. Discrepancies identified during review were resolved before results were accepted. Formal checklist used per laboratory SOP. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form must be justified by physics literature and sensitivity analysis demonstrating that simplifying assumptions do not materially affect QoIs beyond acceptance bounds.",
      "rationale": "Linear elastic model form adopted for stiffness QoI; bilinear isotropic hardening plasticity (Ti-6Al-4V: E=114 GPa, sy=880 MPa, Et=1.1 GPa) used for yield force and 40 mm displacement QoIs. Model form selection supported by published material characterization (ASTM E8 tensile data from three heats) and sensitivity analysis showing <2% QoI sensitivity to ±5% variation in hardening modulus. Gradation 3 achieved: model form justified with quantified sensitivity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be sourced from measurements on the specific lot used in testing; uncertainty in inputs must be propagated to QoI uncertainty.",
      "rationale": "Ti-6Al-4V material properties measured from tensile coupons machined from the same bar stock as the tested screws (N=5 coupons per heat, 3 heats). Geometric dimensions verified by CMM on 3 of 11 test constructs. Input uncertainty propagated via Monte Carlo (N=1000 samples) using measured property distributions. Combined input uncertainty contribution to uval is 3.1% of mean stiffness. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens must be representative of the device design being modeled; traceability to production geometry must be documented.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled per ASTM F1717 fixture specification. Screws sourced from production lots with full dimensional inspection records. CMM measurements confirm shank diameter 7.50 ± 0.02 mm, thread pitch 2.75 mm, consistent with CAD nominal geometry used in FEA. Two independent laboratories (FDA CDRH and DePuy Synthes R&D) each contributed specimens, providing inter-laboratory variability data. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios; at minimum two distinct load levels or configurations must be represented in the validation dataset.",
      "rationale": "Testing performed under a single ASTM F1717 static compression-bending configuration (axial compressive load applied at 10° from vertical via offset anvil). No torsion, fatigue, or dynamic conditions included in this validation activity. This single test condition limits the achieved level to Gradation 2 against a Gradation 3 requirement. Noted as a documented limitation; supplemental fatigue V&V planned for COU2. Decision to Accept is supported by the bounded scope of the COU (static compression-bending only) and the conservative acceptance bounds applied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters must be demonstrably equivalent to experimentally measured conditions; any discrepancies must be quantified and their effect on QoIs bounded.",
      "rationale": "Applied displacement boundary conditions in FEA matched to crosshead displacement measured by laboratory LVDT (resolution 0.001 mm). Fixture compliance characterized separately and removed from experimental displacement data before comparison. Friction coefficient at screw-rod interface estimated from published Ti-Ti tribology data (mu=0.3 ± 0.05); sensitivity analysis shows <1.5% QoI effect over plausible range. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval must be computed and shown to be below 1.96 for all QoIs; percent difference must be below 10% for each QoI.",
      "rationale": "E/uval computed for stiffness (0.84), yield force (1.21), and force at 40 mm displacement (1.47), all below the 1.96 threshold. Percent differences: stiffness 3.2%, yield force 5.7%, 40 mm force 6.9%, all within the 10% acceptance bound. Results consistent across all three solver implementations, confirming solver-independence of conclusions. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected QoIs must be directly linked to the clinical risk drivers identified in the COU; the mapping from QoI to patient safety outcome must be explicitly documented.",
      "rationale": "A thorough qualitative assessment was conducted by the multidisciplinary team (biomechanical engineers, clinical affairs, regulatory affairs) to evaluate whether construct stiffness, yield force, and force at 40 mm displacement are the most clinically relevant quantities for predicting pedicle screw construct failure risk. The team reviewed published clinical literature on pedicle screw fracture mechanisms and concluded that these three QoIs collectively capture the dominant failure modes (elastic deformation under physiological loading, onset of plastic deformation, and post-yield load-carrying capacity). The mapping from each QoI to the patient safety consequence (revision surgery risk) was documented in the Clinical Risk Traceability Matrix (CRTM-001). This assessment was reviewed and approved by the principal investigator and the regulatory affairs lead. The qualitative nature of the QoI relevance determination reflects the current state of the art in spinal implant biomechanics, where direct quantitative linkage between bench QoIs and clinical outcomes remains an active area of research. The team judged the selected QoIs to be appropriate and sufficient for the stated COU without assigning a formal gradation level, consistent with the descriptive approach permitted for this factor under the project's credibility assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activities must be performed on a system sufficiently similar to the COU device and loading environment that the validation evidence is directly transferable.",
      "rationale": "Validation activities performed on the identical device design (non-cannulated 7.5 mm pedicle screw) under the identical ASTM F1717 test configuration as the COU. No extrapolation of validation evidence required. Two-laboratory design provides inter-laboratory robustness. Gradation 3 achieved: validation activities are directly co-incident with the COU in geometry, material, and loading."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors achieved their required gradation level or above. One factor (Test conditions) achieved Gradation 2 against a Gradation 3 requirement, reflecting the single ASTM F1717 static configuration used in validation; this shortfall is accepted given the bounded COU scope (static compression-bending only) and the conservative 10%/<1.96 E/uval acceptance bounds, all of which were met. The factor 'Relevance of the quantities of interest' was evaluated through a comprehensive qualitative assessment documented in CRTM-001 and approved by the principal investigator and regulatory affairs lead. On balance, the overall credibility evidence is judged sufficient to support the claim that the FEA framework reliably predicts ASTM F1717 compression-bending behavior of the non-cannulated pedicle screw construct. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
