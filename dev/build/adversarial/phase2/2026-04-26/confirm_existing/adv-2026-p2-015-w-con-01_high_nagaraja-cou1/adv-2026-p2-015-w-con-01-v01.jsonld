  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2022 R2) operates under a documented software quality plan with version control, regression testing, and audit trail. Required Gradation 2 for Medium model risk.",
      "rationale": "Ansys Mechanical 2022 R2 is used under a 21 CFR Part 11-compliant quality management system. Version control is maintained via Git; regression test suite covers all element types used in the pedicle screw model. Achieved Gradation 3 exceeds the required Gradation 2 for this Medium-risk COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 and Ansys verification manual demonstrate correct implementation of linear elastic and contact formulations used in the model.",
      "rationale": "Three published benchmark problems (Hertzian contact, cantilever beam under end load, and bolt preload relaxation) were solved and results compared to analytical solutions within 0.5%. Code verification is satisfied at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <1% between successive refinements. Richardson extrapolation applied to stiffness and yield force outputs.",
      "rationale": "A three-level mesh refinement study was performed (coarse: ~180k elements, medium: ~420k, fine: ~980k). Richardson extrapolation yields a GCI of 0.4% for construct stiffness and 0.7% for yield force. Discretization error is well-controlled at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6 for all load steps; contact status monitored for chattering.",
      "rationale": "Direct sparse solver (PARDISO) employed for all load steps. Residual norms confirmed below 1e-8. No contact chattering observed across 200 load increments. Gradation 2 achieved, exceeding the required Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented model setup procedure reviewed by independent analyst; boundary conditions and material assignments verified against CAD and material certificates.",
      "rationale": "An independent senior analyst performed a blind model reconstruction from the documented setup procedure and compared outputs to the primary model. Stiffness predictions agreed within 0.3%. Boundary condition assignments and material property inputs were verified against DePuy Synthes material certificates and ASTM F1717 fixture drawings."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic constitutive model with frictional contact is appropriate for the pre-yield compression-bending regime addressed by this COU.",
      "rationale": "The COU addresses quasi-static compression-bending up to and including yield. Linear elastic material with isotropic hardening is applied to the titanium alloy screw (Ti-6Al-4V, E=114 GPa, σ_y=880 MPa). Frictional contact (μ=0.2) is used at screw-rod and screw-block interfaces. Model form is consistent with the physics of the problem at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports for the specific lot used in bench testing; geometric inputs derived from CMM measurements of tested constructs.",
      "rationale": "Material properties (E, σ_y, σ_u) were obtained from lot-specific tensile coupon testing per ASTM E8. CMM measurements of all 11 constructs provided as-manufactured geometry inputs to the FEA ensemble. Uncertainty in material properties propagated via Monte Carlo (N=1000 samples). Achieved Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lots; constructs span normal manufacturing variation as confirmed by dimensional inspection.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. All constructs were drawn from the same production lot and inspected dimensionally. Sample size satisfies the pre-specified statistical power requirement (β=0.8, α=0.05) for detecting a 10% QoI difference. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate the full range of in vivo loading conditions relevant to the COU, including at least two load magnitudes and two fixation torques.",
      "rationale": "Testing was performed at a single load configuration (ASTM F1717 standard conditions: 10 mm/min crosshead speed, 6° offset angle, standard fixation torque). While this satisfies ASTM F1717 requirements, only a single test condition was explored, limiting coverage of the in vivo loading space. Achieved Gradation 2 against a required Gradation 3; this factor is below the required level and is documented as a known gap. The overall credibility assessment proceeds because all other factors meet or exceed requirements and the E/uval metric remains below 1.96 across all QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters (geometry, material properties, boundary conditions) demonstrably correspond to the physical test configuration with differences quantified and bounded.",
      "rationale": "CMM-derived geometry, lot-specific material properties, and laboratory-measured fixation torques were used as direct inputs to the FEA models. Residual differences between nominal and as-measured inputs were propagated through the uncertainty analysis. Parameter equivalency is confirmed at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all three QoIs; percent difference < 10% for mean predictions.",
      "rationale": "E/uval values: stiffness 0.82, yield force 1.14, force at 40 mm 0.97 — all below the 1.96 threshold. Mean percent differences: stiffness 3.1%, yield force 4.7%, force at 40 mm 2.9% — all below 10%. Output comparison is fully quantitative and satisfies the pre-specified acceptance criteria at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical risk of construct failure and are the quantities used in the regulatory submission.",
      "rationale": "A qualitative assessment was conducted by the modeling team and clinical advisors to confirm that the three selected QoIs — construct stiffness, yield force, and force at 40 mm displacement — are the quantities most directly predictive of clinical performance under ASTM F1717 loading. Stiffness governs load sharing with the vertebral column; yield force determines the onset of permanent deformation; force at 40 mm characterises post-yield energy absorption relevant to fatigue initiation. The clinical team confirmed that these QoIs are the primary endpoints used in the 510(k) submission and that no additional QoIs are needed for the non-cannulated design variant. This assessment was conducted through structured expert elicitation and documented in the credibility assessment report, and is considered sufficient to establish relevance without reduction to a numerical gradation scale."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activities (ASTM F1717 bench testing, N=11, two labs) are directly representative of the COU: same device design, same loading mode, same QoIs as the regulatory submission.",
      "rationale": "The validation activity uses the identical non-cannulated 7.5 mm pedicle screw construct that is the subject of the regulatory submission. The ASTM F1717 test protocol directly replicates the loading mode and boundary conditions modelled in the FEA. Both laboratories are ISO 17025 accredited. The validation activities are directly relevant to the COU at Gradation 2."
    }
  ],
