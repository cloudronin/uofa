  "signature": "ed25519:9b3c1e7a2d5f08b4c6e0a3d7f1b9e5c2a8f4d0b6e2c9a5f3d1b7e4c0a8f6d2b",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) used under a validated quality management system with documented version control, regression testing, and user access controls.",
      "rationale": "The FEA software environment operates under an ISO 13485-compliant QMS. Version control records, regression test reports, and software validation documentation were reviewed and found complete. Achieved level 3 exceeds required level 2 for medium model risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions verified against solver output; residual norms monitored to convergence tolerance 1e-6.",
      "rationale": "Ansys Mechanical verification benchmarks covering linear elastic beam bending and contact problems were executed. All benchmark results within 0.5% of analytical solutions. Residual norms confirmed below 1e-6 for all load steps. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between successive refinements; Richardson extrapolation applied to estimate discretization error.",
      "rationale": "A three-level mesh refinement study was conducted on the pedicle screw–rod–vertebral body assembly. QoI (stiffness, yield force) changed by 0.8% between the medium and fine mesh. Richardson extrapolation estimated discretization error of 1.1% for stiffness. Fine mesh adopted for all production runs. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence confirmed; energy balance checked at each load increment.",
      "rationale": "Sparse direct solver (SPARSE) used for all static structural analyses. Energy balance errors < 0.01% confirmed across all 11 simulation runs corresponding to experimental constructs. No convergence warnings issued. Achieved level 2 exceeds required level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs reviewed by independent analyst; boundary condition application documented in controlled simulation plan.",
      "rationale": "An independent senior engineer reviewed all boundary condition assignments, material property inputs, and contact definitions against the controlled simulation plan prior to execution. No discrepancies identified. Peer review checklist archived in the QMS. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics (linear elastic, small-deformation continuum mechanics with frictional contact) justified relative to COU loading regime; sensitivity to model form assumptions documented.",
      "rationale": "The compression-bending loading regime for ASTM F1717 produces predominantly elastic response in the titanium alloy construct up to yield. Linear elastic constitutive models are appropriate for stiffness and yield-force QoIs. Bilinear isotropic hardening was additionally evaluated for post-yield force QoI; results within 3% of linear elastic prediction at 40 mm. Model form uncertainty quantified as < 5% contribution to total uncertainty budget. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (Ti-6Al-4V elastic modulus, yield strength, friction coefficients) sourced from traceable measurements; uncertainty ranges propagated through model.",
      "rationale": "Material properties sourced from coupon tensile testing of the same lot material as the test constructs (n=5 coupons). Friction coefficients measured by pin-on-disk tribometry. Monte Carlo propagation (n=1000) of input uncertainties showed QoI coefficient of variation < 3%. All input values traceable to calibrated measurement systems. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 constructs tested; dimensional measurements confirm geometric conformance to nominal CAD; sample-to-sample variability characterized.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled and tested across two independent laboratories. Dimensional inspection of all constructs confirmed screw outer diameter within ±0.05 mm of nominal. Sample-to-sample coefficient of variation in stiffness was 4.1%, consistent with expected manufacturing variability. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant range of loading rates and environmental conditions; ASTM F1717 protocol followed with documented deviations.",
      "rationale": "Testing was conducted strictly per ASTM F1717 at a single loading rate (5 mm/min) and ambient temperature (23 ± 2 °C). While the protocol was followed without deviation, only one test condition was evaluated, limiting the ability to characterize loading-rate sensitivity. Achieved level 2 is below required level 3; this shortfall is noted and accepted given that the clinical loading rate is quasi-static and rate sensitivity of Ti-6Al-4V in this regime is well-characterized in the literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading replicate experimental setup; fixture compliance characterized and incorporated or shown negligible.",
      "rationale": "Experimental fixture geometry was laser-scanned and incorporated into the FEA boundary condition definitions. Fixture compliance was measured at 0.003 mm/N and shown to contribute < 0.4% to measured stiffness; it was incorporated as a linear spring in the model. Load application angle confirmed within 0.2° of nominal for all test specimens. Required level 2 exceeded; achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of FEA predictions to experimental results using area validation metric and E/uval statistic; acceptance threshold E/uval < 1.96 pre-specified.",
      "rationale": "A comprehensive qualitative assessment of the output comparison was performed by the credibility assessment team, drawing on the collective expertise of analysts from FDA, Ansys, and DePuy Synthes. The team reviewed force-displacement curve overlays, residual plots, and summary statistics for all three QoIs across all 11 constructs. The visual and engineering judgment-based review indicated strong agreement between FEA predictions and experimental measurements, with no systematic bias detected across either laboratory. The team's consensus qualitative evaluation supports the overall Accepted decision, and the richness of the multi-analyst review process provides high confidence in the output comparison findings without necessitating reduction to a single numeric gradation level for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and cited in FDA guidance for pedicle screw system submissions. Each QoI maps directly to a clinical failure mode: stiffness to construct micromotion and pseudarthrosis, yield force to permanent deformation risk, and force at 40 mm to catastrophic fracture risk. Relevance is fully established. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments replicate COU geometry, material, loading, and boundary conditions; gaps between validation and COU are documented and bounded.",
      "rationale": "The validation constructs use the same 7.5 mm non-cannulated pedicle screw design, same Ti-6Al-4V alloy, and same ASTM F1717 test configuration as the COU. Both laboratories used the same standardized UHMWPE vertebral body surrogate. The only gap between validation and COU is the single-condition limitation already captured under Test conditions. No additional relevance gaps were identified. Required level 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 credibility factors for the non-cannulated pedicle screw FEA model under ASTM F1717 compression-bending. Twelve of thirteen factors met or exceeded their required levels. The Test conditions factor achieved level 2 against a required level 3, reflecting the single-condition test protocol; this shortfall was accepted given the quasi-static clinical loading context and the strong agreement across all three QoIs at N=11 constructs in two laboratories. All quantitative acceptance criteria (E/uval < 1.96, QoI error < 10%) were satisfied. The team unanimously concluded that the model credibility is sufficient to support the intended regulatory use and voted to Accept the credibility package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
