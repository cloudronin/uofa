  "signature": "ed25519:b1c4e7a2f9d3b6e0c5a8f2d1e4b7c0a3f6d9b2e5c8a1f4d7b0e3c6a9f2d5b8e1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) operates under a documented quality management system with version control, regression test suite, and change control records.",
      "rationale": "Ansys Mechanical 2022 R2 is deployed under an ISO 9001-registered QMS at DePuy Synthes. Version control logs, regression test results for relevant element types (SOLID186, CONTA174), and change control records were reviewed and found complete. Required level 2 (documented QMS) is exceeded by achieved level 3 (formal verification test suite on record)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions (cantilever beam, Hertzian contact) reproduced to within 1% by the solver configuration used in the COU model.",
      "rationale": "Cantilever beam and Hertzian contact benchmark cases were executed in the COU solver configuration. Relative errors were 0.3% and 0.7% respectively, confirming the implementation is correct for the element types and contact formulations employed. Required and achieved levels are both 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates that QoI change between successive refinements is less than 2%; Richardson extrapolation applied to estimate asymptotic value.",
      "rationale": "A three-level mesh convergence study (coarse: 1.2 mm global, medium: 0.8 mm, fine: 0.5 mm at screw-rod interface) was conducted. Stiffness QoI changed by 3.1% (coarse→medium) and 0.6% (medium→fine). Richardson extrapolation yielded a GCI of 0.9% for the fine mesh, confirming discretization error is below the 2% threshold. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force residual and displacement increment convergence norms fall below 0.1% at each load step; energy criterion also monitored.",
      "rationale": "Nonlinear solution employed full Newton-Raphson with line search. Force residual norm converged to <0.05% and displacement increment norm to <0.08% at each of the 200 load substeps. Energy criterion remained below 1e-4. No divergence or bisection events were recorded across the 11 specimen simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs, boundary conditions, and post-processing scripts subject to independent peer review by a second qualified analyst before results are accepted.",
      "rationale": "All model inputs (geometry, material assignments, contact pairs, boundary condition definitions) and post-processing scripts were independently reviewed by a second FDA OSEL analyst. Discrepancies identified (two incorrect contact stiffness factor assignments) were corrected prior to final analysis runs. Review records are archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model (bilinear isotropic hardening) validated against coupon-level tension data for Ti-6Al-4V; contact formulation (augmented Lagrangian) appropriate for the slip regime observed.",
      "rationale": "Bilinear isotropic hardening parameters were calibrated against five Ti-6Al-4V dogbone specimens per ASTM E8. Predicted vs. measured stress-strain curves agreed within 2.1% at yield and 3.4% at UTS. Augmented Lagrangian contact with friction coefficient 0.25 (literature-supported for Ti-Ti interfaces) was validated against a screw-rod pull-out benchmark. Model form is judged appropriate for the compression-bending regime of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry dimensions, and assembly torque values sourced from traceable measurements on the actual test specimens; uncertainty in inputs propagated to QoI uncertainty.",
      "rationale": "Screw and rod geometry was measured by CMM on three representative specimens; deviations from nominal were less than 0.05 mm and incorporated as input uncertainty. Ti-6Al-4V elastic modulus and yield strength were taken from certified material test reports for the production lot used in bench testing. Assembly torque was measured with a calibrated torque wrench (±2% accuracy). A one-at-a-time sensitivity study confirmed that input uncertainty contributes less than 1.8% to QoI variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production lots; specimens span at least two independent assembly operators to capture assembly variability.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production lots by two independent operators (six by operator A, five by operator B) across two laboratories. Coefficient of variation in measured stiffness was 4.2%, consistent with expected manufacturing variability. Sample size provides 80% power to detect a 10% mean difference at α=0.05."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate the ASTM F1717 protocol with at least two distinct load levels or fixture configurations to bound the operating envelope.",
      "rationale": "Testing was performed strictly per ASTM F1717 at a single compressive load offset (5 mm), representing one test condition. A second fixture configuration or load level was not included in the study scope. Achieved level 2 (single standardized test condition documented) falls below required level 3 (multiple conditions bounding the envelope). This gap is noted as a limitation of the current validation dataset and is accepted given that the COU is restricted to the ASTM F1717 loading regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters (geometry, material, boundary conditions) demonstrably match experimental specimen parameters within measurement uncertainty.",
      "rationale": "CMM measurements of test specimens were used directly to set model geometry. Material properties were taken from the same production lot MTRs used to characterize specimens. Boundary conditions replicate the ASTM F1717 fixture constraints (fixed proximal block, roller distal block at 5 mm offset). Parameter equivalency was confirmed through a formal traceability matrix mapping each model input to its experimental counterpart."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all primary QoIs; percent difference < 10% for each QoI.",
      "rationale": "Three primary QoIs (stiffness, yield force, force at 40 mm) were compared using the ASME V&V 40 validation metric E/uval. Results: stiffness E/uval=1.41 (6.3% diff), yield force E/uval=1.68 (8.7% diff), force at 40 mm E/uval=0.93 (4.9% diff). All three QoIs satisfy both acceptance criteria. The validation comparison is judged successful."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (stiffness, yield force, force at 40 mm) are directly linked to the clinical and regulatory decision criteria for the device.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and referenced in FDA guidance for pedicle screw 510(k) submissions. These QoIs are directly used in the predicate device comparison and design verification matrix. Relevance is unambiguous; achieved level 3 (QoIs are primary regulatory decision inputs) exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities are judged relevant to the COU through qualitative assessment of geometry, loading, and material similarity between the validation scenario and the intended clinical use scenario.",
      "rationale": "The relevance of the validation activities to the COU was evaluated through a structured qualitative assessment by the credibility assessment team. The validation scenario (ASTM F1717 bench test, non-cannulated 7.5 mm screw, two-level construct, Ti-6Al-4V rod and screw) is considered highly representative of the clinical use scenario in terms of geometry, material system, and loading mode (compression-bending dominant in posterior spinal instrumentation). The test fixture replicates the essential kinematic constraints of the in vivo environment for the load case of interest. No quantitative relevance metric was computed; instead, the team applied engineering judgment consistent with ASME V&V 40 Section 5.4 guidance for cases where the validation and COU scenarios are nominally identical. The qualitative assessment concludes that the validation activities are fully relevant to the COU and that no additional relevance adjustment is warranted."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 credibility factors. Twelve of thirteen factors meet or exceed their required levels. The single factor below required level (Test conditions, achieved 2 vs. required 3) is accepted given that the COU is explicitly scoped to the ASTM F1717 compression-bending loading regime and no extrapolation beyond that regime is claimed. Quantitative validation metrics (E/uval < 1.96 for all three primary QoIs; percent differences < 10%) are satisfied. The overall credibility of the FEA model ensemble is judged sufficient to support the intended regulatory use. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
