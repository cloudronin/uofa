  "hash": "sha256:3f7a2c9d1e4b58062a7f3d9c4e1b28a57f3c9d2e4b1a8c7f3d9e2b4a1c8f7d3e",
  "signature": "ed25519:9b2e4a1c7f3d8e5b2a9c4f1e7d3b8a5c2f9e4b1d7a3c8f5e2b9d4a1c7f3e8b5a",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) must be validated under an FDA-recognized SQA framework with documented version control, regression testing, and change management procedures.",
      "rationale": "Ansys Mechanical 2022 R2 is operated under a 21 CFR Part 11-compliant SQA plan. Installation qualification (IQ), operational qualification (OQ), and performance qualification (PQ) records are archived. Version control and regression test suite cover all element types used in this model. Achieved Gradation 3 exceeds the required Gradation 2 for a Medium model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark solutions for beam bending and contact mechanics must reproduce analytical results within 1% for the element formulations used.",
      "rationale": "Cantilever beam and Hertzian contact benchmark problems executed using the SOLID186 and CONTA174/TARGE170 element formulations employed in this model. Maximum deviation from analytical solutions is 0.6% for stiffness and 0.8% for peak stress, satisfying the 1% criterion. Numerical code verification is confirmed at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change of less than 2% between successive refinement levels; Richardson extrapolation-based GCI must be reported.",
      "rationale": "Three-level mesh refinement study performed (coarse: 1.2 mm global, medium: 0.8 mm, fine: 0.5 mm with local refinement at screw-rod interface to 0.15 mm). Construct stiffness QoI changed by 1.1% between medium and fine meshes. Grid Convergence Index (GCI) = 0.9%, well below the 2% threshold. Final mesh uses fine discretization settings. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge to below 1e-6 for all load steps; energy balance error must remain below 0.1%.",
      "rationale": "Direct sparse solver (PARDISO) employed for all load steps. Force and displacement residuals converge to 1e-8 within 12 Newton-Raphson iterations at maximum load. Energy balance error monitored across all 50 substeps; maximum observed value 0.04%. No divergence or negative pivot warnings recorded. Gradation 2 achieved, exceeding the Gradation 1 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be reviewed by an independent analyst; boundary condition and material assignment scripts must be version-controlled and peer-reviewed.",
      "rationale": "Model setup scripts (APDL macros) are stored in a Git repository with mandatory peer-review pull request process. An independent senior analyst performed a blind re-execution of the model from the archived input deck and reproduced QoI values within 0.2% of the primary analyst results. Use error controls confirmed at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive models for Ti-6Al-4V (screw/rod) and UHMWPE (vertebral body surrogate) must be validated against material coupon data; contact formulation must be justified for the slip regime expected.",
      "rationale": "Bilinear isotropic hardening (BISO) constitutive model for Ti-6Al-4V calibrated against tensile coupon data from the same material lot (n=5; E=114 GPa ±2%, σ_y=880 MPa ±1.5%). UHMWPE modeled as linear elastic (E=1.0 GPa) consistent with the stiffness-dominated loading regime. Augmented Lagrangian contact with friction coefficient μ=0.2 (literature-supported for Ti-Ti dry contact) employed at all interfaces. Sensitivity analysis shows ±50% variation in μ produces <3% change in construct stiffness QoI, confirming low sensitivity. Model form Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Geometric inputs must be derived from calibrated CMM measurements of the actual test articles; material properties must be traceable to certified material test reports.",
      "rationale": "CAD geometry for the 7.5 mm non-cannulated screw and 5.5 mm rod imported from the manufacturer's nominal design files and verified against CMM measurements of five test articles (maximum deviation 0.03 mm). Material properties sourced from certified material test reports (MTRs) traceable to ASTM E8 tensile testing. Pedicle screw block geometry derived from ASTM F1717 standard dimensions. Input parameter uncertainty quantified via Latin Hypercube sampling (n=200 runs); combined input uncertainty contributes uinput = 2.1% of QoI mean. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test sample population must include at least 10 constructs; samples must be representative of production lots with documented dimensional inspection.",
      "rationale": "N=11 non-cannulated pedicle screw constructs tested across two independent laboratories (Lab A: n=6, Lab B: n=5). All constructs assembled from production-representative components with documented lot traceability. Dimensional inspection of each construct confirmed screw geometry within 0.05 mm of nominal. Inter-laboratory coefficient of variation for construct stiffness is 4.2%, indicating acceptable production consistency. Sample representativeness confirmed at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span at least two load levels or two fixation configurations to characterize the model response surface; environmental conditions must be controlled and documented.",
      "rationale": "Testing performed under a single ASTM F1717 standard load configuration (static compression-bending at 10 mm/min crosshead speed, ambient temperature 23±2°C). Only one load condition was evaluated, which does not satisfy the Gradation 3 requirement for multi-condition coverage. The shortfall is acknowledged; however, the single condition is the clinically relevant worst-case scenario and is fully consistent with the regulatory submission context. Achieved Gradation 2 against required Gradation 3 — this factor does not meet the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model boundary conditions and loading must be demonstrably equivalent to experimental setup; any deviations must be quantified and shown to have negligible effect on QoI.",
      "rationale": "Experimental fixture geometry (ASTM F1717 block dimensions, loading nose radius, support span) replicated in the FEA model to within 0.1 mm. Displacement-controlled loading applied in the model consistent with the experimental crosshead displacement protocol. Sensitivity analysis varying fixture compliance ±20% shows less than 1.5% change in construct stiffness QoI. Equivalency confirmed at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation metric E/uval must be less than 1.96 for all three QoIs; percent difference must be less than 10% relative to experimental mean.",
      "rationale": "Three QoIs assessed: construct stiffness (E/uval=1.12, %diff=4.8%), yield force (E/uval=1.44, %diff=8.3%), force at 40 mm (E/uval=0.98, %diff=6.1%). All three QoIs satisfy both the E/uval<1.96 criterion and the 10% percent difference bound. Validation uncertainty (uval) computed following ASME V&V 20 methodology incorporating experimental standard uncertainty, numerical uncertainty, and input parameter uncertainty. Output comparison Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly linked to the clinical performance endpoints identified in the COU; the linkage must be explicitly documented.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the ASTM F1717 standard and correspond directly to the clinical performance endpoints for pedicle screw constructs (resistance to deformation under physiological loading, onset of permanent deformation, and load-bearing capacity at large displacement). The linkage from bench QoI to clinical endpoint is documented in the COU description and the FDA guidance document for spinal implants. QoI relevance confirmed at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activity is considered highly relevant to the COU because the bench test protocol directly replicates the intended use loading scenario and the test articles are geometrically and materially equivalent to the submission device.",
      "rationale": "A comprehensive qualitative assessment was conducted to evaluate the degree to which the ASTM F1717 validation activity maps onto the clinical context of use. The validation specimens are geometrically identical to the submission device (same screw diameter, rod diameter, and inter-screw distance), the loading mode (compression-bending) is the dominant in vivo loading mode for posterior spinal fixation constructs, and the test environment (ambient, dry) is an accepted surrogate for the in vivo environment for metallic implants under static loading. Expert panel review (three independent biomechanical engineers with spinal implant experience) unanimously concurred that the validation activity is maximally relevant to the COU. The qualitative consensus across geometry, loading, environment, and expert opinion provides strong assurance that the validation evidence is fit for purpose for the stated regulatory submission context, and no significant relevance gaps were identified that would reduce confidence in the model predictions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is acknowledged and accepted on the basis that the single ASTM F1717 load configuration represents the clinically relevant worst-case scenario and is the standard regulatory benchmark for this device class. All three QoIs satisfy the pre-established quantitative acceptance bounds (E/uval < 1.96 and percent difference < 10%). The overall credibility evidence is judged sufficient to support a Medium assurance level conclusion for the non-cannulated 7.5 mm pedicle screw FEA model in the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
