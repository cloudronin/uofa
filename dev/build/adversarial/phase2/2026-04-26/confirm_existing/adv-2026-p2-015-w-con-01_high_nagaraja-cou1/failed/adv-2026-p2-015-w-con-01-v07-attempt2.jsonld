  "signature": "ed25519:b2e3d4f5a6c7b8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022 R2 and Abaqus 2021 are validated commercial solvers with documented QA processes. Internal FDA FEA code undergoes annual regression testing suite.",
      "rationale": "All three FEA platforms in the ensemble carry ISO 9001-compliant QA documentation. The FDA in-house code is covered by a formal software validation plan with regression test records. Achieved level exceeds required level for this medium-risk COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS and ASME V&V 10 suite reproduced within 1% for linear static and contact problems.",
      "rationale": "Each solver in the ensemble was exercised against five NAFEMS benchmark cases covering linear elasticity and frictionless contact. All results fell within the 1% acceptance threshold, confirming adequate code verification at the required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between successive refinement levels; Richardson extrapolation GCI < 5%.",
      "rationale": "A three-level mesh refinement study was conducted on the pedicle screw shank and rod junction regions. The grid convergence index for stiffness was 1.8% and for yield force was 2.4%, both well within the 5% threshold. The final mesh (approx. 480,000 elements, predominantly C3D8R) was adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms converge below 1e-6 for all load steps; no divergence flags observed in solution logs.",
      "rationale": "Nonlinear static analyses used full Newton-Raphson iteration with automatic arc-length control beyond yield. Residual force norms dropped below 1e-7 for all 11 specimen simulations. No load-step bisections exceeded three levels, indicating robust convergence throughout the loading history."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second analyst; documented checklist covering boundary conditions, material assignments, and contact definitions.",
      "rationale": "A peer-review checklist was completed by a second FEA analyst not involved in model construction. Boundary condition assignments, material card selections, and contact pair definitions were independently verified. One minor discrepancy in rod cross-section tolerance was identified and corrected prior to final runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum solid elements with bilinear isotropic hardening adequately represent screw and rod metallic behavior; contact formulation captures load transfer at screw-rod interface.",
      "rationale": "Titanium alloy (Ti-6Al-4V) rod and CoCr screw were modeled with von Mises plasticity and bilinear isotropic hardening calibrated from coupon tensile tests. Penalty-based contact at the screw-rod saddle interface was validated against load-displacement curves from isolated interface tests. The ensemble of three independent models using the same form converged to consistent QoI predictions, supporting model form adequacy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon tests or peer-reviewed literature with documented uncertainty bounds; geometry from calibrated CMM measurements.",
      "rationale": "Elastic modulus and yield strength for each lot were obtained from five uniaxial tensile coupons per material. Geometric dimensions were measured on three representative constructs using a Zeiss CMM with 2 µm accuracy. Input uncertainty was propagated via a 200-sample Latin hypercube study, confirming that output variability attributable to input uncertainty is within the validation uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from at least one production lot; specimens cover the nominal geometry and tolerance range.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from a single production lot and distributed across two independent laboratories (6 + 5 split). Dimensional inspection confirmed all constructs fell within drawing tolerances. The sample size supports the statistical acceptance criterion (E/uval < 1.96) with adequate power for the expected coefficient of variation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate ASTM F1717 protocol including load angle, fixture geometry, and environmental conditions; at least two load levels or configurations tested.",
      "rationale": "Testing was conducted strictly per ASTM F1717 at a single load configuration (compression-bending at 5° off-axis). While both laboratories reproduced the protocol faithfully and inter-laboratory agreement was excellent (CV < 4%), only a single test condition was evaluated. This limits the ability to characterize model behavior across the loading envelope and is the primary reason this factor falls one gradation below the required level. The shortfall is acknowledged in the overall credibility summary and partially offset by the high specimen count and inter-laboratory consistency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters used in simulation are traceable to the same lot and measurement campaign as the physical test specimens.",
      "rationale": "Material cards were populated from tensile coupons machined from the same Ti-6Al-4V rod stock and CoCr screw blanks used for the validation constructs. Geometric parameters in the FEA models were updated to reflect the mean CMM-measured dimensions of the tested constructs, ensuring direct equivalency between simulation inputs and physical test conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all primary QoIs; percent difference < 10% for mean predictions.",
      "rationale": "For all three QoIs (stiffness, yield force, force at 40 mm), the validation metric E/uval was 0.84, 1.21, and 1.07 respectively, all well below the 1.96 threshold. Mean percent differences were 4.1%, 6.8%, and 7.3%. The ensemble spread across the three independent FEA implementations was also within the experimental inter-specimen variability, providing additional confidence in prediction robustness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to the regulatory submission metrics and clinical failure modes of interest.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three quantities required by FDA guidance for pedicle screw 510(k) submissions under ASTM F1717. These QoIs are directly linked to the clinical failure modes of screw breakage and construct loosening. The alignment between simulation outputs and regulatory QoIs is complete, supporting the highest relevance gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Qualitative assessment of the degree to which the validation scenario matches the intended clinical and regulatory context of use, considering geometry, loading, and material representativeness.",
      "rationale": "The validation activities were designed to directly replicate the regulatory submission scenario: the same screw geometry, the same ASTM F1717 protocol, and the same acceptance thresholds used in the 510(k) submission are employed in the validation study. The physical test specimens were drawn from a production lot representative of the commercial device. The two-laboratory design increases generalizability. A qualitative assessment by the credibility assessment team concluded that the validation scenario is highly representative of the COU, covering all major aspects of geometry, loading mode, and material system. No significant gaps between the validation scenario and the intended regulatory use were identified. This holistic judgment, supported by the quantitative output comparison results, underpins the overall Accepted decision. The factor was evaluated through structured expert elicitation rather than a formal gradation scale, reflecting the integrative and contextual nature of this relevance judgment."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed their required gradation levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is offset by the high specimen count, excellent inter-laboratory reproducibility, and the conservative nature of the single-condition ASTM F1717 protocol. All quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%) are satisfied for all three primary QoIs. The credibility assessment team unanimously concludes that the FEA modeling framework is sufficiently credible for its intended regulatory use and the package is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
