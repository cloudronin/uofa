  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022 R2 and FDA in-house FEA solver must demonstrate documented SQA procedures including version control, regression testing, and change management consistent with Gradation 2 or higher.",
      "rationale": "All three FEA platforms (Ansys Mechanical 2022 R2, FDA in-house solver, DePuy Synthes validated solver) operate under documented SQA frameworks. Ansys holds ISO 9001 certification; FDA solver is governed by 21 CFR Part 820 software validation procedures. Regression test suites covering linear statics, contact mechanics, and nonlinear material response were reviewed and found complete. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks must include at least one beam-bending and one contact patch test with documented convergence to analytical solution within 1%.",
      "rationale": "Euler-Bernoulli beam bending and Hertzian contact patch tests were executed for all three solver platforms. Maximum deviation from analytical solutions was 0.4% for beam bending and 0.7% for contact patch, confirming Gradation 2 compliance. No anomalies identified in iterative solver convergence logs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate <2% change in all three QoIs (stiffness, yield force, force at 40 mm) between the production mesh and a mesh with 1.5× element density.",
      "rationale": "A systematic mesh refinement study was conducted using three mesh densities (coarse: 42k elements, medium: 118k elements, fine: 267k elements). The Richardson extrapolation grid convergence index (GCI) for construct stiffness was 0.8%, for yield force 1.1%, and for force at 40 mm displacement 1.4%. All values fall below the 2% acceptance threshold. The production mesh (118k elements) was adopted for all ensemble runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must fall below 1×10^-6 for all load steps; energy balance error must not exceed 0.1% over the full displacement history.",
      "rationale": "Residual convergence histories were reviewed for all 11 model runs across the three solver platforms. All runs achieved force residuals below 1×10^-7 and energy balance errors below 0.05%. No divergence or spurious oscillation events were recorded in the nonlinear contact iterations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be independently reviewed by a second analyst; boundary condition application and material property assignment must be documented in a traceable simulation record.",
      "rationale": "Each of the three FEA teams performed an independent peer review of model setup prior to submission of results. Boundary conditions (fixed inferior vertebral body fixture, axial compressive load applied at 5° caudal angulation per ASTM F1717 §8.3), material assignments (Ti-6Al-4V: E=114 GPa, σ_y=880 MPa; UHMWPE block: E=0.7 GPa), and contact definitions were verified against the shared simulation protocol document. No discrepancies were identified across teams. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected continuum mechanics formulation (linear elastic vs. elastoplastic) must be justified relative to the expected strain regime; contact formulation must be appropriate for the screw-rod and screw-block interfaces.",
      "rationale": "Bilinear elastoplastic material model with isotropic hardening was selected for Ti-6Al-4V based on anticipated strains exceeding 0.8% at yield force. A sensitivity study comparing linear elastic and elastoplastic formulations showed 18% divergence in yield force prediction, confirming the necessity of the nonlinear model. Augmented Lagrangian contact with a friction coefficient of 0.2 (measured via tribometer on as-machined Ti-6Al-4V surfaces) was applied at all metal-metal interfaces. Model form selection is well-justified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties must be sourced from lot-specific coupon testing or published data with documented uncertainty; geometric inputs must be derived from CMM measurements of the test articles.",
      "rationale": "Titanium alloy material properties were obtained from tensile coupon tests (n=5 coupons from the same material lot as the screw blanks): E=113.8±1.2 GPa, σ_y=882±14 MPa, tangent modulus=2.1±0.3 GPa. UHMWPE block properties were taken from ASTM F648 specification values with ±10% uncertainty bounds applied. Geometric inputs were derived from CMM measurements of three representative test constructs, with dimensional tolerances propagated through a Monte Carlo analysis (1000 samples). Input uncertainty contributions to QoI uncertainty were quantified and found to be dominated by friction coefficient variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be production-representative implants assembled per the validated surgical technique guide; sample size must be sufficient to characterize inter-specimen variability (n≥5 per configuration).",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production-lot implants by a trained surgical technician following the DePuy Synthes VIPER system surgical technique guide. Constructs were distributed across two independent laboratories (n=6 at Lab A, n=5 at Lab B) to characterize inter-laboratory variability. Dimensional inspection confirmed all constructs fell within drawing tolerances. The sample size of 11 provides adequate statistical power to detect a 10% QoI difference with 80% power at α=0.05."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate the clinical loading environment; at minimum, two load configurations (compression-bending and torsion) must be evaluated to bound the design space.",
      "rationale": "Testing was conducted exclusively under ASTM F1717 static compression-bending at a single load configuration (5° angulation, monotonic ramp to 40 mm displacement at 5 mm/min). Torsional and fatigue loading conditions were not included in this validation activity. This limitation results in an achieved level of 2, which falls below the required level of 3. The gap is acknowledged and accepted based on the scope of the current submission; supplementary torsional validation is planned for a subsequent COU. The compression-bending mode is the primary failure mode identified in post-market surveillance data and is therefore considered the highest-priority condition for this submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to the experimental test conditions; any systematic differences must be quantified and their impact on QoI assessed.",
      "rationale": "A parameter equivalency table was constructed mapping each experimental measurement (applied load, fixture geometry, construct dimensions, material lot properties) to the corresponding model input. Systematic differences identified: (1) friction coefficient assumed constant at 0.2 in model vs. measured range 0.17–0.24 in tribometer tests — sensitivity study showed ±4% impact on stiffness QoI; (2) UHMWPE block modulus assumed isotropic vs. slight anisotropy in test material — estimated <1% impact. Both differences are within the QoI acceptance bounds and are accounted for in the validation uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval must be below 1.96 for all three QoIs; percent difference between mean FEA prediction and mean experimental result must be below 10%.",
      "rationale": "Validation metric results: (1) Construct stiffness — mean FEA 187.4 N/mm vs. mean experimental 191.2 N/mm (2.0% difference), E/uval = 0.84; (2) Yield force — mean FEA 312.6 N vs. mean experimental 308.9 N (1.2% difference), E/uval = 0.61; (3) Force at 40 mm — mean FEA 445.2 N vs. mean experimental 438.7 N (1.5% difference), E/uval = 0.72. All three QoIs satisfy both acceptance criteria. The validation metric E/uval accounts for model uncertainty, numerical uncertainty, input uncertainty, and experimental measurement uncertainty as combined in quadrature per ASME V&V 40 Section 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected QoIs (stiffness, yield force, force at 40 mm displacement) must be directly traceable to the clinical decision criteria and the regulatory submission requirements.",
      "rationale": "A qualitative assessment of QoI relevance was conducted by the multidisciplinary review team comprising biomechanical engineers, a spine surgeon, and a regulatory affairs specialist. Construct stiffness is directly correlated with load-sharing behavior at the fusion segment and is a recognized surrogate for clinical stability. Yield force represents the onset of permanent deformation, which is the primary failure mode of concern for pedicle screw constructs under physiological loading. Force at 40 mm displacement is the ASTM F1717-mandated comparative metric and provides a standardized basis for regulatory comparison across device generations. The team consensus was that all three QoIs are highly relevant to the COU and collectively bound the clinically meaningful performance space. This factor was evaluated through structured expert elicitation rather than a quantitative scoring matrix, and the outcome of the elicitation supports the overall Accepted decision. No minority opinions were recorded during the review session."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activity (ASTM F1717 bench test) must be demonstrated to be representative of the clinical use environment with documented similarity assessment.",
      "rationale": "A formal similarity assessment was conducted comparing the ASTM F1717 test configuration to the in vivo lumbar spine loading environment. The compression-bending load case represents the dominant loading mode during activities of daily living (standing, walking) as documented in published intradiscal pressure studies. The UHMWPE block surrogate has been validated against cadaveric vertebral body compliance in prior literature. The two-laboratory design of the validation experiment increases confidence in result generalizability. The validation activity is assessed as directly representative of the COU loading conditions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 compression-bending is assessed as credible for the stated COU. All three QoIs satisfy the pre-established acceptance criteria (E/uval < 1.96; percent difference < 10%). Twelve of thirteen credibility factors meet or exceed their required levels. The single factor below required level (Test conditions, achieved 2 vs. required 3) is accepted based on the primacy of compression-bending in the clinical failure mode profile and the planned supplementary torsional validation activity. The overall evidence base is sufficient to support regulatory submission for the non-cannulated design variant.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
