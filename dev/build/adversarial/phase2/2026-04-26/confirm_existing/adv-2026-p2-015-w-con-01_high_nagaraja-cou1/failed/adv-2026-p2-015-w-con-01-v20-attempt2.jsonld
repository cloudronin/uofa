  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework demonstrates sufficient credibility for the stated COU. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3; however, the assessment team accepted this under a risk-informed rationale given that the COU is limited to a single design and single loading scenario, and that all quantitative validation metrics (E/uval < 1.96 for all three QoIs) confirm model accuracy within pre-established acceptance bounds. The overall credibility evidence package supports an Accepted decision at Medium assurance level.",
