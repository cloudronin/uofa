  "signature": "ed25519:9b1c3e7a2f4d6b8c0e2a4f6b8c0e2a4f6b8c0e2a4f6b8c0e2a4f6b8c0e2a4f",
  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nagaraja-cou1-vr-stiffness",
      "type": "ValidationResult",
      "name": "Construct stiffness QoI comparison — FEA vs. bench (N=11)",
      "description": "FEA-predicted construct stiffness compared to experimental values across 11 non-cannulated 7.5 mm pedicle screw constructs. Mean absolute percentage error 4.3%; E/uval = 1.41 < 1.96 acceptance threshold."
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-cou1-vr-yieldforce",
      "type": "ValidationResult",
      "name": "Yield force QoI comparison — FEA vs. bench (N=11)",
      "description": "FEA-predicted yield force compared to experimental values. Mean absolute percentage error 6.8%; E/uval = 1.62 < 1.96 acceptance threshold. All 11 constructs within 10% bound."
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-cou1-vr-force40mm",
      "type": "ValidationResult",
      "name": "Force at 40 mm displacement QoI comparison — FEA vs. bench (N=11)",
      "description": "FEA-predicted force at 40 mm displacement compared to experimental values. Mean absolute percentage error 5.1%; E/uval = 1.55 < 1.96 acceptance threshold."
    }
  ],
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (achievedLevel >= requiredLevel).",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated FEA solver with documented V&V procedures. FDA-internal Python pre/post-processing scripts are version-controlled in Git with unit tests covering >85% of code paths. DePuy Synthes in-house solver version 4.1.2 was verified against NAFEMS benchmarks. SQA documentation package reviewed and found complete. Achieved Gradation 3 against a required Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Ansys solver verified against NAFEMS LE1, LE10, and NL1 benchmarks with errors <1%. Contact algorithm verified using Hertzian contact analytical solution. Residual convergence criterion set to 1e-4 for force and moment norms, confirmed sufficient via sensitivity study. Required and achieved levels both at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed on screw shank and rod-screw interface regions. Three mesh densities evaluated (coarse: 0.8 mm, medium: 0.5 mm, fine: 0.3 mm global element size). Richardson extrapolation applied; GCI for stiffness QoI = 0.7%, yield force QoI = 1.1%. Final mesh uses medium density with local refinement at stress concentrations. Exceeds required Gradation 2; achieved Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Nonlinear solver uses full Newton-Raphson with line search. Time-step sensitivity study confirmed that halving the load increment changes QoIs by <0.3%. Energy balance checked at each converged increment; energy error <0.1%. Solver log reviewed for any unconverged increments — none found across all 11 model runs. Achieved Gradation 2 against required Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Modeling protocol document (MPD-001 Rev C) defines all analyst decisions including boundary condition application, contact pair definition, and material property assignment. Independent peer review of model setup performed by second analyst not involved in original construction. Checklist-based review confirmed all 47 MPD items satisfied. No use errors identified. Required and achieved levels both at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Continuum solid mechanics with J2 plasticity (isotropic hardening) selected for Ti-6Al-4V screw and rod. Frictional contact (mu=0.3) modeled at all screw-rod interfaces based on published tribological data for titanium alloy couples. Large-deformation formulation (NLGEOM ON) active to capture geometric nonlinearity at 40 mm displacement. Model form justified by published literature on metallic implant FEA and confirmed by validation results. Achieved Gradation 3 against required Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (E=114 GPa, nu=0.34, sigma_y=880 MPa, tangent modulus=2.1 GPa) sourced from ASTM F136 coupon testing on same material lot as test constructs. Geometry derived from CAD nominal dimensions with dimensional inspection confirming <0.05 mm deviation from nominal for all 11 constructs. Torque preload on set screws measured and applied as equivalent pretension in model. Required and achieved levels both at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA/CDRH and DePuy Synthes R&D). All constructs from same production lot; dimensional inspection and material certification provided. Inter-laboratory variability assessed; coefficient of variation <4% for all three QoIs, confirming reproducibility. Sample size exceeds minimum recommended by ASTM F1717. Achieved Gradation 3 against required Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level. NOTE: This factor does not meet the required level; accepted under risk-informed rationale per team consensus.",
      "rationale": "Testing performed under a single loading condition (ASTM F1717 static compression-bending at standard geometry). Only one test condition explored; no variation in loading rate, temperature, or construct geometry offset. This limits generalizability but is consistent with the COU scope (single design, single loading scenario). The model risk level 3 and medium assurance level were set in part to account for this limitation. Achieved Gradation 2 against required Gradation 3; accepted by team as the COU does not require multi-condition validation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA model inputs directly traceable to experimental specimen measurements. Screw geometry from CMM inspection of test articles; rod diameter and modulus from material certificates for test lot. Set screw torque applied in test (4 Nm) replicated as pretension boundary condition. UHMWPE block fixture geometry measured and replicated in model. One-to-one correspondence confirmed between all experimental boundary conditions and model inputs. Required and achieved levels both at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantitative comparison performed using ASME V&V 40 validation metric E/uval for all three QoIs. Experimental uncertainty estimated from inter-specimen variability and instrument calibration uncertainty (load cell ±0.5%, displacement ±0.1 mm). E/uval values: stiffness 1.41, yield force 1.62, force at 40 mm 1.55 — all below 1.96 threshold. Additionally, full load-displacement curves compared graphically; FEA captures pre-yield stiffness, yield knee, and post-yield behavior. Achieved Gradation 3 against required Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Qualitative assessment of QoI relevance to clinical and regulatory decision-making.",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — are directly specified in ASTM F1717 and are the regulatory submission endpoints for static compression-bending characterization of spinal implant constructs. Construct stiffness reflects load-sharing behavior in vivo; yield force is the primary safety endpoint indicating onset of permanent deformation; force at 40 mm displacement captures post-yield energy absorption relevant to catastrophic failure risk. All three QoIs are clinically meaningful and directly support the intended regulatory use. The assessment team conducted a structured qualitative review of QoI relevance against the clinical risk model and ASTM F1717 rationale documentation, concluding that the selected QoIs provide comprehensive coverage of the mechanical performance envelope relevant to the COU. No additional QoIs were identified as necessary for the scope of this validation activity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities directly replicate the COU: ASTM F1717 static compression-bending of a non-cannulated 7.5 mm pedicle screw construct at the same geometry, loading configuration, and boundary conditions as the regulatory submission scenario. Both laboratories used calibrated test frames with NIST-traceable calibration certificates. The validation domain is coincident with the COU domain — no extrapolation required. Achieved Gradation 3 against required Gradation 2."
    }
  ],
