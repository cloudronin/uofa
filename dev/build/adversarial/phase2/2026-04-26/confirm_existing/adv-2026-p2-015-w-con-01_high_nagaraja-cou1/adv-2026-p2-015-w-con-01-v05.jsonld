  "signature": "ed25519:b7e3d2c1f0a9847563d2e1f0c9b8a7d6e5f4c3b2a1908f7e6d5c4b3a2918f7e6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All simulation software (Ansys Mechanical 2022 R2) under configuration management; FDA-validated solver version documented; regression test suite executed with zero critical failures.",
      "rationale": "The FEA ensemble employs Ansys Mechanical 2022 R2 under a documented software quality plan (SQP) compliant with FDA guidance on software validation. Version control is maintained via Git with tagged release commits. Regression tests covering linear-elastic and contact-nonlinear benchmarks were executed prior to study commencement, with all critical tests passing. SQP documentation reviewed and approved by the quality assurance group."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks demonstrate convergence to analytical solutions for beam bending and contact problems; order-of-accuracy test passed.",
      "rationale": "Ansys Mechanical has been verified against NAFEMS standard benchmarks and ASME V&V 10 benchmark problems for structural mechanics. Order-of-accuracy testing for linear elastic beam bending confirmed second-order spatial convergence. Contact mechanics benchmarks (Hertz contact, flat punch) showed agreement within 0.5% of analytical solutions. No code-level defects affecting the current COU were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinement levels; Richardson extrapolation GCI < 5%.",
      "rationale": "A systematic mesh convergence study was conducted using three refinement levels (coarse: ~85k elements, medium: ~210k elements, fine: ~520k elements). Stiffness QoI varied by 1.3% between medium and fine meshes. Richardson extrapolation yielded a Grid Convergence Index of 2.1% for stiffness and 3.4% for yield force, both within the 5% acceptance threshold. The medium mesh was selected for production runs to balance accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear solver residual convergence criteria tighter than 1e-4 for force and displacement norms; no divergence events recorded across all 11 model instances.",
      "rationale": "Nonlinear Newton-Raphson iterations were run to convergence tolerances of 1e-5 (force norm) and 1e-4 (displacement norm) for all 11 construct configurations. Automatic time-stepping with a minimum substep of 1/500 was employed. No solver divergence or unconverged substeps were recorded. Contact stabilization energy was monitored and remained below 0.1% of total strain energy in all cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented modeling procedure with independent peer review; boundary condition and material assignment verified by second analyst.",
      "rationale": "A formal modeling procedure document was prepared prior to analysis, specifying boundary conditions, material property assignments, contact pair definitions, and load application methods. An independent analyst reviewed all model setups against the procedure document and signed off prior to solution runs. No discrepancies were identified. The procedure document is version-controlled and archived with the simulation package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic constitutive model with isotropic hardening validated against coupon data; geometric nonlinearity enabled; contact formulation appropriate for screw-rod interface.",
      "rationale": "The pedicle screw construct is modeled using a continuum finite-deformation elastic-plastic formulation with isotropic hardening calibrated to titanium alloy (Ti-6Al-4V) coupon tensile test data. Geometric nonlinearity (large deformation) is enabled, which is appropriate given the 40 mm displacement endpoint. Augmented Lagrangian contact with friction (mu=0.3) is applied at the screw-rod interface, consistent with published literature for metallic implant contacts. The model form was reviewed and deemed appropriate for the COU by the modeling team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM-certified coupon tests on production lot material; geometric inputs from CMM measurements of production screws; uncertainty bounds documented.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and hardening parameters were derived from tensile coupon tests on three specimens from the same production lot as the tested constructs, per ASTM E8. Geometric dimensions were obtained from coordinate measuring machine (CMM) measurements of five representative screws, with mean values used as nominal inputs. Uncertainty in material properties (±3% on yield strength) and geometry (±0.05 mm on critical dimensions) was propagated through a sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lot; sample traceability documented; dimensional inspection confirms conformance to drawing.",
      "rationale": "Eleven constructs were assembled from production-lot non-cannulated 7.5 mm pedicle screws and standard titanium rods. All components were traceable to manufacturing lot records. Dimensional inspection of five randomly selected screws confirmed conformance to engineering drawing within specified tolerances. Constructs were assembled by a trained technician following the manufacturer's surgical technique guide, and assembly torque was recorded for each construct."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two load levels or configurations representative of the COU; environmental conditions documented.",
      "rationale": "Testing was conducted under a single load configuration (ASTM F1717 standard compression-bending fixture) at ambient laboratory conditions (23±2°C, 50±10% RH) across two independent laboratories. While inter-laboratory reproducibility is demonstrated, only a single test condition (standard F1717 setup) was employed, limiting the breadth of condition coverage. This factor is assessed below the required level; however, the single condition directly corresponds to the regulatory submission context, and the inter-laboratory confirmation partially mitigates the limitation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model boundary conditions and material inputs demonstrably equivalent to experimental setup; fixture geometry replicated in FEA.",
      "rationale": "The ASTM F1717 fixture geometry was replicated in the FEA model using CAD drawings of the test fixture, verified against physical measurements. Displacement-controlled loading was applied in the model consistent with the test machine control mode. Friction coefficients at fixture-construct interfaces were estimated from literature and confirmed insensitive via sensitivity analysis (±50% change in friction produced <1% QoI change). Material inputs were matched to the same production lot used in testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percent difference < 10% for all three QoIs across all 11 constructs.",
      "rationale": "Quantitative output comparison was performed for all three QoIs (stiffness, yield force, force at 40 mm displacement) across all 11 constructs. The validation metric E/uval (where E is the model-experiment difference and uval is the combined validation uncertainty) was below 1.96 for all QoI-construct combinations. Maximum percent difference was 7.8% (yield force, construct 9). All acceptance criteria were met, supporting the Accepted outcome."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest evaluated in the validation study are assessed for their direct relevance to the clinical and regulatory decision context through a structured expert elicitation process documented in the credibility assessment report.",
      "rationale": "A qualitative assessment of QoI relevance was conducted through structured expert elicitation involving three subject matter experts (biomechanical engineer, regulatory affairs specialist, and orthopedic surgeon consultant). The panel confirmed that construct stiffness, yield force, and force at 40 mm displacement are the clinically and regulatorily meaningful endpoints for pedicle screw construct performance under ASTM F1717 loading. The panel noted that these QoIs directly correspond to the failure modes of concern (permanent deformation and fracture) and are the metrics reviewed by FDA in 510(k) submissions for spinal implants. The elicitation was documented in a structured meeting summary and is considered sufficient to establish QoI relevance for this COU without recourse to a formal numerical gradation, as the expert consensus was unambiguous and well-documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities directly replicate the regulatory submission test (ASTM F1717); validation domain fully encompasses the COU domain.",
      "rationale": "The validation activities are directly aligned with the COU: the same FEA modeling framework, the same device design, and the same test standard (ASTM F1717) are used in both the validation study and the intended regulatory submission context. The validation domain (non-cannulated 7.5 mm screw, standard rod, F1717 compression-bending) fully encompasses the COU domain. No extrapolation beyond the validated domain is required for the intended use."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve of thirteen factors met or exceeded their required credibility levels. The Test conditions factor was assessed one gradation below the required level due to the use of a single test configuration; however, this shortfall is mitigated by inter-laboratory confirmation across two independent test sites and the direct correspondence of the single condition to the regulatory submission context. The output comparison factor confirmed that all quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%) were met for all QoIs across all 11 constructs. On balance, the team concludes that the simulation evidence is sufficiently credible to support the intended regulatory use, and the package is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
