  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release notes and regression test suite passing at the version used for all simulations.",
      "rationale": "ANSYS Fluent 2022R2 is used under institutional license with version-controlled case files stored in Git. Regression tests confirm solver version consistency across all five operating-point simulations. Required gradation 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using method of manufactured solutions or benchmark problems must confirm solver spatial discretization order consistent with documented scheme.",
      "rationale": "Second-order upwind spatial discretization is verified against the lid-driven cavity benchmark at Re=1000 and the Taylor–Green vortex. Observed order of accuracy of 1.92 is consistent with the nominal second-order scheme. Required gradation 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the hemolysis index quantity of interest must be less than 5% across all five operating points.",
      "rationale": "Three-level mesh refinement study performed on the FDA generic pump geometry (coarse 2.1 M, medium 5.8 M, fine 14.7 M cells). GCI values for normalised hemolysis index range from 1.8% to 4.1% across operating points, all below the 5% threshold. Required gradation 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with measured inlet flow rates, rotational speeds, and fluid properties within ±5% of CFD boundary conditions.",
      "rationale": "FDA inter-laboratory hemolysis dataset documents inlet flow rates (2–7 L/min), rotational speeds (2000–3500 RPM), and blood analogue viscosity to within 3% of CFD boundary conditions. Traceability of all five operating points is confirmed. Required gradation 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalised index of hemolysis (NIH) must agree with experimental mean within two experimental standard deviations at all five operating points.",
      "rationale": "CFD-predicted NIH values fall within two experimental standard deviations of the FDA inter-laboratory mean at all five operating points. Maximum normalised residual is 1.6σ at the 3500 RPM / 2 L/min condition. Required gradation 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modelled quantity of interest (relative hemolysis index RH) must be directly linked to the clinical endpoint (plasma-free haemoglobin elevation) through a documented mechanistic pathway.",
      "rationale": "The relative hemolysis index RH is derived from the power-law Giersiepen–Wurzinger model applied to CFD-resolved shear stress histories. The mechanistic link from shear-induced erythrocyte damage to plasma-free haemoglobin elevation is documented in the modelling report. Required gradation 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same device geometry class, operating regime, and fluid as the COU, or deviations must be explicitly bounded.",
      "rationale": "Validation uses the FDA generic centrifugal pump, which is the same device class and geometry as the COU device. Blood analogue fluid (glycerol–water at matched viscosity) is used in experiments; deviation from whole blood rheology is bounded by sensitivity analysis showing less than 8% change in NIH. Required gradation 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal iterative convergence monitoring is sufficient; residual-based solver error quantification beyond standard convergence criteria is not required.",
      "rationale": "Solver residuals for continuity, momentum, and turbulence quantities are reduced by at least four orders of magnitude in all simulations. Formal iterative error quantification beyond residual monitoring is not required at MRL 2 and has not been performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documented simulation setup review by a second analyst is sufficient; formal use-error FMEA is not required.",
      "rationale": "Simulation setup files were reviewed by a second CFD analyst prior to production runs. Formal use-error failure mode and effects analysis is not required at MRL 2 and has not been conducted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, selection of turbulence and hemolysis sub-models with literature justification is sufficient; formal model-form uncertainty quantification is not required.",
      "rationale": "The SST k-ω turbulence model and Giersiepen–Wurzinger hemolysis model are selected based on published comparative studies for rotary blood pumps. Formal model-form uncertainty quantification is not required at MRL 2 and has not been performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are sufficient; probabilistic input uncertainty propagation is not required.",
      "rationale": "All boundary condition inputs (flow rate, rotational speed, fluid viscosity, geometry dimensions) are specified at nominal values with documented measurement sources. Probabilistic uncertainty propagation through model inputs is not required at MRL 2 and has not been performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, use of a single well-characterised test article with documented provenance is sufficient; statistical sampling across multiple device units is not required.",
      "rationale": "Validation experiments used a single FDA generic pump test article fabricated to published dimensional specifications. Statistical sampling across multiple manufactured units is not required at MRL 2 and has not been performed."
