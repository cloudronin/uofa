      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification tests and a traceable release history consistent with MRL 2 requirements.",
      "rationale": "The ANSYS Fluent solver version 2022R2 is used under a documented quality management plan. Release notes, regression test suite, and change logs are archived. Achieved level 2 meets the required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method-of-manufactured-solutions or equivalent benchmark at MRL 2.",
      "rationale": "Lid-driven cavity and Poiseuille flow benchmarks confirm second-order spatial accuracy. Published ANSYS verification manual results corroborate implementation correctness at the required gradation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for shear stress scalar must be below 5% on the finest mesh used for hemolysis predictions.",
      "rationale": "Three-mesh Richardson extrapolation yields GCI of 3.1% for volume-averaged shear stress and 2.8% for the hemolysis power-law scalar. Both are within the 5% acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental flow rates, rotational speeds, and fluid properties used in validation must match simulated boundary conditions within stated uncertainty bounds.",
      "rationale": "FDA pump experimental dataset specifies flow rates of 2.5–6 L/min and speeds of 2000–3500 RPM. Boundary conditions in the CFD model are set to match reported values; fluid viscosity and density match blood analog within 2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within combined experimental and simulation uncertainty at all 5 operating points.",
      "rationale": "NIH predictions fall within ±15% of experimental values at all 5 operating points, consistent with combined uncertainty. The relative hemolysis index RH remains below 1.0 for all worst-case configurations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantity of interest (relative hemolysis index RH) must be directly linked to the clinical risk metric and the regulatory acceptance criterion.",
      "rationale": "RH is derived from the power-law hemolysis model and is the direct comparator to the predicate device. It maps unambiguously to the clinical endpoint of plasma-free hemoglobin elevation and is the accepted metric in FDA guidance for CPB hemolysis assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use a geometrically similar pump operated within the COU flow-speed envelope and with the same blood analog fluid.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry, which shares impeller topology with the device under assessment. Operating conditions span the COU envelope. The glycerol-water blood analog used in experiments matches that specified for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when solver is commercially validated and residual convergence is documented.",
      "rationale": "MRL 2 does not require explicit quantification of iterative solver error beyond residual monitoring. Residuals converge to 1e-5 for all equations. Formal iterative error quantification is scoped to MRL 3 and above."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this device class when analyst training records are on file.",
      "rationale": "Analyst training and simulation setup review records are maintained in the quality system. Independent use-error audit is not mandated at MRL 2 for Class II devices; scoped out per project risk plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis constitutive law must be justified by prior literature and sensitivity analysis for centrifugal pump hemolysis at the COU operating conditions.",
      "rationale": "The SST k-omega turbulence model is selected based on published centrifugal pump hemolysis literature. Sensitivity analysis comparing SST k-omega, realizable k-epsilon, and RSM shows less than 8% variation in RH, confirming robustness of the model form choice."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometric dimensions, and boundary condition values must be traceable to measurement data or published references with stated uncertainty.",
      "rationale": "Pump geometry is derived from FDA-published CAD files. Blood analog properties are taken from ASTM F1841 with stated tolerances. Inlet velocity profiles are derived from upstream flow conditioning measurements. All inputs are documented in the simulation data package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when validation relies on published FDA benchmark dataset with documented sample provenance.",
      "rationale": "The FDA generic pump dataset is a publicly archived benchmark with documented experimental protocols. Independent test sample characterization is not required at MRL 2 when using this reference dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
