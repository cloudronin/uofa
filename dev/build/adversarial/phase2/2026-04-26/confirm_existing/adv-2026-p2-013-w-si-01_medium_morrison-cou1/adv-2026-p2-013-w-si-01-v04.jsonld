      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented QA plan with version control and regression testing for CFD solver.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented QA procedures including version-controlled releases and regression test suites. Internal QA documentation confirms compliance with required level 2 practices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark verification cases relevant to internal flow.",
      "rationale": "ANSYS Fluent has been verified against standard lid-driven cavity and pipe-flow benchmarks. Published verification documentation from the vendor and independent literature confirms numerical accuracy of the solver for laminar and turbulent internal flow regimes applicable to the pump geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for shear-stress-derived hemolysis index on the finest two mesh levels.",
      "rationale": "A three-level mesh refinement study was conducted. GCI values for the power-law hemolysis index were 3.8% between medium and fine meshes, satisfying the acceptance criterion. The fine mesh (12.4 million cells) was adopted for all production simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match CFD boundary conditions within ±5%.",
      "rationale": "FDA benchmark experimental data were collected at five flow-rate/speed combinations. CFD boundary conditions were set to match reported experimental values. Fluid viscosity and density were matched to the bovine blood surrogate used in experiments, with all deviations less than 3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) within 25% of experimental mean across all five operating points.",
      "rationale": "Predicted NIH values were compared against published FDA experimental means. Maximum deviation across five operating points was 18.4%, with a mean absolute error of 11.2%, satisfying the 25% acceptance criterion. Worst-case operating condition was correctly ranked in all comparisons."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) is directly linked to the clinical hemolysis endpoint and the regulatory acceptance criterion.",
      "rationale": "The relative hemolysis index RH = NIH_device / NIH_predicate directly maps to the regulatory comparison framework. This QoI captures the hemolytic potential difference between the candidate and predicate device and is the quantity used in the submission acceptance criterion (RH < 1)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions sufficiently represent COU device and operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which shares geometric topology with the candidate CPB device. Operating conditions span the clinical flow-speed envelope. Fluid properties match clinical blood analogue. The validation scenario is judged sufficiently representative of the COU for MRL 2."
    },
    {
