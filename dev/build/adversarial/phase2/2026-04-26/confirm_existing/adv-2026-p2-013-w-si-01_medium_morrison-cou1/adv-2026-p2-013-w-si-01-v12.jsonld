  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented and version-controlled; basic regression tests must pass for the release used.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a validated institutional license. Version control records and release notes confirm no open defects affecting rotating-zone hemolysis simulations. Regression suite passed for all relevant physics modules."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on manufactured solution must confirm solver achieves at least second-order spatial convergence for the scalar transport equation used in hemolysis accumulation.",
      "rationale": "Method of manufactured solutions applied to the power-law hemolysis transport equation on three systematically refined grids. Observed order of accuracy was 1.97, consistent with the second-order upwind discretisation scheme selected. Verification report VR-2024-003 on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the normalised index of hemolysis (NIH) must be below 5% on the medium grid used for production runs.",
      "rationale": "Richardson extrapolation performed on coarse (4.2 M), medium (9.8 M), and fine (22.1 M) cell polyhedral meshes. GCI on the medium grid was 3.1% for NIH at the design operating point, satisfying the 5% threshold. Medium grid adopted for all production COU simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) must be reproduced in simulation to within measurement uncertainty.",
      "rationale": "Five operating points from the FDA benchmark dataset were replicated. Inlet flow rates were matched to within 0.5% of measured values; rotational speed was set to the logged encoder value ±0.2 RPM. Fluid temperature was held at 37 °C consistent with test protocol. Boundary condition fidelity confirmed in simulation setup log SL-2024-011."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must agree with experimental NIH within ±25% across all five operating points; pressure-head predictions must fall within ±10% of measured values.",
      "rationale": "NIH predictions ranged from −18% to +22% relative to experimental values across the five operating points, satisfying the ±25% band. Pressure-head predictions were within ±7%. Worst-case hemolysis operating point (2500 RPM, 6 L/min) correctly identified as highest NIH in both experiment and simulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The model QoI (NIH and relative hemolysis index RH) must be directly mappable to the clinical decision criterion (RH < 1 vs. predicate device).",
      "rationale": "NIH is the standard in vitro hemolysis metric per ASTM F1841. RH is derived directly from NIH ratios between candidate and predicate device simulations. The acceptance criterion RH < 1 is a regulatory standard for Class II CPB submissions. QoI relevance confirmed by clinical consultant review documented in CR-2024-007."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry family, blood analogue fluid, and overlapping operating range as the COU device.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry, which shares the same impeller-volute topology as the COU device. Glycerol-water blood analogue (viscosity 3.5 mPa·s) was used in both validation and COU experiments. Operating range (2000–3000 RPM, 3–8 L/min) fully encompasses the COU operating envelope. Relevance assessment documented in RA-2024-002."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to be monitored; residuals below 1e-5 for all transport equations.",
      "rationale": "At MRL 2, explicit quantification of numerical solver error beyond convergence monitoring is not required. Residuals were monitored and confirmed below 1e-5 for all simulations; no further formal assessment is required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a second analyst; checklist completed.",
      "rationale": "At MRL 2, a full use-error analysis is not required. A peer review checklist was completed by a second CFD analyst confirming boundary condition and material property inputs. No systematic use errors were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form selection (turbulence model, hemolysis constitutive law) must be justified by literature precedent.",
      "rationale": "At MRL 2, formal model form uncertainty quantification is not required. The SST k-ω turbulence model and Giersiepen power-law hemolysis model were selected based on published FDA benchmark studies. Justification documented in model selection note MSN-2024-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Nominal values for all material properties and boundary conditions must be sourced from traceable references.",
      "rationale": "At MRL 2, sensitivity analysis of model inputs is not required. All material properties (density, viscosity) and hemolysis model constants were taken from published literature with traceable citations listed in input data sheet IDS-2024-004. No formal uncertainty propagation was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test samples used in validation experiments must be representative of the manufactured device population.",
      "rationale": "At MRL 2, statistical characterisation of the test sample population is not required. The FDA generic pump geometry is a defined reference geometry; dimensional inspection confirmed the test article was within 0.05 mm of nominal for all critical features. Documentation on file as DI-2024-009."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters in the validation model must be shown to be equivalent to those in the COU model within acceptable tolerance.",
      "rationale": "At MRL 2, a formal equivalency analysis between validation and COU input parameters is not required. Qualitative review confirmed that fluid properties, rotational speed range, and geometric scaling are consistent between validation and COU contexts. Review note RN-2024-005 on file."
    }
