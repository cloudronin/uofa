    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with measured values within combined simulation and experimental uncertainty at all 5 operating points.",
      "rationale": "CFD-predicted NIH values fall within the expanded uncertainty band (k=2) of experimental measurements at all 5 operating points. Maximum normalized residual is 0.18, well within the acceptance criterion. The Giersiepen power-law hemolysis model was calibrated to the test fluid."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear stress distribution, relative hemolysis index RH) must be directly traceable to the clinical decision criterion RH < 1.",
      "rationale": "The primary QoI is the relative hemolysis index RH, computed as the ratio of device NIH to predicate NIH. This quantity is directly used in the regulatory acceptance criterion (RH < 1) and is the output of both the CFD model and the bench experiments, ensuring full relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
