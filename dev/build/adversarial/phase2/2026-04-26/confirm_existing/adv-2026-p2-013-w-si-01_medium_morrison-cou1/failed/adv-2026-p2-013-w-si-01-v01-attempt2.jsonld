      "acceptanceCriteria": "CFD solver must be documented under a quality management system with version control and regression testing at Gradation 2.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is maintained under ISO 9001-compliant QMS with documented version control, regression test suite, and release notes. Achieved level meets required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or benchmark comparison at Gradation 2.",
      "rationale": "Numerical code verification performed via benchmark comparison against analytical Poiseuille flow and lid-driven cavity solutions. Residuals converge to machine precision. Gradation 2 requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified and shown to be below 5% of the quantity of interest at Gradation 2.",
      "rationale": "Richardson extrapolation applied across three systematically refined meshes (2.1M, 6.8M, 18.4M cells). Grid convergence index for wall shear stress QoI is 1.8%, below the 5% threshold. Achieved Gradation 3 exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to reproduce boundary conditions in the CFD model at Gradation 2.",
      "rationale": "FDA experimental dataset provides flow rate, rotational speed, fluid temperature, and hematocrit for all 5 operating points. Boundary conditions reproduced in CFD with documented mapping. Test conditions factor meets Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric between simulation output and experimental measurement must be defined and evaluated at Gradation 2.",
      "rationale": "Normalized index of hemolysis (NIH) compared between CFD predictions and experimental measurements across 5 operating points. Mean absolute error is 12.3%, within accepted tolerance for hemolysis modeling at MRL 2. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the clinical decision (hemolysis identification) at Gradation 2.",
      "rationale": "Primary QoI is the relative hemolysis index (RH) derived from NIH, directly linked to the clinical acceptance criterion RH < 1. Secondary QoIs include shear stress distribution and scalar stress exposure, both mechanistically linked to red blood cell damage. Relevance established at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
