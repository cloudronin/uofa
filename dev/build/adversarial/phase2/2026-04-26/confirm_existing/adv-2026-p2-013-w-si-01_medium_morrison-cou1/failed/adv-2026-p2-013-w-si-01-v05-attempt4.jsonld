      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty assessment not required at MRL 2 for this factor.",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2. The power-law hemolysis model (Giersiepen et al.) is the accepted standard for CFD hemolysis prediction in regulatory submissions at this risk level."
    },
    {
