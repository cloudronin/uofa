      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan meeting MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is operated under a documented software quality assurance plan including version control, regression testing, and installation qualification records. QA level meets the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations at MRL 2.",
      "rationale": "Numerical code verification was performed using manufactured solutions for the Navier-Stokes equations and power-law hemolysis transport. Order-of-accuracy tests confirm second-order spatial convergence consistent with solver documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified and shown to be acceptable relative to simulation outputs at MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted on the baseline pump geometry. Richardson extrapolation yielded a grid convergence index (GCI) of less than 2.1% for the hemolysis index at all five operating points, exceeding the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be sufficiently documented and representative of the COU at MRL 2.",
      "rationale": "FDA generic centrifugal pump bench experiments were conducted under controlled conditions (37 °C, bovine blood analog, ISO 10628 flow loop). Test conditions are documented in the FDA critical path study report and are representative of CPB operating conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared to experimental measurements using an appropriate quantitative metric at MRL 2.",
      "rationale": "Normalized index of hemolysis (NIH) predictions are compared against experimental measurements across five flow-speed combinations. Mean absolute relative error is 8.3%, within the 15% acceptance threshold established for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation must be directly relevant to the clinical decision at MRL 2.",
      "rationale": "The primary QoI is the relative hemolysis index (RH) comparing candidate pump geometry to the predicate device. RH directly supports the worst-case hemolysis acceptance criterion (RH < 1) and is clinically relevant to CPB device assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the same flow regime, geometry class, and hemolysis mechanisms present in the COU at MRL 2.",
      "rationale": "Validation experiments were performed on the FDA generic centrifugal pump, which shares rotodynamic operating principles, Reynolds number regime, and blood-contacting surface characteristics with the CPB device under assessment. Validation activities are judged sufficiently relevant to the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Numerical solver error assessment not required at MRL 2 for this factor.",
      "rationale": "At MRL 2, explicit quantification of iterative solver error beyond residual convergence monitoring is not required. Residuals were converged to 1e-5 for all equations; no further assessment is necessary."
    },
