      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control and regression test suite consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 used under ISO 9001-certified QMS. Regression tests covering turbulent pipe flow and rotating reference frame cases passed. Version locked in simulation archive. Achieved level 1 meets required level 1 for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
