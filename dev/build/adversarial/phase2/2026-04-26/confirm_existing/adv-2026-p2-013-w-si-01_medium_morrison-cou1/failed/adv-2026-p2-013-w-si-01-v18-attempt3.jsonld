      "factorStatus": "assessed",
      "acceptanceCriteria": "Code must demonstrate correct implementation of governing equations via benchmark problems at MRL 2 level 1.",
      "rationale": "Solver verified against ASME V&V 20 benchmark cases for incompressible rotating flow. Method of manufactured solutions applied to scalar transport equation used in hemolysis model. All residuals converged to 1e-6. Level 1 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for normalized hemolysis index must be below 5% on the fine mesh at required level 2.",
      "rationale": "Three-mesh Richardson extrapolation performed on 4.2M, 8.7M, and 17.1M cell meshes. GCI on normalized hemolysis index = 3.1% (fine mesh). Apparent order of convergence p = 1.94, consistent with second-order scheme. Level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match simulation inlet/outlet conditions within 3% for flow rate and rotational speed.",
      "rationale": "In-vitro test loop calibrated with NIST-traceable flow meters (±1.5%). Rotational speed controlled via servo drive with ±0.2% accuracy. Five operating points (2–6 L/min, 2000–3500 RPM) replicated in CFD to within 2.1% on flow and 0.8% on speed. Level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized hemolysis index predictions must agree with experimental measurements within combined simulation and measurement uncertainty bands at all 5 operating points.",
      "rationale": "CFD-predicted normalized hemolysis index compared against modified index of hemolysis measurements across 5 operating points. All predictions fall within expanded uncertainty bands (k=2). Maximum relative error 8.4% at 6 L/min / 3500 RPM; within combined uncertainty of 11.2%. Level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QOI (normalized hemolysis index) must be directly linked to the COU decision QOI (relative hemolysis index RH) with documented mapping.",
      "rationale": "Normalized hemolysis index from validation experiments is algebraically related to the relative hemolysis index used in the COU acceptance criterion (RH < 1). Mapping documented in model report Section 4.2. Both QOIs derived from same Lagrangian stress-accumulation model. Level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating envelope must overlap with COU geometry and operating envelope; any extrapolation documented and bounded.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry identical to COU device geometry. Operating points span the COU envelope (2–6 L/min, 2000–3500 RPM). No extrapolation required. Fluid (bovine blood analog, 37% hematocrit) representative of clinical CPB conditions. Level 2 achieved."
    },
