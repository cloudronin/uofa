      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release validation at Gradation 1 or above.",
      "rationale": "ANSYS Fluent 2022 R2 was used with full vendor QA documentation including regression test suite results, ISO 9001-certified release process, and internal audit trail. Achieved level exceeds the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
