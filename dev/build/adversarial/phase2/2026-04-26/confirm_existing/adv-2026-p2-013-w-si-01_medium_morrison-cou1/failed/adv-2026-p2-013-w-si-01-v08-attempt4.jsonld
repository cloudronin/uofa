      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases at Gradation 1 or above.",
      "rationale": "Solver verified against ASME V&V 20 benchmark cases for incompressible internal flow. Manufactured solution tests confirmed second-order spatial accuracy. Published verification reports accompany the solver release."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
