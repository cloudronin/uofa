  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; six factors were flagged as not-assessed due to data availability limitations at MRL 5. Despite multiple gaps between achieved and required levels — most critically model form (achieved 2, required 5) and equivalency of input parameters (achieved 2, required 5) — the team accepted the package on the basis that the Monte Carlo UQ bounds remain below the clinical hemolysis threshold at the 95th percentile across all assessed operating points, and that the identified gaps are documented for resolution in the next design iteration. Acceptance is conditional on completion of model-form uncertainty quantification prior to regulatory submission.",
