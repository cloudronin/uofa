  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite with regression testing and version-controlled source; all simulation scripts under configuration management.",
      "rationale": "Solver (OpenFOAM v9) has documented regression test suite and is version-controlled. However, hemolysis post-processing scripts lack formal configuration management and independent code review, yielding achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent analytical benchmark must confirm solver order-of-accuracy for both flow and scalar transport equations.",
      "rationale": "MMS verification confirmed second-order spatial accuracy for momentum and pressure. Scalar transport (hemolysis power-law) verified against analytical solution for simple shear flow only; rotating impeller geometry not independently verified, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI for NIH QoI must be below 5% on the production mesh; Richardson extrapolation must be applied.",
      "rationale": "Three-level mesh refinement study yields GCI of 3.2% for NIH on the fine production mesh. Richardson extrapolation applied; asymptotic range confirmed (ratio 0.98). Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, pump speed, flow rate, temperature) must be documented with uncertainty bounds and traceable to calibrated instrumentation.",
      "rationale": "FDA benchmark experimental conditions are well-documented for flow rate and rotational speed. Blood analog fluid viscosity was measured but temperature was not continuously monitored during hemolysis runs; this gap reduces traceability of fluid property uncertainty, achieving level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty Uval) must be computed for all 5 operating points; systematic bias must be assessed.",
      "rationale": "E% computed at all 5 operating points (range 4–18%). Validation uncertainty Uval computed but experimental uncertainty in NIH measurement is large (±15% at 95% CI), limiting confidence in bias characterisation. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (NIH) must be directly the same quantity used in the regulatory decision; no surrogate QoIs permitted at MRL 5.",
      "rationale": "Validation uses NIH as QoI, which is the same metric used in the regulatory submission. However, the clinical decision threshold is expressed as a patient-level plasma free haemoglobin concentration, requiring a conversion step not validated in this study. This indirect mapping reduces achieved level to 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the full COU operating envelope (all 5 flow-speed combinations) with geometry identical to the submission device.",
      "rationale": "Validation performed on FDA generic pump geometry, not the submission device geometry. Operating points span 3 of 5 COU conditions; two high-speed low-flow conditions have no experimental counterpart. Geometric and operating-condition gaps reduce achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual below 1e-6 for all equations; time-step sensitivity study for transient rotor-stator interaction must be documented.",
      "rationale": "Steady-state MRF simulations converge to 1e-5 residuals; transient sliding-mesh simulations used for hemolysis integration show residuals of 1e-4 for energy equation at peak impeller loading. No time-step sensitivity study was performed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent simulation replication by a second analyst; documented boundary condition setup review.",
      "rationale": "Boundary conditions reviewed by a second team member but full independent replication was not performed. Setup checklist exists but is not formally controlled. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model must be justified against literature for the specific flow regime; model-form uncertainty must be quantified.",
      "rationale": "k-omega SST turbulence model selected based on literature precedent for pump flows. Giersiepen-Wurzinger hemolysis power-law model used; known to overpredict at low shear stress. Model-form uncertainty not formally quantified. Achieved level 2 against required level 5 — largest credibility gap in the assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs must have documented uncertainty bounds; sensitivity analysis must identify dominant inputs.",
      "rationale": "Monte Carlo UQ performed on hemolysis model coefficients and inlet velocity profile. Blood density and viscosity treated as deterministic; literature range for viscosity at 37°C is ±8% and was not propagated. Sensitivity analysis identifies power-law exponent alpha as dominant. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog samples must be characterised for haematocrit, viscosity, and erythrocyte fragility; lot-to-lot variability must be reported.",
      "rationale": "FDA benchmark dataset does not report haematocrit or erythrocyte fragility for the blood analog used. Lot-to-lot variability data unavailable. This epistemic gap prevents assessment above level 2 and is flagged as a primary uncertainty source at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Geometric, operational, and fluid-property equivalency between validation experiment and COU must be formally demonstrated using similarity parameters.",
      "rationale": "Formal equivalency analysis between FDA generic pump geometry and submission device geometry has not been performed. Impeller diameter differs by 12%; dimensional similarity not established. This gap is critical at MRL 5 where the validation domain must closely match the COU. Achieved level 2."
