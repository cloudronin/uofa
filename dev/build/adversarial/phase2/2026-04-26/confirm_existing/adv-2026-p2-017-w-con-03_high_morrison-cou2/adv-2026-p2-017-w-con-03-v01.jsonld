  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under formal version control with documented test suite covering hemolysis-relevant flow regimes; all solver changes must pass regression tests before use in regulatory submissions.",
      "rationale": "The CFD solver (OpenFOAM v9) is under git version control with a documented regression test suite. However, the hemolysis post-processing module lacks formal V&V traceability to the solver version used, leaving a gap between required level 4 and achieved level 3. SQA plan is partially complete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must confirm second-order spatial accuracy for all transport equations used in the hemolysis workflow.",
      "rationale": "MMS studies confirm second-order accuracy for the Navier-Stokes solver on structured grids. The scalar hemolysis transport equation achieves only first-order accuracy on the unstructured pump geometry due to non-orthogonality corrections, limiting the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; GCI on hemolysis QoI must be below 5%.",
      "rationale": "GCI computed on three meshes (4M, 12M, 32M cells). GCI on bulk NIH is 6.2%, exceeding the 5% threshold. Near-impeller blade passages show local GCI values up to 14% due to geometric complexity. Achieved level 3 reflects partial but insufficient convergence evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rates, rotational speeds, fluid temperature, hematocrit) must be matched to within ±2% of nominal COU operating conditions.",
      "rationale": "Benchtop tests used bovine blood with hematocrit 33±2% versus clinical target of 40%; temperature controlled to 37±0.5°C matching COU. Flow rate matching is within ±1.5%. Hematocrit deviation introduces a systematic uncertainty not fully captured in the UQ, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or MAPE) must be computed with uncertainty bounds; metric must be below 15% for primary hemolysis QoI.",
      "rationale": "Mean absolute percentage error on NIH across 5 operating points is 18%, exceeding the 15% threshold. One outlier operating point (6 L/min, 3500 RPM) contributes disproportionately. Without that point MAPE is 12%. Achieved level 3 reflects borderline compliance with partial coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (NIH) must be directly mapped to the regulatory acceptance criterion (absolute hemolysis threshold); no surrogate QoIs accepted without documented equivalency.",
      "rationale": "NIH is the primary regulatory QoI and is directly compared to the clinical threshold. However, the power-law hemolysis model outputs a modified index of haemolysis (MIH) that requires a conversion factor to NIH; the conversion uncertainty is not fully propagated, reducing relevance confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be performed on the same device geometry and at COU-representative operating conditions; use of surrogate geometries requires documented similarity analysis.",
      "rationale": "Validation used the FDA generic centrifugal pump, which is a surrogate for the proprietary VAD geometry. A geometric similarity analysis documents key hydraulic diameter and impeller tip speed ratios, but secondary flow structures differ. Achieved level 2 reflects significant geometric extrapolation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to solver tolerance below 1e-6 for all equations; floating-point round-off and iterative residual contributions to QoI uncertainty must be estimated.",
      "rationale": "Iterative residuals were monitored but not formally documented against a tolerance criterion for the hemolysis scalar transport equation. Round-off error contribution was not estimated. Factor flagged as epistemic gap at MRL 5; achieved level 1 by default."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal use-error analysis must document all analyst-controlled inputs and boundary condition choices; sensitivity of QoI to those choices must be quantified.",
      "rationale": "No formal use-error analysis was performed. Analyst choices (turbulence model constants, near-wall treatment, hemolysis model exponents) were not systematically varied. Flagged as epistemic gap; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence closure and hemolysis constitutive model must be justified with reference to published benchmark comparisons at relevant Reynolds and Stokes numbers; alternative model forms must be evaluated.",
      "rationale": "k-omega SST turbulence model and power-law hemolysis model were selected based on prior literature but no formal model-form uncertainty quantification was performed. Alternative closures (e.g., RSM, LES) were not evaluated. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterised with probability distributions; Monte Carlo or equivalent propagation must cover all first-order sensitive inputs.",
      "rationale": "Monte Carlo UQ was performed covering inlet velocity, viscosity, and hemolysis model coefficients. Geometric uncertainty (manufacturing tolerances on impeller blade angle) was not included despite being identified as a first-order sensitive input in a prior sensitivity study. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterisation of experimental test samples (blood lot variability, device-to-device geometric variability) must be documented and propagated into validation uncertainty.",
      "rationale": "Only one blood lot and one physical pump specimen were used for benchtop validation. Inter-lot and device-to-device variability were not characterised. Flagged as epistemic gap; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal parameter equivalency matrix must map each experimental input parameter to its COU counterpart; discrepancies must be quantified and their impact on QoI estimated.",
      "rationale": "No formal equivalency matrix was produced. Hematocrit, blood viscosity model, and rotational speed ranges differ between validation experiment and COU without documented impact quantification. Flagged as epistemic gap at MRL 5."
