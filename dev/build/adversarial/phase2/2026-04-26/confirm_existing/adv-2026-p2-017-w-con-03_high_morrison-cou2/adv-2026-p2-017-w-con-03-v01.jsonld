    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/pump-piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic pump",
      "description": "Quantitative comparison of CFD-predicted velocity magnitude fields against particle image velocimetry (PIV) measurements at three impeller speeds (2500, 3000, 3500 RPM) and two flow rates (4 and 6 L/min). GCI-corrected CFD results show mean absolute error of 8.3% relative to PIV ensemble. Validation activity predates package signature.",
      "evidenceTimestamp": "2026-02-28T09:15:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-benchtop",
      "type": "ValidationResult",
      "name": "Normalised index of haemolysis (NIH) benchtop comparison",
      "description": "Comparison of CFD-predicted normalised index of haemolysis (NIH) against in-vitro benchtop measurements across 5 operating points. Power-law hemolysis model coefficients were calibrated on an independent dataset; this validation uses held-out test points. Predicted NIH values fall within ±18% of measured values for 4 of 5 operating points. Final tabulation and sign-off completed shortly after package signing during post-processing reconciliation.",
      "evidenceTimestamp": "2026-03-14T11:09:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-hemolysis",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "1024-sample Monte Carlo propagation of inlet boundary condition uncertainty, fluid viscosity uncertainty, and hemolysis model coefficient uncertainty through the CFD hemolysis workflow. 95th-percentile NIH prediction remains below clinical threshold of 0.1 g/100 L across all 5 operating points. Results archived prior to package signature.",
      "evidenceTimestamp": "2026-03-10T14:45:00Z"
    }
