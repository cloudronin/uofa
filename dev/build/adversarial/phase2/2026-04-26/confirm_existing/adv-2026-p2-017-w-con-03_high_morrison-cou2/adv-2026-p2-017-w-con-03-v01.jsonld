  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors for the VAD hemolysis CFD model at Model Risk Level 5. Seven factors were formally assessed; all show achieved levels below required levels, reflecting the high stringency of MRL 5. Six factors remain as epistemic gaps. Despite these gaps, the Monte Carlo UQ demonstrates that the 95th-percentile NIH prediction remains below the clinical threshold with margin, and the PIV velocity validation provides sufficient confidence in the flow field prediction for regulatory submission at this stage. The team accepts the package with the understanding that identified gaps must be resolved prior to final device clearance submission.",
    "decidedAt": "2026-03-14T10:22:00Z"
