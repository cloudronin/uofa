  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps relative to MRL 5 requirements, the assessment team accepted the package on the basis that Monte Carlo UQ bounds the primary hemolysis QoI within a conservative safety margin of 2.3× the clinical threshold, and that the systematic over-prediction direction is conservative (protective for patient safety). Remaining gaps in model-form uncertainty and equivalency of input parameters are acknowledged as open items for the next design iteration. The package is accepted with conditions: (1) model-form sensitivity study must be completed prior to IDE submission, (2) triplicate experimental replication must be obtained for the missing operating point.",
