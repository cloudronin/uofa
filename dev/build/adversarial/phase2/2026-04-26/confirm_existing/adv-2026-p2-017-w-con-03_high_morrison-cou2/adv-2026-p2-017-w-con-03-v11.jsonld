  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression testing and configuration management compliant with FDA software guidance for Class III devices.",
      "rationale": "Commercial CFD solver (ANSYS Fluent 2022R2) has published verification test suite and ISO 9001 quality management documentation. However, hemolysis sub-model (power-law Giersiepen formulation) lacks independent regression test suite within the solver framework. Achieved level 3 against required level 4 for MRL 5 Class III application."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent formal verification demonstrating solver correctly implements governing equations for rotating-frame turbulent flow with scalar transport.",
      "rationale": "Solver vendor provides MMS verification for incompressible Navier-Stokes in rotating reference frames. Scalar transport equation used for hemolysis accumulation has not been independently verified via MMS in the rotating-frame configuration. Gap identified; achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization error estimate below 5% for hemolysis QoI at all operating conditions; Richardson extrapolation applied to finest two meshes.",
      "rationale": "Three-mesh GCI study completed. GCI values range 2.8–4.1% across five operating conditions. Richardson extrapolation confirms asymptotic convergence. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol, pump priming procedure) must be documented and match COU operating envelope within stated tolerances.",
      "rationale": "FDA benchmark experimental dataset documents fluid temperature (37±0.5°C) and hematocrit (33±2%). Anticoagulant protocol (heparin concentration) is reported as nominal without lot-to-lot variability data. Priming procedure not fully documented for two of five operating conditions. Achieved level 3 against required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., MAPE, E_rms) with uncertainty bands applied to NIH predictions versus experimental measurements; metric threshold pre-specified before comparison.",
      "rationale": "MAPE of 18.7% computed across five operating conditions. Pre-specified acceptance threshold was 15% MAPE; threshold not met. Uncertainty bands overlap at all conditions but systematic over-prediction of 12–22% observed at high-speed low-flow conditions. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear stress exposure integral) must be identical to QoIs used in the COU regulatory submission. No surrogate QoIs permitted at MRL 5.",
      "rationale": "Validation QoI is NIH, which matches the COU submission QoI directly. Shear stress exposure integral is used as a secondary diagnostic but not as the primary regulatory QoI. Minor gap: validation dataset reports NIH via modified ASTM F1841 protocol while COU submission references ISO 10993-4 equivalence; cross-standard mapping documented but not independently audited. Achieved level 4 against required 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry (FDA generic centrifugal pump) at operating conditions spanning the full COU envelope; blood analogue fluid properties must match human blood within documented tolerances.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry — geometry match confirmed. Operating conditions cover 4 of 5 COU flow-speed combinations; the highest-speed condition (6 L/min, 3600 RPM) was not included in the validation dataset. Blood analogue (glycerol-water) viscosity matched at 37°C but non-Newtonian shear-thinning behaviour not replicated. Significant gap at MRL 5; achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-5 for all equations; mass imbalance below 0.01%; torque monitor convergence within 0.5% over final 500 iterations.",
      "rationale": "Continuity and momentum residuals converge to 1e-5. Scalar transport residual for hemolysis accumulation stalls at 8e-5 for two operating conditions at high rotational speed, indicating marginal iterative convergence. Mass imbalance 0.008% — within tolerance. Torque convergence met. Iterative convergence shortfall for hemolysis scalar reduces achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of boundary condition setup, material property assignment, and post-processing scripts for NIH calculation.",
      "rationale": "Simulation workflow documented in internal technical report. Independent peer review conducted by one engineer; FDA guidance for Class III at MRL 5 recommends two independent reviewers. Post-processing NIH integration script reviewed once; no automated regression test. Achieved level 2 against required 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison to DNS or high-fidelity LES data for rotating pump flow; hemolysis power-law model coefficients sourced from species-matched (human erythrocyte) calibration data.",
      "rationale": "SST k-omega turbulence model selected; justification cites published pump validation literature but no direct LES comparison for this geometry. Power-law hemolysis coefficients (Giersiepen 1990) derived from bovine blood; human erythrocyte fragility correction factor applied as scalar multiplier (0.87) without independent experimental validation of the correction. Model form uncertainty is the dominant epistemic gap. Achieved level 2 against required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters (geometry tolerances, fluid properties, boundary conditions) characterized with probability distributions and propagated through Monte Carlo UQ; sensitivity indices reported.",
      "rationale": "Monte Carlo UQ performed for four input parameters (viscosity, rotational speed, flow rate, hemolysis model coefficients). Pump impeller geometry manufacturing tolerances not included in UQ; surface roughness distribution not characterized. Inlet velocity profile assumed fully developed; in-vivo cannula geometry effects not modelled. Significant input characterization gaps remain at MRL 5. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental validation dataset must include minimum three pump units from different manufacturing lots; inter-unit variability characterised and included in validation uncertainty budget.",
      "rationale": "FDA benchmark dataset uses a single pump unit fabricated to nominal dimensions. No inter-unit variability data available. Manufacturing lot variability in impeller geometry not characterised. This is an epistemic gap flagged at MRL 5; no data exists to elevate above level 1. Factor not assessed beyond gap identification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that simulation input parameters (boundary conditions, fluid properties, geometry) in the validation activity are equivalent or conservative relative to COU operating conditions.",
      "rationale": "Formal equivalency mapping between validation experiment inputs and COU inputs not performed. Blood analogue fluid used in validation has documented viscosity match but haematocrit-dependent shear thinning not replicated. No equivalency argument constructed. Epistemic gap at MRL 5; achieved level 1."
    }
