      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to reproduce boundary conditions in the CFD model.",
      "rationale": "FDA benchmark experimental data includes documented inlet flow rates (2–7 L/min), rotational speeds (2000–3500 RPM), fluid properties (glycerol-water blood analog), and temperature. Boundary conditions faithfully reproduced in simulation. MRL 2 standard met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of CFD-predicted hemolysis against experimental measurements with documented error metrics.",
      "rationale": "NIH predictions compared against FDA interlaboratory study experimental data across 5 operating conditions. Mean relative error of 18% observed, consistent with inter-lab variability of 22%. RH index below 1.0 for all worst-case conditions. Required level 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation activity must directly correspond to clinical decision QoIs (relative hemolysis index).",
      "rationale": "NIH and relative hemolysis index (RH) are the primary QoIs in both validation and clinical decision contexts. Power-law hemolysis model outputs are directly mapped to RH < 1 acceptance criterion used for 510(k) comparison. Full relevance at gradation 2 confirmed."
