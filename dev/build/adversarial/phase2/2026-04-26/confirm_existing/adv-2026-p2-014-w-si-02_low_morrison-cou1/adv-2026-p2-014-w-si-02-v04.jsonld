      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification evidence from solver developer or independent benchmarks demonstrating correct implementation of governing equations at MRL 2.",
      "rationale": "ANSYS Fluent code verification evidence provided through developer-published benchmark suite for incompressible Navier-Stokes equations. Taylor-Green vortex and lid-driven cavity solutions confirm spatial and temporal accuracy. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study demonstrating discretization error below 5% for hemolysis index QoI at MRL 2.",
      "rationale": "Three-level mesh refinement study conducted on FDA generic centrifugal pump geometry. GCI analysis shows discretization error of 3.2% for normalized index of hemolysis (NIH) at the nominal operating point. Richardson extrapolation confirms asymptotic convergence. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
