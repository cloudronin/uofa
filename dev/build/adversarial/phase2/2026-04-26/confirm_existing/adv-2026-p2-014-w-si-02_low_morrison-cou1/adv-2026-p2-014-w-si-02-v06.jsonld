      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used in the simulation is documented, version-controlled, and validated for cardiovascular CFD applications.",
      "rationale": "ANSYS Fluent 2022 R2 is employed under a quality management system that includes version control, regression testing, and documented release notes. All CFD scripts are stored in a version-controlled repository with change logs reviewed by a qualified engineer."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver correctness is confirmed through benchmark cases with known analytical solutions.",
      "rationale": "The solver has been verified against the Taylor-Green vortex benchmark and Poiseuille flow in a circular pipe, demonstrating second-order spatial convergence consistent with the theoretical order of the discretisation scheme."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the hemolysis index quantity of interest is below 5%.",
      "rationale": "A three-level mesh refinement study was performed on the impeller and volute domains. GCI values for the normalised hemolysis index ranged from 1.8% to 3.4%, all within the 5% acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions replicate the five target flow-speed operating points within stated tolerances.",
      "rationale": "Bench tests were conducted at 3 L/min / 3000 RPM, 4 L/min / 3500 RPM, 5 L/min / 4000 RPM, 4 L/min / 4500 RPM, and 3 L/min / 5000 RPM. Flow rate uncertainty was ±0.05 L/min and rotational speed uncertainty was ±10 RPM, both within protocol tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalised index of hemolysis (NIH) agrees with experimental measurements within 15% at all five operating points.",
      "rationale": "Predicted NIH values deviated from experimental measurements by 4.2% to 11.7% across the five operating points, with all deviations within the 15% acceptance criterion. The model consistently over-predicted NIH at high-speed low-flow conditions, a conservative bias for worst-case identification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (relative hemolysis index RH) is directly linked to the clinical endpoint of pump-induced haemolysis.",
      "rationale": "The relative hemolysis index RH is computed as the ratio of device NIH to predicate NIH, directly quantifying the comparative haemolytic potential relevant to the 510(k) substantial equivalence determination."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, blood analogue fluid, and operating envelope as the COU.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry with a 36% glycerol-water blood analogue at 37 °C, matching the COU operating envelope. The five validated operating points span the full range of the intended clinical use envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
