  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented test suite results demonstrating correct implementation of governing equations.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional SQA plan. Version-controlled solver with regression test suite covering rotating machinery cases. All SQA checks passed for MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation via manufactured solution or benchmark problem comparison with documented error norms.",
      "rationale": "Code verification performed against Taylor-Couette flow and lid-driven cavity benchmarks. L2 error norms consistent with expected second-order spatial accuracy. Documented in solver verification report VVR-2022-04."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with at least three mesh refinement levels; GCI < 5% for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study performed (coarse: 2.1M, medium: 5.8M, fine: 14.2M cells). Richardson extrapolation yielded GCI of 2.3% for hemolysis index. Fine mesh selected for production runs. Exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must bracket the CFD boundary conditions within ±10% for flow rate and rotational speed.",
      "rationale": "FDA experimental data collected at 2500 and 3500 RPM across flow rates of 2.5, 5.0, and 7.5 L/min. CFD boundary conditions derived directly from experimental measurements. All five operating points within ±5% of experimental conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±20% across all five operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) compared against published FDA experimental data. Agreement within 15% at all five operating points. Relative hemolysis index RH < 1.0 confirmed for all CPB operating conditions, satisfying acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs computed in simulation must directly correspond to the clinical and regulatory decision metrics for hemolysis assessment.",
      "rationale": "Primary QoI is normalized index of hemolysis (NIH) and relative hemolysis index (RH). Both are standard FDA-accepted metrics for blood pump hemolysis evaluation. Direct correspondence to the COU decision criterion RH < 1 confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow conditions, and fluid properties sufficiently similar to the CPB COU to support extrapolation of credibility.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump, which is the same device geometry as the COU device. Blood analog fluid (glycerol-water mixture) used in experiments with matched viscosity and density. Operating conditions span the CPB clinical range."
    },
    {
