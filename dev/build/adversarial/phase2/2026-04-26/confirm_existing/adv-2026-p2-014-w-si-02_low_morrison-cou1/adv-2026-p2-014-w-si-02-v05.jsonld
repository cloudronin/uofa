      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark comparison demonstrating solver correctly implements governing equations to within expected numerical precision.",
      "rationale": "Code verification performed using the FDA benchmark nozzle case. Velocity profiles and pressure drop match published benchmark results within 2%, confirming correct implementation of the Navier-Stokes solver and scalar transport for hemolysis index."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis showing discretization error below 5% for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study conducted on the FDA generic centrifugal pump. Grid Convergence Index (GCI) for the relative hemolysis index was 3.1% on the medium mesh selected for production runs. Fine mesh used for sensitivity confirmation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid properties) match simulation inputs within stated uncertainty bounds.",
      "rationale": "Experimental test conditions from the FDA interlaboratory study were replicated in CFD boundary conditions. Inlet flow rates of 2.5 and 5.0 L/min at 2500 and 3500 RPM confirmed. Blood analog fluid properties matched to within 3% viscosity tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index within factor of 2 of experimental measurements across all 5 operating points; RH < 1 for all nominal conditions.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) values compared against experimental measurements at all 5 flow-speed combinations. Mean ratio of predicted to measured NIH was 1.18 across operating points. RH < 1 criterion satisfied at all nominal conditions, confirming model acceptability for the intended COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, RH index, shear stress distribution) are directly linked to the clinical hemolysis decision endpoint.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) and the derived relative hemolysis index (RH). Both are standard FDA-accepted metrics for pump hemolysis assessment and directly map to the clinical decision of whether the device exceeds predicate hemolysis levels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
