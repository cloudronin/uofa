  "signature": "ed25519:9b2e4f1a7c3d5e8b0f2a4c6e8d1b3f5a7c9e2d4f6b8a0c2e4d6f8b1a3c5e7d9f",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must demonstrate documented version control, regression testing, and traceable build records consistent with MRL 2 requirements.",
      "rationale": "The ANSYS Fluent v19.2 solver used in this study has documented software quality assurance records including version control logs, regression test suites, and release validation reports. All SQA documentation meets the Gradation 2 threshold for MRL 2 assessments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark verification cases (e.g., lid-driven cavity, Poiseuille flow) demonstrating correct numerical implementation at MRL 2.",
      "rationale": "ANSYS Fluent code verification is documented through manufacturer-supplied benchmark results for canonical flow problems. Order-of-accuracy studies confirm second-order spatial convergence for the finite-volume discretization employed in the CPB pump model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate discretization error below 5% for primary quantities of interest (velocity magnitude, wall shear stress) using at least three systematically refined meshes.",
      "rationale": "A three-level mesh refinement study was conducted using coarse (2.1M), medium (5.8M), and fine (14.3M) element meshes. Richardson extrapolation yielded a grid convergence index (GCI) of 1.8% for mean velocity and 3.2% for peak wall shear stress, both within acceptance bounds. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to reproduce boundary conditions in the CFD model, including fluid properties, flow rates, and rotational speed.",
      "rationale": "FDA benchmark experimental conditions are fully documented in the published dataset (Hariharan et al. 2011). Fluid viscosity, density, inlet flow rates (2.5, 3.5, 4.5, 5.5, 6.0 L/min), and impeller speed (2500, 3500 RPM) are all reproduced in the CFD boundary conditions within measurement uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, validation metric) must be computed between CFD predictions and experimental measurements for primary QoIs.",
      "rationale": "Velocity field comparisons against PIV data yielded normalized RMS errors of 8.4% and 11.2% at 2500 and 3500 RPM respectively, consistent with published inter-laboratory variability for this benchmark. Relative hemolysis index predictions fell within the experimental scatter band for all 5 operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (velocity, shear stress, hemolysis index) must be directly traceable to the clinical decision metric (relative hemolysis index RH).",
      "rationale": "The primary QoI — relative hemolysis index (RH) computed from the power-law hemolysis model — is directly linked to the clinical acceptance criterion (RH < 1). Intermediate QoIs (velocity magnitude, Reynolds shear stress) are mechanistically connected to hemolysis through the Giersiepen-Wurzinger power-law model, establishing clear relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the COU operating envelope (flow rates, rotational speeds, fluid properties) to support extrapolation of credibility to the intended use.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry under flow and speed conditions spanning the CPB operating envelope. The validation domain overlaps with the COU operating range for all 5 flow-speed combinations assessed, supporting direct applicability of validation evidence to the intended regulatory submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal iterative convergence monitoring to tight tolerances is sufficient; full solver error quantification is not required.",
      "rationale": "Iterative convergence was monitored through residual reduction to 1e-5 for all transport equations and confirmed through mass balance checks. Formal solver error quantification beyond residual monitoring is not required at MRL 2 and was not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documented analyst training and peer review of simulation setup is sufficient to address use error.",
      "rationale": "All CFD analysts hold relevant graduate-level training in computational fluid dynamics. Simulation setup was independently reviewed by a second qualified analyst prior to production runs. Formal use error quantification is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty assessment through comparison of turbulence model variants is not required; selection of a validated turbulence model with documented applicability is sufficient.",
      "rationale": "The SST k-omega turbulence model was selected based on published literature demonstrating applicability to rotating machinery flows in the relevant Reynolds number regime. Formal model form uncertainty quantification across multiple turbulence model variants is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are sufficient; full uncertainty propagation through input parameters is not required.",
      "rationale": "All model inputs (fluid density 1056 kg/m3, dynamic viscosity 3.5 mPa·s, pump geometry from FDA benchmark) are sourced from published references with documented traceability. Formal input uncertainty propagation is not required at MRL 2 and was scoped out of this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, use of a single well-characterized benchmark device geometry is acceptable; multi-sample statistical characterization is not required.",
      "rationale": "Validation was conducted using the single FDA generic centrifugal pump geometry, which is a well-characterized benchmark with published dimensional tolerances. Statistical characterization across multiple pump samples is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative confirmation that validation and COU input parameter ranges overlap is sufficient.",
      "rationale": "The validation operating conditions (flow rates 2.5–6.0 L/min, speeds 2500–3500 RPM) encompass the intended COU operating envelope. Quantitative equivalency mapping is not required at MRL 2; qualitative overlap has been confirmed by the assessment team."
    }
