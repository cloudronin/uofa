      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented and met; no divergence or spurious oscillations observed across all load steps.",
      "rationale": "Force and displacement residuals converged to 1e-4 relative tolerance in all 11 simulation runs; no non-convergence events were logged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of boundary condition setup, material assignments, and load application by a second qualified analyst.",
      "rationale": "Simulation setup was performed by a single analyst with no independent review of boundary conditions or material assignments. No formal simulation workflow document was produced; setup was reconstructed post-hoc from analyst notes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model captures elastic-plastic titanium alloy behavior; contact formulation appropriate for screw-rod interface; geometric nonlinearity enabled.",
      "rationale": "Bilinear isotropic hardening (Ti-6Al-4V, E=114 GPa, σ_y=880 MPa, E_t=1.14 GPa) was used; augmented Lagrange contact at screw-rod interface; NLGEOM enabled. Model form is well-established for this class of implant simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometry sourced from traceable measurements; uncertainty in inputs quantified and propagated.",
      "rationale": "Titanium alloy material properties were taken from ASTM F136 certificate of conformance for the production lot; screw geometry was measured via CMM on three production parts. Input uncertainty was propagated via Monte Carlo (N=500) confirming QoI sensitivity within bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 specimens; specimens traceable to production lot; dimensional verification reported.",
      "rationale": "N=11 constructs tested across two independent laboratories; all specimens from the same production lot with dimensional verification by CMM confirming conformance to design drawings."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple loading conditions or parametric variation of test parameters to characterize model behavior across the COU envelope; environmental conditions controlled and documented.",
      "rationale": "Testing was conducted at a single loading rate (5 mm/min) under ambient conditions only; no variation in rod diameter, screw angulation, or block spacing was explored. Environmental conditions were documented but the single test condition limits coverage of the COU envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs match experimental conditions to within measurement uncertainty; any discrepancies documented with sensitivity analysis.",
      "rationale": "Boundary conditions in the FEA replicate the ASTM F1717 fixture geometry; loading rate effects were assessed via quasi-static assumption validation. All discrepancies between nominal and measured specimen dimensions were within CMM uncertainty bands."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all QoIs; E/uval < 1.96 for acceptance.",
      "rationale": "E/uval computed for stiffness (0.84), yield force (1.21), and force at 40 mm (1.07); all below the 1.96 threshold. Percent differences were 4.2%, 6.8%, and 5.1%, all within the 10% acceptance bound."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to the clinical and regulatory decision quantities; linkage to failure modes documented.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly inform the regulatory submission claims regarding structural integrity under physiological loading."
    },
