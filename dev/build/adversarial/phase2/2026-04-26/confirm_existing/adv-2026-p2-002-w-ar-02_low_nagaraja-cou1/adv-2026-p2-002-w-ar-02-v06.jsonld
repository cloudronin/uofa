      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study with at least three mesh densities; reported GCI < 5% for all QoIs.",
      "rationale": "A three-level mesh refinement study was conducted; GCI values for stiffness, yield force, and force at 40 mm were 1.8%, 2.3%, and 2.1% respectively, all below the 5% threshold."
