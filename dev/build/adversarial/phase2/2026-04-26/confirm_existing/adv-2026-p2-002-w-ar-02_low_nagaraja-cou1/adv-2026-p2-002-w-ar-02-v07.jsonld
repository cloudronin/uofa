    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change less than 5% between successive refinements.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw geometry; stiffness QoI varied by less than 2.1% between medium and fine meshes, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence tolerances must be documented and shown to be below 1e-5 for all load steps.",
      "rationale": "Force and displacement residuals were monitored across all load steps; maximum residual was 8.3e-7, well below the 1e-5 threshold. Solver settings are documented in the simulation record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented peer review of model setup, boundary conditions, and loading must be completed by an independent analyst at Gradation 3 or above.",
      "rationale": "No independent peer review of the model setup was conducted. The analyst who built the model also performed the comparison to experimental data. No checklist or second-analyst verification is on record, yielding Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model and contact formulation must be justified relative to the expected deformation regime and validated against analogous published studies.",
      "rationale": "Linear elastic material model with bilinear isotropic hardening for the titanium alloy is consistent with the small-strain regime observed in the F1717 test. Augmented Lagrange contact was selected and justified by prior FDA validation work on similar implant geometries."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions must be sourced from measurements on the tested lot with documented uncertainty.",
      "rationale": "Titanium alloy elastic modulus and yield strength were taken from coupon tests on the same material lot as the pedicle screws. UHMWPE block properties were measured per ISO 5834. Dimensional inputs were derived from CMM measurements of representative hardware."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens must be production-representative hardware from the same design revision, with traceability documented.",
      "rationale": "N=11 constructs were assembled from production-representative 7.5 mm non-cannulated pedicle screws and UHMWPE test blocks. Lot traceability and dimensional inspection records confirm design revision equivalence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing must span the range of clinically relevant loading conditions at Gradation 3 or above; multiple load angles and magnitudes are required.",
      "rationale": "Only a single test condition (6-degree offset, quasi-static compression-bending per ASTM F1717) was evaluated. No variation in load angle, rate, or environmental condition was included. This single-condition coverage corresponds to Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs must be shown to match experimental conditions within documented tolerances for all QoI-driving parameters.",
      "rationale": "Applied displacement profile, fixture geometry, and material assignments in the FEA were reconciled against the experimental test protocol. Differences in boundary representation were quantified and shown to contribute less than 1.5% to QoI predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) must be below 1.96 for all QoIs, with statistical uncertainty in experimental data accounted for.",
      "rationale": "E/uval values were 0.84 (stiffness), 1.12 (yield force), and 0.97 (force at 40 mm), all below the 1.96 threshold. Experimental variability (CV < 8%) was incorporated into the validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must directly correspond to the QoIs relevant to the intended COU decision.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the COU and are the same QoIs measured in the F1717 bench test, ensuring direct correspondence."
