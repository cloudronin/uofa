  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). This model has been applied in clinical research settings to support pre-market submissions for Class II cardiac assist devices, informing pump design decisions across multiple investigational studies.",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-mrl2-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-001",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd-001",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset-001",
    "https://uofa.net/synth/data/fda-pump-cfd-mesh-dataset-001"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison-001",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-head-flow-curve-001",
      "type": "ValidationResult",
      "name": "Pressure-head versus flow curve validation at nominal CPB conditions"
    }
  ],
