  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors were appropriately scoped as not-assessed consistent with MRL 2 requirements. The CFD hemolysis model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device. This model has been applied in clinical research settings and the simulation outputs are considered fit for the intended regulatory submission purpose.",
