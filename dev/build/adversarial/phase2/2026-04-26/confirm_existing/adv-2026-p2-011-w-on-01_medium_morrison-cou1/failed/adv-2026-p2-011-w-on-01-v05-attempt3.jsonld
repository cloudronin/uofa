  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan with version control and regression testing.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a documented QA plan including version control, regression test suite, and change management log. All QA requirements for MRL 2 are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method of manufactured solutions or benchmark problems.",
      "rationale": "Benchmark verification against ASME V&V 20 pipe flow and lid-driven cavity cases confirmed correct solver implementation. Observed order of accuracy matches theoretical order for the second-order scheme employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary quantity of interest with GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed on the GCBP geometry (coarse 4.2M, medium 8.7M, fine 17.1M cells). GCI for hemolysis index was 2.8%, well within the 5% threshold. Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable, including flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA GCBP experimental conditions are fully documented in the published protocol (Hariharan et al. 2011). Flow rates (2.5–7 L/min) and rotational speeds (2000–3500 RPM) are replicated in simulation boundary conditions with traceable uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared quantitatively to experimental measurements using appropriate error metrics.",
      "rationale": "Hemolysis index predictions compared against experimental data across 6 operating points. Mean absolute relative error of 8.3% observed, consistent with inter-laboratory experimental variability. Velocity field comparison via PIV shows good spatial agreement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated quantities of interest must be directly relevant to the clinical or regulatory decision being supported.",
      "rationale": "Hemolysis index and wall shear stress are the primary QoIs, directly linked to red blood cell damage and the regulatory submission metric for CPB device safety. These QoIs are clinically meaningful and align with FDA guidance on blood-contacting device assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed under conditions sufficiently similar to the intended use environment.",
      "rationale": "Validation was performed using the FDA GCBP geometry and blood-analog fluid at physiologically representative operating conditions. The validation domain overlaps substantially with the intended CPB operating envelope, satisfying relevance requirements at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria must be documented; residual reduction of at least three orders of magnitude required.",
      "rationale": "At MRL 2, numerical solver error beyond basic residual monitoring is not required. Residuals were monitored and confirmed to drop four orders of magnitude; no further formal assessment was scoped."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-induced error in model setup and post-processing must be evaluated.",
      "rationale": "Formal use error analysis is not required at MRL 2. Simulation setup was reviewed by a second analyst; no systematic user errors were identified during internal review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Selection of governing equations and turbulence closure must be justified relative to the flow physics.",
      "rationale": "SST k-omega turbulence model selected based on published literature for rotating blood pump flows. Formal model form uncertainty quantification is not required at MRL 2 but model selection rationale is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of model outputs to input parameter uncertainty must be characterized.",
      "rationale": "Input parameter sensitivity analysis is not required at MRL 2. Blood viscosity and density were assigned nominal values from published sources; uncertainty in these inputs was not formally propagated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Adequacy of experimental sample size and repeatability must be demonstrated.",
      "rationale": "The FDA GCBP dataset provides sufficient experimental replication for MRL 2 purposes. Formal statistical power analysis of test sample adequacy is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between simulation input parameters and experimental conditions must be formally demonstrated.",
      "rationale": "At MRL 2, formal equivalency analysis is not required. Boundary conditions were set to match published experimental values; any residual discrepancies are within accepted engineering tolerance for this risk level."
    }
  ],
