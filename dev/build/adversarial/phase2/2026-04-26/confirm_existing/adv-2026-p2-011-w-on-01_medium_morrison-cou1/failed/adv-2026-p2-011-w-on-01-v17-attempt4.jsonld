  "signature": "ed25519:b4e2d1f3a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, regression testing, and quality management procedures consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated code with documented SQA procedures including version-controlled releases, regression test suites, and ISO 9001-compliant development processes. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against known analytical solutions or benchmark problems relevant to internal rotating flow.",
      "rationale": "Code verification was performed using the method of manufactured solutions for the incompressible Navier-Stokes equations. Results demonstrate second-order spatial convergence consistent with the discretization scheme. Benchmark comparisons with the FDA nozzle problem confirm solver accuracy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be estimated and shown to be acceptable relative to quantities of interest at MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted using Richardson extrapolation. The grid convergence index (GCI) for the hemolysis index was less than 2.1% on the medium mesh, which was selected for production runs. Achieved level exceeds required level, providing additional confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable to the operating envelope of the CPB device.",
      "rationale": "FDA benchmark experimental data were collected under controlled conditions spanning flow rates of 2–8 L/min and rotational speeds of 2000–4000 RPM. Test conditions are documented in the FDA critical path dataset and are traceable to calibrated instrumentation with stated uncertainties."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared to experimental measurements using appropriate metrics that account for experimental uncertainty.",
      "rationale": "Predicted hemolysis index values were compared to experimental measurements using normalized RMS error and validation uncertainty metrics per ASME V&V 20. The model predictions fall within the experimental uncertainty band for 85% of operating points evaluated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest computed by the model must be directly relevant to the clinical and regulatory decision being supported.",
      "rationale": "The primary quantity of interest is the normalized index of hemolysis (NIH), which is the standard metric used in FDA guidance for blood-contacting device evaluation. Secondary QoIs include wall shear stress distribution and scalar stress exposure time, both directly linked to erythrocyte damage mechanisms."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the same physics, geometry, and operating regime as the intended use of the model.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry under CPB-representative flow conditions. The validation scenario shares the same pump topology, blood analog fluid properties, and operating range as the COU, ensuring high relevance of the validation evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off errors should be characterized; not required at MRL 2 for this factor.",
      "rationale": "Per MRL 2 requirements, formal numerical solver error quantification beyond standard convergence monitoring is not required. Residuals were monitored to below 1e-5 for all equations, satisfying the minimum expectation for this factor at the applicable risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Assessment of potential user errors in model setup and execution; not required at MRL 2 for this factor.",
      "rationale": "Formal use error analysis is scoped out at MRL 2 for this factor. Standard operating procedures and peer review of simulation setup were employed to minimize user error risk, consistent with organizational quality practices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of the mathematical model form selected relative to the physics of interest; not required at MRL 2 for this factor.",
      "rationale": "The RANS k-omega SST turbulence model was selected based on published literature for rotating internal flows. Formal model form uncertainty quantification is not required at MRL 2; selection rationale is documented in the modeling report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of uncertainty in model input parameters; not required at MRL 2 for this factor.",
      "rationale": "Input parameters including fluid viscosity, density, and boundary conditions are based on published FDA benchmark values. Formal sensitivity analysis of input uncertainty is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of experimental test sample variability and its impact on validation; not required at MRL 2 for this factor.",
      "rationale": "The FDA benchmark dataset used porcine blood analog with documented preparation protocols. Inter-sample variability characterization is not required at MRL 2 for this factor; the published dataset uncertainty bounds are accepted as-is."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
