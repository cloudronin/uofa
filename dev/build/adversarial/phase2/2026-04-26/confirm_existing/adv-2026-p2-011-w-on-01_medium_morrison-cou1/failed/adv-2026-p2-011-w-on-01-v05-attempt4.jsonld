  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented version control, regression testing suite, and code review records must be present for the CFD solver and hemolysis sub-model.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under version control with a documented regression test suite covering 47 benchmark cases. Code review records for the hemolysis power-law sub-model are archived and meet MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least one manufactured solution or analytical benchmark must demonstrate correct implementation of governing equations at the required spatial order.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver confirms second-order spatial convergence. Hemolysis transport equation verified against an analytical scalar advection benchmark."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary quantity of interest (hemolysis index) across at least three mesh refinement levels.",
      "rationale": "Three mesh levels (3.2 M, 8.7 M, and 22.4 M cells) were evaluated. GCI for the normalised index of hemolysis is 4.1%, below the 5% threshold for MRL 2. The medium mesh (8.7 M) was selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity and density) must be documented with stated measurement uncertainty.",
      "rationale": "FDA pump experimental data were collected at five operating points (3–7 L/min, 2500–3500 RPM) with stated uncertainty of ±2% for flow rate and ±1% for rotational speed. Fluid properties for modified Krebs-Henseleit solution are fully documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) must be computed and shown to fall within experimental uncertainty bands for the primary QoI.",
      "rationale": "Predicted normalised index of hemolysis agrees with experimental measurements within 12% across all five operating points, which falls within the combined experimental and numerical uncertainty envelope at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modelled QoIs must be directly linked to the clinical decision metric (worst-case hemolysis operating point) with documented traceability.",
      "rationale": "The normalised index of hemolysis and scalar shear stress exposure time are directly used to rank operating conditions by hemolytic risk. Traceability to the clinical decision criterion is documented in the assessment plan. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating envelope, and fluid analogue as the intended clinical application.",
      "rationale": "Validation was performed on the identical FDA generic centrifugal pump geometry at operating conditions spanning the CPB clinical range (3–7 L/min). Porcine blood analogue properties match those used in the device submission testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance of 1e-5 for all transport equations is sufficient at MRL 2; formal solver error quantification not required.",
      "rationale": "At MRL 2, iterative convergence monitoring is sufficient. All simulations reached residual levels below 1e-6 for continuity and momentum equations. Formal solver error quantification is scoped out per the MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records are sufficient at MRL 2; formal use-error FMEA not required.",
      "rationale": "Simulation analysts hold documented CFD competency qualifications. Formal use-error failure mode analysis is not required at MRL 2 and is therefore not assessed in this package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented selection rationale for the turbulence closure and hemolysis constitutive model is sufficient at MRL 2.",
      "rationale": "The SST k-omega turbulence model and Giersiepen power-law hemolysis model were selected based on published literature review. Formal model-form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Nominal input values with literature or measurement provenance are sufficient at MRL 2; sensitivity analysis not required.",
      "rationale": "All model input parameters (fluid viscosity, density, hemolysis model constants) are sourced from peer-reviewed literature with stated provenance. Parametric sensitivity analysis is not required at MRL 2 and is not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use of a single well-characterised experimental dataset is acceptable at MRL 2.",
      "rationale": "The FDA interlaboratory study dataset provides a single well-characterised reference. Statistical characterisation of inter-sample variability is not required at MRL 2 and is therefore not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Qualitative confirmation that simulation inputs bracket the clinical operating range is sufficient at MRL 2.",
      "rationale": "Operating conditions used in validation (3–7 L/min, 2500–3500 RPM) bracket the CPB clinical operating envelope. Formal equivalency analysis is not required at MRL 2 and is not assessed."
